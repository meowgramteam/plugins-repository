        except Exception as e:
            log(f"[{__id__}] Failed to add settings menu items: {e}")

    def _socks_create_connection(self, dest_host, dest_port):
        sock = None
        try:
            host, port = self._parse_host_port(self.get_setting("proxy_url_set", "").strip())
            if not host:
                return socket.create_connection((dest_host, dest_port))
            user = self.get_setting("proxy_username_set", "").strip()
            pwd = self.get_setting("proxy_password_set", "").strip()
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(15)
            sock.connect((host, port))
            methods = b"\x02" if user and pwd else b"\x00"
            sock.send(b"\x05\x01" + methods)
            response = sock.recv(2)
            if len(response) < 2 or response[0] != 5:
                raise Exception("Invalid SOCKS5 response")
            if response[1] == 2:
                if not user or not pwd:
                    raise Exception("Username/password required")
                sock.send(b"\x01" + bytes([len(user)]) + user.encode() + bytes([len(pwd)]) + pwd.encode())
                auth = sock.recv(2)
                if len(auth) < 2 or auth[1] != 0:
                    raise Exception("SOCKS5 authentication failed")
            try:
                addr_type, addr_data = b"\x01", socket.inet_aton(dest_host)
            except socket.error:
                addr_type, addr_data = b"\x03", bytes([len(dest_host)]) + dest_host.encode()
            sock.send(b"\x05\x01\x00" + addr_type + addr_data + int(dest_port).to_bytes(2, "big"))
            connect_response = sock.recv(10)
            if len(connect_response) < 4 or connect_response[1] != 0:
                raise Exception("SOCKS5 connect failed")
            return sock
        except Exception as e:
            log(f"[{__id__}] SOCKS proxy error: {e}")
            if sock:
                try:
                    sock.close()
                except Exception:
                    pass
            return socket.create_connection((dest_host, dest_port))

    def _mtproto_create_connection(self, dest_host, dest_port):
        sock = None
        try:
            host, port = self._parse_host_port(self.get_setting("proxy_url_set", "").strip())
            if not host:
                return socket.create_connection((dest_host, dest_port))
            secret = self.get_setting("proxy_username_set", "").strip()
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(15)
            sock.connect((host, port))
            if secret:
                sb = secret.encode("utf-8")
                sock.send(b"\xef\xef\xef\xef" + bytes([len(sb)]) + sb)
                if sock.recv(1) != b"\xef":
                    sock.close()
                    return socket.create_connection((dest_host, dest_port))
            dest_info = f"{dest_host}:{dest_port}".encode("utf-8")
            sock.send(b"\xdd\xdd\xdd\xdd" + bytes([len(dest_info)]) + dest_info)
            if sock.recv(1) != b"\xdd":
                sock.close()
                return socket.create_connection((dest_host, dest_port))
            return sock
        except Exception as e:
            log(f"[{__id__}] MTProto proxy error: {e}")
            if sock:
                try:
                    sock.close()
                except Exception:
                    pass
            return socket.create_connection((dest_host, dest_port))

    def _parse_host_port(self, url_setting):
        if not url_setting or ":" not in url_setting:
            return None, None
        if "://" in url_setting:
            url_setting = url_setting.split("://", 1)[1]
        host, port_str = url_setting.split(":", 1)
        try:
            return host, int(port_str)
        except ValueError:
            return None, None

    def _tcp_ping(self, host, port, timeout=10):
        try:
            sock = socket.create_connection((host, port), timeout)
            sock.close()
            return True
        except Exception:
            return False

    def _test_proxy_connection(self, proxies):
        try:
            if not proxies:
                return True
            return requests.get("http://httpbin.org/ip", proxies=proxies, timeout=10).status_code == 200
        except Exception:
            return False

    def _test_socks_connection(self):
        host, port = self._parse_host_port(self.get_setting("proxy_url_set", "").strip())
        return bool(host) and self._tcp_ping(host, port)

    def _test_mtproto_connection(self):
        host, port = self._parse_host_port(self.get_setting("proxy_url_set", "").strip())
        return bool(host) and self._tcp_ping(host, port)

    def _get_proxies(self):
        try:
            proxy_type = self.get_setting("proxy_type_set", 0)
            url = self.get_setting("proxy_url_set", "").strip()
            user = self.get_setting("proxy_username_set", "").strip()
            pwd = self.get_setting("proxy_password_set", "").strip()
            if not url or proxy_type == 0:
                return None, None
            if proxy_type == 3:
                hostport = url.split("://", 1)[-1] if "://" in url else url
                scheme = f"socks5://{user}:{pwd}@{hostport}" if user and pwd else f"socks5://{hostport}"
                try:
                    import requests_html
                    _ = requests_html
                    return {"http": scheme, "https": scheme}, None
                except ImportError:
                    return None, "socks"
            if proxy_type in (1, 2):
                scheme = "http" if proxy_type == 1 else "https"
                clean_url = url.split("://", 1)[1] if "://" in url else url
                proxy_url = f"{scheme}://{user}:{pwd}@{clean_url}" if user and pwd else f"{scheme}://{clean_url}"
                return {"http": proxy_url, "https": proxy_url}, None
            if proxy_type == 4:
                return None, "mtproto"
            return None, None
        except Exception as e:
            log(f"[{__id__}] Error configuring proxy: {e}")
            return None, None

    def on_plugin_load(self):
        try:
            priority = int(self.get_setting("hook_priority_set", 1))
        except Exception:
            priority = 1
        self.add_on_send_message_hook(priority)
        self._temp_dir = self._get_temp_dir()
        if self._temp_dir:
            log("[downloader] loaded")
            self._cleanup_old_files()
            if self.get_setting("show_settings_buttons_set", True):
                self._add_settings_menu_items()
        else:
            log("[downloader] failed to init temp dir")

    def _get_temp_dir(self):
        try:
            base_dir = ApplicationLoader.getFilesDirFixed()
            if not base_dir:
                return None
            temp_dir = File(base_dir, TEMP_DIR_NAME)
            if not temp_dir.exists() and not temp_dir.mkdirs():
                return None
            return temp_dir
        except Exception as e:
            log(f"[downloader] temp dir error: {e}")
            return None

    def _cleanup_old_files(self, max_age_hours=12):
        try:
            now = time.time()
            max_age = max_age_hours * 3600
            for f in self._temp_dir.listFiles():
                if f.isFile() and now - f.lastModified() / 1000 > max_age:
                    f.delete()
        except Exception as e:
            log(f"[downloader] cleanup error: {e}")

    def _http_post(self, url, proxies=None, patch_type=None, **kwargs):
        headers = kwargs.pop("headers", {}) or {}
        headers.setdefault("User-Agent", USER_AGENT)
        if patch_type:
            with self._proxy_connection_patch(patch_type):
                return requests.post(url, headers=headers, proxies=proxies, **kwargs)
        return requests.post(url, headers=headers, proxies=proxies, **kwargs)

    def _http_get(self, url, proxies=None, patch_type=None, **kwargs):
        headers = kwargs.pop("headers", {}) or {}
        headers.setdefault("User-Agent", USER_AGENT)
        if patch_type:
            with self._proxy_connection_patch(patch_type):
                return requests.get(url, headers=headers, proxies=proxies, **kwargs)
        return requests.get(url, headers=headers, proxies=proxies, **kwargs)

    def _show_premium_limit_dialog(self):
        msg = "Чтобы отправлять файлы больше 2 ГБ, подпишитесь на Telegram Premium." if _is_ru() else "Subscribe to Telegram Premium to send files larger than 2 GB."
        self.show_my_info_alert(title="Telegram Premium", message=msg, neutral_button="Premium", neutral_link="https://t.me/premium", neutral_type="link")

    def _build_payload(self, url, mode_override):
        quality = self.get_setting("video_quality_set", 5)
        video_quality = VIDEO_QUALITY_OPTIONS[quality] if isinstance(quality, int) and 0 <= quality < len(VIDEO_QUALITY_OPTIONS) else str(quality)
        bitrate = self.get_setting("audio_bitrate_set", 5)
        audio_bitrate = AUDIO_BITRATE_OPTIONS[bitrate] if isinstance(bitrate, int) and 0 <= bitrate < len(AUDIO_BITRATE_OPTIONS) else "128"
        low = url.lower()
        if "youtube.com" in low or "youtu.be" in low:
            video_quality = VIDEO_QUALITY_OPTIONS[-1]
            audio_bitrate = AUDIO_BITRATE_OPTIONS[-1]
        payload = {
            "url": url,
            "videoQuality": video_quality,
            "audioBitrate": audio_bitrate,
            "convertGif": True,
            "downloadMode": mode_override or "auto",
            "filenameStyle": "basic",
            "allowH265": True,
            "tiktokFullAudio": True,
        }
        return payload

    def _api_list(self):
        api_idx = self.get_setting("api_url_choice_set", 0)
        custom = self.get_setting("api_url_set", "").strip()
        result = []
        if api_idx < len(COBALT_API):
            result.append(COBALT_API[api_idx].rstrip("/"))
        elif custom:
            result.append(custom.rstrip("/"))
        if self.get_setting("auto_fallback_set", True):
            for i, api in enumerate(COBALT_API):
                if i != api_idx:
                    result.append(api.rstrip("/"))
            if api_idx < len(COBALT_API) and custom:
                result.append(custom.rstrip("/"))
        seen = set()
        out = []
        for a in result:
            if a and a not in seen:
                seen.add(a)
                out.append(a)
        return out

    def _cobalt_resolve(self, api_url, url, payload, headers, proxies, patch_type):
        resp = self._http_post(f"{api_url}/", json=payload, headers=headers, timeout=30, proxies=proxies, patch_type=patch_type)
        resp.raise_for_status()
        data = resp.json()
        status = data.get("status")
        if status == "error":
            code = data.get("error", {}).get("code", "unknown error")
            return None, f"API error: {code}"
        if status == "picker":
            items = []
            for it in data.get("picker", []):
                u = it.get("url")
                if not u:
                    continue
                items.append({"url": u, "filename": it.get("filename"), "type": it.get("type") or "photo"})
            if not items:
                return None, "Empty picker"
            audio = data.get("audio")
            audio_item = {"url": audio, "filename": data.get("audioFilename"), "type": "audio"} if audio else None
            return {"items": items, "audio": audio_item}, None
        if status == "local-processing":
            tunnels = data.get("tunnel") or []
            if not tunnels:
                return None, "Local-processing not supported"
            out = data.get("output") or {}
            return {"items": [{"url": tunnels[0], "filename": out.get("filename"), "type": (out.get("type") or "video")}], "audio": None}, None
        direct = data.get("url")
        if not direct:
            return None, "Invalid API response"
        return {"items": [{"url": direct, "filename": data.get("filename"), "type": data.get("type") or "video"}], "audio": None}, None

    def _resolve(self, url, mode_override):
        api_key = self.get_setting("api_key_set", "").strip()
        proxies, patch_type = self._get_proxies()
        if patch_type == "mtproto" and not self._test_mtproto_connection():
            patch_type = None
        elif patch_type == "socks" and not self._test_socks_connection():
            patch_type = None
        elif proxies and not self._test_proxy_connection(proxies):
            proxies = None
        self._current_proxies = proxies
        self._current_patch_type = patch_type
        payload = self._build_payload(url, mode_override)
        headers = {"Accept": "application/json", "Content-Type": "application/json"}
        if api_key:
            headers["Authorization"] = f"Api-Key {api_key}"
        tried = set()
        state = {"error": None}

        def try_list(api_urls):
            for api_url in api_urls:
                if not api_url or api_url in tried:
                    continue
                tried.add(api_url)
                try:
                    result, error = self._cobalt_resolve(api_url, url, payload, headers, proxies, patch_type)
                    if result:
                        return result
                    state["error"] = error
                except Exception as e:
                    state["error"] = f"{api_url}: {e}"
            return None

        result = try_list(self._api_list())
        if result:
            return result
        if self.get_setting("auto_fallback_set", True):
            result = try_list(self._fetch_cobalt_instances())
            if result:
                return result
        fallback = self._fallback_resolve(url)
        if fallback:
            return fallback
        BulletinHelper.show_error(f"Download failed: {state['error']}")
        return None

    def _fetch_cobalt_instances(self):
        urls = []
        try:
            r = self._http_get(COBALT_INSTANCE_LIST_URL, timeout=15, proxies=self._current_proxies, patch_type=self._current_patch_type)
            r.raise_for_status()
            data = r.json()
            if isinstance(data, dict):
                data = data.get("instances") or []
            scored = []
            for item in data:
                try:
                    online = item.get("online")
                    is_online = bool(online.get("api")) if isinstance(online, dict) else bool(online)
                    if not is_online:
                        continue
                    api_host = item.get("api")
                    if not api_host:
                        continue
                    protocol = item.get("protocol") or "https"
                    base = api_host if str(api_host).startswith("http") else f"{protocol}://{api_host}"
                    scored.append((item.get("score") or 0, base.rstrip("/")))
                except Exception:
                    continue
            scored.sort(key=lambda x: x[0], reverse=True)
            urls = [u for _, u in scored]
        except Exception as e:
            log(f"[downloader] cobalt instance list failed: {e}")
        for extra in COBALT_EXTRA_INSTANCES:
            if extra not in urls:
                urls.append(extra)
        return urls[:MAX_INSTANCES_TRIED]

    def _download_direct_to_temp(self, media_url, ext=".mp4", headers=None):
        if self._cancel_requested:
            return None
        path = File(self._temp_dir, f"media_{uuid.uuid4().hex}{ext}").getAbsolutePath()
        resp = self._http_get(media_url, stream=True, timeout=120, proxies=self._current_proxies, patch_type=self._current_patch_type, headers=headers)
        resp.raise_for_status()
        cl = resp.headers.get("content-length")
        limit = PREMIUM_LIMIT if _is_premium_user() else FREE_LIMIT
        if cl and int(cl) > limit:
            resp.close()
            raise RuntimeError("__too_large__")
        with open(path, "wb") as f:
            for chunk in resp.iter_content(chunk_size=1024 * 256):
                if self._cancel_requested:
                    resp.close()
                    try:
                        os.remove(path)
                    except Exception:
                        pass
                    return None
                f.write(chunk)
        if not os.path.exists(path) or os.path.getsize(path) == 0:
            raise RuntimeError("Empty download")
        return path

    def _fallback_resolve(self, url):
        low = url.lower()
        path = None
        try:
            if "tiktok" in low:
                path = self._dl_tikwm(url) or self._dl_ytdlp(url)
            elif "youtube.com" in low or "youtu.be" in low:
                path = self._dl_invidious(url) or self._dl_piped(url) or self._dl_ytdlp(url)
            elif "instagram" in low:
                path = self._dl_instagram(url) or self._dl_ytdlp(url)
            else:
                path = self._dl_ytdlp(url)
        except Exception as e:
            log(f"[downloader] fallback error: {e}")
        if path:
            return {"items": [{"path": path, "type": "video"}], "audio": None}
        return None

    def _dl_tikwm(self, url):
        try:
            r = self._http_get("https://www.tikwm.com/api/", params={"url": url, "hd": 1}, timeout=25, proxies=self._current_proxies, patch_type=self._current_patch_type)
            r.raise_for_status()
            data = r.json()
            if data.get("code") != 0:
                return None
            payload = data.get("data") or {}
            play_url = payload.get("hdplay") or payload.get("play")
            if not play_url:
                return None
            if play_url.startswith("/"):
                play_url = "https://www.tikwm.com" + play_url
            return self._download_direct_to_temp(play_url, ".mp4")
        except Exception as e:
            log(f"[downloader] tikwm failed: {e}")
            return None

    def _dl_invidious(self, url):
        m = YOUTUBE_ID_RE.search(url)
        if not m:
            return None
        vid = m.group(1)
        for base in INVIDIOUS_INSTANCES:
            if self._cancel_requested:
                return None
            try:
                r = self._http_get(f"{base}/api/v1/videos/{vid}", params={"local": "true"}, timeout=20, proxies=self._current_proxies, patch_type=self._current_patch_type)
                r.raise_for_status()
                data = r.json()
                if data.get("error"):
                    continue
                streams = data.get("formatStreams") or []
                best = None
                best_res = -1
                for s in streams:
                    if not s.get("url"):
                        continue
                    digits = re.sub(r"\D", "", s.get("resolution") or "0")
                    res = int(digits) if digits else 0
                    if res >= best_res:
                        best_res = res
                        best = s["url"]
                if best:
                    return self._download_direct_to_temp(best, ".mp4")
            except Exception:
                continue
        return None

    def _dl_piped(self, url):
        m = YOUTUBE_ID_RE.search(url)
        if not m:
            return None
        vid = m.group(1)
        for base in PIPED_INSTANCES:
            if self._cancel_requested:
                return None
            try:
                r = self._http_get(f"{base}/streams/{vid}", timeout=20, proxies=self._current_proxies, patch_type=self._current_patch_type)
                r.raise_for_status()
                data = r.json()
                streams = data.get("videoStreams") or []
                best = None
                for s in streams:
                    if s.get("url") and not s.get("videoOnly", True):
                        best = s["url"]
                if not best and streams:
                    best = streams[0].get("url")
                if best:
                    return self._download_direct_to_temp(best, ".mp4")
            except Exception:
                continue
        return None

    def _dl_instagram(self, url):
        m = INSTAGRAM_CODE_RE.search(url)
        if not m:
            return None
        code = m.group(1)
        try:
            r = self._http_get(f"https://www.instagram.com/reel/{code}/embed/captioned/", timeout=20, proxies=self._current_proxies, patch_type=self._current_patch_type)
            r.raise_for_status()
            html = r.text
            vm = re.search(r'"video_url":"([^"]+)"', html) or re.search(r'property="og:video" content="([^"]+)"', html)
            if not vm:
                return None
            video = vm.group(1).encode().decode("unicode_escape").replace("\\/", "/")
            return self._download_direct_to_temp(video, ".mp4")
        except Exception as e:
            log(f"[downloader] instagram embed failed: {e}")
            return None

    def _dl_ytdlp(self, url):
        try:
            import yt_dlp
        except Exception:
            return None
        try:
            out_tmpl = File(self._temp_dir, f"ytdlp_{uuid.uuid4().hex}.%(ext)s").getAbsolutePath()
            opts = {"outtmpl": out_tmpl, "format": "best[ext=mp4]/best", "quiet": True, "no_warnings": True, "noprogress": True}
            proxy = None
            if self._current_proxies:
                proxy = self._current_proxies.get("https") or self._current_proxies.get("http")
            if proxy:
                opts["proxy"] = proxy
            with yt_dlp.YoutubeDL(opts) as ydl:
                info = ydl.extract_info(url, download=True)
                path = ydl.prepare_filename(info)
            if path and not os.path.exists(path):
                base = os.path.splitext(path)[0]
                for ext in (".mp4", ".mkv", ".webm"):
                    if os.path.exists(base + ext):
                        path = base + ext
                        break
            if path and os.path.exists(path) and os.path.getsize(path) > 0:
                return path
        except Exception as e:
            log(f"[downloader] yt-dlp failed: {e}")
        return None

    def _download_one(self, item, index):
        if self._cancel_requested:
            return None
        existing = item.get("path")
        if existing:
            if os.path.exists(existing) and os.path.getsize(existing) > 0:
                return existing
            return None
        filename = item.get("filename") or f"media_{index}_{uuid.uuid4().hex}{_ext_for(item.get('type'), item.get('filename'))}"
        if "." not in filename:
            filename += _ext_for(item.get("type"), None)
        path = File(self._temp_dir, filename).getAbsolutePath()
        resp = self._http_get(item["url"], stream=True, timeout=90, proxies=self._current_proxies, patch_type=self._current_patch_type)
        resp.raise_for_status()
        content_length = resp.headers.get("content-length")
        total = int(content_length) if content_length else 0
        limit = PREMIUM_LIMIT if _is_premium_user() else FREE_LIMIT
        if total and total > limit:
            resp.close()
            raise RuntimeError("__too_large__")
        with open(path, "wb") as f:
            for chunk in resp.iter_content(chunk_size=1024 * 256):
                if self._cancel_requested:
                    resp.close()
                    try:
                        os.remove(path)
                    except Exception:
                        pass
                    return None
                f.write(chunk)
        if not os.path.exists(path) or os.path.getsize(path) == 0:
            raise RuntimeError("Empty download")
        return path

    def _process_download_and_send(self, url, dialog_id, notify, schedule_date, mode_override=None, reply_to_msg=None, reply_to_top_msg=None):
        if not self._task_in_progress.acquire(blocking=False):
            BulletinHelper.show_error("Another download is already running")
            return
        paths = []
        try:
            resolved = self._resolve(url, mode_override)
            if not resolved:
                self._dismiss_dialog()
                return
            items = resolved["items"]
            audio_item = resolved.get("audio")
            include_source = self.get_setting("include_source_set", True)
            caption = url if include_source else None
            self._set_progress(1)

            if len(items) == 1 and not audio_item:
                try:
                    path = self._download_one(items[0], 0)
                except RuntimeError as e:
                    if str(e) == "__too_large__":
                        if not _is_premium_user():
                            self._show_premium_limit_dialog()
                        else:
                            BulletinHelper.show_error("File too large (>4 GB)")
                        self._dismiss_dialog()
                        return
                    raise
                if not path:
                    self._dismiss_dialog()
                    return
                paths.append(path)
                self._set_progress(99)
                self._send_single(path, items[0].get("type"), url, dialog_id, caption, include_source, notify, schedule_date, reply_to_msg, reply_to_top_msg)
                self._dismiss_dialog()
                return

            total = len(items)
            done = [0]
            lock = threading.Lock()
            results = [None] * total

            def worker(i):
                if self._cancel_requested:
                    return
                try:
                    p = self._download_one(items[i], i)
                    results[i] = (p, items[i].get("type"))
                except Exception as e:
                    log(f"[downloader] item {i} failed: {e}")
                with lock:
                    done[0] += 1
                    self._set_progress(max(1, min(98, int(done[0] * 100 / total))))

            with ThreadPoolExecutor(max_workers=ALBUM_WORKERS) as ex:
                list(ex.map(worker, range(total)))

            if self._cancel_requested:
                for r in results:
                    if r and r[0]:
                        self._delete_file_delayed(r[0], delay=1)
                self._dismiss_dialog()
                return

            media = [r for r in results if r and r[0]]
            for r in media:
                paths.append(r[0])
            if audio_item:
                try:
                    ap = self._download_one(audio_item, total)
                    if ap:
                        paths.append(ap)
                        audio_item = {"path": ap}
                    else:
                        audio_item = None
                except Exception:
                    audio_item = None

            if not media:
                BulletinHelper.show_error("Nothing was downloaded")
                self._dismiss_dialog()
                return
            self._set_progress(99)
            self._send_album(media, dialog_id, caption, notify, schedule_date, reply_to_msg, reply_to_top_msg)
            if audio_item and audio_item.get("path"):
                self.send_audio(audio_item["path"], dialog_id, None, notify, schedule_date, reply_to_msg, reply_to_top_msg)
            self._dismiss_dialog()
        except Exception as e:
            self._dismiss_dialog()
            log(f"[downloader] process error: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error(f"Error: {e}")
        finally:
            for p in paths:
                self._delete_file_delayed(p)
            self._task_in_progress.release()

    def _send_single(self, path, item_type, url, dialog_id, caption, include_source, notify, schedule_date, reply_to_msg, reply_to_top_msg):
        kind = _kind_for_path(path, item_type)
        account_instance = get_account_instance()
        if kind == "gif":
            self._send_gif_as_document(path, dialog_id, caption, notify, schedule_date, reply_to_msg, reply_to_top_msg)
            return
        if kind == "audio":
            self.send_audio(path, dialog_id, caption, notify, schedule_date, reply_to_msg, reply_to_top_msg)
            return
        if kind == "photo":
            entities = None
            photo_caption = None
            if include_source:
                photo_caption = "Source"
                entities = ArrayList()
                ent = TLRPC.TL_messageEntityTextUrl()
                ent.offset = 0
                ent.length = 6
                ent.url = url
                entities.add(ent)
            SendMessagesHelper.prepareSendingPhoto(
                account_instance, path, None, dialog_id, reply_to_msg, reply_to_top_msg,
                None, photo_caption, entities, None, None, 0, None, notify, schedule_date, 0, None, 0
            )
            return
        entities = None
        video_caption = None
        if include_source:
            video_caption = "Source"
            entities = ArrayList()
            ent = TLRPC.TL_messageEntityTextUrl()
            ent.offset = 0
            ent.length = 6
            ent.url = url
            entities.add(ent)
        self.send_video(path, dialog_id, video_caption, notify, schedule_date, reply_to_msg, reply_to_top_msg, entities)

    def _send_album(self, media, dialog_id, caption, notify, schedule_date, reply_to_msg, reply_to_top_msg):
        account_instance = get_account_instance()
        if account_instance is None:
            return
        for start in range(0, len(media), ALBUM_CHUNK):
            chunk = media[start:start + ALBUM_CHUNK]
            media_list = ArrayList()
            for idx, (path, item_type) in enumerate(chunk):
                info = SendMessagesHelper.SendingMediaInfo()
                info.path = path
                if _kind_for_path(path, item_type) == "video":
                    info.isVideo = True
                if start == 0 and idx == 0 and caption:
                    info.caption = caption
                media_list.add(info)
            self._prepare_sending_media_safe(account_instance, media_list, dialog_id, reply_to_msg, reply_to_top_msg, notify, schedule_date)

    def send_video(self, video_path, dialog_id, caption=None, notify=True, schedule_date=0, reply_to_msg=None, reply_to_top_msg=None, entities=None):
        ext = os.path.splitext(video_path)[1].lower()
        if ext in AUDIO_EXTS:
            return self.send_audio(video_path, dialog_id, caption, notify, schedule_date, reply_to_msg, reply_to_top_msg)
        try:
            account_instance = get_account_instance()
            if account_instance is None:
                return
            if caption and entities is None:
                mdc = get_media_data_controller()
                if mdc:
                    entities = mdc.getEntities([caption], True)
            self._prepare_sending_video_safe(account_instance, video_path, dialog_id, reply_to_msg, reply_to_top_msg, entities, notify, schedule_date, False, False, caption, None, 0, 0, 0)
        except Exception as e:
            log(f"[downloader] send_video error: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error(f"Error sending video: {e}")

    def send_audio(self, audio_path, dialog_id, caption=None, notify=True, schedule_date=0, reply_to_msg=None, reply_to_top_msg=None):
        try:
            account_instance = get_account_instance()
            if account_instance is None:
                return
            import mimetypes
            mime, _ = mimetypes.guess_type(audio_path)
            if mime is None:
                ext = os.path.splitext(audio_path)[1].lower()
                mime = {".mp3": "audio/mpeg", ".wav": "audio/wav"}.get(ext, "audio/ogg")
            ext_cache_root = ApplicationLoader.applicationContext.getExternalCacheDir()
            plugin_ext_dir = File(ext_cache_root, TEMP_DIR_NAME)
            if not plugin_ext_dir.exists():
                plugin_ext_dir.mkdirs()
            external_path = File(plugin_ext_dir, File(audio_path).getName()).getAbsolutePath()
            with open(audio_path, "rb") as f_in, open(external_path, "wb") as f_out:
                while True:
                    chunk = f_in.read(1024 * 256)
                    if not chunk:
                        break
                    f_out.write(chunk)
            SendMessagesHelper.prepareSendingDocument(
                account_instance, external_path, external_path, None, caption, mime, dialog_id,
                reply_to_msg, reply_to_top_msg, None, None, None, notify, schedule_date, None, None, 0, False
            )
        except Exception as e:
            log(f"[downloader] send_audio error: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error(f"Error sending audio: {e}")

    def _send_gif_as_document(self, gif_path, dialog_id, caption, notify, schedule_date, reply_to_msg=None, reply_to_top_msg=None):
        try:
            account_instance = get_account_instance()
            if account_instance is None:
                return
            ext_cache_root = ApplicationLoader.applicationContext.getExternalCacheDir()
            plugin_ext_dir = File(ext_cache_root, TEMP_DIR_NAME)
            if not plugin_ext_dir.exists():
                plugin_ext_dir.mkdirs()
            external_path = File(plugin_ext_dir, "animation.gif").getAbsolutePath()
            with open(gif_path, "rb") as f_in, open(external_path, "wb") as f_out:
                while True:
                    chunk = f_in.read(1024 * 256)
                    if not chunk:
                        break
                    f_out.write(chunk)
            SendMessagesHelper.prepareSendingDocument(
                account_instance, external_path, external_path, None, caption, "image/gif", dialog_id,
                reply_to_msg, reply_to_top_msg, None, None, None, notify, schedule_date, None, None, 0, False
            )
        except Exception as e:
            log(f"[downloader] send_gif error: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error(f"Error sending GIF: {e}")

    def _delete_file_delayed(self, path, delay=60):
        def action():
            try:
                time.sleep(delay)
                if os.path.exists(path):
                    os.remove(path)
            except Exception:
                pass
        threading.Thread(target=action, daemon=True).start()

    def _dismiss_dialog(self):
        def action():
            global progress_dialog
            if progress_dialog is not None:
                try:
                    dlg = progress_dialog.get_dialog() if hasattr(progress_dialog, "get_dialog") else progress_dialog
                    if dlg and dlg.isShowing():
                        dlg.dismiss()
                except Exception:
                    pass
                finally:
                    progress_dialog = None
        run_on_ui_thread(action)

    def _show_loading_alert(self):
        global progress_dialog
        self._cancel_requested = False
        fragment = get_last_fragment()
        ctx = fragment.getContext() if fragment else ApplicationLoader.applicationContext
        builder = AlertDialogBuilder(ctx, AlertDialogBuilder.ALERT_TYPE_LOADING)
        builder.set_title(Z("downloading"))
        builder.set_negative_button(Z("cancel"), self._on_progress_cancel)
        builder.set_cancelable(False)
        progress_dialog = builder.show()
        progress_dialog.set_progress(0)

    def _on_progress_cancel(self, builder, which):
        self._cancel_requested = True
        self._dismiss_dialog()

    def _copy_to_clipboard(self, label, text):
        fragment = get_last_fragment()
        ctx = fragment.getContext() if fragment else ApplicationLoader.applicationContext
        clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
        clipboard.setPrimaryClip(ClipData.newPlainText(label, text))
        BulletinHelper.show_info(f"Copied {label} to clipboard")

    def _open_link(self, url):
        fragment = get_last_fragment()
        ctx = fragment.getContext() if fragment else ApplicationLoader.applicationContext
        intent = Intent(Intent.ACTION_VIEW, Uri.parse(url))
        run_on_ui_thread(lambda: ctx.startActivity(intent))

    def _open_tg_link(self, path):
        try:
            fragment = get_last_fragment()
            ctx = fragment.getContext() if fragment else ApplicationLoader.applicationContext
            if "/" in path:
                domain, post = path.split("/", 1)
                intent = Intent(Intent.ACTION_VIEW, Uri.parse(f"tg://resolve?domain={domain}&post={post}"))
                run_on_ui_thread(lambda: ctx.startActivity(intent))
            else:
                mc = get_messages_controller()
                run_on_ui_thread(lambda: mc.openByUserName(path, fragment, 1))
        except Exception as e:
            log(f"[{__id__}] Failed to open tg link: {e}")

    def show_my_info_alert(self, title="TITLE", message="MESSAGE", positive_button="OK", neutral_button=None, neutral_link=None, neutral_type=None):
        fragment = get_last_fragment()
        ctx = fragment.getContext() if fragment else ApplicationLoader.applicationContext
        builder = AlertDialogBuilder(ctx, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
        builder.set_title(title)
        builder.set_message(message)
        builder.set_positive_button(positive_button, lambda b, w: b.dismiss())
        if neutral_button:
            if neutral_type == "link":
                builder.set_neutral_button(neutral_button, lambda b, w: self._open_link(neutral_link))
            else:
                builder.set_neutral_button(neutral_button, lambda b, w: self._copy_to_clipboard(neutral_button, neutral_link))
        builder.show()

    def _on_show_settings_buttons_change(self, enabled):
        def _toggle():
            try:
                if enabled:
                    if not self._drawer_settings_item or not self._chat_settings_item:
                        self._add_settings_menu_items()
                else:
                    if self._drawer_settings_item:
                        self.remove_menu_item(self._drawer_settings_item)
                        self._drawer_settings_item = None
                    if self._chat_settings_item:
                        self.remove_menu_item(self._chat_settings_item)
                        self._chat_settings_item = None
            except Exception as e:
                log(f"[{__id__}] toggle settings buttons: {e}")
        run_on_ui_thread(_toggle)

    def _start_download(self, url, dialog_id, mode_override, reply_to_msg, reply_to_top_msg):
        if self._task_in_progress.locked():
            BulletinHelper.show_error("Another download is already running")
            return False
        threading.Thread(target=self._process_download_and_send, args=(url, dialog_id, True, 0, mode_override, reply_to_msg, reply_to_top_msg), daemon=True).start()
        run_on_ui_thread(lambda: self._show_loading_alert())
        return True

    def on_send_message_hook(self, account, params):
        if not hasattr(params, "message") or not isinstance(params.message, str):
            return HookResult()
        msg = params.message.strip()
        if self.get_setting("auto_link_set", False) and re.fullmatch(r"https?://\S+", msg):
            parsed = urllib.parse.urlparse(msg)
            host_full = (parsed.hostname or "").lower()
            if host_full.startswith("www."):
                host_full = host_full[4:]
            parts = host_full.split(".")
            base = ".".join(parts[-2:]) if len(parts) >= 2 else host_full
            group_key = BASE_TO_GROUP.get(base)
            if group_key and group_key in self._get_auto_link_services():
                if self._start_download(msg, params.peer, None, getattr(params, "replyToMsg", None), getattr(params, "replyToTopMsg", None)):
                    return HookResult(strategy=HookStrategy.CANCEL)
                return HookResult(strategy=HookStrategy.CANCEL)
        if msg.startswith(".down ") or msg.startswith(".up ") or msg.startswith(".dl "):
            parts = msg.split()
            if len(parts) < 2 or not parts[1]:
                BulletinHelper.show_error("No URL provided")
                return HookResult(strategy=HookStrategy.CANCEL)
            mode_override = parts[2].lower() if len(parts) > 2 else None
            self._start_download(parts[1].strip(), params.peer, mode_override, getattr(params, "replyToMsg", None), getattr(params, "replyToTopMsg", None))
            return HookResult(strategy=HookStrategy.CANCEL)
        return HookResult()

    def _test_current_proxy(self):
        def test():
            try:
                proxy_type = self.get_setting("proxy_type_set", 0)
                if proxy_type == 0:
                    return
                if proxy_type == 4:
                    success = self._test_mtproto_connection()
                elif proxy_type == 3:
                    success = self._test_socks_connection()
                else:
                    proxies, _ = self._get_proxies()
                    success = self._test_proxy_connection(proxies) if proxies else False
                if success:
                    BulletinHelper.show_success("Тест подключения прокси успешен!" if _is_ru() else "Proxy connection test successful!")
                else:
                    BulletinHelper.show_error("Тест подключения прокси не удался" if _is_ru() else "Proxy connection test failed")
            except Exception as e:
                BulletinHelper.show_error(f"{'Ошибка теста прокси' if _is_ru() else 'Proxy test error'}: {e}")
        threading.Thread(target=test, daemon=True).start()
