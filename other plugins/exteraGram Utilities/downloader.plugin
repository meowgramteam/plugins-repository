def _is_ru():
    try:
        from org.telegram.messenger import LocaleController
        lc = LocaleController.getInstance()
        info = lc.getCurrentLocaleInfo() if lc else None
        for attr in ("shortName", "pluralLangCode", "langCode"):
            v = getattr(info, attr, None)
            if v and str(v).lower().startswith("ru"):
                return True
    except Exception:
        pass
    try:
        return str(Locale.getDefault().getLanguage() or "").lower().startswith("ru")
    except Exception:
        return False


def Z(key):
    return TRANSLATIONS.get(key, (key, key))[0 if _is_ru() else 1]


def _is_premium_user():
    try:
        ai = get_account_instance()
        if ai is None:
            return False
        uc = ai.getUserConfig()
        return bool(uc.isPremium()) if uc else False
    except Exception:
        return False


def _ext_for(item_type, filename):
    if filename and "." in filename:
        ext = "." + filename.rsplit(".", 1)[-1].lower()
        if 1 < len(ext) <= 6 and ext[1:].isalnum():
            return ext
    if item_type == "photo":
        return ".jpg"
    if item_type == "gif":
        return GIF_EXT
    if item_type == "audio":
        return ".mp3"
    return ".mp4"


def _kind_for_path(path, item_type):
    ext = os.path.splitext(path)[1].lower()
    if item_type in ("photo", "video", "gif", "audio"):
        base = item_type
    elif ext in IMAGE_EXTS:
        base = "photo"
    elif ext in AUDIO_EXTS:
        base = "audio"
    elif ext == GIF_EXT:
        base = "gif"
    else:
        base = "video"
    return base


class VideoDownloaderPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._temp_dir = None
        self._cancel_requested = False
        self._drawer_settings_item = None
        self._chat_settings_item = None
        self._task_in_progress = threading.Lock()
        self._current_proxies = None
        self._current_patch_type = None

    @contextmanager
    def _proxy_connection_patch(self, patch_type):
        import requests.packages.urllib3.util.connection as uc
        original = uc.create_connection
        try:
            if patch_type == "socks":
                uc.create_connection = lambda addr, timeout=None, **kw: self._socks_create_connection(addr[0], addr[1])
            elif patch_type == "mtproto":
                uc.create_connection = lambda addr, timeout=None, **kw: self._mtproto_create_connection(addr[0], addr[1])
            yield
        finally:
            uc.create_connection = original

    def _set_progress(self, value):
        def action():
            dlg = None
            try:
                dlg = progress_dialog.get_dialog() if hasattr(progress_dialog, "get_dialog") else progress_dialog
            except Exception:
                dlg = progress_dialog
            if dlg and hasattr(dlg, "isShowing") and dlg.isShowing():
                try:
                    progress_dialog.set_progress(value)
                except Exception:
                    pass
        run_on_ui_thread(action)

    def _get_auto_link_services(self):
        saved = self.get_setting("auto_link_services_set", None)
        if not saved:
            return set(AUTO_GROUP_LABELS.keys())
        try:
            return set(saved)
        except Exception:
            return set(AUTO_GROUP_LABELS.keys())

    def _set_auto_link_services(self, services_set):
        try:
            self.set_setting("auto_link_services_set", list(services_set))
        except Exception:
            pass

    def _toggle_auto_service(self, base, enabled):
        current = self._get_auto_link_services()
        if enabled:
            current.add(base)
        else:
            current.discard(base)
        self._set_auto_link_services(current)

    def _service_setting_key(self, base):
        return "auto_service_" + base.replace(".", "_").replace("-", "_").replace("/", "_")

    def _prepare_sending_media_safe(self, account_instance, media_list, dialog_id, reply_to_msg, reply_to_top_msg, notify, schedule_date):
        attempts = [
            (account_instance, media_list, dialog_id, reply_to_msg, reply_to_top_msg,
             None, None, False, True, None, notify, schedule_date, 0, 0, False,
             None, None, 0, 0, False, 0, 0, None),
            (account_instance, media_list, dialog_id, reply_to_msg, reply_to_top_msg,
             None, None, False, True, None, None, notify, schedule_date, 0, 0, False,
             None, None, 0, 0, False, 0, 0, None),
            (account_instance, media_list, dialog_id, reply_to_msg, reply_to_top_msg,
             None, None, False, True, None, None, notify, schedule_date, 0, 0, False,
             None, None, 0, 0, False, 0, 0, None, None, False),
        ]
        last_error = None
        for args in attempts:
            try:
                SendMessagesHelper.prepareSendingMedia(*args)
                return
            except TypeError as e:
                last_error = e
        raise last_error

    def _prepare_sending_video_safe(self, account_instance, video_path, dialog_id, reply_to_msg, reply_to_top_msg, entities, notify, schedule_date, force_document, has_media_spoilers, caption, quick_reply_shortcut, quick_reply_shortcut_id, effect_id, stars):
        try:
            SendMessagesHelper.prepareSendingVideo(
                account_instance, video_path, None, None, None, dialog_id, reply_to_msg, reply_to_top_msg,
                None, None, entities, 0, None, notify, schedule_date, 0, force_document, has_media_spoilers,
                caption, quick_reply_shortcut, quick_reply_shortcut_id, effect_id, stars
            )
        except TypeError:
            SendMessagesHelper.prepareSendingVideo(
                account_instance, video_path, None, None, None, dialog_id, reply_to_msg, reply_to_top_msg,
                None, None, entities, 0, None, notify, schedule_date, force_document, has_media_spoilers,
                caption, quick_reply_shortcut, quick_reply_shortcut_id, effect_id, stars
            )

