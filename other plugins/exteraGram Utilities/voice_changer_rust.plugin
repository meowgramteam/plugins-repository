import ctypes
import base64

SO_ARM64 = ""
SO_ARMV7 = ""

class NativeDSPLoader:
    def __init__(self, cache_dir: str):
        self.cache_dir = cache_dir
        self.lib = None
        self._load_library()

    def _load_library(self):
        import platform
        arch = platform.machine().lower()
        log(f"[VoiceChanger] Device architecture: {arch}")
        import zlib
        if "arm64" in arch or "aarch64" in arch:
            so_data = zlib.decompress(base64.b64decode(SO_ARM64))
            filename = "libvoice_dsp_arm64.so"
        elif "arm" in arch:
            so_data = zlib.decompress(base64.b64decode(SO_ARMV7))
            filename = "libvoice_dsp_armv7.so"
        else:
            raise RuntimeError(f"Unsupported architecture: {arch}")

        so_path = os.path.join(self.cache_dir, filename)
        if not os.path.exists(so_path) or os.path.getsize(so_path) != len(so_data):
            log(f"[VoiceChanger] Extracting native library to {so_path}")
            with open(so_path, "wb") as f:
                f.write(so_data)

        log(f"[VoiceChanger] Loading native library from {so_path}")
        self.lib = ctypes.CDLL(so_path)
        self.lib.process_voice_native.argtypes = [
            ctypes.POINTER(ctypes.c_short),
            ctypes.c_int,
            ctypes.POINTER(ctypes.c_short),
            ctypes.c_int,
            ctypes.c_int,
            ctypes.c_float,
            ctypes.c_float,
            ctypes.c_int,
            ctypes.c_float,
            ctypes.c_float,
            ctypes.c_int,
            ctypes.c_float,
            ctypes.c_float,
            ctypes.c_float,
        ]
        self.lib.process_voice_native.restype = ctypes.c_int
        self.lib.ogg_crc_native.argtypes = [
            ctypes.POINTER(ctypes.c_ubyte),
            ctypes.c_int,
        ]
        self.lib.ogg_crc_native.restype = ctypes.c_uint

        self.lib.decode_ogg_opus_native.argtypes = [
            ctypes.c_char_p,
            ctypes.POINTER(ctypes.POINTER(ctypes.c_short)),
            ctypes.POINTER(ctypes.c_int),
            ctypes.POINTER(ctypes.c_int),
            ctypes.POINTER(ctypes.c_int),
        ]
        self.lib.decode_ogg_opus_native.restype = ctypes.c_int

        self.lib.encode_ogg_opus_native.argtypes = [
            ctypes.POINTER(ctypes.c_short),
            ctypes.c_int,
            ctypes.c_char_p,
            ctypes.c_int,
            ctypes.c_int,
        ]
        self.lib.encode_ogg_opus_native.restype = ctypes.c_int

        self.lib.free_pcm_buffer.argtypes = [
            ctypes.POINTER(ctypes.c_short),
            ctypes.c_int,
        ]
        self.lib.free_pcm_buffer.restype = None


