def _resolve_lang():
    try:
        plugin = _plugin_ref[0]
        if plugin is not None:
            idx = plugin.get_setting("lang", 0)
            mapping = {1: "ru", 2: "en", 3: "kk", 4: "be", 5: "uk"}
            if idx in mapping:
                return mapping[idx]
        # auto — system locale
        try:
            from java.util import Locale
            sys_lang = Locale.getDefault().getLanguage()
            if sys_lang in _STRINGS:
                return sys_lang
        except:
            pass
        return "ru"
    except:
        return "ru"


def _t(key, **kwargs):
    lang = _resolve_lang()
    s = _STRINGS.get(lang, _STRINGS["ru"]).get(key, _STRINGS["ru"].get(key, key))
    if kwargs:
        try:
            return s.format(**kwargs)
        except:
            return s
    return s


LABEL = _t("library_label")

PHOTO_EXTS = {'.jpg', '.jpeg', '.png', '.webp'}
VIDEO_EXTS = {'.mp4', '.avi', '.mov', '.webm', '.mkv', '.3gp'}

R_INPUT, R_CARD, R_CHIP, R_FAB = 10, 12, 16, 24
GALLERY_REQ = 0xA042
ZIP_PICK_REQ = 0xA043

DOWNLOADS_DIR = "/storage/emulated/0/Download"
HELP_URL = "https://telegra.ph/Test-05-12-388"  # TODO: заменить на реальную статью с FAQ

LANG_CODES = ["auto", "ru", "en", "kk", "be", "uk"]
LANG_LABELS = ["Авто", "Русский", "English", "Қазақша", "Беларуская", "Українська"]
PAD_SHEET, PAD_DIALOG = 16, 20
PAD_INPUT_H, PAD_INPUT_V = 14, 12
GAP_SECTION, GAP_ITEM = 12, 8

MAX_CATEGORIES = 30
MAX_CATEGORY_LEN = 10

APP_DIR = os.path.dirname(os.path.realpath(__file__))
DB_PATH = os.path.join(APP_DIR, "memes_db.json")
SETTINGS_PATH = os.path.join(APP_DIR, "plugin_settings.json")


def _safe_drawable(*names):
    for n in names:
        try:
            return getattr(R.drawable, n)
        except AttributeError:
            continue
    return 0


def _load_db():
    try:
        with open(DB_PATH, "r", encoding="utf-8") as f:
            data = json.load(f)
    except:
        return [], []
    if isinstance(data, list):
        # Legacy DB shape (plain list of memes); migrated on next _save_db.
        return data, []
    if isinstance(data, dict):
        return data.get("memes", []), data.get("categories", [])
    return [], []


def _save_db(memes, categories):
    with open(DB_PATH, "w", encoding="utf-8") as f:
        json.dump({"memes": memes, "categories": categories}, f, ensure_ascii=False, indent=2)

def _load_settings():
    try:
        with open(SETTINGS_PATH, "r", encoding="utf-8") as f:
            return json.load(f)
    except:
        return {"onboarding_done": False}

def _save_settings(settings):
    try:
        with open(SETTINGS_PATH, "w", encoding="utf-8") as f:
            json.dump(settings, f, ensure_ascii=False, indent=2)
    except:
        pass


class _DBTxn:
    __slots__ = ("memes", "cats", "cancelled")

    def __init__(self, memes, cats):
        self.memes = memes
        self.cats = cats
        self.cancelled = False

    def cancel(self):
        self.cancelled = True


@contextmanager
def _db_txn():
    """RMW над БД с автосохранением. `t.cancel()` отменяет save; любое исключение
    в теле → bulletin + cancel. После `with` поле `t.cancelled` сигналит, можно ли
    запускать post-save UI."""
    try:
        m, c = _load_db()
    except Exception as e:
        try:
            BulletinHelper.show_success(_t("error_db_read", e=e))
        except Exception:
            pass
        # Yielding pre-cancelled txn so the with-body doesn't NameError on t.memes/t.cats.
        t = _DBTxn([], [])
        t.cancelled = True
        yield t
        return
    t = _DBTxn(m, c)
    try:
        yield t
    except Exception as e:
        t.cancelled = True
        try:
            BulletinHelper.show_success(_t("error_prefix", e=e))
        except Exception:
            pass
        return
    if not t.cancelled:
        try:
            _save_db(t.memes, t.cats)
        except Exception as e:
            t.cancelled = True
            try:
                BulletinHelper.show_success(_t("error_db_save", e=e))
            except Exception:
                pass


def _tokens(s):
    return [t for t in s.lower().split() if t]


def _match_description(desc, query):
    desc_low = (desc or "").lower()
    return all(w in desc_low for w in _tokens(query))


def _short_desc(s, n=30):
    if not s:
        return ""
    s = " ".join(s.split())
    if len(s) <= n:
        return s
    return s[:n].rstrip() + "…"


class MemeLibraryPlugin(BasePlugin):

    def on_plugin_load(self):
        _plugin_ref[0] = self
        self._pv_hook_ref = None
        self._selected = set()
        self._current_dialog_id = 0
        self._activity_callbacks = {}  # request_code -> callback(uri)
        self._activity_result_hook_ref = None
        self._thumb_cache = {}  # (filepath, size) -> Bitmap
        self._drawer_item_id = None
        self._setup_activity_result_hook()

        if not os.path.exists(DB_PATH):
            with open(DB_PATH, "w", encoding="utf-8") as f:
                json.dump([], f)

        self.add_menu_item(MenuItemData(
            menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
            text=_t("save_to_memes"),
            on_click=self.handle_save_meme,
            icon="msg_save",
            subtext=_t("save_locally"),
            priority=100
        ))
        self.add_menu_item(MenuItemData(
            menu_type=MenuItemType.CHAT_ACTION_MENU,
            text=_t("library_label"),
            on_click=self.handle_open_library,
            icon="msg_gallery",
            priority=100
        ))
        if self.get_setting("show_in_drawer", True):
            self._drawer_item_id = self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                text=_t("library_label"),
                on_click=self.handle_open_library,
                icon="msg_gallery",
                priority=80
            ))
        self._setup_photo_viewer_hook()

    def _setup_photo_viewer_hook(self):
        plugin = self
        try:
            PV = find_class("org.telegram.ui.PhotoViewer")
            if not PV:
                return
            pv_class = PV.getClass()
            spa = [m for m in pv_class.getDeclaredMethods() if m.getName() == "setParentActivity"]
            if not spa:
                return

            class Hook:
                def after_hooked_method(h, param):
                    try:
                        pv = param.thisObject
                        mi = get_private_field(pv, "menuItem")
                        if not mi:
                            return
                        try:
                            if mi.hasSubItem(MEME_MENU_ID):
                                return
                        except:
                            pass
                        sub = mi.addSubItem(MEME_MENU_ID, R.drawable.msg_folders, _t("save_to_memes"))
                        try:
                            sub.setColors(COLOR_WHITE, COLOR_WHITE)
                        except:
                            pass

                        class CP(dynamic_proxy(View.OnClickListener)):
                            def onClick(cp, v):
                                try:
                                    try:
                                        mi.toggleSubMenu()
                                    except:
                                        pass
                                    msg = get_private_field(pv, "currentMessageObject")
                                    ctx = {'message': msg, 'from_photoviewer': True}
                                    if msg:
                                        try:
                                            fp = FileLoader.getInstance(msg.currentAccount).getPathToMessage(msg.messageOwner)
                                            if fp and fp.exists():
                                                ctx['filepath'] = str(fp.getAbsolutePath())
                                        except:
                                            pass
                                    run_on_ui_thread(lambda: plugin.handle_save_meme(ctx))
                                except Exception as e:
                                    err = str(e)
                                    run_on_ui_thread(lambda: BulletinHelper.show_success(_t("error_prefix", e=err)))
                        sub.setOnClickListener(CP())
                    except:
                        pass

            for m in spa:
                m.setAccessible(True)
                self._pv_hook_ref = self.hook_method(m, Hook())
        except:
            pass

    def _setup_activity_result_hook(self):
        plugin = self
        try:
            LA = find_class("org.telegram.ui.LaunchActivity")
            if not LA:
                return
            cls = LA.getClass()
            methods = []
            while cls is not None and not methods:
                try:
                    methods = [m for m in cls.getDeclaredMethods()
                               if m.getName() == "onActivityResult"]
                except:
                    pass
                if not methods:
                    try:
                        cls = cls.getSuperclass()
                    except:
                        break
            if not methods:
                return

            class Hook:
                def after_hooked_method(h, param):
                    try:
                        req  = int(param.args[0])
                        res  = int(param.args[1])
                        data = param.args[2]
                        if res != -1 or not data:
                            return
                        if req not in (GALLERY_REQ, ZIP_PICK_REQ):
                            return
                        uri = data.getData()
                        cb = plugin._activity_callbacks.pop(req, None)
                        if uri and cb:
                            run_on_ui_thread(lambda: cb(uri))
                    except:
                        pass

            for m in methods:
                m.setAccessible(True)
                self._activity_result_hook_ref = self.hook_method(m, Hook())
        except:
            pass

    def create_settings(self):
        cur_dir = self.get_meme_dir()
        return [
            Header(text=_t("settings_header_general")),
            Text(
                text=_t("settings_change_dir"),
                icon="msg_folders",
                on_click=self._on_change_dir_click,
            ),
            Divider(text=_t("settings_current_dir", dir=cur_dir)),

            Text(
                text=_t("settings_export"),
                icon="msg_leave",
                on_click=self._on_export_click,
            ),
            Text(
                text=_t("settings_import"),
                icon="msg_download",
                on_click=self._on_import_click,
            ),
            Divider(text=_t("settings_export_hint")),

            Header(text=_t("settings_header_other")),
            Selector(
                key="lang",
                text=_t("settings_language"),
                default=0,
                items=LANG_LABELS,
                icon="msg_translate",
            ),
            Switch(
                key="show_in_drawer",
                text=_t("settings_show_in_drawer"),
                default=True,
                icon="msg_list",
                on_change=self._on_drawer_toggle,
            ),
            Text(
                text=_t("settings_help"),
                icon="msg_help",
                on_click=self._on_help_click,
            ),
            Text(
                text=_t("settings_reset_tutorial"),
                icon="msg_retry",
                on_click=self._on_reset_onboarding_click,
            ),
            Text(
                text=_t("settings_clear_library"),
                icon="msg_delete",
                red=True,
                on_click=self._on_clear_click,
            ),
        ]

    def _get_activity(self):
        try:
            f = get_last_fragment()
            return f.getParentActivity() if f is not None else None
        except Exception:
            return None

    def get_meme_dir(self):
        d = self.get_setting("meme_save_dir", "/storage/emulated/0/Pictures/ExteraMemes").strip()
        if not d:
            d = "/storage/emulated/0/Pictures/ExteraMemes"
        if not os.path.exists(d):
            try:
                os.makedirs(d)
            except:
                d = os.path.join(APP_DIR, "memes_fallback")
                if not os.path.exists(d):
                    os.makedirs(d)
                    
        nm = os.path.join(d, ".nomedia")
        if not os.path.exists(nm):
            try:
                open(nm, "w").close()
            except: pass
            
        return d

    def _on_drawer_toggle(self, enabled):
        """Добавляет / удаляет пункт «Библиотека мемов» из бокового меню."""
        try:
            if enabled:
                if not self._drawer_item_id:
                    self._drawer_item_id = self.add_menu_item(MenuItemData(
                        menu_type=MenuItemType.DRAWER_MENU,
                        text=_t("library_label"),
                        on_click=self.handle_open_library,
                        icon="msg_gallery",
                        priority=80
                    ))
            else:
                if self._drawer_item_id is not None:
                    self.remove_menu_item(self._drawer_item_id)
                    self._drawer_item_id = None
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _ensure_nomedia_scan(self, directory):
        """Один раз при смене директории просит MediaScanner перечитать .nomedia,
        чтобы файлы мемов исчезли из галереи телефона."""
        last = self.get_setting("nomedia_scan_dir", "")
        if last == directory:
            return
        try:
            from android.media import MediaScannerConnection
            activity = self._get_activity()
            if not activity:
                return
            ctx = activity.getApplicationContext()
            nm = os.path.join(directory, ".nomedia")
            if os.path.exists(nm):
                MediaScannerConnection.scanFile(ctx, [nm], None, None)
                self.set_setting("nomedia_scan_dir", directory)
        except:
            pass

    def _run_async(self, work_fn, on_done):
        class _Worker(dynamic_proxy(Runnable)):
            def run(s):
                try:
                    result = work_fn()
                except Exception as e:
                    result = _t("error_prefix", e=e)
                run_on_ui_thread(lambda: on_done(result))
        try:
            from java.lang import Thread
            Thread(_Worker()).start()
        except:
            try:
                on_done(work_fn())
            except Exception as e:
                on_done(_t("error_prefix", e=e))

    def _on_change_dir_click(self, view):
        activity = self._get_activity()
        cur_dir = self.get_meme_dir()

        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("dir_change_title"))

        container = LinearLayout(activity)
        container.setOrientation(LinearLayout.VERTICAL)
        p = AndroidUtilities.dp(PAD_DIALOG)
        container.setPadding(p, AndroidUtilities.dp(GAP_ITEM), p, AndroidUtilities.dp(GAP_ITEM))

        inp = self._styled_input(activity, "/storage/emulated/0/Pictures/...", cur_dir)
        container.addView(inp, LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

        hint_tv = TextView(activity)
        hint_tv.setText(_t("dir_move_hint"))
        hint_tv.setTextSize(1, 12.0)
        try:
            hint_tv.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
        except:
            pass
        hlp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        hlp.setMargins(0, AndroidUtilities.dp(8), 0, 0)
        container.addView(hint_tv, hlp)

        builder.setView(container)

        plugin = self

        def on_save():
            new_path = inp.getText().toString().strip()
            if not new_path or new_path == cur_dir:
                return
            try:
                BulletinHelper.show_success(_t("dir_moving"))
                plugin._run_async(
                    lambda: plugin._migrate_meme_dir(cur_dir, new_path),
                    lambda msg: BulletinHelper.show_success(msg),
                )
            except Exception as e:
                BulletinHelper.show_success(_t("error_prefix", e=e))

        builder.setPositiveButton(_t("btn_save_and_move"), self._dlg_listener(on_save))
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _migrate_meme_dir(self, old_dir, new_dir):
        """Возвращает строку-результат для bulletin."""
        try:
            if not os.path.exists(new_dir):
                os.makedirs(new_dir)
        except Exception as e:
            return _t("dir_error_create", e=e)

        memes, categories = _load_db()
        moved = 0
        errors = 0

        for m in memes:
            old_fp = m.get("filepath", "")
            if not old_fp or not os.path.exists(old_fp):
                if old_fp:
                    fname = os.path.basename(old_fp)
                    m["filepath"] = os.path.join(new_dir, fname)
                continue

            fname = os.path.basename(old_fp)
            new_fp = os.path.join(new_dir, fname)

            if os.path.abspath(old_fp) == os.path.abspath(new_fp):
                continue

            base, ext = os.path.splitext(fname)
            i = 1
            while os.path.exists(new_fp):
                new_fp = os.path.join(new_dir, f"{base}_{i}{ext}")
                i += 1

            try:
                shutil.move(old_fp, new_fp)
                m["filepath"] = new_fp
                m["filename"] = os.path.basename(new_fp)
                moved += 1
            except Exception:
                errors += 1

        try:
            _save_db(memes, categories)
        except Exception as e:
            return _t("dir_moved_db_error", moved=moved, e=e)

        try:
            self.set_setting("meme_save_dir", new_dir, reload_settings=True)
        except Exception as e:
            return _t("dir_moved_settings_error", moved=moved, e=e)

        try:
            self._thumb_cache.clear()
        except:
            pass

        if errors:
            return _t("dir_moved_errors", moved=moved, errors=errors)
        return _t("dir_moved", moved=moved)

    def _on_help_click(self, view):
        try:
            from android.content import Intent
            from android.net import Uri
            activity = self._get_activity()
            intent = Intent(Intent.ACTION_VIEW, Uri.parse(HELP_URL))
            activity.startActivity(intent)
        except Exception as e:
            BulletinHelper.show_success(_t("help_open_error", e=e))

    def _on_export_click(self, view):
        BulletinHelper.show_success(_t("exporting"))
        self._run_async(
            lambda: self._export_library_zip(),
            lambda msg: BulletinHelper.show_success(msg),
        )

    def _export_library_zip(self):
        memes, categories = _load_db()
        if not memes:
            return _t("export_empty")

        if not os.path.exists(DOWNLOADS_DIR):
            try:
                os.makedirs(DOWNLOADS_DIR)
            except:
                pass

        stamp = time.strftime("%Y-%m-%d_%H%M")
        out_path = os.path.join(DOWNLOADS_DIR, f"meme_library_{stamp}.zip")

        # Normalize to media/<filename> so the ZIP is portable across users.
        normalized = []
        for m in memes:
            fp = m.get("filepath", "")
            fname = os.path.basename(fp) if fp else ""
            if fname:
                nm = dict(m)
                nm["filepath"] = f"media/{fname}"
                normalized.append(nm)
            else:
                normalized.append(m)

        with zipfile.ZipFile(out_path, "w", zipfile.ZIP_DEFLATED) as zf:
            zf.writestr(
                "memes_db.json",
                json.dumps({"memes": normalized, "categories": categories},
                           ensure_ascii=False, indent=2),
            )
            for m in memes:
                fp = m.get("filepath", "")
                if fp and os.path.exists(fp):
                    try:
                        zf.write(fp, f"media/{os.path.basename(fp)}")
                    except:
                        pass

        return _t("export_done", count=len(memes), filename=os.path.basename(out_path))

    def _on_import_click(self, view):
        from android.content import Intent
        activity = self._get_activity()
        plugin = self

        def callback(uri):
            run_on_ui_thread(lambda: plugin._handle_imported_zip(activity, uri))

        self._activity_callbacks[ZIP_PICK_REQ] = callback
        try:
            intent = Intent(Intent.ACTION_GET_CONTENT)
            intent.setType("application/zip")
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            activity.startActivityForResult(intent, ZIP_PICK_REQ)
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _handle_imported_zip(self, activity, uri):
        BulletinHelper.show_success(_t("importing"))
        self._run_async(
            lambda: self._import_library_zip(activity, uri),
            lambda msg: BulletinHelper.show_success(msg),
        )

    def _import_library_zip(self, activity, uri):
        """Merge-with-rename: при коллизии имени файл переименовывается, не перезаписывается."""
        from java.io import FileOutputStream

        cr = activity.getContentResolver()
        tmp_zip = os.path.join(APP_DIR, f"_import_{int(time.time())}.zip")
        in_s = cr.openInputStream(uri)
        out = FileOutputStream(tmp_zip)
        buf = bytearray(8192)
        while True:
            n = in_s.read(buf)
            if n < 0:
                break
            out.write(buf, 0, n)
        in_s.close(); out.close()

        tmp_dir = os.path.join(APP_DIR, f"_import_extract_{int(time.time())}")
        os.makedirs(tmp_dir, exist_ok=True)
        try:
            with zipfile.ZipFile(tmp_zip, "r") as zf:
                zf.extractall(tmp_dir)
        except Exception as e:
            shutil.rmtree(tmp_dir, ignore_errors=True)
            try: os.remove(tmp_zip)
            except: pass
            return _t("import_zip_error", e=e)

        manifest = os.path.join(tmp_dir, "memes_db.json")
        if not os.path.exists(manifest):
            shutil.rmtree(tmp_dir, ignore_errors=True)
            try: os.remove(tmp_zip)
            except: pass
            return _t("import_no_manifest")

        with open(manifest, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict):
            imp_memes = data.get("memes", [])
            imp_cats = data.get("categories", [])
        else:
            imp_memes = data or []
            imp_cats = []

        cur_memes, cur_cats = _load_db()
        meme_dir = self.get_meme_dir()
        existing_names = set(os.path.basename(m.get("filepath", "")) for m in cur_memes)

        added = 0
        for m in imp_memes:
            rel = m.get("filepath", "") or m.get("filename", "")
            if not rel:
                continue
            src_name = os.path.basename(rel)
            # ZIP может быть собран как с папкой media/, так и без неё.
            src = os.path.join(tmp_dir, "media", src_name)
            if not os.path.exists(src):
                src = os.path.join(tmp_dir, src_name)
                if not os.path.exists(src):
                    continue

            dst_name = src_name
            base, ext = os.path.splitext(src_name)
            i = 1
            while (dst_name in existing_names
                   or os.path.exists(os.path.join(meme_dir, dst_name))):
                dst_name = f"{base}_{i}{ext}"
                i += 1
            dst = os.path.join(meme_dir, dst_name)
            try:
                shutil.copy2(src, dst)
            except:
                continue
            existing_names.add(dst_name)
            new_m = dict(m)
            new_m["filename"] = dst_name
            new_m["filepath"] = dst
            cur_memes.append(new_m)
            added += 1

        for c in imp_cats:
            if c and c not in cur_cats and len(cur_cats) < MAX_CATEGORIES:
                cur_cats.append(c)

        _save_db(cur_memes, cur_cats)

        shutil.rmtree(tmp_dir, ignore_errors=True)
        try: os.remove(tmp_zip)
        except: pass

        return _t("import_done", added=added)

    def _on_clear_click(self, view):
        activity = self._get_activity()
        memes, cats = _load_db()

        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("clear_title"))
        builder.setMessage(_t("clear_message", memes=len(memes), cats=len(cats)))

        plugin = self

        class DL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def onClick(s, d, w):
                try:
                    for m in memes:
                        fp = m.get("filepath", "")
                        if fp and os.path.exists(fp):
                            try:
                                os.remove(fp)
                            except:
                                pass
                    _save_db([], [])
                    try:
                        plugin._thumb_cache.clear()
                    except:
                        pass
                    BulletinHelper.show_success(_t("clear_done"))
                except Exception as e:
                    BulletinHelper.show_success(_t("error_prefix", e=e))

        builder.setPositiveButton(_t("btn_delete"), DL())
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _on_reset_onboarding_click(self, view):
        try:
            self.set_setting("tutorial_done", False)
            try:
                settings = _load_settings()
                settings["onboarding_done"] = False
                settings["tutorial_done"] = False
                _save_settings(settings)
            except:
                pass
            BulletinHelper.show_success(_t("onboarding_reset"))
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _get_local_file_path(self, msg):
        try:
            media = msg.messageOwner.media
            if not media:
                return None
            fl = FileLoader.getInstance(msg.currentAccount)
            if hasattr(media, 'document') and media.document:
                p = fl.getPathToAttach(media.document, True)
                if p and p.exists():
                    return str(p.getAbsolutePath())
            if hasattr(media, 'photo') and media.photo:
                ps = FileLoader.getClosestPhotoSizeWithSize(media.photo.sizes, 1000)
                if ps:
                    p = fl.getPathToAttach(ps, True)
                    if p and p.exists():
                        return str(p.getAbsolutePath())
        except:
            pass
        return None

    def _notify_after(self, text, delay=250):
        """Delay даёт новому sheet появиться, чтобы BulletinHelper auto-detect
        привязал bulletin к нему, а не к фрагменту под ним."""
        class _R(dynamic_proxy(Runnable)):
            def run(s):
                try:
                    BulletinHelper.show_success(text)
                except:
                    pass
        try:
            AndroidUtilities.runOnUIThread(_R(), delay)
        except:
            try:
                BulletinHelper.show_success(text)
            except:
                pass

    def _drag_handle(self, activity):
        container = FrameLayout(activity)
        handle = View(activity)
        try:
            handle.setBackground(self._rounded_bg(Theme.getColor(Theme.key_dialogGrayLine), 2))
        except:
            pass
        container.addView(handle, FrameLayout.LayoutParams(
            AndroidUtilities.dp(36), AndroidUtilities.dp(4), Gravity.CENTER_HORIZONTAL))
        return container

    def _get_bright_accent_color(self):
        try:
            return Theme.getColor(Theme.key_featuredStickers_addButton)
        except:
            try:
                return Theme.getColor(Theme.key_windowBackgroundWhiteBlueButton)
            except:
                return Theme.getColor(Theme.key_chats_actionBackground)

    def _make_chip(self, activity, label, active=False):
        """Возвращает (chip, bg_drawable). bg_drawable передаётся наружу
        для анимации corner radius при активации (pill → квадрат)."""
        chip = TextView(activity)
        chip.setText(label)
        chip.setTextSize(1, 13.0)
        chip.setSingleLine(True)
        chip.setGravity(Gravity.CENTER)
        chip.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(6), AndroidUtilities.dp(12), AndroidUtilities.dp(6))
        chip.setClickable(True)
        chip.setFocusable(True)
        bg = None
        try:
            bg = GradientDrawable()
            # Стартуем с pill (dp16); _morph_chip_active анимирует до dp6 при выборе.
            bg.setCornerRadius(AndroidUtilities.dp(16))
            if active:
                bg.setColor(self._get_bright_accent_color())
                try:
                    chip.setTextColor(Theme.getColor(Theme.key_chats_actionIcon))
                except:
                    chip.setTextColor(COLOR_WHITE)
            else:
                bg.setColor(Theme.getColor(Theme.key_dialogSearchBackground))
                chip.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            chip.setBackground(bg)
        except:
            pass

        # Анимация нажатия/отпускания: scale pop — тактильный отклик
        try:
            class _CT(dynamic_proxy(View.OnTouchListener)):
                def onTouch(s, v, event):
                    try:
                        action = event.getAction()
                        if action == MotionEvent.ACTION_DOWN:
                            v.animate().scaleX(0.92).scaleY(0.92).setDuration(50).start()
                        elif action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            class _Back(dynamic_proxy(Runnable)):
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(70).start()
                                    except:
                                        pass
                            v.animate().scaleX(1.04).scaleY(1.04).setDuration(35).withEndAction(
                                _Back()
                            ).start()
                    except:
                        pass
                    return False
            chip.setOnTouchListener(_CT())
        except:
            pass

        return chip, bg

    def _rounded_bg(self, color, radius_dp, stroke_w=0, stroke_color=0):
        d = GradientDrawable()
        d.setCornerRadius(AndroidUtilities.dp(radius_dp))
        d.setColor(color)
        if stroke_w:
            d.setStroke(AndroidUtilities.dp(stroke_w), stroke_color)
        return d

    def _btn_listener(self, fn):
        class _L(dynamic_proxy(View.OnClickListener)):
            def onClick(s, v):
                fn(v)
        return _L()

    def _dlg_listener(self, fn):
        class _L(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def onClick(s, d, w):
                fn()
        return _L()

    def _styled_input(self, activity, hint, text="", singleline=True):
        inp = EditTextBoldCursor(activity)
        inp.setInputType(InputType.TYPE_CLASS_TEXT)
        inp.setHint(hint)
        if text:
            inp.setText(text)
        inp.setSingleLine(singleline)
        inp.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        inp.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        inp.setTextSize(1, 16.0)
        try:
            inp.setCursorColor(Theme.getColor(Theme.key_dialogTextLink))
        except:
            pass
        try:
            inp.setBackground(self._rounded_bg(Theme.getColor(Theme.key_dialogSearchBackground), R_INPUT))
            inp.setPadding(
                AndroidUtilities.dp(PAD_INPUT_H), AndroidUtilities.dp(PAD_INPUT_V),
                AndroidUtilities.dp(PAD_INPUT_H), AndroidUtilities.dp(PAD_INPUT_V))
        except:
            pass
        return inp

    def _build_meme_form(self, activity, path, initial_category, initial_description, categories):
        """Возвращает (container, cat_inp, desc_inp) — общая форма для save/edit."""
        from android.text import InputFilter

        container = LinearLayout(activity)
        container.setOrientation(LinearLayout.VERTICAL)
        pad = AndroidUtilities.dp(PAD_DIALOG)
        container.setPadding(pad, AndroidUtilities.dp(GAP_SECTION), pad, AndroidUtilities.dp(GAP_SECTION))

        if path and os.path.exists(path):
            try:
                bmp = self._thumb(path, 0)
                if bmp:
                    max_w = AndroidUtilities.dp(300)
                    if bmp.getWidth() > max_w:
                        r = max_w / bmp.getWidth()
                        bmp = Bitmap.createScaledBitmap(bmp, max_w, int(bmp.getHeight() * r), True)
                    pv = ImageView(activity)
                    pv.setImageBitmap(bmp)
                    pv.setScaleType(ImageView.ScaleType.CENTER_CROP)
                    try:
                        pv.setBackground(self._rounded_bg(0, R_CARD))
                        pv.setClipToOutline(True)
                    except:
                        pass
                    plp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(160))
                    plp.setMargins(0, 0, 0, AndroidUtilities.dp(16))
                    container.addView(pv, plp)
            except:
                pass

        cat_inp = self._styled_input(activity, _t("form_category_hint"), initial_category or "")
        try:
            cat_inp.setFilters([InputFilter.LengthFilter(MAX_CATEGORY_LEN)])
        except:
            pass
        catlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        catlp.setMargins(0, 0, 0, AndroidUtilities.dp(GAP_SECTION))
        container.addView(cat_inp, catlp)

        if categories:
            hscroll = HorizontalScrollView(activity)
            hscroll.setHorizontalScrollBarEnabled(False)
            chip_row = LinearLayout(activity)
            chip_row.setOrientation(LinearLayout.HORIZONTAL)
            for cat_name in categories:
                chip, _ = self._make_chip(activity, cat_name, False)
                def _make_handler(c):
                    def _h(v):
                        cat_inp.setText(c)
                        try:
                            cat_inp.setSelection(len(c))
                        except:
                            pass
                    return _h
                chip.setOnClickListener(OnClickListener(_make_handler(cat_name)))
                clp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                clp.setMargins(0, 0, AndroidUtilities.dp(6), 0)
                chip_row.addView(chip, clp)
            hscroll.addView(chip_row)
            hslp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            hslp.setMargins(0, 0, 0, AndroidUtilities.dp(16))
            container.addView(hscroll, hslp)

        desc_inp = self._styled_input(activity, _t("form_description_hint"), initial_description or "", singleline=False)
        container.addView(desc_inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

        return container, cat_inp, desc_inp

    def _pick_from_gallery(self, activity):
        from android.content import Intent
        plugin = self

        def callback(uri):
            run_on_ui_thread(lambda: plugin._save_from_gallery_uri(activity, uri))

        self._activity_callbacks[GALLERY_REQ] = callback
        try:
            intent = Intent(Intent.ACTION_GET_CONTENT)
            intent.setType("*/*")
            try:
                from java import jarray
                from java.lang import String
                intent.putExtra(Intent.EXTRA_MIME_TYPES,
                                jarray(String)(["image/*", "video/*"]))
            except:
                intent.setType("image/*")   # fallback если jarray недоступен
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            activity.startActivityForResult(intent, GALLERY_REQ)
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _save_from_gallery_uri(self, activity, uri):
        try:
            from java.io import FileOutputStream
            cr   = activity.getContentResolver()
            mime = cr.getType(uri) or "image/jpeg"
            lm = mime.lower()
            if "gif" in lm:                    ext = ".gif"
            elif "png" in lm:                  ext = ".png"
            elif "webp" in lm:                 ext = ".webp"
            elif "mp4" in lm:                  ext = ".mp4"
            elif "webm" in lm:                 ext = ".webm"
            elif "3gp" in lm:                  ext = ".3gp"
            elif "avi" in lm:                  ext = ".avi"
            elif "quicktime" in lm or "mov" in lm: ext = ".mov"
            elif "video" in lm:                ext = ".mp4"
            else:                              ext = ".jpg"
            temp_path = os.path.join(self.get_meme_dir(), f"gallery_{int(time.time())}{ext}")
            in_s = cr.openInputStream(uri)
            out  = FileOutputStream(temp_path)
            buf  = bytearray(8192)
            while True:
                n = in_s.read(buf)
                if n < 0:
                    break
                out.write(buf, 0, n)
            in_s.close()
            out.close()
            self.handle_save_meme({'filepath': temp_path})
        except Exception as e:
            BulletinHelper.show_success(_t("import_error", e=e))

    def handle_save_meme(self, context):
        message = context.get('message')
        activity = self._get_activity()

        path = context.get('filepath')
        if not path and message:
            path = self._get_local_file_path(message)
            if not path:
                try:
                    fp = FileLoader.getInstance(message.currentAccount).getPathToMessage(message.messageOwner)
                    if fp and fp.exists():
                        path = str(fp.getAbsolutePath())
                except:
                    pass
        if not path:
            BulletinHelper.show_success(_t("save_file_not_found"))
            return

        memes, categories = _load_db()

        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("save_title"))
        container, cat_inp, desc_inp = self._build_meme_form(activity, path, "", "", categories)
        builder.setView(container)

        plugin = self
        def save():
            cat = cat_inp.getText().toString().strip()[:MAX_CATEGORY_LEN]
            desc = desc_inp.getText().toString().strip()
            with _db_txn() as t:
                if cat and cat not in t.cats:
                    if len(t.cats) >= MAX_CATEGORIES:
                        BulletinHelper.show_success(_t("category_limit", max=MAX_CATEGORIES))
                        t.cancel()
                        return
                    t.cats.append(cat)
                ext = os.path.splitext(path)[1] or ".jpg"
                td = plugin.get_meme_dir()
                nf = f"meme_{int(time.time())}{ext}"
                np = os.path.join(td, nf)
                with open(path, 'rb') as s, open(np, 'wb') as d:
                    d.write(s.read())
                t.memes.append({
                    "filename": nf, "filepath": np,
                    "tags": desc, "category": cat,
                    "timestamp": time.time(), "favorite": False
                })
            if not t.cancelled:
                BulletinHelper.show_success(_t("save_done"))
                try:
                    if hasattr(plugin, '_active_sheet') and plugin._active_sheet and plugin._active_sheet.isShowing():
                        plugin._active_sheet.dismiss()
                        run_on_ui_thread(lambda: plugin.handle_open_library({'dialog_id': getattr(plugin, '_current_dialog_id', 0)}))
                except: pass

        builder.setPositiveButton(_t("btn_save"), self._dlg_listener(save))
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def handle_open_library(self, context):
        try:
            activity = self._get_activity()
            dialog_id = context.get('dialog_id') or 0
            memes, categories = _load_db()
            self._selected = set()
            self._current_dialog_id = dialog_id

            # Исключаем папку мемов из галереи при первом открытии / смене директории
            self._ensure_nomedia_scan(self.get_meme_dir())

            # Читаем флаг туториала из SDK-настроек (надёжнее JSON-файла)
            tutorial_done = self.get_setting("tutorial_done", False)
            if not tutorial_done:
                # Обратная совместимость: мигрируем из старого JSON-файла
                try:
                    old = _load_settings()
                    if old.get("tutorial_done", False):
                        self.set_setting("tutorial_done", True)
                        tutorial_done = True
                except:
                    pass

            if not tutorial_done:
                self._show_tutorial_sheet(activity, memes)
            else:
                self._show_library_sheet(activity, memes)
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

