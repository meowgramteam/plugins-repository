        t3.setTypeface(Typeface.DEFAULT_BOLD)
        t3.setGravity(Gravity.CENTER)
        tlp3 = LinearLayout.LayoutParams(-1, -2)
        tlp3.setMargins(0, AndroidUtilities.dp(4), 0, 0)
        title_area.addView(t3, tlp3)

