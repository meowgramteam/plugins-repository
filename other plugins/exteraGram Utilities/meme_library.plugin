        # --- SPACER 1 ---
        spacer1 = View(activity)
        content_layout.addView(spacer1, LinearLayout.LayoutParams(-1, 0, 1.0))

        # --- IMAGE AREA ---
        image_area = FrameLayout(activity)

        welcome_sticker = BackupImageView(activity)
        welcome_sticker.setRoundRadius(AndroidUtilities.dp(12))
        w_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(230), AndroidUtilities.dp(230), Gravity.CENTER)
        image_area.addView(welcome_sticker, w_lp)

        tutorial_sticker = BackupImageView(activity)
        tutorial_sticker.setRoundRadius(AndroidUtilities.dp(12))
        t_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(185), AndroidUtilities.dp(370), Gravity.CENTER)
        image_area.addView(tutorial_sticker, t_lp)

        features_sticker = BackupImageView(activity)
        features_sticker.setRoundRadius(AndroidUtilities.dp(12))
        f_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(145), AndroidUtilities.dp(145), Gravity.CENTER)
        image_area.addView(features_sticker, f_lp)

        content_layout.addView(image_area, LinearLayout.LayoutParams(-1, -2))

        # --- SPACER 2 ---
        spacer2 = View(activity)
        content_layout.addView(spacer2, LinearLayout.LayoutParams(-1, 0, 1.0))

        btn = TextView(activity)
        btn.setTextSize(1, 16.0)
        btn.setTextColor(COLOR_WHITE)
        btn.setGravity(Gravity.CENTER)
        btn.setTypeface(Typeface.DEFAULT_BOLD)
        try:
            bg = Theme.createSimpleSelectorRoundRectDrawable(
                AndroidUtilities.dp(12),
                self._get_bright_accent_color(),
                Theme.getColor(Theme.key_listSelector)
            )
            btn.setBackground(bg)
        except:
            pass
        btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
        btn.setClickable(True)
        btn.setFocusable(True)
        
        blp = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM)
        blp.setMargins(AndroidUtilities.dp(24), 0, AndroidUtilities.dp(24), AndroidUtilities.dp(24))
        base_frame.addView(btn, blp)

        slides = [
            {"type": "welcome", "pack": "gehirnfullIcons", "index": 0, "btn": _t("slide_btn_start")},
            {"type": "tutorial", "title": _t("slide_title_1"), "pack": "gehirnfullIcons", "index": 2, "btn": _t("slide_btn_next")},
            {"type": "tutorial", "title": _t("slide_title_2"), "pack": "gehirnfullIcons", "index": 3, "btn": _t("slide_btn_next")},
            {"type": "tutorial", "title": _t("slide_title_3"), "pack": "gehirnfullIcons", "index": 4, "btn": _t("slide_btn_next")},
            {"type": "features", "pack": "gehirnfullIcons", "index": 5, "btn": _t("slide_btn_finish")},
        ]
        
        current_slide = [0]
        
        def _update_slide():
            idx = current_slide[0]
            if idx < len(slides):
                slide = slides[idx]
                stype = slide.get("type", "tutorial")
                if slide.get("is_welcome"): stype = "welcome"
                
                title_area.setVisibility(View.VISIBLE if stype == "welcome" else View.GONE)
                slide_title.setVisibility(View.VISIBLE if stype == "tutorial" else View.GONE)
                features_text_area.setVisibility(View.VISIBLE if stype == "features" else View.GONE)
                
                welcome_sticker.setVisibility(View.VISIBLE if stype == "welcome" else View.GONE)
                tutorial_sticker.setVisibility(View.VISIBLE if stype == "tutorial" else View.GONE)
                features_sticker.setVisibility(View.VISIBLE if stype == "features" else View.GONE)
                
                try:
                    mdc = MediaDataController.getInstance(UserConfig.selectedAccount)
                    if stype == "welcome":
                        mdc.setPlaceholderImageByIndex(welcome_sticker, slide["pack"], slide["index"], "230_230")
                    elif stype == "features":
                        mdc.setPlaceholderImageByIndex(features_sticker, slide["pack"], slide["index"], "145_145")
                    else:
                        slide_title.setText(slide["title"])
                        mdc.setPlaceholderImageByIndex(tutorial_sticker, slide["pack"], slide["index"], "185_370")
                except:
                    pass
                
                btn.setText(slide["btn"])
                
                try:
                    target_sticker = welcome_sticker if stype == "welcome" else (features_sticker if stype == "features" else tutorial_sticker)
                    target_sticker.setScaleX(0.8)
                    target_sticker.setScaleY(0.8)
                    target_sticker.animate().scaleX(1.0).scaleY(1.0).setDuration(200).start()
                except:
                    pass

        _update_slide()

        sheet = BottomSheet(activity, False)
        sheet.setCustomView(main_root)
        
        class _OnNext(dynamic_proxy(View.OnClickListener)):
            def onClick(s, v):
                current_slide[0] += 1
                if current_slide[0] >= len(slides):
                    try:
                        plugin.set_setting("tutorial_done", True)
                    except: pass
                    sheet.dismiss()
                    run_on_ui_thread(lambda: plugin._show_library_sheet(activity, db))
                else:
                    _update_slide()
                    
        btn.setOnClickListener(_OnNext())
        sheet.show()

    def _icon_button_touch_anim(self, view):
        try:
            class _T(dynamic_proxy(View.OnTouchListener)):
                def onTouch(s, v, event):
                    try:
                        action = event.getAction()
                        if action == MotionEvent.ACTION_DOWN:
                            v.animate().scaleX(0.82).scaleY(0.82).setDuration(60).start()
                        elif action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            class _S(dynamic_proxy(Runnable)):
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(90).start()
                                    except:
                                        pass
                            v.animate().scaleX(1.12).scaleY(1.12).setDuration(50).withEndAction(
                                _S()
                            ).start()
                    except:
                        pass
                    return False
            view.setOnTouchListener(_T())
        except:
            pass

    def _lib_build_header(self, activity):
        """Возвращает (header_row, back_btn, title, fav_btn). Иконка fav_btn
        и видимость back_btn выставляются caller'ом в _update_mode_ui."""
        header_row = LinearLayout(activity)
        header_row.setOrientation(LinearLayout.HORIZONTAL)
        header_row.setGravity(Gravity.CENTER_VERTICAL)

        back_btn = ImageView(activity)
        back_icon_id = _safe_drawable('msg_arrow_back')
        if back_icon_id:
            back_btn.setImageResource(back_icon_id)
        try:
            back_btn.setColorFilter(Theme.getColor(Theme.key_dialogTextBlack))
        except:
            pass
        back_btn.setScaleType(ImageView.ScaleType.CENTER)
        back_btn.setClickable(True)
        back_btn.setFocusable(True)
        back_btn.setVisibility(View.GONE)
        back_btn.setPadding(0, AndroidUtilities.dp(4), AndroidUtilities.dp(8), AndroidUtilities.dp(4))
        blp = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
        blp.setMargins(0, 0, AndroidUtilities.dp(4), 0)
        self._icon_button_touch_anim(back_btn)
        header_row.addView(back_btn, blp)

        title = TextView(activity)
        title.setTextSize(1, 24.0)
        title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        title.setTypeface(Typeface.DEFAULT_BOLD)
        header_row.addView(title, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

        fav_btn = ImageView(activity)
        try:
            fav_btn.setColorFilter(self._get_bright_accent_color())
        except:
            pass
        fav_btn.setScaleType(ImageView.ScaleType.CENTER)
        fav_btn.setClickable(True)
        fav_btn.setFocusable(True)
        fav_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
        self._icon_button_touch_anim(fav_btn)
        header_row.addView(fav_btn, LinearLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(44)))

        return header_row, back_btn, title, fav_btn

    def _lib_build_search_field(self, activity):
        sf = EditTextBoldCursor(activity)
        sf.setHint(_t("lib_search_hint"))
        sf.setInputType(InputType.TYPE_CLASS_TEXT)
        sf.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        sf.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        sf.setTextSize(1, 15.0)
        sf.setSingleLine(True)
        sf.setFocusable(True)
        sf.setFocusableInTouchMode(True)
        try:
            sf.setBackground(self._rounded_bg(Theme.getColor(Theme.key_dialogSearchBackground), R_INPUT))
            sf.setPadding(AndroidUtilities.dp(PAD_INPUT_H), AndroidUtilities.dp(10), AndroidUtilities.dp(PAD_INPUT_H), AndroidUtilities.dp(10))
        except:
            pass
        return sf

    def _lib_build_morph_fab(self, activity):
        """Два иконочных слоя кросс-фейдятся (add ↔ send) поверх непрерывно видимого
        фона — без визуальных «дыр» в момент переключения.
        Возвращает (morph_btn, morph_bg, icon_add, icon_send, btn_size)."""
        btn_size = AndroidUtilities.dp(48)
        morph_btn = FrameLayout(activity)
        morph_bg = GradientDrawable()
        morph_bg.setCornerRadius(float(AndroidUtilities.dp(R_CARD)))
        morph_bg.setColor(self._get_bright_accent_color())
        morph_btn.setBackground(morph_bg)
        try:
            morph_btn.setElevation(AndroidUtilities.dp(2))
        except:
            pass
        morph_btn.setClickable(True)
        morph_btn.setFocusable(True)

        icon_add = ImageView(activity)
        icon_add.setImageResource(R.drawable.filled_add_sticker)
        icon_add.setScaleType(ImageView.ScaleType.CENTER)
        try:
            icon_add.setColorFilter(Theme.getColor(Theme.key_chats_actionIcon))
        except:
            pass
        icon_add.setAlpha(1.0)
        morph_btn.addView(icon_add, FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT))

        icon_send = ImageView(activity)
        icon_send.setImageResource(R.drawable.attach_send)
        icon_send.setScaleType(ImageView.ScaleType.CENTER)
        try:
            icon_send.setColorFilter(Theme.getColor(Theme.key_chats_actionIcon))
        except:
            pass
        icon_send.setAlpha(0.0)
        morph_btn.addView(icon_send, FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT))

        try:
            class _FabTouch(dynamic_proxy(View.OnTouchListener)):
                def onTouch(s, v, event):
                    try:
                        action = event.getAction()
                        if action == MotionEvent.ACTION_DOWN:
                            v.animate().scaleX(0.87).scaleY(0.87).setDuration(70).start()
                        elif action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            class _FabSettle(dynamic_proxy(Runnable)):
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(110).start()
                                    except:
                                        pass
                            v.animate().scaleX(1.03).scaleY(1.03).setDuration(55).withEndAction(
                                _FabSettle()
                            ).start()
                    except:
                        pass
                    return False
            morph_btn.setOnTouchListener(_FabTouch())
        except:
            pass

        return morph_btn, morph_bg, icon_add, icon_send, btn_size

    def _morph_chip_active(self, bg_drawable):
        try:
            from android.animation import ValueAnimator
            from_r = float(AndroidUtilities.dp(16))
            to_r = float(AndroidUtilities.dp(6))
            anim = ValueAnimator.ofFloat(from_r, to_r)
            anim.setDuration(150)
            class _MUL(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                def __init__(s, d):
                    super().__init__()
                    s.d = d
                def onAnimationUpdate(s, a):
                    try:
                        s.d.setCornerRadius(float(a.getAnimatedValue()))
                    except:
                        pass
            anim.addUpdateListener(_MUL(bg_drawable))
            anim.start()
        except:
            try:
                bg_drawable.setCornerRadius(float(AndroidUtilities.dp(6)))
            except:
                pass

    def _show_library_sheet(self, activity, db, title_override=None, favorites_only=False):
        plugin = self
        plugin._selected = set()

        # Загружаем категории заново (могут отличаться от тех, что были на сохранении)
        _, categories = _load_db()

        root = LinearLayout(activity)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setFitsSystemWindows(False)
        pad = AndroidUtilities.dp(PAD_SHEET)
        root.setPadding(pad, 0, pad, 0)
        # LayoutTransition даёт плавное скрытие chip_scroll при переходе в «Избранное».
        try:
            lt_root = LayoutTransition()
            lt_root.setDuration(180)
            root.setLayoutTransition(lt_root)
        except:
            pass

        drag_handle_container = self._drag_handle(activity)
        dclp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(20))
        dclp.setMargins(0, AndroidUtilities.dp(8), 0, 0)
        root.addView(drag_handle_container, dclp)

        header_row, back_btn, title, fav_btn = self._lib_build_header(activity)
        hrlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        hrlp.setMargins(0, AndroidUtilities.dp(GAP_ITEM), 0, AndroidUtilities.dp(GAP_SECTION))
        root.addView(header_row, hrlp)

        sf = self._lib_build_search_field(activity)
        slp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        slp.setMargins(0, 0, 0, AndroidUtilities.dp(10))
        root.addView(sf, slp)

        chip_scroll = HorizontalScrollView(activity)
        chip_scroll.setHorizontalScrollBarEnabled(False)
        chip_row = LinearLayout(activity)
        chip_row.setOrientation(LinearLayout.HORIZONTAL)
        chip_scroll.addView(chip_row, LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
        cslp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        cslp.setMargins(0, 0, 0, AndroidUtilities.dp(10))
        root.addView(chip_scroll, cslp)

        content_frame = FrameLayout(activity)
        content_frame.setFitsSystemWindows(False)
        cflp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(400))
        cflp.setMargins(0, AndroidUtilities.dp(GAP_ITEM), 0, 0)
        root.addView(content_frame, cflp)

        scroll = ScrollView(activity)
        scroll.setClipToPadding(False)
        scroll.setClipChildren(False)  # cell scale-pop вылезает за границы scroll
        scroll.setPadding(0, AndroidUtilities.dp(8), 0,
        AndroidUtilities.dp(64))
        content_frame.addView(scroll, FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT))

        # Не даём BottomSheet перехватывать вертикальный свайп грида — иначе шторка
        # закрывается при скролле. Закрытие остаётся через drag-handle и tap-outside.
        try:
            class ScrollGuard(dynamic_proxy(View.OnTouchListener)):
                def onTouch(s, v, event):
                    try:
                        action = event.getAction()
                        if action == MotionEvent.ACTION_DOWN:
                            v.getParent().requestDisallowInterceptTouchEvent(True)
                        elif action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            v.getParent().requestDisallowInterceptTouchEvent(False)
                    except:
                        pass
                    return False
            scroll.setOnTouchListener(ScrollGuard())
        except:
            pass

        grid = LinearLayout(activity)
        grid.setOrientation(LinearLayout.VERTICAL)
        grid.setClipChildren(False)
        grid.setClipToPadding(False)
        scroll.addView(grid, FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT))

        overlay_row = FrameLayout(activity)
        overlay_row_lp = FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(56), Gravity.BOTTOM)
        overlay_row_lp.setMargins(AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12), AndroidUtilities.dp(16))
        content_frame.addView(overlay_row, overlay_row_lp)

        send_count = TextView(activity)
        send_count.setText(_t("lib_selected_count", count=0))
        send_count.setTextSize(1, 13.0)
        send_count.setGravity(Gravity.CENTER)
        try:
            send_count.setBackground(self._rounded_bg(Theme.getColor(Theme.key_dialogBackground), R_CHIP))
            send_count.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        except:
            send_count.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
        send_count.setPadding(
            AndroidUtilities.dp(10), AndroidUtilities.dp(5),
            AndroidUtilities.dp(10), AndroidUtilities.dp(5))
        send_count.setAlpha(0.0)
        send_count.setVisibility(View.GONE)
        overlay_row.addView(send_count, FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.WRAP_CONTENT, FrameLayout.LayoutParams.WRAP_CONTENT,
            Gravity.START | Gravity.CENTER_VERTICAL))

        morph_btn, morph_bg, icon_add, icon_send, btn_size = self._lib_build_morph_fab(activity)
        mlp = FrameLayout.LayoutParams(btn_size, btn_size, Gravity.END | Gravity.CENTER_VERTICAL)
        mlp.setMargins(0, 0, AndroidUtilities.dp(4), 0)
        overlay_row.addView(morph_btn, mlp)

        morph_state = ['add']  # 'add' | 'send'

        # needFocus=True обязательно — без него клавиатура не вызывается из листа.
        sheet = BottomSheet(activity, True)
        sheet.setCustomView(root)
        plugin._active_sheet = sheet

        state = {
            'cells': {},
            'overlays': {},     # fp → sel_drawable, нужен для animated alpha обводки
            'filtered': [],
            'query': '',
            'category': None,   # None = "Все"
            'favorites_only': favorites_only,
        }

        def _update_mode_ui():
            mode_label = _t("lib_favorites_title") if state['favorites_only'] else (title_override or _t("library_label"))
            cnt = len(state['filtered'])
            if state['category'] is not None and not state['favorites_only']:
                line1 = f"{mode_label} —\n"
                line2 = f"{state['category']} ({cnt})"
                try:
                    ssb = SpannableStringBuilder(line1 + line2)
                    span_start = len(line1)
                    span_end = span_start + len(line2)
                    accent = self._get_bright_accent_color()
                    ssb.setSpan(
                        ForegroundColorSpan(accent),
                        span_start, span_end,
                        Spanned.SPAN_EXCLUSIVE_EXCLUSIVE
                    )
                    ssb.setSpan(
                        StyleSpan(Typeface.ITALIC),
                        span_start, span_end,
                        Spanned.SPAN_EXCLUSIVE_EXCLUSIVE
                    )
                    title.setText(ssb)
                except:
                    title.setText(line1 + line2)
            else:
                title.setText(f"{mode_label} ({cnt})")
            chip_scroll.setVisibility(View.GONE if state['favorites_only'] else View.VISIBLE)
            back_btn.setVisibility(View.VISIBLE if state['favorites_only'] else View.GONE)
            if state['favorites_only']:
                icon_id = _safe_drawable('msg_fave', 'msg_star', 'msg_star_outline', 'msg_bookmark')
            else:
                icon_id = _safe_drawable('msg_star_outline', 'msg_star', 'msg_fave', 'msg_bookmark')
            if icon_id:
                fav_btn.setImageResource(icon_id)

        def _apply_filters():
            favs_only = state['favorites_only']
            base = [m for m in db if m.get("favorite", False)] if favs_only else list(db)
            if state['category'] is not None:
                base = [m for m in base if m.get("category", "") == state['category']]
            q = state['query']
            if q:
                base = [m for m in base if _match_description(m.get("tags", ""), q)]
            state['filtered'] = base
            state['cells'] = {}
            state['overlays'] = {}  # старые drawable'ы привязаны к удалённым cell'ам.
            grid.removeAllViews()
            if favs_only:
                empty_text = _t("lib_empty_favorites")
            elif not db:
                empty_text = _t("lib_empty_library")
            else:
                empty_text = _t("lib_empty_search")
            plugin._fill_grid_v2(
                activity, grid, base, db, sheet, state,
                lambda: _update_selection(),
                empty_text=empty_text,
                refresh_fn=_apply_filters,
                notify_fn=lambda msg: _bulletin_over_sheet(sheet, msg),
            )
            _update_mode_ui()

        def _bulletin_over_sheet(s, msg):
            try:
                from org.telegram.ui.Components import BulletinFactory
                fragment = get_last_fragment()
                rp = fragment.getResourceProvider() if fragment else None
                BulletinFactory.of(s.container, rp).createSimpleBulletin(
                    R.raw.chats_infotip, msg
                ).show(True)
            except Exception:
                BulletinHelper.show_success(msg)

        def _animate_morph(target):
            try:
                from android.animation import ValueAnimator
                from_dp = float(AndroidUtilities.dp(R_FAB if morph_state[0] == 'send' else R_CARD))
                to_dp = float(AndroidUtilities.dp(R_FAB if target == 'send' else R_CARD))
                anim = ValueAnimator.ofFloat(from_dp, to_dp)
                anim.setDuration(240)
                class _UL(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                    def onAnimationUpdate(s, a):
                        try:
                            morph_bg.setCornerRadius(float(a.getAnimatedValue()))
                        except:
                            pass
                anim.addUpdateListener(_UL())
                anim.start()
            except:
                try:
                    morph_bg.setCornerRadius(float(AndroidUtilities.dp(R_FAB if target == 'send' else R_CARD)))
                except:
                    pass

            try:
                if target == 'send':
                    icon_add.animate().alpha(0.0).setDuration(220).start()
                    icon_send.animate().alpha(1.0).setDuration(220).start()
                else:
                    icon_send.animate().alpha(0.0).setDuration(220).start()
                    icon_add.animate().alpha(1.0).setDuration(220).start()
            except:
                if target == 'send':
                    icon_add.setAlpha(0.0); icon_send.setAlpha(1.0)
                else:
                    icon_send.setAlpha(0.0); icon_add.setAlpha(1.0)

        def _update_selection():
            cnt = len(plugin._selected)
            target = 'send' if cnt > 0 else 'add'
            if target != morph_state[0]:
                _animate_morph(target)
                morph_state[0] = target

            if cnt > 0:
                send_count.setText(_t("lib_selected_count", count=cnt))
                if send_count.getVisibility() != View.VISIBLE:
                    send_count.setVisibility(View.VISIBLE)
                try:
                    send_count.animate().alpha(1.0).setDuration(200).start()
                except:
                    send_count.setAlpha(1.0)
            else:
                class _HidePill(dynamic_proxy(Runnable)):
                    def run(s):
                        try:
                            send_count.setVisibility(View.GONE)
                        except:
                            pass
                try:
                    send_count.animate().alpha(0.0).setDuration(200).withEndAction(_HidePill()).start()
                except:
                    send_count.setAlpha(0.0)
                    send_count.setVisibility(View.GONE)

            from android.animation import ValueAnimator
            for fp, sel_drawable in state.get('overlays', {}).items():
                try:
                    is_sel = fp in plugin._selected
                    from_a = sel_drawable.getAlpha()
                    to_a = 255 if is_sel else 0
                    if from_a == to_a:
                        continue
                    anim = ValueAnimator.ofInt(from_a, to_a)
                    anim.setDuration(180)
                    class _UL(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                        def __init__(s, d):
                            super().__init__()
                            s.d = d
                        def onAnimationUpdate(s, a):
                            try:
                                s.d.setAlpha(int(a.getAnimatedValue()))
                            except:
                                pass
                    anim.addUpdateListener(_UL(sel_drawable))
                    anim.start()
                except:
                    pass

        def _rebuild_chips():
            if chip_row is None:
                return
            chip_row.removeAllViews()
            # Подсчёт по категориям
            counts = {}
            for m in db:
                c = m.get("category", "")
                if c:
                    counts[c] = counts.get(c, 0) + 1
            # Sort categories by usage frequency, then alphabetically.
            sorted_cats = sorted(categories, key=lambda c: (-counts.get(c, 0), c.lower()))

            active_bgs = []

            def add(chip_view):
                clp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                clp.setMargins(0, 0, AndroidUtilities.dp(6), 0)
                chip_row.addView(chip_view, clp)

            is_all_active = state['category'] is None
            all_chip, all_bg = self._make_chip(activity, _t("chip_all"), is_all_active)
            if is_all_active and all_bg:
                active_bgs.append(all_bg)
            def _all_click(v):
                state['category'] = None
                _rebuild_chips()
                _apply_filters()
            all_chip.setOnClickListener(OnClickListener(_all_click))
            add(all_chip)

            if len(categories) < MAX_CATEGORIES:
                plus_chip, _ = self._make_chip(activity, "+", False)
                def _plus_click(v):
                    plugin._show_create_category_dialog(activity, sheet, db)
                plus_chip.setOnClickListener(OnClickListener(_plus_click))
                add(plus_chip)

            for cat_name in sorted_cats:
                cnt = counts.get(cat_name, 0)
                label = f"{cat_name} {cnt}" if cnt else cat_name
                is_cat_active = state['category'] == cat_name
                chip, chip_bg = self._make_chip(activity, label, is_cat_active)
                if is_cat_active and chip_bg:
                    active_bgs.append(chip_bg)

                def _make_handler(c):
                    def _h(v):
                        state['category'] = None if state['category'] == c else c
                        _rebuild_chips()
                        _apply_filters()
                    return _h
                chip.setOnClickListener(OnClickListener(_make_handler(cat_name)))

                def _make_long(c):
                    def _h(v):
                        plugin._show_category_actions(activity, sheet, db, c)
                        return True
                    return _h
                chip.setOnLongClickListener(OnLongClickListener(_make_long(cat_name)))

                add(chip)

            for bg in active_bgs:
                plugin._morph_chip_active(bg)

        _rebuild_chips()
        _apply_filters()

        def _on_fav_click(v):
            try:
                state['favorites_only'] = not state['favorites_only']
                state['category'] = None
                _rebuild_chips()
                _apply_filters()
            except Exception as e:
                BulletinHelper.show_success(_t("error_prefix", e=e))
        fav_btn.setOnClickListener(OnClickListener(_on_fav_click))

        def _on_back_click(v):
            try:
                if state['favorites_only']:
                    state['favorites_only'] = False
                    state['category'] = None
                    _rebuild_chips()
                    _apply_filters()
            except Exception as e:
                BulletinHelper.show_success(_t("error_prefix", e=e))
        back_btn.setOnClickListener(OnClickListener(_on_back_click))

        from android.text import TextWatcher
        class SW(dynamic_proxy(TextWatcher)):
            def beforeTextChanged(s, cs, st, c, a): pass
            def onTextChanged(s, cs, st, b, c): pass
            def afterTextChanged(s, ed):
                try:
                    state['query'] = ed.toString().strip().lower()
                    _apply_filters()
                except:
                    pass
        sf.addTextChangedListener(SW())

        def _on_morph_click(v):
            try:
                if morph_state[0] == 'send':
                    if not plugin._selected:
                        return
                    selected_list = list(plugin._selected)
                    dlg_id = plugin._current_dialog_id
                    sheet.dismiss()
                    if dlg_id:
                        run_on_ui_thread(lambda: plugin._send_native(dlg_id, selected_list))
                    else:
                        run_on_ui_thread(lambda: plugin._show_native_forward(activity, selected_list))
                else:
                    plugin._pick_from_gallery(activity)
            except Exception as e:
                BulletinHelper.show_success(_t("error_prefix", e=e))
        morph_btn.setOnClickListener(OnClickListener(_on_morph_click))

        sheet.show()

        # ADJUST_NOTHING — клавиатура накладывается сверху, не толкая sheet вверх.
        try:
            sheet.getWindow().setSoftInputMode(WindowManager.LayoutParams.SOFT_INPUT_ADJUST_NOTHING)
        except:
            pass


    def _thumb(self, fp, size):
        """size > 0 → масштабировать до size×size; size == 0 → нативное разрешение (для превью)."""
        cache_key = (fp, size)
        try:
            cached = self._thumb_cache.get(cache_key)
            if cached is not None:
                return cached
        except:
            pass

        bmp = None
        ext = os.path.splitext(fp)[1].lower()
        if ext in VIDEO_EXTS:
            try:
                from android.media import ThumbnailUtils
                from android.provider import MediaStore
                bmp = ThumbnailUtils.createVideoThumbnail(fp, MediaStore.Images.Thumbnails.MINI_KIND)
            except:
                pass
            if not bmp:
                try:
                    from android.media import MediaMetadataRetriever
                    mmr = MediaMetadataRetriever()
                    mmr.setDataSource(fp)
                    bmp = mmr.getFrameAtTime(0)
                    mmr.release()
                except:
                    pass
        else:
            try:
                # Two-pass decode: bounds-only pass picks inSampleSize so we don't load full bitmap.
                opts = BitmapFactory.Options()
                opts.inJustDecodeBounds = True
                BitmapFactory.decodeFile(fp, opts)
                ow, oh = opts.outWidth, opts.outHeight
                target = size if size > 0 else 1024
                in_sample = 1
                if ow > 0 and oh > 0 and target > 0:
                    while (ow // (in_sample * 2)) >= target and (oh // (in_sample * 2)) >= target:
                        in_sample *= 2
                opts2 = BitmapFactory.Options()
                opts2.inSampleSize = in_sample
                bmp = BitmapFactory.decodeFile(fp, opts2)
            except:
                try:
                    bmp = BitmapFactory.decodeFile(fp)
                except:
                    pass

        if bmp and size > 0:
            try:
                bmp = Bitmap.createScaledBitmap(bmp, size, size, True)
            except:
                pass

        if bmp:
            try:
                self._thumb_cache[cache_key] = bmp
                # Кэп ~200 эскизов; FIFO-сброс 50 самых старых.
                if len(self._thumb_cache) > 200:
                    for k in list(self._thumb_cache.keys())[:50]:
                        self._thumb_cache.pop(k, None)
            except:
                pass
        return bmp

    def _build_play_indicator(self, activity):
        play_indicator = ImageView(activity)
        play_icon_id = _safe_drawable('ic_action_play', 'play_mini_video', 'play')
        if play_icon_id:
            play_indicator.setImageResource(play_icon_id)
        try:
            play_indicator.setColorFilter(-1)  # ARGB white
        except:
            pass
        play_indicator.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
        pip = AndroidUtilities.dp(3)
        play_indicator.setPadding(pip, pip, pip, pip)
        # Не _rounded_bg — нужен OVAL, _rounded_bg делает только прямоугольники.
        try:
            pi_bg = GradientDrawable()
            pi_bg.setShape(GradientDrawable.OVAL)
            pi_bg.setColor(self._get_bright_accent_color())
            play_indicator.setBackground(pi_bg)
        except:
            pass
        return play_indicator

    def _make_cell_touch_listener(self):
        """Тап: bounce 0.93→1.02→1.0. Long-press (>300ms): freeze 0.93 → spring-back."""
        class _CellTouch(dynamic_proxy(View.OnTouchListener)):
            def __init__(s):
                super().__init__()
                s.in_hold = [False]
                s.hold_runner = [None]
            def onTouch(s, v, event):
                try:
                    action = event.getAction()
                    in_hold = s.in_hold
                    hold_runner = s.hold_runner
                    if action == MotionEvent.ACTION_DOWN:
                        in_hold[0] = False
                        v.setTranslationZ(AndroidUtilities.dp(2))
                        v.animate().scaleX(0.93).scaleY(0.93).setDuration(80).start()
                        class _Hold(dynamic_proxy(Runnable)):
                            def __init__(h):
                                super().__init__()
                            def run(r):
                                in_hold[0] = True
                        hold_runner[0] = _Hold()
                        v.postDelayed(hold_runner[0], 300)
                    elif action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                        if hold_runner[0] is not None:
                            v.removeCallbacks(hold_runner[0])
                            hold_runner[0] = None
                        if in_hold[0]:
                            class _HoldBack(dynamic_proxy(Runnable)):
                                def __init__(b):
                                    super().__init__()
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(100).start()
                                        v.setTranslationZ(0)
                                    except:
                                        pass
                            v.animate().scaleX(1.02).scaleY(1.02).setDuration(50).withEndAction(
                                _HoldBack()
                            ).start()
                        else:
                            class _Return(dynamic_proxy(Runnable)):
                                def __init__(ret):
                                    super().__init__()
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(130).start()
                                        v.setTranslationZ(0)
                                    except:
                                        pass
                            class _Bounce(dynamic_proxy(Runnable)):
                                def __init__(b):
                                    super().__init__()
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.02).scaleY(1.02).setDuration(70).withEndAction(
                                            _Return()
                                        ).start()
                                    except:
                                        pass
                            v.animate().scaleX(0.93).scaleY(0.93).setDuration(80).withEndAction(
                                _Bounce()
                            ).start()
                except:
                    pass
                return False
        return _CellTouch()

    def _build_action_row(self, activity, outer, icon_names, label, text_color_key, on_click_fn):
        """Строка действия в меню мема (`_show_meme_actions`): иконка + текст + тач-анимация.
        Кладёт строку прямо в `outer`. Цвет и иконки настраиваются через параметры —
        одна и та же сборка для favorite/edit/delete."""
        ROW_H = AndroidUtilities.dp(48)
        ICON_W = AndroidUtilities.dp(24)
        ICON_TEXT_GAP = AndroidUtilities.dp(16)

        row = LinearLayout(activity)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setClickable(True)
        row.setFocusable(True)
        row.setPadding(AndroidUtilities.dp(PAD_SHEET), 0, AndroidUtilities.dp(PAD_SHEET), 0)
        try:
            class _RT(dynamic_proxy(View.OnTouchListener)):
                def onTouch(s, v, event):
                    try:
                        a = event.getAction()
                        if a == MotionEvent.ACTION_DOWN:
                            v.animate().scaleX(0.965).scaleY(0.965).setDuration(70).start()
                        elif a in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            class _Settle(dynamic_proxy(Runnable)):
                                def run(r):
                                    try:
                                        v.animate().scaleX(1.0).scaleY(1.0).setDuration(100).start()
                                    except:
                                        pass
                            v.animate().scaleX(1.025).scaleY(1.025).setDuration(60).withEndAction(
                                _Settle()
                            ).start()
                    except:
                        pass
                    return False
            row.setOnTouchListener(_RT())
        except:
            pass
        icon_id = _safe_drawable(*icon_names)
        iv = ImageView(activity)
        if icon_id:
            iv.setImageResource(icon_id)
        try:
            iv.setColorFilter(Theme.getColor(text_color_key))
        except:
            pass
        iv.setScaleType(ImageView.ScaleType.CENTER)
        row.addView(iv, LinearLayout.LayoutParams(ICON_W, ICON_W))
        tv = TextView(activity)
        tv.setText(label)
        tv.setTextSize(1, 16.0)
        try:
            tv.setTextColor(Theme.getColor(text_color_key))
        except:
            pass
        ilp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT)
        ilp.setMargins(ICON_TEXT_GAP, 0, 0, 0)
        row.addView(tv, ilp)
        row.setOnClickListener(OnClickListener(on_click_fn))
        outer.addView(row, LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, ROW_H))

    def _fill_grid_v2(self, activity, container, filtered, full_db, sheet, state, update_fn,
                      empty_text=None, refresh_fn=None, notify_fn=None):
        """refresh_fn: перерисовать грид без закрытия шторки (после toggle favorite).
        notify_fn(msg): показать bulletin поверх открытой шторки."""
        COLS = 3
        cell_w = (AndroidUtilities.displaySize.x - AndroidUtilities.dp(48)) // COLS
        th = cell_w - AndroidUtilities.dp(8)
        plugin = self

        if not filtered:
            tv = TextView(activity)
            tv.setText(empty_text if empty_text is not None else _t("lib_empty_search"))
            tv.setTextSize(1, 15.0)
            tv.setGravity(Gravity.CENTER)
            try:
                tv.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
            except:
                pass
            elp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(120))
            elp.setMargins(0, AndroidUtilities.dp(24), 0, 0)
            container.addView(tv, elp)
            return

        row = None
        for idx, meme in enumerate(filtered):
            if idx % COLS == 0:
                row = LinearLayout(activity)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setClipChildren(False)
                rlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                rlp.setMargins(0, 0, 0, AndroidUtilities.dp(4))
                container.addView(row, rlp)

            cell = LinearLayout(activity)
            cell.setOrientation(LinearLayout.VERTICAL)
            cell.setGravity(Gravity.CENTER_HORIZONTAL)
            clp = LinearLayout.LayoutParams(cell_w, LinearLayout.LayoutParams.WRAP_CONTENT)
            clp.setMargins(AndroidUtilities.dp(2), 0, AndroidUtilities.dp(2), 0)
            p = AndroidUtilities.dp(4)
            cell.setPadding(p, p, p, p)

            fp = meme.get("filepath", "")
            state['cells'][fp] = cell

            thumb_holder = FrameLayout(activity)
            try:
                thumb_holder.setBackground(self._rounded_bg(Theme.getColor(Theme.key_dialogSearchBackground), R_CARD))
                thumb_holder.setClipToOutline(True)
            except:
                pass

            img = ImageView(activity)
            img.setScaleType(ImageView.ScaleType.CENTER_CROP)
            try:
                if os.path.exists(fp):
                    bmp = self._thumb(fp, th)
                    if bmp:
                        img.setImageBitmap(bmp)
            except:
                pass
            thumb_holder.addView(img, FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT))

            ext = os.path.splitext(fp)[1].lower()
            if ext in VIDEO_EXTS or ext == '.gif':
                play_indicator = self._build_play_indicator(activity)
                pi_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                pi_lp.gravity = Gravity.BOTTOM | Gravity.END
                pi_lp.setMargins(0, 0, AndroidUtilities.dp(5), AndroidUtilities.dp(5))
                thumb_holder.addView(play_indicator, pi_lp)

            # Selection border анимируется через setAlpha drawable'а — see _update_selection.
            sel_drawable = None
            try:
                sel_drawable = self._rounded_bg(
                    0, R_CHIP,
                    stroke_w=1,
                    stroke_color=self._get_bright_accent_color(),
                )
                sel_drawable.setAlpha(255 if fp in plugin._selected else 0)
                cell.setBackground(sel_drawable)
            except:
                pass
            if sel_drawable is not None:
                state.get('overlays', {})[fp] = sel_drawable

            cell.addView(thumb_holder, LinearLayout.LayoutParams(th, th))

            tv = TextView(activity)
            tv.setText(meme.get("tags", "") or "—")
            tv.setTextSize(1, 11.0)
            tv.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
            tv.setGravity(Gravity.CENTER)
            tv.setMaxLines(1)
            tv.setSingleLine(True)
            tvlp = LinearLayout.LayoutParams(th - AndroidUtilities.dp(12), LinearLayout.LayoutParams.WRAP_CONTENT)
            tvlp.setMargins(0, AndroidUtilities.dp(2), 0, AndroidUtilities.dp(2))
            cell.addView(tv, tvlp)

            row.addView(cell, clp)

            class CC(dynamic_proxy(View.OnClickListener)):
                def __init__(s, fp):
                    super().__init__()
                    s.fp = fp
                def onClick(s, v):
                    if s.fp in plugin._selected:
                        plugin._selected.discard(s.fp)
                    else:
                        plugin._selected.add(s.fp)
                    run_on_ui_thread(update_fn)
            cell.setOnClickListener(CC(fp))

            cell.setOnTouchListener(plugin._make_cell_touch_listener())

            class LC(dynamic_proxy(View.OnLongClickListener)):
                def __init__(s, m):
                    super().__init__()
                    s.m = m
                def onLongClick(s, v):
                    run_on_ui_thread(lambda: plugin._show_meme_actions(
                        activity, s.m, full_db, sheet,
                        refresh_fn=refresh_fn,
                        notify_fn=notify_fn,
                    ))
                    return True
            cell.setOnLongClickListener(LC(meme))
            cell.setClickable(True)

            if fp in plugin._selected:
                try:
                    cell.setBackground(self._rounded_bg(
                        0, R_CHIP,
                        stroke_w=1,
                        stroke_color=self._get_bright_accent_color(),
                    ))
                except:
                    pass

    def _show_meme_actions(self, activity, meme, full_db, sheet, refresh_fn=None, notify_fn=None):
        """refresh_fn: перерисовать грид после toggle favorite, не закрывая шторку.
        notify_fn(msg): bulletin поверх шторки."""
        plugin = self
        is_fav = meme.get("favorite", False)
        filepath = meme.get("filepath", "")

        try:
            builder_ref = [None]

            def _close():
                try:
                    b = builder_ref[0]
                    if b is not None:
                        b.dismiss()
                except:
                    pass

            outer = LinearLayout(activity)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setGravity(Gravity.CENTER_HORIZONTAL)

            preview_ext = os.path.splitext(filepath)[1].lower() if filepath else ''
            file_ok = bool(filepath) and os.path.exists(filepath)
            is_video = file_ok and preview_ext in VIDEO_EXTS
            is_gif = file_ok and preview_ext == '.gif'

            max_w_px = AndroidUtilities.dp(280)
            max_h_px = AndroidUtilities.dp(360)
            min_short_px = AndroidUtilities.dp(160)

            preview_view = None
            preview_lp = None

            if is_video:
                # VideoView использует SurfaceView, который рендерится отдельным слоем
                # НИЖЕ окна Dialog → пиксели не видны. TextureView рендерится в иерархии диалога.
                from android.view import TextureView, Surface
                from android.media import MediaPlayer, MediaMetadataRetriever

                vw, vh = 0, 0
                try:
                    mmr = MediaMetadataRetriever()
                    mmr.setDataSource(filepath)
                    vw_s = mmr.extractMetadata(MediaMetadataRetriever.METADATA_KEY_VIDEO_WIDTH)
                    vh_s = mmr.extractMetadata(MediaMetadataRetriever.METADATA_KEY_VIDEO_HEIGHT)
                    vw = int(vw_s) if vw_s else 0
                    vh = int(vh_s) if vh_s else 0
                    mmr.release()
                except:
                    pass
                if vw <= 0 or vh <= 0:
                    vw, vh = AndroidUtilities.dp(200), AndroidUtilities.dp(200)
                scale = min(max_w_px / vw, max_h_px / vh, 1.0)
                dw, dh = int(vw * scale), int(vh * scale)
                short_now = min(dw, dh) if min(dw, dh) > 0 else 1
                if short_now < min_short_px:
                    sup = min_short_px / short_now
                    dw = min(int(dw * sup), max_w_px)
                    dh = min(int(dh * sup), max_h_px)

                tex = TextureView(activity)
                # Фон не ставим: превью живёт на едином фоне диалога

                # Удерживаем ссылки в closure, чтобы GC не собрал плеер до отрисовки
                mp_ref = [None]
                surface_ref = [None]
                vpath = filepath  # фиксируем в closure

                class _PL(dynamic_proxy(MediaPlayer.OnPreparedListener)):
                    def onPrepared(s, m):
                        try:
                            m.setVolume(0.0, 0.0)
                        except:
                            pass
                        try:
                            m.setLooping(False)
                        except:
                            pass
                        try:
                            m.start()
                        except:
                            pass

                class _STL(dynamic_proxy(TextureView.SurfaceTextureListener)):
                    def onSurfaceTextureAvailable(s, st, w, h):
                        try:
                            mp = MediaPlayer()
                            mp_ref[0] = mp
                            surface = Surface(st)
                            surface_ref[0] = surface
                            mp.setSurface(surface)
                            mp.setDataSource(vpath)
                            mp.setOnPreparedListener(_PL())
                            mp.prepareAsync()
                        except Exception as e:
                            try:
                                BulletinHelper.show_success(f"Видео: {e}")
                            except:
                                pass
                    def onSurfaceTextureSizeChanged(s, st, w, h):
                        pass
                    def onSurfaceTextureDestroyed(s, st):
                        try:
                            mp = mp_ref[0]
                            if mp is not None:
                                try: mp.stop()
                                except: pass
                                try: mp.release()
                                except: pass
                            mp_ref[0] = None
                        except:
                            pass
                        try:
                            sf = surface_ref[0]
                            if sf is not None:
                                sf.release()
                            surface_ref[0] = None
                        except:
                            pass
                        return True
                    def onSurfaceTextureUpdated(s, st):
                        pass

                tex.setSurfaceTextureListener(_STL())

                preview_view = tex
                preview_lp = LinearLayout.LayoutParams(dw, dh)
            else:
                img = ImageView(activity)
                img.setScaleType(ImageView.ScaleType.FIT_CENTER)
                img.setAdjustViewBounds(True)
                img.setMaxHeight(max_h_px)
                img.setMaxWidth(max_w_px)

                used_animated = False
                if is_gif:
                    try:
                        from android.graphics import ImageDecoder
                        from java.io import File
                        src = ImageDecoder.createSource(File(filepath))
                        drawable = ImageDecoder.decodeDrawable(src)
                        img.setImageDrawable(drawable)
                        try:
                            drawable.setRepeatCount(0)
                        except:
                            pass
                        try:
                            drawable.start()
                        except:
                            pass
                        # Маленькие GIF — задаём фиксированный размер с учётом min/max.
                        try:
                            iw = drawable.getIntrinsicWidth()
                            ih = drawable.getIntrinsicHeight()
                            if iw > 0 and ih > 0 and min(iw, ih) < min_short_px:
                                sg = min_short_px / min(iw, ih)
                                dw = min(int(iw * sg), max_w_px)
                                dh = min(int(ih * sg), max_h_px)
                                preview_lp = LinearLayout.LayoutParams(dw, dh)
                        except:
                            pass
                        used_animated = True
                    except:
                        pass

                if not used_animated:
                    try:
                        if file_ok:
                            bmp = self._thumb(filepath, 0)
                            if bmp:
                                w, h = bmp.getWidth(), bmp.getHeight()
                                short = min(w, h)
                                if short > 0 and short < min_short_px:
                                    scale = min_short_px / short
                                    bmp = Bitmap.createScaledBitmap(bmp, int(w * scale), int(h * scale), True)
                                img.setImageBitmap(bmp)
                    except:
                        pass

                preview_view = img
                if preview_lp is None:
                    preview_lp = LinearLayout.LayoutParams(
                        LinearLayout.LayoutParams.WRAP_CONTENT,
                        LinearLayout.LayoutParams.WRAP_CONTENT)

            # ClipToOutline скругляет углы как у ImageView (bitmap/GIF), так и у TextureView (video).
            preview_wrapper = FrameLayout(activity)
            try:
                preview_wrapper.setBackground(self._rounded_bg(0x00000000, R_CARD))
                preview_wrapper.setClipToOutline(True)
            except:
                pass
            preview_wrapper.addView(preview_view, FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT))

            preview_lp.gravity = Gravity.CENTER_HORIZONTAL
            preview_lp.setMargins(0, 0, 0, AndroidUtilities.dp(16))
            outer.addView(preview_wrapper, preview_lp)

            # clipChildren/clipToPadding для scale-pop анимаций action-row.
            outer.setClipChildren(False)
            outer.setClipToPadding(False)

            title_tv = TextView(activity)
            title_tv.setText(_t("meme_title"))
            title_tv.setTextSize(1, 17.0)
            title_tv.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title_tv.setTypeface(Typeface.DEFAULT_BOLD)
            title_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT)
            title_lp.setMargins(AndroidUtilities.dp(PAD_SHEET), 0, AndroidUtilities.dp(PAD_SHEET), 0)
            outer.addView(title_tv, title_lp)

            short = _short_desc(meme.get("tags", ""))
            if short:
                sub_tv = TextView(activity)
                sub_tv.setText(short)
                sub_tv.setTextSize(1, 13.0)
                sub_tv.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
                sub_tv.setMaxLines(2)
                sub_lp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT)
                sub_lp.setMargins(AndroidUtilities.dp(PAD_SHEET), AndroidUtilities.dp(2), AndroidUtilities.dp(PAD_SHEET), AndroidUtilities.dp(GAP_SECTION))
                outer.addView(sub_tv, sub_lp)
            else:
                spacer = View(activity)
                slp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(GAP_SECTION))
                outer.addView(spacer, slp)

            def _fav_click(v):
                _close()
                run_on_ui_thread(lambda: plugin._toggle_favorite(
                    meme, full_db,
                    refresh_fn=refresh_fn,
                    notify_fn=notify_fn,
                ))

            def _edit_click(v):
                _close()
                run_on_ui_thread(lambda: plugin._edit_meme(activity, meme, full_db, sheet))

            def _del_click(v):
                _close()
                run_on_ui_thread(lambda: plugin._delete_meme(activity, meme, full_db, sheet))

            fav_icons = ['msg_fave', 'msg_star_outline', 'msg_star', 'msg_bookmark']
            fav_label = _t("meme_unfav") if is_fav else _t("meme_fav")
            self._build_action_row(activity, outer, fav_icons, fav_label, Theme.key_dialogTextBlack, _fav_click)
            self._build_action_row(activity, outer, ['msg_edit', 'menu_edit', 'edit'], _t("meme_edit"), Theme.key_dialogTextBlack, _edit_click)
            self._build_action_row(activity, outer, ['msg_delete', 'chats_delete', 'menu_delete'], _t("meme_delete"), Theme.key_text_RedBold, _del_click)

            builder = AlertDialogBuilder(activity)
            builder.set_view(outer)
            builder.show()
            builder_ref[0] = builder
        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _edit_meme(self, activity, meme, full_db, sheet):
        _, categories = _load_db()
        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("edit_title"))
        path = meme.get("filepath", "")
        container, cat_inp, desc_inp = self._build_meme_form(
            activity, path,
            meme.get("category", ""),
            meme.get("tags", ""),
            categories
        )
        builder.setView(container)

        plugin = self

        class SL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def __init__(s, pl):
                super().__init__()
                s.pl = pl
            def onClick(s, d, w):
                new_cat = cat_inp.getText().toString().strip()[:MAX_CATEGORY_LEN]
                new_desc = desc_inp.getText().toString().strip()
                with _db_txn() as t:
                    if new_cat and new_cat not in t.cats:
                        if len(t.cats) >= MAX_CATEGORIES:
                            BulletinHelper.show_success(_t("category_limit", max=MAX_CATEGORIES))
                            t.cancel()
                            return
                        t.cats.append(new_cat)
                    target_fp = meme.get("filepath", "")
                    for m in t.memes:
                        if m.get("filepath") == target_fp:
                            m["tags"] = new_desc
                            m["category"] = new_cat
                            break
                if t.cancelled:
                    return
                sheet.dismiss()
                run_on_ui_thread(lambda: s.pl._show_library_sheet(activity, t.memes))
                plugin._notify_after(_t("edit_saved"), 300)
        builder.setPositiveButton(_t("btn_save"), SL(self))
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _delete_meme(self, activity, meme, full_db, sheet):
        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("delete_title"))
        short = _short_desc(meme.get("tags", ""), 60) or "—"
        builder.setMessage(_t("delete_message", desc=short))
        plugin = self

        class DL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def __init__(s, pl):
                super().__init__()
                s.pl = pl
            def onClick(s, d, w):
                try:
                    fp = meme.get("filepath", "")
                    if os.path.exists(fp):
                        os.remove(fp)
                    try:
                        for k in list(plugin._thumb_cache.keys()):
                            if k[0] == fp:
                                plugin._thumb_cache.pop(k, None)
                    except:
                        pass
                    with _db_txn() as t:
                        t.memes = [m for m in t.memes if m.get("filepath") != fp]
                    if t.cancelled:
                        return
                    sheet.dismiss()
                    if t.memes:
                        run_on_ui_thread(lambda: s.pl._show_library_sheet(activity, t.memes))
                        plugin._notify_after(_t("delete_done"), 300)
                    else:
                        BulletinHelper.show_success(_t("delete_done"))
                except Exception as e:
                    BulletinHelper.show_success(_t("error_prefix", e=e))
        builder.setPositiveButton(_t("btn_delete"), DL(self))
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _toggle_favorite(self, meme, full_db, refresh_fn=None, notify_fn=None):
        """Toggle in-place: меняем full_db, диск, переданный meme-объект.
        refresh_fn() перерисовывает грид без закрытия шторки."""
        try:
            target_fp = meme.get("filepath", "")
            new_state = not meme.get("favorite", False)

            # Сначала мутируем живой full_db (он же используется открытым гридом).
            for m in full_db:
                if m.get("filepath") == target_fp:
                    m["favorite"] = new_state
                    break

            with _db_txn() as t:
                for m in t.memes:
                    if m.get("filepath") == target_fp:
                        m["favorite"] = new_state
                        break
            if t.cancelled:
                return

            # 3. Обновляем meme-объект (передан по ссылке из меню действий)
            meme["favorite"] = new_state

            # 4. Перерисовываем грид без закрытия шторки
            if refresh_fn:
                try:
                    refresh_fn()
                except Exception:
                    pass

            label = _t("fav_added") if new_state else _t("fav_removed")
            if notify_fn:
                try:
                    notify_fn(label)
                except Exception:
                    pass
            else:
                BulletinHelper.show_success(label)

        except Exception as e:
            BulletinHelper.show_success(_t("error_prefix", e=e))

    def _show_create_category_dialog(self, activity, sheet, full_db):
        from android.text import InputFilter
        _, categories = _load_db()
        if len(categories) >= MAX_CATEGORIES:
            BulletinHelper.show_success(_t("category_limit", max=MAX_CATEGORIES))
            return

        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("cat_new_title"))
        inp = self._styled_input(activity, _t("cat_name_hint", max=MAX_CATEGORY_LEN))
        try:
            inp.setFilters([InputFilter.LengthFilter(MAX_CATEGORY_LEN)])
        except:
            pass
        lay = LinearLayout(activity)
        lay.setOrientation(LinearLayout.VERTICAL)
        p = AndroidUtilities.dp(PAD_DIALOG)
        lay.setPadding(p, AndroidUtilities.dp(GAP_ITEM), p, 0)
        lay.addView(inp)
        builder.setView(lay)

        plugin = self

        class SL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def onClick(s, d, w):
                name = inp.getText().toString().strip()[:MAX_CATEGORY_LEN]
                if not name:
                    return
                with _db_txn() as t:
                    if name in t.cats:
                        BulletinHelper.show_success(_t("cat_exists"))
                        t.cancel()
                        return
                    if len(t.cats) >= MAX_CATEGORIES:
                        BulletinHelper.show_success(_t("cat_limit", max=MAX_CATEGORIES))
                        t.cancel()
                        return
                    t.cats.append(name)
                if t.cancelled:
                    return
                sheet.dismiss()
                run_on_ui_thread(lambda: plugin._show_library_sheet(activity, t.memes))
                plugin._notify_after(_t("cat_created", name=name), 300)
        builder.setPositiveButton(_t("btn_create"), SL())
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _show_category_actions(self, activity, sheet, full_db, category):
        plugin = self
        actions = [_t("cat_rename"), _t("cat_delete_action")]

        def on_item(bld, which):
            try:
                bld.dismiss()
            except:
                pass
            if which == 0:
                run_on_ui_thread(lambda: plugin._rename_category(activity, sheet, category))
            elif which == 1:
                run_on_ui_thread(lambda: plugin._delete_category(activity, sheet, category))

        builder = AlertDialogBuilder(activity)
        builder.set_title(category)
        builder.set_items(actions, on_item)
        builder.show()

    def _rename_category(self, activity, sheet, old_name):
        from android.text import InputFilter
        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("cat_rename_title", name=old_name))
        inp = self._styled_input(activity, _t("cat_rename_hint", max=MAX_CATEGORY_LEN), old_name)
        try:
            inp.setFilters([InputFilter.LengthFilter(MAX_CATEGORY_LEN)])
        except:
            pass
        lay = LinearLayout(activity)
        lay.setOrientation(LinearLayout.VERTICAL)
        p = AndroidUtilities.dp(PAD_DIALOG)
        lay.setPadding(p, AndroidUtilities.dp(GAP_ITEM), p, 0)
        lay.addView(inp)
        builder.setView(lay)

        plugin = self

        class SL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def onClick(s, d, w):
                new_name = inp.getText().toString().strip()[:MAX_CATEGORY_LEN]
                if not new_name or new_name == old_name:
                    return
                with _db_txn() as t:
                    if new_name in t.cats:
                        BulletinHelper.show_success(_t("cat_exists"))
                        t.cancel()
                        return
                    t.cats = [new_name if c == old_name else c for c in t.cats]
                    for m in t.memes:
                        if m.get("category") == old_name:
                            m["category"] = new_name
                if t.cancelled:
                    return
                sheet.dismiss()
                run_on_ui_thread(lambda: plugin._show_library_sheet(activity, t.memes))
                plugin._notify_after(_t("cat_renamed"), 300)
        builder.setPositiveButton(_t("btn_save"), SL())
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _delete_category(self, activity, sheet, name):
        plugin = self
        builder = AlertDialog.Builder(activity)
        builder.setTitle(_t("cat_delete_title", name=name))
        builder.setMessage(_t("cat_delete_message"))

        class DL(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def onClick(s, d, w):
                with _db_txn() as t:
                    t.cats = [c for c in t.cats if c != name]
                    for m in t.memes:
                        if m.get("category") == name:
                            m["category"] = ""
                if t.cancelled:
                    return
                sheet.dismiss()
                run_on_ui_thread(lambda: plugin._show_library_sheet(activity, t.memes))
                plugin._notify_after(_t("cat_deleted"), 300)
        builder.setPositiveButton(_t("btn_delete"), DL())
        builder.setNegativeButton(_t("btn_cancel"), None)
        builder.show()

    def _send_file(self, dialog_id, path, caption=""):
        ext = os.path.splitext(path)[1].lower()
        if ext in PHOTO_EXTS:
            send_photo(dialog_id, path, caption=caption)
        else:
            send_document(dialog_id, path, caption=caption)

    def _send_native(self, dialog_id, filepaths):
        """Нативная отправка через SendMessagesHelper.prepareSendingMedia с учётом
        reply/thread, группировкой в альбом и подписью с premium-эмодзи из
        chatActivityEnterView. Fallback на _do_send_loop, если что-то недоступно."""
        valid = [fp for fp in filepaths if os.path.exists(fp)]
        if not valid:
            return

        try:
            fragment = get_last_fragment()
            is_chat = fragment is not None and fragment.getClass().getName().endswith(".ChatActivity")
        except Exception:
            fragment, is_chat = None, False

        if not is_chat:
            self._do_send_loop(dialog_id, valid, "")
            return

        caption_text = ""
        caption_entities = None
        reply_msg = None
        reply_top_msg = None
        enter_view = None
        edit = None
        try:
            enter_view = get_private_field(fragment, "chatActivityEnterView")
        except Exception:
            pass
        try:
            reply_msg = get_private_field(fragment, "replyingMessageObject")
        except Exception:
            pass
        try:
            reply_top_msg = get_private_field(fragment, "threadMessageObject")
        except Exception:
            pass
        if enter_view is not None:
            try:
                edit = get_private_field(enter_view, "messageEditText")
                if edit is not None:
                    editable = edit.getText()
                    if editable is not None:
                        caption_text, caption_entities = self._extract_text_and_entities(editable)
            except Exception:
                edit = None

        # Альбом группирует только photo/video; документы отправляем отдельным батчем.
        media_batch = []
        doc_batch = []
        for fp in valid:
            ext = os.path.splitext(fp)[1].lower()
            if ext in PHOTO_EXTS or ext in VIDEO_EXTS:
                media_batch.append((fp, ext in VIDEO_EXTS))
            else:
                doc_batch.append(fp)

        try:
            from client_utils import get_account_instance
            from java.util import ArrayList as JArrayList
            SMH = find_class("org.telegram.messenger.SendMessagesHelper")
            SMI = find_class("org.telegram.messenger.SendMessagesHelper$SendingMediaInfo")
            acc = get_account_instance()
        except Exception:
            self._do_send_loop(dialog_id, valid, caption_text)
            return
        if SMH is None or SMI is None or acc is None:
            self._do_send_loop(dialog_id, valid, caption_text)
            return

        method = self._resolve_prepare_sending_media(SMH)
        if method is None:
            self._do_send_loop(dialog_id, valid, caption_text)
            return

        def build_infos(items, with_caption, with_video_flag):
            lst = JArrayList()
            for i, item in enumerate(items):
                try:
                    info = SMI()
                except Exception:
                    return None
                try:
                    if with_video_flag:
                        fp, is_video = item
                        info.path = fp
                        try:
                            info.isVideo = is_video
                        except Exception:
                            pass
                    else:
                        info.path = item
                except Exception:
                    pass
                if with_caption and i == 0 and caption_text:
                    try:
                        info.caption = caption_text
                    except Exception:
                        pass
                    if caption_entities is not None:
                        try:
                            info.entities = caption_entities
                        except Exception:
                            pass
                lst.add(info)
            return lst

        def invoke_send(lst, group_media):
            args = self._build_prepare_args(method, acc, lst, dialog_id, reply_msg, reply_top_msg, group_media)
            if args is None:
                return False
            try:
                from java import jarray
                from java.lang import Object
                method.setAccessible(True)
                # Method.invoke(Object, Object...) ждёт Object[] — Chaquopy не разворачивает
                # Python-список в varargs для рефлексии, нужен явный jarray(Object).
                method.invoke(None, jarray(Object)(args))
                return True
            except Exception:
                return False

        def go():
            sent_any_native = False
            if media_batch:
                lst = build_infos(media_batch, with_caption=True, with_video_flag=True)
                if lst is not None and invoke_send(lst, group_media=(len(media_batch) > 1)):
                    sent_any_native = True
            if doc_batch:
                # Подпись клеим к документам только если фото/видео-батча не было
                lst = build_infos(doc_batch, with_caption=(not media_batch), with_video_flag=False)
                if lst is not None and invoke_send(lst, group_media=False):
                    sent_any_native = True

            if not sent_any_native:
                self._do_send_loop(dialog_id, valid, caption_text)

            # Очищаем инпут безусловно, если забрали из него подпись.
            if edit is not None and caption_text:
                try:
                    edit.setText("")
                except Exception:
                    pass
                try:
                    fragment.hideFieldPanel(False)
                except Exception:
                    pass

        run_on_ui_thread(go)

    def _do_send_loop(self, dialog_id, filepaths, caption_text=""):
        """Fallback. Caption клеим только к первому файлу (как делает Telegram сам)."""
        sent = 0
        for i, fp in enumerate(filepaths):
            if not os.path.exists(fp):
                continue
            try:
                cap = caption_text if i == 0 else ""
                self._send_file(dialog_id, fp, cap)
                sent += 1
            except Exception as e:
                BulletinHelper.show_success(_t("error_prefix", e=e))
        if sent:
            BulletinHelper.show_success(_t("send_done", count=sent))

    def _resolve_prepare_sending_media(self, smh_class):
        """find_class() возвращает Chaquopy jclass-прокси; рефлексия (getDeclaredMethods)
        работает только на реальном java.lang.Class, который достаётся через .getClass().
        Среди overload'ов берём самый широкий — арность меняется между билдами."""
        try:
            real_class = smh_class.getClass()
        except Exception:
            return None
        if real_class is None:
            return None

        candidates = []
        try:
            for m in real_class.getDeclaredMethods():
                if m.getName() == "prepareSendingMedia":
                    candidates.append(m)
        except Exception:
            pass
        if not candidates:
            try:
                for m in real_class.getMethods():
                    if m.getName() == "prepareSendingMedia":
                        candidates.append(m)
            except Exception:
                pass
        if not candidates:
            return None

        try:
            candidates.sort(key=lambda x: x.getParameterCount(), reverse=True)
        except Exception:
            pass
        return candidates[0]

    def _build_prepare_args(self, method, account_instance, media_list, dialog_id, reply_msg, reply_top_msg, group_media):
        """Эвристическая раскладка под фактическую сигнатуру prepareSendingMedia.
        Method.invoke требует Object[], поэтому long/int/boolean явно боксятся в
        Long/Integer/Boolean (иначе IllegalArgumentException).

        Маппинг по позиции типа: AccountInstance → acc; ArrayList → media_list;
        первый long → dialog_id; первые два MessageObject → reply/replyTop;
        boolean[0]=forceDocument(False), [1]=groupMedia, [2]=notify(True), далее False;
        int → 0; String/прочие ref → None."""
        try:
            from java.lang import Long, Integer, Boolean
        except:
            return None
        try:
            param_types = method.getParameterTypes()
        except:
            return None
        n = len(param_types)
        args = [None] * n
        long_count = 0
        msgobj_count = 0
        bool_count = 0
        for i in range(n):
            try:
                tn = param_types[i].getName()
            except:
                tn = ""
            if tn.endswith("AccountInstance"):
                args[i] = account_instance
            elif tn == "java.util.ArrayList":
                args[i] = media_list
            elif tn == "long":
                args[i] = Long(int(dialog_id) if long_count == 0 else 0)
                long_count += 1
            elif tn.endswith("MessageObject"):
                if msgobj_count == 0:
                    args[i] = reply_msg
                elif msgobj_count == 1:
                    args[i] = reply_top_msg
                else:
                    args[i] = None
                msgobj_count += 1
            elif tn == "boolean":
                if bool_count == 0:
                    v = False
                elif bool_count == 1:
                    v = bool(group_media)
                elif bool_count == 2:
                    v = True
                else:
                    v = False
                args[i] = Boolean(v)
                bool_count += 1
            elif tn == "int":
                args[i] = Integer(0)
            else:
                args[i] = None
        return args

    def _extract_text_and_entities(self, editable):
        """MediaDataController.getEntities принимает CharSequence[] (in/out — модифицирует
        [0] на «очищенный» текст без spans-маркеров) и сохраняет premium-эмодзи."""
        try:
            text = editable.toString()
        except:
            return "", None
        if not text:
            return "", None
        try:
            from client_utils import get_media_data_controller
            from java import jarray
            from java.lang import CharSequence
            mdc = get_media_data_controller()
            arr = jarray(CharSequence)([editable])
            entities = mdc.getEntities(arr, True)
            try:
                stripped = arr[0].toString()
            except:
                stripped = text
            return stripped, entities
        except:
            return text, None

    def _show_native_forward(self, activity, filepaths):
        """Запускает родной Intent.ACTION_SEND[_MULTIPLE] на сам Telegram-package —
        открывается нативный диалог «Переслать в…»."""
        from android.content import Intent
        from android.net import Uri
        from java.io import File

        valid = [fp for fp in filepaths if os.path.exists(fp)]
        if not valid:
            BulletinHelper.show_success(_t("send_files_not_found"))
            return

        try:
            pkg = activity.getPackageName()

            def make_uri(fp):
                # FileProvider обязателен на Android 7+ (StrictMode FileUriExposedException).
                try:
                    from androidx.core.content import FileProvider
                    return FileProvider.getUriForFile(activity, pkg + ".provider", File(fp))
                except:
                    return Uri.fromFile(File(fp))

            if len(valid) == 1:
                intent = Intent(Intent.ACTION_SEND)
                intent.setType("image/*")
                intent.putExtra(Intent.EXTRA_STREAM, make_uri(valid[0]))
            else:
                from java.util import ArrayList as JArrayList
                uris = JArrayList()
                for fp in valid:
                    uris.add(make_uri(fp))
                intent = Intent(Intent.ACTION_SEND_MULTIPLE)
                intent.setType("image/*")
                intent.putParcelableArrayListExtra(Intent.EXTRA_STREAM, uris)

            intent.setPackage(pkg)
            intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
            activity.startActivity(intent)
        except Exception as e:
            BulletinHelper.show_success(_t("send_forward_error", e=e))
