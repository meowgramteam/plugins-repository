MUSIC_GAP_THRESHOLD_SEC = 5.0
MUSIC_GAP_MARKER = "♪"

# LRCLIB/LRC часто хранит только начало строки, но не её конец.
# Если в LRC есть пустой таймкод, используем его как настоящий конец предыдущей строки.
# Если пустого таймкода нет, конец строки оценивается мягко по длине текста.
ESTIMATED_MIN_LINE_DURATION_SEC = 2.0
ESTIMATED_MAX_LINE_DURATION_SEC = 10.0
ESTIMATED_CHARS_PER_SEC = 7.0


# =============================
# Общие утилиты
# =============================


def safe_str(value: Any, default: str = "") -> str:
    if value is None:
        return default
    try:
        text = str(value)
    except Exception:
        return default
    text = text.strip()
    return text if text else default


def normalize_key(*parts: str) -> str:
    text = " ".join([safe_str(p) for p in parts if safe_str(p)])
    text = text.lower()
    text = re.sub(r"\([^)]*\)|\[[^]]*\]", " ", text)
    text = re.sub(r"feat\.?|ft\.?", " ", text, flags=re.I)
    text = re.sub(r"[^\wа-яё]+", " ", text, flags=re.IGNORECASE)
    return re.sub(r"\s+", " ", text).strip()


def dp(context: Any, value: int) -> int:
    try:
        density = context.getResources().getDisplayMetrics().density
        return int(value * density + 0.5)
    except Exception:
        return value


def float_safe(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except Exception:
        return default


def clamp_int(value: int, minimum: int, maximum: int) -> int:
    return max(minimum, min(maximum, int(value)))


def setting_int(plugin: Any, key: str, default: int, minimum: int, maximum: int) -> int:
    try:
        raw = plugin.get_setting(key, str(default)) if plugin else str(default)
        return clamp_int(int(float(str(raw).replace(',', '.').strip())), minimum, maximum)
    except Exception:
        return clamp_int(default, minimum, maximum)


def setting_float(plugin: Any, key: str, default: float, minimum: float, maximum: float) -> float:
    try:
        raw = plugin.get_setting(key, str(default)) if plugin else str(default)
        value = float(str(raw).replace(',', '.').strip())
        return max(minimum, min(maximum, value))
    except Exception:
        return max(minimum, min(maximum, float(default)))


def setting_bool(plugin: Any, key: str, default: bool) -> bool:
    try:
        raw = plugin.get_setting(key, default) if plugin else default
        if isinstance(raw, bool):
            return raw
        return str(raw).strip().lower() in ("1", "true", "yes", "да", "on")
    except Exception:
        return default


def argb_gray(alpha: int, value: int) -> int:
    return Color.argb(clamp_int(alpha, 0, 255), clamp_int(value, 0, 255), clamp_int(value, 0, 255), clamp_int(value, 0, 255))


class ViewClickListener(dynamic_proxy(View.OnClickListener)):
    def __init__(self, callback):
        super().__init__()
        self.callback = callback

    def onClick(self, view):
        try:
            self.callback(view)
        except Exception:
            pass


class DoubleTapLineClickListener(dynamic_proxy(View.OnClickListener)):
    """Лёгкий double-tap без GestureDetector: два клика по строке за короткое время."""
    def __init__(self, callback, threshold_sec: float = 0.34):
        super().__init__()
        self.callback = callback
        self.threshold_sec = threshold_sec
        self.last_click_at = 0.0

    def onClick(self, view):
        try:
            now = time.time()
            if now - self.last_click_at <= self.threshold_sec:
                self.last_click_at = 0.0
                self.callback(view)
            else:
                self.last_click_at = now
        except Exception:
            pass


class TelegramUtils:
    @staticmethod
    def get_icon_id(name: str) -> int:
        context = get_last_fragment().getContext()
        return context.getResources().getIdentifier(name, "drawable", context.getPackageName())

    @staticmethod
    def get_locale_id(name: str) -> int:
        context = get_last_fragment().getContext()
        return context.getResources().getIdentifier(name, "string", context.getPackageName())

    @classmethod
    def locale_string(cls, name: str) -> str:
        try:
            return TGLocale.getString(cls.get_locale_id(name))
        except Exception:
            return name


# =============================
# Данные трека / текста
# =============================


class TrackInfo:
    def __init__(self, title: str, artist: str, duration: float, query_fallback: str = ""):
        self.title = title
        self.artist = artist
        self.duration = duration
        self.query_fallback = query_fallback

    @property
    def display_title(self) -> str:
        return self.title or self.query_fallback or "Неизвестный трек"

    @property
    def display_artist(self) -> str:
        return self.artist or "Неизвестный артист"

    @property
    def query(self) -> str:
        if self.artist and self.title:
            return f"{self.artist} {self.title}"
        if self.title:
            return self.title
        return self.query_fallback

    @property
    def cache_key(self) -> str:
        # В ключ добавлен провайдер и версия обработки строк, чтобы старый кэш
        # без музыкальных пауз не подмешивался к новой разметке.
        return normalize_key("lrclib", "gapnotes_v1", self.artist, self.title, self.query_fallback)


class LyricsResult:
    def __init__(
        self,
        lines: List[Dict[str, Any]],
        synced: bool,
        source: str = "LRCLIB",
        source_url: Optional[str] = None,
        matched_title: str = "",
        matched_artist: str = "",
    ):
        self.lines = lines
        self.synced = synced
        self.source = source
        self.source_url = source_url
        self.matched_title = matched_title
        self.matched_artist = matched_artist

    def to_cache(self) -> Dict[str, Any]:
        return {
            "lines": self.lines,
            "synced": self.synced,
            "source": self.source,
            "source_url": self.source_url,
            "matched_title": self.matched_title,
            "matched_artist": self.matched_artist,
            "saved_at": int(time.time()),
        }

    @classmethod
    def from_cache(cls, item: Dict[str, Any]) -> Optional["LyricsResult"]:
        try:
            lines = item.get("lines") or []
            if not lines:
                return None
            return cls(
                lines=lines,
                synced=bool(item.get("synced", False)),
                source=safe_str(item.get("source"), "LRCLIB"),
                source_url=item.get("source_url"),
                matched_title=safe_str(item.get("matched_title")),
                matched_artist=safe_str(item.get("matched_artist")),
            )
        except Exception:
            return None


# =============================
# LRCLIB provider
# =============================


class LrclibLyricsProvider:
    def __init__(self, plugin: "Plugin"):
        self.plugin = plugin

    def get_lyrics(self, track: TrackInfo) -> LyricsResult:
        cached = self.plugin.cache_get(track.cache_key)
        if cached:
            result = LyricsResult.from_cache(cached)
            if result:
                return result

        if not track.query:
            raise Exception("Не удалось определить название трека")

        data = self._get_exact(track)
        if not data:
            data = self._search_best(track)
        if not data:
            raise Exception("LRCLIB не нашёл подходящий текст")

        result = self._record_to_result(data, track)
        self.plugin.cache_put(track.cache_key, result.to_cache())
        return result

    def _headers(self) -> Dict[str, str]:
        return {
            "User-Agent": LRCLIB_USER_AGENT,
            "Accept": "application/json",
        }

    def _get_exact(self, track: TrackInfo) -> Optional[Dict[str, Any]]:
        if not track.title:
            return None

        params: Dict[str, Any] = {"track_name": track.title}
        if track.artist:
            params["artist_name"] = track.artist
        if track.duration > 0:
            # LRCLIB API принимает duration в секундах.
            params["duration"] = int(round(track.duration))

        try:
            response = requests.get(LRCLIB_GET_URL, params=params, headers=self._headers(), timeout=NETWORK_TIMEOUT)
            if response.status_code == 404:
                return None
            response.raise_for_status()
            data = response.json()
            if isinstance(data, dict) and (data.get("syncedLyrics") or data.get("plainLyrics") or data.get("instrumental")):
                return data
        except Exception as e:
            self.plugin.log("LRCLIB exact get failed: " + str(e))
        return None

    def _search_best(self, track: TrackInfo) -> Optional[Dict[str, Any]]:
        searches: List[Dict[str, Any]] = []

        if track.title:
            by_fields: Dict[str, Any] = {"track_name": track.title}
            if track.artist:
                by_fields["artist_name"] = track.artist
            searches.append(by_fields)

        if track.query:
            searches.append({"q": track.query})

        if track.title and not track.artist:
            searches.append({"q": track.title})

        candidates: List[Dict[str, Any]] = []
        for params in searches:
            try:
                response = requests.get(LRCLIB_SEARCH_URL, params=params, headers=self._headers(), timeout=NETWORK_TIMEOUT)
                response.raise_for_status()
                data = response.json()
                if isinstance(data, list):
                    for item in data:
                        if isinstance(item, dict):
                            candidates.append(item)
            except Exception as e:
                self.plugin.log("LRCLIB search failed: " + str(e))

        if not candidates:
            return None
        return self._choose_best_candidate(track, candidates)

    def _choose_best_candidate(self, track: TrackInfo, candidates: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        target_title = normalize_key(track.title)
        target_artist = normalize_key(track.artist)
        target_duration = track.duration

        best_score = -99999.0
        best_item = None
        seen_ids = set()

        for item in candidates:
            item_id = safe_str(item.get("id"))
            if item_id and item_id in seen_ids:
                continue
            if item_id:
                seen_ids.add(item_id)

            title = normalize_key(item.get("trackName"))
            artist = normalize_key(item.get("artistName"))
            duration = float_safe(item.get("duration"), 0.0)
            has_synced = bool(item.get("syncedLyrics"))
            has_plain = bool(item.get("plainLyrics"))
            instrumental = bool(item.get("instrumental"))

            if not has_synced and not has_plain and not instrumental:
                continue

            score = 0.0
            if has_synced:
                score += 40
            elif has_plain:
                score += 12
            if instrumental:
                score += 3

            if target_title and title == target_title:
                score += 32
            elif target_title and (target_title in title or title in target_title):
                score += 18

            if target_artist and artist == target_artist:
                score += 28
            elif target_artist and (target_artist in artist or artist in target_artist):
                score += 14

            if target_duration > 0 and duration > 0:
                diff = abs(duration - target_duration)
                if diff <= 2:
                    score += 18
                elif diff <= 5:
                    score += 12
                elif diff <= 12:
                    score += 4
                else:
                    score -= min(20.0, diff / 3.0)

            # Без совпадения хотя бы по названию или исполнителю результат слишком рискованный.
            if target_title and title and not (target_title in title or title in target_title):
                score -= 16
            if target_artist and artist and not (target_artist in artist or artist in target_artist):
                score -= 8

            if score > best_score:
                best_score = score
                best_item = item

        return best_item

    def _record_to_result(self, data: Dict[str, Any], track: Optional[TrackInfo] = None) -> LyricsResult:
        source_url = None
        try:
            if data.get("id") is not None:
                source_url = "https://lrclib.net/api/get/" + str(data.get("id"))
        except Exception:
            source_url = None

        if bool(data.get("instrumental")) and not data.get("plainLyrics") and not data.get("syncedLyrics"):
            return LyricsResult(
                lines=[{"time": 0.0, "text": "Инструментал"}],
                synced=True,
                source="LRCLIB",
                source_url=source_url,
                matched_title=safe_str(data.get("trackName")),
                matched_artist=safe_str(data.get("artistName")),
            )

        synced_text = safe_str(data.get("syncedLyrics"))
        if synced_text:
            duration = float_safe(data.get("duration"), 0.0)
            if duration <= 0 and track is not None:
                duration = float_safe(track.duration, 0.0)
            lines = self._parse_lrc(synced_text, duration)
            if lines:
                return LyricsResult(
                    lines=lines,
                    synced=True,
                    source="LRCLIB",
                    source_url=source_url,
                    matched_title=safe_str(data.get("trackName")),
                    matched_artist=safe_str(data.get("artistName")),
                )

        plain_text = safe_str(data.get("plainLyrics"))
        if plain_text:
            return LyricsResult(
                lines=self._plain_to_lines(plain_text),
                synced=False,
                source="LRCLIB",
                source_url=source_url,
                matched_title=safe_str(data.get("trackName")),
                matched_artist=safe_str(data.get("artistName")),
            )

        raise Exception("LRCLIB вернул запись, но без текста")

    def _parse_lrc(self, synced_lyrics: str, duration: float = 0.0) -> List[Dict[str, Any]]:
        lyric_events: List[Dict[str, Any]] = []
        empty_events: List[float] = []
        time_pattern = re.compile(r"\[(\d{1,3}):(\d{2})(?:[.:](\d{1,3}))?\]")

        for raw_line in synced_lyrics.replace("\r", "\n").split("\n"):
            raw_line = raw_line.strip()
            if not raw_line:
                continue

            matches = list(time_pattern.finditer(raw_line))
            if not matches:
                continue

            text = time_pattern.sub("", raw_line).strip()
            if re.match(r"^\[.+\]$", text):
                continue

            for match in matches:
                minutes = int(match.group(1))
                seconds = int(match.group(2))
                fraction_raw = match.group(3) or "0"
                if len(fraction_raw) == 1:
                    fraction = int(fraction_raw) / 10.0
                elif len(fraction_raw) == 2:
                    fraction = int(fraction_raw) / 100.0
                else:
                    fraction = int(fraction_raw[:3]) / 1000.0
                time_value = minutes * 60 + seconds + fraction

                # Пустые LRC-строки не показываем как пустоту, но сохраняем их как
                # точный момент окончания предыдущей вокальной строки/начала паузы.
                if not text:
                    empty_events.append(time_value)
                else:
                    lyric_events.append({"time": time_value, "text": text})

        lyric_events.sort(key=lambda item: float_safe(item.get("time"), 0.0))
        empty_events.sort()
        return self._inject_music_gap_markers(lyric_events, empty_events, duration)

    def _inject_music_gap_markers(
        self,
        lines: List[Dict[str, Any]],
        empty_times: List[float],
        duration: float = 0.0,
    ) -> List[Dict[str, Any]]:
        if not lines:
            return lines

        threshold = float(MUSIC_GAP_THRESHOLD_SEC)
        output: List[Dict[str, Any]] = []

        first_time = float_safe(lines[0].get("time"), 0.0)
        if first_time >= threshold:
            output.append({"time": 0.0, "text": MUSIC_GAP_MARKER, "pause": True})

        for index, line in enumerate(lines):
            output.append(line)
            current_start = float_safe(line.get("time"), 0.0)
            next_start = None
            if index + 1 < len(lines):
                next_start = float_safe(lines[index + 1].get("time"), 0.0)
            elif duration and duration > 0:
                next_start = float_safe(duration, 0.0)

            if next_start is None or next_start <= current_start:
                continue

            line_end = self._estimate_line_end_time(line, current_start, next_start, empty_times)
            if next_start - line_end >= threshold:
                # Если подряд уже есть такая же пауза на том же времени, не дублируем.
                if not output or safe_str(output[-1].get("text")) != MUSIC_GAP_MARKER or abs(float_safe(output[-1].get("time"), -9999.0) - line_end) > 0.05:
                    output.append({"time": line_end, "text": MUSIC_GAP_MARKER, "pause": True})

        output.sort(key=lambda item: float_safe(item.get("time"), 0.0))
        return output

    def _estimate_line_end_time(
        self,
        line: Dict[str, Any],
        current_start: float,
        next_start: float,
        empty_times: List[float],
    ) -> float:
        # Лучший вариант: LRCLIB иногда содержит пустую строку с таймкодом.
        # Считаем её настоящим концом предыдущей фразы.
        for empty_time in empty_times:
            if current_start < empty_time < next_start:
                return max(current_start, min(next_start, empty_time))

        # Если точного окончания строки нет, аккуратно оцениваем длительность по длине текста.
        text = safe_str(line.get("text"))
        estimated = len(text) / float(ESTIMATED_CHARS_PER_SEC) if text else ESTIMATED_MIN_LINE_DURATION_SEC
        estimated = max(float(ESTIMATED_MIN_LINE_DURATION_SEC), min(float(ESTIMATED_MAX_LINE_DURATION_SEC), estimated))
        return max(current_start, min(next_start, current_start + estimated))

    def _plain_to_lines(self, lyrics: str) -> List[Dict[str, Any]]:
        result: List[Dict[str, Any]] = []
        lyrics = lyrics.replace("\r", "\n")
        for raw_line in lyrics.split("\n"):
            line = raw_line.strip()
            if re.match(r"^\[.+\]$", line):
                continue
            result.append({"time": None, "text": line})
        while result and not safe_str(result[0].get("text")):
            result.pop(0)
        while result and not safe_str(result[-1].get("text")):
            result.pop()
        return result or [{"time": None, "text": "Текст пустой"}]


# =============================
# UI просмотра текста
# =============================


class LyricsViewer:
    def __init__(self, plugin: "Plugin", track: TrackInfo):
        self.plugin = plugin
        self.track = track
        self.provider = LrclibLyricsProvider(plugin)
        self.context = get_last_fragment().getContext()
        self.dialog: Optional[Dialog] = None
        self.frame_root: Optional[FrameLayout] = None
        self.background_image: Optional[ImageView] = None
        self.background_fade_image: Optional[ImageView] = None
        self.dim_overlay: Optional[View] = None
        self.ambient_container: Optional[FrameLayout] = None
        self.ambient_blob_views: List[View] = []
        self.ambient_blob_states: List[Dict[str, Any]] = []
        self.ambient_palette: List[Tuple[int, int, int]] = []
        self.ambient_loop_started = False
        self.bg_bitmap: Optional[Bitmap] = None
        self.bg_path: Optional[str] = None
        self.root: Optional[LinearLayout] = None
        self.scroll: Optional[ScrollView] = None
        self.lines_container: Optional[LinearLayout] = None
        self.status_text: Optional[TextView] = None
        self.source_text: Optional[TextView] = None
        self.line_views: List[TextView] = []
        self.line_click_listeners: List[Any] = []
        self.lines: List[str] = []
        self.line_times: List[Optional[float]] = []
        self.has_synced = False
        self.current_index = -1
        self.running = False
        self.sync_loop_started = False
        self.load_generation = 0
        self.loading_started_at = 0.0
        self.source_url: Optional[str] = None

    def show(self):
        self.dialog = Dialog(self.context)
        self.dialog.requestWindowFeature(Window.FEATURE_NO_TITLE)
        self.dialog.setCancelable(True)

        # FrameLayout нужен, чтобы под всем интерфейсом лежала размытая обложка,
        # а сам интерфейс оставался обычной редактируемой Python-оболочкой.
        self.frame_root = FrameLayout(self.context)
        self.frame_root.setBackgroundColor(COLOR_BG)

        self.background_image = ImageView(self.context)
        self.background_image.setScaleType(ImageView.ScaleType.CENTER_CROP)
        self.background_image.setBackgroundColor(COLOR_BG)
        self.background_image.setAlpha(1.0)
        self.frame_root.addView(self.background_image, FrameLayout.LayoutParams(-1, -1))

        # Второй слой нужен для плавной смены обложек.
        # Старая обложка остаётся на фоне, пока новая подгружается и мягко проявляется сверху.
        self.background_fade_image = ImageView(self.context)
        self.background_fade_image.setScaleType(ImageView.ScaleType.CENTER_CROP)
        self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        self.background_fade_image.setAlpha(0.0)
        self.frame_root.addView(self.background_fade_image, FrameLayout.LayoutParams(-1, -1))

        self.dim_overlay = View(self.context)
        self.dim_overlay.setBackgroundColor(self._dim_overlay_color())
        self.frame_root.addView(self.dim_overlay, FrameLayout.LayoutParams(-1, -1))

        # Ambient Overlay: полупрозрачные плавные цветные пятна поверх фона,
        # но ниже текста и верхней плашки. Делает фон живее, не мешая чтению.
        self.ambient_container = FrameLayout(self.context)
        self.ambient_container.setBackgroundColor(Color.TRANSPARENT)
        self.frame_root.addView(self.ambient_container, FrameLayout.LayoutParams(-1, -1))
        self._rebuild_ambient_blobs(None)
        self._ensure_ambient_loop()

        self.root = LinearLayout(self.context)
        self.root.setOrientation(LinearLayout.VERTICAL)
        self.root.setBackgroundColor(Color.TRANSPARENT)
        self.root.setLayoutParams(LinearLayout.LayoutParams(-1, -1))
        self.frame_root.addView(self.root, FrameLayout.LayoutParams(-1, -1))

        self._build_header()
        self._build_body_loading()

        self.dialog.setContentView(self.frame_root)
        self.dialog.show()

        try:
            window = self.dialog.getWindow()
            window.setLayout(-1, -1)
            window.setBackgroundDrawable(self._round_rect(Color.TRANSPARENT, 0))
        except Exception:
            pass

        self.running = True
        self._ensure_sync_loop()
        self._reload_for_track(self.track, clear_background=False)

    def _build_header(self):
        header = LinearLayout(self.context)
        header.setOrientation(LinearLayout.HORIZONTAL)
        header.setGravity(Gravity.CENTER_VERTICAL)
        header.setPadding(dp(self.context, 4), dp(self.context, 6), dp(self.context, 4), dp(self.context, 6))
        header.setBackgroundColor(self._header_bg_color())
        self.root.addView(header, LinearLayout.LayoutParams(-1, dp(self.context, self._header_height_dp())))

        side_width = dp(self.context, 52)

        close = TextView(self.context)
        close.setText("×")
        close.setGravity(Gravity.CENTER)
        close.setTextColor(Color.WHITE)
        close.setTextSize(33)
        close.setTypeface(Typeface.DEFAULT)
        close.setOnClickListener(ViewClickListener(lambda _: self.close()))
        header.addView(close, LinearLayout.LayoutParams(side_width, -1))

        title_box = LinearLayout(self.context)
        title_box.setOrientation(LinearLayout.VERTICAL)
        title_box.setGravity(Gravity.CENTER)
        title_box.setPadding(dp(self.context, 2), 0, dp(self.context, 2), 0)
        header.addView(title_box, LinearLayout.LayoutParams(0, -1, 1.0))

        title = TextView(self.context)
        title.setText(self.track.display_title)
        title.setTextColor(Color.WHITE)
        title.setTextSize(self._title_text_size())
        title.setTypeface(Typeface.DEFAULT_BOLD)
        self._apply_active_text_shadow(title)
        title.setSingleLine(True)
        title.setMaxLines(1)
        title.setEllipsize(TextUtils.TruncateAt.END)
        title.setGravity(Gravity.CENTER)
        title_box.addView(title, LinearLayout.LayoutParams(-1, -2))

        artist = TextView(self.context)
        artist.setText(self.track.display_artist)
        artist.setTextColor(self._muted_text_color())
        artist.setTextSize(self._subtitle_text_size())
        self._apply_inactive_text_shadow(artist)
        artist.setSingleLine(True)
        artist.setMaxLines(1)
        artist.setEllipsize(TextUtils.TruncateAt.END)
        artist.setGravity(Gravity.CENTER)
        lp_artist = LinearLayout.LayoutParams(-1, -2)
        lp_artist.setMargins(0, dp(self.context, 2), 0, 0)
        title_box.addView(artist, lp_artist)

        # Симметричный пустой блок справа: из-за него название и автор реально по центру,
        # а не сдвинуты вправо/влево от кнопки закрытия.
        spacer = View(self.context)
        header.addView(spacer, LinearLayout.LayoutParams(side_width, -1))

    def _build_body_loading(self):
        container = FrameLayout(self.context)
        self.root.addView(container, LinearLayout.LayoutParams(-1, 0, 1.0))

        box = LinearLayout(self.context)
        box.setOrientation(LinearLayout.VERTICAL)
        box.setGravity(Gravity.CENTER)
        box.setPadding(dp(self.context, 24), dp(self.context, 24), dp(self.context, 24), dp(self.context, 24))
        container.addView(box, FrameLayout.LayoutParams(-1, -1))

        progress = ProgressBar(self.context)
        box.addView(progress, LinearLayout.LayoutParams(dp(self.context, 42), dp(self.context, 42)))

        self.status_text = TextView(self.context)
        self.status_text.setText("Ищу текст на LRCLIB…")
        self.status_text.setTextColor(self._muted_text_color())
        self.status_text.setTextSize(16)
        self._apply_inactive_text_shadow(self.status_text)
        self.status_text.setGravity(Gravity.CENTER)
        lp = LinearLayout.LayoutParams(-1, -2)
        lp.setMargins(0, dp(self.context, 18), 0, 0)
        box.addView(self.status_text, lp)

    def _ensure_sync_loop(self) -> None:
        if self.sync_loop_started:
            return
        self.sync_loop_started = True
        run_on_queue(self._sync_loop)

    def _reload_for_track(self, track: TrackInfo, clear_background: bool = True):
        if not self.root:
            return

        self.track = track
        self.load_generation += 1
        generation = self.load_generation
        self.loading_started_at = time.time()
        self.current_index = -1
        self.lines = []
        self.line_times = []
        self.line_views = []
        self.line_click_listeners = []
        self.has_synced = False

        self.root.removeAllViews()
        self._build_header()
        self._build_body_loading()

        if clear_background:
            self._clear_cover_background()

        self._load_cover_background_async(generation)
        threading.Thread(
            target=lambda: self._load_lyrics_background(generation, track),
            name="LyricsLRCLIBLoad",
            daemon=True,
        ).start()

    def _check_track_changed(self) -> bool:
        try:
            # Если музыка остановлена или Telegram на мгновение ещё не отдал данные нового трека,
            # не сбрасываем текущий экран в ошибку. Ждём следующего тика.
            if not is_music():
                return False
            new_track = get_current_track_info()
            if not new_track.query:
                return False
            if new_track.cache_key != self.track.cache_key:
                # Не очищаем старую обложку сразу: держим её как placeholder,
                # пока новая не подгрузится и не проявится плавно.
                self._reload_for_track(new_track, clear_background=False)
                return True
        except Exception as e:
            self.plugin.log("track change check failed: " + str(e))
        return False

    def _load_lyrics_background(self, generation: int, track: TrackInfo):
        try:
            result = self.provider.get_lyrics(track)
            run_on_ui_thread_safe(lambda: self._show_lyrics(result, generation))
        except Exception as e:
            self.plugin.log("Lyrics load failed: " + str(e))
            self.plugin.log(traceback.format_exc())
            run_on_ui_thread_safe(lambda: self._show_error(str(e), generation))

    def _show_error(self, message: str, generation: Optional[int] = None):
        if generation is not None and generation != self.load_generation:
            return
        if not self.root:
            return
        self.loading_started_at = 0.0
        self.root.removeAllViews()
        self._build_header()

        box = LinearLayout(self.context)
        box.setOrientation(LinearLayout.VERTICAL)
        box.setGravity(Gravity.CENTER)
        box.setPadding(dp(self.context, 24), dp(self.context, 24), dp(self.context, 24), dp(self.context, 24))
        self.root.addView(box, LinearLayout.LayoutParams(-1, 0, 1.0))

        title = TextView(self.context)
        title.setText("Текст не найден :<")
        title.setGravity(Gravity.CENTER)
        title.setTextColor(COLOR_TEXT_ERROR)
        title.setTextSize(22)
        title.setTypeface(Typeface.DEFAULT_BOLD)
        self._apply_active_text_shadow(title)
        box.addView(title, LinearLayout.LayoutParams(-1, -2))

        msg = TextView(self.context)
        msg.setText(message)
        msg.setGravity(Gravity.CENTER)
        msg.setTextColor(self._muted_text_color())
        msg.setTextSize(15)
        self._apply_inactive_text_shadow(msg)
        lp = LinearLayout.LayoutParams(-1, -2)
        lp.setMargins(0, dp(self.context, 12), 0, 0)
        box.addView(msg, lp)

        retry = TextView(self.context)
        retry.setText("Повторить поиск")
        retry.setGravity(Gravity.CENTER)
        retry.setTextColor(Color.WHITE)
        retry.setTextSize(16)
        retry.setTypeface(Typeface.DEFAULT_BOLD)
        self._apply_active_text_shadow(retry)
        retry.setPadding(dp(self.context, 18), dp(self.context, 12), dp(self.context, 18), dp(self.context, 12))
        retry.setBackground(self._round_rect(Color.rgb(32, 32, 32), 18))
        retry.setOnClickListener(ViewClickListener(lambda _: self._retry()))
        lp_retry = LinearLayout.LayoutParams(-2, -2)
        lp_retry.setMargins(0, dp(self.context, 22), 0, 0)
        box.addView(retry, lp_retry)

    def _retry(self):
        if not self.root:
            return
        self._reload_for_track(get_current_track_info(), clear_background=False)

    def _show_lyrics(self, result: LyricsResult, generation: Optional[int] = None):
        if generation is not None and generation != self.load_generation:
            return
        if not self.root:
            return
        self.loading_started_at = 0.0
        self.source_url = result.source_url
        self.root.removeAllViews()
        self._build_header()

        self.has_synced = result.synced
        self.scroll = ScrollView(self.context)
        self.scroll.setFillViewport(True)
        self.scroll.setClipToPadding(False)
        self.scroll.setPadding(0, dp(self.context, SCROLL_TOP_PADDING_DP), 0, dp(self.context, SCROLL_BOTTOM_PADDING_DP))
        self.root.addView(self.scroll, LinearLayout.LayoutParams(-1, 0, 1.0))

        self.lines_container = LinearLayout(self.context)
        self.lines_container.setOrientation(LinearLayout.VERTICAL)
        self.lines_container.setGravity(Gravity.CENTER_HORIZONTAL)
        self.lines_container.setPadding(dp(self.context, SIDE_PADDING_DP), 0, dp(self.context, SIDE_PADDING_DP), 0)
        self.scroll.addView(self.lines_container, ScrollView.LayoutParams(-1, -2))

        self.lines = []
        self.line_times = []
        self.line_views = []
        self.line_click_listeners = []

        for index, item in enumerate(result.lines):
            line = safe_str(item.get("text"))
            time_value = item.get("time")
            self.lines.append(line)
            self.line_times.append(None if time_value is None else float_safe(time_value, None))

            tv = TextView(self.context)
            tv.setGravity(Gravity.CENTER)
            tv.setTextColor(self._inactive_text_color())
            tv.setTextSize(self._line_text_size())
            tv.setTypeface(Typeface.DEFAULT_BOLD)
            self._apply_inactive_text_shadow(tv)
            tv.setIncludeFontPadding(True)
            tv.setText(line if line else " ")

            # Двойное нажатие по строке с таймкодом перематывает трек к этой строке.
            # Для plainLyrics без таймкодов действие не навешиваем, чтобы не было случайных прыжков.
            if time_value is not None:
                try:
                    listener = DoubleTapLineClickListener(lambda _view, i=index: self._seek_to_line_index(i))
                    tv.setClickable(True)
                    tv.setOnClickListener(listener)
                    self.line_click_listeners.append(listener)
                except Exception:
                    pass

            lp = LinearLayout.LayoutParams(-1, -2 if line else dp(self.context, EMPTY_LINE_HEIGHT_DP))
            lp.setMargins(0, dp(self.context, LINE_MARGIN_VERTICAL_DP), 0, dp(self.context, LINE_MARGIN_VERTICAL_DP))
            self.lines_container.addView(tv, lp)
            self.line_views.append(tv)

        self.source_text = TextView(self.context)
        self.source_text.setGravity(Gravity.CENTER)
        self.source_text.setTextColor(self._muted_text_color())
        self.source_text.setTextSize(12)
        self._apply_inactive_text_shadow(self.source_text)
        if result.synced:
            self.source_text.setText("Источник текста: LRCLIB")
        else:
            self.source_text.setText("Источник текста: LRCLIB • без таймкодов :(")
        lp_source = LinearLayout.LayoutParams(-1, -2)
        lp_source.setMargins(0, dp(self.context, 24), 0, dp(self.context, 30))
        self.lines_container.addView(self.source_text, lp_source)

        # Синхронизированным LRC-текстам сразу выбираем актуальную строку.
        # Для plainLyrics без таймкодов не подсвечиваем белую строку вообще:
        # весь текст остаётся серым и не "живет своей жизнью".
        if result.synced:
            self._update_current_line(force=True, instant_scroll=True)
            self._schedule_initial_scroll(generation)
        else:
            self.current_index = -1

    def _sync_loop(self):
        while self.running:
            time.sleep(SYNC_INTERVAL_SEC)
            try:
                if not self.dialog or not self.dialog.isShowing():
                    self.running = False
                    break
                run_on_ui_thread_safe(self._sync_tick)
            except Exception:
                self.running = False
                break
        self.sync_loop_started = False

    def _sync_tick(self):
        if self._check_track_changed():
            return
        if self._check_loading_timeout():
            return
        self._update_current_line()

    def _check_loading_timeout(self) -> bool:
        try:
            if self.loading_started_at <= 0:
                return False
            # Если текст уже показан или открыт экран ошибки, таймер больше не нужен.
            if self.line_views:
                return False
            if time.time() - self.loading_started_at < SEARCH_UI_TIMEOUT_SEC:
                return False
            generation = self.load_generation
            # Инвалидируем поздний ответ старого потока, чтобы он не перерисовал экран после таймаута.
            self.load_generation += 1
            self.loading_started_at = 0.0
            self._show_error(SEARCH_TIMEOUT_MESSAGE, None)
            self.plugin.log("LRCLIB search timed out on UI after " + str(SEARCH_UI_TIMEOUT_SEC) + " sec, generation " + str(generation))
            return True
        except Exception as e:
            self.plugin.log("loading timeout check failed: " + str(e))
            return False

    def _seek_to_line_index(self, index: int) -> None:
        try:
            if index < 0 or index >= len(self.line_times):
                return
            time_value = self.line_times[index]
            if time_value is None:
                return

            seconds = max(0.0, float_safe(time_value, 0.0))
            ok = seek_current_track_to_sec(seconds, self.track.duration)
            if ok:
                self.current_index = -1
                self._update_current_line(force=True, instant_scroll=False)
                try:
                    view = self.line_views[index]
                    view.animate().cancel()
                    view.setScaleX(0.97)
                    view.setScaleY(0.97)
                    view.animate().scaleX(1.0).scaleY(1.0).setDuration(120).start()
                except Exception:
                    pass
            else:
                self.plugin.log("seek failed for lyric line at " + str(seconds) + " sec")
        except Exception as e:
            self.plugin.log("line double-tap seek failed: " + str(e))

    def _update_current_line(self, force: bool = False, instant_scroll: bool = False):
        if not self.line_views:
            return

        # У plainLyrics нет реальных таймкодов, поэтому не выделяем "активную"
        # белую строку по примерному прогрессу трека. Весь текст остаётся серым.
        if not self.has_synced:
            if self.current_index != -1:
                self.current_index = -1
                for line_view in self.line_views:
                    try:
                        line_view.animate().cancel()
                        line_view.setTextColor(self._inactive_text_color())
                        line_view.setTextSize(self._line_text_size())
                        line_view.setTypeface(Typeface.DEFAULT_BOLD)
                        self._apply_inactive_text_shadow(line_view)
                        line_view.setScaleX(1.0)
                        line_view.setScaleY(1.0)
                        line_view.setAlpha(1.0)
                    except Exception:
                        pass
            return

        index = self._calculate_current_index()
        if not force and index == self.current_index:
            return

        old_index = self.current_index
        self.current_index = index

        if 0 <= old_index < len(self.line_views):
            old = self.line_views[old_index]
            old.setTextColor(self._inactive_text_color())
            old.setTextSize(self._line_text_size())
            old.setTypeface(Typeface.DEFAULT_BOLD)
            self._apply_inactive_text_shadow(old)
            self._animate_line_out(old)

        current = self.line_views[index]
        current.setTextColor(COLOR_TEXT_ACTIVE)
        current.setTextSize(self._active_line_text_size())
        current.setTypeface(Typeface.DEFAULT_BOLD)
        self._apply_active_text_shadow(current)
        self._animate_line_in(current, force)

        self._scroll_to_index(index, instant=instant_scroll)

    def _animate_line_in(self, view: TextView, force: bool = False) -> None:
        if not self._animate_lines_enabled() or force:
            try:
                view.setScaleX(1.0)
                view.setScaleY(1.0)
                view.setAlpha(1.0)
            except Exception:
                pass
            return
        try:
            view.animate().cancel()
            view.setAlpha(0.86)
            view.setScaleX(0.965)
            view.setScaleY(0.965)
            view.animate().alpha(1.0).scaleX(1.0).scaleY(1.0).setDuration(self._animation_ms()).start()
        except Exception:
            pass

    def _animate_line_out(self, view: TextView) -> None:
        if not self._animate_lines_enabled():
            try:
                view.setScaleX(1.0)
                view.setScaleY(1.0)
                view.setAlpha(1.0)
            except Exception:
                pass
            return
        try:
            view.animate().cancel()
            view.animate().alpha(1.0).scaleX(1.0).scaleY(1.0).setDuration(self._animation_ms()).start()
        except Exception:
            pass

    def _calculate_current_index(self) -> int:
        progress = max(0.0, get_current_progress_sec() + self._sync_offset_sec())

        if self.has_synced and self.line_times:
            best_index = 0
            found = False
            for i, time_value in enumerate(self.line_times):
                if time_value is None:
                    continue
                if float_safe(time_value) <= progress:
                    best_index = i
                    found = True
                else:
                    break
            if found:
                return max(0, min(len(self.line_views) - 1, best_index))
            # До первой LRC-строки держим первую строку, а не прыгаем по всему тексту.
            return 0

        # Fallback для plainLyrics без таймкодов.
        duration = self.track.duration if self.track.duration > 0 else get_current_duration_sec()
        non_empty_indices = [i for i, line in enumerate(self.lines) if line.strip()]
        if not non_empty_indices:
            return 0
        if duration <= 0:
            return non_empty_indices[0]

        ratio = max(0.0, min(1.0, progress / duration))
        pos = int(round(ratio * (len(non_empty_indices) - 1)))
        return non_empty_indices[max(0, min(len(non_empty_indices) - 1, pos))]

    def _schedule_initial_scroll(self, generation: Optional[int] = None):
        # Сразу после построения списка Android ещё может не знать реальные размеры строк.
        # Поэтому делаем несколько коротких повторов: первый почти мгновенный, остальные
        # страхуют случаи, когда разметка/шрифт/обложка догружаются чуть позже.
        def worker():
            for delay in (0.03, 0.10, 0.22, 0.45):
                time.sleep(delay)
                run_on_ui_thread_safe(lambda g=generation: self._scroll_to_current_after_layout(g))

        try:
            threading.Thread(target=worker, name="LyricsInitialScroll", daemon=True).start()
        except Exception:
            pass

    def _scroll_to_current_after_layout(self, generation: Optional[int] = None):
        if generation is not None and generation != self.load_generation:
            return
        if not self.scroll or not self.line_views:
            return
        try:
            index = self._calculate_current_index()
            self._update_current_line(force=True, instant_scroll=True)
            self._scroll_to_index(index, instant=True)
        except Exception:
            pass

    def _scroll_to_index(self, index: int, instant: bool = False):
        if not self.scroll or index < 0 or index >= len(self.line_views):
            return
        try:
            line_view = self.line_views[index]
            top = line_view.getTop()
            height = line_view.getHeight()
            scroll_height = self.scroll.getHeight()
            padding_top = self.scroll.getPaddingTop()

            # Если layout ещё не прошёл, размеры будут нулевыми. В таком случае ничего
            # не делаем: _schedule_initial_scroll повторит прокрутку через несколько мс.
            if scroll_height <= 0 or height <= 0:
                return

            # В старой версии строка получалась ниже центра, потому что в расчёте не учитывался
            # верхний padding у ScrollView. Добавляем padding_top к target_y — строка становится
            # реально по центру видимой области, а не на padding_top ниже.
            target_y = max(0, int(top - scroll_height / 2 + height / 2 + padding_top))
            if instant:
                self.scroll.scrollTo(0, target_y)
            else:
                self.scroll.smoothScrollTo(0, target_y)
        except Exception:
            pass

    def _setting_int(self, key: str, default: int, minimum: int, maximum: int) -> int:
        return setting_int(self.plugin, key, default, minimum, maximum)

    def _setting_float(self, key: str, default: float, minimum: float, maximum: float) -> float:
        return setting_float(self.plugin, key, default, minimum, maximum)

    def _header_height_dp(self) -> int:
        return self._setting_int("header_height_dp", DEFAULT_HEADER_HEIGHT_DP, 52, 92)

    def _header_bg_color(self) -> int:
        return Color.argb(self._setting_int("header_alpha", DEFAULT_HEADER_ALPHA, 0, 255), 10, 10, 10)

    def _dim_overlay_color(self) -> int:
        return Color.argb(self._setting_int("dim_alpha", DEFAULT_DIM_ALPHA, 0, 230), 0, 0, 0)

    def _inactive_alpha(self) -> int:
        return self._setting_int("inactive_alpha", DEFAULT_INACTIVE_ALPHA, 70, 230)

    def _inactive_text_color(self) -> int:
        return argb_gray(self._inactive_alpha(), 185)

    def _muted_text_color(self) -> int:
        return argb_gray(self._inactive_alpha(), 185)

    def _title_text_size(self) -> int:
        return self._setting_int("title_text_size", DEFAULT_TITLE_TEXT_SIZE, 12, 24)

    def _subtitle_text_size(self) -> int:
        return self._setting_int("subtitle_text_size", DEFAULT_SUBTITLE_TEXT_SIZE, 10, 20)

    def _line_text_size(self) -> int:
        return self._setting_int("line_text_size", DEFAULT_LINE_TEXT_SIZE, 18, 42)

    def _active_line_text_size(self) -> int:
        return self._setting_int("active_line_text_size", DEFAULT_ACTIVE_LINE_TEXT_SIZE, 20, 50)

    def _active_text_shadow_radius(self) -> float:
        return float(self._setting_int("active_text_shadow_radius", int(round(DEFAULT_ACTIVE_TEXT_SHADOW_RADIUS)), 0, 10))

    def _inactive_text_shadow_radius(self) -> float:
        return float(self._setting_int("inactive_text_shadow_radius", int(round(DEFAULT_INACTIVE_TEXT_SHADOW_RADIUS)), 0, 10))

    def _blur_radius(self) -> int:
        return self._setting_int("blur_radius", DEFAULT_BLUR_RADIUS, 0, 32)

    def _animate_lines_enabled(self) -> bool:
        return setting_bool(self.plugin, "animate_lines", DEFAULT_ANIMATE_LINES)

    def _animation_ms(self) -> int:
        return self._setting_int("animation_ms", DEFAULT_ANIMATION_MS, 60, 450)

    def _sync_offset_sec(self) -> float:
        return self._setting_float("sync_offset_sec", DEFAULT_SYNC_OFFSET_SEC, -5.0, 5.0)

    def close(self):
        self.running = False
        try:
            if self.dialog:
                self.dialog.dismiss()
        except Exception:
            pass
        try:
            if self.bg_bitmap is not None and not self.bg_bitmap.isRecycled():
                self.bg_bitmap.recycle()
        except Exception:
            pass
        self.bg_bitmap = None

    def _apply_active_text_shadow(self, text_view: TextView) -> None:
        try:
            text_view.setShadowLayer(self._active_text_shadow_radius(), TEXT_SHADOW_DX, TEXT_SHADOW_DY, TEXT_SHADOW_COLOR)
        except Exception:
            pass

    def _apply_inactive_text_shadow(self, text_view: TextView) -> None:
        try:
            text_view.setShadowLayer(self._inactive_text_shadow_radius(), TEXT_SHADOW_DX, TEXT_SHADOW_DY, TEXT_SHADOW_COLOR)
        except Exception:
            pass

    def _clear_cover_background(self) -> None:
        try:
            if self.background_fade_image:
                self.background_fade_image.animate().cancel()
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        except Exception:
            pass
        try:
            if self.background_image:
                self.background_image.animate().cancel()
                self.background_image.setAlpha(1.0)
                self.background_image.setImageDrawable(None)
                self.background_image.setBackgroundColor(COLOR_BG)
        except Exception:
            pass
        try:
            if self.bg_bitmap is not None and not self.bg_bitmap.isRecycled():
                self.bg_bitmap.recycle()
        except Exception:
            pass
        self.bg_bitmap = None
        self.bg_path = None

    def _cover_fade_ms(self) -> int:
        # Пока без отдельной настройки, чтобы не раздувать меню: значение подобрано так,
        # чтобы обложка появлялась мягко, но не ощущалась медленной.
        return DEFAULT_COVER_FADE_MS

    def _ambient_enabled(self) -> bool:
        return setting_bool(self.plugin, "ambient_enabled", DEFAULT_AMBIENT_ENABLED)

    def _ambient_alpha(self) -> int:
        return self._setting_int("ambient_alpha", DEFAULT_AMBIENT_ALPHA, 0, 180)

    def _ambient_blob_count(self) -> int:
        return self._setting_int("ambient_blobs", DEFAULT_AMBIENT_BLOBS, 2, 12)

    def _ambient_blob_size_dp(self) -> int:
        return self._setting_int("ambient_blob_size_dp", DEFAULT_AMBIENT_BLOB_SIZE_DP, 160, 720)

    def _ambient_speed_sec(self) -> int:
        return self._setting_int("ambient_speed_sec", DEFAULT_AMBIENT_SPEED_SEC, 4, 28)

    def _ambient_saturation(self) -> int:
        return self._setting_int("ambient_saturation", DEFAULT_AMBIENT_SATURATION, 50, 220)

    def _fallback_ambient_palette(self) -> List[Tuple[int, int, int]]:
        return [(146, 83, 255), (51, 154, 255), (255, 84, 162), (255, 190, 92), (92, 255, 214)]

    def _extract_ambient_palette(self, src_path: str) -> Optional[List[Tuple[int, int, int]]]:
        """Берём цвета именно из обложки, без сильного искусственного перекраса.

        Предыдущая версия слишком сильно вытягивала насыщенность и яркость, поэтому
        ambient-слой иногда выглядел "не от этой обложки". Здесь логика мягче:
        - используем реальные доминирующие цвета;
        - не превращаем серые/тёмные оттенки в кислотные;
        - добавляем средний цвет обложки, чтобы палитра лучше совпадала с общей гаммой.
        """
        if not PIL_AVAILABLE or not src_path or not os.path.exists(src_path):
            return None
        try:
            im = Image.open(src_path).convert("RGB")
            im.thumbnail((80, 80))

            pixels = list(im.getdata())
            if not pixels:
                return None

            avg_r = sum(p[0] for p in pixels) // len(pixels)
            avg_g = sum(p[1] for p in pixels) // len(pixels)
            avg_b = sum(p[2] for p in pixels) // len(pixels)

            try:
                pal_img = im.convert("P", palette=Image.ADAPTIVE, colors=18)
            except Exception:
                pal_img = im.convert("P", colors=18)
            palette_raw = pal_img.getpalette() or []
            colors = pal_img.getcolors(80 * 80) or []

            candidates: List[Tuple[float, Tuple[int, int, int]]] = []
            saturation_mul = self._ambient_saturation() / 100.0

            for count, idx in colors:
                base = int(idx) * 3
                if base + 2 >= len(palette_raw):
                    continue
                r, g, b = int(palette_raw[base]), int(palette_raw[base + 1]), int(palette_raw[base + 2])
                h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)

                # Почти чёрные цвета оставляем только если они реально заметны, иначе пятна будут грязными.
                if val < 0.08:
                    continue

                # Очень аккуратная коррекция: цвет остаётся цветом обложки, а настройка насыщенности
                # только слегка усиливает/ослабляет его, не перепридумывая палитру.
                if sat > 0.06:
                    sat = max(0.04, min(1.0, sat * saturation_mul))
                val = max(0.16, min(0.98, val))
                rr, gg, bb = colorsys.hsv_to_rgb(h, sat, val)
                rgb = (int(rr * 255), int(gg * 255), int(bb * 255))

                # Балансируем частотность и выразительность. Так палитра не становится случайным
                # набором редких ярких пикселей, но и не уходит в один серый/чёрный цвет.
                score = float(count) * (0.55 + sat) * (0.55 + val)
                candidates.append((score, rgb))

            # Средний цвет помогает ambient-слою совпасть с общей гаммой обложки.
            avg_h, avg_s, avg_v = colorsys.rgb_to_hsv(avg_r / 255.0, avg_g / 255.0, avg_b / 255.0)
            if avg_v >= 0.08:
                avg_s = max(0.04, min(1.0, avg_s * saturation_mul)) if avg_s > 0.06 else avg_s
                rr, gg, bb = colorsys.hsv_to_rgb(avg_h, avg_s, max(0.16, min(0.98, avg_v)))
                candidates.append((len(pixels) * 0.35, (int(rr * 255), int(gg * 255), int(bb * 255))))

            candidates.sort(reverse=True, key=lambda item: item[0])

            output: List[Tuple[int, int, int]] = []
            for _, rgb in candidates:
                too_close = False
                for old in output:
                    if abs(old[0] - rgb[0]) + abs(old[1] - rgb[1]) + abs(old[2] - rgb[2]) < 44:
                        too_close = True
                        break
                if not too_close:
                    output.append(rgb)
                if len(output) >= 8:
                    break

            # Если обложка почти монохромная, всё равно даём несколько близких вариантов,
            # чтобы пятна не выглядели одинаковыми.
            if len(output) == 1:
                r, g, b = output[0]
                h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)
                for delta in (-0.035, 0.028, 0.055):
                    rr, gg, bb = colorsys.hsv_to_rgb((h + delta) % 1.0, sat, max(0.14, min(0.98, val * random.uniform(0.86, 1.10))))
                    output.append((int(rr * 255), int(gg * 255), int(bb * 255)))

            return output or None
        except Exception as e:
            self.plugin.log("ambient palette failed: " + str(e))
            return None

    def _ambient_blob_drawable(self, rgb: Tuple[int, int, int], size_px: int) -> GradientDrawable:
        r, g, b = rgb
        drawable = GradientDrawable()
        try:
            drawable.setShape(GradientDrawable.OVAL)
            drawable.setGradientType(GradientDrawable.RADIAL_GRADIENT)
            drawable.setGradientCenter(0.5, 0.5)
            drawable.setGradientRadius(float(size_px) * 0.56)
            # Центр чуть прозрачнее, чем раньше: цвета мягче слипаются и меньше выбиваются из обложки.
            drawable.setColors([
                Color.argb(210, r, g, b),
                Color.argb(88, r, g, b),
                Color.argb(0, r, g, b),
            ])
        except Exception:
            try:
                drawable.setShape(GradientDrawable.OVAL)
                drawable.setColor(Color.argb(72, r, g, b))
            except Exception:
                pass
        return drawable

    def _shift_ambient_color(self, rgb: Tuple[int, int, int], state: Dict[str, Any]) -> Tuple[int, int, int]:
        """Лёгкая смена оттенка без ухода от палитры обложки."""
        try:
            r, g, b = rgb
            h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)
            phase = float_safe(state.get("phase"), 0.0)
            # Максимум около ±3.5% круга оттенка — ощущается живо, но цвет всё ещё "из обложки".
            hue_shift = math.sin(phase) * 0.035
            sat_mul = 0.92 + 0.14 * math.sin(phase * 0.73 + 1.7)
            val_mul = 0.92 + 0.16 * math.cos(phase * 0.61 + 0.9)
            rr, gg, bb = colorsys.hsv_to_rgb((h + hue_shift) % 1.0, max(0.0, min(1.0, sat * sat_mul)), max(0.12, min(1.0, val * val_mul)))
            return (int(rr * 255), int(gg * 255), int(bb * 255))
        except Exception:
            return rgb

    def _rebuild_ambient_blobs(self, palette: Optional[List[Tuple[int, int, int]]] = None) -> None:
        try:
            if not self.ambient_container:
                return
            had_blobs = bool(self.ambient_blob_views)
            self.ambient_container.removeAllViews()
            self.ambient_blob_views = []
            self.ambient_blob_states = []

            if not self._ambient_enabled() or self._ambient_alpha() <= 0:
                try:
                    self.ambient_container.setVisibility(View.GONE)
                except Exception:
                    pass
                return

            try:
                self.ambient_container.setVisibility(View.VISIBLE)
            except Exception:
                pass
            target_alpha = max(0.0, min(1.0, self._ambient_alpha() / 255.0))
            # При смене палитры мягко проявляем новый слой, чтобы цвета не прыгали резко.
            self.ambient_container.setAlpha(0.0 if (had_blobs or palette) else target_alpha)

            self.ambient_palette = palette or self._fallback_ambient_palette()
            count = self._ambient_blob_count()
            size_px = dp(self.context, self._ambient_blob_size_dp())
            w, h = self._ambient_screen_size()
            for i in range(count):
                color = self.ambient_palette[i % len(self.ambient_palette)]
                blob = View(self.context)
                blob.setBackground(self._ambient_blob_drawable(color, size_px))
                try:
                    blob.setAlpha(random.uniform(0.62, 0.95))
                except Exception:
                    pass
                lp = FrameLayout.LayoutParams(size_px, size_px)
                self.ambient_container.addView(blob, lp)
                self.ambient_blob_views.append(blob)

                state = {
                    "base_color": color,
                    "phase": random.uniform(0.0, 6.28318),
                    "angle": random.uniform(0.0, 6.28318),
                    "x": random.uniform(-size_px * 0.42, max(1.0, w - size_px * 0.58)),
                    "y": random.uniform(-size_px * 0.36, max(1.0, h - size_px * 0.48)),
                    "scale": random.uniform(0.82, 1.22),
                    "alpha": random.uniform(0.58, 0.96),
                }
                self.ambient_blob_states.append(state)

            self._animate_ambient_step(first=True)
            try:
                self.ambient_container.animate().alpha(target_alpha).setDuration(max(180, self._cover_fade_ms())).start()
            except Exception:
                self.ambient_container.setAlpha(target_alpha)
        except Exception as e:
            self.plugin.log("ambient rebuild failed: " + str(e))

    def _ensure_ambient_loop(self) -> None:
        if self.ambient_loop_started:
            return
        self.ambient_loop_started = True

        def worker():
            try:
                # Небольшая задержка нужна, чтобы FrameLayout успел получить размеры.
                time.sleep(0.20)
                while self.running and self.dialog and self.dialog.isShowing():
                    if self._ambient_enabled() and self.ambient_blob_views:
                        run_on_ui_thread_safe(lambda: self._animate_ambient_step(first=False))
                    # Частые маленькие шаги лучше длинных переходов: нет ощущения, что круги
                    # доехали до точки и остановились.
                    time.sleep(max(0.45, min(2.2, self._ambient_speed_sec() / 9.0)))
            except Exception:
                pass
            self.ambient_loop_started = False

        try:
            threading.Thread(target=worker, name="LyricsAmbientOverlay", daemon=True).start()
        except Exception:
            self.ambient_loop_started = False

    def _ambient_screen_size(self) -> Tuple[int, int]:
        try:
            if self.frame_root:
                w = self.frame_root.getWidth()
                h = self.frame_root.getHeight()
                if w > 0 and h > 0:
                    return int(w), int(h)
        except Exception:
            pass
        try:
            dm = self.context.getResources().getDisplayMetrics()
            return int(dm.widthPixels), int(dm.heightPixels)
        except Exception:
            return dp(self.context, 390), dp(self.context, 780)

    def _ambient_linear_interpolator(self) -> Any:
        try:
            return jclass("android.view.animation.LinearInterpolator")()
        except Exception:
            return None

    def _animate_ambient_step(self, first: bool = False) -> None:
        try:
            if not self.ambient_container or not self.ambient_blob_views or not self._ambient_enabled():
                return
            w, h = self._ambient_screen_size()
            size_px = dp(self.context, self._ambient_blob_size_dp())
            step_delay = max(0.45, min(2.2, self._ambient_speed_sec() / 9.0))
            duration = 0 if first else int(step_delay * 1450)
            interpolator = None if first else self._ambient_linear_interpolator()

            # Если по какой-то причине состояний меньше, чем view, восстанавливаем их без падения.
            while len(self.ambient_blob_states) < len(self.ambient_blob_views):
                color = self.ambient_palette[len(self.ambient_blob_states) % max(1, len(self.ambient_palette))] if self.ambient_palette else self._fallback_ambient_palette()[0]
                self.ambient_blob_states.append({
                    "base_color": color,
                    "phase": random.uniform(0.0, 6.28318),
                    "angle": random.uniform(0.0, 6.28318),
                    "x": random.uniform(-size_px * 0.42, max(1.0, w - size_px * 0.58)),
                    "y": random.uniform(-size_px * 0.36, max(1.0, h - size_px * 0.48)),
                    "scale": random.uniform(0.82, 1.22),
                    "alpha": random.uniform(0.58, 0.96),
                })

            for i, blob in enumerate(self.ambient_blob_views):
                state = self.ambient_blob_states[i]
                min_x = -int(size_px * 0.48)
                max_x = max(min_x + 1, w - int(size_px * 0.52))
                min_y = -int(size_px * 0.42)
                max_y = max(min_y + 1, h - int(size_px * 0.48))

                if first:
                    x = float_safe(state.get("x"), random.uniform(min_x, max_x))
                    y = float_safe(state.get("y"), random.uniform(min_y, max_y))
                    scale = float_safe(state.get("scale"), random.uniform(0.82, 1.22))
                    alpha = float_safe(state.get("alpha"), random.uniform(0.58, 0.96))
                else:
                    # Хаотичная, но плавная траектория: random-walk + синусоидальные микросмещения.
                    phase = float_safe(state.get("phase"), 0.0) + random.uniform(0.22, 0.62)
                    angle = float_safe(state.get("angle"), 0.0) + random.uniform(-1.35, 1.35)
                    speed_factor = max(0.42, min(1.45, 11.0 / max(4.0, float(self._ambient_speed_sec()))))
                    step = size_px * random.uniform(0.045, 0.13) * speed_factor
                    swirl_x = math.sin(phase * 1.31 + i * 0.77) * size_px * random.uniform(0.010, 0.032)
                    swirl_y = math.cos(phase * 1.17 + i * 0.91) * size_px * random.uniform(0.010, 0.032)
                    x = float_safe(state.get("x"), random.uniform(min_x, max_x)) + math.cos(angle) * step + swirl_x
                    y = float_safe(state.get("y"), random.uniform(min_y, max_y)) + math.sin(angle) * step + swirl_y

                    # Мягкий отскок от краёв, чтобы круги не зависали снаружи и не телепортировались.
                    if x < min_x or x > max_x:
                        angle = math.pi - angle + random.uniform(-0.55, 0.55)
                        x = max(min_x, min(max_x, x))
                    if y < min_y or y > max_y:
                        angle = -angle + random.uniform(-0.55, 0.55)
                        y = max(min_y, min(max_y, y))

                    scale = max(0.72, min(1.36, float_safe(state.get("scale"), 1.0) + random.uniform(-0.055, 0.055) + math.sin(phase * 0.7 + i) * 0.018))
                    alpha = max(0.48, min(1.0, float_safe(state.get("alpha"), 0.8) + random.uniform(-0.045, 0.045)))
                    state["phase"] = phase
                    state["angle"] = angle
                    state["x"] = x
                    state["y"] = y
                    state["scale"] = scale
                    state["alpha"] = alpha

                    shifted = self._shift_ambient_color(state.get("base_color", self.ambient_palette[i % len(self.ambient_palette)] if self.ambient_palette else (255, 255, 255)), state)
                    try:
                        blob.setBackground(self._ambient_blob_drawable(shifted, size_px))
                    except Exception:
                        pass

                if first:
                    blob.setTranslationX(float(x))
                    blob.setTranslationY(float(y))
                    blob.setScaleX(scale)
                    blob.setScaleY(scale)
                    blob.setAlpha(alpha)
                    try:
                        shifted = self._shift_ambient_color(state.get("base_color", self.ambient_palette[i % len(self.ambient_palette)] if self.ambient_palette else (255, 255, 255)), state)
                        blob.setBackground(self._ambient_blob_drawable(shifted, size_px))
                    except Exception:
                        pass
                else:
                    try:
                        blob.animate().cancel()
                    except Exception:
                        pass
                    try:
                        animator = blob.animate().translationX(float(x)).translationY(float(y)).scaleX(scale).scaleY(scale).alpha(alpha).setDuration(duration)
                        if interpolator is not None:
                            animator.setInterpolator(interpolator)
                        animator.start()
                    except Exception:
                        blob.setTranslationX(float(x))
                        blob.setTranslationY(float(y))
                        blob.setScaleX(scale)
                        blob.setScaleY(scale)
                        blob.setAlpha(alpha)
        except Exception as e:
            self.plugin.log("ambient animate failed: " + str(e))

    def _load_cover_background_async(self, generation: Optional[int] = None) -> None:
        if not self.background_image:
            return
        if generation is None:
            generation = self.load_generation
        track_snapshot = self.track

        def worker():
            bitmap = None
            bg_path = None
            try:
                cover_path = self._extract_album_art_path()
                if not cover_path:
                    cover_path = self._fetch_cover_online(track_snapshot.title, track_snapshot.artist)

                if cover_path and os.path.exists(cover_path):
                    if PIL_AVAILABLE:
                        bg_path = self._make_blurred_cache(cover_path, track_snapshot)
                    else:
                        bg_path = cover_path

                palette = None
                if cover_path and os.path.exists(cover_path):
                    palette = self._extract_ambient_palette(cover_path)
                elif bg_path and os.path.exists(bg_path):
                    palette = self._extract_ambient_palette(bg_path)

                if bg_path and os.path.exists(bg_path):
                    options = BitmapFactory.Options()
                    options.inPreferredConfig = Bitmap.Config.ARGB_8888
                    bitmap = BitmapFactory.decodeFile(bg_path, options)

                if bitmap is not None:
                    run_on_ui_thread_safe(lambda p=bg_path, b=bitmap, g=generation, pal=palette: self._apply_cover_bitmap(p, b, g, pal))
                else:
                    # Если у трека реально нет обложки, убираем старую не резко, а плавно.
                    run_on_ui_thread_safe(lambda g=generation: self._fade_to_empty_cover(g))
            except Exception as e:
                self.plugin.log("cover background failed: " + str(e))
                try:
                    if bitmap is not None and not bitmap.isRecycled():
                        bitmap.recycle()
                except Exception:
                    pass

        threading.Thread(target=worker, name="LyricsCoverBG", daemon=True).start()

    def _apply_cover_bitmap(self, path: Optional[str], bitmap: Bitmap, generation: Optional[int] = None, palette: Optional[List[Tuple[int, int, int]]] = None) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                if bitmap is not None and not bitmap.isRecycled():
                    bitmap.recycle()
                return
            if not self.dialog or not self.dialog.isShowing() or not self.background_image:
                if bitmap is not None and not bitmap.isRecycled():
                    bitmap.recycle()
                return
            if bitmap is None or bitmap.isRecycled():
                return

            self._rebuild_ambient_blobs(palette)

            old_bitmap = self.bg_bitmap
            drawable = BitmapDrawable(self.context.getResources(), bitmap)
            self.bg_bitmap = bitmap
            self.bg_path = path

            # Если фон уже есть, новая обложка проявляется отдельным слоем поверх старой.
            # Так нет момента с пустым/чёрным фоном и нет резкого скачка картинки.
            if self.background_fade_image and old_bitmap is not None and old_bitmap is not bitmap:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
                self.background_fade_image.setImageDrawable(drawable)
                self.background_fade_image.setAlpha(0.0)
                try:
                    self.background_fade_image.setVisibility(View.VISIBLE)
                except Exception:
                    pass
                try:
                    self.background_fade_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_fade_image.setAlpha(1.0)
                self._finish_cover_crossfade_later(drawable, old_bitmap, generation)
            else:
                try:
                    self.background_image.animate().cancel()
                except Exception:
                    pass
                self.background_image.setImageDrawable(drawable)
                self.background_image.setBackgroundColor(Color.TRANSPARENT)
                self.background_image.setAlpha(0.0)
                try:
                    self.background_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_image.setAlpha(1.0)
                if old_bitmap is not None and old_bitmap is not bitmap:
                    self._recycle_bitmap_later(old_bitmap, self._cover_fade_ms())
        except Exception:
            try:
                if bitmap is not None and bitmap is not self.bg_bitmap and not bitmap.isRecycled():
                    bitmap.recycle()
            except Exception:
                pass

    def _finish_cover_crossfade_later(self, drawable: BitmapDrawable, old_bitmap: Optional[Bitmap], generation: Optional[int]) -> None:
        delay = max(0.05, (self._cover_fade_ms() + 80) / 1000.0)

        def worker():
            time.sleep(delay)
            run_on_ui_thread_safe(lambda: self._finish_cover_crossfade(drawable, old_bitmap, generation))

        threading.Thread(target=worker, name="LyricsCoverFadeFinish", daemon=True).start()

    def _finish_cover_crossfade(self, drawable: BitmapDrawable, old_bitmap: Optional[Bitmap], generation: Optional[int]) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if not self.dialog or not self.dialog.isShowing() or not self.background_image:
                return
            self.background_image.setImageDrawable(drawable)
            self.background_image.setBackgroundColor(Color.TRANSPARENT)
            self.background_image.setAlpha(1.0)
            if self.background_fade_image:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        finally:
            if old_bitmap is not None and old_bitmap is not self.bg_bitmap:
                try:
                    if not old_bitmap.isRecycled():
                        old_bitmap.recycle()
                except Exception:
                    pass

    def _fade_to_empty_cover(self, generation: Optional[int] = None) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if not self.background_image:
                return
            old_bitmap = self.bg_bitmap
            self.bg_bitmap = None
            self.bg_path = None
            self._rebuild_ambient_blobs(None)

            if self.background_fade_image and old_bitmap is not None:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(COLOR_BG)
                self.background_fade_image.setAlpha(0.0)
                try:
                    self.background_fade_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_fade_image.setAlpha(1.0)

                def finish():
                    time.sleep((self._cover_fade_ms() + 80) / 1000.0)
                    run_on_ui_thread_safe(lambda: self._finish_empty_cover(generation, old_bitmap))
                threading.Thread(target=finish, name="LyricsCoverEmptyFade", daemon=True).start()
            else:
                self._finish_empty_cover(generation, old_bitmap)
        except Exception:
            pass

    def _finish_empty_cover(self, generation: Optional[int], old_bitmap: Optional[Bitmap]) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if self.background_image:
                try:
                    self.background_image.animate().cancel()
                except Exception:
                    pass
                self.background_image.setImageDrawable(None)
                self.background_image.setBackgroundColor(COLOR_BG)
                self.background_image.setAlpha(1.0)
            if self.background_fade_image:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        finally:
            if old_bitmap is not None:
                try:
                    if not old_bitmap.isRecycled():
                        old_bitmap.recycle()
                except Exception:
                    pass

    def _recycle_bitmap_later(self, bitmap: Optional[Bitmap], delay_ms: int) -> None:
        if bitmap is None:
            return

        def worker():
            time.sleep(max(0.05, (delay_ms + 80) / 1000.0))
            try:
                if bitmap is not self.bg_bitmap and not bitmap.isRecycled():
                    bitmap.recycle()
            except Exception:
                pass

        threading.Thread(target=worker, name="LyricsCoverRecycle", daemon=True).start()

    def _make_blurred_cache(self, src_path: str, track: Optional[TrackInfo] = None) -> Optional[str]:
        if not PIL_AVAILABLE:
            return None
        try:
            cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
            os.makedirs(cache_dir, exist_ok=True)
            track = track or self.track
            raw_key = f"{track.artist}|{track.title}|{track.duration}|{src_path}|blur={self._blur_radius()}"
            suffix = hashlib.md5(raw_key.encode("utf-8", "ignore")).hexdigest()[:16]
            out_path = os.path.join(cache_dir, f"cover_blur_{suffix}.jpg")

            # Если уже есть готовый размытый фон — не пересоздаём.
            if os.path.exists(out_path) and os.path.getmtime(out_path) >= os.path.getmtime(src_path):
                return out_path

            im = Image.open(src_path).convert("RGB")
            max_side = 720
            w, h = im.size
            scale = max(w, h) / float(max_side)
            if scale > 1.0:
                resample = getattr(Image, "LANCZOS", getattr(Image, "BICUBIC", 3))
                im = im.resize((max(1, int(w / scale)), max(1, int(h / scale))), resample)
            im = im.filter(ImageFilter.GaussianBlur(radius=self._blur_radius()))
            im.save(out_path, "JPEG", quality=68, optimize=True)
            return out_path
        except Exception as e:
            self.plugin.log("make blurred cover failed: " + str(e))
            return None

    def _extract_album_art_path(self) -> Optional[str]:
        try:
            mc = get_media_controller().getInstance()

            # Основной вариант из miniPlayer+: MediaController.getAudioInfo().getCoverFile()
            try:
                ai = mc.getAudioInfo()
                if ai is not None:
                    cf = ai.getCoverFile()
                    if cf is not None and cf.exists():
                        return cf.getAbsolutePath()
            except Exception:
                pass

            mo = mc.getPlayingMessageObject()
            if mo is None:
                return None
            try:
                doc = mo.getDocument()
            except Exception:
                doc = None
            if doc is None:
                return None

            best_thumb = None
            max_area = -1
            thumbs = getattr(doc, "thumbs", None)
            if thumbs:
                iterator = None
                try:
                    iterator = thumbs.iterator()
                except Exception:
                    iterator = None

                if iterator is not None:
                    while iterator.hasNext():
                        t = iterator.next()
                        area = self._thumb_area(t)
                        if area > max_area:
                            max_area = area
                            best_thumb = t
                else:
                    try:
                        for t in thumbs:
                            area = self._thumb_area(t)
                            if area > max_area:
                                max_area = area
                                best_thumb = t
                    except Exception:
                        pass

            if best_thumb is None:
                return None

            FileLoader = jclass("org.telegram.messenger.FileLoader")
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            fl = FileLoader.getInstance(UserConfig.selectedAccount)
            pf = fl.getPathToAttach(best_thumb, True)
            if pf is not None and pf.exists():
                return pf.getAbsolutePath()

            # Если обложка ещё не скачана, просим Telegram её подгрузить
            # и несколько раз быстро проверяем кэш. Это убирает ситуацию,
            # когда фон появляется только при повторном открытии окна.
            try:
                fl.loadFile(best_thumb, True, False)
            except Exception:
                pass
            for _ in range(8):
                try:
                    time.sleep(0.15)
                    pf = fl.getPathToAttach(best_thumb, True)
                    if pf is not None and pf.exists():
                        return pf.getAbsolutePath()
                except Exception:
                    break
        except Exception as e:
            self.plugin.log("extract album art failed: " + str(e))
        return None

    def _thumb_area(self, thumb: Any) -> int:
        try:
            return int(getattr(thumb, "w", 0)) * int(getattr(thumb, "h", 0))
        except Exception:
            return 0

    def _fetch_cover_online(self, title: str, artist: str) -> Optional[str]:
        # Запасной вариант из miniPlayer+: если Telegram/файл не отдал обложку,
        # пробуем взять artwork из iTunes Search API.
        query = f"{artist} {title}".strip()
        if not query:
            return None
        try:
            resp = requests.get(
                "https://itunes.apple.com/search",
                params={"term": query, "media": "music", "limit": 1},
                timeout=5.0
            )
            if resp.status_code != 200:
                return None
            data = resp.json()
            results = data.get("results") or []
            if not results:
                return None
            art = results[0].get("artworkUrl100")
            if not art:
                return None
            art = art.replace("100x100bb", "1200x1200bb")
            img_resp = requests.get(art, timeout=7.0)
            if img_resp.status_code != 200:
                return None
            cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
            os.makedirs(cache_dir, exist_ok=True)
            suffix = hashlib.md5(query.encode("utf-8", "ignore")).hexdigest()[:16]
            path = os.path.join(cache_dir, f"cover_online_{suffix}.jpg")
            with open(path, "wb") as f:
                f.write(img_resp.content)
            return path
        except Exception as e:
            self.plugin.log("fetch online cover failed: " + str(e))
            return None

    def _round_rect(self, color: int, radius_dp: int) -> GradientDrawable:
        drawable = GradientDrawable()
        drawable.setColor(color)
        drawable.setCornerRadius(dp(self.context, radius_dp))
        return drawable


