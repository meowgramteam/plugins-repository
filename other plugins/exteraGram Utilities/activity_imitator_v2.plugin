class ActivityControlPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._active_loops = {} # Словарь активных циклов для каждого чата
        self._lock = threading.Lock()
        self._langs = ["en", "ru", "fr", "ar", "he"]

    def _get_str(self, key: str) -> Any:
        """Получает строку на выбранном языке из настроек."""
        try:
            # Принудительно приводим к int, так как настройки могут вернуться строкой
            lang_idx = int(self.get_setting("lang_idx", 1))
        except (ValueError, TypeError):
            lang_idx = 1
            
        if lang_idx >= len(self._langs) or lang_idx < 0:
            lang_idx = 0
            
        lang_code = self._langs[lang_idx]
        return STRINGS.get(lang_code, STRINGS["en"]).get(key, key)

    def on_plugin_load(self):
        # Инициализация пункта меню при загрузке
        self.update_menu()

    def update_menu(self):
        """Обновляет пункт меню в три-дот меню чата."""
        self.remove_menu_item("imitator_menu_action")
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                text=self._get_str("MENU_ITEM"),
                on_click=self.show_action_menu,
                icon="msg_edit",
                item_id="imitator_menu_action"
            )
        )

    def _on_lang_change(self, new_idx: int):
        """Вызывается при смене языка пользователем."""
        self.set_setting("lang_idx", int(new_idx))
        self.update_menu()

    def create_settings(self) -> List[Any]:
        # Генерация экрана настроек
        return [
            Header(text=self._get_str("SETTINGS_TITLE")),
            Selector(
                key="lang_idx",
                text=self._get_str("LANG_LABEL"),
                items=["English", "Русский", "Français", "العربية", "עברית"],
                default=1,
                on_change=self._on_lang_change
            )
        ]

    def show_action_menu(self, context: Dict[str, Any]):
        """Отображает диалог выбора типа активности."""
        fragment = context.get("fragment") or get_last_fragment()
        activity = fragment.getParentActivity() if fragment else None
        dialog_id = context.get("dialog_id")

        if not activity or not dialog_id:
            return

        actions_list = self._get_str("ACTIONS")
        tl_actions = [
            TLRPC.TL_sendMessageTypingAction(),
            TLRPC.TL_sendMessageRecordAudioAction(),
            TLRPC.TL_sendMessageRecordVideoAction(),
            TLRPC.TL_sendMessageUploadPhotoAction(),
            TLRPC.TL_sendMessageUploadVideoAction(),
            TLRPC.TL_sendMessageGamePlayAction(),
            TLRPC.TL_sendMessageChooseContactAction(),
            TLRPC.TL_sendMessageGeoLocationAction(),
            TLRPC.TL_sendMessageUploadDocumentAction()
        ]

        # Подготовка списка элементов диалога
        menu_items = []
        for i in range(len(actions_list)):
            menu_items.append((actions_list[i], tl_actions[i]))
        
        menu_items.append((self._get_str("RANDOM"), "RANDOM"))
        menu_items.append((self._get_str("STOP_ALL"), "STOP"))

        def on_action_chosen(bld, index):
            bld.dismiss()
            if index < 0 or index >= len(menu_items): return
            
            label, action_obj = menu_items[index]
            
            if action_obj == "STOP":
                self.stop_activity(dialog_id)
                return
            
            # После выбора действия открываем меню выбора времени
            run_on_ui_thread(lambda: self.show_duration_menu(activity, dialog_id, action_obj))

        builder = AlertDialogBuilder(activity)
        builder.set_title(self._get_str("WHAT_TO_DO"))
        builder.set_items([m[0] for m in menu_items], on_action_chosen)
        builder.show()

    def show_duration_menu(self, activity: Any, dialog_id: int, action_obj: Any):
        """Отображает диалог выбора длительности имитации."""
        durations = [
            (f"5 {self._get_str('SEC')}", 5),
            (f"10 {self._get_str('SEC')}", 10),
            (f"30 {self._get_str('SEC')}", 30),
            (f"1 {self._get_str('MINUTES')}", 60),
            (self._get_str("INFINITE"), -1)
        ]

        def on_time_chosen(bld, index):
            bld.dismiss()
            if index < 0 or index >= len(durations): return
            _, seconds = durations[index]
            self.start_activity_loop(dialog_id, action_obj, seconds)

        builder = AlertDialogBuilder(activity)
        builder.set_title(self._get_str("FOR_HOW_LONG"))
        builder.set_items([d[0] for d in durations], on_time_chosen)
        builder.show()

    def start_activity_loop(self, dialog_id: int, action_obj: Any, seconds: int):
        """Запускает фоновый поток для отправки пакетов активности."""
        self.stop_activity(dialog_id)

        stop_event = threading.Event()
        with self._lock:
            self._active_loops[dialog_id] = stop_event

        # Пул действий для режима случайной активности
        random_pool = [
            TLRPC.TL_sendMessageTypingAction(),
            TLRPC.TL_sendMessageRecordAudioAction(),
            TLRPC.TL_sendMessageRecordVideoAction(),
            TLRPC.TL_sendMessageUploadPhotoAction(),
            TLRPC.TL_sendMessageUploadVideoAction(),
            TLRPC.TL_sendMessageGamePlayAction()
        ]

        def loop_runner():
            start_time = time.time()
            current_action = action_obj
            last_action_change = 0
            
            while not stop_event.is_set():
                # Логика смены действия для режима RANDOM
                if action_obj == "RANDOM":
                    if time.time() - last_action_change > random.randint(5, 10):
                        current_action = random.choice(random_pool)
                        last_action_change = time.time()
                
                self._send_raw_request(dialog_id, current_action)
                
                # Проверка лимита времени
                if seconds != -1 and time.time() - start_time >= seconds:
                    break
                
                # Короткие интервалы сна для быстрой реакции на STOP
                for _ in range(40):
                    if stop_event.is_set():
                        # Отправляем пакет отмены при ручной остановке
                        self._send_raw_request(dialog_id, TLRPC.TL_sendMessageCancelAction())
                        return
                    time.sleep(0.1)
            
            # Завершение по времени или выходу из цикла
            self._send_raw_request(dialog_id, TLRPC.TL_sendMessageCancelAction())
            with self._lock:
                if self._active_loops.get(dialog_id) == stop_event:
                    self._active_loops.pop(dialog_id, None)
            
            # Уведомление об успешном завершении
            if not stop_event.is_set():
                 run_on_ui_thread(lambda: BulletinHelper.show_info(self._get_str("FINISHED")))

        threading.Thread(target=loop_runner, daemon=True).start()
        run_on_ui_thread(lambda: BulletinHelper.show_success(self._get_str("STARTED")))

    def stop_activity(self, dialog_id: int):
        """Останавливает имитацию в конкретном чате."""
        with self._lock:
            stop_event = self._active_loops.pop(dialog_id, None)
            if stop_event:
                stop_event.set()
                self._send_raw_request(dialog_id, TLRPC.TL_sendMessageCancelAction())
                run_on_ui_thread(lambda: BulletinHelper.show_info(self._get_str("STOPPED")))

    def _send_raw_request(self, dialog_id: int, action: Any):
        """Формирует и отправляет сетевой запрос к API Telegram."""
        try:
            peer = get_messages_controller().getInputPeer(dialog_id)
            if not peer: return
            req = TLRPC.TL_messages_setTyping()
            req.peer = peer
            req.action = action
            send_request(req, None)
        except Exception as e:
            log(f"Activity Error: {e}")

    def on_plugin_unload(self):
        # Останавливаем все активные потоки при выключении плагина
        with self._lock:
            for dialog_id in list(self._active_loops.keys()):
                stop_event = self._active_loops.pop(dialog_id, None)
                if stop_event:
                    stop_event.set()