__name__ = "Activity Control"
__description__ = "Имитирует активность с выбором времени, случайным режимом и поддержкой нескольких языков. | Imitates activity with time selection, random mode, and multi-language support."
__author__ = "@Skorvash"
__version__ = "1.5.2"
__min_version__ = "11.12.0"

