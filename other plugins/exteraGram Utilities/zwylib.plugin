class SingletonMeta(type):
    _instances = {}

    def __call__(cls, *args, **kwargs):
        if cls not in cls._instances:
            instance = super().__call__(*args, **kwargs)
            cls._instances[cls] = instance
        return cls._instances[cls]


class Callback1(dynamic_proxy(Utilities.Callback)):
    def __init__(self, fn: Callable[[Any], None]):
        super().__init__()
        self._fn = fn

    def run(self, arg):
        try:
            self._fn(arg)
        except Exception:
            _logger.error("Error in Callback1.", exc_info=True)


class CacheFile:
    def __init__(self, filename: str, read_on_init=True, compress=False):
        self.filename = filename
        self.path = os.path.join(_CACHE_DIRECTORY, filename)
        self._content = b""
        self.compress = compress
        self.logger = build_log(f"{__id__}.cache")

        os.makedirs(_CACHE_DIRECTORY, exist_ok=True)

        if read_on_init:
            self.read()

    def read(self):
        if not os.path.exists(self.path):
            self.logger.error(f"File '{self.path}' does not exist.")
            return

        try:
            with open(self.path, "rb") as file:
                file_content = file.read()

            if not file_content:
                return

            is_zlib = (
                len(file_content) >= 2 and
                (file_content[0] & 0x0F) == 8 and
                (file_content[0] * 256 + file_content[1]) % 31 == 0
            )

            if is_zlib:
                try:
                    file_content = zlib.decompress(file_content)
                except zlib.error:
                    self.logger.error(f"Header matched in '{self.path}' but decompress failed:", exc_info=True)

            self._content = file_content
        except Exception:
            self.logger.error(f"Failed to load data from '{self.path}':", exc_info=True)

    def write(self):
        data = self._content if self._content is not None else b""
        if self.compress and data:
            data = zlib.compress(data, level=6)

        try:
            with open(self.path, "wb") as file:
                file.write(data)
        except PermissionError:
            self.logger.error(f"Have no permissions to edit '{self.path}':", exc_info=True)

    def wipe(self):
        self._content = b""
        self.write()

    def delete(self):
        if not os.path.exists(self.path):
            self.logger.error(f"File '{self.path}' does not exist.")
            return

        try:
            os.remove(self.path)
        except Exception:
            self.logger.error(f"Failed to delete '{self.path}':", exc_info=True)

    @property
    def content(self) -> bytes:
        return self._content

    @content.setter
    def content(self, value: bytes):
        self._content = value


class JsonCacheFile(CacheFile):
    def __init__(self, filename: str, default: Any, read_on_init=True, compress=False):
        self._default = default  # Храним оригинал для копирования
        self.json_content = self._get_copy_of_default()
        super().__init__(filename, read_on_init, compress)

    def _get_copy_of_default(self) -> Any:
        return copy.deepcopy(self._default)

    def read(self):
        super().read()

        if not self._content:
            self.json_content = self._get_copy_of_default()
            return

        try:
            self.json_content = json.loads(self._content.decode("utf-8", errors="replace"))
        except (UnicodeDecodeError, json.JSONDecodeError):
            self.logger.error(f"Failed to load JSON from '{self.path}':", exc_info=True)
            self.json_content = self._get_copy_of_default()

    def write(self):
        self._content = json.dumps(self.json_content, ensure_ascii=False).encode("utf-8", errors="replace")
        super().write()

    def wipe(self):
        self.json_content = self._get_copy_of_default()
        self.write()

    @property
    def content(self) -> Any:
        return self.json_content

    @content.setter
    def content(self, value: Any):
        self.json_content = value


@dataclass
class _UpdaterTask:
    plugin_id: str
    channel_id: int
    message_id: int


class _AutoUpdater:
    def __init__(self):
        self.tasks: List[_UpdaterTask] = []
        self.force_check_event = asyncio.Event()
        self.stop_event = asyncio.Event()
        self._current_task: Optional[Future[None]] = None

    def run(self):
        def _run_internal():
            self._current_task = async_manager.run_task(self._loop())

        if self._current_task and not self._current_task.done():
            _au_logger.debug("AutoUpdater task already started.")
            return

        # wait until the client finished loading
        run_on_queue(_run_internal, delay=2000)
        _au_logger.debug("Planned AutoUpdater run in 2 seconds.")

    # noinspection PyTypeChecker
    def stop(self):
        async_manager.loop.call_soon_threadsafe(self.stop_event.set)
        async_manager.loop.call_soon_threadsafe(self.force_check_event.set)  # awake coro immediately

    async def _loop(self):
        _au_logger.debug("AutoUpdater loop started.")

        while not self.stop_event.is_set():
            try:
                await self.check_for_updates()

                try:
                    await asyncio.wait_for(
                        self.force_check_event.wait(),
                        timeout=S.autoupdate_timeout.safe_get(int)
                    )
                    _au_logger.debug("Forced update check...")
                except asyncio.TimeoutError:
                    pass
                finally:
                    self.force_check_event.clear()

            except Exception:
                _au_logger.error("Exception in async cycle:", exc_info=True)
                await asyncio.sleep(30)

    async def check_for_updates(self):
        for task in list(self.tasks):
            plugin_id = task.plugin_id

            if PluginUtils.get_plugin(plugin_id) is None:
                _au_logger.debug(f"Plugin '{plugin_id}' was not found. Task was removed.")
                self.remove_task(task)
                continue

            if not PluginUtils.is_plugin_loaded_or_loading(plugin_id):
                _au_logger.debug(f"Plugin '{plugin_id}' is disabled. Task was skipped.")
                continue

            if not autoupdate_config.is_autoupdate_on(plugin_id):
                _au_logger.debug(f"Autoupdates disabled for plugin '{plugin_id}'. Task was skipped.")
                continue

            _au_logger.debug(f"Executing for task '{plugin_id}' ({task}).")

            try:
                response = await Requests.get_message(-task.channel_id, task.message_id)
                messages = arraylist_to_list(response.messages)
                if not messages:
                    _au_logger.warning(f"Message {task.message_id} not found in '{task.channel_id}'.")
                    continue

                message = messages[0]
                msg_obj = MessageObject(UserConfig.selectedAccount, message, False, False)
            except Exception:
                _au_logger.error("An error occurred:", exc_info=True)
                continue

            _au_logger.debug("Checking if the file is a plugin...")
            await ensure_media_downloaded(msg_obj)

            if not PluginsController.isPlugin(msg_obj):
                _au_logger.debug(f"The document attached to task '{plugin_id}' message is not plugin. Task was skipped.")
                continue

            if not S.disable_ts_check.get() and message.edit_date == autoupdate_config.get_last_updated(plugin_id):
                _au_logger.debug(f"Attachment for task '{plugin_id}' has not been updated. Task was skipped.")
                continue

            _au_logger.debug("File verified. Installing plugin...")

            autoupdate_config.set_last_updated(plugin_id, message.edit_date)
            await PluginUtils.async_download_and_install_plugin(msg_obj, plugin_id, skip_media_download=True)

    def add_task(self, task: _UpdaterTask):
        if task in self.tasks:
            _au_logger.warning(f"Task {task.plugin_id} is already present.")
            return
        self.tasks.append(task)
        _au_logger.debug(f"Added task '{task.plugin_id}'.")

    def remove_task(self, task: _UpdaterTask):
        if task not in self.tasks:
            _au_logger.warning(f"Task '{task.plugin_id}' is not present.")
            return
        self.tasks.remove(task)
        _au_logger.debug(f"Removed task '{task.plugin_id}'")

    def remove_task_by_id(self, plugin_id: str):
        filtered_tasks = list(filter(lambda task: task.plugin_id != plugin_id, self.tasks))
        if len(filtered_tasks) < len(self.tasks):
            self.tasks = filtered_tasks
            _au_logger.debug(f"Removed task '{plugin_id}'.")
        else:
            _au_logger.warning(f"Task '{plugin_id}' is not present.")

    # noinspection PyTypeChecker
    def force_update_check(self):
        async_manager.loop.call_soon_threadsafe(self.force_check_event.set)
        _au_logger.debug("force_update_check")


@overload
def add_autoupdater_task(channel_id: int, message_id: int):
    ...


@overload
def add_autoupdater_task(plugin_id: str, channel_id: int, message_id: int):
    ...


def add_autoupdater_task(plugin_id: Union[str, int], channel_id: int, message_id: Optional[int] = None):
    if isinstance(plugin_id, int):  # using (channel_id: int, message_id: int) args signature
        channel_id, message_id = plugin_id, channel_id
        plugin_id = _get_plugin_id_from_stack()

    task = _UpdaterTask(plugin_id, channel_id, message_id)

    if not PluginUtils.is_plugin_loaded_or_loading(plugin_id) and plugin_id != __id__:
        _logger.warning(f"Auto update task of '{plugin_id}' wasn't registered: plugin is missing or it's off.")
        return

    if _autoupdater is None:
        _companion.module.autoupdates_tasks.append(task)
        _logger.debug(f"Saved AutoUpdater task '{plugin_id}' to cache.")
        return

    _autoupdater.add_task(task)
    _logger.debug(f"Added '{plugin_id}' AutoUpdater task.")


def remove_autoupdater_task(plugin_id: Optional[str] = None):
    if plugin_id is None:
        plugin_id = _get_plugin_id_from_stack()

    if _autoupdater is None:
        _companion.module.autoupdates_tasks = list(
            filter(lambda task: task.plugin_id != plugin_id, _companion.module.autoupdates_tasks)
        )
        _logger.debug(f"Removed '{plugin_id}' AutoUpdater task from cache.")
        return

    _autoupdater.remove_task_by_id(plugin_id)
    _logger.debug(f"Removed '{plugin_id}' AutoUpdater task.")


def _cache_all_autoupdater_tasks():
    _companion.module.autoupdates_tasks.clear()
    _companion.module.autoupdates_tasks = _autoupdater.tasks.copy()
    _logger.debug("All AutoUpdater tasks have been cached.")


def _load_cached_autoupdater_tasks():
    _autoupdater.tasks = _companion.module.autoupdates_tasks.copy()
    _companion.module.autoupdates_tasks.clear()
    _logger.debug("All AutoUpdater tasks have been loaded from cache.")


def _is_java_obj(obj):
    if hasattr(obj, "getClass"):
        return any(i.startswith("_chaquopy") for i in dir(obj.getClass()))
    return False


def _safe_mapper(obj: Any):
    try:
        if _is_java_obj(obj):
            return AppUtils.getGson().toJson(obj)
        return str(obj)
    except Exception:
        try:
            if _is_java_obj(obj):
                cls_name = obj.getClass().getSimpleName()
                obj_hash = hex(id(obj))[-8:]
                return f"<{cls_name}@{obj_hash}>"
            return str(obj)
        except Exception:
            return f"<UNREPRESENTABLE_{type(obj).__name__}>"


class _CustomLogger(logging.Logger):
    def _log(self, level, msg, args, exc_info=None, extra=None, stack_info=False, stacklevel=1):
        func_name = inspect.stack()[2].function
        level_name = logging.getLevelName(level)

        prefix = f"[{level_name}] [{self.name}] [{func_name}]"
        formatted_msg = f"{_safe_mapper(msg)} {' '.join(map(_safe_mapper, args))}".strip()
        final_output = f"{prefix} {formatted_msg}"

        if exc_info:
            tb = traceback.format_exc() if exc_info is True else "".join(
                traceback.format_exception(type(exc_info), exc_info, exc_info.__traceback__)
            )
            final_output += f"\n{tb.strip()}"

        _internal_log(final_output)


def build_log(plugin_name: str, level=logging.NOTSET) -> logging.Logger:
    manager = logging.Logger.manager

    if plugin_name in manager.loggerDict:
        old_logger = manager.loggerDict[plugin_name]
        if hasattr(old_logger, "handlers"):
            old_logger.handlers.clear()
        del manager.loggerDict[plugin_name]

    new_logger = logging.getLogger(plugin_name)

    if level != logging.NOTSET:
        new_logger.setLevel(level)

    if not isinstance(new_logger, _CustomLogger):
        new_logger.__class__ = _CustomLogger

    return new_logger


class _InnerBulletinHelper(_BulletinHelper):
    def __init__(self, prefix: Optional[str] = None):
        self.prefix = "" if not prefix or not prefix.strip() else f"{prefix}:"

    def _get_prefixed_text(self, text: str) -> str:
        return f"{self.prefix} {text}" if self.prefix else text

    def show_info(self, message: str, fragment: Optional[Any] = None):
        _BulletinHelper.show_info(self._get_prefixed_text(message), fragment)

    def show_error(self, message: str, fragment: Optional[Any] = None):
        _BulletinHelper.show_simple(self._get_prefixed_text(message), R.raw.error, fragment)

    def show_success(self, message: str, fragment: Optional[Any] = None):
        _BulletinHelper.show_success(self._get_prefixed_text(message), fragment)

    def show_with_copy(self, message: str, text_to_copy: str, icon_res_id: int):
        _BulletinHelper.show_with_button(
            self._get_prefixed_text(message),
            icon_res_id,
            L.copy_button,
            on_click=lambda: copy_to_clipboard(text_to_copy),
        )

    def show_info_with_copy(self, message: str, copy_text: str):
        self.show_with_copy(message, str(copy_text), R.raw.info)

    def show_error_with_copy(self, message: str, copy_text: str):
        self.show_with_copy(message, str(copy_text), R.raw.error)

    def show_success_with_copy(self, message: str, copy_text: str):
        self.show_with_copy(message, str(copy_text), R.raw.contact_check)

    def show_with_post_redirect(self, message: str, button_text: str, peer_id: int, message_id: int, topic_id=0, peer_username: Optional[str] = None, icon_res_id: int=0):
        def open_post():
            async_manager.run_task(safe_open_message(
                peer_id,
                message_id,
                topic_id,
                peer_username
            ))

        _BulletinHelper.show_with_button(
            self._get_prefixed_text(message),
            icon_res_id,
            button_text,
            on_click=lambda: open_post(),
        )

    def show_info_with_post_redirect(self, message: str, button_text: str, peer_id: int, message_id: int, topic_id=0, peer_username: Optional[str] = None):
        self.show_with_post_redirect(message, button_text, peer_id, message_id, topic_id, peer_username, R.raw.info)

    def show_error_with_post_redirect(self, message: str, button_text: str, peer_id: int, message_id: int, topic_id=0, peer_username: Optional[str] = None):
        self.show_with_post_redirect(message, button_text, peer_id, message_id, topic_id, peer_username, R.raw.error)

    def show_success_with_post_redirect(self, message: str, button_text: str, peer_id: int, message_id: int, topic_id=0, peer_username: Optional[str] = None):
        self.show_with_post_redirect(message, button_text, peer_id, message_id, topic_id, peer_username, R.raw.contact_check)


def build_bulletin_helper(prefix: Optional[str] = None) -> "_InnerBulletinHelper":
    return _InnerBulletinHelper(prefix)


class _SmartString(str):
    def __call__(self, **kwargs):
        try:
            return self.format(**kwargs)
        except KeyError:
            return self


class _Locales:
    def __init__(self, locales: Dict[str, Dict[str, str]]):
        for language_code, locales_dict in locales.items():
            setattr(self, language_code, locales_dict)

        if "en" in locales:
            self.default = locales["en"]
        elif locales:
            self.default = locales[next(iter(locales))]
        else:
            self.default = {}

    def __getattr__(self, key: str) -> Union[str, Callable]:
        return self.get(key)

    @staticmethod
    def _get_plural_form(number: int, forms: list, lang: str) -> str:
        number = abs(number)
        f_len = len(forms)

        if lang in ("ru", "uk") and f_len >= 3:
            if number % 10 == 1 and number % 100 != 11: return forms[0]
            if 2 <= number % 10 <= 4 and (number % 100 < 10 or number % 100 >= 20): return forms[1]
            return forms[2]

        # fallback
        if f_len == 0: return ""
        if f_len == 1: return forms[0]
        return forms[0] if number == 1 else forms[1]

    def _get_from_default(self, key: str) -> str:
        return self.default.get(key, key)

    def get(self, key: str, dictionary: Optional[Dict[str, str]] = None) -> Union[str, _SmartString]:
        if dictionary is None:
            lang = locales_controller.get_current_locale()
            dictionary = self.__dict__.get(lang, self.default)

        if not isinstance(dictionary, dict):
            dictionary = self.default

        val = dictionary.get(key)
        if val is None:
            val = self._get_from_default(key)

        if isinstance(val, str) and "{" in val and "}" in val:
            return _SmartString(val)
        return val

    def plural(self, key: str, number: int) -> str:
        lang = locales_controller.get_current_locale()
        dictionary = self.__dict__.get(lang, self.default)

        if not isinstance(dictionary, dict):
            dictionary = self.default

        forms = dictionary.get(key, self._get_from_default(key))
        if not isinstance(forms, list):
            return str(forms)
        return self._get_plural_form(number, forms, lang)


class _LocalesController:
    def __init__(self):
        self._locale: Optional[str] = None
        self.subs: Dict[str, Callable[[], None]] = {}

    def refresh_locale(self):
        self._locale = LocaleController.getInstance().getCurrentLocaleInfo().pluralLangCode
        for sub in self.subs.values():
            try:
                sub()
            except Exception:
                _logger.error("An error occurred:", exc_info=True)

    def subscribe_to_refresh(self, sub: Callable[[], None]):
        plugin_id = _get_plugin_id_from_stack() or __id__
        self.subs[plugin_id] = sub
        _logger.debug(f"'{plugin_id}' was subscribed to locale refresh.")

    def unsubscribe_from_refresh(self, plugin_id: Optional[str] = None):
        plugin_id = plugin_id or _get_plugin_id_from_stack() or __id__
        self.subs.pop(plugin_id, None)

    def get_current_locale(self) -> str:
        if not self._locale:
            self.refresh_locale()
        return self._locale

    @staticmethod
    def generate_locale_class(dictionaries: Dict[str, Dict[str, str]]) -> _Locales:
        return _Locales(dictionaries)


