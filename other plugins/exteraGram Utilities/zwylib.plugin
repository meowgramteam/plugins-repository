_au_logger = build_log(f"{__id__}.autoupdater")
_req_logger = build_log(f"{__id__}.requests")
_async_logger = build_log(f"{__id__}.async")
_stats_logger = build_log(f"{__id__}.stats")

_bulletin = build_bulletin_helper()
_unhook: Optional[Callable]
_hook: Optional[Callable]
_loaded_or_loading_plugins: Set[str] = {__id__}

_AU_CHANNEL_USERNAME = "zwyPlugins"
_AU_CHANNEL_ID = 2521243181
_AU_MSG_ID = 48

MK_STATS_API_URL = "https://mkstats.mk69.su/api"
MK_STATS_PING_INTERVAL = 1500
MK_STATS_POW_SOLVE_SECONDS = 6

_CELL_CACHE: Dict[str, "Custom"] = {}

DEFAULT_COMMAND_PREFIX = "."
_ALLOWED_ARG_TYPES_SIGNATURE = Union[str, int, float, bool, None, Any]
_ALLOWED_ARG_TYPES = (str, int, float, bool, Any)
_ALLOWED_ORIGIN = (Union, Optional)
_stub_command_signature = inspect.signature(_InternalCmdUtils.stub_command_callback)
_stub_command_args = [_ArgSpec.from_parameter(param) for param in _stub_command_signature.parameters.values()]

_plugins_dir = file_utils.get_plugins_dir()
