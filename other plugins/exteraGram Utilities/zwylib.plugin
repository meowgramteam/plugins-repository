def is_zwylib_version_sufficient(plugin_name: str, version: str, notify=True) -> bool:
    is_sufficient = Version(__version__) >= Version(version)
    if notify and not is_sufficient:
        _bulletin.show_error_with_post_redirect(
            L.not_sufficient_zwylib_ver(plugin_name=plugin_name, version=version, cur_ver=__version__),
            L.update_bulletin_button,
            _AU_CHANNEL_ID, _AU_MSG_ID, peer_username=_AU_CHANNEL_USERNAME
        )
    return is_sufficient


class CannotCastError(Exception):
    pass


class WrongArgumentAmountError(Exception):
    pass


class MissingRequiredArguments(Exception):
    pass


class InvalidTypeError(Exception):
    pass


@dataclass
class _CommandTestUnit:
    input: str
    arg_specs: Tuple[inspect.Parameter, ...]
    expected_args: Optional[Tuple[Any, ...]]
    should_succeed: bool
    description: str
    expected_exception: Optional[Type[Exception]] = None


@dataclass
class _ArgSpec:
    name: str
    annotation: Any
    kind: inspect._ParameterKind
    default: Any = inspect.Parameter.empty
    is_optional: bool = False

    @classmethod
    def from_parameter(cls, param: inspect.Parameter) -> "_ArgSpec":
        annotation = param.annotation if param.annotation != inspect.Parameter.empty else Any
        is_optional = get_origin(annotation) in (Union, Optional) and type(None) in get_args(annotation)
        return cls(
            name=param.name,
            annotation=annotation,
            kind=param.kind,
            default=param.default,
            is_optional=is_optional
        )


@dataclass
class _Command:
    func: Callable
    name: str
    aliases: List[str] = field(default_factory=list)
    args: List[_ArgSpec] = field(default_factory=list)
    subcommands: Dict[str, "_Command"] = field(default_factory=dict)
    error_handler: Optional[Callable] = None

    def stub_subcommand(self, name: str):
        sub_cmd = _InternalCmdUtils.create_stub_command(name=name)
        _InternalCmdUtils.register_command(
            target=self.subcommands,
            command=sub_cmd,
            plugin_id=self.name,
            is_subcommand=True
        )
        return sub_cmd

    def subcommand(self, name: str, aliases: List[str] = None):
        def decorator(func: Callable[[], None]):
            sub_cmd = _InternalCmdUtils.create_command(func=func, name=name)
            if aliases:
                sub_cmd.aliases = aliases
            _InternalCmdUtils.register_command(
                target=self.subcommands,
                command=sub_cmd,
                plugin_id=self.name,
                is_subcommand=True
            )
            return sub_cmd
        return decorator

    def register_error_handler(self, func: Callable[[Any, int, Exception], Optional[HookResult]]):
        _cmd_logger.info(f"Registering error handler for {self.name} command...")
        signature = inspect.signature(func)
        if len(signature.parameters) != 3:
            raise MissingRequiredArguments("Error handler must have only 'param', 'account' and 'exception' arguments.")
        self.error_handler = func
        return func

    def __repr__(self):
        return f"{self.__class__.__name__}(name={self.name}, subs={list(self.subcommands.values())})"


class _InternalCmdUtils:
    @staticmethod
    def register_command(target: Dict[str, "_Command"], command: "_Command", plugin_id: str, is_subcommand=False):
        log_prefix = f"Command {command.name}:" if is_subcommand else f"Dispatcher {plugin_id}:"
        cmd_type = "Subcommand" if is_subcommand else "Command"
        pending_commands = _companion.module.pending_commands
        all_names = [command.name] + command.aliases

        for n in all_names:
            if not n:
                _cmd_logger.error(f"{log_prefix} {cmd_type} name/alias cannot be empty.")
                return
            if " " in n:
                _cmd_logger.error(f"{log_prefix} {cmd_type} name/alias ({n}) cannot contain spaces")
                return

        if command_manager.temporal and not is_subcommand:
            _cmd_logger.debug(f"{log_prefix} {cmd_type} manager is not initialized, saving command to pending list.")
            if plugin_id not in pending_commands:
                pending_commands[plugin_id] = []

            existing_names = []
            for cmd in pending_commands[plugin_id]:
                existing_names.extend([cmd.name] + cmd.aliases)

            for n in all_names:
                if n in existing_names:
                    _cmd_logger.error(f"{log_prefix} {cmd_type} name/alias '{n}' is already in pending list.")
                    return

            pending_commands[plugin_id].append(command)
            return

        for n in all_names:
            if n in target:
                _cmd_logger.error(f"{log_prefix} {cmd_type} name/alias '{n}' is already registered.")
                return

        for n in all_names:
            target[n] = command
            _cmd_logger.debug(f"{log_prefix} Registered {cmd_type.lower()} key: {n}.")

    @staticmethod
    def _is_allowed_type(arg_type):
        """
        Check if the argument type is supported, including Optional and Union types with NoneType.

        :param arg_type: The type to check.
        :returns: True if the type is supported, False otherwise.
        """
        if arg_type in _ALLOWED_ARG_TYPES:
            return True

        if arg_type is type(None):
            return True

        origin = get_origin(arg_type)
        if origin in _ALLOWED_ORIGIN:
            return all(_InternalCmdUtils._is_allowed_type(t) for t in get_args(arg_type))
        return False

    @staticmethod
    def _cast_arg(arg: str, target_type: type):
        """
        Just casts a string to the target type.
        :raises CannotCastError: If the string cannot be cast to the target type.
        """

        if target_type == str or target_type == Any:
            return arg
        elif target_type == int:
            return int(arg)
        elif target_type == float:
            return float(arg)
        elif target_type == bool:
            if arg.lower() in ("true", "1", "yes", "on"):
                return True
            elif arg.lower() in ("false", "0", "no", "off"):
                return False
            else:
                raise CannotCastError(f"Cannot cast '{arg}' to bool")
        else:
            raise CannotCastError(f"Unsupported target type: {target_type}")

    @staticmethod
    def _smart_cast(arg: str, annotation):
        """
        Casts the string to the type specified in the annotation, including Optional and Union.
        :raises CannotCastError: If the string cannot be cast to any of the types in Union or the annotation is not supported.
        """

        origin = get_origin(annotation)
        args = get_args(annotation)

        if annotation in _ALLOWED_ARG_TYPES:
            try:
                return _InternalCmdUtils._cast_arg(arg, annotation)
            except Exception:
                raise CannotCastError(f"Could not cast '{arg}' to {annotation}")
        elif origin is Union:
            for possible_type in args:
                if possible_type == type(None):
                    continue
                try:
                    return _InternalCmdUtils._cast_arg(arg, possible_type)
                except Exception:
                    continue
            raise CannotCastError(f"Could not cast '{arg}' to any of: {args}")
        raise CannotCastError(f"Unsupported annotation: {annotation}")

    @staticmethod
    def parse_args(raw_args: List[str], command_args: List[_ArgSpec]) -> Tuple[Any, ...]:
        """
        Parses a list of raw argument strings into typed arguments based on the command's argument specifications.

        :param raw_args: List of raw argument strings.
        :param command_args: List of ArgSpec describing the expected arguments.
        :returns: Tuple of parsed arguments.
        :raises WrongArgumentAmountError: If the number of provided arguments is incorrect.
        :raises CannotCastError: If an argument cannot be cast to the expected type.
        """

        out: List[Any] = []
        required_arg_count = sum(
            1 for arg in command_args
            if not arg.is_optional and arg.default == inspect.Parameter.empty and arg.kind != inspect.Parameter.VAR_POSITIONAL
        )
        is_variadic = any(arg.kind == inspect.Parameter.VAR_POSITIONAL for arg in command_args)

        if not is_variadic and len(raw_args) > len(command_args):
            raise WrongArgumentAmountError(f"Expected at most {len(command_args)} arguments, got {len(raw_args)}.")
        if len(raw_args) < required_arg_count:
            raise WrongArgumentAmountError(f"Expected at least {required_arg_count} arguments, got {len(raw_args)}.")

        for i, cmd_arg in enumerate(command_args):
            if cmd_arg.kind == inspect.Parameter.VAR_POSITIONAL:
                variadic_args = raw_args[i:] if i < len(raw_args) else []
                if not variadic_args:
                    _cmd_logger.error(f"No variadic arguments provided for {cmd_arg.name}, returning empty tuple.")
                    break

                for arg in variadic_args:
                    _cmd_logger.debug(f"Processing variadic argument: {arg}, expected type: {cmd_arg.annotation}.")
                    parsed_arg = _InternalCmdUtils._smart_cast(arg, cmd_arg.annotation)
                    _cmd_logger.debug(f"Variadic argument parsed successfully: {parsed_arg}.")
                    out.append(parsed_arg)
                break
            elif i < len(raw_args):
                _cmd_logger.debug(f"Processing argument {i}: {raw_args[i]}, expected type: {cmd_arg.annotation}.")
                parsed_arg = _InternalCmdUtils._smart_cast(raw_args[i], cmd_arg.annotation)
                _cmd_logger.debug(f"Argument {i} parsed successfully: {parsed_arg}.")
                out.append(parsed_arg)
            elif cmd_arg.default != inspect.Parameter.empty:
                _cmd_logger.debug(f"Argument {i} missing, using default value: {cmd_arg.default}.")
                out.append(cmd_arg.default)
            elif cmd_arg.is_optional:
                _cmd_logger.debug(f"Argument {i} missing, using None for Optional type: {cmd_arg.annotation}.")
                out.append(None)
            else:
                _cmd_logger.debug(f"Argument {i} missing for non-Optional, non-default type: {cmd_arg.annotation}.")
                raise WrongArgumentAmountError(f"Expected argument {i} of type {cmd_arg.annotation}, but none provided.")
        return tuple(out)

    @staticmethod
    def create_command(func: Callable, name: str) -> _Command:
        signature = inspect.signature(func)
        parameters = list(signature.parameters.values())
        return_type = signature.return_annotation

        if len(parameters) < 2:
            raise MissingRequiredArguments(
                "Command must have 'param' variable as first argument and 'account' variable as second argument"
            )

        args = [_ArgSpec.from_parameter(param) for param in parameters]

        for index, arg in enumerate(args):
            if arg.kind == inspect.Parameter.VAR_POSITIONAL:
                origin_type = get_origin(arg.annotation) or arg.annotation
                if not _InternalCmdUtils._is_allowed_type(origin_type):
                    raise InvalidTypeError(
                        f"Variadic argument (index: {index}) type must be one of "
                        f"{*_ALLOWED_ARG_TYPES, *_ALLOWED_ORIGIN}, got {arg.annotation}"
                    )
            elif not _InternalCmdUtils._is_allowed_type(arg.annotation):
                raise InvalidTypeError(
                    f"Command argument (index: {index}) signature must be one of "
                    f"{*_ALLOWED_ARG_TYPES, *_ALLOWED_ORIGIN}, got {arg.annotation}"
                )

        is_async = inspect.iscoroutinefunction(func)
        if is_async:
            if return_type not in [inspect.Parameter.empty, None]:
                raise InvalidTypeError(f"Async command function must return NoneType, got {return_type}")
        elif return_type != HookResult:
            return_type_name = "NoneType" if return_type == inspect.Parameter.empty else return_type
            raise InvalidTypeError(f"Command function must return {HookResult} object, got {return_type_name}")

        return _Command(func=func, name=name, args=args)

    @staticmethod
    def create_stub_command(name: str) -> _Command:
        return _Command(func=_InternalCmdUtils.stub_command_callback, name=name, args=_stub_command_args)

    @staticmethod
    def stub_command_callback(_, __, *args) -> HookResult:
        text = L.likely_cmd_name_misspelling if args else L.stub_command_message
        _bulletin.show_info(text)
        return HookResult(strategy=HookStrategy.CANCEL)

    @staticmethod
    def show_command_exception(cmd: _Command, exc: Exception, from_err_handler=False):
        message = f"Uncaught exception occurred while the execution of '{cmd.name}' command"
        if from_err_handler:
            message += "'s ERROR HANDLER"
        message += ":\n" + format_exc_from(exc)

        _cmd_logger.error(message)
        _bulletin.show_error_with_copy(
            L.command_execution_error(cmd_name=cmd.name),
            message
        )


class Dispatcher:
    def __init__(self, plugin_id: str, prefix: str, commands_priority: int):
        self.plugin_id = plugin_id
        self.prefix = prefix
        self.commands_priority = commands_priority
        self.listeners: Dict[str, _Command] = {}  # command_name -> Command

    @staticmethod
    def validate_prefix(prefix: str) -> bool:
        return prefix and " " not in prefix

    def set_prefix(self, prefix: str):
        if not self.validate_prefix(prefix):
            _cmd_logger.error(f"{self.plugin_id} dp: Prefix validation failed (got '{prefix}').")
            return

        _cmd_logger.info(f"{self.plugin_id} dp: Set '{prefix}' prefix.")
        self.prefix = prefix
        command_manager.update_dispatcher_prefix_cache(self.plugin_id)

    def register_command(self, name: str, aliases: List[str] = None):
        def decorator(func: Callable[[], None]):
            command = _InternalCmdUtils.create_command(func=func, name=name)
            if aliases:
                command.aliases = aliases
            _InternalCmdUtils.register_command(
                target=self.listeners,
                command=command,
                plugin_id=self.plugin_id,
            )
            return command
        return decorator

    def register_stub_command(self, name: str):
        command = _InternalCmdUtils.create_stub_command(name=name)
        _InternalCmdUtils.register_command(
            target=self.listeners,
            command=command,
            plugin_id=self.plugin_id,
        )
        return command

    def unregister_command(self, name: str):
        _cmd_logger.info(f"{self.plugin_id} dp: Unregistered command '{name}'.")
        self.listeners.pop(name, None)


class _CommandManager:
    def __init__(self):
        self._dispatchers: Dict[str, Dispatcher] = {}  # plugin_id -> Dispatcher
        self._prefixes_cache = JsonCacheFile("zwylib__cmds_prefixes", {})
        self.temporal = True

    def mark_as_not_temporal(self):
        self.temporal = False

    def get_dispatcher(self, plugin_id: str | None = None, prefix: str = "default", commands_priority=-1) -> Dispatcher:
        if plugin_id is None:
            plugin_id = _get_plugin_id_from_stack()

        if not prefix or prefix == "default":
            prefix = DEFAULT_COMMAND_PREFIX

        if plugin_id in self._prefixes_cache.content:
            prefix = self._prefixes_cache.content[plugin_id]

        if plugin_id not in self._dispatchers:
            self._dispatchers[plugin_id] = Dispatcher(
                plugin_id=plugin_id,
                prefix=prefix,
                commands_priority=commands_priority,
            )
            _cmd_logger.debug(f"Dispatcher for '{plugin_id}' was created.")
            self.sort_dispatchers()

        _cmd_logger.debug(f"Got dispatcher for '{plugin_id}' with prefix '{prefix}'.")
        return self._dispatchers[plugin_id]

    def remove_dispatcher(self, plugin_id: str | None):
        if plugin_id is None:
            plugin_id = _get_plugin_id_from_stack()
        self._dispatchers.pop(plugin_id, None)
        _cmd_logger.debug(f"Removed dispatcher for '{plugin_id}'.")

    def sort_dispatchers(self):
        """Sorts dispatchers by their commands priority. Dispatchers with higher priority will be processed first."""
        self._dispatchers = dict(sorted(self._dispatchers.items(), key=lambda i: i[1].commands_priority, reverse=True))
        _cmd_logger.debug("Dispatchers sorted by priority.")

    def load_pending_commands(self):
        pending_commands: Dict[str, List[_Command]] = _companion.module.pending_commands
        _cmd_logger.debug("Loading pending commands:", pending_commands)

        for plugin_id, commands in pending_commands.items():
            if not commands:
                continue

            if not PluginUtils.is_plugin_loaded_or_loading(plugin_id):
                _cmd_logger.info(f"Pending commands of '{plugin_id}' weren't registered: plugin is missing or it's off.")
                continue

            dispatcher = self.get_dispatcher(plugin_id)
            for command in commands:
                dispatcher.listeners[command.name] = command

            _cmd_logger.info(f"Registered all pending commands for '{plugin_id}'.")
        pending_commands.clear()

    def save_commands_as_pending(self):
        _cmd_logger.info("Saving all commands to pending list...")

        pending_commands: Dict[str, List[_Command]] = _companion.module.pending_commands
        for plugin_id, dp in self._dispatchers.items():
            pending_commands[plugin_id] = list(dp.listeners.values())

    def unregister_all(self):
        _cmd_logger.info("Unregistering all dispatchers...")
        self._dispatchers.clear()

    def update_dispatcher_prefix_cache(self, plugin_id: str):
        _cmd_logger.info(f"Updating prefix cache for '{plugin_id}'...")
        dp = self.get_dispatcher(plugin_id)

        if dp.prefix == DEFAULT_COMMAND_PREFIX:
            _cmd_logger.warning(f"'{plugin_id}' prefix is the same as the default. Removing from cache.")
            self._prefixes_cache.content.pop(plugin_id, None)
            self._prefixes_cache.write()
            return

        self._prefixes_cache.content[plugin_id] = dp.prefix
        self._prefixes_cache.write()

    def handle_send_message_hook(self, params, account: int) -> HookResult:
        original_text = getattr(params, "message")
        if not original_text:
            return HookResult()

        for plugin_id, dp in self._dispatchers.items():
            _cmd_logger.debug(f"Searching for commands in {plugin_id} dispatcher...")

            if not original_text.startswith(dp.prefix):
                continue

            msg_text = original_text[len(dp.prefix):]
            msg_text = msg_text.lstrip()
            args: List[Any] = shlex.split(msg_text.strip())

            if not args:
                continue

            cmd = dp.listeners.get(args[0])
            if not cmd:
                continue

            _cmd_logger.debug(f"Found command: {cmd.name}. Looking for subcommands...")

            args = args[1:]
            while args and args[0] in cmd.subcommands:
                cmd = cmd.subcommands[args[0]]
                args = args[1:]
                _cmd_logger.debug(f"Found subcommand: {cmd.name}. Continuing to search...")

            args.insert(0, params)
            args.insert(1, account)

            try:
                _cmd_logger.debug("Preparing arguments...")
                parsed_args = _InternalCmdUtils.parse_args(args, cmd.args)

                if inspect.iscoroutinefunction(cmd.func):
                    _cmd_logger.debug(f"Executing async command with args {parsed_args}...")
                    async_manager.run_task(cmd.func(*parsed_args))
                    return HookResult(strategy=HookStrategy.CANCEL)
                else:
                    _cmd_logger.debug(f"Executing command with args {parsed_args}...")
                    return cmd.func(*parsed_args)
            except Exception as e:
                if not cmd.error_handler:
                    _InternalCmdUtils.show_command_exception(cmd, e)
                    return HookResult(strategy=HookStrategy.CANCEL)

                _cmd_logger.debug(
                    f"An exception has been caught in '{cmd.name}' command execution.\n"
                    "Running error handler..."
                )

                try:
                    if inspect.iscoroutinefunction(cmd.error_handler):
                        async_manager.run_task(cmd.error_handler(params, account, e))
                        return HookResult(strategy=HookStrategy.CANCEL)
                    else:
                        return cmd.error_handler(params, account, e)
                except Exception as e:
                    # really, bud?
                    _InternalCmdUtils.show_command_exception(cmd, e, from_err_handler=True)
                    return HookResult(strategy=HookStrategy.CANCEL)
        return HookResult()


def format_exc() -> str:
    return traceback.format_exc().strip()


def format_exc_from(e: Exception) -> str:
    exc_info = traceback.format_exception(type(e), e, e.__traceback__)
    return "".join(exc_info).strip()


def format_exc_only(e: Exception) -> str:
    exc_info = traceback.format_exception_only(type(e), e)
    return "".join(exc_info).strip()


class _Companion:
    defaults = {
        "autoupdates_tasks": [],
        "pending_commands": {},
    }

    def __init__(self):
        self.module = None

    @staticmethod
    def create():
        lines = ["# Auto-generated zwylib companion file\n"]
        for key, default in _Companion.defaults.items():
            lines.append(f"\n{key} = {repr(default)}")

        os.makedirs(os.path.dirname(_COMPANION_PATH), exist_ok=True)
        with open(_COMPANION_PATH, "w", encoding="utf-8") as f:
            f.writelines(lines)

    def import_it(self):
        import zwylib_companion
        self.module = zwylib_companion


def arraylist_to_list(j_array_list: Optional[ArrayList]) -> Optional[List]:
    return j_array_list.toArray() if j_array_list else None


def iterable_to_arraylist(iterable: Optional[Iterable[Any]], int_auto_convert=True) -> Optional[ArrayList]:
    if iterable is None:
        return None

    arraylist = ArrayList()
    for obj in list(iterable):
        if int_auto_convert and isinstance(obj, int):
            try:
                arraylist.add(jint(obj))
                continue
            except OverflowError:
                pass
        arraylist.add(obj)

    return arraylist


@deprecated("Function list_to_arraylist(list[any], bool) is deprecated. Use iterable_to_arraylist(iterable[any], bool) instead")
def list_to_arraylist(python_list: Optional[List], int_auto_convert=True):
    iterable_to_arraylist(python_list, int_auto_convert)


def process_updates(updates: TLRPC.TL_updates):
    if not isinstance(updates, TLRPC.TL_updates):
        _req_logger.debug(f"Response is not TLRPC.TL_updates ({type(updates)}).")
        return

    try:
        get_messages_controller().processUpdates(cast(TLRPC.Updates, updates), False)
    except Exception:
        _logger.error("An error occurred:", exc_info=True)


def _request_callback_factory(callback: Optional[Callable]):
    def inner_callback(response, error):
        process_updates(response)
        callback(response, error) if callback else None
    return inner_callback


class Requests:
    @staticmethod
    def send(req, callback: Optional[Callable], delay: Optional[int] = None, **kwargs):
        for k, v in kwargs.items():
            setattr(req, k, v)

        _req_logger.debug(f"Sending request {req} with {delay} delay.")
        run_on_ui_thread(
            lambda: send_request(req, _request_callback_factory(callback)),
            delay=delay or 0
        )

    @classmethod
    async def async_send(cls, req: TLObject, delay: Optional[int] = None, **kwargs) -> TLObject:
        loop = async_manager.loop
        future = loop.create_future()

        def callback(response: TLObject, error: TLRPC.TL_error):
            def bridge():
                if future.done():
                    return

                if error:
                    future.set_exception(Exception(f"Error {error.code}: {error.text}"))
                else:
                    future.set_result(response)

            # noinspection PyTypeChecker
            loop.call_soon_threadsafe(bridge)

        cls.send(req, callback, delay, **kwargs)
        return await future

    @staticmethod
    def reload_admins(chat_id: int):
        get_messages_controller().loadChannelAdmins(chat_id, False)
        _req_logger.debug(f"Reloaded admin list in '{chat_id}'.")

    @staticmethod
    def delete_messages(messages: List[int], peer_id: int, topic_id: Optional[int] = None):
        run_on_ui_thread(
            lambda: get_messages_controller().deleteMessages(
                iterable_to_arraylist(messages), None, None,
                peer_id, topic_id or 0, True, 0
            )
        )
        _req_logger.debug(f"Deleted {messages} in '{peer_id}' (thread id {topic_id or 0}).")

    @staticmethod
    async def change_slowmode(chat_id: int, seconds=0, delay=0):
         process_updates(
             await Requests.async_send(
                 TLRPC.TL_channels_toggleSlowMode(),
                 delay,
                 channel=get_messages_controller().getInputChannel(chat_id),
                 seconds=seconds
             )
         )

    @staticmethod
    async def ban(chat_id: int, peer_id: int, until_date: int | None = None, delay=0):
        banned_rights = TLRPC.TL_chatBannedRights()
        banned_rights.until_date = until_date or 0

        for attr in dir(banned_rights):
            if isinstance(getattr(banned_rights, attr), bool):
                setattr(banned_rights, attr, True)

        msg_controller = get_messages_controller()
        process_updates(
            await Requests.async_send(
                TLRPC.TL_channels_editBanned(),
                delay,
                participant=msg_controller.getInputPeer(peer_id),
                channel=msg_controller.getInputChannel(msg_controller.getChat(chat_id)),
                banned_rights=banned_rights
            )
        )

    @staticmethod
    async def unban(chat_id: int, target_peer_id: int, delay=0):
        msg_controller = get_messages_controller()
        await Requests.async_send(
            TLRPC.TL_channels_editBanned(),
            delay,
            participant=msg_controller.getInputPeer(target_peer_id),
            channel=msg_controller.getInputChannel(chat_id),
            banned_rights=TLRPC.TL_chatBannedRights()
        )

    @classmethod
    async def get_message(cls, peer_id: int, message_id: int) -> Optional[TLRPC.messages_Messages]:
        return await cls.get_messages(peer_id, [message_id])

    @staticmethod
    async def get_messages(peer_id: int, messages: List[int]) -> Optional[TLRPC.messages_Messages]:
        if ChatObject.isChannel(get_messages_controller().getChat(-peer_id)):
            req = TLRPC.TL_channels_getMessages()
            req.channel = get_messages_controller().getInputChannel(-peer_id)
        else:
            req = TLRPC.TL_messages_getMessages()
        return await Requests.async_send(req, id=iterable_to_arraylist(messages))

    @staticmethod
    async def search_messages(peer_id: int, delay=0, **kwargs) -> TLRPC.messages_Messages:
        msg_controller = get_messages_controller()

        req = TLRPC.TL_messages_search()
        req.peer = msg_controller.getInputPeer(peer_id)
        req.filter = kwargs.pop("filter", TLRPC.TL_inputMessagesFilterEmpty())
        req.q = kwargs.pop("q", "")

        from_id: Any = kwargs.pop("from_id", None)
        if from_id:
            req.from_id = msg_controller.getInputPeer(from_id)
            req.flags |= 1

        top_msg_id: Any = kwargs.pop("top_msg_id", None)
        if top_msg_id:
            req.top_msg_id = top_msg_id
            req.flags |= 2

        saved_peer_id: Any = kwargs.pop("saved_peer_id", None)
        if saved_peer_id:
            req.saved_peer_id = msg_controller.getInputPeer(saved_peer_id)
            req.flags |= 4

        saved_reaction: Any = kwargs.pop("saved_reaction", None)
        if saved_reaction:
            req.saved_reaction.add(saved_reaction.toTLReaction())
            req.flags |= 8

        response = await Requests.async_send(req, delay, **kwargs)
        return cast(TLRPC.messages_Messages, response)

    @staticmethod
    async def get_chat_participant(chat_id: int, target_peer_id: int) -> TLRPC.TL_channels_channelParticipant:
        msg_controller = get_messages_controller()
        return cast(
            TLRPC.TL_channels_channelParticipant,
            await Requests.async_send(
                TLRPC.TL_channels_getParticipant(),
                channel=msg_controller.getInputChannel(chat_id),
                participant=msg_controller.getInputPeer(target_peer_id)
            )
        )


def _register_zwylib_commands():
    _logger.debug("Registering ZwyLib commands...")
    dp = command_manager.get_dispatcher(__id__)

    zwylib = dp.register_stub_command("zwylib")

    @zwylib.subcommand("cmds")
    def zwylib_cmds(params, _) -> HookResult:
        def collect_commands(command: _Command, prefix=""):
            full_name = (prefix + " " + command.name).strip()
            names = [full_name]
            for sub in command.subcommands.values():
                names.extend(collect_commands(sub, prefix=full_name))
            return names

        lines = []
        # noinspection PyProtectedMember
        for dispatcher in command_manager._dispatchers.values():
            lines.append(f"\n- {dispatcher.plugin_id}:")
            for cmd in dispatcher.listeners.values():
                for name in collect_commands(cmd):
                    lines.append(f"\t- {name}")

        text = "\n".join(lines)
        parsed = markdown_utils.parse_markdown(text)

        params.message = parsed.text
        for ent in parsed.entities:
            params.entities.add(ent.to_tlrpc_object())

        return HookResult(strategy=HookStrategy.MODIFY_FINAL, params=params)

    @zwylib_cmds.subcommand("test")
    def test_command_system(params, _) -> HookResult:
        test_cases = [
            _CommandTestUnit(
                input="",
                arg_specs=(),
                expected_args=(),
                should_succeed=True,
                description="No arguments"
            ),
            _CommandTestUnit(
                input="hi",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=inspect.Parameter.empty),
                ),
                expected_args=("hi",),
                should_succeed=True,
                description="Single mandatory not annotated argument"
            ),
            _CommandTestUnit(
                input="hi",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=Any),
                ),
                expected_args=("hi",),
                should_succeed=True,
                description="Single mandatory Any argument"
            ),
            _CommandTestUnit(
                input="hi",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=str),
                ),
                expected_args=("hi",),
                should_succeed=True,
                description="Single mandatory str argument"
            ),
            _CommandTestUnit(
                input="42.5",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=float),
                ),
                expected_args=(42.5,),
                should_succeed=True,
                description="Float argument"
            ),
            _CommandTestUnit(
                input="true",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=bool),
                ),
                expected_args=(True,),
                should_succeed=True,
                description="Single mandatory bool argument"
            ),
            _CommandTestUnit(
                input="",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=int),
                ),
                expected_args=None,
                should_succeed=False,
                description="Missing mandatory int argument",
                expected_exception=WrongArgumentAmountError
            ),
            _CommandTestUnit(
                input="",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=str, default="default"),
                ),
                expected_args=("default",),
                should_succeed=True,
                description="Argument with default value"
            ),
            _CommandTestUnit(
                input="42 default 1",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=int),
                    inspect.Parameter(name="arg2", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=str),
                    inspect.Parameter(name="arg3", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=int),
                ),
                expected_args=(42, "default", 1),
                should_succeed=True,
                description="Multiple arguments with int and str"
            ),
            _CommandTestUnit(
                input="hi",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=Optional[str]),
                ),
                expected_args=("hi",),
                should_succeed=True,
                description="Optional str argument with valid input"
            ),
            _CommandTestUnit(
                input="",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=Optional[str]),
                ),
                expected_args=(None,),
                should_succeed=True,
                description="Optional str argument with no input"
            ),
            _CommandTestUnit(
                input="hi",
                arg_specs=(
                    inspect.Parameter(name="arg1", kind=inspect.Parameter.POSITIONAL_OR_KEYWORD, annotation=Optional[int]),
                ),
                expected_args=(None,),
                should_succeed=False,
                description="Optional int argument with invalid input",
                expected_exception=CannotCastError
            ),
            _CommandTestUnit(
                input="1 2 3",
                arg_specs=(
                    inspect.Parameter(name="args", kind=inspect.Parameter.VAR_POSITIONAL, annotation=int),
                ),
                expected_args=(1, 2, 3),
                should_succeed=True,
                description="Variadic int arguments"
            ),
            _CommandTestUnit(
                input="1 two 3",
                arg_specs=(
                    inspect.Parameter(name="args", kind=inspect.Parameter.VAR_POSITIONAL, annotation=int),
                ),
                expected_args=(None, None, None),
                should_succeed=False,
                description="Variadic int arguments with invalid input",
                expected_exception=CannotCastError
            ),
            _CommandTestUnit(
                input="",
                arg_specs=(
                    inspect.Parameter(name="args", kind=inspect.Parameter.VAR_POSITIONAL, annotation=str),
                ),
                expected_args=(),
                should_succeed=True,
                description="Variadic str arguments with no input"
            ),
            _CommandTestUnit(
                input="",
                arg_specs=(
                    inspect.Parameter(name="args", kind=inspect.Parameter.VAR_POSITIONAL, annotation=inspect.Parameter.empty),
                ),
                expected_args=(),
                should_succeed=True,
                description="Variadic Any arguments with no input"
            ),
        ]

        results = []
        for i, case in enumerate(test_cases):
            test_number = i + 1

            try:
                cmd_parameters = [_ArgSpec.from_parameter(param) for param in case.arg_specs]
                args = shlex.split(case.input) if case.input.strip() else []
                parsed_args = _InternalCmdUtils.parse_args(args, cmd_parameters)

                if case.should_succeed:
                    if parsed_args == case.expected_args:
                        results.append(f"Test {test_number} ({case.description}): Passed")
                    else:
                        results.append(f"Test {test_number} ({case.description}): Failed - Expected args {case.expected_args}, got {parsed_args}\nInput: {case.input}")
                else:
                    results.append(f"Test {test_number} ({case.description}): Failed - Expected to fail, but succeeded with args {parsed_args}\nInput: {case.input}")
            except Exception as e:
                if case.should_succeed:
                    results.append(f"Test {test_number} ({case.description}): Failed with {format_exc_only(e)}\nInput: {case.input}")
                elif case.expected_exception and isinstance(e, case.expected_exception):
                    results.append(f"Test {test_number} ({case.description}): Passed")
                else:
                    results.append(f"Test {test_number} ({case.description}): Failed with unexpected error {format_exc_only(e)}\nInput: {case.input}")

        text = "Command system tests:\n\n" + "\n\n".join(results)
        parsed = markdown_utils.parse_markdown(text)

        params.message = parsed.text
        for ent in parsed.entities:
            params.entities.add(ent.to_tlrpc_object())

        return HookResult(strategy=HookStrategy.MODIFY_FINAL, params=params)

    zwylib_au = zwylib.stub_subcommand("au")

    @zwylib_au.subcommand("list")
    def zwylib_au_list(params, _) -> HookResult:
        text = "ZwyLib autoupdater tasks:\n" + "\n".join([f"\t- [{i.plugin_id}](https://t.me/c/{i.channel_id}/{i.message_id})" for i in _autoupdater.tasks])
        new_msg = markdown_utils.parse_markdown(text)

        params.message = new_msg.text
        for i in new_msg.entities:
            params.entities.add(i.to_tlrpc_object())

        return HookResult(strategy=HookStrategy.MODIFY_FINAL, params=params)


@dataclass
class SettingEntry:
    key: str
    default: Any
    icon: Optional[str] = None

    def get(self) -> Any:
        return SettingsManager.get(self)

    def safe_get(self, factory: Callable[[Any], _T], bulletin_text: str = None, log_text: str = None) -> _T:
        try:
            return factory(self.get())
        except Exception:
            _logger.error(log_text or f"Error getting setting '{self.key}', using default instead. Trace:", exc_info=True)
            if bulletin_text:
                _bulletin.show_error(bulletin_text)
            return factory(self.default)

    def set(self, value: Any):
        SettingsManager.set(self.key, value)

    def _bind(self, component_cls, **kwargs):
        kwargs["key"] = self.key
        kwargs["default"] = self.default
        if self.icon:
            kwargs["icon"] = self.icon
        return component_cls(**kwargs)

    def as_input(self, **kwargs) -> Input:
        return self._bind(Input, **kwargs)

    def as_selector(self, **kwargs) -> Selector:
        return self._bind(Selector, **kwargs)

    def as_switch(self, **kwargs) -> Switch:
        return self._bind(Switch, **kwargs)


class S:
    autoupdate_timeout = SettingEntry("autoupdate_timeout", "600", icon="msg2_autodelete")
    enable_autoupdates = SettingEntry("enable_autoupdates", True, icon="msg_download")
    disable_ts_check = SettingEntry("disable_ts_check", False, icon="msg_recent")
    debug_mode = SettingEntry("debug_mode", False, icon="msg_log")

    # Deprecated
    disable_autoupdate = SettingEntry("disable_autoupdate", False)


class SettingsManager:
    @classmethod
    def get(cls, item: Union[str, SettingEntry], default: Optional[_T] = None) -> Optional[_T]:
        plugin_id = _get_plugin_id_from_stack() or __id__
        if isinstance(item, SettingEntry):
            return plugin_settings.get_setting(plugin_id, item.key, item.default)
        return plugin_settings.get_setting(plugin_id, item, default)

    @classmethod
    def set(cls, item: Union[str, SettingEntry], value: Any, reload_settings=True):
        plugin_id = _get_plugin_id_from_stack() or __id__
        key = item.key if isinstance(item, SettingEntry) else item

        plugin_settings.set_setting(plugin_id, key, value)
        if reload_settings:
            cls.reload()

    @classmethod
    def reload(cls, plugin_id: str = None):
        plugin_id = plugin_id or _get_plugin_id_from_stack() or __id__
        PluginsController.getInstance().loadPluginSettings(plugin_id)

    # noinspection PyProtectedMember
    @classmethod
    def remove_setting(cls, key: str, plugin_id: str = None):
        plugin_id = plugin_id or _get_plugin_id_from_stack() or __id__
        with plugin_settings._lock:
            if plugin_id in plugin_settings._settings_cache:
                plugin_settings._settings_cache[plugin_id].pop(key, None)
                plugin_settings._save_settings_to_file()


class _PrefsGenerator:
    @classmethod
    def generate_entries(cls) -> list:
        try:
            stuff = [
                cls._gen_autoupdate(),
                cls._gen_dev()
            ]
            return [item for sublist in stuff for item in sublist]
        except Exception as e:
            _logger.error("An error occurred while generating settings:", exc_info=True)
            return [
                Divider(f"An error occurred while generating settings:\n{e}"),
                Text(
                    text="Copy full traceback",
                    icon="msg_copy",
                    on_click=lambda _: copy_to_clipboard(format_exc_from(e))
                )
            ]

    @classmethod
    def _gen_autoupdate(cls) -> list:
        def force_update_check_onclick():
            if not _autoupdater:
                _bulletin.show_error(L.au_not_initialised)
                return
            _autoupdater.force_update_check()
            _bulletin.show_info(L.force_update_check_started)

        entries: List = [
            Header(L.autoupdater_header),
            S.enable_autoupdates.as_switch(
                text=L.enable_autoupdates_title,
                subtext=L.enable_autoupdates_hint,
                on_change=lambda enabled: _autoupdater.stop() if enabled else _autoupdater.run()
            ),
        ]

        if not S.enable_autoupdates.get():
            entries.append(Divider())
            return entries

        return [
            *entries,
            S.autoupdate_timeout.as_input(
                text=L.autoupdate_timeout_title,
                subtext=L.autoupdate_timeout_hint,
            ),
            Text(
                text=L.force_update_check,
                icon="msg_photo_switch2",
                accent=True,
                on_click=lambda _: force_update_check_onclick()
            ),
            Divider(),
            safe_set_subtext(
                Text(
                    text=L.prefs_manage_au_tasks,
                    icon="msg_list",
                    create_sub_fragment=lambda: cls._gen_autoupdate_sub()
                ),
                L.prefs_manage_au_tasks_hint
            ),
            Divider(),
        ]

    @classmethod
    def _gen_autoupdate_sub(cls):
        plugins = PluginUtils.get_plugins()
        if not plugins:
            return [Text(L.no_plugins_used_zwylib_autoupdater_found)]

        active_plugins = {
            p_id: p for p_id, p in plugins.items()
            if _does_plugin_uses_zwylib_autoupdater(p_id) and PluginUtils.is_plugin_loaded_or_loading(p_id)
        }

        if not active_plugins:
            return [Text(L.no_plugins_used_zwylib_autoupdater_found)]

        for cached_id in list(_CELL_CACHE.keys()):
            if cached_id not in active_plugins:
                del _CELL_CACHE[cached_id]

        enabled_cells = []
        disabled_cells = []

        for plugin_id, plugin in active_plugins.items():
            if plugin_id not in _CELL_CACHE:
                _CELL_CACHE[plugin_id] = Custom(
                    factory=plugin_cell_setting_factory_instance,
                    factory_args=plugin,
                ) if _SUPPORTS_AUTOUPDATE_TASKS_MANAGE else Text(
                    text=plugin.getName(),
                    icon="msg_plugins",
                    on_click=lambda _, pid=plugin_id: toggle_plugin_autoupdates(pid)
                )

            cell = _CELL_CACHE[plugin_id]
            if autoupdate_config.is_autoupdate_on(plugin_id):
                enabled_cells.append(cell)
            else:
                disabled_cells.append(cell)

        entries = []

        if enabled_cells:
            entries += [Header(L.prefs_au_enabled_header), *enabled_cells, Divider()]

        if disabled_cells:
            entries += [Header(L.prefs_au_disabled_header), *disabled_cells, Divider()]

        if isinstance(entries[-1], Divider):
            entries.pop(-1)
        entries.append(Divider(L.prefs_au_tasks_hint))

        return entries

    @classmethod
    def _gen_dev(cls) -> list:
        def switch_debug_mode(enabled: bool):
            _logger.setLevel(logging.DEBUG if enabled else logging.INFO)
            _logger.info(f"Set '{logging.getLevelName(_logger.level)}' level.")

        show_on_debug_mode = [
            S.disable_ts_check.as_switch(
                text=L.disable_timestamp_check_title,
                subtext=L.disable_timestamp_check_hint,
            ) if S.enable_autoupdates.get() else None,
        ]

        return [
            Header(L.dev_header),
            S.debug_mode.as_switch(
                text=L.debug_mode_title,
                subtext=L.debug_mode_hint,
                on_change=switch_debug_mode,
            ),
            *(show_on_debug_mode if S.debug_mode.get() else []),
            Divider()
        ]


def safe_set_subtext(text_item: Text, subtext: str) -> Text:
    # clients on pre 12.5.1 version have no subtext field and will
    # raise an exception if we pass subtext directly to constructor
    setattr(text_item, "subtext", subtext)
    return text_item


class _PrefsUtils:
    @classmethod
    def execute_migrations(cls):
        previous = SettingsManager.get(S.disable_autoupdate.key, None)
        if previous is not None:
            S.enable_autoupdates.set(not previous)


def open_message(peer_id: int, msg_id: int, topic_id: Optional[int] = None):
    launch_activity = cast(LaunchActivity, get_last_fragment().getParentActivity())
    launch_activity.openMessage(peer_id, msg_id, None, None, topic_id or 0, -1, None)


async def safe_open_message(peer_id: int, msg_id: int, topic_id=0, chat_username: Optional[str] = None):
    loop = async_manager.loop
    future = loop.create_future()

    access_hash = get_messages_controller().getInputPeer(-peer_id)
    if access_hash != 0:
        open_message(peer_id, msg_id, topic_id)
        return

    if not chat_username:
        _logger.warning(f"No access_hash and no username for peer '{peer_id}'.")
        return

    def resolve(chat: Optional[TLRPC.Chat]):
        if not future.done():
            loop.call_soon_threadsafe(future.set_result, chat)

    ChatUtils.getInstance().resolveChannel(chat_username, Callback1(resolve))

    if await future:
        open_message(peer_id, msg_id, topic_id)
    else:
        _logger.error(f"Resolution failed for '{chat_username}'.")


class _AsyncMarker:
    def __init__(self, obj, success_method: str, error_method: Optional[str] = None):
        self.obj = obj
        self.success_method = success_method
        self.error_method = error_method


def _wrap_callback_methods(marker: _AsyncMarker, future: Future):
    loop = async_manager.loop
    target_obj = marker.obj

    def get_and_save_original(method_name: str) -> Callable:
        """
        Searches for the original method. If the method has already been wrapped
        earlier, takes it from the 'save' so as not wrap already wrapped method.
        """
        original_attr_name = f"__zwy_orig_{method_name}"

        if hasattr(target_obj, original_attr_name):
            return getattr(target_obj, original_attr_name)

        original_method = getattr(target_obj, method_name)
        setattr(target_obj, original_attr_name, original_method)
        return original_method

    pure_success = get_and_save_original(marker.success_method)

    def wrapped_success(*cb_args):
        pure_success(*cb_args)
        res = cb_args[0] if len(cb_args) == 1 else cb_args
        loop.call_soon_threadsafe(future.set_result, res)

    setattr(target_obj, marker.success_method, wrapped_success)

    if marker.error_method:
        pure_error = get_and_save_original(marker.error_method)

        def wrapped_error(*cb_args):
            pure_error(*cb_args)
            err_msg = "Java error: " + " ".join(map(str, cb_args))
            loop.call_soon_threadsafe(future.set_exception, Exception(err_msg))

        setattr(target_obj, marker.error_method, wrapped_error)


def _get_plugin_id_from_stack() -> Optional[str]:
    stack = inspect.stack()
    for frame in stack[1:]:
        if _plugins_dir not in frame.filename:
            break
        if frame.filename != __file__:
            return os.path.splitext(os.path.basename(frame.filename))[0]
    return None


class _AsyncManager:
    def __init__(self):
        self.loop = asyncio.new_event_loop()
        self.thread = threading.Thread(target=self._run_event_loop, daemon=True, name="ZwyAsyncThread")
        self.tasks: Dict[str, Set[asyncio.Task]] = defaultdict(set)
        self.started = False

    def _run_event_loop(self):
        asyncio.set_event_loop(self.loop)
        self.loop.run_forever()

    def start(self):
        if self.started:
            _async_logger.warning("Async thread is already started.")
            return
        self.thread.start()
        self.started = True
        _async_logger.debug("Async thread has been started.")

    def stop(self):
        if not self.started:
            _async_logger.warning("Async thread is not started.")
            return

        # noinspection PyTypeChecker
        self.loop.call_soon_threadsafe(self.loop.stop)
        self.thread.join()
        _async_logger.debug("Async loop has been stopped.")

    def run_task(self, coro: Coroutine):
        if not self.started:
            self.start()

        plugin_id = _get_plugin_id_from_stack()

        async def task_wrapper():
            current_task = asyncio.current_task()
            self.tasks[plugin_id].add(current_task)

            try:
                return await coro
            except asyncio.CancelledError:
                _async_logger.debug(f"One of '{plugin_id}' tasks was cancelled.")
                raise
            except Exception:
                _async_logger.error(f"Error in '{plugin_id}' task:", exc_info=True)
            finally:
                self.tasks[plugin_id].discard(current_task)

        return asyncio.run_coroutine_threadsafe(task_wrapper(), self.loop)

    def cancel_all_tasks(self):
        self.cancel_all_for(_get_plugin_id_from_stack())

    def cancel_all_for(self, plugin_id: str):
        tasks_to_cancel = self.tasks.get(plugin_id, set()).copy()
        if not tasks_to_cancel:
            return

        for task in tasks_to_cancel:
            # noinspection PyTypeChecker
            self.loop.call_soon_threadsafe(task.cancel)
        self.tasks[plugin_id].clear()

        _async_logger.debug(f"Cancelled {len(tasks_to_cancel)} tasks for '{plugin_id}'.")

    @staticmethod
    def as_callback(callback_obj, success, error=None):
        return _AsyncMarker(callback_obj, success, error)

    async def wrap_java_call(self, java_method, *args, **kwargs):
        loop = self.loop
        future = loop.create_future()

        mutable_args = list(args)
        for i, arg in enumerate(mutable_args):
            if isinstance(arg, _AsyncMarker):
                _wrap_callback_methods(arg, future)
                mutable_args[i] = arg.obj
                break

        try:
            java_method(*mutable_args, **kwargs)
        except Exception as e:
            if not future.done():
                future.set_exception(e)

        return await future


def _perform_cleanup(plugin_id: str):
    async_manager.cancel_all_for(plugin_id)
    remove_autoupdater_task(plugin_id)
    command_manager.remove_dispatcher(plugin_id)
    locales_controller.unsubscribe_from_refresh(plugin_id)

    if plugin_id in _loaded_or_loading_plugins:
        _loaded_or_loading_plugins.remove(plugin_id)

    _logger.debug(f"Performed cleanup for '{plugin_id}'.")


class _OnPluginUnloadHook(MethodHook):
    def before_hooked_method(self, param: XC_MethodHook.MethodHookParam):
        try:
            _perform_cleanup(param.args[0])
        except Exception:
            _logger.error("An error occurred:", exc_info=True)


@dataclass
class PickedDialogs:
    users: List[int]
    chats: List[int]


@dataclass
class _TopicKey:
    dialog_id: int
    topic_id: int


class DialogPicker:
    class _PickerDelegate(dynamic_proxy(GroupCreateActivity.GroupCreateActivityDelegate)):
        def __init__(self, future: Future):
            super().__init__()
            self.future = future

        def didSelectUsers(self, _, __, ids):
            if self.future.done():
                return

            loop = async_manager.loop

            try:
                picked = PickedDialogs([], [])
                for i in ids.toArray():
                    if i < 0:
                        picked.chats.append(-i)
                    else:
                        picked.users.append(i)

                loop.call_soon_threadsafe(self.future.set_result, picked)
            except Exception as e:
                loop.call_soon_threadsafe(self.future.set_exception, e)

    class _GroupCreateAdapterHook(MethodHook):
        def after_hooked_method(self, param: XC_MethodHook.MethodHookParam):
            try:
                adapter = param.thisObject
                contacts = get_private_field(adapter, "contacts")
                new_contacts = iterable_to_arraylist(filter(lambda i: isinstance(i, TLRPC.Chat), contacts.toArray()))
                set_private_field(adapter, "contacts", new_contacts)
                _logger.debug("Filtered contacts out.")
            except Exception:
                _logger.error("An error occurred:", exc_info=True)

    class _ChatsPickerDelegate(dynamic_proxy(DialogsActivity.DialogsActivityDelegate)):
        def __init__(self, future: Future):
            super().__init__()
            self.future = future

        # noinspection PyPep8Naming, PyUnusedLocal
        def didSelectDialogs(self, fragment, dids, message, param, notify, scheduleDate, scheduleRepeatPeriod, topicsFragment) -> bool:
            if self.future.done():
                return True

            try:
                j_topic_key = dids.get(0)
                dialog_id = j_topic_key.dialogId
                topic_id = j_topic_key.topicId

                async_manager.loop.call_soon_threadsafe(
                    self.future.set_result,
                    _TopicKey(-dialog_id, topic_id)
                )

                run_on_ui_thread(lambda: get_last_fragment().finishFragment(not bool(topic_id)))
                if topic_id:
                    run_on_ui_thread(lambda: get_last_fragment().finishFragment(True))
            except Exception as e:
                async_manager.loop.call_soon_threadsafe(self.future.set_exception, e)
            return True

    class _OnFragmentDestroyHook(MethodHook):
        def __init__(self, future: Future, hooks: List):
            self.future = future
            self.hooks = hooks

        def after_hooked_method(self, param: XC_MethodHook.MethodHookParam):
            for i in self.hooks:
                _unhook(i)

            if not self.future.done():
                async_manager.loop.call_soon_threadsafe(
                    self.future.set_exception,
                    Exception("Cancelled.")
                )

    @classmethod
    async def pick_dialogs(cls, pre_picked: Optional[List[int]] = None, chats_only=False) -> PickedDialogs:
        loop = async_manager.loop
        future = loop.create_future()

        try:
            hooks = []
            args = Bundle()
            args.putBoolean("isAlwaysShare", True)
            args.putInt("chatAddType", 2)

            activity = GroupCreateActivity(args)
            activity.setDelegate(cls._PickerDelegate(future))
            if pre_picked:
                pre_picked = [-i for i in pre_picked]
                activity.select(iterable_to_arraylist(pre_picked, int_auto_convert=False), False, False)

            if chats_only:
                clazz = GroupCreateActivity.GroupCreateAdapter.getClass()
                for constructor in clazz.getConstructors():
                    hooks.append(_hook(constructor, cls._GroupCreateAdapterHook()))

            method = activity.getClass().getDeclaredMethod("onFragmentDestroy")
            hooks.append(_hook(method, cls._OnFragmentDestroyHook(future, hooks)))

            run_on_ui_thread(lambda: get_last_fragment().presentFragment(activity))
        except Exception as e:
            future.set_exception(e)

        return await future

    @classmethod
    async def pick_chat(cls, groups=True, channels=True, topics=False) -> _TopicKey:
        future = async_manager.loop.create_future()

        try:
            hooks = []
            args = create_bundle({
                "dialogsType": getattr(DialogsActivity, "DIALOGS_TYPE_ADD_USERS_TO", 2),
                "onlySelect": True,
                "canSelectTopics": topics,
                "allowSwitchAccount": False,
                "allowGlobalSearch": True,
                "allowUsers": False,
                "allowBots": False,
                "allowChannels": channels,
                "allowLegacyGroups": groups,
                "allowMegagroups": groups,
                "allowGroups": groups,
            })

            activity = DialogsActivity(args)
            activity.setDelegate(cls._ChatsPickerDelegate(future))

            method = activity.getClass().getDeclaredMethod("onFragmentDestroy")
            hooks.append(_hook(method, cls._OnFragmentDestroyHook(future, hooks)))

            run_on_ui_thread(lambda: get_last_fragment().presentFragment(activity))
        except Exception as e:
            future.set_exception(e)

        return await future


class UI:
    @dataclass
    class PopupMenuItem:
        text: str
        on_click: Callable[[], None]
        icon: str
        is_red: bool = False

    class PopupMenuBuilder:
        def __init__(self, view: View):
            self._view = view
            self._items: List["UI.PopupMenuItem"] = []

        def add_item(self, item: "UI.PopupMenuItem"):
            self._items.append(item)

        def show(self):
            try:
                fragment = get_last_fragment()
                builder = ItemOptions.makeOptions(fragment, self._view)

                for item in self._items:
                    context = ApplicationLoader.applicationContext
                    icon_res_id = context.getResources().getIdentifier(item.icon, "drawable", context.getPackageName())
                    builder.add(icon_res_id, item.text, item.is_red, JRunnable(item.on_click))

                builder.show()
            except Exception:
                _logger.error("An error occurred:", exc_info=True)

    @dataclass
    class AlertButton:
        text: str
        on_click: Optional[Callable[[AlertDialogBuilder, int], None]] = None
        type: int = AlertDialogBuilder.BUTTON_POSITIVE
        red: bool = False

    class AlertDialog:
        def __init__(self, title: str, text: str, buttons: List["UI.AlertButton"]):
            self.text = text
            self.title = title
            self.buttons = buttons
            self._builder: Optional[AlertDialogBuilder] = None

        def show(self):
            """
            Shows an alert popup. Should be called from UI thread.
            """
            builder = self._builder
            if builder and (dialog := builder.get_dialog()) and dialog.isShowing():
                _logger.warning("Alert already shown.")
                return

            builder = AlertDialogBuilder(get_last_fragment().getParentActivity(), AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self.title)
            builder.set_message(self.text)
            builder.create()

            builder.set_cancelable(True)
            builder.set_canceled_on_touch_outside(True)

            for btn in self.buttons:
                if not btn:
                    continue

                match btn.type:
                    case AlertDialogBuilder.BUTTON_POSITIVE:
                        builder.set_positive_button(btn.text, btn.on_click)
                    case AlertDialogBuilder.BUTTON_NEGATIVE:
                        builder.set_negative_button(btn.text, btn.on_click)
                    case AlertDialogBuilder.BUTTON_NEUTRAL:
                        builder.set_neutral_button(btn.text, btn.on_click)

                if btn.red:
                    builder.make_button_red(btn.type)

            builder.show()
            _logger.debug("Alert created and shown.")

        def dismiss(self):
            def do_on_ui_thread():
                self._builder.dismiss()
                self._builder = None

            if self._builder and (dialog := self._builder.get_dialog()) and dialog.isShowing():
                run_on_ui_thread(do_on_ui_thread)
                _logger.debug("Alert was dismissed.")

    class BaseInputDialog(Generic[_T]):
        class _ViewClickListener(dynamic_proxy(View.OnClickListener)):
            def __init__(self, callback):
                super().__init__()
                self.callback = callback

            def onClick(self, view):
                self.callback(view)

        class _DialogClickListener(dynamic_proxy(AlertDialog.OnButtonClickListener)):
            def __init__(self, callback):
                super().__init__()
                self.callback = callback

            def onClick(self, dialog, which):
                self.callback(dialog, which)

        class _DismissListener(dynamic_proxy(DialogInterface.OnDismissListener)):
            def __init__(self, edit_text, resolve):
                super().__init__()
                self.edit_text = edit_text
                self.resolve = resolve

            def onDismiss(self, _):
                AndroidUtilities.hideKeyboard(self.edit_text)
                self.resolve(None)

        class _ShowListener(dynamic_proxy(DialogInterface.OnShowListener)):
            def __init__(self, edit_text):
                super().__init__()
                self.edit_text = edit_text

            def onShow(self, _):
                self.edit_text.requestFocus()
                self.edit_text.setSelection(self.edit_text.length())
                AndroidUtilities.showKeyboard(self.edit_text)

        def __init__(self):
            self.edit_text: Optional[EditTextBoldCursor] = None
            self.container: Optional[LinearLayout] = None

        def create_checkbox(self, context, label: str, is_checked: bool, divider: bool, on_click_extra=None):
            cell = CheckBoxCell(context, 1)
            cell.setBackgroundDrawable(Theme.getSelectorDrawable(False))
            cell.setText(label, "", is_checked, divider)

            p_left = AndroidUtilities.dp(16) if LocaleController.isRTL else AndroidUtilities.dp(8)
            p_right = AndroidUtilities.dp(8) if LocaleController.isRTL else AndroidUtilities.dp(16)
            cell.setPadding(p_left, 0, p_right, 0)

            def on_click(_):
                cell.setChecked(not cell.isChecked(), True)
                if on_click_extra:
                    on_click_extra(cell.isChecked())

            cell.setOnClickListener(self._ViewClickListener(on_click))
            return cell

        async def _show_impl(
                self,
                title: str,
                initial_text: str = "",
                hint: str = "",
                on_build_view: Callable[[LinearLayout, Any, Any], None] = None,
                get_result: Callable[[], _T] = None
        ) -> Optional[_T]:
            loop = async_manager.loop
            future = loop.create_future()

            def resolve(result):
                if not future.done():
                    loop.call_soon_threadsafe(future.set_result, result)

            def show_dialog_on_ui():
                fragment = get_last_fragment()
                get_themed_color = fragment.getThemedColor
                context = fragment.getParentActivity()

                builder = AlertDialog.Builder(context)
                builder.setTitle(title)

                self.container = LinearLayout(context)
                self.container.setOrientation(LinearLayout.VERTICAL)

                self.edit_text = EditTextBoldCursor(context)
                self.edit_text.lineYFix = True
                self.edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
                self.edit_text.setText(initial_text)
                self.edit_text.setTextColor(get_themed_color(Theme.key_dialogTextBlack))
                self.edit_text.setHintColor(get_themed_color(Theme.key_groupcreate_hintText))
                self.edit_text.setHintText(hint)
                self.edit_text.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_MULTI_LINE)
                self.edit_text.setCursorColor(get_themed_color(Theme.key_windowBackgroundWhiteInputFieldActivated))
                self.edit_text.setLineColors(
                    get_themed_color(Theme.key_windowBackgroundWhiteInputField),
                    get_themed_color(Theme.key_windowBackgroundWhiteInputFieldActivated),
                    get_themed_color(Theme.key_text_RedRegular)
                )
                self.edit_text.setBackgroundDrawable(None)
                self.edit_text.setPadding(0, AndroidUtilities.dp(6), 0, AndroidUtilities.dp(6))

                self.container.addView(self.edit_text, LayoutHelper.createLinear(MATCH_PARENT, WRAP_CONTENT, 24, 0, 24, 10))

                if on_build_view:
                    on_build_view(self.container, context, get_themed_color)

                builder.setView(self.container)
                builder.setWidth(AndroidUtilities.dp(292))

                def on_done(_, __):
                    res = get_result() if get_result else self.edit_text.getText().toString()
                    dialog.dismiss()
                    resolve(res)

                builder.setPositiveButton(L.alert_done, self._DialogClickListener(on_done))
                builder.setNegativeButton(L.alert_cancel, self._DialogClickListener(lambda _, __: dialog.dismiss()))

                dialog = builder.create()
                dialog.setDismissDialogByButtons(False)
                dialog.setOnDismissListener(self._DismissListener(self.edit_text, resolve))
                dialog.setOnShowListener(self._ShowListener(self.edit_text))
                dialog.show()

            run_on_ui_thread(show_dialog_on_ui)
            return await future

    class StringInputDialog(BaseInputDialog[str]):
        @classmethod
        async def show(cls, title: str, initial_text="", hint="") -> Optional[str]:
            return await cls()._show_impl(title=title, initial_text=initial_text, hint=hint)

    class SelectorDialog:
        class _ViewClickListener(dynamic_proxy(View.OnClickListener)):
            def __init__(self, callback: Callable[[View], None]):
                super().__init__()
                self.callback = callback

            def onClick(self, view: View):
                self.callback(view)

        @classmethod
        async def show(cls, title: str, items: List[str], current_index: int = -1) -> Optional[int]:
            loop = async_manager.loop
            future = loop.create_future()

            def resolve(result):
                if not future.done():
                    loop.call_soon_threadsafe(future.set_result, result)

            def show_on_ui():
                fragment = get_last_fragment()
                if not fragment:
                    resolve(None)
                    return

                context = fragment.getParentActivity()

                builder = AlertDialogBuilder(context)
                builder.set_title(title)

                linear_layout = LinearLayout(context)
                linear_layout.setOrientation(LinearLayout.VERTICAL)

                def on_item_click(index: int):
                    builder.dismiss()
                    resolve(index)

                for i, item_text in enumerate(items):
                    cell = RadioColorCell(context)
                    cell.setPadding(AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4), 0)
                    cell.setCheckColor(
                        Theme.getColor(Theme.key_radioBackground),
                        Theme.getColor(Theme.key_dialogRadioBackgroundChecked)
                    )
                    cell.setTextAndValue(item_text, i == current_index)
                    cell.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 2))
                    cell.setOnClickListener(cls._ViewClickListener(
                        lambda _, idx=i: on_item_click(idx)
                    ))

                    linear_layout.addView(cell, LayoutHelper.createLinear(MATCH_PARENT, WRAP_CONTENT))

                builder.set_view(linear_layout)

                builder.set_negative_button(
                    L.alert_cancel,
                    lambda dialog_builder, which: dialog_builder.dismiss()
                )

                builder.set_on_dismiss_listener(lambda _: resolve(None))

                builder.create()
                builder.show()

            run_on_ui_thread(show_on_ui)
            return await future


def is_client_version_sufficient(version_to_compare: str) -> bool:
    try:
        return Version(BuildVars.BUILD_VERSION_STRING) >= Version(version_to_compare)
    except Exception:
        _logger.error("An error occurred:", exc_info=True)
    return False


class _MediaDownloadObserver:
    def __init__(self, target_file_name: str, future: Future):
        self.target_file_name = target_file_name
        self.future = future
        self.delegate = NotificationCenterDelegate()
        self.delegate.didReceivedNotification = self.notification_received

    # noinspection PyUnusedLocal
    def notification_received(self, notification_id: int, account: int, args: List[Any]):
        if not args or not args[0]:
            return

        file_name = str(args[0])
        if file_name != self.target_file_name:
            return

        if self.future.done():
            return

        loop = async_manager.loop
        if notification_id == NotificationCenter.fileLoaded:
            _logger.debug(f"File '{self.target_file_name}' downloaded successfully.")
            loop.call_soon_threadsafe(self.future.set_result, True)
        elif notification_id == NotificationCenter.fileLoadFailed:
            _logger.debug(f"File '{self.target_file_name}' download failed.")
            loop.call_soon_threadsafe(self.future.set_result, False)


async def ensure_media_downloaded(msg_obj: MessageObject) -> bool:
    media: Optional[TLRPC.MessageMedia] = MessageObject.getMedia(msg_obj)
    if not media:
        _logger.debug(f"Media not found in MessageObject: {msg_obj}")
        return False

    file_loader = get_file_loader()
    attachment = media.photo or media.document
    file_name = FileLoader.getAttachFileName(attachment)
    file_path = file_loader.getPathToAttach(attachment, True)

    if file_path and file_path.exists() and file_path.length() > 0:
        _logger.debug(f"Media already exists: {file_path.getAbsolutePath()}")
        return True

    _logger.debug(f"Starting download for {file_name}...")

    future = async_manager.loop.create_future()
    observer = _MediaDownloadObserver(file_name, future)
    nc = get_notification_center()

    def start_download():
        nc.addObserver(observer.delegate, NotificationCenter.fileLoaded)
        nc.addObserver(observer.delegate, NotificationCenter.fileLoadFailed)

        if msg_obj.isPhoto():
            location = ImageLocation.getForPhoto(
                FileLoader.getClosestPhotoSizeWithSize(media.photo.sizes, 9999),
                media.photo
            )
            file_loader.loadFile(location, "image", "jpg", 1, 1)
        else:
            file_loader.loadFile(media.document, None, 1, 1)

    def stop_download():
        nc.removeObserver(observer.delegate, NotificationCenter.fileLoaded)
        nc.removeObserver(observer.delegate, NotificationCenter.fileLoadFailed)

    run_on_ui_thread(start_download)
    try:
        success = await future
    except Exception:
        _logger.error(f"Exception during download:", exc_info=True)
        success = False
    run_on_ui_thread(stop_download)

    return success


def create_bundle(args: Dict[str, Union[bool, int, str, float]]) -> Bundle:
    bundle = Bundle()
    methods = {
        int: bundle.putInt,
        bool: bundle.putBoolean,
        str: bundle.putString,
        float: bundle.putFloat,
    }

    for k, v in args.items():
        if method := methods.get(type(v), None):
            method(k, v)
    return bundle


class _RefreshLanguageHook(MethodHook):
    def after_hooked_method(self, _):
        _logger.debug("Refreshing locale...")
        locales_controller.refresh_locale()
        SettingsManager.reload()


def _does_plugin_require_zwylib(plugin_id: str, allow_self=False) -> bool:
    try:
        with open(PluginUtils.get_plugin_path(plugin_id), encoding="utf-8", errors="ignore") as f:
            source = f.read().lower()

        if not allow_self and plugin_id == __id__:
            return False

        return "import zwylib" in source or "from zwylib import" in source
    except Exception:
        _logger.error("An error occurred:", exc_info=True)
        return False


def _does_plugin_uses_zwylib_autoupdater(plugin_id: str) -> bool:
    if plugin_id == __id__:
        return True

    if not _does_plugin_require_zwylib(plugin_id, allow_self=True):
        return False

    try:
        with open(PluginUtils.get_plugin_path(plugin_id), encoding="utf-8", errors="ignore") as f:
            source = f.read().lower()

        return "add_autoupdater_task" in source
    except Exception:
        _logger.error("An error occurred:", exc_info=True)
        return False


def _reload_plugins_require_zwylib():
    if not (plugins := PluginUtils.get_plugins()):
        return

    _logger.debug(f"Reloading plugins require {__name__}...")

    try:
        for plugin_id, plugin in plugins.items():
            if plugin.getEngine() != PluginsConstants.PYTHON:
                continue

            is_plugin_loaded = PluginUtils.is_plugin_loaded_or_loading(plugin_id)
            plugin_has_error_cuz_of_zwylib = (err := plugin.getError()) and err and "zwylib" in err.getMessage().lower()
            if not is_plugin_loaded and not plugin_has_error_cuz_of_zwylib:
                continue

            if _does_plugin_require_zwylib(plugin_id):
                PluginUtils.reload_plugin(plugin_id)
    except Exception:
        _logger.error("An error occurred:", exc_info=True)


class PluginUtils:
    @classmethod
    def get_python_engine(cls) -> PythonPluginsEngine:
        return cast(PythonPluginsEngine, PluginsController.engines.get(PluginsConstants.PYTHON))

    @classmethod
    def get_plugin(cls, plugin_id: str) -> Optional[Plugin]:
        try:
            return cls.get_plugins_hashmap().get(plugin_id)
        except Exception:
            _logger.error("An error occurred:", exc_info=True)
        return None

    @classmethod
    def get_plugins_hashmap(cls) -> Optional[ConcurrentHashMap]:
        try:
            return PluginsController.getInstance().plugins
        except Exception:
            _logger.error("An error occurred:", exc_info=True)
        return None

    @classmethod
    def get_plugins(cls) -> Optional[Dict[str, Plugin]]:
        try:
            plugins_hashmap = cls.get_plugins_hashmap()
            return {k: plugins_hashmap.get(k) for k in plugins_hashmap.keySet().toArray()}
        except Exception:
            _logger.error("An error occurred:", exc_info=True)
        return None

    @classmethod
    def get_plugin_path(cls, plugin_id: str) -> str:
        return os.path.join(_plugins_dir, f"{plugin_id}.py")

    @classmethod
    async def install_plugin(cls, file_path: str) -> bool:
        def install_callback(error: Optional[str]):
            if error:
                _logger.error(f"Error installing '{file_path}':", exc_info=Exception(error))
                loop.call_soon_threadsafe(future.set_result, False)
            else:
                loop.call_soon_threadsafe(future.set_result, True)

        loop = async_manager.loop
        future = loop.create_future()

        _logger.debug(f"Installing '{os.path.split(file_path)[1]}' plugin...")

        try:
            cls.get_python_engine().loadPluginFromFile(file_path, None, Callback1(install_callback))
        except Exception:
            future.set_result(False)
            _logger.error(f"Error installing '{file_path}':", exc_info=True)

        return await future

    @classmethod
    def reload_plugin(cls, plugin_id: str):
        try:
            cls.get_python_engine().loadPlugin(plugin_id, cls.get_plugin_path(plugin_id))
            _logger.debug(f"Planned reload of '{plugin_id}'.")
        except Exception:
            _logger.error("An error occurred:", exc_info=True)

    @classmethod
    def is_plugin_loaded_or_loading(cls, plugin_id: str) -> bool:
        plugin = cls.get_plugin(plugin_id)
        return plugin_id in _loaded_or_loading_plugins or (plugin and plugin.isEnabled())

    @classmethod
    async def async_download_and_install_plugin(cls, msg_obj: MessageObject, plugin_id: str, skip_media_download=False, max_tries=3):
        if not skip_media_download:
            media_loaded = False
            for try_num in range(1, max_tries + 1):
                _logger.debug(f"Trying to load '{plugin_id}.plugin' file... (try {try_num}/{max_tries})")
                if media_loaded := await ensure_media_downloaded(msg_obj):
                    break

            if not media_loaded:
                _logger.warning("File was not loaded. Plugin installation aborted.")
                return

            _logger.debug("File was loaded successfully.")

        media = MessageObject.getMedia(msg_obj)
        attachment = media.photo or media.document
        file_path = get_file_loader().getPathToAttach(attachment, True)

        if await PluginUtils.install_plugin(str(file_path)):
            _logger.info(f"Plugin '{plugin_id}' was successfully downloaded and installed.")


def hook_max_args_method(clazz, method_name: str, hook_instance: XposedHook):
    method = max(
        [i for i in clazz.getDeclaredMethods() if i.getName() == method_name],
        key=lambda i: i.getParameterCount(),
        default=None
    )

    if not method:
        _logger.warning(f"Failed to hook {method_name}.")
        return

    method.setAccessible(True)
    _hook(method, hook_instance)


class _OnPluginToggle(MethodHook):
    def before_hooked_method(self, param: XC_MethodHook.MethodHookParam):
        try:
            plugin_id: str = param.args[0]
            enabled: bool = param.args[1]

            _CELL_CACHE.pop(plugin_id, None)

            if enabled:
                _loaded_or_loading_plugins.add(plugin_id)
            else:
                _perform_cleanup(plugin_id)
        except Exception:
            _logger.error("An error occurred:", exc_info=True)


def toggle_plugin_autoupdates(pid: str):
    autoupdate_config.toggle_autoupdate(pid)
    SettingsManager.reload()


_SUPPORTS_AUTOUPDATE_TASKS_MANAGE = is_client_version_sufficient("12.5.1")
if _SUPPORTS_AUTOUPDATE_TASKS_MANAGE:
    try:
        from ui.settings import Custom
        from extera_utils.classes import Base, java_subclass, joverride
        # noinspection PyUnresolvedReferences
        from com.exteragram.messenger.plugins.models import CustomSetting

        # noinspection PyPep8Naming,PyUnusedLocal,PyAttributeOutsideInit
        @java_subclass(FrameLayout)
        class PluginCell(Base):
            def on_post_init(self, context: Context):
                self.need_divider = False
                self.setWillNotDraw(False)

                self.icon_view = BackupImageView(context)
                self.icon_view.setRoundRadius(AndroidUtilities.dp(8))
                self.addView(self.icon_view,
                             LayoutHelper.createFrame(48, 48, Gravity.LEFT | Gravity.CENTER_VERTICAL, 16, 0, 0, 0))

                text_layout = LinearLayout(context)
                text_layout.setOrientation(LinearLayout.VERTICAL)

                self.name_text_view = TextView(context)
                self.name_text_view.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                self.name_text_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                self.name_text_view.setLines(1)
                self.name_text_view.setSingleLine(True)

                self.author_text_view = TextView(context)
                self.author_text_view.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
                self.author_text_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                self.author_text_view.setLines(1)
                self.author_text_view.setSingleLine(True)

                text_layout.addView(self.name_text_view, LayoutHelper.createLinear(MATCH_PARENT, WRAP_CONTENT))
                text_layout.addView(self.author_text_view,
                                    LayoutHelper.createLinear(MATCH_PARENT, WRAP_CONTENT, 0, 2, 0, 0))
                self.addView(text_layout,
                             LayoutHelper.createFrame(MATCH_PARENT, WRAP_CONTENT, Gravity.LEFT | Gravity.CENTER_VERTICAL,
                                                      76, 0, 16, 0))

            def set_data(self, plugin: Plugin, divider: bool):
                self.need_divider = divider
                self.name_text_view.setText(plugin.getName() or "Unknown Plugin")

                version = plugin.getVersion() or "1.0"
                author = plugin.getAuthor() or "Unknown"
                self.author_text_view.setText(f"v{version} • {author}")

                show_icon = plugin.getPack() is not None and plugin.getIndex() >= 0
                pack, index = (plugin.getPack(), plugin.getIndex()) if show_icon else ("exteraPlugins", 0)
                get_media_data_controller().setPlaceholderImageByIndex(self.icon_view, pack, index, "100_100")

                self.requestLayout()

            @joverride()
            def onMeasure(self, widthMeasureSpec: int, heightMeasureSpec: int):
                super().onMeasure(
                    View.MeasureSpec.makeMeasureSpec(View.MeasureSpec.getSize(widthMeasureSpec), View.MeasureSpec.EXACTLY),
                    View.MeasureSpec.makeMeasureSpec(AndroidUtilities.dp(68), View.MeasureSpec.EXACTLY),
                )


        # noinspection PyPep8Naming,PyUnusedLocal,PyAttributeOutsideInit,PyMethodMayBeStatic
        @java_subclass(CustomSetting.Factory)
        class PluginCellSettingFactory(Base):
            @joverride()
            def create(self, plugin: Plugin, setting: CustomSetting, args):
                if not args:
                    return None

                item = UItem.ofFactory(self.getClass())
                item.object = args
                return item

            @joverride()
            def createView(self, context, list_view, current_account, class_guid, resources_provider):
                return PluginCell.new_instance(context).java

            @joverride()
            def bindView(self, view, item, divider, adapter, list_view):
                if item.object:
                    PluginCell.from_java(view).set_data(item.object, divider)

            @joverride()
            def onClick(self, plugin, item, view):
                toggle_plugin_autoupdates(item.object.getId())


        plugin_cell_setting_factory_instance = PluginCellSettingFactory.new_instance().java
        UItem.UItemFactory.setup(plugin_cell_setting_factory_instance)
    except Exception:
        traceback.print_exc()


class _AutoUpdateConfig:
    def __init__(self):
        self._storage = JsonCacheFile("zwylib_au__config", {})
        self._timestamps_storage = JsonCacheFile("zwylib_au__msg_edited_ts", {})  # plugin_id: edit_timestamp_of_message_with_file
        self._merge_configs_if_needed()

    def _update_key(self, plugin_id: str, key: str, value):
        self._storage.content.setdefault(plugin_id, {})[key] = value
        self._storage.write()

    def _merge_configs_if_needed(self):
        if os.path.exists(self._timestamps_storage.path):
            _logger.debug(f"Merging timestamps info to common config: {self._timestamps_storage.content}")

            for plugin_id, timestamp in self._timestamps_storage.content.items():
                self._update_key(plugin_id, "last_updated", timestamp)
            self._timestamps_storage.delete()

    def is_autoupdate_on(self, plugin_id: str) -> bool:
        return self._storage.content.get(plugin_id, {}).get("autoupdates", True)

    def enable_autoupdate(self, plugin_id: str, enabled: bool):
        self._update_key(plugin_id, "autoupdates", enabled)
        _logger.debug(f"{'Enabled' if enabled else 'Disabled'} autoupdates for '{plugin_id}'.")

    def toggle_autoupdate(self, plugin_id: str):
        self.enable_autoupdate(plugin_id, not self.is_autoupdate_on(plugin_id))

    def get_last_updated(self, plugin_id: str) -> int:
        return self._storage.content.get(plugin_id, {}).get("last_updated", 0)

    def set_last_updated(self, plugin_id: str, timestamp: int):
        return self._update_key(plugin_id, "last_updated", timestamp)


@dataclass
class _MkStatsClientData:
    plugin_id: str
    plugin_version: str
    client_name: str
    client_version: str
    install_token: str
    device_fingerprint: str
    api_base_url: str

    @staticmethod
    def create_handshake_payload(
            plugin_id: str,
            version: str,
            client_name: str,
            client_version: str,
            user_hash: str,
            device_fingerprint: str
    ) -> dict:
        return {
            "plugin_id": plugin_id,
            "version": version,
            "client_name": client_name,
            "client_version": client_version,
            "user_hash": user_hash,
            "device_fingerprint": device_fingerprint,
        }

    def to_dict(self, user_hash: str, event: Optional[str] = None, count: Optional[int] = None) -> dict:
        payload = {
            "plugin_id": self.plugin_id,
            "version": self.plugin_version,
            "client_name": self.client_name,
            "client_version": self.client_version,
            "install_token": self.install_token,
            "user_hash": user_hash,
            "device_fingerprint": self.device_fingerprint,
            "timestamp": int(time.time()),
        }
        if event:
            payload["event"] = event
        if count is not None:
            payload["count"] = count
        return payload


class _MkStats:
    def __init__(self):
        self._cache = JsonCacheFile(
            "zwylib__mk_stats_cache",
            {
                "device_id": "",
                "install_token": "",
            }
        )

        self._task: Optional[asyncio.Future] = None
        self._stop_event = asyncio.Event()
        self._client_data: Optional[_MkStatsClientData] = None
        self._handshake_in_progress = False

    def _update_token(self, token: str):
        self._cache.json_content["install_token"] = token
        self._cache.write()
        if self._client_data:
            self._client_data.install_token = token
        _stats_logger.debug(f"Install token updated: {'[SET]' if token else '[CLEARED]'}.")

    def _get_device_id(self) -> str:
        if not self._cache.json_content.get("device_id"):
            self._cache.json_content["device_id"] = uuid.uuid4().hex
            self._cache.write()
            _stats_logger.debug("Generated new device_id.")
        return self._cache.json_content["device_id"]

    @staticmethod
    def _generate_user_hash(device_id: str, plugin_id: str) -> str:
        payload = f"{device_id}:{plugin_id}:mkstats:v1"
        return hashlib.sha256(payload.encode("utf-8")).hexdigest()

    @staticmethod
    def _generate_device_fingerprint(device_id: str) -> str:
        payload = f"{device_id}:mkstats:device:v1"
        return hashlib.sha256(payload.encode("utf-8")).hexdigest()

    @staticmethod
    def _normalize_api_base(url: str) -> str:
        base = url.rstrip("/")
        return f"{base}/v1" if base.endswith("/api") else base

    @staticmethod
    def _get_client_info() -> Tuple[str, str]:
        try:
            raw_client_name = LocaleController.getString("exteraAppName")
            is_extera = not "LOC_ERR" in raw_client_name
            is_ayu = raw_client_name == "AyuGram"

            if is_ayu:
                client_name = "AyuGram"
            elif is_extera:
                client_name = "exteraGram"
            else:
                client_name = "unknown"

            client_version = BuildVars.BUILD_VERSION_STRING

            _stats_logger.debug(f"Client detection: name='{client_name}', version='{client_version}'.")
            return client_name, client_version
        except Exception:
            _stats_logger.debug("Failed to get client info:", exc_info=True)
            return "unknown", "unknown"

    @staticmethod
    async def _post_json(url: str, payload: dict) -> dict:
        safe_payload = payload.copy()
        if "install_token" in safe_payload:
            safe_payload["install_token"] = "[HIDDEN]"
        if "user_hash" in safe_payload:
            safe_payload["user_hash"] = safe_payload["user_hash"][:16] + "..."

        _stats_logger.debug(f"Sending POST to {url} | payload: {safe_payload}.")

        def _sync_post():
            try:
                data = json.dumps(payload).encode("utf-8")
                request = urllib.request.Request(
                    url, data=data, headers={"Content-Type": "application/json"}
                )
                with urllib.request.urlopen(request, timeout=10) as response:
                    body = response.read().decode("utf-8")
                    output = json.loads(body) if body else {}
                    output["_http_status"] = getattr(response, "status", 200)
                    return output
            except urllib.error.HTTPError as error:
                try:
                    body = error.read().decode("utf-8")
                    output = json.loads(body) if body else {"raw": body}
                except Exception:
                    output = {"raw": ""}
                output["_http_status"] = getattr(error, "code", 0)
                _stats_logger.debug(f"HTTPError {error.code} on {url}: {output.get('raw', '')[:300]}.")
                return output
            except Exception as e:
                _stats_logger.debug(f"POST request to {url} failed:", exc_info=True)
                return {"_http_status": 0, "error": str(e)}

        try:
            result = await asyncio.to_thread(_sync_post)
            _stats_logger.debug(f"Response from {url}: status={result.get('_http_status')}.")
            return result
        except Exception:
            _stats_logger.debug("Failed to run _post_json in thread:", exc_info=True)
            return {"_http_status": 0}

    @staticmethod
    async def _solve_pow(challenge: str, difficulty: int) -> Optional[str]:
        def _sync_solve():
            try:
                target_diff = max(1, difficulty)
                deadline = time.time() + MK_STATS_POW_SOLVE_SECONDS
                prefix = "0" * target_diff
                nonce = 0

                while time.time() < deadline:
                    candidate = format(nonce, "x")
                    if hashlib.sha256(f"{challenge}:{candidate}".encode("utf-8")).hexdigest().startswith(prefix):
                        _stats_logger.debug(f"POW solved with nonce {candidate}.")
                        return candidate
                    nonce += 1
                _stats_logger.debug("POW solve timeout.")
                return None
            except Exception:
                _stats_logger.debug("POW solving error:", exc_info=True)
                return None

        return await asyncio.to_thread(_sync_solve)

    async def _handshake(self, plugin_id: str, plugin_version: str) -> Optional[str]:
        if self._handshake_in_progress:
            _stats_logger.debug("Handshake already in progress, skipping duplicate.")
            return None

        self._handshake_in_progress = True
        try:
            device_id = self._get_device_id()
            client_name, client_version = self._get_client_info()

            payload = _MkStatsClientData.create_handshake_payload(
                plugin_id=plugin_id,
                version=plugin_version,
                client_name=client_name,
                client_version=client_version,
                user_hash=self._generate_user_hash(device_id, plugin_id),
                device_fingerprint=self._generate_device_fingerprint(device_id)
            )

            api_base = self._normalize_api_base(MK_STATS_API_URL)
            _stats_logger.debug("Starting handshake.")

            response = await self._post_json(f"{api_base}/handshake", payload)

            if token := response.get("install_token"):
                self._update_token(token)
                _stats_logger.debug("Handshake successful (direct token).")
                return token

            challenge = response.get("pow_challenge")
            if response.get("pow_required") and challenge:
                _stats_logger.debug(f"POW required, difficulty: {response.get('pow_difficulty')}")
                nonce = await self._solve_pow(challenge, int(response.get("pow_difficulty", 1)))

                if nonce:
                    payload["pow_challenge"] = challenge
                    payload["pow_nonce"] = nonce
                    _stats_logger.debug("Sending handshake with solved POW")
                    response = await self._post_json(f"{api_base}/handshake", payload)

                    if token := response.get("install_token"):
                        self._update_token(token)
                        _stats_logger.info("Handshake successful after POW.")
                        return token

            _stats_logger.warning("Handshake failed - no valid token received.")
            return None

        except Exception:
            _stats_logger.debug("Unexpected error during handshake:", exc_info=True)
            return None
        finally:
            self._handshake_in_progress = False

    async def _start_internal(self, plugin_id: str, plugin_version: str):
        try:
            token = self._cache.json_content.get("install_token")
            if not token:
                _stats_logger.debug("No token found in cache → performing handshake.")
                token = await self._handshake(plugin_id, plugin_version)

            if not token:
                _stats_logger.warning("mkStats disabled: initial handshake failed.")
                return

            device_id = self._get_device_id()
            client_name, client_version = self._get_client_info()

            self._client_data = _MkStatsClientData(
                plugin_id=plugin_id,
                plugin_version=plugin_version,
                client_name=client_name,
                client_version=client_version,
                install_token=token,
                device_fingerprint=self._generate_device_fingerprint(device_id),
                api_base_url=self._normalize_api_base(MK_STATS_API_URL)
            )

            _stats_logger.info(f"mkStats started successfully → {client_name} {client_version}.")
            await self._ping_loop()

        except Exception:
            _stats_logger.debug("Critical error in _start_internal:", exc_info=True)

    async def _ping_loop(self):
        backoff = 0
        handshake_backoff = 0

        while not self._stop_event.is_set():
            if not self._client_data or not self._client_data.install_token:
                _stats_logger.debug("Ping loop: waiting for valid client_data...")
                try:
                    await asyncio.wait_for(self._stop_event.wait(), timeout=5.0)
                except asyncio.TimeoutError:
                    continue
                except Exception:
                    _stats_logger.debug("Error while waiting in guard clause:", exc_info=True)
                continue

            try:
                user_hash = self._generate_user_hash(self._get_device_id(), self._client_data.plugin_id)
                payload = self._client_data.to_dict(user_hash=user_hash)

                safe_payload = payload.copy()
                safe_payload["install_token"] = "[HIDDEN]"
                _stats_logger.debug(f"Sending ping | payload: {safe_payload}.")

                response = await self._post_json(f"{self._client_data.api_base_url}/data", payload)
                status = int(response.get("_http_status", 0))

                match status:
                    case 200:
                        backoff = 0
                        handshake_backoff = 0
                        _stats_logger.debug("Ping successful.")

                    case 401:
                        _stats_logger.warning("Received 401 - invalid token. Starting re-handshake...")
                        self._update_token("")
                        new_token = await self._handshake(self._client_data.plugin_id, self._client_data.plugin_version)
                        if new_token:
                            handshake_backoff = 0
                        else:
                            handshake_backoff = min(300, max(10, handshake_backoff * 2 or 10))
                            _stats_logger.debug(f"Re-handshake failed, waiting {handshake_backoff}s before retry.")

                    case 429:
                        backoff = min(21600, max(60, (backoff * 2) if backoff else 60))
                        _stats_logger.debug(f"Rate limited (429), backoff={backoff}s.")

                    case _:
                        if status != 0:
                            _stats_logger.debug(f"Ping returned unexpected status: {status}.")

            except Exception:
                _stats_logger.debug("Error in ping loop:", exc_info=True)

            wait_seconds = (backoff or MK_STATS_PING_INTERVAL) + random.randint(0, 60)
            if handshake_backoff > 0:
                wait_seconds = max(wait_seconds, handshake_backoff)

            try:
                await asyncio.wait_for(self._stop_event.wait(), timeout=wait_seconds)
            except asyncio.TimeoutError:
                continue
            except Exception:
                _stats_logger.debug("Unexpected error while waiting for next ping:", exc_info=True)

    def start(self, plugin_id: str, plugin_version: str):
        if self._task and not self._task.done():
            _stats_logger.debug("mkStats loop already running, skipping start request.")
            return

        self._stop_event.clear()
        self._task = async_manager.run_task(self._start_internal(plugin_id, plugin_version))
        _stats_logger.debug("mkStats loop start requested.")

    def stop(self):
        self._stop_event.set()
        if self._task:
            self._task.cancel()
            self._task = None
        _stats_logger.debug("mkStats loop stop requested.")

    def track_event(self, event: str, count: int = 1):
        if not (self._client_data and self._client_data.install_token):
            _stats_logger.debug(f"track_event('{event}') skipped - no active session.")
            return

        async def _send():
            try:
                user_hash = self._generate_user_hash(self._get_device_id(), self._client_data.plugin_id)
                payload = self._client_data.to_dict(user_hash=user_hash, event=event, count=count)

                safe_payload = payload.copy()
                safe_payload["install_token"] = "[HIDDEN]"
                _stats_logger.debug(f"Sending event '{event}' | payload: {safe_payload}.")

                response = await self._post_json(f"{self._client_data.api_base_url}/event", payload)
                status = int(response.get("_http_status", 0))

                if status == 401:
                    _stats_logger.warning("Event returned 401.")
                    self._update_token("")
                elif status not in (200, 0):
                    _stats_logger.debug(f"Event '{event}' returned status {status}.")
            except Exception:
                _stats_logger.debug(f"Failed to send event '{event}':", exc_info=True)

        async_manager.run_task(_send())


