__id__ = "py_module_installer"
__name__ = "ModuleInstaller"
__description__ = "Установка .py модулей Heroku/Hikka прямо из Telegram с отображением метаданных и команд."
__author__ = "@RnPlugins"
__version__ = "1.0.0"
__icon__ = "RnDev/11"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
import os
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader

DEX_B64 = """"""

class Plugin(BasePlugin):
    def log(self, message: str) -> None:
        super().log(message)
        try:
            log_path = os.path.join(
                ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(),
                "py_module_installer.log"
            )
            with open(log_path, "a", encoding="utf-8") as f:
                f.write(message + "\n")
        except Exception:
            pass

    def on_plugin_load(self):
        try:
            log_file = os.path.join(ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(), "py_module_installer.log")
            if os.path.exists(log_file):
                os.remove(log_file)
        except Exception:
            pass

        self.log("Loading PyModuleInstaller module...")
        try:
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.PyModuleInstaller")

            try:
                from java import jclass
                System = jclass("java.lang.System")
                System.clearProperty("py_module_installer_hooks_registered")
            except Exception:
                pass

            try:
                self.dex_instance = self.dex_class.newInstance()
            except Exception as proxy_err:
                self.log(f"newInstance failed ({proxy_err}), trying getInstance()...")
                get_inst = self.dex_class.getMethod("getInstance")
                self.dex_instance = get_inst.invoke(None)
                if self.dex_instance is None:
                    raise Exception("getInstance() returned null")

            start_method = self.dex_class.getMethod("start")
            start_method.invoke(self.dex_instance)
            self.log("PyModuleInstaller started.")

            try:
                prefix = self.get_setting("prefix", "")
                self.log(f"Prefix: '{prefix}'")
                from java import jclass
                System = jclass("java.lang.System")
                System.setProperty("py_module_installer_prefix", prefix or "")
                
                set_prefix_method = self.dex_class.getMethod("setPrefix", parent_cl.loadClass("java.lang.String"))
                set_prefix_method.invoke(None, prefix or "")
            except Exception as pe:
                self.log(f"setPrefix error: {pe}")

        except Exception as e:
            self.log(f"Failed to load: {e}")
            
        try:
            from ui.alert import AlertDialogBuilder
            from client_utils import get_last_fragment
            from android_utils import run_on_ui_thread
            prefix = self.get_setting("prefix", "")
            if not prefix:
                def show_prefix_alert():
                    try:
                        fragment = get_last_fragment()
                        if fragment is None:
                            return
                        ctx = fragment.getParentActivity()
                        if ctx is None:
                            return
                        builder = AlertDialogBuilder(ctx, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
                        builder.set_title("ModuleInstaller")
                        builder.set_message("Укажите префикс команд юзербота в настройках плагина.")
                        builder.set_positive_button("Настройки", lambda d, _: (
                            d.dismiss(),
                            self._open_settings(),
                        ))
                        builder.set_negative_button("Позже", lambda d, _: d.dismiss())
                        builder.show()
                    except Exception as e:
                        self.log(f"show_prefix_alert error: {e}")
                run_on_ui_thread(show_prefix_alert)
        except Exception as alert_e:
            self.log(f"Prefix alert error: {alert_e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading PyModuleInstaller module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(self.dex_instance)
                self.log("PyModuleInstaller module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
            self.dex_instance = None
        except Exception as e:
            self.log(f"Failed to unload PyModuleInstaller module: {e}")

    def _open_settings(self):
        try:
            cl = ApplicationLoader.applicationContext.getClassLoader()
            pc_class = cl.loadClass("com.exteragram.messenger.plugins.PluginsController")
            method = pc_class.getMethod("openPluginSettings", cl.loadClass("java.lang.String"))
            method.invoke(None, "py_module_installer")
        except Exception as e:
            self.log(f"_open_settings error: {e}")

    def _on_prefix_change(self, value):
        try:
            from java import jclass
            System = jclass("java.lang.System")
            System.setProperty("py_module_installer_prefix", value or "")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                cl = ApplicationLoader.applicationContext.getClassLoader()
                set_prefix_method = self.dex_class.getMethod("setPrefix", cl.loadClass("java.lang.String"))
                set_prefix_method.invoke(None, value or "")
        except Exception as e:
            self.log(f"on_prefix_change error: {e}")

    def create_settings(self) -> list:
        from ui.settings import Header, Input
        return [
            Header(text="ModuleInstaller"),
            Input(
                key="prefix",
                text="Префикс команд",
                default="",
                icon="msg_link",
                on_change=self._on_prefix_change,
            )
        ]
