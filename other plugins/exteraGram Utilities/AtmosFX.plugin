            ),
            Divider(),
            Header(text="Отключить типы погоды"),
            Text(
                text="Выключи погодный эмодзи которые не хочешь видеть",
            ),
            Switch(
                key="weather_disable_snow",
                text="❄️ Отключить снег",
                default=False,
            ),
            Switch(
                key="weather_disable_rain",
                text="💧 Отключить дождь",
                default=False,
            ),
            Switch(
                key="weather_disable_storm",
                text="⚡ Отключить грозу",
                default=False,
            ),
            Switch(
                key="weather_disable_fog",
                text="🌫️ Отключить туман",
                default=False,
            ),
            Switch(
                key="weather_disable_clear",
                text="☀️ Отключить ясно",
                default=False,
            ),
            Switch(
                key="weather_disable_clouds",
                text="☁️ Отключить облачно",
                default=False,
            ),
        ]

    def _show_count_picker(self):
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue
            from android_utils import OnClickListener
            from ui.bulletin import BulletinHelper

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            options = ["10", "20", "30", "50", "75", "100", "150", "200"]
            current = str(self.get_setting("max_count", "50"))
            idx = options.index(current) if current in options else 3

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)
            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("❄️ Количество частиц")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(options) - 1)
            picker.setDisplayedValues(options)
            picker.setValue(idx)
            picker.setWrapSelectorWheel(False)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-1, -2, Gravity.CENTER, 32, 0, 32, 0))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]
            plugin = self

            ok_btn = TextView(act)
            ok_btn.setText("Готово")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            def on_ok(v):
                val = options[picker.getValue()]
                plugin.set_setting("max_count", val, reload_settings=False)
                plugin._apply_count(int(val))
                BulletinHelper.show_info(f"✅ Частиц: {val}")
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()

            ok_btn.setOnClickListener(OnClickListener(on_ok))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()
        except Exception as e:
            self.log(f"[SF] count picker: {e}")

