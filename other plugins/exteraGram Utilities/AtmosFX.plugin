    def _apply_count(self, count: int):
        try:
            if self._snow_cls is None:
                return
            f = self._snow_cls.getDeclaredField("maxCount")
            f.setAccessible(True)
            self._max_count = count
        except Exception as e:
            self.log(f"[SF] apply_count: {e}")


class _WeatherPillHook(MethodHook):
    def __init__(self, plugin):
        self._p = plugin

    def after_hooked_method(self, param):
        try:
            p = self._p
            method_name = param.method.getName()
            if method_name == "setData" and param.args:
                state = param.args[0]
                if state is not None:
                    try:
                        cls = state.getClass()
                        f_emoji = cls.getDeclaredField("emoji")
                        f_emoji.setAccessible(True)
                        emoji = str(f_emoji.get(state) or "")
                        try:
                            f_temp = cls.getDeclaredField("temperature")
                            f_temp.setAccessible(True)
                            p._weather_temperature = float(str(f_temp.get(state)))
                        except Exception:
                            p._weather_temperature = None
                        if emoji is not None:
                            code = p._weather_emoji_to_code(emoji)
                            if code is not None and code != p._weather_code:
                                old_code = p._weather_code
                                p._weather_code = code
                                p._bitmaps.clear()
                                p.log(f"[SF] WeatherPill weather changed: {old_code} -> {code}")
                                from android_utils import run_on_ui_thread
                                import threading
                                def _delayed_refresh():
                                    import time
                                    for _ in range(5):
                                        if getattr(p, "_effect_instances", None):
                                            run_on_ui_thread(p._refresh_all_bitmaps)
                                            return
                                        time.sleep(0.3)
                                    run_on_ui_thread(p._refresh_all_bitmaps)
                                threading.Thread(target=_delayed_refresh, daemon=True).start()
                    except Exception as e:
                        p.log(f"[SF] read State.emoji: {e}")
        except Exception as e:
            p.log(f"[SF] WeatherPillHook: {e}")


class _UpdateHook(MethodHook):
    def __init__(self, plugin):
        self._p = plugin

    def after_hooked_method(self, param):
        try:
            p = self._p
            method_name = param.method.getName()
            if method_name != "createParticlesBitmap":
                return
            p._effect_instances = getattr(p, "_effect_instances", set())
            try:
                p._effect_instances.add(param.thisObject)
            except Exception:
                pass
            args_info = [str(type(a).__name__) for a in (param.args or [])]
            p.log(f"[SF] createParticlesBitmap args={args_info} result={type(param.getResult()).__name__}")
            if p.get_setting("stars_mode", False):
                return
            emoji = p.get_active_emoji()
            if not emoji:
                return
            orig_bmp = param.getResult()
            if orig_bmp is not None:
                try:
                    orig_w = orig_bmp.getWidth()
                    orig_h = orig_bmp.getHeight()
                    p.log(f"[SF] orig: {orig_w}x{orig_h}")
                    cache_key = f"{emoji}_{orig_w}_{orig_h}"
                    emojis   = p.get_active_emojis()
                    rotation = p.get_setting("rotation", False)
                    n_emojis = len(emojis) if emojis else 0
                    cell     = orig_h
                    orig_count = orig_w // cell if cell > 0 else 1
                    atlas_count = max(orig_count, n_emojis) if n_emojis > 0 else orig_count
                    atlas_w  = cell * atlas_count
                    emoji_key = "_".join(emojis) if emojis else "default"
                    rot_key = f"{atlas_w}x{cell}_{emoji_key}_r{rotation}"
                    if rot_key not in p._bitmaps or p._bitmaps[rot_key] is None:
                        from android.graphics import Canvas, Bitmap, Paint
                        bmp    = Bitmap.createBitmap(atlas_w, cell, Bitmap.Config.ARGB_8888)
                        canvas = Canvas(bmp)
                        for idx in range(atlas_count):
                            x0    = idx * cell
                            cur_e = emojis[idx % n_emojis] if n_emojis > 0 else None
                            angle = (idx * (360.0 / atlas_count)) % 360 if rotation else 0
                            drawn = False
                            if cur_e and p._m_drawable is not None:
                                try:
                                    drawable = p._m_drawable.invoke(None, cur_e)
                                    if drawable is not None:
                                        loaded = True
                                        if p._m_is_loaded:
                                            loaded = bool(p._m_is_loaded.invoke(drawable))
                                        if loaded:
                                            if angle != 0:
                                                canvas.save()
                                                canvas.rotate(angle, x0 + cell/2.0, cell/2.0)
                                            drawable.setBounds(x0, 0, x0 + cell, cell)
                                            drawable.draw(canvas)
                                            if angle != 0:
                                                canvas.restore()
                                            drawn = True
                                except Exception:
                                    pass
                            if not drawn and cur_e:
                                paint = Paint(Paint.ANTI_ALIAS_FLAG)
                                paint.setTextSize(cell * 0.75)
                                paint.setTextAlign(Paint.Align.CENTER)
                                fm = paint.getFontMetrics()
                                y  = cell / 2.0 - (fm.ascent + fm.descent) / 2.0
                                if angle != 0:
                                    canvas.save()
                                    canvas.rotate(angle, x0 + cell/2.0, cell/2.0)
                                canvas.drawText(cur_e, x0 + cell/2.0, y, paint)
                                if angle != 0:
                                    canvas.restore()
                        p._bitmaps[rot_key] = bmp
                    if p._f_bitmap is not None:
                        try:
                            p._f_bitmap.set(param.thisObject, p._bitmaps[rot_key])
                        except Exception:
                            pass
                    cache_key = rot_key
                    param.setResult(p._bitmaps[cache_key])
                except Exception as e:
                    p.log(f"[SF] after hook: {e}")
        except Exception:
            pass

    def before_hooked_method(self, param):
        try:
            p = self._p
            method_name = param.method.getName()
            if method_name == "createParticlesBitmap":
                return
            if method_name == "updateParticles" and param.args:
                if p.get_setting("stars_mode", False):
                    effect = param.thisObject
                    effect_id = id(effect)
                    ticks = p._stars_ticks = getattr(p, "_stars_ticks", {})
                    ticks[effect_id] = ticks.get(effect_id, 0) + 1
                    if ticks[effect_id] > 400:
                        param.args[0] = 0
                        return
                if p.get_setting("weather_mode", False):
                    emojis = p.get_active_emojis()
                    if not emojis:
                        param.args[0] = 0
                        return
                speed = int(p.get_setting("speed", "20"))
                dt = param.args[0]
                speed_mult = speed / 20.0
                _, weather_speed = p._get_weather_intensity()
                if p.get_setting("weather_mode", False):
                    speed_mult *= weather_speed
                param.args[0] = int(dt * speed_mult)
                effect = param.thisObject
                if p._f_bitmap is not None:
                    try:
                        current_bmp = p._f_bitmap.get(effect)
                        if current_bmp is not None:
                            w = current_bmp.getWidth()
                            h = current_bmp.getHeight()
                            if w == 60 and h == 30:
                                emoji = p.get_active_emoji()
                                if emoji:
                                    p._replace_bitmap_on_effect(effect)
                    except Exception:
                        pass
						
            max_count = getattr(p, "_max_count", None)
            if p._snow_cls is not None:
                try:
                    effect = param.thisObject
                    f = p._snow_cls.getDeclaredField("maxCount")
                    f.setAccessible(True)
                    base = max_count if max_count is not None else int(f.get(effect))
                    count_mult, _ = p._get_weather_intensity()
                    final = max(5, min(150, int(base * count_mult)))
                    f.setInt(effect, final)
                except Exception:
                    pass
        except Exception:
            pass
