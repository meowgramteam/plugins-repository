__id__ = "auto_delete"
__name__ = "Auto Delete"
__description__ = "Авто-удаление сообщений по времени."
__author__ = "~GRED~"
__version__ = "2.0.1"
__icon__ = "exteraPlugins/0"
__min_version__ = "11.12.0"

import time
import threading
import datetime
from typing import Dict, Any

from base_plugin import BasePlugin, MenuItemData, MenuItemType, HookResult, HookStrategy
from client_utils import get_last_fragment, get_messages_controller, send_request, RequestCallback
from android_utils import run_on_ui_thread, OnClickListener
from ui.bulletin import BulletinHelper
from ui.settings import Header, Switch, Divider, Selector, Text, Input, Input


class AutoDeletePlugin(BasePlugin):

    def on_plugin_load(self):
        self._timers        = {}
        self._edit_timers   = {}
        self._pending       = {}
        self._pending_delete_at     = None
        self._pending_original_text = None
        self._pending_params        = None
        self._pending_account       = None
        self.add_on_send_message_hook()  # регистрируем хук отправки
        self.add_hook("TL_messages_sendMessage")
        self.add_menu_item(MenuItemData(
            menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
            text="🕐 Авто-удаление",
            on_click=self._on_click,
            icon="msg_scheduled",
        ))

    def on_plugin_unload(self):
        for t in list(self._timers.values()) + list(self._edit_timers.values()):
            try:
                t.cancel()
            except Exception:
                pass

    def _format_date(self, delete_at_unix: int) -> str:
        """Форматируем дату удаления согласно настройке пользователя."""
        dt_obj = datetime.datetime.fromtimestamp(delete_at_unix)
        fmt = str(self.get_setting("date_format", "")).strip()

        months_num  = ["01","02","03","04","05","06","07","08","09","10","11","12"]
        months_short = ["янв","фев","мар","апр","май","июн","июл","авг","сен","окт","ноя","дек"]
        months_full  = ["января","февраля","марта","апреля","мая","июня",
                        "июля","августа","сентября","октября","ноября","декабря"]

        if fmt:
            result = fmt
            result = result.replace("YYYY", f"{dt_obj.year:04d}")
            result = result.replace("YY",   f"{dt_obj.year % 100:02d}")
            result = result.replace("MMMM", months_full[dt_obj.month - 1])
            result = result.replace("MMM",  months_short[dt_obj.month - 1])
            result = result.replace("MM",   f"{dt_obj.month:02d}")
            result = result.replace("M",    str(dt_obj.month))
            result = result.replace("DD",   f"{dt_obj.day:02d}")
            result = result.replace("D",    str(dt_obj.day))
            result = result.replace("HH",   f"{dt_obj.hour:02d}")
            result = result.replace("H",    str(dt_obj.hour))
            result = result.replace("mm",   f"{dt_obj.minute:02d}")
            result = result.replace("m",    str(dt_obj.minute))
            result = result.replace("ss",   f"{dt_obj.second:02d}")
            result = result.replace("s",    str(dt_obj.second))
            return result

        # Стандартный формат
        return dt_obj.strftime("%d.%m в %H:%M")

    def _round_remaining(self, remaining: int) -> int:
        """Округляем оставшееся время согласно настройке."""
        r = int(self.get_setting("time_rounding", "0"))
        if r == 0:
            return remaining  # без округления
        if r == 1:
            return (remaining // 5) * 5
        if r == 2:
            return (remaining // 10) * 10
        if r == 3:
            return (remaining // 30) * 30
        if r == 4:
            return (remaining // 60) * 60  # до минут
        if r == 5:
            return (remaining // 300) * 300  # до 5 минут
        return remaining

    def _format_remaining(self, delete_at_unix: int) -> str:
        remaining = delete_at_unix - int(time.time())
        if remaining <= 0:
            return "сейчас"
        remaining = self._round_remaining(remaining)

        # Если больше 24ч — показываем дату
        if remaining >= 86400:
            dt = datetime.datetime.fromtimestamp(delete_at_unix)
            return dt.strftime("%d.%m в %H:%M")

        h = remaining // 3600
        m = (remaining % 3600) // 60
        s = remaining % 60

        # Пользовательский формат
        fmt = str(self.get_setting("time_format", "")).strip()
        if fmt:
            result = fmt
            result = result.replace("hh", f"{h:02d}")
            result = result.replace("mm", f"{m:02d}")
            result = result.replace("ss", f"{s:02d}")
            result = result.replace("h",  str(h))
            result = result.replace("m",  str(m))
            result = result.replace("s",  str(s))
            return result

        # Автоформат
        if remaining < 60:
            return f"{s}сек"
        if remaining < 3600:
            return f"{m}мин {s}сек" if s else f"{m}мин"
        return f"{h}ч {m}мин" if m else f"{h}ч"

    def _show_rounding_picker(self):
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            options = [
                "Без округления",
                "До 5 секунд",
                "До 10 секунд",
                "До 30 секунд",
                "До минут",
                "До 5 минут",
            ]
            current = int(self.get_setting("time_rounding", "0"))

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("⏱ Округление {time}")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(options) - 1)
            picker.setDisplayedValues(options)
            picker.setValue(current)
            picker.setWrapSelectorWheel(False)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-1, -2, Gravity.CENTER, 32, 0, 32, 0))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]

            ok_btn = TextView(act)
            ok_btn.setText("Готово")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            def on_ok(v):
                idx = picker.getValue()
                self.set_setting("time_rounding", str(idx), reload_settings=False)
                BulletinHelper.show_info(f"✅ Округление: {options[idx]}")
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()

            ok_btn.setOnClickListener(OnClickListener(on_ok))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_rounding_picker: {e}")

    def _get_cooldown_seconds(self) -> int:
        return int(self.get_setting("edit_cooldown_secs", 60))

    def post_request_hook(self, request_name: str, account: int, response: Any, error: Any) -> HookResult:
        """После отправки — запускаем авто-удаление и редактирование {time}."""
        try:
            if request_name != "TL_messages_sendMessage" or error:
                return HookResult(strategy=HookStrategy.DEFAULT)
            delete_at     = getattr(self, "_pending_delete_at", None)
            original_text = getattr(self, "_pending_original_text", None)
            if not delete_at or not original_text:
                return HookResult(strategy=HookStrategy.DEFAULT)

            # Сбрасываем pending
            self._pending_delete_at      = None
            self._pending_original_text  = None

            # Получаем msg_id и dialog_id из ответа
            try:
                updates = response
                msgs = getattr(updates, "updates", None)
                if msgs is None:
                    return HookResult(strategy=HookStrategy.DEFAULT)
                for i in range(msgs.size()):
                    upd = msgs.get(i)
                    msg = getattr(upd, "message", None)
                    if msg is None:
                        continue
                    msg_id = getattr(msg, "id", 0)
                    if not msg_id:
                        continue
                    try:
                        dialog_id = msg.getDialogId()
                    except Exception:
                        dialog_id = 0
                    if msg_id and dialog_id:
                        has_t = "{time}" in original_text
                        has_d = "{date}" in original_text
                        run_on_ui_thread(lambda m=msg_id, d=dialog_id, ht=has_t: (
                            self._schedule(m, d, delete_at),
                            self._schedule_edit(m, d, delete_at, original_text) if ht else None
                        ))
                        break
            except Exception as e:
                self.log(f"[AutoDelete] post_request parse: {e}")
        except Exception as e:
            self.log(f"[AutoDelete] post_request_hook: {e}")
        return HookResult(strategy=HookStrategy.DEFAULT)

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        """Перехватываем отправку — если есть {time}, показываем пикер."""
        try:
            text = str(getattr(params, "message", "") or "")
            if "{time}" not in text and "{date}" not in text:
                return HookResult()

            # Если уже показываем пикер — пропускаем
            if getattr(self, "_picker_showing", False):
                from base_plugin import HookStrategy
                result = HookResult()
                result.strategy = HookStrategy.CANCEL
                return result

            # Если это повторный вызов для того же текста — игнорируем
            last_text = getattr(self, "_last_hook_text", None)
            if last_text == text:
                from base_plugin import HookStrategy
                result = HookResult()
                result.strategy = HookStrategy.CANCEL
                return result

            self._last_hook_text  = text
            self._picker_showing  = True
            self._pending_params  = params
            self._pending_account = account

            run_on_ui_thread(lambda: self._show_time_picker_for_send(text))

            from base_plugin import HookStrategy
            result = HookResult()
            result.strategy = HookStrategy.CANCEL
            return result

        except Exception as e:
            self.log(f"[AutoDelete] on_send_message_hook: {e}")
        return HookResult()

    def _show_time_picker_for_send(self, original_text: str):
        """Показываем пикер времени перед отправкой сообщения с {time}."""
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue
            from client_utils import send_request, RequestCallback
            from org.telegram.tgnet import TLRPC

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            import datetime as dt
            now = dt.datetime.now()

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("🕐 Когда удалить сообщение?")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(4))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            sub = TextView(act)
            has_time = "{time}" in original_text
