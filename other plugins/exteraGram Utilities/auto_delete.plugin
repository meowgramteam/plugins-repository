            ok_btn.setText("Отправить")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            def on_ok(v):
                try:
                    import datetime as dt2
                    target = now.replace(
                        hour=hour_picker.getValue(),
                        minute=minute_picker.getValue(),
                        second=second_picker.getValue(),
                        microsecond=0
                    ) + dt2.timedelta(days=day_picker.getValue())

                    delete_at = int(target.timestamp())
                    if delete_at <= int(time.time()):
                        BulletinHelper.show_error("Выбранное время уже прошло!")
                        return

                    plugin._picker_showing = False
                    plugin._last_hook_text = None
                    if sheet_ref[0]:
                        sheet_ref[0].dismiss()

                    # Подставляем переменные в текст и отправляем
                    new_text = original_text
                    if "{time}" in new_text:
                        new_text = new_text.replace("{time}", plugin._format_remaining(delete_at))
                    if "{date}" in new_text:
                        new_text = new_text.replace("{date}", plugin._format_date(delete_at))

                    params = plugin._pending_params
                    if params:
                        params.message = new_text
                        # Отправляем через SendMessagesHelper
                        try:
                            from org.telegram.messenger import SendMessagesHelper
                            smh = SendMessagesHelper.getInstance(plugin._pending_account)
                            smh.sendMessage(params)
                        except Exception as e1:
                            plugin.log(f"[AutoDelete] send failed: {e1}")

                    # Запланируем удаление — msg_id узнаем через хук ответа
                    plugin._pending_delete_at = delete_at
                    plugin._pending_original_text = original_text

                except Exception as e:
                    plugin.log(f"[AutoDelete] on_ok send: {e}")

            ok_btn.setOnClickListener(OnClickListener(on_ok))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))

            cancel_btn = TextView(act)
            cancel_btn.setText("Отмена")
            cancel_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            cancel_btn.setGravity(Gravity.CENTER)
            try:
                cancel_btn.setTextColor(Theme.getColor(Theme.key_text_RedRegular))
            except Exception:
                cancel_btn.setTextColor(Theme.getColor(Theme.key_dialogTextRed))
            cancel_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            cancel_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                AndroidUtilities.dp(8),
                Theme.getColor(Theme.key_dialogBackground),
                Theme.getColor(Theme.key_dialogBackgroundGray)
            ))
            cancel_btn.setClickable(True)
            def on_cancel(v):
                plugin._picker_showing = False
                plugin._last_hook_text = None
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()

            cancel_btn.setOnClickListener(OnClickListener(on_cancel))
            root.addView(cancel_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_time_picker_for_send: {e}")
            self._picker_showing = False

    def _on_click(self, context: Dict[str, Any]):
        try:
            message = context.get("message")
            if message is None:
                return
            msg_id    = message.getId()
            dialog_id = message.getDialogId()
            # Проверяем есть ли {time} в тексте
            try:
                msg_text = message.messageOwner.message if hasattr(message, "messageOwner") else ""
            except Exception:
                msg_text = ""
            self._show_datetime_picker(msg_id, dialog_id, msg_text)
        except Exception as e:
            self.log(f"[AutoDelete] {e}")

