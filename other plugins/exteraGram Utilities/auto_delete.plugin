    def _schedule(self, msg_id, dialog_id, delete_at_unix):
        if msg_id in self._timers:
            self._timers[msg_id].cancel()

        delay = max(1, delete_at_unix - int(time.time()))
        dt    = datetime.datetime.fromtimestamp(delete_at_unix).strftime("%d.%m в %H:%M:%S")

        def do_delete():
            # Отменяем таймер редактирования если есть
            if msg_id in self._edit_timers:
                self._edit_timers[msg_id].cancel()
                del self._edit_timers[msg_id]
            run_on_ui_thread(lambda: self._delete(msg_id, dialog_id))

        t = threading.Timer(delay, do_delete)
        t.daemon = True
        t.start()
        self._timers[msg_id] = t

        def on_undo():
            if msg_id in self._timers:
                self._timers[msg_id].cancel()
                del self._timers[msg_id]
            if msg_id in self._edit_timers:
                self._edit_timers[msg_id].cancel()
                del self._edit_timers[msg_id]
            BulletinHelper.show_info("✅ Авто-удаление отменено")

        try:
            BulletinHelper.show_undo(f"🕐 Удалится {dt}", on_undo=on_undo)
        except Exception:
            BulletinHelper.show_info(f"🕐 Удалится {dt}")

    def _schedule_edit(self, msg_id, dialog_id, delete_at_unix, original_text):
        """Планируем периодическое редактирование."""
        if msg_id in self._edit_timers:
            self._edit_timers[msg_id].cancel()
            del self._edit_timers[msg_id]

        cooldown = self._get_cooldown_seconds()

        if cooldown == 0:
            return

        self._start_edit_timer(msg_id, dialog_id, delete_at_unix, original_text, cooldown)

    def _start_edit_timer(self, msg_id, dialog_id, delete_at_unix, original_text, cooldown):
        """Запускаем один таймер на следующее редактирование."""
        remaining = delete_at_unix - time.time()
        if remaining <= cooldown:
            return  # Осталось меньше кулдауна — не редактируем
        plugin = self

        def on_timer():
            if msg_id not in plugin._timers:
                return  # Уже удалено
            run_on_ui_thread(lambda: plugin._do_edit(msg_id, dialog_id, delete_at_unix, original_text))
            # Следующий таймер
            plugin._start_edit_timer(msg_id, dialog_id, delete_at_unix, original_text, cooldown)

        t = threading.Timer(cooldown, on_timer)
        t.daemon = True
        t.start()
        self._edit_timers[msg_id] = t

    def _do_edit(self, msg_id, dialog_id, delete_at_unix, original_text):
        """Редактируем сообщение — заменяем {time} на оставшееся время."""
        try:
            from org.telegram.tgnet import TLRPC
            mc   = get_messages_controller()
            peer = mc.getInputPeer(dialog_id)

            new_text = str(original_text)
            if "{time}" in new_text:
                new_text = new_text.replace("{time}", self._format_remaining(delete_at_unix))
            if "{date}" in new_text:
                new_text = new_text.replace("{date}", self._format_date(delete_at_unix))

            req           = TLRPC.TL_messages_editMessage()
            req.peer      = peer
            req.id        = msg_id
            req.message   = new_text
            req.flags     = req.flags | 2048  # FLAG_MESSAGE = 2048
            req.no_webpage = True

            send_request(req, RequestCallback(
                lambda r, e: self.log(f"[AutoDelete] edit cb: e={e}") if e else None
            ))
        except Exception as e:
            self.log(f"[AutoDelete] _do_edit: {e}")

    def _delete(self, msg_id, dialog_id):
        try:
            from java.util import ArrayList
            from java.lang import Integer
            msg_list = ArrayList()
            msg_list.add(Integer(msg_id))
            get_messages_controller().deleteMessages(
                msg_list, None, None, dialog_id, 0, True, 0
            )
            if msg_id in self._timers:
                del self._timers[msg_id]
            BulletinHelper.show_info("🗑 Сообщение удалено")
        except Exception as e:
            self.log(f"[AutoDelete] {e}")

    # ~~~ Настройки

    def create_settings(self):
        return [
            Header(text="Переменная {time}"),
            Text(
                text="Частота обновления",
                subtext="Нажми чтобы выбрать кулдаун",
                on_click=lambda v: self._show_cooldown_picker(),
            ),
            Text(
                text="Округление времени",
                subtext="Нажми чтобы выбрать",
                on_click=lambda v: self._show_rounding_picker(),
            ),
            Divider(),
            Header(text="Формат {time}"),
            Input(
                key="time_format",
                text="Шаблон формата",
                subtext="Используй: hh=час mm=мин ss=сек. \n\nПримеры: \n  hh:mm:ss \n  mm:ss \n  удалиртся через mm:ss",
                default="",
            ),
            Divider(),
            Header(text="Формат {date}"),
            Input(
                key="date_format",
                text="Шаблон {date}",
                subtext="DD=день \nMM=мес MMM=мес(кратко) MMMM=мес(полностью) \nYY/YYYY=год \nHH=час mm=мин ss=сек. \n\nПримеры: \n  DD.MM.YYYY в HH:mm \n  D MMMM в HH:mm",
                default="",
            ),
        ]

    def _show_cooldown_picker(self):
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            # Все варианты кулдауна
            options = [
                (5,      "5 сек"),
                (10,     "10 сек"),
                (15,     "15 сек"),
                (30,     "30 сек"),
                (60,     "1 мин"),
                (120,    "2 мин"),
                (300,    "5 мин"),
                (600,    "10 мин"),
                (900,    "15 мин"),
                (1800,   "30 мин"),
                (3600,   "1 час"),
                (7200,   "2 часа"),
                (10800,  "3 часа"),
                (21600,  "6 часов"),
                (43200,  "12 часов"),
                (86400,  "24 часа"),
            ]
            labels   = [o[1] for o in options]
            seconds  = [o[0] for o in options]

            current  = int(self.get_setting("edit_cooldown_secs", 60))
            try:
                cur_idx = seconds.index(current)
            except ValueError:
                cur_idx = 4  # 1 мин по умолчанию

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("⏱ Частота обновления {time}")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(labels) - 1)
            picker.setDisplayedValues(labels)
            picker.setValue(cur_idx)
            picker.setWrapSelectorWheel(False)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-2, -2, Gravity.CENTER))

            from android.view import View
            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]

            ok_btn = TextView(act)
            ok_btn.setText("Сохранить")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            from android_utils import OnClickListener
            def on_save(v):
                idx = picker.getValue()
                secs = seconds[idx]
                self.set_setting("edit_cooldown_secs", secs, reload_settings=False)
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()
                BulletinHelper.show_info(f"✅ Кулдаун: {labels[idx]}")

            ok_btn.setOnClickListener(OnClickListener(on_save))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_cooldown_picker: {e}")
