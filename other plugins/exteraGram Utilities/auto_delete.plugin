            pickers_row = LinearLayout(act)
            pickers_row.setOrientation(LinearLayout.HORIZONTAL)
            pickers_row.setGravity(Gravity.CENTER)

            day_picker = NumberPicker(act)
            day_picker.setMinValue(0)
            day_picker.setMaxValue(30)
            day_labels = []
            for i in range(31):
                d = now + dt.timedelta(days=i)
                day_labels.append("Сегодня" if i == 0 else ("Завтра" if i == 1 else d.strftime("%d %b")))
            day_picker.setDisplayedValues(day_labels)
            day_picker.setValue(0)
            try:
                day_picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass

            hour_picker = NumberPicker(act)
            hour_picker.setMinValue(0)
            hour_picker.setMaxValue(23)
            hour_picker.setValue(now.hour)
            try:
