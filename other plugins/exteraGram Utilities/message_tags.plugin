__id__ = "message_tags"
__name__ = "Local Tags"
__description__ = "Add local tags to any message and search them per chat"
__author__ = "@venerr"
__version__ = "1.0.0"
__icon__ = "PusheenFull/37"
__min_version__ = "12.5.1"


