__id__          = "temp_sub"
__name__        = "TempSub"
__description__ = "Временные подписки на каналы с автоматической отпиской по расписанию."
__author__      = "@itNotMax - @MaxExteraPlugins"
__version__     = "2.4"
__icon__        = "MaxExteraPluginsStickers/5"
__min_version__ = "12.5.1"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

from typing import Any, List, Optional, Dict
import json
import time
import datetime

from org.telegram.tgnet import TLRPC
from org.telegram.messenger import MessagesController, UserConfig, AndroidUtilities, ChatObject

from base_plugin import BasePlugin, HookResult, HookStrategy, AppEvent, MenuItemData, MenuItemType, MethodHook
from client_utils import send_request, RequestCallback, run_on_queue, get_last_fragment, PLUGINS_QUEUE
from android_utils import run_on_ui_thread, OnLongClickListener
from hook_utils import find_class, get_private_field
from ui.settings import Header, Input, Text, Switch, Divider
from ui.alert import AlertDialogBuilder
from ui.bulletin import BulletinHelper


def _activity():
    f = get_last_fragment()
    if f:
        try:
            return f.getParentActivity()
        except:
            pass
    return None


class TempSubPlugin(BasePlugin):

    _check_task_scheduled = False
    _editing_channel_id = None
    _hooked_views = {}

    def on_plugin_load(self):
        self._ensure_data()
        self._setup_drawer_menu()
        self._setup_join_button_hook()
        run_on_queue(self._check_and_leave_expired, PLUGINS_QUEUE, 3000)
        self._schedule_periodic_check()

    def on_plugin_unload(self):
        self._check_task_scheduled = False
        self._hooked_views.clear()

    def on_app_event(self, event: AppEvent):
        if event == AppEvent.START or event == AppEvent.RESUME:
            run_on_queue(self._check_and_leave_expired, PLUGINS_QUEUE, 2000)
            self._schedule_periodic_check()

    def _setup_join_button_hook(self):
        try:
            ChatActivityClass = find_class("org.telegram.ui.ChatActivity")
            if not ChatActivityClass:
                return

            me = self

            class BottomOverlayHook(MethodHook):
                def after_hooked_method(self_hook, param):
                    try:
                        chat_activity = param.thisObject
                        if chat_activity is None:
                            return
                        run_on_ui_thread(lambda: me._try_attach_long_press(chat_activity), 300)
                    except:
                        pass

            try:
                self.hook_all_methods(ChatActivityClass, "updateBottomOverlay", BottomOverlayHook())
            except:
                pass

            try:
                self.hook_all_methods(ChatActivityClass, "onResume", BottomOverlayHook())
            except:
                pass

        except:
            pass

    def _try_attach_long_press(self, chat_activity):
        try:
            current_chat = get_private_field(chat_activity, "currentChat")
            if current_chat is None:
                return

            try:
                if not ChatObject.isChannel(current_chat):
                    return
            except:
                return

            try:
                if not ChatObject.isNotInChat(current_chat):
                    return
            except:
                return

            me = self
            chat_ref = chat_activity

            def on_long_click(view):
                try:
                    chat = get_private_field(chat_ref, "currentChat")
                    if chat is None:
                        return False
                    try:
                        if not ChatObject.isNotInChat(chat):
                            return False
                    except:
                        return False

                    channel_id = chat.id
                    access_hash = chat.access_hash
                    title = chat.title
                    username = ""
                    try:
                        if chat.username:
                            username = chat.username
                    except:
                        pass

                    run_on_ui_thread(lambda: me._show_quick_temp_sub_dialog(
                        channel_id, access_hash, title, username
                    ))
                    return True
                except:
                    return False

            listener = OnLongClickListener(on_long_click)

            view_names = [
                "bottomOverlayChatText",
                "bottomOverlayChat",
            ]

            for name in view_names:
                try:
                    view = get_private_field(chat_activity, name)
                    if view is not None:
                        view_hash = hash(str(id(view)) + name)
                        if view_hash not in self._hooked_views:
                            self._hooked_views[view_hash] = True
                            try:
                                view.setLongClickable(True)
                                view.setOnLongClickListener(listener)
                            except:
                                pass
                except:
                    pass

            try:
                bcbl = get_private_field(chat_activity, "bottomChannelButtonsLayout")
                if bcbl is not None:
                    try:
                        container = bcbl.getContainer()
                        if container is not None:
                            view_hash = hash(str(id(container)) + "container")
                            if view_hash not in self._hooked_views:
                                self._hooked_views[view_hash] = True
                                try:
                                    container.setLongClickable(True)
                                    container.setOnLongClickListener(listener)
                                except:
                                    pass
                    except:
                        pass

                    layout_hash = hash(str(id(bcbl)) + "bcbl")
                    if layout_hash not in self._hooked_views:
                        self._hooked_views[layout_hash] = True
                        try:
                            bcbl.setLongClickable(True)
                            bcbl.setOnLongClickListener(listener)
                        except:
                            pass
            except:
                pass

            try:
                boc = get_private_field(chat_activity, "bottomOverlayChat")
                if boc is not None:
                    self._attach_to_all_children(boc, listener, "boc")
            except:
                pass

        except:
            pass

    def _attach_to_all_children(self, view_group, listener, prefix):
        try:
            from android.view import ViewGroup as VG
            try:
                if not isinstance(view_group, VG):
                    return
            except:
                return
            try:
                count = view_group.getChildCount()
            except:
                return
            for i in range(count):
                try:
                    child = view_group.getChildAt(i)
                    if child is not None:
                        child_hash = hash(str(id(child)) + prefix + str(i))
                        if child_hash not in self._hooked_views:
                            self._hooked_views[child_hash] = True
                            try:
                                child.setLongClickable(True)
                                child.setOnLongClickListener(listener)
                            except:
                                pass
                        self._attach_to_all_children(child, listener, prefix + str(i))
                except:
                    continue
        except:
            pass

