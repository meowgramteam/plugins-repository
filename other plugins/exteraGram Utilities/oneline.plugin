        "close": "Закрыть",
        "reset": "Сброс",
        "menu": "Меню",
        "drag_hint": "Тяните от точки через все клетки",
        "select_mode": "Выберите режим",
        "levels_title": "Выберите уровень",
        "command_help": "Используйте '.oneline' или 3dot menu",
        "settings_title": "Oneline",
        "version_info": "Версия: {version}",
        "reset_progress": "Сбросить прогресс",
        "reset_confirm": "Вы уверены?",
        "reset_success": "Прогресс сброшен!",
        "credit": "Oneline made by @devavaika",
        "streak": "Серия: {n}",
        "cells_left": "Клеток: {done}/{total}",
        "congrats": "Поздравляем! Все 500 уровней пройдены!",
    }
    en = {
        "menu_title": "Oneline",
        "adventure": "Adventure",
        "endless": "Endless",
        "level": "Level {n}",
        "completed": "Level Complete!",
        "next": "Next",
        "restart": "Restart",
        "exit": "Exit",
        "close": "Close",
        "reset": "Reset",
        "menu": "Menu",
        "drag_hint": "Drag from dot through all cells",
        "select_mode": "Select Mode",
        "levels_title": "Select Level",
        "command_help": "Use '.oneline' or 3dot menu",
        "settings_title": "Oneline",
        "version_info": "Version: {version}",
        "reset_progress": "Reset Progress",
        "reset_confirm": "Are you sure?",
        "reset_success": "Progress reset!",
