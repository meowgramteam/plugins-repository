# Optional generated Java class for TextWatcher. If unavailable, KillEx still works,
# but manual-typing detection becomes best-effort only through long-click blocking.
try:
    from java.lang import Object as JObject
    from android.text import TextWatcher
    from extera_utils.classes import Base, java_subclass, joverload

    @java_subclass(JObject, TextWatcher)
    class AntiPasteWatcher(Base):
        def __init__(self):
            self.paste_detected = False

        @joverload("beforeTextChanged", ["java.lang.CharSequence", "int", "int", "int"])
        def before_text_changed(self, s, start, count, after):
            # Pasting/replacing a chunk usually inserts or replaces more than one char at once.
            try:
                if int(after) > 1 or int(count) > 1:
                    self.paste_detected = True
            except Exception:
                pass

        @joverload("onTextChanged", ["java.lang.CharSequence", "int", "int", "int"])
        def on_text_changed(self, s, start, before, count):
            try:
                if int(count) > 1 or int(before) > 1:
                    self.paste_detected = True
            except Exception:
                pass

        @joverload("afterTextChanged", ["android.text.Editable"])
        def after_text_changed(self, editable):
            return None

    HAS_TEXT_WATCHER = True
except Exception:
    AntiPasteWatcher = None
    HAS_TEXT_WATCHER = False


