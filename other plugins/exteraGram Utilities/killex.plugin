DB_KEY = "killex_db_v1"
ENABLED_KEY = "enabled"
STRICT_UI_KEY = "strict_ui"
STRICT_MESSAGES_KEY = "hide_messages_with_blocked_links"
OUTGOING_KEY = "cancel_outgoing_mentions"
DEBUG_KEY = "debug"
ADD_INPUT_KEY = "add_target_input"

UNBAN_PHRASE = "Я осознанно снимаю KillEx-бан и принимаю риск вернуть профиль в клиент"

USERNAME_RE = re.compile(r"(?i)(?:^|[\s/@?=&:.-])([a-z][a-z0-9_]{4,31})(?:$|[\s/?#&=.,:;!)-])")
DIRECT_USERNAME_RE = re.compile(r"(?i)^(?:@|https?://t\.me/|https?://telegram\.me/|tg://resolve\?domain=)?([a-z][a-z0-9_]{4,31})/?$")
TG_USER_ID_RE = re.compile(r"(?i)tg://user\?id=(\d+)")
TME_ID_RE = re.compile(r"(?i)t\.me/user\?id=(\d+)")


def _argb(a: int, r: int, g: int, b: int) -> int:
    value = ((a & 255) << 24) | ((r & 255) << 16) | ((g & 255) << 8) | (b & 255)
    return value - 0x100000000 if value >= 0x80000000 else value


def _shuffle_copy(values):
    values = list(values)
    random.shuffle(values)
    return values

