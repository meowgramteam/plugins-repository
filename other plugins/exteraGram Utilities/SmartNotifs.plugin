                  default=""),
            Switch(key="auto_about_random", text="🎲 Случайный порядок",
                   subtext="Выключено — варианты меняются по порядку",
                   default=False),
            Switch(key="auto_about_no_repeat", text="🚫 Без повторения",
                   subtext="Не выбирать вариант который уже стоит в профиле",
                   default=False),
            Divider(),

            Header(text="📊 Статистика"),
