            Switch(key="sleep_enabled", text="Включить",
                   subtext="Системное уведомление в заданное время", default=False),
            Input(key="sleep_time", text="Время (ЧЧ:ММ)", default="22:00"),
            Input(key="sleep_text", text="Текст уведомления", default="Пора спать 😴"),
            Switch(key="sleep_change_bio", text="Менять «о себе» при напоминании",
                   subtext="Автоматически обновит bio", default=False),
            Input(key="sleep_bio_text", text="Текст «о себе» для режима сна",
                  subtext="⚠️ Только для exteraGram. В AyuGram смена bio недоступна через API.",
                  default="сплю 😴"),
            Divider(),

            Header(text="⏰ Напоминание об отдыхе"),
            Switch(key="break_enabled", text="Включить",
                   subtext="Напомнит если долго сидишь в TG", default=False),
            Input(key="break_interval", text="Через сколько минут",
                  subtext="Например: 30", default="30"),
            Input(key="break_text", text="Текст напоминания",
                  subtext="{min} заменится на реальное время",
                  default="⏰ Ты уже {min} мин в Telegram — пора сделать перерыв!"),
            Divider(),

            Header(text="🔄 Авто-смена профиля"),
            Switch(key="auto_profile_enabled", text="Включить",
                   subtext="Автоматически менять имя / фамилию / о себе", default=False),
        ] + self._auto_mode_items() + [
            Input(key="auto_first_name", text="Варианты имени",
                  subtext="Через запятую: Иван, Иван П., Я. Пусто — не менять",
                  default=""),
            Switch(key="auto_fn_random", text="🎲 Случайный порядок (имя)",
                   default=False),
            Switch(key="auto_fn_no_repeat", text="🚫 Без повторения (имя)",
                   subtext="Не выбирать вариант который уже стоит",
                   default=False),
            Input(key="auto_last_name", text="Варианты фамилии",
                  subtext="Через запятую. Пусто — не менять",
                  default=""),
            Switch(key="auto_ln_random", text="🎲 Случайный порядок (фамилия)",
                   default=False),
            Switch(key="auto_ln_no_repeat", text="🚫 Без повторения (фамилия)",
                   subtext="Не выбирать вариант который уже стоит",
                   default=False),
            Input(key="auto_about", text="Варианты «о себе»",
