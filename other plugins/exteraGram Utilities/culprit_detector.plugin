                    rec["symbolized_by"] = "debuggerd"
                    rec["corroboration"] = "tombstone_confirmed"
                    rec["tombstone_debuggerd"] = _tb
                    if rec.get("event_ts") is None:
                        _ev = _tb.get("event_ts") or _tb.get("logcat_ts")
                        if _ev is not None:
                            try: rec["event_ts"] = int(_ev)
                            except Exception: pass
                    rec["frames_symbolized"] = _mt_sym
                    try:
                        if any(_is_hook_frame(_hf) for _hf in _mt_sym):
