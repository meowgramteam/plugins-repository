                        _log("Block#4C +MD: SIGILL in JVM/ART runtime (%s), no fresh selfkill -> runtime_abort_suspect, conf=low" % _md_where)
        except Exception as _emd:
            _log("Block#4C +MD err: %s" % _emd)

        try:
            if rec.get("tombstone_source") == "inprocess_native_dump" and rec.get("frames"):
                _tb = _parse_debuggerd_tombstone(fault_addr=rec.get("fault_addr"),
                                                 signo=rec.get("signo"),
                                                 crash_ts=rec.get("crash_ts") or rec.get("ts"))
                if _tb:
