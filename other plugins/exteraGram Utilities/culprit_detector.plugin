                src = "self-kill/intentional-restart-programmatic"; conf = "low"
                _log("PRE-MORTEM: программный само-рестарт плагина %r (py-метод restart/reload) -> под-класс intentional-restart/programmatic, conf=low" % pid)
        rec = {
            "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
            "exc_cls": "ProcessTermination", "exc_msg": "%s(%s)" % (method_tag, argval),
            "thread": _pm_thread_name(), "via_hook": False, "hooked_method": method_tag,
            "self_kill": True, "benign_restart": benign_restart, "programmatic_restart": prog_restart, "kill_method": method_tag, "kill_arg": argval,
            "pid_stack": active_pid,
            "pid_crumb": crumb_pid, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age,
            "py_stack": pyframes[:40], "pid_py": pid_py,
