        if hasattr(lib, "cd_wd_read"):
            lib.cd_wd_start.argtypes = [c.c_char_p, c.c_char_p, c.c_char_p, c.c_int32]; lib.cd_wd_start.restype = c.c_int
            lib.cd_wd_stop.restype = c.c_int
            lib.cd_wd_running.restype = c.c_int
            lib.cd_wd_read.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_wd_read.restype = c.c_int
            if hasattr(lib, "cd_wd_set_period"):
                lib.cd_wd_set_period.argtypes = [c.c_int32]; lib.cd_wd_set_period.restype = None
            if hasattr(lib, "cd_wd_polls"):
                lib.cd_wd_polls.restype = c.c_int64
            _WD_NATIVE_OK = True
        else:
            _WD_NATIVE_OK = False
    except Exception:
        _WD_NATIVE_OK = False

    global _SMAPS_NATIVE_OK
    try:
        if hasattr(lib, "cd_smaps_groups"):
            lib.cd_smaps_groups.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_smaps_groups.restype = c.c_int
            lib.cd_smaps_rollup.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_smaps_rollup.restype = c.c_int
            lib.cd_smaps_selftest.restype = c.c_int
            _smaps_layout_ok = True
            try:
                if hasattr(lib, "cd_smaps_group_count"):
                    lib.cd_smaps_group_count.restype = c.c_int32
                    if int(lib.cd_smaps_group_count()) != len(_SMAPS_NATIVE_GROUPS): _smaps_layout_ok = False
                if hasattr(lib, "cd_smaps_field_count"):
                    lib.cd_smaps_field_count.restype = c.c_int32
                    if int(lib.cd_smaps_field_count()) != _SMAPS_NATIVE_FIELDS: _smaps_layout_ok = False
                if hasattr(lib, "cd_smaps_layout_version"):
                    lib.cd_smaps_layout_version.restype = c.c_int32
                    if int(lib.cd_smaps_layout_version()) != _SMAPS_NATIVE_LAYOUT_VERSION: _smaps_layout_ok = False
            except Exception:
                _smaps_layout_ok = False
            _SMAPS_NATIVE_OK = bool(_smaps_layout_ok)
            if _SMAPS_NATIVE_OK:
                try: _log("Block#6D +DU(smaps-native): selftest groups=%d" % int(lib.cd_smaps_selftest()))
                except Exception: pass
            else:
                try: _log("Block#6D +DU(smaps-native): layout drift vs .so (groups/fields/version) -> disabled (guards against memory misattribution)")
                except Exception: pass
        else:
            _SMAPS_NATIVE_OK = False
    except Exception:
        _SMAPS_NATIVE_OK = False

def _b4c_decl(lib):
    c = ctypes
    lib.cd_lt_init.argtypes = [c.c_int32]; lib.cd_lt_init.restype = c.c_int
    lib.cd_register_loader.argtypes = [c.c_int64, c.c_int32]; lib.cd_register_loader.restype = c.c_int
    lib.cd_loader_pid.argtypes = [c.c_int64]; lib.cd_loader_pid.restype = c.c_int32
    lib.cd_lt_count.restype = c.c_int32
    lib.cd_lt_clear.restype = None
    lib.cd_set_active_plugin.argtypes = [c.c_int32]; lib.cd_set_active_plugin.restype = None
    lib.cd_clear_active_plugin.restype = None
    lib.cd_active_plugin.restype = c.c_int32
    try: lib.cd_reset_active_plugin.restype = None
    except Exception: pass
    lib.cd_install_crash_handler.argtypes = [c.c_char_p]; lib.cd_install_crash_handler.restype = c.c_int
    lib.cd_uninstall_crash_handler.restype = None
    if hasattr(lib, "cd_crash_handler_mask"):
        lib.cd_crash_handler_mask.restype = c.c_uint
    if hasattr(lib, "cd_set_host_lib_dir"):
        lib.cd_set_host_lib_dir.argtypes = [c.c_char_p]; lib.cd_set_host_lib_dir.restype = c.c_int
    if hasattr(lib, "cd_maps_refresh"):
        lib.cd_maps_refresh.restype = c.c_int
    if hasattr(lib, "cd_maps_count"):
        lib.cd_maps_count.restype = c.c_int
    if hasattr(lib, "cd_tomb_count"):
        lib.cd_tomb_count.restype = c.c_int64
    if hasattr(lib, "cd_compactions"):
        lib.cd_compactions.restype = c.c_int64
    if hasattr(lib, "cd_compact"):
        lib.cd_compact.restype = c.c_int64

