            _ig_runtime = (_ig_top in _IG_RT) or (_ig_top_frame_so in _IG_RT)
            _ig_scope_guess = ((rec.get("pid_choice_src") == "scope") or (rec.get("pid") is None)) and (rec.get("fso_src") in ("system-top", "none", None))
            if _ig_runtime and (rec.get("cause") == "NULL_DEREF") and _ig_scope_guess:
                _ig_ts = rec.get("ts") or int(time.time() * 1000)
                _ig_best = None; _ig_best_ts = -1
                try:
                    for _cv in _b16_disk_candidates():
                        if _cv.get("confidence") != "high": continue
                        _cts = _cv.get("ts")
