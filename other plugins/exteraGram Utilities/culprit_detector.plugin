                    _log("Block#4C +IG: runtime NULL_DEREF (top_so=%s), no pyerr in window -> scope guess %r downgraded conf=low (runtime_unwind_suspect)" % (_ig_top or "runtime", rec.get("pid")))
        except Exception as _eig:
            _log("Block#4C +IG enrich err: %s" % _eig)
        if rec.get("pid") is not None and a_pid is not None and a_pid >= 0 and c_pid is not None and c_pid >= 0 and a_pid != c_pid:
            _log(f"Block#4C: scope(active_pid={a_pid}) и culprit_pid={c_pid} расходятся -> выбран источник '{rec.get('pid_choice_src')}' (плагин={rec.get('pid')!r})")
        try:
            if rec.get("ts") is None:
                try: rec["ts"] = int(os.path.getmtime(p) * 1000)
                except Exception: rec["ts"] = int(time.time() * 1000)
        except Exception: pass
        try:
