def _b20_loop_native(stop, evfd=-1, seq0=-1):
    global _DN_MIDSTALL_SNAPSHOT
    last_seq = seq0
    if last_seq < 0:
        try: last_seq = int(_NLIB.cd_anr_stall_seq())
        except Exception: last_seq = 0
    if evfd < 0:
        try: evfd = int(_NLIB.cd_anr_eventfd())
        except Exception: evfd = -1
    last_ping = 0.0
    last_beat = 0.0
    _infl_since = None
    _mid = []
    ev = 0
    while not stop.is_set():
        try:
            try: ev |= int(_NLIB.cd_anr_events_take())
            except Exception: pass
            now = time.monotonic()
            try: inflight = int(_NLIB.cd_anr_inflight())
            except Exception: inflight = 1
            if (now - last_ping) * 1000.0 >= _B20_PING_MS and not inflight:
                _b20_post_ping(); last_ping = now
            if (now - last_beat) * 1000.0 >= _B20_BEAT_MS:
                _b20_post_beat(); last_beat = now
            if inflight:
                if _infl_since is None: _infl_since = last_ping if last_ping > 0.0 else now
                if ev & 2:
                    _held = (now - _infl_since) * 1000.0
                    try:
                        _jf, _pn, _cmp = _dn_capture_java_ui_stack()
                        if _jf:
                            _ks = _dn_capture_kernel_state(globals().get("_B33_UI_TID"))
                            _mid.append({"held_ms": _held, "jframes": _jf, "plugin_n": _pn, "component": _cmp, "kernel": _ks, "scope_owner": _dn_live_scope_owner()})
                            if len(_mid) > _DN_MIDSTALL_MAX: _mid = _mid[-_DN_MIDSTALL_MAX:]
                    except Exception: pass
            else:
                _infl_since = None
                if _mid and not (ev & 1): _mid = []
            if ev & 1:
                try: seq = int(_NLIB.cd_anr_stall_seq())
                except Exception: seq = last_seq
                if seq != last_seq:
                    last_seq = seq
                    try: waited = int(_NLIB.cd_anr_stalled_ms())
                    except Exception: waited = _B20_TIMEOUT_MS
                    _DN_MIDSTALL_SNAPSHOT = list(_mid)
                    _gil_begin(_GIL_B20)
                    try:
                        _b20_report_stall(waited)
                    finally:
                        _gil_end(_GIL_B20)
            ev = 0
            _tn = time.monotonic()
            timo = max(0.05, _B20_BEAT_MS / 1000.0 - (_tn - last_beat))
            if not inflight:
                _wp = max(0.05, _B20_PING_MS / 1000.0 - (_tn - last_ping))
                if _wp < timo: timo = _wp
            try:
                if select.select([evfd], [], [], timo)[0]:
                    try: os.read(evfd, 8)
                    except Exception: pass
            except Exception:
                stop.wait(timo)
        except Exception as e:
            try: _log("Block#20 native loop err: %r" % e)
            except Exception: pass
            stop.wait(0.25)

def _b20_start():
    global _B20_THREAD, _B20_NATIVE, _B20_BEAT_INFLIGHT
    _B20_BEAT_INFLIGHT = False
    if not _B20_ON:
        _log("Block#20: disabled"); return
    if not _b20_setup_handler():
        _log("Block#20: setup failed -> ANR watchdog OFF"); return
    _B20_NATIVE = bool(_ANR_NATIVE_OK and _NLIB is not None)
    if not _B20_NATIVE:
        _log("Block#20: native ANR (cd_anr_start) missing -> watchdog OFF (rebuild .so)"); return
    _B20_STOP.clear()
    _a20fd = -1
    try:
        _a20fd = int(_NLIB.cd_anr_eventfd())
    except Exception:
        _a20fd = -1
    _a20seq0 = -1
    try:
        _a20seq0 = int(_NLIB.cd_anr_stall_seq())
    except Exception:
        _a20seq0 = -1
    try:
        _NLIB.cd_anr_mid_cfg(int(_DN_MIDSTALL_AFTER_MS), int(_DN_MIDSTALL_EVERY_MS))
    except Exception:
        pass
    try:
        rc = int(_NLIB.cd_anr_start(int(_B20_TIMEOUT_MS), int(_B20_MAX_PLAUSIBLE_MS), 250))
    except Exception as e:
        _log("Block#20: cd_anr_start err: %r -> watchdog OFF" % e); return
    if rc < 0:
        _log("Block#20: cd_anr_start rc=%d -> watchdog OFF" % rc); return
    _B20_THREAD = threading.Thread(target=_b20_loop_native, args=(_B20_STOP, _a20fd, _a20seq0), name="culprit-anr", daemon=True)
    _B20_THREAD.start()
    _log("Block#20 ANR watchdog: start ping=%dms timeout=%dms detect=C/native (Tier 2b, event-wake) -> %s" % (
        _B20_PING_MS, _B20_TIMEOUT_MS, _ANR_FILE_NAME))

def _b20_stop():
    global _B20_THREAD, _B20_BEAT_INFLIGHT
    _B20_BEAT_INFLIGHT = False
    try:
        _B20_STOP.set()
        if _NLIB is not None:
            try: _NLIB.cd_anr_event_wake()
            except Exception: pass
        t = _B20_THREAD
        if t is not None: t.join(timeout=2.0)
        if _B20_NATIVE and _NLIB is not None:
            try: _NLIB.cd_anr_stop()
            except Exception: pass
        _B20_THREAD = None
        try:
            if _B20_HANDLER is not None: _B20_HANDLER.removeCallbacksAndMessages(None)
        except Exception: pass
        globals()["_B20_PING"] = None; globals()["_B20_BEAT"] = None; globals()["_B20_HANDLER"] = None
        globals()["_B20_BEAT_INFLIGHT"] = False
        _log("Block#20 ANR watchdog: stopped (callbacks cleared)")
    except Exception:
        pass

class Plugin(BasePlugin):
    def on_plugin_load(self):
        global _CRUMB
        _init_log(); _log(f"Culprit Detector v{__version__} loading")
        try: _aw_cleanup_stale_tmp()
        except Exception: pass
        try: _b28_apply_settings(self)
        except Exception as _eb28s: _log("Block#28 settings restore err: %s" % _eb28s)
        try: _cp_reclaim_basehooks()
        except Exception as _ecp: _log("cooperative-patch reclaim err: %s" % _ecp)
        _load_pidindex(); _log(f"Block#2 pid-index restored: {len(_IDX_PID)} entries")
        info = registry_info()
        _log(f"Block#2 реестр: backend={info['backend']} addr=0x{info['addr']:x} "
             f"slots={info['slots']} slot={info['slot_bytes']}B layout={info['layout']} v{info['version']}")
        _selftest_registry()
        _load_native()
        if globals().get("_ABI_FAIL", False):
            _log("Culprit Detector: ABI mismatch -- detector loaded but inert (+DT). Rebuild/embed current libculprit.so (ABI %d)." % _SO_ABI_EXPECT)
            return
        try:
            _mn_rs = _reg_snapshot_restore()
            if _mn_rs:
                _log("Block#2 +MN: tid->plugin реестр восстановлен после reload: %d живых потоков" % _mn_rs)
        except Exception as _emn:
            _log("Block#2 +MN restore err: %s" % _emn)
        try:
            if _NATIVE_OK and _NLIB is not None:
                _NLIB.cd_reset_active_plugin(); _log("Block#5/TLS active-стек сброшен (reset)")
        except Exception:
            pass
        try:
            _omap, _on, _ost = _build_hook_owner_map()
            _owners = sorted(set(v for v in _omap.values() if v))
            _log(f"Block#4A карта хуков: методов={_on} статус={_ost} владельцы={_owners}")
            _log(f"Block#4A фреймворки хуков: {_probe_hook_frameworks()}")
            _ldrs = _plugin_loaders()
            _log(f"Block#4B classloader-карта(boot): загрузчиков={len(_ldrs)} уникальных={len(set(r for _,r,_ in _ldrs))}")
        except Exception as _e:
            _log(f"Block#4A карта err: {_e}")
        _CRUMB = _CrumbFile()
        prev = _CRUMB.read_prev()
        _log(f"PREVIOUS breadcrumb: {prev!r}" if prev else "PREVIOUS breadcrumb: none")
        try:
            self._install_crash_handler()
        except Exception as _eeh:
            try: _log("Block#5 +EH ранний арм UEH err: %s" % _eeh)
            except Exception: pass
        self._boot_verdict()
        self._exec_unhooks = []; self._execcb_unhooks = []; self._load_unhooks = []; self._loader_unhooks = []; self._suicide_unhooks = []; self._appevent_unhooks = []; self._psa_unhooks = []
        self._install_execute(); self._install_exec_errcb(); self._install_loadplugin(); self._install_appevent(); self._install_psa_scope(); self._install_crash_handler(); self._install_loader_hook(); self._install_b24_dexhook(); self._install_b27_view_hook(); self._install_b28c_proxy_hook(); self._install_b23_bitmap_hook(); self._install_gpu_rs_hook(); self._install_anim_op_hook(); self._install_mvel_op_hook(); self._install_binder_op_hook(); self._install_camera_op_hook(); self._install_mediacodec_op_hook(); self._install_gl_op_hook(); self._install_looper_barrier_hook(); self._install_suicide_hook(); self._install_direct_hook(); self._install_thread_start_hook(); self._coexist_selfcheck()
        _log(f"v{__version__} ready (tid registry + crash verdict + native malloc-tags={_NATIVE_OK})")
        try:
            _partb_install()
        except Exception as _eb:
            _log(f"PartB install err: {_eb}")
        try:
            _b10_install()
        except Exception as _eb10:
            _log(f"Block#10 install err: {_eb10}")
        try:
            _b12_install()
        except Exception as _eb12:
            _log(f"Block#12 install err: {_eb12}")
        try:
            _b13_install()
        except Exception as _eb13:
            _log(f"Block#13 install err: {_eb13}")
        try:
            _b14_install()
        except Exception as _eb14:
            _log(f"Block#14 install err: {_eb14}")
        try:
            _b15_install(self)
        except Exception as _eb15:
            _log(f"Block#15 install err: {_eb15}")
        try:
            _b25_install(self)
        except Exception as _eb25:
            _log(f"Block#25 install err: {_eb25}")
        try:
            _b17_install()
        except Exception as _eb17:
            _log(f"Block#17 install err: {_eb17}")
        try:
            _b18_install()
        except Exception as _eb18:
            _log(f"Block#18 install err: {_eb18}")
        try:
            _b19_start()
        except Exception as _eb19:
            _log(f"Block#19 install err: {_eb19}")
        try:
            _b26_start()
        except Exception as _eb26:
            _log(f"Block#26 install err: {_eb26}")
        try:
            _b30_start()
        except Exception as _eb30kg:
            _log(f"Block#30 install err: {_eb30kg}")
        try:
            _b31_start()
        except Exception as _eb31fg:
            _log(f"Block#31 install err: {_eb31fg}")
        try:
            _b20_start()
        except Exception as _eb20:
            _log(f"Block#20 install err: {_eb20}")
        try:
            _b29_start()
        except Exception as _eb29:
            _log(f"Block#29 install err: {_eb29}")
        try:
            _b33_start()
        except Exception as _eb33:
            _log(f"Block#33 install err: {_eb33}")
        try:
