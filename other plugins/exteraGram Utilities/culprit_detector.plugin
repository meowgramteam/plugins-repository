                    rec["confidence"] = "high"
                elif _ck == "host" and rec.get("host_so"):
                    rec["confidence"] = "high"
        except Exception: pass
        try:
            if rec.get("signo") == 4 and rec.get("pid") is None:
                _md_top = ((rec.get("top_so") or "").rsplit("/", 1)[-1] or "").lower()
                _md_fso = ""
                _md_fr = rec.get("frames") or []
                if _md_fr and isinstance(_md_fr[0], str) and ".so" in _md_fr[0]:
                    _md_fso = _md_fr[0].split("+", 1)[0].split(" ", 1)[0].rsplit("/", 1)[-1].lower()
                if (_md_top in _MD_RT_SO) or (_md_fso in _MD_RT_SO):
                    rec["runtime_abort_suspect"] = True
                    rec["native_subtype"] = "runtime_abort"
                    _md_where = _md_top or _md_fso or "runtime"
                    _md_sk = None
                    try:
                        _md_vp = _kg_verdict_path()
