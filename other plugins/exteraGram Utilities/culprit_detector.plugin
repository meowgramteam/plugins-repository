                            if _md_cts is not None and _md_bts is not None:
                                _md_ok = abs(int(_md_cts) - int(_md_bts)) <= _MD_VERDICT_FRESH_MS
                            elif _md_cts is None:
                                _md_ok = (time.time() - os.path.getmtime(_md_vp)) * 1000.0 <= _MD_VERDICT_FRESH_MS
                        except Exception:
