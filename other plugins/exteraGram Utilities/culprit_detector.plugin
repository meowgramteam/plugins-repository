_PSA_TL = threading.local()

def _psa_tl_stk():
    s = getattr(_PSA_TL, "stk", None)
    if s is None: s = _PSA_TL.stk = []
    return s

def _psa_resolve_pid(inst):
    if inst is None: return None
    for _fn in _PSA_PLUGIN_ATTRS:
        try: v = getattr(inst, _fn, None)
        except Exception: continue
        if v is None: continue
        try:
            if callable(v): v = v()
        except Exception: continue
        if v is None: continue
        pid = v if isinstance(v, str) else None
        if pid is None:
            for _an in _PSA_ID_ATTRS:
                try: a = getattr(v, _an, None)
                except Exception: continue
                if a is None: continue
                try:
                    if callable(a): a = a()
                except Exception: continue
                if isinstance(a, str) and a: pid = a; break
        if isinstance(pid, str) and pid:
            try: pid = _canon_pid(pid)
            except Exception: pass
            if isinstance(pid, str) and pid and pid not in (_SELF_ID, __id__):
                return pid
    return None

class _PsaScopeHook(MethodHook):
    def before_hooked_method(self, param):
        pushed = False
        try:
            pid = _psa_resolve_pid(getattr(param, "thisObject", None))
            if pid: pushed = bool(_scoped_set(pid))
        except Exception:
            pushed = False
        try: _psa_tl_stk().append(pushed)
        except Exception: pass
    def after_hooked_method(self, param):
        try:
            st = _psa_tl_stk()
            if st and st.pop(): _scoped_clear()
        except Exception:
            pass

_KZ_MO_AMBIG = "\x00ambig"
_KZ_MO_CAP = 512
_KZ_MO_LOCK = threading.Lock()
_KZ_MO_MAP = {}

def _kz_mo_note(mname, pid):
    if not mname or not pid: return
    if pid in (_SELF_ID, __id__): return
    if "." in mname or " " in mname: return
    try:
        with _KZ_MO_LOCK:
            cur = _KZ_MO_MAP.get(mname)
            if cur is None:
                if len(_KZ_MO_MAP) < _KZ_MO_CAP:
                    _KZ_MO_MAP[mname] = pid
            elif cur != pid and cur != _KZ_MO_AMBIG:
                _KZ_MO_MAP[mname] = _KZ_MO_AMBIG
    except Exception:
        pass

def _kz_mo_lookup(jframes):
    try:
        for _f in (jframes or []):
            if "LSPHooker_." not in _f: continue
            _mn = _f.split("LSPHooker_.", 1)[1].split("(", 1)[0].strip()
            if not _mn: continue
            _o = _KZ_MO_MAP.get(_mn)
            if _o and _o != _KZ_MO_AMBIG:
                return _o, _mn
    except Exception:
        pass
    return None, None

_IU_BRIDGE_NAMES = ("PyMethodHook", "com.exteragram.messenger.plugins.xposed",
                    "HookCallbackDispatcher", "XposedBridge", "callThrowsNative",
                    "LSPHooker_")

def _iu_stack_is_bridge(jframes, component):
    
    try:
        if component and any(_s in component for _s in _IU_BRIDGE_NAMES):
            return True
        for _f in (jframes or [])[:8]:
            if any(_s in _f for _s in _IU_BRIDGE_NAMES):
                return True
    except Exception:
        pass
    return False

def _iu_bridge_owner(jframes, waited_ms, ui_tid=None):
    
    try:
        _op = _b20_owner_from_op(int(waited_ms) + 2500)
        if _op and _op.get("owner"):
            return _op.get("owner"), ("op:" + str(_op.get("domain") or "?"))
    except Exception:
        pass
    try:
        _o, _fr, _how, _meta = _hook_owner_for_frames(jframes or [])
        if _o and _o not in (_SELF_ID, __id__):
            return _o, ("hook-map:" + str(_how))
    except Exception:
        pass
    try:
        _o2, _mn2 = _kz_mo_lookup(jframes)
        if _o2:
            return _o2, ("reg-map:" + str(_mn2))
    except Exception:
        pass
    try:
        for _f in (jframes or []):
            _cls = _f.split("(", 1)[0].rsplit(".", 1)[0] if "(" in _f else _f
            _pid = _map_stack_to_id(_cls, _known_union()) if _cls else None
            if _pid and _pid not in (_SELF_ID, __id__):
                return _pid, "stack-loader"
    except Exception:
        pass
    try:
        _crows, _cmeta = _b29_cpu_top()
        _hog = _b29_hog_culprit(_crows, _cmeta)
        if _hog is None:
            _crows, _cmeta = _b29_fresh_top(160)
            _hog = _b29_hog_culprit(_crows, _cmeta)
        if _hog and _hog.get("owner") and _hog["owner"] not in (_SELF_ID, __id__):
            _how5 = None
            try:
                if ui_tid is not None and int(_hog["tid"]) == int(ui_tid):
                    _how5 = "cpu-hog:ui-tid=%s:%.0f%%" % (_hog["tid"], _hog["pct"])
            except Exception:
                _how5 = None
            if _how5 is None:
                _sat = [_r for _r in (_crows or []) if _r.get("owner") == _hog["owner"] and float(_r.get("pct") or 0.0) >= _B29_CORROB_PCT]
                if len(_sat) >= 2:
                    _how5 = "cpu-hog:multi:tid=%s:%.0f%%x%d" % (_hog["tid"], _hog["pct"], len(_sat))
            if _how5:
                return _hog["owner"], _how5
    except Exception:
        pass
    return None, None

def _op_family_native_install(dom):
    
    _U = dom.upper()
    if not (globals().get("_%s_NATIVE_ON" % _U, True) and globals().get("_%s_NATIVE_OK" % _U, False)
            and _NLIB is not None and _CTYPES_OK):
        return (False, 0)
    off = int(globals().get("_%s_ENTRY_OFFSET" % _U, 0) or 0)
    try:
        _self = getattr(_NLIB, "cd_%s_selftest" % dom)
        _inst = getattr(_NLIB, "cd_%s_install" % dom)
    except Exception:
        return (False, 0)
    try:
        _ok = int(_self(ctypes.c_int32(off)))
    except Exception:
        _ok = 0
    if _ok <= 0:
        return (False, 0)
    try:
        _n = int(_inst(ctypes.c_int32(off)))
    except Exception:
        _n = 0
    if _n > 0:
        return (True, _n)
    return (False, 0)

def _mvel_native_diag():
    try:
        if _NLIB is None or not _CTYPES_OK or not hasattr(_NLIB, "cd_mvel_diag"):
            return None
        _cap = 10
        _buf = (ctypes.c_int64 * _cap)()
        _w = int(_NLIB.cd_mvel_diag(_buf, ctypes.c_int(_cap)))
        if _w <= 0:
            return None
        _r = [int(_buf[i]) for i in range(min(_w, _cap))]
        return _r + [0] * max(0, _cap - len(_r))
    except Exception:
        return None

