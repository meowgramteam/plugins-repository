def _host_lib_dir():
    try:
        ctx = _app_context()
        if ctx is None: return None
        ai = ctx.getApplicationInfo()
        d = getattr(ai, "nativeLibraryDir", None)
        return str(d) if d else None
    except Exception:
        return None

def _scope_decl(lib):
    c = ctypes
    if not all(hasattr(lib, n) for n in ("cd_scope_enter", "cd_scope_leave", "cd_scope_current")):
        return False
    lib.cd_scope_enter.argtypes = [c.c_int32]; lib.cd_scope_enter.restype = c.c_int
    lib.cd_scope_leave.argtypes = []; lib.cd_scope_leave.restype = c.c_int
    lib.cd_scope_current.argtypes = []; lib.cd_scope_current.restype = c.c_int32
    global _ARM_OK
    try:
        if all(hasattr(lib, n) for n in ("cd_scope_arm", "cd_scope_arm_clear")):
            lib.cd_scope_arm.argtypes = [c.c_int32]; lib.cd_scope_arm.restype = c.c_int
            lib.cd_scope_arm_clear.argtypes = []; lib.cd_scope_arm_clear.restype = c.c_int
            try:
                lib.cd_scope_arm_window_ns.argtypes = [c.c_int64]; lib.cd_scope_arm_window_ns.restype = c.c_int64
            except Exception: pass
            _ARM_OK = True
            try:
                if all(hasattr(lib, n) for n in ("cd_seed_arm", "cd_seed_take")):
                    lib.cd_seed_arm.argtypes = [c.c_int32]; lib.cd_seed_arm.restype = c.c_int
                    lib.cd_seed_take.argtypes = []; lib.cd_seed_take.restype = c.c_int32
                    globals()["_SEED_OK"] = True
            except Exception:
                globals()["_SEED_OK"] = False
    except Exception:
        _ARM_OK = False
    global _PIDCOUNT_OK
    try:
        if hasattr(lib, "cd_reg_set_pid_count"):
            lib.cd_reg_set_pid_count.argtypes = [c.c_int32]; lib.cd_reg_set_pid_count.restype = c.c_int
            _PIDCOUNT_OK = True
            try: lib.cd_reg_set_pid_count(c.c_int32(len(_IDX_PID)))
            except Exception: pass
    except Exception:
        _PIDCOUNT_OK = False
    try:
        if all(hasattr(lib, n) for n in ("cd_b10_enter", "cd_b10_leave", "cd_b10_selftest")):
            lib.cd_b10_enter.argtypes = [c.c_int32, c.c_int32, c.c_int32, c.c_int32]; lib.cd_b10_enter.restype = c.c_int32
            lib.cd_b10_leave.argtypes = [c.c_int32, c.c_int32, c.c_int32]; lib.cd_b10_leave.restype = c.c_int32
            lib.cd_b10_selftest.argtypes = [c.c_int32]; lib.cd_b10_selftest.restype = c.c_int32
            global _CD_B10_ENTER, _CD_B10_LEAVE
            _CD_B10_ENTER = lib.cd_b10_enter
            _CD_B10_LEAVE = lib.cd_b10_leave
            if int(lib.cd_b10_selftest(0)) == 1:
                _log("Block#10/G: нативный reentry-gate (cd_b10_enter/leave) доступен — горячий путь _w без Python-dict")
            else:
                _log("Block#10/G: WARN cd_b10_selftest != 1 -- native reentry-gate self-test failed (out-of-sync .so build!)")
    except Exception:
        pass
    try:
        lib.cd_scope_depth.argtypes = []; lib.cd_scope_depth.restype = c.c_int32
    except Exception: pass
    try:
        lib.cd_thread_inherited.argtypes = []; lib.cd_thread_inherited.restype = c.c_int64
    except Exception: pass
    return True

def _b4c_init(lib):
    global _B4C_OK
    try:
        _b4c_decl(lib)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C: символы не найдены в .so (старый бинарь?) — #4C отключён: {e}")
        return
    try:
        rc = int(lib.cd_lt_init(int(_LT_SLOTS)))
        ncp = _native_crash_path()
        ncw = None
        try:
            ncw = _aw_mirror_path(ncp) if ncp else None
        except Exception:
            ncw = None
        ncp_install = ncw or ncp
        inst = -1
        if ncp_install:
            inst = int(lib.cd_install_crash_handler(ncp_install.encode("utf-8")))
            if hasattr(lib, "cd_maps_refresh"):
                try:
                    _mc = int(lib.cd_maps_refresh())
                    _log(f"Block#4C +CO maps snapshot: {_mc} modules")
                except Exception as _emr:
                    _log(f"Block#4C +CO cd_maps_refresh err: {_emr}")
        hld = None
        if hasattr(lib, "cd_set_host_lib_dir"):
            try:
                hld = _host_lib_dir()
                lib.cd_set_host_lib_dir((hld or "").encode("utf-8"))
            except Exception as _ehl:
                _log(f"Block#4C: cd_set_host_lib_dir err: {_ehl}"); hld = None
        if rc != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_lt_init FAIL rc={rc} — #4C отключён (native-crash attribution OFF)")
            return
        if ncp and inst != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_install_crash_handler FAIL rc={inst} — #4C отключён")
            return
        _B4C_OK = True
        _b4c_cov = ""
        if inst == 0 and hasattr(lib, "cd_crash_handler_mask"):
            try:
                _b4c_msk = int(lib.cd_crash_handler_mask()) & 0x1F
                _b4c_full = (_b4c_msk == 0x1F)
                _b4c_cov = f", coverage={'FULL' if _b4c_full else 'PARTIAL'} mask=0x{_b4c_msk:02x}"
                if not _b4c_full:
                    _log(f"Block#4C: native-crash coverage PARTIAL mask=0x{_b4c_msk:02x} (не все сигналы захвачены)")
            except Exception as _emsk:
                _log(f"Block#4C: cd_crash_handler_mask err: {_emsk}")
        _log(f"Block#4C: lt_init rc={rc} slots={_LT_SLOTS}, crash_handler={'OK' if inst==0 else 'rc=%d' % inst}{_b4c_cov} -> {ncp_install}")
        _log(f"Block#4C +CJ host-native: lib_dir={hld!r} -> {'ON' if hld else 'OFF (старый .so или нет контекста)'}")
        global _SCOPE_OK
        try:
            if _scope_decl(lib):
                lib.cd_scope_enter(-1); lib.cd_scope_leave()
                _SCOPE_OK = True
                try:
                    global _JP_ARM_SEED
                    _jp_rev = int(lib.cd_build_rev()) if hasattr(lib, "cd_build_rev") else 0
                    _JP_ARM_SEED = bool(_SEED_OK and _jp_rev >= 10435)
                    _log("Block#3E +JP: thread-start owner-seed via native seed-slot = %s (rev=%s, seed_ok=%s, arm_ok=%s)" % (("ON" if _JP_ARM_SEED else "OFF (native path unavailable; hook no-op)"), _jp_rev, _SEED_OK, _ARM_OK))
                except Exception: pass
                _log("Block#10/C scope: cd_scope_enter/leave доступны — _scoped_set/clear через ОДИН нативный вызов")
                try:
                    if hasattr(lib, "cd_thread_inherited"):
                        _log("Block#10/C: cd_thread_inherited=%d (порождённые потоки унаследовали тег)" % int(lib.cd_thread_inherited()))
                except Exception: pass
            else:
                _SCOPE_OK = False
                _log("Block#10/C scope: cd_scope_* нет в .so (старый бинарь) — _scoped_set/clear через legacy (2 вызова)")
        except Exception as _esc:
            _SCOPE_OK = False
            _log("Block#10/C scope: декл/round-trip err: %s" % _esc)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C init err: {e}")

def _load_native():
    global _NLIB, _NATIVE_OK
    if not _CTYPES_OK or _REG_BUF is None:
        _log("Block#3: ctypes/shared-реестр недоступен — натив отключён (tid=Java id)")
        return
    if not _SO_ARM64:
        _log("Block#3: .so не вшит (_SO_ARM64 пуст) — запусти embed_so.py; натив отключён")
        return
    try:
        path = _b3_extract_so()
        if not path:
            return
        try:
            jclass("java.lang.System").load(path)
            _log("Block#3 System.load OK (namespace-load удался)")
        except Exception as e:
            _es = str(e)
            if ("getClassLoader" in _es) or ("null object reference" in _es):
                _log("Block#3 System.load: рефлексивный вызов без Java-caller — ожидаемо, .so грузится через ctypes.CDLL (не ошибка)")
            else:
                _log(f"Block#3 System.load warn: {_es}")
        lib = ctypes.CDLL(path)
        _b3_decl(lib)
        try:
            _abi = int(lib.cd_abi_version()) if hasattr(lib, "cd_abi_version") else None
        except Exception:
            _abi = None
        if _abi != _SO_ABI_EXPECT:
            globals()["_ABI_FAIL"] = True
            _log("Block#3 ABI MISMATCH .so=%s expected %d -- native disabled, plugin inert (+DT)" % (str(_abi), _SO_ABI_EXPECT))
            _NLIB = None; _NATIVE_OK = False
            return
        globals()["_SO_ABI_SEEN"] = int(_abi)
        try: _log("Block#3 +HS: native .so ABI=%d OK (expected %d) -- native active" % (int(_abi), _SO_ABI_EXPECT))
        except Exception: pass
        try: _log("Block#3 native build rev=%s" % (str(int(lib.cd_build_rev())) if hasattr(lib, "cd_build_rev") else "<absent: old .so>"))
        except Exception: pass
        info = registry_info()
        rc = int(lib.cd_init(ctypes.c_uint64(info["addr"]), int(info["slots"]), int(info["slot_bytes"])))
        if rc != 0:
            _log(f"Block#3 cd_init FAIL rc={rc} — натив отключён")
            return
        hooks = int(lib.cd_start())
        if hooks < 0:
            _log(f"Block#3 cd_start FAIL rc={hooks} — натив отключён")
            try: lib.cd_stop()
            except Exception: pass
            _NLIB = None; _NATIVE_OK = False
            return
        _NLIB = lib; _NATIVE_OK = True
        try:
            if _NA_NATIVE_OK and _NA_SAMPLE_ENABLE and hasattr(lib, "cd_na_enable"):
                lib.cd_na_enable(1, int(_NA_MIN_BYTES))
                _log("Block#3S native alloc-site capture: ON min=%d" % int(_NA_MIN_BYTES))
                try: _na_mark_epoch()
                except Exception: pass
        except Exception as _ena:
            _log("Block#3S cd_na_enable err: %s" % _ena)
        _b4c_init(lib)
        try:
            _b19_init(lib)
        except Exception as _e19:
            _log(f"Block#19 init err: {_e19}")
        try:
            _b26_init(lib)
        except Exception as _e26:
            _log(f"Block#26 init err: {_e26}")
        try:
            _b30_init(lib)
        except Exception as _e30kg:
            _log(f"Block#30 init err: {_e30kg}")
        try:
            _b31_init(lib)
        except Exception as _e31fg:
            _log(f"Block#31 init err: {_e31fg}")
        _log(f"Block#3 натив загружен: {path}")
        _log(f"Block#3 cd_init OK (reg=0x{info['addr']:x} slots={info['slots']} slot={info['slot_bytes']}B), хуков malloc={hooks}")
        if hooks <= 0:
            _log("Block#3 ⚠ ноль хуков — sh не перехватил libc (проверь sh)")
    except Exception as e:
        _NLIB = None; _NATIVE_OK = False
        _log(f"Block#3 load err: {e}")

def _so_features_str():
    g = globals()
    flags = [("OOM", "_OOM_NATIVE_OK"), ("ANR", "_ANR_NATIVE_OK"),
             ("GREF", "_GREF_NATIVE_OK"), ("OP", "_OP_NATIVE_OK"),
             ("SCOPE", "_SCOPE_OK"), ("TRIM", "_TRIM_NATIVE_OK"),
             ("LOWMEM", "_LOWMEM_NATIVE_OK"), ("WD", "_WD_NATIVE_OK")]
    try:
        return "  ".join("%s:%s" % (lbl, "on" if g.get(v) else "off") for lbl, v in flags)
    except Exception:
        return ""

def _so_health():
    
    exp = _SO_ABI_EXPECT
    if not _NATIVE_OK or _NLIB is None:
        return {"ok": False, "state": "not_loaded", "abi": None, "expect": exp}
    abi = None
    try:
        if hasattr(_NLIB, "cd_abi_version"):
            abi = int(_NLIB.cd_abi_version())
    except Exception:
        abi = None
    if abi is None:
        return {"ok": False, "state": "stale", "abi": None, "expect": exp}
    if abi != exp:
        return {"ok": False, "state": "abi_mismatch", "abi": abi, "expect": exp}
    return {"ok": True, "state": "ok", "abi": abi, "expect": exp}


def native_mem_snapshot(top=5):
    d = _direct_snapshot()
    if not _NATIVE_OK or _NLIB is None:
        if not d["live_by_pid"] and d["total"] == 0:
            return None
        _pairs_src = dict(d["live_by_pid"])
        if int(d["live_untagged"]) > 0: _pairs_src["⟨untagged⟩"] = int(d["live_untagged"])
        pairs = sorted(_pairs_src.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": 0, "untagged": 0, "dropped": 0, "dropped_bytes": -1, "live": 0,
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    try:
        n = len(_IDX_PID)
        arr = (ctypes.c_int64 * max(n, 1))()
        _NLIB.cd_snapshot(arr, n)
        combined = {}
        for i in range(n):
            pid = _resolve_idx(i) or f"idx{i}"
            combined[pid] = combined.get(pid, 0) + int(arr[i])
        for pid, b in d["live_by_pid"].items():
            combined[pid] = combined.get(pid, 0) + int(b)
        _unt = int(d["live_untagged"]) + int(_NLIB.cd_untagged())
        if _unt > 0: combined["⟨untagged⟩"] = combined.get("⟨untagged⟩", 0) + _unt
        pairs = sorted(combined.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": int(_NLIB.cd_total()), "untagged": int(_NLIB.cd_untagged()),
            "dropped": int(_NLIB.cd_dropped()), "dropped_bytes": (int(_NLIB.cd_dropped_bytes()) if hasattr(_NLIB,'cd_dropped_bytes') else -1), "live": int(_NLIB.cd_live_count()),
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    except Exception:
        return None

class _CrumbFile:
    NAME = "last_breadcrumb.txt"
    def __init__(self):
        self.path = None; self._lock = threading.Lock()
        try:
            d = File(_DIR)
            if not d.exists(): d.mkdirs()
            self.path = File(d, self.NAME).getAbsolutePath()
        except Exception as e:
            _log(f"crumb init err: {e}")
    def read_prev(self):
        try:
            if self.path and os.path.exists(self.path):
                with open(self.path, "r", encoding="utf-8") as f:
                    return f.read().strip()
        except Exception: pass
        return None
    def write(self, pid, where):
        if not self.path: return
        with self._lock:
            try:
                with open(self.path, "w", encoding="utf-8") as f:
                    f.write(f"{pid}\t{where}\t{int(time.time()*1000)}"); f.flush()
            except Exception: pass
_CRUMB = None

_B34_WAL_NAME = "load_wal.json"
_B34_PID_NAME = "boot_pid.json"
_B34_SEEN_NAME = "exitinfo_seen.json"
_B34_VERDICT_NAME = "exitinfo_verdict.json"
_B34_GRACE_MS = 20000
_B34_WAL_LOCK = threading.Lock()
_B34_WAL_TIMER = [None]
_B34_WAL_SEQ = [0]
_B34_WIN_LOADING_MS = 300000
_B34_WIN_LOADED_MS = 30000
_B34_WIN_SKEW_MS = 2000
_B34_EARLY_NAME = "early_deaths.json"
_B34_EARLY_MS = 60000
_B34_SELF_IDS = frozenset(("culprit_detector", "__regtest__"))
_B34_REASONS = {0: "UNKNOWN", 1: "EXIT_SELF", 2: "SIGNALED", 3: "LOW_MEMORY", 4: "CRASH(Java)", 5: "CRASH_NATIVE", 6: "ANR", 7: "INITIALIZATION_FAILURE", 8: "PERMISSION_CHANGE", 9: "EXCESSIVE_RESOURCE_USAGE", 10: "USER_REQUESTED", 11: "USER_STOPPED", 12: "DEPENDENCY_DIED", 13: "OTHER", 14: "FREEZER", 15: "PACKAGE_STATE_CHANGE", 16: "PACKAGE_UPDATED"}
_B34_SIGNALS = {4: "SIGILL", 5: "SIGTRAP", 6: "SIGABRT", 7: "SIGBUS", 8: "SIGFPE", 9: "SIGKILL", 11: "SIGSEGV", 15: "SIGTERM"}
_B34_BLAMELESS = {3, 8, 10, 11, 12, 14, 15, 16}
def _b34_path(name):
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, name).getAbsolutePath()
    except Exception:
        return None
def _b34_read_json(name):
    try:
        p = _b34_path(name)
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return json.load(f)
    except Exception: pass
    return None
def _b34_clear(name):
    try:
        p = _b34_path(name)
        if p and os.path.exists(p): os.remove(p)
    except Exception: pass
_B34_WAL_STACK = []
def _b34_wal_persist_locked():
    p = _b34_path(_B34_WAL_NAME)
    if not p: return
    try:
        if not _B34_WAL_STACK:
            if os.path.exists(p): os.remove(p)
            return
        tmp = "%s.tmp.%d" % (p, os.getpid())
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump({"seq": _B34_WAL_SEQ[0], "stack": list(_B34_WAL_STACK)}, f)
            f.flush(); os.fsync(f.fileno())
        os.replace(tmp, p)
    except Exception as e:
        _log("B34 wal write err: %s" % e)
def _b34_wal_push(pid):
    with _B34_WAL_LOCK:
        if _B34_WAL_STACK and _B34_WAL_STACK[-1].get("pid") == pid and _B34_WAL_STACK[-1].get("phase") == "loading":
            _B34_WAL_STACK[-1]["ts"] = int(time.time() * 1000)
            _b34_wal_persist_locked()
            return
        _B34_WAL_SEQ[0] += 1
        _B34_WAL_STACK.append({"pid": pid, "phase": "loading", "ts": int(time.time() * 1000)})
        _b34_wal_persist_locked()
def _b34_wal_mark_loaded(pid):
    with _B34_WAL_LOCK:
        _B34_WAL_SEQ[0] += 1
        for e in reversed(_B34_WAL_STACK):
            if e.get("pid") == pid and e.get("phase") == "loading":
                e["phase"] = "loaded"; e["ts"] = int(time.time() * 1000)
                break
        else:
            for e in reversed(_B34_WAL_STACK):
                if e.get("pid") == pid and e.get("phase") == "loaded":
                    e["ts"] = int(time.time() * 1000)
                    break
            else:
                _B34_WAL_STACK.append({"pid": pid, "phase": "loaded", "ts": int(time.time() * 1000)})
        _b34_wal_persist_locked()
    _b34_wal_schedule_sweep(None)
def _b34_wal_pop_fail(pid):
    with _B34_WAL_LOCK:
        _B34_WAL_SEQ[0] += 1
        for i in range(len(_B34_WAL_STACK) - 1, -1, -1):
            if _B34_WAL_STACK[i].get("pid") == pid:
                del _B34_WAL_STACK[i]
                break
        _b34_wal_persist_locked()
def _b34_wal_sweep():
    nxt = None
    with _B34_WAL_LOCK:
        now = int(time.time() * 1000)
        keep = []; changed = False
        for e in _B34_WAL_STACK:
            if e.get("phase") == "loaded":
                try: left = _B34_GRACE_MS - (now - int(e.get("ts", 0)))
                except Exception: left = 0
                if left <= 0:
                    changed = True
                    continue
                if nxt is None or left < nxt: nxt = left
            keep.append(e)
        if changed:
            _B34_WAL_SEQ[0] += 1
            del _B34_WAL_STACK[:]
            _B34_WAL_STACK.extend(keep)
            _b34_wal_persist_locked()
    if nxt is not None:
        _b34_wal_schedule_sweep(nxt)
def _b34_wal_schedule_sweep(delay_ms):
    try:
        t = _B34_WAL_TIMER[0]
        if t is not None:
            try: t.cancel()
            except Exception: pass
        d = (_B34_GRACE_MS if delay_ms is None else max(250, int(delay_ms))) / 1000.0
        t = threading.Timer(d, _b34_wal_sweep)
        t.daemon = True
        _B34_WAL_TIMER[0] = t
        t.start()
    except Exception as e:
        _log("B34 wal timer err: %s" % e)
def _b34_reason_str(code, status):
    r = _B34_REASONS.get(code, "reason=%s" % code)
    try:
        if code == 2:
            r += " (%s)" % _B34_SIGNALS.get(status, "sig=%s" % status)
        elif code == 1:
            r += " (exit=%s)" % status
    except Exception: pass
    return r
def _b34_early_note(ets, cands):
    streak = 1
    try:
        ed = _b34_read_json(_B34_EARLY_NAME) or {}
        old = ed.get("plugins") or []
        if int(ed.get("count", 0)) > 0 and (not old or not cands or set(old) == set(cands)):
            streak = int(ed.get("count", 0)) + 1
    except Exception: pass
    try: _atomic_json_write(_b34_path(_B34_EARLY_NAME), {"count": streak, "last_ts": int(ets), "plugins": list(cands or [])})
    except Exception: pass
    return streak
def _b34_boot_postmortem():
    wal = _b34_read_json(_B34_WAL_NAME)
    prev = _b34_read_json(_B34_PID_NAME)
    _b34_clear(_B34_WAL_NAME)
    cur_pid = int(os.getpid())
    same_process = False
    try:
        same_process = (prev is not None and int(prev.get("pid", -1)) == cur_pid)
    except Exception: pass
    prev_boot_ts = 0
    try:
        if prev is not None: prev_boot_ts = int(prev.get("ts", 0))
    except Exception: pass
    try:
        _atomic_json_write(_b34_path(_B34_PID_NAME), {"pid": cur_pid, "ts": int(time.time() * 1000)})
    except Exception as e:
        _log("B34 boot-pid write err: %s" % e)
    best = None; nrec = -1
    try:
        ctx = _app_context()
        sdk = 0
        try: sdk = int(getattr(jclass("android.os.Build$VERSION"), "SDK_INT", 0))
        except Exception: pass
        if ctx is None:
            _log("B34: контекст недоступен -- ExitInfo пропущен")
        elif sdk < 30:
            _log("B34: API %s < 30 -- ApplicationExitInfo недоступен" % sdk)
        else:
            am = ctx.getSystemService("activity")
            pkg = str(ctx.getPackageName())
            lst = am.getHistoricalProcessExitReasons(pkg, 0, 16)
            nrec = int(lst.size()) if lst is not None else 0
            seen = _b34_read_json(_B34_SEEN_NAME) or {}
            try: last_seen = int(seen.get("ts", 0))
            except Exception: last_seen = 0
            prev_pid = -1
            try:
                if prev is not None: prev_pid = int(prev.get("pid", -1))
            except Exception: pass
            for i in range(nrec):
                ei = lst.get(i)
                try:
                    if str(ei.getProcessName()) != pkg: continue
                    ts = int(ei.getTimestamp())
                    if ts <= last_seen: continue
                    if prev_pid > 0 and int(ei.getPid()) != prev_pid: continue
                    if best is None or ts > int(best.getTimestamp()): best = ei
                except Exception: pass
    except Exception as e:
        _log("B34 ExitInfo query err: %s" % e)
    if same_process and best is None:
        _log("B34: reload детектора в том же процессе (pid=%s) -- смерти не было%s" % (cur_pid, ", stale WAL снят" if wal is not None else ""))
        return
    culprit = None; phase = None; wal_ts = 0
    stack = None
    if isinstance(wal, dict):
        if isinstance(wal.get("stack"), list):
            stack = wal.get("stack")
        elif wal.get("pid"):
            stack = [wal]
    if stack:
        act = None; lastl = None
        for e in stack:
            try:
                if e.get("phase") == "loading": act = e
                if e.get("phase") == "loaded" and (lastl is None or int(e.get("ts", 0)) >= int(lastl.get("ts", 0))): lastl = e
            except Exception: pass
        pick = act if act is not None else lastl
        if pick is not None:
            try:
                culprit = str(pick.get("pid") or "") or None
                phase = str(pick.get("phase") or "?")
                wal_ts = int(pick.get("ts", 0))
            except Exception: pass
    if best is None and culprit is None:
        if nrec >= 0:
            _log("B34 ExitInfo: свежих записей о прошлой сессии нет (records=%s), WAL чист" % nrec)
        return
    v = {"src": "exitinfo/b34", "event_type": "process_exit_postmortem", "correlation_kind": "load_window", "process_scoped": True, "ts": int(time.time() * 1000), "detector_version": __version__}
    code = -1; status = 0; ets = None
    if best is not None:
        try:
            code = int(best.getReason()); status = int(best.getStatus())
            ets = int(best.getTimestamp())
            try: _atomic_json_write(_b34_path(_B34_SEEN_NAME), {"ts": ets})
            except Exception: pass
            rs = _b34_reason_str(code, status)
            desc = ""
            try: desc = str(best.getDescription() or "")
            except Exception: pass
            _log("=========== POST-MORTEM ПРОШЛОЙ СЕССИИ (Block#34, ExitInfo) ===========")
            _log("процесс (pid=%s) завершён: %s" % (int(best.getPid()), rs))
            if desc: _log("  описание системы: %s" % desc[:220])
            v["exit_reason"] = rs; v["exit_code"] = code; v["exit_status"] = status
            v["exit_ts"] = ets; v["exit_desc"] = desc[:220]
        except Exception as e:
            _log("B34 ExitInfo decode err: %s" % e)
    else:
        _log("=========== POST-MORTEM ПРОШЛОЙ СЕССИИ (Block#34, WAL) ===========")
        _log("причина смерти системой не сообщена (ExitInfo пуст/недоступен)")
        v["exit_reason"] = "unknown"
    life = None
    if ets is not None and prev_boot_ts > 0:
        life = max(0, int(ets) - prev_boot_ts)
        v["session_lifetime_ms"] = life
        _log("  прошлая сессия прожила ~%s мс" % life)
    blameless = (code in _B34_BLAMELESS)
    if best is not None and not blameless and life is not None and life >= _B34_EARLY_MS:
        try: _atomic_json_write(_b34_path(_B34_EARLY_NAME), {"count": 0})
        except Exception: pass
    if culprit is not None:
        v["load_window_plugin"] = culprit; v["load_window_phase"] = phase
        delta = None; in_window = True
        if ets is not None and wal_ts > 0:
            delta = int(ets) - int(wal_ts)
            v["wal_exit_delta_ms"] = delta
            win = _B34_WIN_LOADING_MS if phase == "loading" else _B34_WIN_LOADED_MS
            in_window = (-_B34_WIN_SKEW_MS <= delta <= win)
        if not in_window:
            v["wal_correlation"] = False; v["wal_rejected"] = "timestamp_out_of_window"
            v["culprit"] = "unknown"; v["confidence"] = "low"; v["attribution"] = False
            if blameless: v["culprit_kind"] = "system"
            _log("  WAL вне окна корреляции: %s (phase=%s, delta=%sms) -- плагин НЕ обвиняется" % (culprit, phase, delta))
        elif blameless:
            v["wal_correlation"] = True; v["attribution"] = False
            v["culprit"] = "system/user"; v["culprit_kind"] = "system"; v["confidence"] = "low"
            _log("  blameless-причина; окно загрузки: %s (phase=%s, delta=%sms) -- только контекст" % (culprit, phase, delta))
        else:
            v["wal_correlation"] = True
            if phase == "loading":
                v["attribution"] = True
                v["culprit"] = culprit
                v["confidence"] = "medium" if best is not None else "low"
                _log("  смерть во время загрузки плагина: %s (delta=%sms, conf=%s)" % (culprit, delta, v["confidence"]))
            else:
                streak = 0
                if best is not None and life is not None and life < _B34_EARLY_MS:
                    streak = _b34_early_note(ets, [culprit])
                    v["early_boot_death"] = True; v["early_death_streak"] = streak
                if streak >= 2:
                    v["correlation_kind"] = "early_boot_repeat"
                    v["attribution"] = True; v["culprit"] = culprit; v["confidence"] = "medium"
                    _log("  ПОВТОРЯЮЩАЯСЯ ранняя смерть после загрузки %s: %s-я подряд (delta=%sms) -> culprit, conf=medium" % (culprit, streak, delta))
                else:
                    v["attribution"] = False
                    v["culprit"] = "unknown"; v["confidence"] = "low"
                    _log("  смерть вскоре после успешной загрузки %s (delta=%sms) -- корреляция слабая, плагин только контекст%s" % (culprit, delta, "; при повторе будет атрибутирован" if streak == 1 else ""))
    else:
        v["culprit"] = "unknown"; v["confidence"] = "low"; v["attribution"] = False
        if blameless: v["culprit_kind"] = "system"
        if best is not None and not blameless and life is not None and life < _B34_EARLY_MS:
            cands = []
            try:
                cands = [p for p in (_load_known() or []) if isinstance(p, str) and p and p not in _B34_SELF_IDS]
            except Exception: pass
            streak = _b34_early_note(ets, cands)
            v["early_boot_death"] = True; v["early_death_streak"] = streak; v["boot_window_plugins"] = cands
            _log("  РАННЯЯ СМЕРТЬ СЕССИИ: прожила %s мс (подряд: %s)" % (life, streak))
            if len(cands) == 1:
                v["correlation_kind"] = "early_boot"; v["attribution"] = True
                v["culprit"] = cands[0]
                v["confidence"] = "medium" if streak >= 2 else "low"
                _log("  подозреваемый: %s (единственный известный сторонний плагин, conf=%s)" % (cands[0], v["confidence"]))
            elif cands:
                _log("  известные сторонние плагины (загрузка хуком не покрыта): %s" % ", ".join(cands))
    try: _atomic_json_write(_b34_path(_B34_VERDICT_NAME), v)
    except Exception as e:
        _log("B34 verdict write err: %s" % e)
    _log("=======================================================================")
def _known_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _KNOWN_FILE).getAbsolutePath()
    except Exception:
        return None
def _load_known():
    p = _known_path()
    try:
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return list(json.load(f))
    except Exception:
        pass
    return []
def _save_known(pid):
    try:
        cur = set(_load_known())
        if pid in cur: return
        cur.add(pid)
        p = _known_path()
        if not p: return
        _atomic_json_write(p, sorted(cur))
    except Exception:
        pass

def _known_union():
    out = set()
    try:
        out.update(_load_known() or [])
    except Exception:
        pass
    try:
        out.update([n for n in _IDX_PID if isinstance(n, str) and n])
    except Exception:
        pass
    try:
        p = _idxnames_path()
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                out.update([v for v in m.values() if isinstance(v, str) and v])
    except Exception:
        pass
    return list(out)


def _simple(class_str):
    s = class_str.replace("class ", "").strip()
    for sep in ("$", "."):
        if sep in s: s = s.split(sep)[-1]
    return s
def _tokens(s):
    return set(t for t in re.split(r"[^a-z0-9]+", (s or "").lower()) if len(t) >= 3)
def _is_hook_frame(f):
    if not f: return False
    for m in _HOOK_MARKERS:
        if m in f: return True
    return False
def _is_system_class(cls):
    if not cls: return True
    if "culprit" in cls.lower(): return True
    for p in _SYS_PREFIXES:
        if cls.startswith(p): return True
    return False
def _is_obfuscated(frame):
    parts = (frame or "").split(".")
    if len(parts) < 2: return True
    return all(len(p) <= 2 for p in parts[:-1])
def _short_method(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[-2:]) if len(parts) >= 2 else frame
def _squash(s):
    return re.sub(r"[^a-z0-9]+", "", (s or "").lower())
def _py_module_of(frame):
    if not frame or not frame.startswith(_PY_PREFIX): return None
    rest = frame[len(_PY_PREFIX):]
    if not rest: return None
    return rest.split(".", 1)[0]
def _is_py_runtime_frame(fr):
    if not fr or not fr.startswith(_PY_PREFIX): return False
    low = fr[len(_PY_PREFIX):].lower()
    return any(low == s or low.startswith(s) for s in _PY_SYS_MODS)
def _stack_culprit(frames):
    for fr in frames:
        if _is_system_class(fr): continue
        if _is_hook_frame(fr): continue
        if _is_py_runtime_frame(fr): continue
        if _is_obfuscated(fr): continue
        return fr
    return None
def _pkg_of(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[:3]) if len(parts) >= 3 else frame
def _map_stack_to_id(culprit_frame, known):
    if not culprit_frame or not known: return None
    mod = _py_module_of(culprit_frame)
    sq = _squash(mod) if mod else ""
    if sq:
        for pid in known:
            if _squash(pid) == sq: return pid
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and (ps in sq or sq in ps): return pid
    ct = _tokens(culprit_frame) - _GENERIC
    if not ct: return None
    best = None; best_score = 0; second = 0
    for pid in known:
        pt = _tokens(pid) - _GENERIC
        score = len(ct & pt)
        if score > best_score:
            second = best_score; best_score = score; best = pid
        elif score > second:
            second = score
    if best_score >= 1 and best_score > second:
        return best
    return None

_REENTRY = threading.local()
_FIRST_LOGGED = False
def _note_first(pid, where):
    global _FIRST_LOGGED
    if _FIRST_LOGGED: return
    _FIRST_LOGGED = True
    _log(f"first breadcrumb captured: pid={pid} where={where!r}")

def _crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CRASH_FILE_NAME).getAbsolutePath()
    except Exception:
        return None
_APP_PRIV_DIR = None
_AW_LOG_SEEN = {}
def _aw_mirror_path(path):
    try:
        pd = _app_priv_dir()
        if not pd: return None
        return os.path.join(pd, os.path.basename(path))
    except Exception:
        return None
def _aw_mirror_list():
    out = []
    try:
        pd = _app_priv_dir()
        if not pd: return out
        names = File(pd).list()
        if names:
            for nm in names:
                try:
                    if nm.endswith(".stage"): continue
                    if not (nm.endswith(".json") or nm.endswith(".txt") or _rc_is_quarantine_name(nm) or _rc_is_stale_processing(os.path.join(pd, nm), nm)): continue
                    out.append(File(pd, nm).getAbsolutePath())
                except Exception: pass
    except Exception: pass
    return out
def _aw_log_once(path, sig, msg):
    try:
        if _AW_LOG_SEEN.get(path) == sig:
            return
        _AW_LOG_SEEN[path] = sig
    except Exception:
        pass
    try: _log(msg)
    except Exception: pass
def _aw_log_clear(path):
    try:
        _AW_LOG_SEEN.pop(path, None)
    except Exception: pass
def _app_priv_dir():
    global _APP_PRIV_DIR
    try:
        if _APP_PRIV_DIR:
            return _APP_PRIV_DIR
    except Exception:
        pass
    d = None
    try:
        ctx = _app_context()
        if ctx is not None:
            base = None
            try: base = ctx.getCacheDir().getAbsolutePath()
            except Exception: base = None
            if not base:
                try: base = ctx.getFilesDir().getAbsolutePath()
                except Exception: base = None
            if base:
                jd = File(base, "culprit_tmp")
                try:
                    if not jd.exists(): jd.mkdirs()
                except Exception: pass
                if jd.exists() and jd.isDirectory():
                    d = jd.getAbsolutePath()
    except Exception:
        d = None
    if d:
        _APP_PRIV_DIR = d
    return d

_FALLBACK_IO_LOCK = threading.Lock()
def _atomic_same_dir_replace(path, text):
    sib = None
    try:
        d = os.path.dirname(path) or "."
        sib = os.path.join(d, os.path.basename(path) + ".fb." + str(os.getpid()) + "." + str(threading.get_ident()))
        with open(sib, "w", encoding="utf-8") as f:
            f.write(text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        os.replace(sib, path)
        return True
    except Exception:
        if sib:
            try: os.remove(sib)
            except Exception: pass
        return False

def _aw_target_is_precious(path):
    try:
        return os.path.exists(path) and os.path.getsize(path) > 0
    except Exception:
        return False


def _atomic_write_fallback(path, text):
    last_exc = None
    try:
        if _atomic_same_dir_replace(path, text):
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        if not _aw_target_is_precious(path):
            with open(path, "w", encoding="utf-8") as f3:
                f3.write(text); f3.flush()
                try: os.fsync(f3.fileno())
                except Exception: pass
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        mp = _aw_mirror_path(path)
        if mp:
            if _atomic_same_dir_replace(mp, text):
                return (True, "app_priv", None)
            if not _aw_target_is_precious(mp):
                with open(mp, "w", encoding="utf-8") as f4:
                    f4.write(text); f4.flush()
                    try: os.fsync(f4.fileno())
                    except Exception: pass
                return (True, "app_priv", None)
    except Exception as e:
        last_exc = e
    return (False, None, last_exc)

def _atomic_json_write_impl(path, data, max_len=None, dedup=False, max_items=None, max_bytes=None):
    if not path: return False
    _is_seq = isinstance(data, (list, tuple))
    if max_items is None and _is_seq and max_len is not None:
        max_items = max_len
    if max_bytes is None and (not _is_seq) and max_len is not None:
        max_bytes = max_len
    try:
        if max_items is not None and _is_seq:
            try:
                if len(data) > max_items: data = data[-max_items:]
            except Exception: pass
    except Exception: pass
    try:
        _text = json.dumps(data, ensure_ascii=False)
    except Exception as e0:
        try: _log("atomic write enc err (%s): %s: %s" % (path, type(e0).__name__, e0))
        except Exception: pass
        return False
    if max_bytes is not None and not _is_seq:
        try:
            if len(_text) > max_bytes:
                try: _log("atomic write oversize (%s): %d > %d bytes; skipped (max_bytes)" % (path, len(_text), max_bytes))
                except Exception: pass
                return False
        except Exception: pass
    _vh = None
    if dedup:
        try:
            _vh = hash(_text)
            if _VERDICT_DEDUP.get(path) == _vh:
                return True
        except Exception:
            _vh = None
    try:
        if _VERDICT_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_verdict_write"):
            _vb = _text.encode("utf-8")
            _ntmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
            _vrc = int(_NLIB.cd_verdict_write(
                ctypes.c_char_p(_ntmp.encode("utf-8")),
                ctypes.c_char_p(path.encode("utf-8")),
                ctypes.c_char_p(_vb), ctypes.c_int32(len(_vb))))
            if _vrc == 0:
                _aw_log_clear(path)
                if _vh is not None:
                    try: _VERDICT_DEDUP[path] = _vh
                    except Exception: pass
                return True
    except Exception:
        pass
    try:
        tmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(_text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        try:
            os.replace(tmp, path)
        except Exception:
            if _aw_target_is_precious(path):
                try: os.remove(tmp)
                except Exception: pass
                raise
            try:
                with _FALLBACK_IO_LOCK:
                    with open(path, "w", encoding="utf-8") as f2:
                        f2.write(_text); f2.flush()
                        try: os.fsync(f2.fileno())
                        except Exception: pass
            finally:
                try: os.remove(tmp)
                except Exception: pass
        _aw_log_clear(path)
        if _vh is not None:
            try: _VERDICT_DEDUP[path] = _vh
            except Exception: pass
        return True
    except Exception as e1:
        with _FALLBACK_IO_LOCK:
            ok, where, fe = _atomic_write_fallback(path, _text)
        if ok:
            if where == "app_priv":
                _aw_log_once(path, "app_priv", "atomic persist: %s -> app-private mirror (sdcard denied); included in share-logs" % path)
            else:
                _aw_log_clear(path)
            return True
        _aw_log_once(path, "fail", "atomic write err (%s): primary=%s fallback=%s: %s" % (path, type(e1).__name__, (type(fe).__name__ if fe is not None else "n/a"), fe))
        return False

_MOMENT_AUTOCAP_ON = True
_MOMENT_SEEN = {}
_MOMENT_INFLIGHT = set()
_MOMENT_LOCK = threading.Lock()
_MOMENT_SEEN_MAX = 512
_MOMENT_SESSION_MAX = 300
_MOMENT_SESSION_N = 0
_MOMENT_PRE_MS = 8000
_MOMENT_POST_MS = 8000
_MOMENT_MAX_LINES = 800
_MOMENT_MAX_CHARS = 60000
_MOMENT_FRESH_MS = 180000
_MOMENT_STALE_MS = 90000
_MOMENT_RATE_S = 45.0
_MOMENT_FAM_TS = {}
_MOMENT_SKIP = ("client_lowmem.json", "client_trim_unavailable.json", "client_lowmem_unavailable.json", "self_overhead.json")
_MOMENT_SRC_MAP = None

_MOMENT_INDEX_NAME = "culprit_moment_index.json"
_MOMENT_INDEX_MAX = 500
_MOMENT_FILES_MAX = 200
_MOMENT_FILES_BYTES = 25 * 1024 * 1024

def _moment_kind(base):
    try:
        b = base or ""
        if "*" in b:
            return b.split("*", 1)[0].rstrip("_")
        m = _moment_src_map()
        for k in m:
            if "*" in k:
                pre = k.split("*", 1)[0]
                if pre and b.startswith(pre):
                    return pre.rstrip("_")
        return b[:-5] if b.endswith(".json") else b
    except Exception:
        return base

def _moment_event_id(base, center_ms, culprit=None):
    try:
        _eid = "%s_%d" % (_moment_kind(base), int(center_ms))
        if culprit:
            try:
                _eid = "%s_%s" % (_eid, hashlib.sha1(str(culprit).encode("utf-8", "replace")).hexdigest()[:6])
            except Exception:
                pass
        return _eid
    except Exception:
        return "%s_%s" % (base, center_ms)

def _moment_event_prefix(base, center_ms):
    try:
        return "%s_%d" % (_moment_kind(base), int(center_ms))
    except Exception:
        return "%s_%s" % (base, center_ms)

def _moment_filename(base, center_ms, culprit=None):
    return "culprit_moment_%s.txt" % _moment_event_id(base, center_ms, culprit)

def _moment_index_path():
    try:
        return os.path.join(_DIR, _MOMENT_INDEX_NAME)
    except Exception:
        return None

def _moment_index_load():
    paths = []
    try: paths.append(_moment_index_path())
    except Exception: pass
    try: paths.append(_aw_mirror_path(_MOMENT_INDEX_NAME))
    except Exception: pass
    for p in paths:
        if not p:
            continue
        try:
            if os.path.exists(p):
                with open(p, "r", encoding="utf-8", errors="replace") as f:
                    d = json.load(f)
                if isinstance(d, dict):
                    return d
        except Exception:
            continue
    return {}

def _moment_index_upsert(event_id, entry):
    if not event_id:
        return
    try:
        with _MOMENT_LOCK:
            idx = _moment_index_load()
            e = dict(entry or {})
            e["event_id"] = event_id
            idx[event_id] = e
            if len(idx) > _MOMENT_INDEX_MAX:
                try:
                    keys = sorted(idx, key=lambda k: idx[k].get("created_ms", 0))
                    for k in keys[:len(idx) - _MOMENT_INDEX_MAX]:
                        idx.pop(k, None)
                except Exception:
                    pass
            p = _moment_index_path()
            if p:
                _atomic_json_write_impl(p, idx)
    except Exception:
        pass


def _moment_prune_files():
    try:
        import glob as _glob2
        dirs = []
        try: dirs.append(_DIR)
        except Exception: pass
        try:
            _md = _app_priv_dir()
            if _md: dirs.append(_md)
        except Exception: pass
        entries = []
        for d in dirs:
            if not d:
                continue
            try:
                for p in _glob2.glob(os.path.join(d, "culprit_moment_*.txt")):
                    try:
                        st = os.stat(p)
                        entries.append((st.st_mtime, st.st_size, p, os.path.basename(p)))
                    except Exception:
                        pass
            except Exception:
                pass
        if not entries:
            return
        entries.sort(key=lambda e: e[0])
        total = sum(e[1] for e in entries)
        n = len(entries)
        removed = set()
        i = 0
        while i < len(entries) and (n > _MOMENT_FILES_MAX or total > _MOMENT_FILES_BYTES):
            _mt, sz, p, bn = entries[i]
            try:
                os.remove(p)
                removed.add(bn)
                n -= 1
                total -= sz
            except Exception:
                pass
            i += 1
        if removed:
            try:
                with _MOMENT_LOCK:
                    idx = _moment_index_load()
                    ch = False
                    for k in list(idx.keys()):
                        try:
                            f = idx.get(k, {}).get("file")
                            if f and os.path.basename(f) in removed:
                                idx.pop(k, None); ch = True
                        except Exception:
                            pass
                    if ch:
                        _ip = _moment_index_path()
                        if _ip:
                            _atomic_json_write_impl(_ip, idx)
            except Exception:
                pass
    except Exception:
        pass

def _moment_find_existing_path(base, center_ms, culprit=None):

    cands = []
    prefix = None
    try:
        prefix = _moment_event_prefix(base, center_ms)
    except Exception:
        prefix = None
    if culprit:
        try:
            cands.append(_moment_filename(base, center_ms, culprit))
        except Exception:
            pass
    try:
        if prefix:
            idx = _moment_index_load()
            for k in sorted(idx, key=lambda x: idx.get(x, {}).get("created_ms", 0)):
                if k == prefix or k.startswith(prefix + "_"):
                    f = idx.get(k, {}).get("file")
                    if f:
                        cands.append(f)
    except Exception:
        pass
    try:
        if prefix:
            cands.append("culprit_moment_%s.txt" % prefix)
    except Exception:
        pass
    for fn in cands:
        if not fn:
            continue
        try:
            p1 = os.path.join(_DIR, fn)
            if os.path.exists(p1):
                return p1
        except Exception:
            pass
        try:
            mp = _aw_mirror_path(fn)
            if mp and os.path.exists(mp):
                return mp
        except Exception:
            pass
    return None


def _moment_src_map():
    global _MOMENT_SRC_MAP
    if _MOMENT_SRC_MAP is not None:
        return _MOMENT_SRC_MAP
    m = {}
    try:
        for src in _UI_VERDICT_SOURCES:
            try:
                fn, label, emoji, what, gate = src
                m[fn] = (label, emoji, what, gate)
            except Exception:
                pass
    except Exception:
        m = {}
    _MOMENT_SRC_MAP = m
    return m

def _moment_meta_for(base):
    m = _moment_src_map()
    if base in m:
        return m[base]
    for k, v in m.items():
        if "*" in k:
            pre = k.split("*", 1)[0]
            if pre and base.startswith(pre):
                return v
    return None

def _moment_center_ms(d):
    def _coerce(ts):
        try:
            if isinstance(ts, (int, float)):
                return int(ts if ts > 1e11 else ts * 1000.0)
            if isinstance(ts, str) and ts:
                import time as _t2
                if "-" in ts and ":" in ts:
                    return int(_t2.mktime(_t2.strptime(ts, "%Y-%m-%d %H:%M:%S")) * 1000.0)
                f = float(ts)
                return int(f if f > 1e11 else f * 1000.0)
        except Exception:
            return None
        return None
    _c = _coerce(d.get("event_ts"))
    if _c is not None:
        return _c
    _tb = d.get("tombstone_debuggerd")
    if isinstance(_tb, dict):
        _c = _coerce(_tb.get("event_ts") or _tb.get("logcat_ts"))
        if _c is not None:
            return _c
    for _src in ("crash_ts", "ts"):
        _c = _coerce(d.get(_src))
        if _c is not None:
            return _c
    return None

def _moment_culprit(d):
    try:
        c = (d.get("culprit") or d.get("crashed_plugin_id") or d.get("pid")
             or d.get("plugin") or d.get("py_module") or d.get("scoped_pid") or d.get("owner"))
        ck = d.get("culprit_kind")
        if not c and isinstance(ck, str):
            if ck.startswith("plugin:"):
                c = ck.split(":", 1)[1]
            elif ck == "host":
                c = d.get("host_so_owner") or "host"
        if not c:
            for _sub in ("verdict", "gref"):
                try:
                    _sv = d.get(_sub)
                    if isinstance(_sv, dict):
                        _cc = _sv.get("culprit") or _sv.get("owner")
                        if _cc:
                            c = _cc; break
                except Exception:
                    pass
        if not c:
            try:
                _ops = d.get("op_stamps")
                if isinstance(_ops, dict) and _ops:
                    _best = None
                    for _st in _ops.values():
                        if not isinstance(_st, dict): continue
                        _ow = _st.get("owner"); _ag = _st.get("age_ms")
                        if isinstance(_ow, str) and _ow.startswith("#") and _ow[1:].isdigit():
                            _nm = _resolve_idx(int(_ow[1:]))
                            if not (isinstance(_nm, str) and _nm):
                                _nm = _resolve_idx_durable(int(_ow[1:]))
                            _ow = _nm if (isinstance(_nm, str) and _nm) else ""
                        if not _ow or _ow == _SELF_ID or _ow == __id__: continue
                        if _ag is None or _ag < 0 or _ag > _GPU_OP_WINDOW_MS: continue
                        if _best is None or _ag < _best[0]: _best = (_ag, _ow)
                    if _best is not None: c = _best[1]
            except Exception:
                pass
        if not c:
            _ao = d.get("anr_owner")
            c = _ao if not isinstance(_ao, int) else (_ao if _ao >= 0 else None)
        if not c:
            try:
                _oi = int(d.get("owner_idx", -1))
                if _oi >= 0: c = _resolve_idx_durable(_oi)
            except Exception:
                pass
        try:
            if isinstance(c, bool):
                c = None
            elif isinstance(c, (int, float)) and int(c) < 0:
                c = None
            elif isinstance(c, str) and c.strip().lstrip("-").isdigit() and int(c.strip()) < 0:
                c = None
        except Exception:
            pass
        s = str(c).strip() if c else ""
        if "/" in s:
            s = s.rsplit("/", 1)[1]
        if s.endswith(".py"):
            s = s[:-3]
        if not s and d.get("hook_involved"):
            return "хук плагина (не определён)"
        return s or "не определён"
    except Exception:
        return "?"

def _moment_when(center_ms):
    try:
        return time.strftime("%d.%m %H:%M", time.localtime(center_ms / 1000.0))
    except Exception:
        return "-"

def _moment_is_tombstone_dump(lines, min_share=0.7):
    if not lines:
        return False
    _n = 0; _tot = 0
    for ln in lines:
        if not ln.strip():
            continue
        _tot += 1
        if (" F DEBUG " in ln) or (" F libc " in ln) or ("*** *** ***" in ln) or ("beginning of crash" in ln):
            _n += 1
    return _tot > 0 and (float(_n) / float(_tot)) >= min_share

def _moment_is_noise(ln):
    try:
        if "HWUI" in ln and "Image decoding logging dropped" in ln: return True
        if "Choreographer" in ln and "Skipped " in ln and "frames" in ln: return True
    except Exception:
        pass
    return False

def _moment_read_and_slice(center, pre_ms, post_ms, max_lines, max_chars):
    texts = []
    try:
        texts = _b28_read_logcat(prefilter=False)
    except Exception as e:
        try: _log("moment: logcat read err: %s" % e)
        except Exception: pass
    picked = []; total = 0; keep = False; _noise_supp = 0; matched_window = False
    _line_seen = 0; _ts_seen = 0; _newest_ts = None
    for blob in texts:
        for ln in blob.split("\n"):
            if ln.strip(): _line_seen += 1
            ets = _b28_logcat_event_ts(ln)
            if ets is not None:
                _ts_seen += 1
                if _newest_ts is None or ets > _newest_ts: _newest_ts = ets
                keep = (center is not None) and (-pre_ms <= (ets - center) <= post_ms)
            if keep:
                matched_window = True
                if _moment_is_noise(ln):
                    _noise_supp += 1; continue
                picked.append(ln); total += len(ln) + 1
                if len(picked) >= max_lines or total >= max_chars: break
        if len(picked) >= max_lines or total >= max_chars: break
    sealed = (_line_seen > 0 and _ts_seen == 0)
    stale = ((not picked) and _ts_seen > 0 and center is not None and _newest_ts is not None and (center - _newest_ts) > _MOMENT_STALE_MS)
    tail_mode = False
    _all_noise = False
    if not picked and matched_window:
        _all_noise = True
        picked = ["        … [+KP3] все строки окна были шумом HWUI/Choreographer: %d" % _noise_supp]
    if not picked:
        tail_mode = True
        allln = []
        for blob in texts:
            allln.extend(blob.split("\n"))
        picked = allln[-300:]
    if picked and not tail_mode and not _all_noise and _noise_supp > 0:
        picked.append("        … [+KP3] отфильтровано %d шумовых строк (HWUI/Choreographer) до лимита max_lines" % _noise_supp)
    return picked, tail_mode, sealed, stale

def _moment_atomic_text_write(target, body):
    _tmp = target + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
    try:
        with open(_tmp, "w", encoding="utf-8", errors="replace") as f:
            f.write(body)
        os.replace(_tmp, target)
        return True
    except Exception:
        try: os.remove(_tmp)
        except Exception: pass
    return False

def _moment_write_text(target, body):
    if _moment_atomic_text_write(target, body):
        return True
    try:
        mp = _aw_mirror_path(target)
        if mp and _moment_atomic_text_write(mp, body):
            return True
    except Exception:
        pass
    return False

def _breadcrumb_slice(center_ms, pre_ms, post_ms, max_lines=400):
    path = _LOG_PATH
    if not path:
        return []
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            _lines = f.read().splitlines()
    except Exception:
        return []
    try:
        _lt = time.localtime(center_ms / 1000.0)
        _midnight = center_ms - ((_lt.tm_hour * 3600 + _lt.tm_min * 60 + _lt.tm_sec) * 1000) - (center_ms % 1000)
    except Exception:
        return []
    out = []
    for ln in _lines:
        if len(ln) < 10 or ln[0] != "[" or ln[3] != ":" or ln[6] != ":" or ln[9] != "]":
            continue
        try:
            _hh = int(ln[1:3]); _mm = int(ln[4:6]); _ss = int(ln[7:9])
        except Exception:
            continue
        ets = _midnight + (_hh * 3600 + _mm * 60 + _ss) * 1000
        d = ets - center_ms
        if d > post_ms + 43200000:
            ets -= 86400000; d = ets - center_ms
        elif d < -(pre_ms + 43200000):
            ets += 86400000; d = ets - center_ms
        if -pre_ms <= d <= post_ms:
            out.append(ln)
            if len(out) >= max_lines:
                break
    return out


_HZ_FB_KEYS = ("event_type", "reason", "where", "confidence", "src", "culprit_kind", "stalled_ms", "trim_level", "throws_per_min", "throws_in_window", "exc_cls", "exc_msg", "cause", "top_so", "signo", "py_file", "py_line", "symbol")


def _hz_moment_fallback(rec):
    out = [_cd_tr("(logcat пуст — снимок из вердикта)")]
    if not isinstance(rec, dict):
        return out
    for _k in _HZ_FB_KEYS:
        _v = rec.get(_k)
        if _v is not None and _v != "" and _v != -1:
            out.append("%s=%s" % (_k, _v))
    _vd = rec.get("verdict")
    if isinstance(_vd, dict):
        for _k in ("culprit", "top_named", "culprit_bytes", "top_named_bytes"):
            _vv = _vd.get(_k)
            if _vv is not None and _vv != "":
                out.append("verdict.%s=%s" % (_k, _vv))
    _mem = rec.get("mem")
    if isinstance(_mem, dict) and _mem.get("pct") is not None:
        out.append("mem.pct=%s used=%s limit=%s" % (_mem.get("pct"), _mem.get("used"), _mem.get("limit")))
    _top = rec.get("top")
    if isinstance(_top, list) and _top:
        out.append("top_alloc:")
        for _e in _top[:6]:
            try:
                out.append("  %s=%s" % (_e[0], _e[1]))
            except Exception:
                out.append("  %s" % (_e,))
    _st = rec.get("stack")
    if isinstance(_st, list) and _st:
        out.append("stack:")
        for _s in _st[:12]:
            out.append("  %s" % (_s,))
    _ct = rec.get("cpu_top")
    if isinstance(_ct, list) and _ct:
        out.append("cpu_top:")
        for _t in _ct[:8]:
            try:
                out.append("  %s %.1f%% owner=%s" % (_t.get("name"), float(_t.get("pct") or 0), _t.get("owner")))
            except Exception:
                out.append("  %s" % (_t,))
    return out


_MOMENT_DEDUP_MIN_RUN = 3

def _moment_logline_key(ln):
    try:
        parts = ln.split(None, 5)
        if (len(parts) >= 6 and len(parts[0]) == 5 and parts[0][2] == "-"
                and ":" in parts[1] and parts[2].isdigit() and parts[3].isdigit()
                and len(parts[4]) == 1):
            return parts[4] + " " + parts[5]
    except Exception:
        pass
    return ln.strip()

def _moment_dedup_lines(lines, min_run=None):
    if min_run is None:
        min_run = _MOMENT_DEDUP_MIN_RUN
    out = []; removed = 0
    i = 0; n = len(lines)
    while i < n:
        key = _moment_logline_key(lines[i])
        j = i + 1
        while j < n and _moment_logline_key(lines[j]) == key:
            j += 1
        run = j - i
        if run >= min_run:
            out.append(lines[i])
            out.append("        … ×%d (dedup: %s)" % (run, key[:80]))
            removed += run - 2
        else:
            out.extend(lines[i:j])
        i = j
    return out, removed


def _moment_capture_worker(key, base, label, emoji, culprit, center, rec=None):
    global _MOMENT_SESSION_N
    _ok = False
    try:
        fn = _moment_filename(base, center, culprit)
        target = os.path.join(_DIR, fn)
        event_id = _moment_event_id(base, center, culprit)
        if os.path.exists(target):
            _moment_index_upsert(event_id, {"file": fn, "source": base, "culprit": culprit, "label": label, "center_ms": int(center), "created_ms": int(time.time() * 1000)})
            _ok = True
            return
        picked, tail, _iw_sealed, _iy_stale = _moment_read_and_slice(center, _MOMENT_PRE_MS, _MOMENT_POST_MS,
                                              _MOMENT_MAX_LINES, _MOMENT_MAX_CHARS)
        _kz_retry = False
        if _iy_stale:
            try:
                time.sleep(0.35)
                _p2, _t2, _s2, _st2 = _moment_read_and_slice(center, _MOMENT_PRE_MS, _MOMENT_POST_MS,
                                                             _MOMENT_MAX_LINES, _MOMENT_MAX_CHARS)
                if not _st2:
                    picked, tail, _iw_sealed, _iy_stale = _p2, _t2, _s2, _st2
                    _kz_retry = True
            except Exception:
                pass
        head = ["Culprit Detector — %s" % _cd_tr("логи момента"),
                "%s %s" % (emoji or "", _cd_tr(label) or "-"),
                _cd_tr("Виноват: %s") % culprit,
                _cd_tr("Когда: %s") % _moment_when(center),
                "crash_ts=%d  window=-%dms/+%dms" % (center, _MOMENT_PRE_MS, _MOMENT_POST_MS),
                "event_id=%s  source=%s" % (event_id, base)]
        _hz_empty = not picked
        _iy_tomb = (tail and (not _hz_empty) and _moment_is_tombstone_dump(picked))
        _use_fb = _hz_empty or _iw_sealed or _iy_stale or _iy_tomb
        try:
            _MOMENT_FAM_TS[(base, culprit)] = (time.time(), bool(_use_fb))
        except Exception:
            pass
        if tail and not _use_fb:
            head.append(_cd_tr("(точное время не найдено — показан хвост logcat)"))
        head.append("[+HV auto-capture @ confirm]")
        if _hz_empty:
            head.append("[+HZ] logcat ring empty (lines=0) - verdict fallback")
        if _iw_sealed:
            head.append("[+IW] logcat sealed by host ((HKS)..(HKE), no threadtime) - verdict+breadcrumb fallback")
        if _iy_stale:
            head.append("[+IY] logcat stale (newest ts older than window) - verdict+breadcrumb fallback")
        if _kz_retry:
            head.append("[+KZ(3)] logcat was stale -> live re-read OK")
        if _iy_tomb:
            head.append("[+IY] logcat tail is tombstone/crash-buffer dump - verdict+breadcrumb fallback")
        _dd_lines = picked; _dd_removed = 0
        if picked and not _use_fb:
            try:
                _dd_lines, _dd_removed = _moment_dedup_lines(picked)
            except Exception:
                _dd_lines = picked; _dd_removed = 0
            if _dd_removed > 0:
                head.append("[+IX] dedup: свёрнуто %d повторяющихся строк (анти-спам)" % _dd_removed)
        head.append("=" * 60)
        _hz_body_lines = _hz_moment_fallback(rec) if _use_fb else _dd_lines
        if _use_fb:
            _iw_bc = _breadcrumb_slice(center, _MOMENT_PRE_MS, _MOMENT_POST_MS)
            if _iw_bc:
                _hz_body_lines = list(_hz_body_lines) + ["", "breadcrumb (+/-window):"] + _iw_bc
        if base in ("native_crash_verdict.json", "native_crash_history.json") and isinstance(rec, dict):
            _hz_body_lines = list(_hz_body_lines) + _native_crash_moment_evidence(rec)
        body = "\n".join(head) + "\n" + "\n".join(_hz_body_lines)
        if _moment_write_text(target, body):
            _ok = True
            _moment_index_upsert(event_id, {"file": fn, "source": base, "culprit": culprit, "label": label, "center_ms": int(center), "created_ms": int(time.time() * 1000), "lines": len(picked), "tail": bool(tail), "empty": bool(_hz_empty), "fallback": bool(_use_fb), "sealed": bool(_iw_sealed)})
            try: _moment_prune_files()
            except Exception: pass
            try: _log("+HV: auto-moment -> %s (lines=%d%s)" % (fn, len(picked), ", tail" if tail else ""))
            except Exception: pass
    except Exception as e:
        try: _log("+HV moment worker err: %s" % e)
        except Exception: pass
    finally:
        with _MOMENT_LOCK:
            _MOMENT_INFLIGHT.discard(key)
            if _ok:
                try:
                    _MOMENT_SEEN[key] = time.time()
                    if len(_MOMENT_SEEN) > _MOMENT_SEEN_MAX:
                        for _k in sorted(_MOMENT_SEEN, key=lambda x: _MOMENT_SEEN[x])[:len(_MOMENT_SEEN) - _MOMENT_SEEN_MAX]:
                            _MOMENT_SEEN.pop(_k, None)
                except Exception:
                    pass
            else:
                try:
                    if _MOMENT_SESSION_N > 0: _MOMENT_SESSION_N -= 1
                except Exception:
                    pass

def _moment_autocap(path, data):
    global _MOMENT_SESSION_N
    if not _MOMENT_AUTOCAP_ON:
        return
    try:
        base = os.path.basename(path or "")
        if not base or not base.endswith(".json"):
            return
        if base in _MOMENT_SKIP:
            return
        meta = _moment_meta_for(base)
        if not meta:
            return
        label, emoji, _, gate = meta
        now_ms = time.time() * 1000.0
        items = data if isinstance(data, list) else [data]
        for it in items:
            try:
                if not isinstance(it, dict):
                    continue
                if bool(it.get("benign_restart")):
                    continue
                if bool(it.get("repeat_suppressed")) and not bool(it.get("repeat_sample")):
                    continue
                if gate and not any(bool(it.get(g)) for g in gate):
                    continue
                ck = it.get("culprit_kind")
                is_native = base in ("native_crash_verdict.json", "native_crash_history.json")
                if isinstance(ck, str) and ck == "system" and not is_native:
                    continue
                center = _moment_center_ms(it)
                if not center:
                    continue
                if center > now_ms + 5000.0 or (now_ms - center) > _MOMENT_FRESH_MS:
                    continue
                culprit = _moment_culprit(it)
                key = _moment_event_id(base, center, culprit)
                try:
                    _ft, _ffb = _MOMENT_FAM_TS.get((base, culprit), (0.0, False))
                    if _ffb and (time.time() - _ft) < _MOMENT_RATE_S and base not in ("native_crash_verdict.json", "native_crash_history.json"):
                        continue
                except Exception:
                    pass
                with _MOMENT_LOCK:
                    if key in _MOMENT_SEEN or key in _MOMENT_INFLIGHT:
                        continue
                    if _MOMENT_SESSION_N >= _MOMENT_SESSION_MAX:
                        continue
                    _MOMENT_INFLIGHT.add(key)
                    _MOMENT_SESSION_N += 1
                try:
                    threading.Thread(target=_moment_capture_worker,
                                     args=(key, base, label, emoji, culprit, center, it),
                                     name="culprit-moment", daemon=True).start()
                except Exception:
                    with _MOMENT_LOCK:
                        _MOMENT_INFLIGHT.discard(key)
            except Exception:
                continue
    except Exception:
        pass

def _extras_real_path(p):
    try:
        if os.path.exists(p):
            return p
    except Exception:
        pass
    try:
        mp = _aw_mirror_path(p)
        if mp and os.path.exists(mp):
            return mp
    except Exception:
        pass
    return None

def _send_logs_extras(names):

    out = []
    _errs = []
    try: _aw_cleanup_stale_tmp()
    except Exception: pass
    try:
        texts = []
        try:
            texts = _b28_read_logcat(prefilter=False)
        except Exception as e:
            _errs.append("logcat_read: %s" % e)
        allln = []
        for blob in (texts or []):
            allln.extend(blob.split("\n"))
        tail = allln[-1200:]
        body = ("Culprit Detector send-logs current logcat\ncaptured=%s\nlines=%d\n%s\n" %
                (time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()), len(tail), "=" * 60)) + "\n".join(tail)
        _p = os.path.join(_DIR, "send_logs_current_logcat.txt")
        if _moment_write_text(_p, body):
            _rp = _extras_real_path(_p)
            if _rp:
                out.append(_rp)
    except Exception as e:
        _errs.append("current_logcat: %s" % e)
    try:
        nm2 = list(names or [])
        nm2.append("send_logs_current_logcat.txt")
        nm2.append("archive_manifest.json")
        seen = set(); nmu = []
        for x in nm2:
            if _aw_atomic_tmp_parse(x) is not None:
                continue
            if x not in seen:
                seen.add(x); nmu.append(x)
        moment = [x for x in nmu if x.startswith("culprit_moment_") and x.endswith(".txt")]
        _man_verdict_exact = ("client_leak.json", "client_lowmem.json", "client_oom_killed.json",
                              "client_trim_unavailable.json", "client_lowmem_unavailable.json",
                              "hook_exception_flood.json", "native_crash_history.json")
        verdict = [x for x in nmu if x.endswith(".json") and ("verdict" in x
                   or x.startswith(("oom_dump", "b23_bitmap_oom")) or x in _man_verdict_exact)]
        native = {
            "abi_expect": _SO_ABI_EXPECT,
            "native_ok": bool(_NATIVE_OK),
            "oom": bool(_OOM_NATIVE_OK), "anr": bool(_ANR_NATIVE_OK),
            "gref": bool(_GREF_NATIVE_OK), "smaps": bool(_SMAPS_NATIVE_OK),
        }
        man = {
            "detector_version": __version__,
            "archived_at": time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()),
            "archived_ms": int(time.time() * 1000),
            "file_count": len(nmu),
            "verdict_file_count": len(verdict),
            "moment_snapshot_count": len(moment),
            "files": sorted(nmu),
            "moment_snapshots": sorted(moment),
            "native_lib": native,
            "errors": _errs,
        }
        _pm = os.path.join(_DIR, "archive_manifest.json")
        if _moment_write_text(_pm, json.dumps(man, ensure_ascii=False, indent=2)):
            _rpm = _extras_real_path(_pm)
            if _rpm:
                out.append(_rpm)
    except Exception as e:
        try: _log("send_logs: manifest err: %s" % e)
        except Exception: pass
    return out

_AW_TMP_MARKERS = (".tmp.", ".fb.")

def _aw_atomic_tmp_parse(name):
    try:
        for _mk in _AW_TMP_MARKERS:
            if _mk not in name:
                continue
            _tail = name.rsplit(_mk, 1)[1]
            _pp = _tail.split(".")
            if len(_pp) == 2 and _pp[0].isdigit() and _pp[1].isdigit():
                return (_mk, int(_pp[0]), int(_pp[1]))
    except Exception:
        pass
    return None

def _aw_cleanup_stale_tmp(max_age_s=600, dead_age_s=5, own_age_s=None):
    removed = 0
    try:
        _mypid = int(os.getpid()); _now = time.time()
        _dirs = []
        try:
            _d0 = globals().get("_DIR")
            if _d0: _dirs.append(_d0)
        except Exception: pass
        try:
            _md = _app_priv_dir()
            if _md and _md not in _dirs: _dirs.append(_md)
        except Exception: pass
        for _dd in _dirs:
            try: _names = os.listdir(_dd)
            except Exception: continue
            for _tnm in _names:
                try:
                    _pt = _aw_atomic_tmp_parse(_tnm)
                    if _pt is None: continue
                    _fp = os.path.join(_dd, _tnm)
                    if not os.path.isfile(_fp): continue
                    try: _age = _now - os.path.getmtime(_fp)
                    except Exception: continue
                    _tpid = _pt[1]
                    if _tpid == _mypid:
                        _stale = _age > (max_age_s if own_age_s is None else own_age_s)
                    else:
                        _alive = False
                        try: _alive = os.path.exists("/proc/%d" % _tpid)
                        except Exception: _alive = False
                        _stale = (_age > max_age_s) if _alive else (_age > dead_age_s)
                    if _stale:
                        os.remove(_fp); removed += 1
                except Exception: continue
        if removed:
            try: _log("+ML: удалены осиротевшие атомарные tmp/fb-файлы: %d" % removed)
            except Exception: pass
    except Exception: pass
    return removed


def _atomic_json_write(path, data, max_len=None, dedup=False):

    try:
        if isinstance(data, dict):
            if data.get("event_type") and "detector_version" not in data:
                data = dict(data)
                data["detector_version"] = __version__
        elif isinstance(data, (list, tuple)):
            _chg = False; _cp = []
            for _it in data:
                if isinstance(_it, dict) and _it.get("event_type") and "detector_version" not in _it:
                    _it = dict(_it); _it["detector_version"] = __version__; _chg = True
                _cp.append(_it)
            if _chg:
                data = _cp
    except Exception:
        pass
    _ok = _atomic_json_write_impl(path, data, max_len, dedup)
    if _ok:
        try: _moment_autocap(path, data)
        except Exception: pass
    return _ok


def _write_crash_verdict(rec):
    p = _crash_path()
    if not p: return False
    try:
        rec.setdefault("event_type", "app_crash"); rec.setdefault("dropbox_tag", "data_app_crash")
        rec.setdefault("tombstone_norm_version", 1); rec.setdefault("persisted", False)
    except Exception: pass
    try:
        if _is_safemode_collateral(rec.get("exc_cls"), rec.get("exc_msg")):
            _victim = rec.get("crashed_plugin_id")
            rec["safe_mode_collateral"] = True
            rec["safemode_victim"] = _victim
            _corr = rec.get("correlated") or {}
            _root = _corr.get("culprit")
            if _root and _root != _victim and _corr.get("confidence") in ("high", "medium"):
                rec["crashed_plugin_id"] = _root
                rec["src"] = "safe-mode-collateral->corr-root"
                rec["confidence"] = _corr.get("confidence")
            else:
                rec["crashed_plugin_id"] = "safe-mode-collateral"
                rec["src"] = "safe-mode-collateral"
                rec["confidence"] = "none"
            rec["culprit_kind"] = "collateral"
            rec["reason"] = _SAFEMODE_COLLATERAL_REASON
    except Exception: pass
    try:
        _cx = rec.get("crashed_plugin_id") or rec.get("culprit")
        if _cx and _cx not in ("safe-mode-collateral", "unknown", "none"):
            _b10_passive_mark_recent_owner_force(_cx, rec.get("ts"), "native_crash_owner")
    except Exception: pass
    try:
        return bool(_atomic_json_write(p, rec))
    except Exception:
        return False

_LOAD_FILE_NAME = "load_verdict.json"
_LOAD_FAILS_MAX = 20
_LOAD_DEDUP_MS = 4000
_LOAD_SEEN = {}; _LOAD_SEEN_LOCK = threading.Lock()
_PY_PREFIX = "<python>."
_PY_SYS_MODS = ("importlib", "java.chaquopy", "java.", "chaquopy_java",
                "_sdk_version", "encodings.", "<frozen", "base_plugin")

def _load_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LOAD_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _thr_chain(thr):
    out = []; n = 0; cur = thr
    while cur is not None and n < 12:
        n += 1
        try: cls = cur.getClass().getName()
        except Exception: cls = "?"
        try: msg = cur.getMessage()
        except Exception: msg = None
        out.append((cls, msg, cur))
        try: nxt = cur.getCause()
        except Exception: nxt = None
        if nxt is cur: break
        cur = nxt
    return out

def _py_module_from_throwable(chain):
    for (_c, _m, exc) in chain:
        try: st = exc.getStackTrace()
        except Exception: st = None
        if st is None: continue
        for el in st:
            try:
                cn = el.getClassName() or ""
                mn = el.getMethodName() or ""
                fn = el.getFileName() or ""
                ln = el.getLineNumber()
            except Exception:
                continue
            if not cn.startswith(_PY_PREFIX): continue
            if mn != "<module>": continue
            mod = cn[len(_PY_PREFIX):]
            low = mod.lower()
            if any(low == s or low.startswith(s) for s in _PY_SYS_MODS): continue
            return mod, (fn or (mod + ".py")), (int(ln) if ln is not None else -1)
    return None, None, -1

def _load_reason(chain):
    for (cls, msg, _e) in reversed(chain):
        if msg:
            scls = cls.rsplit(".", 1)[-1] if cls else "?"
            return ("%s: %s" % (scls, msg)) if (scls and scls not in (msg or "")) else msg
    for (cls, _m, _e) in reversed(chain):
        if cls and cls != "?":
            return cls.rsplit(".", 1)[-1]
    return "unknown"

_MEM_PRESSURE_REASON = "🧠 Python MemoryError — процесс исчерпал память (Python-куча); стек мог не сформироваться"
def _is_py_memoryerror(exc_cls, exc_msg):
    try:
        ec = str(exc_cls or ""); em = str(exc_msg or "")
        return ("MemoryError" in ec) or ("MemoryError" in em)
    except Exception:
        return False


_SAFEMODE_COLLATERAL_REASON = "safe-mode collateral — плагин заблокирован SafeModeImporter (жертва, не причина); корень — плагин, вызвавший safe-mode"
def _is_safemode_collateral(exc_cls, exc_msg):
    try:
        ec = str(exc_cls or ""); em = str(exc_msg or "")
        return ("Safe mode enabled" in em) or ("Safe mode enabled" in ec) or ("SafeModeImporter" in em)
    except Exception:
        return False


def _record_load_fail(scoped_pid, thr, where):
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if where == "loadPlugin" and scoped_pid:
        culprit = scoped_pid; src = "scope/loadPlugin"; conf = "high" if py_mod else "medium"
    elif py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped_pid:
        culprit = scoped_pid; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_load_fail": True, "event_type": "plugin_load_exception", "dropbox_tag": "plugin_load_blocked", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped_pid, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    if _is_py_memoryerror(top_cls, top_msg) or ("MemoryError" in (reason or "")):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON; reason = rec["reason"]
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _LOAD_SEEN_LOCK:
        if now - _LOAD_SEEN.get(key, 0) < _LOAD_DEDUP_MS: return
        _LOAD_SEEN[key] = now
    try: _load_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_load_fail(rec)
    except Exception: pass

_PERSIST_IO_LOCK = __import__("threading").Lock()


def _persist_load_fail(rec):
    p = _load_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LOAD_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

_RC_PROC_START = time.time()

def _rc_rearm_orphan(base):
    if not base: return
    proc = base + ".processing"
    try:
        if os.path.exists(base): return
        _rt = None; _rm = None
        for _sfx in (".retry", ".retry.2", ".retry.3"):
            _c = base + _sfx
            try:
                if os.path.exists(_c):
                    _m = os.path.getmtime(_c)
                    if _rm is None or _m < _rm: _rm = _m; _rt = _c
            except Exception: pass
        if _rt is not None:
            _pc = _rc_publish_noreplace3(_rt, base)
            if _pc == -1 and not globals().get("_RC_NOREP_WARN"):
                globals()["_RC_NOREP_WARN"] = True
                try: _log("+MU: retry publish отложен - нет атомарного no-replace (os.link/renameat2), источник сохранён: %s" % _rt)
                except Exception: pass
            return
        if not os.path.exists(proc): return
        if os.path.getmtime(proc) >= _RC_PROC_START: return
        _ppc = _rc_publish_noreplace3(proc, base)
        if _ppc == -1:
            if not globals().get("_RC_PROC_NOREP_WARN"):
                globals()["_RC_PROC_NOREP_WARN"] = True
                try: _log("+MV: .processing publish отложен - нет атомарного no-replace (os.link/renameat2), источник сохранён: %s" % proc)
                except Exception: pass
    except Exception:
        pass

def _rc_read_path(p):
    try:
        mp = _aw_mirror_path(p) if p else None
    except Exception:
        mp = None
    _rc_rearm_orphan(p)
    if mp: _rc_rearm_orphan(mp)
    try: pe = bool(p) and os.path.exists(p)
    except Exception: pe = False
    try: me = bool(mp) and os.path.exists(mp)
    except Exception: me = False
    if pe and me:
        try:
            if os.path.getmtime(mp) > os.path.getmtime(p): return mp
        except Exception: pass
        return p
    if pe: return p
    if me: return mp
    return None

def _rc_remove_both(p):
    if not p: return
    try: mp = _aw_mirror_path(p)
    except Exception: mp = None
    for _fp in (p, mp):
        try:
            if _fp and os.path.exists(_fp): os.remove(_fp)
        except Exception: pass

def _rc_take_path(p):
    if not p: return None
    _PERSIST_IO_LOCK.acquire()
    try:
        rp = _rc_read_path(p)
        if not rp: return None
        try: mp = _aw_mirror_path(p)
        except Exception: mp = None
        try: _claim_m = os.path.getmtime(rp)
        except Exception: _claim_m = None
        tmp = rp + ".processing"
        try:
            if os.path.exists(tmp) and _rc_park_pending(rp, tmp) is None:
                return None
        except Exception:
            return None
        try:
            os.rename(rp, tmp); claimed = tmp
        except Exception:
            return None
        _other = p if rp != p else mp
        if _other and _other != rp:
            try:
                if os.path.exists(_other) and (_claim_m is None or os.path.getmtime(_other) <= _claim_m):
                    os.remove(_other)
            except Exception: pass
        return claimed
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _rc_expect_list(raw):
    if not isinstance(raw, list):
        raise ValueError("verdict: expected list, got %s" % type(raw).__name__)
    for _i, _it in enumerate(raw):
        if not isinstance(_it, dict):
            raise ValueError("verdict: item %d expected object, got %s" % (_i, type(_it).__name__))
    return list(raw)

def _rc_expect_dict(raw):
    if not isinstance(raw, dict):
        raise ValueError("verdict: expected object, got %s" % type(raw).__name__)
    return raw

def _rc_is_quarantine_name(nm):
    try:
        return nm.endswith((".corrupted.1", ".corrupted.2", ".corrupted.3", ".retry", ".retry.2", ".retry.3"))
    except Exception:
        return False

def _rc_is_stale_processing(path, nm):
    try:
        if not nm.endswith(".processing"): return False
        return (time.time() - os.path.getmtime(path)) >= 60.0
    except Exception:
        return False

def _rc_native_noreplace(src, dst):
    try:
        if globals().get("_ABI_FAIL"): return -1
        _nl = globals().get("_NLIB", None)
        if _nl is None or not hasattr(_nl, "cd_rename_noreplace"): return -1
        _rc = int(_nl.cd_rename_noreplace(os.fsencode(src), os.fsencode(dst)))
        if _rc == 0: return 1
        if _rc == -17: return 0
        return -1
    except Exception:
        return -1

def _rc_publish_noreplace3(src, dst):
    try:
        os.link(src, dst)
    except FileExistsError:
        return 0
    except Exception:
        return _rc_native_noreplace(src, dst)
    try:
        os.unlink(src)
        return 1
    except Exception:
        try: os.unlink(dst)
        except Exception: pass
        return -1

def _rc_publish_noreplace(src, dst):
    return _rc_publish_noreplace3(src, dst) == 1

def _rc_park_pending(base, src):
    for _sfx in (".retry", ".retry.2", ".retry.3"):
        _dst = base + _sfx
        try:
            _pc = _rc_publish_noreplace3(src, _dst)
            if _pc == 1: return _dst
            if _pc == 0: continue
            return None
        except Exception:
            return None
    return None

def _rc_clear_taken(_rp, ok, err=None):
    if not _rp: return
    try:
        if (not ok) and os.path.isfile(_rp) and os.path.getsize(_rp) > 0:
            _base = _rp[:-11] if _rp.endswith(".processing") else _rp
            if isinstance(err, (OSError, MemoryError)):
                _dst = None
                try:
                    if _rc_publish_noreplace(_rp, _base):
                        _dst = _base
                    else:
                        _dst = _rc_park_pending(_base, _rp)
                except Exception: _dst = None
                try:
                    if _dst:
                        _log("+MR: временная ошибка чтения (%s) - вердикт возвращён для повтора: %s" % (type(err).__name__, _dst))
                    else:
                        _log("+MS: не удалось вернуть вердикт для повтора (%s) - источник сохранён: %s" % (type(err).__name__, _rp))
                except Exception: pass
                return
            _q1 = _base + ".corrupted.1"
            _q2 = _base + ".corrupted.2"; _q3 = _base + ".corrupted.3"
            try:
                if os.path.exists(_q2): os.replace(_q2, _q3)
            except Exception: pass
            try:
                if os.path.exists(_q1): os.replace(_q1, _q2)
            except Exception: pass
            try:
                os.replace(_rp, _q1)
            except Exception:
                try: _log("+MS: карантин не удался - источник сохранён: %s" % _rp)
                except Exception: pass
            else:
                try: _log("+MQ: повреждённый verdict-файл отправлен в карантин: %s" % _q1)
                except Exception: pass
            return
    except Exception: pass
    try: os.remove(_rp)
    except Exception: pass

def _read_and_clear_load_fails():
    p = _load_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = _rc_expect_list(json.load(f))
    except Exception as _mr_e:
        out = None
        if _rp:
            _rc_clear_taken(_rp, False, _mr_e)
            _rp = None
    if _rp:
        _rc_clear_taken(_rp, out is not None)
    if out is None: out = []
    return out

def _load_verdict_log(rec, when):
    try:
        _log("============= LOAD/IMPORT VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ЗАГРУЗКИ: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ЗАГРУЗКИ: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(loadPlugin-арг): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("====================================================")
    except Exception: pass
_HOOK_FILE_NAME = "hook_verdict.json"
_HOOK_FAILS_MAX = 20
_HOOK_DEDUP_MS = 4000
_HOOK_SEEN = {}; _HOOK_SEEN_LOCK = threading.Lock()
_BLOCK9_ON = True

def _hook_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _HOOK_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _hook_scope_pid():
    try:
        c = get_culprit_for_tid(_cur_tid())
        if c and c != "unknown": return c
    except Exception: pass
    return None

def _record_hook_fail(thr, where="executeHook", scoped=None):
    if not _BLOCK9_ON: return
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    if not chain: return
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if scoped is None: scoped = _hook_scope_pid()
    if py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped:
        culprit = scoped; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_hook_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _HOOK_SEEN_LOCK:
        if now - _HOOK_SEEN.get(key, 0) < _HOOK_DEDUP_MS: return
        _HOOK_SEEN[key] = now
    try: _hook_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_hook_fail(rec)
    except Exception: pass

def _persist_hook_fail(rec):
    p = _hook_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        try:
            rec.setdefault("event_type", "hook_exception"); rec.setdefault("dropbox_tag", "data_app_crash"); rec.setdefault("tombstone_norm_version", 1)
        except Exception: pass
        cur.append(rec)
        _atomic_json_write(p, cur, _HOOK_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_hook_fails():
    p = _hook_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = _rc_expect_list(json.load(f))
    except Exception as _mr_e:
        out = None
        if _rp:
            _rc_clear_taken(_rp, False, _mr_e)
            _rp = None
    if _rp:
        _rc_clear_taken(_rp, out is not None)
    if out is None: out = []
    return out

def _hook_verdict_log(rec, when):
    try:
        _log("============= RUNTIME HOOK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ХУКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ХУКА: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(tid): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("====================================================")
    except Exception: pass
_GATE_FILE_NAME = "gate_verdict.json"
_GATE_FAILS_MAX = 20
_GATE_DEDUP_MS = 60000
_GATE_SEEN = {}; _GATE_SEEN_LOCK = threading.Lock()
_BLOCK11_ON = True
_B11_TIMERS = []
_PC_CLASS = "com.exteragram.messenger.plugins.PluginsController"
_PPE_CLASS = "com.exteragram.messenger.plugins.PythonPluginsEngine"
_XCFG_CLASS = "com.exteragram.messenger.ExteraConfig"

def _b11_jc(name):
    try:
        return jclass(name)
    except BaseException:
        pass
    try:
        return find_class(name)
    except BaseException:
        return None

def _b11_attr(obj, *names):
    for n in names:
        try:
            v = getattr(obj, n)
        except Exception:
            continue
        try:
            return v() if callable(v) else v
        except Exception:
            continue
    return None

def _gate_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GATE_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b11_controller():
    jc = _b11_jc(_PC_CLASS)
    if jc is None: return None
    return _b11_attr(jc, "INSTANCE")

def _b11_runtime_sdk():
    jc = _b11_jc(_PPE_CLASS)
    if jc is None: return None
    v = _b11_attr(jc, "getSDK_VERSION", "SDK_VERSION")
    return str(v) if v is not None else None

def _b11_safe_mode():
    jc = _b11_jc(_XCFG_CLASS)
    if jc is None: return None
    v = _b11_attr(jc, "getPluginsSafeMode")
    return bool(v) if v is not None else None

def _b11_plugin_entries():
    ctrl = _b11_controller()
    if ctrl is None: return []
    m = _b11_attr(ctrl, "getPlugins", "plugins")
    if m is None: return []
    last = None
    for _ in range(3):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("Block#11: entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _b11_is_loaded(pid):
    try:
        with _REG_LOCK:
            r = _REGISTRY.get(pid)
        if r and r.get("inst"): return True
    except Exception: pass
    return False

def _record_gate_fail(pid, kind, reason, thr=None, extra=None):
    if not _BLOCK11_ON: return
    py_mod = py_file = None; py_line = -1; top_cls = "?"; top_msg = None
    if thr is not None:
        try: chain = _thr_chain(thr)
        except Exception: chain = []
        if chain:
            py_mod, py_file, py_line = _py_module_from_throwable(chain)
            r2 = _load_reason(chain)
            if r2 and r2 != "unknown": reason = r2
            top_cls = chain[0][0]; top_msg = chain[0][1]
    if py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif pid:
        culprit = pid; src = "plugins-map/" + kind; conf = "high" if thr is not None else "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    _gv_lib = False
    try:
        _cul_s = culprit if isinstance(culprit, str) else ""
        _gv_dotted = ("." in _cul_s) and (" " not in _cul_s) and (not _cul_s.endswith(".")) and (not _cul_s.startswith("."))
        _gv_known = set()
        try: _gv_known = set(_load_known() or [])
        except Exception: _gv_known = set()
        if _gv_dotted and _cul_s and (_cul_s not in _gv_known):
            _gv_lib = True
            if conf == "high": conf = "medium"
            src = (src or "none") + "?lib-style"
    except Exception:
        _gv_lib = False
    rec = {"had_gate_fail": True, "event_type": "plugin_gate_blocked", "dropbox_tag": "plugin_gate_blocked", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "kind": kind, "pid": pid, "py_module": py_mod, "py_file": py_file,
           "py_line": py_line, "reason": reason, "exc_cls": top_cls, "exc_msg": top_msg,
           "extra": extra, "ts": int(time.time() * 1000)}
    if _gv_lib:
        rec["library_style_id"] = True
        rec["note"] = "возможно вендоренная зависимость (library-style id вида a.b.c); инициатор импорта (плагин) не определён"
    key = "%s|%s|%s" % (culprit, reason, kind); now = rec["ts"]
    with _GATE_SEEN_LOCK:
        if now - _GATE_SEEN.get(key, 0) < _GATE_DEDUP_MS: return
        _GATE_SEEN[key] = now
    try: _gate_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_gate_fail(rec)
    except Exception: pass

def _persist_gate_fail(rec):
    p = _gate_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _GATE_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_gate_fails():
    p = _gate_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = _rc_expect_list(json.load(f))
    except Exception as _mr_e:
        out = None
        if _rp:
            _rc_clear_taken(_rp, False, _mr_e)
            _rp = None
    if _rp:
        _rc_clear_taken(_rp, out is not None)
    if out is None: out = []
    return out

def _gate_verdict_log(rec, when):
    try:
        _log("============= PRE-IMPORT/GATE VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: %r conf=%s kind=%s src=%s" % (cul, conf, rec.get("kind"), rec.get("src")))
        else:
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: неизвестен (kind=%s)" % rec.get("kind"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        ex = rec.get("extra")
        if ex: _log("  детали: %s" % ex)
        ec = rec.get("exc_cls")
        if ec and ec != "?": _log("  исключение: %s: %s" % (ec, rec.get("exc_msg")))
        _log("=======================================================")
    except Exception: pass

def _b11_scan(reason="scan"):
    if not _BLOCK11_ON: return
    try:
        sm = _b11_safe_mode()
        if sm is True:
            _record_gate_fail(None, "safe-mode",
                              "движок в SAFE-MODE -> плагины не загружаются (тихо, без исключения)",
                              extra="ExteraConfig.getPluginsSafeMode()=true")
    except Exception: pass
    rt_sdk = _b11_runtime_sdk()
    entries = _b11_plugin_entries()
    for ent in entries:
        try:
            pid = str(ent.getKey())
            pj = ent.getValue()
        except Exception:
            continue
        if pj is None: continue
        err = _b11_attr(pj, "getError", "error")
        if err is not None:
            try: _intern(pid); _save_known(pid)
            except Exception: pass
            _record_gate_fail(pid, "error",
                              "движок проглотил исключение загрузки (plugins[%s].error)" % pid, thr=err)
            continue
        try:
            if _b11_is_loaded(pid): continue
        except Exception: pass
        psdk = _b11_attr(pj, "getSdkVersion", "sdkVersion")
        psdk = str(psdk) if psdk is not None else ""
        pav = _b11_attr(pj, "getAppVersion", "appVersion")
        pav = str(pav) if pav is not None else ""
        req = _b11_attr(pj, "getRequirements", "requirements")
        try: req = list(req) if req is not None else []
        except Exception: req = []
        if rt_sdk and psdk and psdk != rt_sdk and rt_sdk != "unknown":
            _record_gate_fail(pid, "sdk-version",
                              "несовпадение sdk_version (плагин=%s, рантайм=%s) -> вероятная тихая не-загрузка" % (psdk, rt_sdk),
                              extra="app_version(min)=%s requirements=%s" % (pav or "-", req or "-"))

_B11P_ON = True
_PREIMPORT_DIR = None
_PREIMPORT_FINDER = None

def _b11p_plugins_dir():
    global _PREIMPORT_DIR
    if _PREIMPORT_DIR is not None:
        return _PREIMPORT_DIR
    d = None
    try:
        PC = jclass(_PC_CLASS).getInstance()
        pd = getattr(PC, "pluginsDir", None)
        if pd is not None:
            try: d = str(pd.getAbsolutePath())
            except Exception: d = str(pd)
    except Exception:
        d = None
    if not d:
        try:
            fp = globals().get("__file__")
            if isinstance(fp, str) and fp:
                d = os.path.dirname(fp)
        except Exception:
            d = None
    _PREIMPORT_DIR = d or ""
    return _PREIMPORT_DIR

def _b11p_record(fullname, module, exc):
    if not _BLOCK11_ON or not _B11P_ON: return
    pid = None
    if isinstance(fullname, str) and fullname and fullname != _SELF_ID and fullname != __id__:
        pid = fullname
    if pid is None:
        try:
            cand = getattr(module, "__id__", None)
            if isinstance(cand, str) and cand: pid = cand
        except Exception: pass
    py_file = None; py_line = -1
    try:
        tb = getattr(exc, "__traceback__", None)
        while tb is not None:
            try:
                g = tb.tb_frame.f_globals
                fn = g.get("__file__")
                if fn: py_file = fn
                py_line = tb.tb_lineno
            except Exception: pass
            tb = tb.tb_next
    except Exception: pass
    try: ecls = type(exc).__name__
    except Exception: ecls = "?"
    try: emsg = str(exc)
    except Exception: emsg = None
    reason = "падение во время импорта модуля плагина (до on_plugin_load): %s: %s" % (ecls, emsg)
    extra = "pre-import module=%s" % fullname
    if py_file: extra += " @ %s:%s" % (py_file, py_line)
    try:
        _intern(pid); _save_known(pid)
    except Exception: pass
    _record_gate_fail(pid, "pre-import", reason, thr=None, extra=extra)
    try: _log("Block#11P: поймано падение импорта плагина %r (%s)" % (pid or fullname, ecls))
    except Exception: pass

class _PreImportGuardLoader:
    def __init__(self, real, fullname):
        self._real = real
        self._fullname = fullname
    def create_module(self, spec):
        try:
            return self._real.create_module(spec)
        except Exception:
            return None
    def exec_module(self, module):
        try:
            self._real.exec_module(module)
        except BaseException as e:
            try: _b11p_record(self._fullname, module, e)
            except Exception: pass
            raise
    def __getattr__(self, name):
        if name in ("_real", "_fullname"):
            raise AttributeError(name)
        return getattr(self._real, name)

class _PreImportFinder:
    def find_spec(self, fullname, path=None, target=None):
        if not _B11P_ON: return None
        try:
            pdir = _b11p_plugins_dir()
            if not pdir: return None
            spec = None
            for finder in list(_sys.meta_path):
                if finder is self: continue
                fs = getattr(finder, "find_spec", None)
                if fs is None: continue
                try: spec = fs(fullname, path, target)
                except Exception: spec = None
                if spec is not None: break
            if spec is None: return None
            loader = getattr(spec, "loader", None)
            origin = getattr(spec, "origin", None)
            if loader is None or not isinstance(origin, str): return spec
            if isinstance(loader, _PreImportGuardLoader): return spec
            try: in_pdir = (os.path.dirname(origin) == pdir) or origin.startswith(pdir)
            except Exception: in_pdir = False
            if not in_pdir: return spec
            try:
                spec.loader = _PreImportGuardLoader(loader, fullname)
            except Exception:
                return spec
            return spec
        except Exception:
            return None

def _b11p_install():
    global _PREIMPORT_FINDER
    if not _B11P_ON: return
    if _PREIMPORT_FINDER is not None: return
    try:
        _b11p_plugins_dir()
        f = _PreImportFinder()
        _sys.meta_path.insert(0, f)
        _PREIMPORT_FINDER = f
        _log("Block#11P: pre-import gate installed (dir=%s)" % (_PREIMPORT_DIR or "?"))
    except Exception as e:
        try: _log("Block#11P install err: %s" % e)
        except Exception: pass

def _b11p_uninstall():
    global _PREIMPORT_FINDER
    f = _PREIMPORT_FINDER
    if f is None: return
    try:
        if f in _sys.meta_path: _sys.meta_path.remove(f)
    except Exception: pass
    _PREIMPORT_FINDER = None


def _b11_install_scan():
    for delay in (3.0, 8.0):
        try:
            t = threading.Timer(delay, lambda d=delay: _b11_scan("post-load+%ss" % int(d)))
            t.daemon = True; t.start()
            _B11_TIMERS.append(t)
        except Exception as e:
            try: _log("Block#11: scan timer err: %s" % e)
            except Exception: pass

def _jc(name):
    try:
        return jclass(name)
    except Exception:
        try:
            from java import jclass as _j
            return _j(name)
        except Exception:
            return None

def _oom_path(name=None):
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, name or _OOM_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _java_mem():
    ju = -1; jm = -1; nh = -1
    try:
        rt = _jc("java.lang.Runtime").getRuntime()
        jm = int(rt.maxMemory()); ju = int(rt.totalMemory()) - int(rt.freeMemory())
    except Exception:
        pass
    try:
        nh = int(_jc("android.os.Debug").getNativeHeapAllocatedSize())
    except Exception:
        pass
    return ju, jm, nh

_UNTAGGED_LABEL = "⟨untagged⟩"

_GREF_LIVE_DEGRADE_MIN = 4096
_GREF_LIVE_DEGRADE_FRAC = 0.25
def _gref_live_sum():
    try:
        if not (globals().get("_GREF_LIVE_OK") and _NLIB is not None and ctypes is not None):
            return 0
        try: n = int(_NLIB.cd_gref_tags())
        except Exception: n = 0
        s = 0
        if n > 0:
            arr = (ctypes.c_int64 * n)()
            m = int(_NLIB.cd_gref_live_snapshot(arr, ctypes.c_int32(n)))
            i = 0
            while i < m and i < n:
                v = int(arr[i])
                if v > 0: s += v
                i += 1
        try: s += max(0, int(_NLIB.cd_gref_live_untagged()))
        except Exception: pass
        return s
    except Exception:
        return 0
def _oom_gref_top():
    try:
        if not (_GREF_NATIVE_OK and _NLIB is not None and ctypes is not None):
            return None
        try:
            if not int(_NLIB.cd_gref_running()):
                return None
        except Exception:
            return None
        _live_ok = bool(globals().get("_GREF_LIVE_OK"))
        overflow = 0; del_untracked = 0
        if _live_ok:
            try: overflow = int(_NLIB.cd_gref_overflow())
            except Exception: overflow = 0
            try: del_untracked = int(_NLIB.cd_gref_del_untracked())
            except Exception: del_untracked = 0
        _cnt = ctypes.c_int64(0)
        try: creation_total = int(_NLIB.cd_gref_total())
        except Exception: creation_total = 0
        _degraded = (not _live_ok) or (overflow > 0) or (del_untracked >= _GREF_LIVE_DEGRADE_MIN and float(del_untracked) >= _GREF_LIVE_DEGRADE_FRAC * float(max(1, creation_total)))
        src = "native"; is_live = False
        if _live_ok and not _degraded:
            idx = int(_NLIB.cd_gref_live_top1(ctypes.byref(_cnt)))
            top_cnt = int(_cnt.value)
            if idx < 0 or top_cnt <= 0:
                return None
            is_live = True; src = "native_live"
            total = _gref_live_sum()
            try: untagged = int(_NLIB.cd_gref_live_untagged())
            except Exception: untagged = 0
            if total <= 0: total = top_cnt
        else:
            idx = int(_NLIB.cd_gref_top1(ctypes.byref(_cnt)))
            top_cnt = int(_cnt.value)
            if idx < 0 or top_cnt <= 0:
                return None
            try: total = int(_NLIB.cd_gref_total())
            except Exception: total = 0
            try: untagged = int(_NLIB.cd_gref_untagged())
            except Exception: untagged = 0
        name = None
        try: name = _resolve_idx(idx)
        except Exception: name = None
        if not name:
            try: name = _resolve_idx_durable(idx)
            except Exception: name = None
        if not name or name == _SELF_ID or name == __id__:
            return None
        return {"culprit": name, "count": top_cnt, "total": total,
                "untagged": untagged, "src": src, "live": is_live, "overflow": overflow, "del_untracked": del_untracked, "degraded": _degraded}
    except Exception:
        return None

_NA_HINT_MAX_AGE_MS = 180000
_NA_HINT_MIN_BYTES = 1048576

def _mr_untagged_top_module(odump):
    try:
        p = _oom_path(_NA_NAME)
        if not p or not os.path.exists(p):
            return None
        try: _mt = int(os.path.getmtime(p) * 1000)
        except Exception: _mt = None
        try: _ts = int(odump.get("ts") or 0)
        except Exception: _ts = 0
        if _mt is not None and _ts > 0 and abs(_mt - _ts) > _NA_HINT_MAX_AGE_MS:
            return None
        with open(p, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        best = None
        for s in (d.get("sites") or []):
            try:
                rb = int(s.get("retained_bytes") or 0)
            except Exception:
                continue
            if rb < _NA_HINT_MIN_BYTES:
                continue
            if best is None or rb > best[0]:
                frames = s.get("frames") or []
                mod = None
                if frames:
                    try: mod = str(frames[0]).split("+", 1)[0].split("/")[-1].strip()
                    except Exception: mod = None
                if mod:
                    best = (rb, mod, s.get("bucket") or "app")
        if not best:
            return None
        return {"module": best[1], "bytes": best[0], "bucket": best[2]}
    except Exception:
        return None

def _oom_native_site_hint(odump):
    try:
        _sv = odump.get("verdict") or {}
        _snsc = _sv.get("native_site_culprit"); _snsb = int(_sv.get("native_site_bytes") or 0)
        if _snsc and _snsb >= _NA_HINT_MIN_BYTES:
            return {"module": _snsc, "bytes": _snsb, "count": int(_sv.get("native_site_count") or 0), "bucket": _sv.get("native_site_bucket")}
    except Exception:
        pass
    try:
        p = _oom_path(_NA_NAME)
        if not p or not os.path.exists(p):
            return None
        try: _mt = int(os.path.getmtime(p) * 1000)
        except Exception: _mt = None
        try: _ts = int(odump.get("ts") or 0)
        except Exception: _ts = 0
        if _mt is not None and _ts > 0 and abs(_mt - _ts) > _NA_HINT_MAX_AGE_MS:
            return None
        with open(p, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        best = None
        for s in (d.get("sites") or []):
            try:
                if s.get("bucket") == "gfx":
                    continue
                rb = int(s.get("retained_bytes") or 0)
            except Exception:
                continue
            if rb < _NA_HINT_MIN_BYTES:
                continue
            if best is None or rb > best[0]:
                frames = s.get("frames") or []
                mod = None
                if frames:
                    try: mod = str(frames[0]).split("+", 1)[0].split("/")[-1].strip()
                    except Exception: mod = None
                if mod:
                    best = (rb, mod, int(s.get("count") or 0), s.get("bucket"))
        if not best:
            return None
        return {"module": best[1], "bytes": best[0], "count": best[2], "bucket": best[3]}
    except Exception:
        return None

_OOM_RPS_OP_WINDOW_MS = 8000
_OOM_RPS_DOMAINS = ("gl", "anim", "mediacodec")
_OOM_PSEUDO_TAGS = ("python_interpreter",)
_OOM_MR_UNTAGGED_FAMILY = ("ambient_device_pressure", "no_attribution", "untagged_dominates",
                           "untagged_edges_named", "rate_untagged_dominant",
                           "async_download_untagged_dominant", "native_site_hint")


def _oom_untagged_alias(name):
    if name == _UNTAGGED_LABEL:
        return True
    try:
        _n = str(name).strip().strip("<>()\u27e8\u27e9").strip().lower()
    except Exception:
        return False
    return _n == "untagged"

def _oom_verdict(odump):
    try:
        top = list(odump.get("top") or [])
    except Exception:
        top = []
    untagged = 0; real = []; total_attr = 0; _interp_b = 0
    for kv in top:
        try:
            name = kv[0]; b = int(kv[1])
        except Exception:
            continue
        if b < 0: b = 0
        total_attr += b
        if _oom_untagged_alias(name):
            untagged += b
        elif name in _OOM_PSEUDO_TAGS:
            untagged += b
            _interp_b += b
        elif name == _SELF_ID or name == __id__:
            pass
        else:
            real.append((name, b))
    real.sort(key=lambda x: x[1], reverse=True)
    denom = total_attr if total_attr > 0 else 1
    culprit = real[0][0] if real else None
    culprit_bytes = real[0][1] if real else 0
    second_bytes = real[1][1] if len(real) > 1 else 0
    share = float(culprit_bytes) / float(denom)
    untagged_share = float(untagged) / float(denom)
    margin = (float(culprit_bytes - second_bytes) / float(culprit_bytes)) if culprit_bytes > 0 else 0.0
    try:
        rate = float(odump.get("rate_mbps") or 0.0)
    except Exception:
        rate = 0.0
    global _OOM_PREV_EMIT
    _gr_cul = None; _gr_b = 0; _gr_win = None; _gr_unt = 0; _gr_unt_known = True
    try:
        _now_ts = int(odump.get("ts") or int(time.time() * 1000))
        _cur_map = {}
        for kv in top:
            try:
                _gk = _UNTAGGED_LABEL if _oom_untagged_alias(kv[0]) else str(kv[0])
                _cur_map[_gk] = _cur_map.get(_gk, 0) + max(0, int(kv[1]))
            except Exception: pass
        _prev = _OOM_PREV_EMIT
        _OOM_PREV_EMIT = {"ts": _now_ts, "top": _cur_map}
        if _prev and 0 < (_now_ts - int(_prev.get("ts") or 0)) <= _OOM_GROWTH_FRESH_MS:
            _gr_win = _now_ts - int(_prev.get("ts") or 0)
            _pm = _prev.get("top") or {}
            _best = None
            for _gn, _gb in _cur_map.items():
                if _gn not in _pm:
                    if _gn == _UNTAGGED_LABEL or _gn in _OOM_PSEUDO_TAGS:
                        _gr_unt_known = False
                    continue
                _gd = _gb - int(_pm.get(_gn, 0))
                if _gd <= 0: continue
                if _gn == _UNTAGGED_LABEL:
                    _gr_unt += _gd
                elif _gn in _OOM_PSEUDO_TAGS:
                    _gr_unt += _gd
                elif _gn not in (_SELF_ID, __id__) and (_best is None or _gd > _best[1]):
                    _best = (_gn, _gd)
            if _best:
                _gr_cul, _gr_b = _best[0], int(_best[1])
    except Exception:
        _gr_cul = None; _gr_b = 0; _gr_win = None; _gr_unt = 0; _gr_unt_known = True
    tagged_total = total_attr - untagged
    tagged_share = (float(culprit_bytes) / float(tagged_total)) if tagged_total > 0 else 0.0
    if culprit is None:
        conf = "low"
        display = _UNTAGGED_LABEL if untagged > 0 else None
        reason_detail = "no_attribution"
    elif untagged > culprit_bytes:
        _nl_interp_dom = (_interp_b > 0 and _interp_b * 2 >= untagged)
        if rate >= 15.0 and tagged_share >= 0.80 and culprit_bytes > 524288 and not _nl_interp_dom:
            conf = "medium"
            display = culprit
            reason_detail = "async_download_pattern"
        elif rate >= 50.0 and culprit_bytes > 262144:
            conf = "low"
            display = culprit
            reason_detail = "rate_suspect"
        else:
            conf = "low"
            display = _UNTAGGED_LABEL
            if culprit_bytes > 262144 and untagged < culprit_bytes * _OOM_EDGE_RATIO:
                reason_detail = "untagged_edges_named"
            else:
                reason_detail = "untagged_dominates"
    elif share >= 0.60 and untagged_share <= 0.25 and margin >= 0.50:
        conf = "high"; display = culprit; reason_detail = "clear_leader"
    elif share >= 0.30 and untagged_share <= 0.50:
        conf = "medium"; display = culprit; reason_detail = "probable_leader"
    else:
        conf = "low"; display = culprit; reason_detail = "weak_leader"
    gref_culprit = None; gref_count = 0; gref_total = 0; gref_share = 0.0; gref_live = False; gref_overflow = 0; gref_del_untracked = 0
    _byte_named = (display != _UNTAGGED_LABEL and display is not None)
    _gref_took_display = False
    _g = None
    try: _g = odump.get("gref")
    except Exception: _g = None
    if not _g:
        try: _g = _oom_gref_top()
        except Exception: _g = None
    if _g:
        try:
            _gn = _g.get("culprit"); _gc = int(_g.get("count") or 0)
            _gt = int(_g.get("total") or 0)
            _gu = int(_g.get("untagged") or 0)
            _named = _gt - _gu
            _gsh = (float(_gc) / float(_named)) if _named > 0 else ((float(_gc) / float(_gt)) if _gt > 0 else 0.0)
            if _gn and _gc >= _B28C_MIN and _gsh >= _B28C_DOMINANCE:
                gref_culprit = _gn; gref_count = _gc
                gref_total = _gt; gref_share = _gsh
                gref_live = bool(_g.get("live")); gref_overflow = int(_g.get("overflow") or 0); gref_del_untracked = int(_g.get("del_untracked") or 0)
                if not _byte_named:
                    display = _gn
                    reason_detail = "globalref_native"
                    conf = "high" if _g.get("live") else "medium"
                    _gref_took_display = True
        except Exception:
            pass
    is_unt = (display == _UNTAGGED_LABEL)
    if _gref_took_display:
        display_bytes = untagged; display_share = untagged_share
    else:
        display_bytes = untagged if is_unt else culprit_bytes
        display_share = untagged_share if is_unt else share
    native_site = None
    if not _gref_took_display:
        try: native_site = _oom_native_site_hint(odump)
        except Exception: native_site = None
    if native_site and (is_unt or display is None):
        reason_detail = "native_site_hint"
        try:
            _if_b = int(native_site.get("bytes") or 0)
            _if_mod = native_site.get("module")
            if _if_mod and _if_b >= _NA_HINT_MIN_BYTES:
                display = _if_mod
                display_bytes = _if_b
                display_share = (float(_if_b) / float(denom)) if denom > 0 else 0.0
                reason_detail = "native_site_promoted"
                conf = "medium" if (untagged > 0 and _if_b >= untagged * 0.5) else "low"
        except Exception:
            pass
    _cl_corr = None
    try:
        _cl_corr = _recent_client_lowmem()
    except Exception:
        _cl_corr = None
    try:
        _ig_amb = ("ambient(device)" in str(odump.get("reason") or "")) and (rate < 2.0)
        if _ig_amb and (not _byte_named) and (not _gref_took_display) and reason_detail in ("native_site_promoted", "native_site_hint", "untagged_dominates", "no_attribution", "untagged_edges_named"):
            if reason_detail == "native_site_promoted":
                display = _UNTAGGED_LABEL
                display_bytes = untagged
                display_share = untagged_share
            reason_detail = "ambient_device_pressure"
            conf = "low"
    except Exception:
        pass
    _rps = None; _rps_basis = None
    try:
        if culprit and culprit not in (_UNTAGGED_LABEL, _SELF_ID, __id__):
            _rps_op = None
            try: _rps_op = _b20_owner_from_op_in_domains(_OOM_RPS_OP_WINDOW_MS, _OOM_RPS_DOMAINS, owner=culprit)
            except Exception: _rps_op = None
            _rps_op_dom = (_rps_op.get("domain") if _rps_op else None)
            if _rps_op is not None and _rps_op_dom in _OOM_RPS_DOMAINS:
                _rps = culprit
                _rps_basis = "top native allocator (%dB) == fresh %s op-stamp owner (age=%dms); anr_scope_owner=%r" % (int(culprit_bytes), _rps_op_dom, int((_rps_op.get("age_ms") or 0)), _b20_owner_from_scope())
    except Exception:
        _rps = None; _rps_basis = None
    _tagged_leader = None; _tagged_leader_bytes = 0; _tagged_leader_share = 0.0
    try:
        if reason_detail in ("async_download_pattern", "rate_suspect") and untagged > culprit_bytes and share < _OOM_TAGGED_HEADLINE_MIN_SHARE and display == culprit:
            _tagged_leader = culprit; _tagged_leader_bytes = int(culprit_bytes); _tagged_leader_share = round(share, 4)
            _mp_async = (reason_detail == "async_download_pattern")
            display = _UNTAGGED_LABEL
            display_bytes = untagged; display_share = untagged_share
            reason_detail = "async_download_untagged_dominant" if _mp_async else "rate_untagged_dominant"
            conf = "low"
            try: _log("Block#7 +JR(fix3)/+MP(2): OOM headline demoted -- untagged %dB > tagged leader %r %dB (abs share %.1f%% < %.0f%%) -> culprit=untagged/host, %r kept as tagged_leader" % (int(untagged), _tagged_leader, int(culprit_bytes), share * 100.0, _OOM_TAGGED_HEADLINE_MIN_SHARE * 100.0, _tagged_leader))
            except Exception: pass
    except Exception:
        pass
    _rs_txt = str(odump.get("reason") or "")
    _sev = "pre_oom_growth" if (("rate" in _rs_txt) and ("pct" not in _rs_txt)) else "oom_pressure"
    try:
        if (_gr_cul and _gr_win and _gr_b >= _OOM_GROWTH_MIN_BYTES and _gr_b > _gr_unt
                and _gr_unt_known
                and ("rate" in _rs_txt)
                and reason_detail in ("rate_suspect", "rate_untagged_dominant", "untagged_dominates", "weak_leader")
                and not _gref_took_display):
            _gb_cur = 0
            for _rn, _rb in real:
                if _rn == _gr_cul:
                    _gb_cur = int(_rb); break
            display = _gr_cul
            display_bytes = _gb_cur if _gb_cur > 0 else _gr_b
            display_share = (float(display_bytes) / float(denom)) if denom else 0.0
            conf = "medium" if _gr_b >= 2 * max(1, _gr_unt) else "low"
            reason_detail = "growth_leader"
            try: _log("Block#7 +MP(3): rate-событие -> headline по РОСТУ за окно %dмс: %s +%.1f МБ (untagged +%.1f МБ); retained-лидер %r оставлен в top_named" % (int(_gr_win), _gr_cul, _gr_b/1048576.0, _gr_unt/1048576.0, culprit))
            except Exception: pass
    except Exception: pass
    _co_s = None; _co_b = 0
    try:
        if display == culprit and len(real) > 1 and second_bytes > 0 and margin < 0.25:
            _co_s = real[1][0]; _co_b = int(second_bytes)
    except Exception: pass
    return {"culprit": display, "top_named": culprit, "top_named_bytes": culprit_bytes,
            "resource_pressure_suspect": _rps, "rps_basis": _rps_basis,
            "culprit_bytes": culprit_bytes, "second_bytes": second_bytes,
            "margin": round(margin, 4), "share": round(share, 4),
            "display_bytes": display_bytes, "display_share": round(display_share, 4),
            "untagged_bytes": untagged, "untagged_share": round(untagged_share, 4),
            "interpreter_bytes": _interp_b, "raw_untagged_bytes": (untagged - _interp_b),
            "rate_mbps": round(rate, 2), "reason": odump.get("reason"),
            "severity": _sev, "growth_culprit": _gr_cul, "growth_bytes": _gr_b,
            "growth_window_ms": _gr_win, "growth_untagged_bytes": _gr_unt,
            "co_suspect": _co_s, "co_suspect_bytes": _co_b,
            "growth_baseline_present": bool(_gr_win),
            "growth_untagged_baseline": (None if not _gr_win else bool(_gr_unt_known)),
            "gref_culprit": gref_culprit, "gref_count": gref_count,
            "gref_total": gref_total, "gref_share": round(gref_share, 4),
            "gref_live": gref_live, "gref_overflow": gref_overflow, "gref_del_untracked": gref_del_untracked,
            "native_site_culprit": (native_site["module"] if native_site else None),
            "native_site_bytes": (native_site["bytes"] if native_site else 0),
            "native_site_count": (native_site["count"] if native_site else 0),
            "native_site_bucket": (native_site["bucket"] if native_site else None),
            "reason_detail": reason_detail, "confidence": conf,
            "client_lowmem_corrob": _cl_corr,
            "tagged_leader": _tagged_leader, "tagged_leader_bytes": _tagged_leader_bytes, "tagged_leader_share": _tagged_leader_share}

def _oom_verdict_log(odump, where):
    try:
        v = odump.get("verdict") if isinstance(odump, dict) else None
        if not isinstance(v, dict):
            v = _oom_verdict(odump)
    except Exception as e:
        try: _log(f"OOM verdict err: {e}")
        except Exception: pass
        return None
    cul = v.get("culprit")
    if cul is None:
        return v
    _OOM_RD_TXT = {
        "untagged_dominates": "untagged dominates; named plugin too small to explain OOM",
        "no_attribution": "no attribution; all memory untagged (raw threads / Part A .so)",
        "clear_leader": "clear leader",
        "probable_leader": "probable leader",
        "weak_leader": "weak leader; low confidence",
        "async_download_pattern": "async HTTP/network: plugin dominates tagged; untagged = urllib3/TCP/JNI buffers outside scope",
        "rate_suspect": "fast growth rate with active named plugin; untagged dominates",
        "rate_untagged_dominant": "rate-triggered; untagged dominates and named share is tiny -> host/untagged headlined, named kept as tagged_leader (+MP)",
        "growth_leader": "rate-triggered; headline by per-owner growth delta over the last emit window; retained leader kept in top_named (+MP)",
        "globalref_native": "native JNI global-ref attribution (Block#28C/+JO): the plugin owning the most LIVE global-refs (NewGlobalRef minus DeleteGlobalRef, charged to the ref creator) dominates the JNI table; falls back to cumulative CREATION/churn wording when the live map is degraded (overflow / late hook) or the .so predates +JO",
        "native_site_hint": "untagged at OOM, but the native alloc-site sampler names the dominant holder module (large mmap/direct allocs bypass the malloc tagger)",
        "ambient_device_pressure": "device-wide RAM pressure with ~zero process growth: meminfo saturated device-side while our RSS is small/flat -- NOT this process leaking (holder/untagged suppressed, no per-process culprit)",
        "globalref_ambient": "RSS/native leak but the JNI global-ref pool is >90%% untagged and the named plugin owns <5%% of ALL refs: gref creation-dominance among a tiny tagged slice is unrepresentative -> not pinned (host-ambient, low)",
    }
    rd = v.get("reason_detail")
    _log("================ OOM VERDICT (%s) ================" % where)
    _mp_hdr = "БЫСТРЫЙ РОСТ ПАМЯТИ(pre-OOM)" if v.get("severity") == "pre_oom_growth" else "ВИНОВНИК OOM(память)"
    _log("%s: %r conf=%s — %.0f МБ (отслежено детектором, НЕ доля от ОЗУ) отрыв=%.0f МБ rate=%sМБ/с untagged=%.0f МБ reason=%s" % (
        _mp_hdr,
        cul, v["confidence"], float(v["display_bytes"])/1048576.0,
        max(0.0, (float(v.get("culprit_bytes") or 0) - float(v.get("second_bytes") or 0)))/1048576.0,
        v["rate_mbps"], float(v["untagged_bytes"])/1048576.0, v.get("reason")))
    try:
        if v.get("co_suspect"):
            _log("  co-suspect: %s %.0f МБ (отрыв от лидера <25%% — виновник не единственный кандидат)" % (v.get("co_suspect"), float(v.get("co_suspect_bytes") or 0)/1048576.0))
        if v.get("growth_culprit"):
            _log("  рост за окно %sмс: %s +%.0f МБ (untagged +%.0f МБ)" % (v.get("growth_window_ms"), v.get("growth_culprit"), float(v.get("growth_bytes") or 0)/1048576.0, float(v.get("growth_untagged_bytes") or 0)/1048576.0))
    except Exception: pass
    _rps = v.get("resource_pressure_suspect")
    if _rps:
        _log("  [+RP] process-level resource-pressure suspect: %s -- держатель нативной памяти И владелец UI-стойла/ANR (gl/anim/mediacodec op-stamp); device-OOM вердикт НЕ меняется [%s]" % (_rps, v.get("rps_basis")))
    if cul == _UNTAGGED_LABEL:
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        if tn:
            _log("  top_named=%s %.0f МБ" % (tn, tnb/1048576.0))
        _nsc = v.get("native_site_culprit")
        if _nsc:
            _log("  native-site(holder)=%s %.0f МБ x%s bucket=%s -- держатель нативной памяти по сэмплеру (модульная подсказка; malloc-теги его не видят)" % (
                _nsc, int(v.get("native_site_bytes") or 0)/1048576.0, v.get("native_site_count"), v.get("native_site_bucket")))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  → виновник по памяти не определён достоверно (named-плагин не объясняет OOM)")
    elif rd == "globalref_native":
        gn = v.get("gref_culprit"); gc = int(v.get("gref_count") or 0)
        gt = int(v.get("gref_total") or 0)
        gsh = (float(gc) / float(gt) * 100.0) if gt > 0 else 0.0
        if v.get("gref_live"):
            _log("  global-refs(LIVE): %s=%d из %d живых (%.0f%%) -- атрибуция по ЖИВЫМ JNI global-ref (Block#28C/+JO: NewGlobalRef+DeleteGlobalRef, owner=создатель)" % (gn, gc, gt, gsh))
            _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
            _log("  -> доминирование по ЖИВЫМ (не удалённым) global-ref: подтверждённый держатель JNI-таблицы, а не churn; malloc-теги его не видят")
        else:
            _log("  global-refs(native/churn): %s=%d из %d (%.0f%%) -- атрибуция по нативному счётчику NewGlobalRef (Block#28C)" % (gn, gc, gt, gsh))
            _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
            _log("  -> live-карта деградирована (overflow=%d / del_untracked=%d) или .so без +JO -> откат на НАКОПЛЕННЫЙ темп создания (churn): доминирование по созданию, доверие среднее" % (int(v.get("gref_overflow") or 0), int(v.get("gref_del_untracked") or 0)))
    elif rd in ("async_download_pattern", "rate_suspect"):
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        unt = int(v.get("untagged_bytes") or 0)
        _async_ratio = round(float(unt) / float(tnb), 1) if tnb > 0 else 0.0
        _named_pct = round(float(tnb) / float(tnb + unt) * 100.0, 1) if (tnb + unt) > 0 else 0.0
        _log("  named=%s %.0f МБ untagged=%.0f МБ async_ratio=%.1fx (named %.0f из %.0f МБ отслеженных)" % (
            tn, tnb/1048576.0, unt/1048576.0, _async_ratio, tnb/1048576.0, (tnb+unt)/1048576.0))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _h6_nsc = v.get("native_site_culprit"); _h6_nsb = int(v.get("native_site_bytes") or 0)
        if _h6_nsc and _h6_nsb >= _NA_HINT_MIN_BYTES and _h6_nsc != tn:
            _log("  [+H6] из untagged ~%.0f МБ удерживает %r (нативный модуль-держатель, НЕ HTTP-буферы плагина)" % (_h6_nsb/1048576.0, _h6_nsc))
            _log("  → виновник по async-паттерну (named-плагин), но часть untagged = нативный держатель выше, а не сеть")
        else:
            _log("  → виновник определён по async-паттерну: буферы HTTP-загрузки вне scope падают в untagged")
    else:
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        try:
            _mrm = v.get("untagged_top_module")
            if _mrm:
                _mrb = v.get("untagged_top_module_bucket")
                _mrg = "; gfx: ресурсы могли быть созданы плагином, хотя выделение прошло через системную библиотеку" if _mrb == "gfx" else ""
                _log("  [+NF] топ-модуль sampled untagged: %s ~%.0f МБ bucket=%s -- владелец не установлен, это holder/module hint, а НЕ атрибуция%s" % (_mrm, int(v.get("untagged_top_module_bytes") or 0) / 1048576.0, _mrb, _mrg))
        except Exception:
            pass
    _log("=================================================")
    return v

def _mr_esc_metrics(rec):
    v = rec.get("verdict") or {}
    try: _r = float(rec.get("rate_mbps") or 0.0)
    except Exception: _r = 0.0
    def _i(k):
        try: return int(v.get(k) or 0)
        except Exception: return 0
    _hm = v.get("untagged_top_module")
    _tn = v.get("top_named")
    return {"rate": _r, "display_b": _i("display_bytes"), "growth_b": _i("growth_bytes"),
            "untagged_b": _i("untagged_bytes"),
            "holder_b": _i("untagged_top_module_bytes"), "top_named_b": _i("top_named_bytes"),
            "holder": (str(_hm) if _hm else None), "top_named": (str(_tn) if _tn else None)}

def _oom_persist(rec):
    try:
        if (not rec.get("repeat_suppressed")) or rec.get("repeat_sample"):
            hp = _oom_path("oom_dump_%d.json" % rec["ts"])
            if hp:
                _atomic_json_write(hp, rec)
    except Exception:
        pass
    p = _oom_path()
    if not p: return
    _atomic_json_write(p, rec)

def _oom_log_dump(rec):
    m = rec.get("mem", {})
    pc = m.get("pct"); pcs = round(pc*100,1) if (pc is not None and pc>=0) else -1
    _log("================ PRE-OOM DUMP ================")
    _log(f'PRE-OOM trigger: reason={rec.get("reason")} rate={rec.get("rate_mbps")}MB/s')
    _log(f'  mem: src={m.get("src")} used={m.get("used")}B limit={m.get("limit")}B pct={pcs}%')
    _log(f'  rss={m.get("rss")}B native_heap={m.get("native_heap")}B java={m.get("java_used")}/{m.get("java_max")}B cgroup={m.get("cg_cur")}/{m.get("cg_max")}B')
    _log(f'  tracked: cd_total={m.get("cd_total")}B live={rec.get("native_live")} dropped={rec.get("dropped")}')
    if rec.get("direct_total") is not None:
        _log(f'  direct(NIO off-heap): live={rec.get("direct_live_total")}B cumulative={rec.get("direct_total")}B untagged_live={rec.get("direct_live_untagged")}B')
    _log(f'  TOP-{_OOM_TOPN} consumers (plugin: bytes [native_live+direct_live]):')
    for i, kv in enumerate(rec.get("top", [])):
        try: _log(f'    #{i+1} {kv[0]}: {int(kv[1])}B')
        except Exception: pass
    try: _oom_verdict_log(rec, "live")
    except Exception: pass
    _log("==============================================")

def _read_and_clear_oom_dump():
    p = _oom_path()
    if not p: return None
    rec = None
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                rec = _rc_expect_dict(json.load(f))
    except Exception as _mr_e:
        rec = None
        if _rp:
            _rc_clear_taken(_rp, False, _mr_e)
            _rp = None
    if _rp:
        _rc_clear_taken(_rp, rec is not None)
    return rec

import struct as _struct
_OOM_HDR_FMT = "<II12q4i"
_OOM_HDR_LEN = _struct.calcsize(_OOM_HDR_FMT)
_OOM_TOP_FMT = "<iiq"
_OOM_TOP_LEN = _struct.calcsize(_OOM_TOP_FMT)
_OOM_MAGIC = 0x4F4F4D32

def _oom_sentinel_path():
    return _oom_path(_OOM_SENTINEL_NAME)

def _oom_decode_sentinel(blob):
    if not blob or len(blob) < _OOM_HDR_LEN:
        return None
    h = _struct.unpack_from(_OOM_HDR_FMT, blob, 0)
    (magic, ver, ts_ms, used, limit, rate_milli, cd_total, untagged, live_count,
        dropped, dropped_bytes, rss, cg_cur, cg_max, reason, src, topn, _pad) = h
    if magic != _OOM_MAGIC:
        return None
    topn = max(0, min(int(topn), 64))
    tops = []
    off = _OOM_HDR_LEN
    for _ in range(topn):
        if off + _OOM_TOP_LEN > len(blob): break
        idx, _p, b = _struct.unpack_from(_OOM_TOP_FMT, blob, off)
        off += _OOM_TOP_LEN
        if idx >= 0 and b > 0:
            tops.append((int(idx), int(b)))
    return {"ver": int(ver), "ts_ms": int(ts_ms), "used": int(used), "limit": int(limit),
            "rate_mbps": (rate_milli / 1000.0), "cd_total": int(cd_total),
            "untagged": int(untagged), "live_count": int(live_count),
            "dropped": int(dropped), "dropped_bytes": int(dropped_bytes),
            "rss": int(rss), "cg_cur": int(cg_cur), "cg_max": int(cg_max),
            "reason_bits": int(reason), "src_code": int(src), "tops": tops}

def _direct_pm_path():
    return _oom_path(_DIRECT_PM_NAME)

def _direct_premortem_dump():
    try:
        p = _direct_pm_path()
        if not p: return
        d = _direct_snapshot()
        d["ts"] = int(time.time() * 1000)
        _atomic_json_write(p, d)
    except Exception:
        pass

def _direct_premortem_read_and_clear():
    try:
        p = _direct_pm_path()
        if not p: return None
        _rp = _rc_take_path(p)
        if not _rp: return None
        d = None
        try:
            try:
                with open(_rp, "r", encoding="utf-8") as f:
                    d = _rc_expect_dict(json.load(f))
            except Exception as _mr_e:
                _rc_clear_taken(_rp, False, _mr_e)
                _rp = None
                raise
        finally:
            if _rp:
                _rc_clear_taken(_rp, d is not None)
        return d
    except Exception:
        return None

def _oom_sentinel_to_rec(s, merge_direct=False, direct_snap=None):
    src = {0: "cgroup", 1: "rss", 2: "none", 3: "meminfo"}.get(s["src_code"], "native")
    used = s["used"]; limit = s["limit"]
    pct = (float(used) / float(limit)) if (limit and limit > 0 and used >= 0) else -1.0
    ju, jm, nh = (-1, -1, -1)
    try: ju, jm, nh = _java_mem()
    except Exception: pass
    m = {"used": used, "limit": limit, "src": src, "pct": pct,
         "java_used": ju, "java_max": jm, "native_heap": nh,
         "rss": s["rss"], "cg_cur": s["cg_cur"], "cg_max": s["cg_max"],
         "cd_total": s["cd_total"]}
    top = []
    for idx, b in s["tops"]:
        nm = _resolve_idx(idx) or ("idx%d" % idx)
        top.append([nm, int(b)])
    if s["untagged"] > 0:
        top.append([_UNTAGGED_LABEL, int(s["untagged"])])
    direct_fields = {}
    _ds = direct_snap if direct_snap is not None else (_direct_snapshot() if merge_direct else None)
    if _ds is not None:
        _premortem = direct_snap is not None
        try:
            _by = _ds.get("live_by_pid") or {}; _unt = int(_ds.get("live_untagged", 0) or 0)
            _combined = {}
            for _nm, _b in top:
                _combined[_nm] = _combined.get(_nm, 0) + int(_b)
            for _pid, _b in _by.items():
                _combined[_pid] = _combined.get(_pid, 0) + int(_b)
            if _unt > 0:
                _combined[_UNTAGGED_LABEL] = _combined.get(_UNTAGGED_LABEL, 0) + _unt
            top = [[_k, _v] for _k, _v in _combined.items()]
            direct_fields = {
                "direct_total": int(_ds.get("total", 0) or 0), "direct_untagged": int(_ds.get("untagged", 0) or 0),
                "direct_live_total": int(_ds.get("live_total", 0) or 0), "direct_live_untagged": int(_ds.get("live_untagged", 0) or 0),
                "direct_merged": ("premortem-live" if _premortem else "live"),
            }
        except Exception:
            direct_fields = {}
    top.sort(key=lambda kv: kv[1], reverse=True)
    top = top[:_OOM_TOPN]
    rbits = s["reason_bits"]; hit = []
    if rbits & 1: hit.append("pct>=%d%%" % int(_OOM_PCT*100))
    if rbits & 2: hit.append("rate>=%dMB/s" % int(_OOM_RATE_MBPS))
    if rbits & 4: hit.append("ambient(device)")
    rec = {"had_oom": True, "reason": "+".join(hit) or "native", "ts": s["ts_ms"],
           "mem": m, "rate_mbps": round(s["rate_mbps"], 2),
           "thr_pct": _OOM_PCT, "thr_rate_mbps": _OOM_RATE_MBPS,
           "top": top, "native_total": s["cd_total"], "native_live": s["live_count"],
           "dropped": s["dropped"], "dropped_bytes": s["dropped_bytes"], "src": "native"}
    if direct_fields: rec.update(direct_fields)
    try:
        _g = _oom_gref_top()
        if _g: rec["gref"] = _g
    except Exception: pass
    try: rec["verdict"] = _oom_verdict(rec)
    except Exception: pass
    try:
        _mrv = rec.get("verdict")
        if isinstance(_mrv, dict) and _mrv.get("reason_detail") == "ambient_device_pressure":
            rec["culprit"] = "устройство (нехватка ОЗУ)"
            rec["pressure_source"] = "device"
            _mrv["culprit_display"] = "устройство (нехватка ОЗУ)"
            _mrv["pressure_source"] = "device"
    except Exception:
        pass
    try:
        _mrv = rec.get("verdict")
        if isinstance(_mrv, dict) and _mrv.get("reason_detail") in ("no_attribution", "untagged_dominates", "ambient_device_pressure", "untagged_edges_named"):
            _mrh = _mr_untagged_top_module(rec)
            if _mrh:
                _mrv["untagged_top_module"] = _mrh["module"]
                _mrv["untagged_top_module_bytes"] = _mrh["bytes"]
                _mrv["untagged_top_module_bucket"] = _mrh["bucket"]
                _mrv["untagged_top_module_role"] = "holder_hint"
                _mrv["untagged_top_module_owner"] = None
                _mrv["untagged_top_module_attribution"] = False
    except Exception:
        pass
    try:
        if rbits & 4:
            rec["event_type"] = "device_mem_pressure"; rec["dropbox_tag"] = "device_mem_pressure"
            rec["ambient"] = True; rec["scope"] = "device"
            rec["process_scoped"] = False; rec["oom_evidence"] = "device_meminfo_fallback"
        else:
            rec["event_type"] = "client_oom_leak"; rec["dropbox_tag"] = "client_oom_leak"
            rec["ambient"] = False; rec["scope"] = "process"; rec["process_scoped"] = True
        rec["tombstone_norm_version"] = 1
    except Exception: pass
    return rec

def _oom_native_emit(where):
    try:
        if not (_OOM_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_emit_snapshot")):
            return
        pth = _oom_path("oom_native_emit.json")
        if not pth:
            return
        tmp = pth + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
        _NLIB.cd_emit_snapshot(ctypes.c_char_p(tmp.encode("utf-8")),
                               ctypes.c_char_p(pth.encode("utf-8")),
                               ctypes.c_int32(1))
    except Exception:
        pass

def _oom_consume_native(where, do_log=True):
    p = _oom_sentinel_path()
    if not p: return None
    blob = None
    _rp = _rc_take_path(p)
    if not _rp: return None
    try:
        with open(_rp, "rb") as f:
            blob = f.read()
    except Exception:
        blob = None
    try:
        if os.path.exists(_rp): os.remove(_rp)
    except Exception:
        pass
    if not blob: return None
    s = _oom_decode_sentinel(blob)
    if not s: return None
    try: _oom_native_emit(where)
    except Exception: pass
    if where in ("live", "settings"):
        rec = _oom_sentinel_to_rec(s, merge_direct=True)
    elif where == "boot":
        _pm = _direct_premortem_read_and_clear()
        if _pm is not None:
            try:
                if abs(int(_pm.get("ts", 0)) - int(s.get("ts_ms", 0))) > 120000: _pm = None
            except Exception: pass
        rec = _oom_sentinel_to_rec(s, direct_snap=_pm)
    else:
        rec = _oom_sentinel_to_rec(s)
    global _OOM_MR_SLOTS
    _mr_sup = False
    try:
        if where == "live":
            _mrv = rec.get("verdict") or {}
            _mr_rd = str(_mrv.get("reason_detail"))
            if str(_mrv.get("culprit")) == _UNTAGGED_LABEL and _mr_rd in _OOM_MR_UNTAGGED_FAMILY:
                _mr_rd = "untagged_family"
            _mr_key = (str(_mrv.get("culprit")), _mr_rd, str(_mrv.get("confidence")),
                       str(rec.get("scope")), str(rec.get("event_type")))
            try: _mr_pb = int(float(rec.get("mem", {}).get("pct") or 0.0) * 20.0)
            except Exception: _mr_pb = 0
            _mr_m = _mr_esc_metrics(rec)
            _mr_p = _OOM_MR_SLOTS.get(_mr_key)
            _mr_esc = None
            if _mr_p:
                _mr_b = _mr_p.get("m") or {}
                _mr_e = []
                if _mr_pb > int(_mr_p.get("pb", -1)): _mr_e.append("pct")
                _mr_pr = float(_mr_b.get("rate") or 0.0)
                if _mr_m["rate"] >= _mr_pr * _OOM_REPEAT_ESC_RATE_X and (_mr_m["rate"] - _mr_pr) >= 1.0: _mr_e.append("rate")
                if _mr_m["display_b"] >= int(_mr_b.get("display_b") or 0) + _OOM_REPEAT_ESC_DISPLAY_B: _mr_e.append("display_bytes")
                if _mr_m["growth_b"] >= int(_mr_b.get("growth_b") or 0) + _OOM_REPEAT_ESC_GROWTH_B: _mr_e.append("growth_bytes")
                if _mr_m["untagged_b"] >= int(_mr_b.get("untagged_b") or 0) + _OOM_REPEAT_ESC_UNTAGGED_B: _mr_e.append("untagged_bytes")
                if _mr_m["holder"] != _mr_b.get("holder") and max(int(_mr_m.get("holder_b") or 0), int(_mr_b.get("holder_b") or 0)) >= _OOM_REPEAT_ESC_DISPLAY_B: _mr_e.append("holder")
                if _mr_m["top_named"] != _mr_b.get("top_named") and max(int(_mr_m.get("top_named_b") or 0), int(_mr_b.get("top_named_b") or 0)) >= _OOM_REPEAT_ESC_DISPLAY_B: _mr_e.append("top_named")
                if _mr_e: _mr_esc = ",".join(_mr_e)
            if (_mr_p and str(_mrv.get("confidence")) == "low" and _mr_p.get("key") == _mr_key
                    and _mr_esc is None
                    and (time.time() - float(_mr_p.get("t", 0.0))) < _OOM_REPEAT_COOLDOWN_S):
                _mr_sup = True
                _mr_p["n"] = int(_mr_p.get("n", 0)) + 1
                rec["repeat_suppressed"] = True
                rec["repeat_count"] = _mr_p["n"]
                _mr_h = _mr_p.get("hist")
                if not isinstance(_mr_h, dict):
                    _mr_h = {"first_ts": rec.get("ts"), "min_pct": None, "max_pct": None,
                             "min_rate_mbps": None, "max_rate_mbps": None,
                             "max_growth_bytes": 0, "max_display_bytes": 0, "max_untagged_bytes": 0,
                             "min_growth_bytes": None, "min_display_bytes": None, "min_untagged_bytes": None}
                    _mr_p["hist"] = _mr_h
                try: _mr_pct = round(float(rec.get("mem", {}).get("pct") or 0.0), 4)
                except Exception: _mr_pct = 0.0
                _mr_h["repeat_count"] = _mr_p["n"]
                _mr_h["last_ts"] = rec.get("ts")
                _mr_h["min_pct"] = _mr_pct if _mr_h.get("min_pct") is None else min(float(_mr_h["min_pct"]), _mr_pct)
                _mr_h["max_pct"] = _mr_pct if _mr_h.get("max_pct") is None else max(float(_mr_h["max_pct"]), _mr_pct)
                _mr_h["min_rate_mbps"] = _mr_m["rate"] if _mr_h.get("min_rate_mbps") is None else min(float(_mr_h["min_rate_mbps"]), _mr_m["rate"])
                _mr_h["max_rate_mbps"] = _mr_m["rate"] if _mr_h.get("max_rate_mbps") is None else max(float(_mr_h["max_rate_mbps"]), _mr_m["rate"])
                _mr_h["max_growth_bytes"] = max(int(_mr_h.get("max_growth_bytes") or 0), _mr_m["growth_b"])
                _mr_h["max_display_bytes"] = max(int(_mr_h.get("max_display_bytes") or 0), _mr_m["display_b"])
                _mr_h["max_untagged_bytes"] = max(int(_mr_h.get("max_untagged_bytes") or 0), _mr_m["untagged_b"])
                _mr_h["min_growth_bytes"] = _mr_m["growth_b"] if _mr_h.get("min_growth_bytes") is None else min(int(_mr_h["min_growth_bytes"]), _mr_m["growth_b"])
                _mr_h["min_display_bytes"] = _mr_m["display_b"] if _mr_h.get("min_display_bytes") is None else min(int(_mr_h["min_display_bytes"]), _mr_m["display_b"])
                _mr_h["min_untagged_bytes"] = _mr_m["untagged_b"] if _mr_h.get("min_untagged_bytes") is None else min(int(_mr_h["min_untagged_bytes"]), _mr_m["untagged_b"])
                rec["repeat_history"] = dict(_mr_h)
                _mr_n = int(_mr_p["n"])
                if _mr_n <= 2 or (_mr_n & (_mr_n - 1)) == 0:
                    rec["repeat_sample"] = True
            else:
                if _mr_p and _mr_p.get("key") == _mr_key and int(_mr_p.get("n", 0)) > 0:
                    if _mr_esc: rec["repeat_escalated"] = _mr_esc
                    if isinstance(_mr_p.get("hist"), dict):
                        rec["repeat_history"] = dict(_mr_p["hist"])
                _OOM_MR_SLOTS[_mr_key] = {"key": _mr_key, "t": time.time(), "pb": _mr_pb, "n": 0, "m": _mr_m}
                if len(_OOM_MR_SLOTS) > _OOM_MR_SLOTS_MAX:
                    try:
                        del _OOM_MR_SLOTS[min(_OOM_MR_SLOTS, key=lambda _sk: float(_OOM_MR_SLOTS[_sk].get("t", 0.0)))]
                    except Exception:
                        _OOM_MR_SLOTS.clear()
    except Exception:
        _mr_sup = False
    try: _oom_persist(rec)
    except Exception: pass
    if do_log:
        if _mr_sup:
            try:
                _log("PRE-OOM repeat suppressed (x%d%s): %s/%s conf=low pct=%.1f%% rate=%.1fМБ/с growth=%.1fМБ -- полная эмиссия после кулдауна либо эскалации (pct/rate/bytes/growth/holder)" % (int(rec.get("repeat_count") or 0), (" [sample]" if rec.get("repeat_sample") else ""), (rec.get("verdict") or {}).get("culprit"), (rec.get("verdict") or {}).get("reason_detail"), float(rec.get("mem", {}).get("pct") or 0.0) * 100.0, float(rec.get("rate_mbps") or 0.0), float((rec.get("verdict") or {}).get("growth_bytes") or 0) / 1048576.0))
            except Exception:
                pass
            if rec.get("repeat_sample"):
                try: _oom_log_dump(rec)
                except Exception: pass
        else:
            try:
                if rec.get("repeat_escalated"):
                    _log("PRE-OOM repeat ЭСКАЛАЦИЯ (%s) после x%d подавленных -- полная эмиссия" % (rec.get("repeat_escalated"), int((rec.get("repeat_history") or {}).get("repeat_count") or 0)))
            except Exception:
                pass
            try: _oom_log_dump(rec)
            except Exception: pass
    return rec

def _oom_consume_loop(stop_evt, evfd=-1, seq0=-1, trim0=-1, lowmem0=-1):
    last_seq = seq0
    last_trim_seq = trim0
    last_lowmem_seq = lowmem0
    if last_seq < 0:
        try:
            last_seq = int(_NLIB.cd_oom_seq()) if (_OOM_NATIVE_OK and _NLIB is not None) else 0
        except Exception:
            last_seq = 0
    if last_trim_seq < 0:
        try:
            last_trim_seq = int(_NLIB.cd_trim_seq()) if (_TRIM_NATIVE_OK and _NLIB is not None) else 0
        except Exception:
            last_trim_seq = 0
    if last_lowmem_seq < 0:
        try:
            last_lowmem_seq = int(_NLIB.cd_lowmem_seq()) if (_LOWMEM_NATIVE_OK and _NLIB is not None) else 0
        except Exception:
            last_lowmem_seq = 0
    if evfd < 0:
        try:
            evfd = int(_NLIB.cd_b6_eventfd())
        except Exception:
            evfd = -1
    try:
        _log("Block#6: режим 10s-idle + event-wake + 2s-boost (eventfd=%d, idle=%.0fs, boost=%.0fs/%.0fs)" % (evfd, _B6_IDLE_S, _B6_BOOST_S, _B6_BOOST_WINDOW_S))
    except Exception: pass
    boost_until = 0.0
    last_jt = 0.0
    last_full = 0.0
    while not stop_evt.is_set():
        try: ev = int(_NLIB.cd_b6_events_take())
        except Exception: ev = 0
        if not ev:
            _tn = time.monotonic()
            _until_full = max(0.0, _B6_IDLE_S - (_tn - last_full))
            _mode_wait = _B6_BOOST_S if _tn < boost_until else _B6_IDLE_S
            timo = min(_mode_wait, _until_full)
            try:
                if select.select([evfd], [], [], timo)[0]:
                    try: os.read(evfd, 8)
                    except Exception: pass
            except Exception:
                stop_evt.wait(timo)
            if stop_evt.is_set(): break
            try: ev = int(_NLIB.cd_b6_events_take())
            except Exception: ev = 0
        if ev & 0x17:
            boost_until = time.monotonic() + _B6_BOOST_WINDOW_S
        now = time.monotonic()
        do_full = (now - last_full) >= _B6_IDLE_S
        if do_full:
            last_full = now
        do_jheap = do_full or now < boost_until
        do_kill = do_full or bool(ev & 16)
        do_leak = do_full or bool(ev & 8)
        do_trim = do_full or bool(ev & 2)
        do_lowmem = do_full or bool(ev & 4)
        do_oom = do_full or bool(ev & 1)
        if do_jheap:
            _gil_begin(_GIL_B6_JHEAP)
            try:
                _oom_check_java_heap()
            except Exception: pass
            _gil_end(_GIL_B6_JHEAP)
        if do_kill:
            _gil_begin(_GIL_B6_KILL)
            try:
                _oom_check_killcount("live")
            except Exception: pass
            _gil_end(_GIL_B6_KILL)
        if do_leak:
            _gil_begin(_GIL_B6_LEAK)
            try:
                _leak_check("live")
            except Exception: pass
            _gil_end(_GIL_B6_LEAK)
        if do_trim:
            try:
                if _TRIM_NATIVE_OK and _NLIB is not None and _OOM_CLIENT_KILL_STATE.get("trim_native"):
                    tseq = int(_NLIB.cd_trim_seq())
                    if tseq != last_trim_seq:
                        last_trim_seq = tseq
                        try: _lv = int(_NLIB.cd_trim_level())
                        except Exception: _lv = -1
                        if _lv < 0 or _lv >= 15:
                            _gil_begin(_GIL_B6)
                            try:
                                _client_lowmem_note("onTrimMemory", _lv,
                                    "система просит освободить память (onTrimMemory level=%d)" % _lv)
                            except Exception: pass
                            _gil_end(_GIL_B6)
            except Exception as _et:
                try: _log(f"Block#6C trim consume err: {_et}")
                except Exception: pass
        if do_lowmem:
            try:
                if _LOWMEM_NATIVE_OK and _NLIB is not None and _OOM_CLIENT_KILL_STATE.get("lowmem_native"):
                    lseq = int(_NLIB.cd_lowmem_seq())
                    if lseq != last_lowmem_seq:
                        last_lowmem_seq = lseq
                        _gil_begin(_GIL_B6)
                        try:
                            _client_lowmem_note("onLowMemory", "low",
                                "система сообщила о критической нехватке памяти (onLowMemory)")
                        except Exception: pass
                        _gil_end(_GIL_B6)
            except Exception as _el:
                try: _log(f"Block#6CL lowmem consume err: {_el}")
                except Exception: pass
        if do_full:
            try:
                _gil_begin(_GIL_B6)
                try: _b10_passive_flush_if_dirty()
                except Exception: pass
                _gil_end(_GIL_B6)
            except Exception: pass
        if do_oom:
            try:
                if _OOM_NATIVE_OK and _NLIB is not None:
                    seq = int(_NLIB.cd_oom_seq())
                    if seq != last_seq:
                        last_seq = seq
                        _gil_begin(_GIL_B6)
                        try:
                            _oom_consume_native("live", do_log=True)
                        finally:
                            _gil_end(_GIL_B6)
            except Exception as e:
                try: _log(f"Block#6 consume err: {e}")
                except Exception: pass
        try:
            jt = float(_OOM_CLIENT_KILL_STATE.get("last_jheap_ts", 0.0))
            if jt != last_jt:
                last_jt = jt
                if jt: boost_until = time.monotonic() + _B6_BOOST_WINDOW_S
        except Exception: pass


_OOM_CLIENT_KILL_STATE = {"last_jheap_ts": 0.0, "trim_native": False, "lowmem_native": False}

def _proc_oom_score():
    adj = None; score = None
    try:
        with open("/proc/self/oom_score_adj", "r") as f:
            adj = int(f.read().strip())
    except Exception:
        adj = None
    try:
        with open("/proc/self/oom_score", "r") as f:
            score = int(f.read().strip())
    except Exception:
        score = None
    return adj, score

def _oom_killcount_now():
    try:
        if _OOM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_oom_killcount"):
            v = int(_NLIB.cd_oom_killcount())
            return v if v >= 0 else None
    except Exception:
        pass
    return None

def _oom_killcount_read_stored():
    try:
        p = _oom_path(_OOM_KILLCOUNT_FILE)
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return int(json.load(f).get("count", -1))
    except Exception:
        pass
    return None

def _oom_killcount_store(n):
    try:
        p = _oom_path(_OOM_KILLCOUNT_FILE)
        if p: _atomic_json_write(p, {"count": int(n), "ts": int(time.time())})
    except Exception:
        pass

def _client_kill_verdict(prev, cur, where):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_oom_killed", "dropbox_tag": "client_oom_killed", "tombstone_norm_version": 1,
            "had_oom": True, "had_client_oom": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "high",
            "reason": "ядро/LMK убило процесс по нехватке памяти (oom_kill %d→%d)" % (prev, cur),
            "where": where,
            "kill_prev": int(prev), "kill_cur": int(cur), "kill_delta": int(cur - prev),
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_CLIENT_KILL_NAME)
        if p: _atomic_json_write(p, rec)
        _log("================ CLIENT OOM-KILL ================")
        _log("CLIENT OOM-KILL: where=%s oom_kill %d->%d (delta=%d) oom_score_adj=%s oom_score=%s java=%s/%s" % (
            where, prev, cur, cur - prev, adj, score, ju, jm))
        _log("=================================================")
    except Exception as e:
        try: _log("Block#6A client-kill verdict err: %s" % e)
        except Exception: pass

def _oom_check_killcount(where):
    cur = _oom_killcount_now()
    if cur is None: return
    prev = _oom_killcount_read_stored()
    if prev is not None and cur > prev:
        _client_kill_verdict(prev, cur, where + ": cgroup oom_kill")
    if prev is None or cur != prev:
        _oom_killcount_store(cur)

def _client_lowmem_note(source, level, detail):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_mem_pressure", "dropbox_tag": "client_mem_pressure", "tombstone_norm_version": 1,
            "had_client_lowmem": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "medium",
            "reason": detail, "where": source, "trim_level": level,
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_TRIM_NAME)
        if p: _atomic_json_write(p, rec)
        _log("CLIENT LOW-MEM: src=%s level=%s java=%s/%s oom_score=%s :: %s" % (
            source, level, ju, jm, score, detail))
    except Exception as e:
        try: _log("Block#6BC lowmem note err: %s" % e)
        except Exception: pass

def _recent_client_lowmem(max_age_ms=180000):
    try:
        p = _oom_path(_OOM_TRIM_NAME)
        if not (p and os.path.exists(p)):
            return None
        with open(p, "r", encoding="utf-8") as f:
            r = json.load(f)
        if not isinstance(r, dict):
            return None
        ts = r.get("ts")
        if ts is not None:
            try:
                if (time.time() - float(ts)) * 1000.0 > max_age_ms:
                    return None
            except Exception:
                pass
        return {"trim_level": r.get("trim_level"), "oom_score_adj": r.get("oom_score_adj"),
                "oom_score": r.get("oom_score"), "where": r.get("where"), "ts": ts}
    except Exception:
        return None

def _recent_oom_dump(max_age_ms=8000):
    try:
        p = _oom_path(_OOM_FILE_NAME)
        if not (p and os.path.exists(p)):
            return None
        with open(p, "r", encoding="utf-8") as f:
            r = json.load(f)
        if not isinstance(r, dict):
            return None
        ts = r.get("ts")
        if ts is not None:
            try:
                _age = (time.time() * 1000.0) - float(ts)
                if _age < 0 or _age > max_age_ms:
                    return None
            except Exception:
                pass
        _vd = r.get("verdict") if isinstance(r.get("verdict"), dict) else {}
        return {"culprit": (r.get("culprit") or _vd.get("culprit") or _vd.get("top_named")),
                "pressure_source": (r.get("pressure_source") or _vd.get("pressure_source")),
                "rate_mbps": r.get("rate_mbps"),
                "confidence": _vd.get("confidence"), "ts": ts}
    except Exception:
        return None

def _oom_check_java_heap():
    try:
        now = time.time()
        if (now - _OOM_CLIENT_KILL_STATE.get("last_jheap_ts", 0.0)) < _OOM_JHEAP_COOLDOWN_S:
            return
        ju, jm, _ = _java_mem()
        if ju > 0 and jm > 0 and (float(ju) / float(jm)) >= _OOM_JHEAP_PCT:
            _OOM_CLIENT_KILL_STATE["last_jheap_ts"] = now
            frac = float(ju) / float(jm)
            _client_lowmem_note("ART/Java-heap", "java_heap",
                "Java-куча у предела: %.0f%% (%d/%d МБ) — близко к OutOfMemoryError" % (
                    frac * 100.0, ju // 1048576, jm // 1048576))
    except Exception:
        pass

def _trim_native_unavailable_marker(detail):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_trim_unavailable", "dropbox_tag": "client_trim_unavailable", "tombstone_norm_version": 1,
            "had_client_trim_unavailable": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "low",
            "reason": "нативный off-GIL onTrimMemory interceptor не установился — обработка onTrimMemory отключена (no-op); Python-фолбэк (dynamic_proxy) удалён в 1.4.46/0.9.387 [%s]" % detail,
            "where": "onTrimMemory (native install unavailable)",
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_TRIM_UNAVAIL_NAME)
        if p: _atomic_json_write(p, rec)
    except Exception as _em:
        try: _log("Block#6C trim-unavail marker err: %s" % _em)
        except Exception: pass

def _lowmem_native_unavailable_marker(detail):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_lowmem_unavailable", "dropbox_tag": "client_lowmem_unavailable", "tombstone_norm_version": 1,
            "had_client_lowmem_unavailable": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "low",
            "reason": "нативный off-GIL onLowMemory interceptor не установился — onLowMemory отключён (no-op); Python-фолбэк (dynamic_proxy) удалён в 1.4.46/0.9.387 [%s]" % detail,
            "where": "onLowMemory (native install unavailable)",
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_LOWMEM_UNAVAIL_NAME)
        if p: _atomic_json_write(p, rec)
    except Exception as _em:
        try: _log("Block#6CL lowmem-unavail marker err: %s" % _em)
        except Exception: pass

def _b6_register_lowmem_native():
    try:
        if _LOWMEM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_lowmem_install"):
            m = int(_NLIB.cd_lowmem_install(0))
            if m > 0:
                _OOM_CLIENT_KILL_STATE["lowmem_native"] = True
                _log("Block#6CL: onLowMemory -> нативный off-GIL interceptor=%d (handleLowMemory, GIL-free, без Python-bounce на UI)" % m)
                return
            _lowmem_native_unavailable_marker("cd_lowmem_install=%d" % m)
            _log("Block#6CL: нативный lowmem interceptor n=%d -> onLowMemory no-op (handleLowMemory не JIT-скомпилирован; маркер в вердикт)" % m)
            return
    except Exception as _eln:
        try:
            _lowmem_native_unavailable_marker("cd_lowmem_install err: %s" % _eln)
            _log("Block#6CL native lowmem install err: %s -> onLowMemory no-op (маркер в вердикт)" % _eln)
        except Exception: pass
        return
    if _NLIB is None:
        _lu_detail = "lib handle missing (_NLIB=None, _LOWMEM_NATIVE_OK=%s)" % _LOWMEM_NATIVE_OK
    elif not _LOWMEM_NATIVE_OK:
        _lu_detail = "native symbol absent (cd_lowmem_install not in .so, _LOWMEM_NATIVE_OK=False)"
    else:
        _lu_detail = "cd_lowmem_install symbol not bound (_LOWMEM_NATIVE_OK=True, hasattr=False)"
    _lowmem_native_unavailable_marker("native lowmem unavailable: %s" % _lu_detail)
    _log("Block#6CL: нативный lowmem недоступен (%s) -> onLowMemory no-op (маркер в вердикт)" % _lu_detail)

def _b6_register_trim_callbacks():
    try:
        if _TRIM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_trim_install"):
            n = int(_NLIB.cd_trim_install(0))
            if n > 0:
                _OOM_CLIENT_KILL_STATE["trim_native"] = True
                _log("Block#6C: onTrimMemory -> нативный off-GIL interceptor=%d (handleTrimMemory, GIL-free, без Python-bounce на UI)" % n)
            else:
                _trim_native_unavailable_marker("cd_trim_install=%d" % n)
                _log("Block#6C: нативный trim interceptor n=%d -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % n)
        else:
            if _NLIB is None:
                _tu_detail = "lib handle missing (_NLIB=None, _TRIM_NATIVE_OK=%s)" % _TRIM_NATIVE_OK
            elif not _TRIM_NATIVE_OK:
                _tu_detail = "native symbol absent (cd_trim_install not in .so, _TRIM_NATIVE_OK=False)"
            else:
                _tu_detail = "cd_trim_install symbol not bound (_TRIM_NATIVE_OK=True, hasattr=False)"
            _trim_native_unavailable_marker("native trim unavailable: %s" % _tu_detail)
            _log("Block#6C: нативный trim недоступен (%s) -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % _tu_detail)
    except Exception as _etn:
        try:
            _trim_native_unavailable_marker("cd_trim_install err: %s" % _etn)
            _log("Block#6C native trim install err: %s -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % _etn)
        except Exception: pass
    try:
        _b6_register_lowmem_native()
    except Exception as _elr:
        try: _log("Block#6CL lowmem register err: %s" % _elr)
        except Exception: pass
    return None

def _b6_unregister_trim_callbacks():
    try:
        if _OOM_CLIENT_KILL_STATE.get("trim_native"):
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_trim_unhook"):
                    _NLIB.cd_trim_unhook()
            except Exception: pass
            _OOM_CLIENT_KILL_STATE["trim_native"] = False
            _log("Block#6C: нативный onTrimMemory interceptor снят")
    except Exception as e:
        try: _log("Block#6C trim unregister err: %s" % e)
        except Exception: pass
    try:
        if _OOM_CLIENT_KILL_STATE.get("lowmem_native"):
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_lowmem_unhook"):
                    _NLIB.cd_lowmem_unhook()
            except Exception: pass
            _OOM_CLIENT_KILL_STATE["lowmem_native"] = False
            _log("Block#6CL: нативный onLowMemory interceptor снят")
    except Exception as e2:
        try: _log("Block#6CL lowmem unregister err: %s" % e2)
        except Exception: pass

_LEAK_NAME = "client_leak.json"
_NA_NAME = "native_alloc_sites.json"
_NA_SAMPLE_ENABLE = True
_NA_MIN_BYTES = 8192
_NA_NATIVE_OK = False
_LEAK_NATIVE_OK = False
_LEAK_DIM_KEYS = ("rss", "java", "native", "fd", "threads")
_LEAK_DIM_NAMES = {"rss": "RSS", "java": "Java-heap", "native": "native-heap",
                   "fd": "descriptors (fd)", "threads": "threads"}
_LEAK_BYTE_DIMS = ("rss", "java", "native")
_LEAK_SNAP_HEAD = 3
_LEAK_SNAP_PER = 7
_LEAK_STATE = {"last_seq": 0}
_LEAK_SEG_KEYS = ("summary.java-heap", "summary.native-heap", "summary.graphics",
                  "summary.stack", "summary.code", "summary.system",
                  "summary.total-pss", "summary.total-swap")
_LEAK_SEG_LABELS = {"summary.java-heap": "java-heap", "summary.native-heap": "native-heap",
                    "summary.graphics": "graphics", "summary.stack": "stack",
                    "summary.code": "code", "summary.system": "system",
                    "summary.total-pss": "total-pss", "summary.total-swap": "total-swap"}
_LEAK_SEG_TOP_SKIP = ("total-pss", "total-swap")
_LEAK_SEG_RING = []
_LEAK_SEG_MIN_GAP_MS = 25000
_LEAK_SEG_RING_MAX = 160

def _leak_seg_read(g=None, roll=None):
    try:
        if g is None:
            g = _smaps_scan_native()
        if not g:
            return None
        def _p(name):
            v = g.get(name)
            return int(v["pss"]) if v else 0
        java_heap = _p("dalvik-heap")
        native_heap = _p("native-malloc")
        graphics = _p("gfx-gpu") + _p("gfx-dmabuf")
        stack = _p("thread-stack")
        code = _p("code-so") + _p("code-dex-oat-art") + _p("code-apk")
        if roll is None:
            roll = _smaps_rollup_native()
        total_pss = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
        total_swap = int(roll["swap"]) if roll else sum(int(v["swap"]) for v in g.values())
        system = total_pss - (java_heap + native_heap + graphics + stack + code)
        if system < 0: system = 0
        return {"summary.java-heap": java_heap, "summary.native-heap": native_heap,
                "summary.graphics": graphics, "summary.stack": stack,
                "summary.code": code, "summary.system": system,
                "summary.total-pss": total_pss, "summary.total-swap": total_swap}
    except Exception:
        return None

def _leak_seg_sample():
    try:
        now = int(time.time() * 1000)
        if _LEAK_SEG_RING and (now - _LEAK_SEG_RING[-1][0]) < _LEAK_SEG_MIN_GAP_MS:
            return
        segs = _leak_seg_read()
        if not segs:
            return
        _LEAK_SEG_RING.append((now, segs))
        if len(_LEAK_SEG_RING) > _LEAK_SEG_RING_MAX:
            del _LEAK_SEG_RING[:len(_LEAK_SEG_RING) - _LEAK_SEG_RING_MAX]
    except Exception:
        pass

def _leak_seg_delta(span_s):
    try:
        if len(_LEAK_SEG_RING) < 2:
            return None
        now, cur = _LEAK_SEG_RING[-1][0], _LEAK_SEG_RING[-1][1]
        target = now - int(float(span_s or 0) * 1000)
        base_t, base = _LEAK_SEG_RING[0][0], _LEAK_SEG_RING[0][1]
        for t, segs in _LEAK_SEG_RING:
            if t <= target:
                base_t, base = t, segs
            else:
                break
        out = {"baseline_age_ms": now - base_t, "n_samples": len(_LEAK_SEG_RING),
               "span_s": (now - base_t) / 1000.0, "segments": {}}
        best_name, best_growth = None, None
        for k in _LEAK_SEG_KEYS:
            f, l = base.get(k), cur.get(k)
            if f is None or l is None:
                continue
            lbl = _LEAK_SEG_LABELS.get(k, k)
            g = l - f
            out["segments"][lbl] = {"first": f, "last": l, "growth": g}
            if lbl not in _LEAK_SEG_TOP_SKIP and (best_growth is None or g > best_growth):
                best_name, best_growth = lbl, g
        if best_name is not None:
            out["top"] = {"segment": best_name, "growth": best_growth}
        return out if out["segments"] else None
    except Exception:
        return None

def _leak_feed_java():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        ju, jm, _nh = _java_mem()
        if ju is None:
            return
        _NLIB.cd_leak_feed_java(ctypes.c_int64(int(ju)),
                                ctypes.c_int64(int(jm) if jm else -1))
    except Exception:
        pass

def _leak_read_native_snap():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return None
        n = int(_NLIB.cd_leak_slots())
        if n <= 0 or n > 4096:
            return None
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_leak_read(arr, ctypes.c_int32(n)))
        if got < _LEAK_SNAP_HEAD:
            return None
        vals = [int(arr[i]) for i in range(got)]
        ts_ms, flags, dimn = vals[0], vals[1], vals[2]
        dims = []
        for d in range(dimn):
            base = _LEAK_SNAP_HEAD + d * _LEAK_SNAP_PER
            if base + _LEAK_SNAP_PER > got:
                break
            key = _LEAK_DIM_KEYS[d] if d < len(_LEAK_DIM_KEYS) else ("dim%d" % d)
            dims.append({"dim": key, "leaking": bool(flags & (1 << d)),
                         "first": vals[base + 0], "last": vals[base + 1],
                         "slope_per_s": vals[base + 2] / 1000.0,
                         "r2": vals[base + 3] / 1000.0,
                         "growth": vals[base + 4], "n": vals[base + 5],
                         "span_s": vals[base + 6] / 1000.0})
        return {"ts_ms": ts_ms, "flags": flags, "dims": dims}
    except Exception as e:
        try: _log("Block#6D snap read err: %s" % e)
        except Exception: pass
        return None

def _leak_fmt_amount(dim, v):
    try:
        if dim in _LEAK_BYTE_DIMS:
            return "%.1f MB" % (float(v) / (1024.0 * 1024.0))
        return str(int(v))
    except Exception:
        return str(v)

def _leak_mem_snapshot():
    snap = {}
    try:
        g = _smaps_scan_native()
        if g:
            def _p(name):
                v = g.get(name)
                return int(v["pss"]) if v else 0
            roll = _smaps_rollup_native()
            dalvik = _p("dalvik-heap")
            native = _p("native-malloc")
            total = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
            other = total - dalvik - native
            if other < 0: other = 0
            snap["pss"] = {"dalvik": dalvik, "native": native, "other": other, "total": total}
            seg = _leak_seg_read(g, roll)
            if seg: snap["memstat"] = seg
    except Exception: pass
    try:
        kinds = {}
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            kinds[kk] = kinds.get(kk, 0) + 1
        if kinds: snap["fd_by_kind"] = kinds
    except Exception: pass
    return snap

_LEAK_PEAK_NAME = "client_leak_peak.json"
_LEAK_PEAK_MIN_GAP_MS = 60000
_LEAK_PEAK_STATE = {"last_ms": 0}
_SMAPS_NATIVE_GROUPS = ("native-malloc", "gfx-gpu", "gfx-dmabuf", "shmem-ashmem",
                        "code-so", "code-dex-oat-art", "code-apk", "fonts",
                        "dalvik-heap", "thread-stack", "file-other", "anon-other",
                        "anon-private")
_SMAPS_NATIVE_FIELDS = 4
_SMAPS_NATIVE_LAYOUT_VERSION = 1

def _smaps_scan_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        n = len(_SMAPS_NATIVE_GROUPS) * _SMAPS_NATIVE_FIELDS
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_smaps_groups(arr, ctypes.c_int32(n)))
        if got < n:
            return None
        out = {}
        for i, name in enumerate(_SMAPS_NATIVE_GROUPS):
            b = i * _SMAPS_NATIVE_FIELDS
            out[name] = {"rss": int(arr[b + 0]), "pss": int(arr[b + 1]),
                         "swap": int(arr[b + 2]), "n": int(arr[b + 3])}
        return out
    except Exception:
        return None

def _smaps_rollup_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        arr = (ctypes.c_int64 * 3)()
        got = int(_NLIB.cd_smaps_rollup(arr, ctypes.c_int32(3)))
        if got < 3:
            return None
        return {"pss": int(arr[0]), "rss": int(arr[1]), "swap": int(arr[2])}
    except Exception:
        return None

def _smaps_top_groups(limit=14):
    g = _smaps_scan_native()
    if not g:
        return None
    items = [(k, v) for k, v in g.items() if (v["rss"] or v["pss"] or v["swap"] or v["n"])]
    if not items:
        return None
    items.sort(key=lambda kv: kv[1].get("pss", 0), reverse=True)
    return [{"group": k, "rss": v["rss"], "pss": v["pss"], "swap": v["swap"], "maps": v["n"]}
            for k, v in items[:limit]]

def _smaps_rollup_text():
    try:
        with open("/proc/self/smaps_rollup", "r") as f:
            return f.read()[:4096]
    except Exception:
        return None

def _leak_fd_detail():
    out = {"by_kind": {}, "by_target": {}}
    try:
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            out["by_kind"][kk] = out["by_kind"].get(kk, 0) + 1
            if tgt.startswith("anon_inode:"):
                tb = "anon_inode:" + tgt[11:].strip("[]").split(":")[0][:24]
            elif tgt.startswith("/dev/"):
                tb = "/dev/" + tgt[5:].split("/")[0]
            elif tgt.startswith("/"):
                dot = tgt.rfind(".")
                tb = ("ext:" + tgt[dot:][:8]) if dot > tgt.rfind("/") else "file-other"
            elif tgt.startswith("socket:") or tgt.startswith("pipe:"):
                tb = kk
            else:
                tb = "other"
            out["by_target"][tb] = out["by_target"].get(tb, 0) + 1
    except Exception:
        pass
    try:
        tt = sorted(out["by_target"].items(), key=lambda kv: kv[1], reverse=True)[:15]
        out["by_target"] = dict(tt)
    except Exception:
        pass
    return out

def _dumpsys_meminfo_text():
    proc = None; rdr = None
    try:
        pid = os.getpid()
        Runtime = jclass("java.lang.Runtime")
        proc = Runtime.getRuntime().exec(["sh", "-c", "dumpsys meminfo %d 2>&1" % pid])
        ins = proc.getInputStream()
        rdr = jclass("java.io.BufferedReader")(jclass("java.io.InputStreamReader")(ins))
        sb = []; n = 0
        while n < 400:
            ln = rdr.readLine()
            if ln is None: break
            sb.append(str(ln)); n += 1
        txt = "\n".join(sb)
        return txt[:8192] if txt.strip() else None
    except Exception:
        return None
    finally:
        if rdr is not None:
            try: rdr.close()
            except Exception: pass
        if proc is not None:
            try: proc.getOutputStream().close()
            except Exception: pass
            try: proc.getErrorStream().close()
            except Exception: pass
            try: proc.destroy()
            except Exception: pass

def _leak_peak_capture(where, rec):
    try:
        now = int(time.time() * 1000)
        if (now - _LEAK_PEAK_STATE.get("last_ms", 0)) < _LEAK_PEAK_MIN_GAP_MS:
            return
        _LEAK_PEAK_STATE["last_ms"] = now
        cap = {"type": "client_leak_peak", "ts": now, "where": where,
               "leaking_dims": rec.get("leaking_dims"),
               "confidence": rec.get("confidence"),
               "rss_top_segment": rec.get("rss_top_segment"),
               "meminfo": _leak_mem_snapshot(),
               "smaps_rollup": _smaps_rollup_text(),
               "smaps_top_groups": _smaps_top_groups(),
               "fd_detail": _leak_fd_detail(),
               "dumpsys_meminfo": _dumpsys_meminfo_text()}
        p = _oom_path(_LEAK_PEAK_NAME)
        if p: _atomic_json_write(p, cap)
        try:
            tg = cap.get("smaps_top_groups") or []
            top = ", ".join("%s=%.1fMB" % (g["group"], g["pss"] / 1048576.0) for g in tg[:5])
            _log("Block#6D peak-capture -> %s | top smaps: %s" % (_LEAK_PEAK_NAME, top))
        except Exception:
            pass
    except Exception as e:
        try: _log("Block#6D peak-capture err: %s" % e)
        except Exception: pass

_NA_CLIENT_LIBS = ("libtmessages", "libetgadblock", "libculprit", "libvosk", "libmaps-mobile", "libimage_processing_util_jni", "liblanguage_id_l2c_jni", "libsurface_util_jni", "libjnidispatch", "libshadowhook", "libdatastore_shared_counter", "libchaquopy_java", "libpython", "libsqlite3_chaquopy", "libsqlite3_python", "libcrypto_chaquopy", "libcrypto_python", "libssl_chaquopy", "libssl_python")
_NA_GFX_LIBS = ("vulkan", "adreno", "libgsl", "libllvm-glnext", "libEGL", "libGLES", "libvulkan", "libVK", "mali", "libgpu", "powervr", "libhwui", "libskia", "libgui", "librenderengine", "libnativewindow", "libjnigraphics")

def _na_frame_cat(fr):
    try:
        m = fr.split("+", 1)[0]
    except Exception:
        return None
    for pfx in _NA_CLIENT_LIBS:
        if m.startswith(pfx):
            return "app"
    for pfx in _NA_GFX_LIBS:
        if m.startswith(pfx):
            return "gfx"
    return None

_NA_GFX_FAMILY_MIN = 3
_NA_TOPBUCKET_MIN_BYTES = 2 * 1024 * 1024
_NA_EPOCH_MS = 0
_NA_EPOCH_MIN_AGE_S = 30.0
_NA_DROPS_UNDERSAMPLE_MIN = 5000
_NA_DROPS_UNDERSAMPLE_FRAC = 0.05
_NA_COVERAGE_LOW = 0.25
_NA_XVAL_MIN_GROWTH = 8 * 1024 * 1024

def _na_mark_epoch():
    global _NA_EPOCH_MS
    try: _NA_EPOCH_MS = int(time.time() * 1000)
    except Exception: _NA_EPOCH_MS = 0


def _na_mod_label(frame):
    try:
        m = frame.split("+", 1)[0]
    except Exception:
        return None
    if not m:
        return None
    if m.endswith(".so"):
        m = m[:-3]
    _p = m.rsplit(".", 1)
    if len(_p) == 2 and _p[1].isdigit():
        m = _p[0]
    return m or None

def _na_top_bucket_summary():
    try:
        p = _oom_path(_NA_NAME)
        if not p or not os.path.exists(p):
            return None
        with open(p, "r", encoding="utf-8") as _f:
            d = json.load(_f)
    except Exception:
        return None
    sites = d.get("sites")
    if not isinstance(sites, list) or not sites:
        return None
    agg = {}
    gfx_frame = {}
    for s in sites:
        try:
            frames = s.get("frames") or []
            bucket = s.get("bucket") or "app"
            rb = int(s.get("retained_bytes") or 0)
        except Exception:
            continue
        if rb <= 0 or not frames:
            continue
        mod = None
        for fr in frames:
            c = _na_frame_cat(fr)
            if (bucket == "app" and c == "app") or (bucket == "gfx" and c == "gfx"):
                mod = _na_mod_label(fr); break
        if not mod:
            mod = _na_mod_label(frames[0]) or "?"
        label = ("%s/%s" % (bucket, mod)) if bucket == "gfx" else mod
        e = agg.get(label)
        if e is None:
            agg[label] = [rb, 1, bucket, mod]
        else:
            e[0] += rb; e[1] += 1
        if bucket == "gfx":
            tf = frames[0]
            g = gfx_frame.get(tf)
            if g is None:
                gfx_frame[tf] = [1, rb]
            else:
                g[0] += 1; g[1] += rb
    if not agg:
        return None
    order = sorted(agg.items(), key=lambda kv: kv[1][0], reverse=True)
    modules = []
    for label, (b, n, bucket, mod) in order:
        if b < _NA_TOPBUCKET_MIN_BYTES:
            continue
        modules.append({"label": label, "module": mod, "bucket": bucket, "bytes": b, "sites": n})
        if len(modules) >= 3:
            break
    parts = []
    for _i, _m in enumerate(modules):
        _mb = _m["bytes"] / 1048576.0
        parts.append(("%s dominant (~%.0fMB)" if _i == 0 else "%s (~%.0fMB)") % (_m["label"], _mb))
    display = ("host_native: " + " + ".join(parts)) if parts else None
    leak_family = None; gfx_family = None
    if gfx_frame:
        _tf, (_cnt, _b) = max(gfx_frame.items(), key=lambda kv: kv[1][0])
        if _cnt >= _NA_GFX_FAMILY_MIN:
            leak_family = "hwui_gfx"
            gfx_family = {"top_frame": _tf, "sites": _cnt, "bytes": _b}
    _stats = None; _under = False; _ureas = None; _eage = None
    try:
        _lsb = int(d.get("live_sampled_bytes") or 0)
        _samp = int(d.get("sampled_allocs") or 0)
        _drops = int(d.get("table_full_drops") or 0)
        _uniq = int(d.get("unique_stacks") or 0)
        _stats = {"live_sampled_bytes": _lsb, "sampled_allocs": _samp,
                  "table_full_drops": _drops, "unique_stacks": _uniq,
                  "min_bytes": int(d.get("min_bytes") or 0)}
        _denom = _samp + _drops
        _dfrac = (float(_drops) / float(_denom)) if _denom > 0 else 0.0
        if _drops >= _NA_DROPS_UNDERSAMPLE_MIN and _dfrac >= _NA_DROPS_UNDERSAMPLE_FRAC:
            _under = True
            _ureas = "table_full_drops=%d (%.0f%% of inserts) -> alloc-site table saturated, sites truncated" % (_drops, _dfrac * 100.0)
        if _NA_EPOCH_MS > 0:
            _eage = max(0.0, (time.time() * 1000 - _NA_EPOCH_MS) / 1000.0)
            if _eage < _NA_EPOCH_MIN_AGE_S:
                _under = True
                _er2 = "alloc-site epoch reset %.0fs ago (recent detector reload) -> cold table" % _eage
                _ureas = (_ureas + "; " + _er2) if _ureas else _er2
    except Exception:
        pass
    return {"display": display, "modules": modules, "leak_family": leak_family, "gfx_family": gfx_family,
            "sampled_stats": _stats, "undersampled": _under, "undersample_reason": _ureas, "epoch_age_s": _eage}

_JR_HOST_LIB_HINTS = ("libhwui", "libtmessages", "libc.so", "libc++", "libjemalloc", "libegl", "libgles", "vulkan", "adreno", "gralloc", "libgui", "libui", "libandroid", "libutils", "libskia", "librs", "libbinder", "libcutils", "libft2", "libharfbuzz", "libsqlite", "libz.so", "libunwind", "libbase", "libnativewindow", "dmabuf", "ashmem", "libmali", "libopencl")
_JR_PYRT_LIB_HINTS = ("libpython", "libchaquopy", "chaquopy", "libpycore")
_JR_NATIVE_HOST_SHARE = 0.80
_JR_PLUGIN_NATIVE_MIN_BYTES = 4194304
_B28C_UNTAG_AMBIENT_LO = 0.60
_OOM_PREV_EMIT = None
_OOM_GROWTH_FRESH_MS = 180000
_OOM_GROWTH_MIN_BYTES = 4 * 1024 * 1024
_OOM_REPEAT_COOLDOWN_S = 600.0
_OOM_REPEAT_ESC_RATE_X = 1.5
_OOM_REPEAT_ESC_DISPLAY_B = 16 * 1048576
_OOM_REPEAT_ESC_GROWTH_B = 8 * 1048576
_OOM_REPEAT_ESC_UNTAGGED_B = 32 * 1048576
_OOM_MR_SLOTS = {}
_OOM_MR_SLOTS_MAX = 6  # +NL(2): максимум независимых repeat-слотов (ключ: culprit/family/conf/scope/event_type)
_OOM_TAGGED_HEADLINE_MIN_SHARE = 0.10
_LEAK_LAST_KIND = {}

def _jr_native_host_split(ns):
    try:
        if not ns or not ns.get("modules"):
            return (0, 0, 0.0)
        host_b = 0; pyrt_b = 0; other_b = 0
        for m in (ns.get("modules") or []):
            try: b = int(m.get("bytes") or 0)
            except Exception: b = 0
            if b <= 0:
                continue
            mod = (m.get("module") or "").lower()
            bucket = m.get("bucket") or "app"
            if any(h in mod for h in _JR_PYRT_LIB_HINTS):
                pyrt_b += b
            elif (bucket == "gfx") or any(h in mod for h in _JR_HOST_LIB_HINTS):
                host_b += b
            else:
                other_b += b
        hostish = host_b + other_b
        tot = hostish + pyrt_b
        sh = (float(hostish) / float(tot)) if tot > 0 else 0.0
        return (hostish, pyrt_b, sh)
    except Exception:
        return (0, 0, 0.0)

_NA_OTHER_TOPN = 40

def _na_filter_client(path):
    try:
        with open(path, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        sites = d.get("sites")
        if not isinstance(sites, list):
            return None
        kept = []; other = []
        for s in sites:
            frames = s.get("frames") or []
            cat = None
            for fr in frames:
                c = _na_frame_cat(fr)
                if c == "app":
                    cat = "app"; break
                if c == "gfx" and cat is None:
                    cat = "gfx"
            if cat:
                s["bucket"] = cat
                kept.append(s)
            else:
                other.append(s)
        def _rb(x):
            try: return int(x.get("retained_bytes") or 0)
            except Exception: return 0
        try:
            kept.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(kept): _s["rank"] = _i + 1
        except Exception: pass
        try:
            other.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(other): _s["rank"] = _i + 1
        except Exception: pass
        kept_bytes = 0
        for _s in kept: kept_bytes += _rb(_s)
        other_bytes = 0
        for _s in other: other_bytes += _rb(_s)
        other_n = len(other)
        other_top = other[:_NA_OTHER_TOPN]
        d["sites"] = kept
        d["other_sites"] = other_top
        _app_n = 0; _gfx_n = 0
        for _s in kept:
            if _s.get("bucket") == "gfx": _gfx_n += 1
            else: _app_n += 1
        d["filtered"] = {"mode": "client_plugin_focused", "kept_sites": len(kept), "kept_app_sites": _app_n, "kept_gfx_sites": _gfx_n, "kept_retained_bytes": kept_bytes, "other_sites": other_n, "other_retained_bytes": other_bytes, "other_sites_listed": len(other_top)}
        _atomic_json_write(path, d)
        return (len(kept), kept_bytes, other_n, other_bytes)
    except Exception as e:
        try: _log("Block#3S na filter err: %s" % e)
        except Exception: pass
        return None

def _na_dump(where):
    try:
        if not (_NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_dump")):
            return
        try:
            if not int(_NLIB.cd_na_is_on()):
                return
        except Exception:
            return
        p = _oom_path(_NA_NAME)
        if not p:
            return
        n = int(_NLIB.cd_na_dump(p.encode("utf-8")))
        _flt = _na_filter_client(p)
        try:
            _log("Block#3S native alloc-sites -> %s | live_sampled=%d uniq=%d sampled=%d full_drops=%d" % (
                _NA_NAME, n, int(_NLIB.cd_na_unique()), int(_NLIB.cd_na_sampled_count()), int(_NLIB.cd_na_full_drops())))
        except Exception:
            pass

        try:
            _f3 = int(_NLIB.cd_na_full_drops()) if hasattr(_NLIB, "cd_na_full_drops") else 0
            _s3 = int(_NLIB.cd_na_sampled_count()) if hasattr(_NLIB, "cd_na_sampled_count") else 0
            _p3 = _LE_3S_PREV[0]
            _LE_3S_PREV[0] = (_f3, _s3)
            _df3 = (_f3 - _p3[0]) if _p3 is not None else -1
            _ds3 = (_s3 - _p3[1]) if _p3 is not None else -1
            _attempts3 = _ds3 if _ds3 >= _df3 else _df3
            if _df3 > 0 and _ds3 >= 0 and _attempts3 >= _LE_3S_MIN_INSERTS and (float(_df3) / float(_attempts3)) >= _LE_3S_DROP_FRAC and hasattr(_NLIB, "cd_na_min_bytes") and hasattr(_NLIB, "cd_na_enable"):
                _cur3 = int(_NLIB.cd_na_min_bytes())
                if 0 < _cur3 < _LE_3S_MIN_CAP:
                    _new3 = _cur3 * 2
                    if _new3 > _LE_3S_MIN_CAP:
                        _new3 = _LE_3S_MIN_CAP
                    if int(_NLIB.cd_na_enable(1, int(_new3))) == 0:
                        global _NA_MIN_BYTES
                        _NA_MIN_BYTES = int(_new3)
                        _log("Block#3S +LG: alloc-site table saturated in window (full_drops=+%d, %.0f%% of %d window capture attempts) -> adaptive min_bytes %d -> %d" % (_df3, 100.0 * float(_df3) / float(_attempts3), _attempts3, _cur3, _new3))
        except Exception:
            pass
        if _flt is not None:
            try:
                _log("Block#3S site split: client/plugin=%d (%.2fMB), other/system=%d (%.2fMB) [retained in other_sites]" % (
                    _flt[0], _flt[1] / 1048576.0, _flt[2], _flt[3] / 1048576.0))
            except Exception:
                pass
    except Exception as e:
        try: _log("Block#3S na dump err: %s" % e)
        except Exception: pass

def _iz_proxy_top():
    try:
        p = _b28c_proxy_path()
        if not p or not os.path.exists(p):
            return None
        with open(p, "r", encoding="utf-8") as f:
            data = json.load(f)
        if not isinstance(data, dict) or not data:
            return None
        total = 0; best = None; best_n = -1
        for pid, rec in data.items():
            if not pid or pid == _SELF_ID or pid == __id__:
                continue
            try: n = int((rec or {}).get("count") or 0)
            except Exception: n = 0
            if n <= 0:
                continue
            total += n
            if n > best_n:
                best_n = n; best = pid
        if not best or best_n <= 0 or total <= 0:
            return None
        return {"culprit": best, "count": int(best_n), "total": int(total),
                "untagged": 0, "src": "proxy"}
    except Exception:
        return None



_LE_TAG_HIST = []
_LE_TAG_LAST = [0]
_LE_TAG_PERIOD_MS = 30000
_LE_TAG_KEEP = 80
_LE_MIN_BYTES = 16777216
_LE_SHARE = 0.20
_LE_COVER = 0.5
_LE_3S_DROP_FRAC = 0.10
_LE_3S_MIN_CAP = 131072
_LE_3S_MIN_INSERTS = 2048
_LE_3S_PREV = [None]

def _le_tag_sample():
    try:
        now = int(time.time() * 1000)
        if now - _LE_TAG_LAST[0] < _LE_TAG_PERIOD_MS:
            return
        _LE_TAG_LAST[0] = now
        try:
            _topn = max(16, len(_IDX_PID) + 8)
        except Exception:
            _topn = 64
        s = native_mem_snapshot(top=_topn)
        if not s or not s.get("top"):
            return
        m = {}
        for _pid, _b in (s.get("top") or []):
            if (not _pid) or _pid.startswith("⟨") or _pid in (_SELF_ID, __id__, "__regtest__", "culprit_detector"):
                continue
            try: _b = int(_b)
            except Exception: continue
            if _b > 0:
                m[_pid] = _b
        _LE_TAG_HIST.append((now, m))
        if len(_LE_TAG_HIST) > _LE_TAG_KEEP:
            del _LE_TAG_HIST[:len(_LE_TAG_HIST) - _LE_TAG_KEEP]
    except Exception:
        pass

def _le_tag_attr(dims):
    try:
        nat = None
        for d in dims:
            if d.get("dim") == "native" and d.get("leaking"):
                nat = d
                break
        if not nat:
            return None
        span_ms = int(float(nat.get("span_s") or 0.0) * 1000.0)
        growth = int(nat.get("growth") or 0)
        if span_ms <= 0 or growth <= 0 or len(_LE_TAG_HIST) < 2:
            return None
        now = int(time.time() * 1000)
        lo = now - span_ms - _LE_TAG_PERIOD_MS
        win = [e for e in _LE_TAG_HIST if e[0] >= lo]
        if len(win) < 2:
            return None
        t0, first = win[0]
        t1, last = win[-1]
        if (t1 - t0) < int(span_ms * _LE_COVER):
            return None
        best = None; best_g = 0
        for _pid, _b in last.items():
            _g = int(_b) - int(first.get(_pid, 0))
            if _g > best_g:
                best_g = _g; best = _pid
        if not best:
            return None
        need = _LE_MIN_BYTES
        _shr = int(growth * _LE_SHARE)
        if _shr > need:
            need = _shr
        if best_g < need:
            return None
        return {"culprit": best, "growth": int(best_g), "native_growth": int(growth),
                "share_of_native_growth": (round(float(best_g) / float(growth), 4) if growth > 0 else 0.0),
                "first_bytes": int(first.get(best, 0)), "last_bytes": int(last.get(best, 0)),
                "hist_n": len(win), "hist_span_s": round((t1 - t0) / 1000.0, 1),
                "src": "malloc-tagger", "pseudo": bool(best in _OOM_PSEUDO_TAGS)}
    except Exception:
        return None


def _leak_emit(decoded, where):
    try:
        dims = decoded.get("dims", [])
        leaking = [d for d in dims if d.get("leaking")]
        if not leaking:
            return
        try: adj, score = _proc_oom_score()
        except Exception: adj, score = None, None
        rss_r2 = max([d["r2"] for d in leaking if d["dim"] == "rss"] or [0.0])
        conf = "high" if rss_r2 >= 0.90 else "medium"
        _gref_attr = None
        try:
            _lk = [d.get("dim") for d in leaking]
            if any(x in ("native", "rss", "java") for x in _lk):
                _g = _oom_gref_top()
                if not _g:
                    _g = _iz_proxy_top()
                if _g:
                    _gc = int(_g.get("count") or 0); _gt = int(_g.get("total") or 0)
                    _gu = int(_g.get("untagged") or 0); _gnm = _gt - _gu
                    _gsh = (float(_gc) / float(_gnm)) if _gnm > 0 else ((float(_gc) / float(_gt)) if _gt > 0 else 0.0)
                    if _g.get("culprit") and _gc >= _B28C_MIN and _gsh >= _B28C_DOMINANCE:
                        _gref_attr = {"culprit": _g.get("culprit"), "count": _gc,
                                      "total": _gt, "share": round(_gsh, 4),
                                      "untagged": int(_g.get("untagged") or 0),
                                      "src": (_g.get("src") or "native"), "live": bool(_g.get("live"))}
        except Exception:
            _gref_attr = None
        if _gref_attr:
            try:
                if _gref_attr.get("live"):
                    _log("Block#6D/A: client leak attributed to LIVE native global-refs (+JO: DeleteGlobalRef tracked; confirmed holder) -> %s (%d/%d live gref, %.0f%%)" % (
                        _gref_attr["culprit"], _gref_attr["count"], _gref_attr["total"], _gref_attr["share"] * 100.0))
                else:
                    _log("Block#6D/A: client leak attributed to native global-ref CREATION/churn (not a confirmed leak; live map degraded or pre-+JO .so) -> %s (%d/%d gref, %.0f%%)" % (
                        _gref_attr["culprit"], _gref_attr["count"], _gref_attr["total"], _gref_attr["share"] * 100.0))
            except Exception: pass
        _ii_ambient = None
        try:
            if _gref_attr:
                _iu = int(_gref_attr.get("untagged") or 0)
                _it = int(_gref_attr.get("total") or 0)
                _ic = int(_gref_attr.get("count") or 0)
                _iu_sh = (float(_iu) / float(_it)) if _it > 0 else 0.0
                _abs_sh = (float(_ic) / float(_it)) if _it > 0 else 0.0
                _java_leak = any(d.get("dim") == "java" and d.get("leaking") for d in dims)
                _rssnat = any(d.get("dim") in ("rss", "native") and d.get("leaking") for d in dims)
                if (_iu_sh >= _B28C_UNTAG_AMBIENT) and _rssnat and (not _java_leak) and (_abs_sh < _B28C_ABS_MIN_SHARE):
                    _ii_ambient = {"gref_suspect": dict(_gref_attr), "untagged_share": round(_iu_sh, 4), "abs_share": round(_abs_sh, 4)}
                    _gref_attr = None
                    conf = "low"
                    try: _log("Block#6D/A +II: gref attribution demoted (ambient/untagged dominates: untagged=%.0f%% of total, suspect abs=%.1f%% of total, rss/native leak, java flat) -> host-unattributed low" % (_iu_sh * 100.0, _abs_sh * 100.0))
                    except Exception: pass
        except Exception:
            _ii_ambient = None
        _jr_reclass = None
        try:
            if _gref_attr:
                _jr_java = any(d.get("dim") == "java" and d.get("leaking") for d in dims)
                _jr_rssnat = any(d.get("dim") in ("rss", "native") and d.get("leaking") for d in dims)
                if _jr_rssnat and (not _jr_java):
                    try: _na_dump(where)
                    except Exception: pass
                    _jr_ns = None
                    try: _jr_ns = _na_top_bucket_summary()
                    except Exception: _jr_ns = None
                    _jr_hostb, _jr_plugb, _jr_hostsh = _jr_native_host_split(_jr_ns)
                    _jr_untag_sh = 0.0
                    try:
                        _jt = int(_gref_attr.get("total") or 0); _ju = int(_gref_attr.get("untagged") or 0)
                        _jr_untag_sh = (float(_ju) / float(_jt)) if _jt > 0 else 0.0
                    except Exception: _jr_untag_sh = 0.0
                    _jr_was_host = (_LEAK_LAST_KIND.get(where) == "host")
                    _jr_pyrt_ok = (_jr_plugb < _JR_PLUGIN_NATIVE_MIN_BYTES)
                    _jr_trig = None
                    if _jr_pyrt_ok:
                        if _jr_hostsh >= _JR_NATIVE_HOST_SHARE: _jr_trig = "native_host_dominated"
                        elif _jr_untag_sh >= _B28C_UNTAG_AMBIENT_LO: _jr_trig = "untagged_dominant+native_flat"
                        elif _jr_was_host: _jr_trig = "hysteresis_prior_host"
                    if _jr_trig:
                        _jr_reclass = {"gref_suspect": dict(_gref_attr), "trigger": _jr_trig,
                                       "native_host_bytes": int(_jr_hostb), "native_plugin_bytes": int(_jr_plugb),
                                       "native_host_share": round(_jr_hostsh, 4), "untagged_share": round(_jr_untag_sh, 4),
                                       "top_modules": (_jr_ns.get("modules") if _jr_ns else None),
                                       "prior_host": bool(_jr_was_host),
                                       "basis": "live-gref pin not corroborated by native (host libs own %.0f%% of sampled native bytes, python-runtime ~%dB) or java-heap growth -> host-native leak, gref is churn/correlation" % (_jr_hostsh * 100.0, int(_jr_plugb))}
                        _gref_attr = None
                        if conf != "low":
                            _jr_reclass["conf_from"] = conf; conf = "low"
                        try: _log("Block#6D/A +JR: gref attribution reclassified to HOST (trigger=%s host_native=%.0f%% py-rt=%dB untagged=%.0f%%%s) -> kind=host, plugin kept as gref_suspect, conf=low" % (_jr_trig, _jr_hostsh * 100.0, int(_jr_plugb), _jr_untag_sh * 100.0, (", prior_host" if _jr_was_host else "")))
                        except Exception: pass
        except Exception:
            _jr_reclass = None
        _na_sum = None; _na_dumped = False
        if (not _gref_attr) and (not _ii_ambient):
            try: _na_dump(where); _na_dumped = True
            except Exception: pass
            try: _na_sum = _na_top_bucket_summary()
            except Exception: _na_sum = None
        _na_reason = (_na_sum.get("display") if (_na_sum and _na_sum.get("display") and not _na_sum.get("undersampled")) else "host_unattributed")

        _le_attr = None
        if (not _gref_attr) and (not _ii_ambient):
            try:
                _le_attr = _le_tag_attr(dims)
            except Exception:
                _le_attr = None
        if _le_attr:
            if _le_attr.get("pseudo"):
                conf = "low"
            elif conf != "low":
                conf = "medium"
            try:
                _kind_label = ("interpreter-pool" if _le_attr.get("pseudo") else "plugin-native")
                _log("Block#6D +LE(fix1): client native leak attributed by malloc-tagger growth -> %s (+%.1fMB of +%.1fMB native-heap, %.0f%%, hist n=%d/%.0fs) -> kind=%s, conf=%s" % (
                    _le_attr["culprit"], _le_attr["growth"] / 1048576.0, _le_attr["native_growth"] / 1048576.0,
                    _le_attr["share_of_native_growth"] * 100.0, _le_attr["hist_n"], _le_attr["hist_span_s"], _kind_label, conf))
            except Exception:
                pass
        rec = {"type": "client_memory_leak",
               "event_type": "client_memory_leak", "dropbox_tag": "client_memory_leak", "tombstone_norm_version": 1,
               "verdict": "CLIENT MEMORY LEAK",
               "where": where,
               "ts": int(time.time() * 1000),
               "confidence": conf,
               "culprit": (_gref_attr["culprit"] if _gref_attr else (_le_attr["culprit"] if _le_attr else "client (host process)")),
               "kind": ("plugin-globalref" if _gref_attr else (("interpreter-pool" if _le_attr.get("pseudo") else "plugin-native") if _le_attr else "host")),
               "gref_attribution": _gref_attr,
               "gref_suspect": (_ii_ambient.get("gref_suspect") if _ii_ambient else (_jr_reclass.get("gref_suspect") if _jr_reclass else None)),
               "gref_native_xcheck": (_jr_reclass if _jr_reclass else None),
               "tagged_attribution": (_le_attr if _le_attr else None),
               "ambient_note": (_ii_ambient if _ii_ambient else None),
               "reason_detail": (("globalref_" + (_gref_attr.get("src") or "native")) if _gref_attr else ("globalref_ambient" if _ii_ambient else (("interpreter_pool_growth" if _le_attr.get("pseudo") else "plugin_native_tagged") if _le_attr else _na_reason))),
               "oom_score_adj": adj, "oom_score": score,
               "dims": dims,
               "leaking_dims": [d["dim"] for d in leaking],
               "mem_snapshot": _leak_mem_snapshot()}
        try:
            if rec.get("reason_detail") == "host_unattributed" and rec.get("leaking_dims") == ["fd"]:
                _fdd = None
                for _d in dims:
                    if _d.get("dim") == "fd":
                        _fdd = _d; break
                _fk = ((rec.get("mem_snapshot") or {}).get("fd_by_kind") or {})
                _fkt = ", ".join("%s=%d" % (_k, int(_v or 0)) for _k, _v in sorted(_fk.items(), key=lambda kv: -int(kv[1] or 0))[:3])
                if _fdd is not None:
                    rec["reason_detail"] = "fd_leak: %d->%d (+%d)%s" % (int(_fdd.get("first") or 0), int(_fdd.get("last") or 0), int(_fdd.get("growth") or 0), ((", kinds: " + _fkt) if _fkt else ""))
                    try: _log("Block#6D +MO: fd-утечка без native-атрибуции -> reason_detail=%s" % rec["reason_detail"])
                    except Exception: pass
        except Exception: pass
        if _na_sum:
            if _na_reason != "host_unattributed":
                rec["reason_detail_base"] = "host_unattributed"
                try: _log("Block#6D +IX: host leak enriched -> %s" % _na_reason)
                except Exception: pass
            if _na_sum.get("modules"): rec["native_top_modules"] = _na_sum["modules"]
            if _na_sum.get("leak_family") and _na_sum.get("undersampled"):
                rec["leak_family_suspect"] = _na_sum["leak_family"]
                rec["gfx_family_suspect"] = _na_sum.get("gfx_family")
                try: _log("Block#6D +MP: leak_family=%s с undersampled-таблицы -> только suspect (не классификация)" % _na_sum["leak_family"])
                except Exception: pass
            elif _na_sum.get("leak_family"):
                rec["leak_family"] = _na_sum["leak_family"]
                rec["gfx_family"] = _na_sum.get("gfx_family")
                try:
                    _gf = _na_sum.get("gfx_family") or {}
                    _log("Block#6D +IX: leak_family=hwui_gfx (gfx top-frame %s x%s, ~%.0fMB) -- рост кэша текстур/битмапов/RenderNode на стороне клиента" % (_gf.get("top_frame"), _gf.get("sites"), (_gf.get("bytes") or 0) / 1048576.0))
                except Exception: pass
        try:
            _rss_span = max([float(d.get("span_s") or 0) for d in dims] or [0.0])
            _seg = _leak_seg_delta(_rss_span)
            if _seg:
                rec["rss_segments"] = _seg
                if _seg.get("top"): rec["rss_top_segment"] = _seg["top"]
                _order = sorted(_seg.get("segments", {}).items(),
                                key=lambda kv: kv[1].get("growth", 0), reverse=True)
                _slines = ["  RSS segment deltas (window ~%.0fs):" % _seg.get("span_s", 0)]
                for _nm, _v in _order:
                    _slines.append("    %-12s %+.1f MB (%.1f -> %.1f MB)" % (
                        _nm, _v.get("growth", 0) / 1048576.0,
                        _v.get("first", 0) / 1048576.0, _v.get("last", 0) / 1048576.0))
                try: _log("\n".join(_slines))
                except Exception: pass
        except Exception: pass
        try:
            _nm_pss = 0; _top_native = None; _tg = []
            try:
                _tg = _smaps_top_groups() or []
                for _grp in _tg:
                    if _grp.get("group") == "native-malloc":
                        _nm_pss = int(_grp.get("pss") or 0)
                    if _top_native is None and _grp.get("group") in _SMAPS_NATIVE_GROUPS:
                        _top_native = _grp
            except Exception:
                _tg = []
            _under = bool(_na_sum.get("undersampled")) if _na_sum else False
            if _na_sum and _under:
                rec["native_alloc_undersampled"] = True
                if _na_sum.get("undersample_reason"): rec["native_alloc_undersample_reason"] = _na_sum.get("undersample_reason")
                if _na_sum.get("epoch_age_s") is not None: rec["native_alloc_epoch_age_s"] = round(float(_na_sum["epoch_age_s"]), 1)
                try: _log("Block#6D +JQ(fix1): native alloc-site attribution UNDER-SAMPLED (%s) -- top-bucket bytes are a floor, not the true leak size" % _na_sum.get("undersample_reason"))
                except Exception: pass
            if _na_sum and _na_sum.get("sampled_stats") and _nm_pss > 0:
                _lsb = int(_na_sum["sampled_stats"].get("live_sampled_bytes") or 0)
                _cov = (float(_lsb) / float(_nm_pss)) if _nm_pss > 0 else None
                rec["native_alloc_coverage"] = {"sampled_live_bytes": _lsb, "native_malloc_bytes": _nm_pss,
                                                "ratio": (round(_cov, 4) if _cov is not None else None),
                                                "low": bool(_cov is not None and _cov < _NA_COVERAGE_LOW)}
                if _cov is not None and _cov < _NA_COVERAGE_LOW:
                    rec["native_alloc_coverage_note"] = "malloc-hook sees ~%.0f%% of native-malloc RSS; the gap is non-malloc (Vulkan/gralloc/dmabuf suballocators) invisible to the tagger" % (_cov * 100.0)
                    try: _log("Block#6D +JQ(fix3): malloc coverage ~%.1f%% (sampled %.1fMB / native-malloc %.1fMB) -- large non-malloc gap" % (_cov * 100.0, _lsb / 1048576.0, _nm_pss / 1048576.0))
                    except Exception: pass
            if _na_sum and (not rec.get("rss_top_segment")) and _top_native is not None:
                _fb = {"group": _top_native.get("group"), "pss": int(_top_native.get("pss") or 0),
                       "rss": int(_top_native.get("rss") or 0), "source": "smaps_top_group_absolute"}
                rec["rss_localization_fallback"] = _fb
                _mp_ldims = rec.get("leaking_dims") or []
                if (rec.get("reason_detail") == "host_unattributed" and (not _le_attr)
                        and any(_x in _mp_ldims for _x in ("rss", "native", "java"))):
                    rec["reason_detail"] = "host_native: %s largest (~%.0fMB, smaps abs)" % (_fb["group"], _fb["pss"] / 1048576.0)
                    rec["reason_detail_base"] = "host_unattributed"
                try: _log("Block#6D +JQ(fix2): no per-segment baseline (ring cleared/short) -> fallback localization to top smaps group %s (~%.0fMB)" % (_fb["group"], _fb["pss"] / 1048576.0))
                except Exception: pass
            try:
                _ldims = rec.get("leaking_dims") or []
                _seg2 = rec.get("rss_segments") or {}
                _segtop = (_seg2.get("top") or {}) if isinstance(_seg2, dict) else {}
                _stname = _segtop.get("segment"); _stg = int(_segtop.get("growth") or 0)
                if _ldims == ["rss"] and _stname in ("native-heap", "graphics") and _stg >= _NA_XVAL_MIN_GROWTH and not _under:
                    _relabel = "native-malloc" if _stname == "native-heap" else "gfx"
                    rec["rss_reclassified"] = {"from": "rss", "to": _relabel, "segment": _stname,
                                               "segment_growth": _stg,
                                               "basis": "rss-only leak corroborated by growing %s smaps segment" % _stname}
                    if conf == "medium":
                        conf = "high"; rec["confidence"] = conf
                        rec["confidence_bumped"] = "rss<->smaps cross-validated (+JQ fix4)"
                    try: _log("Block#6D +JQ(fix4): rss-only leak cross-validated by growing %s segment (+%.1fMB) -> reclassified rss->%s, confidence=%s" % (_stname, _stg / 1048576.0, _relabel, conf))
                    except Exception: pass
            except Exception: pass
        except Exception as _jqe:
            try: _log("Block#6D +JQ enrich err: %s" % _jqe)
            except Exception: pass
        lines = ["CLIENT MEMORY LEAK (%s) conf=%s" % (where, conf)]
        for d in dims:
            mark = "LEAK" if d.get("leaking") else "  - "
            nm = _LEAK_DIM_NAMES.get(d["dim"], d["dim"])
            lines.append("  [%s] %-16s %s -> %s growth=%s slope=%.4g/s r2=%.2f n=%d span=%.0fs" % (
                mark, nm, _leak_fmt_amount(d["dim"], d["first"]),
                _leak_fmt_amount(d["dim"], d["last"]),
                _leak_fmt_amount(d["dim"], d["growth"]),
                d["slope_per_s"], d["r2"], d["n"], d["span_s"]))
        try: _log("\n".join(lines))
        except Exception: pass
        p = _oom_path(_LEAK_NAME)
        if p: _atomic_json_write(p, rec, 65536)
        try: _LEAK_LAST_KIND[where] = rec.get("kind")
        except Exception: pass
        try: _leak_peak_capture(where, rec)
        except Exception: pass
        if not _na_dumped:
            try: _na_dump(where)
            except Exception: pass
    except Exception as e:
        try: _log("Block#6D leak emit err: %s" % e)
        except Exception: pass

def _leak_check(where):
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        _leak_feed_java()
        _leak_seg_sample()
        _le_tag_sample()
        seq = int(_NLIB.cd_leak_seq())
        if seq == _LEAK_STATE.get("last_seq", 0):
            return
        _LEAK_STATE["last_seq"] = seq
        decoded = _leak_read_native_snap()
        if decoded and decoded.get("flags"):
            _leak_emit(decoded, where)
    except Exception as e:
        try: _log("Block#6D leak check err: %s" % e)
        except Exception: pass

def _read_and_clear_crash_verdict():
    p = _crash_path()
    if not p: return None
    rec = None
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                rec = _rc_expect_dict(json.load(f))
    except Exception as _mr_e:
        rec = None
        if _rp:
            _rc_clear_taken(_rp, False, _mr_e)
            _rp = None
    if _rp:
        _rc_clear_taken(_rp, rec is not None)
    return rec

_BLOCK4A_ON = True
_BLOCK4B_ON = True
_XPOSED_BRIDGE_CLASSES = (
    "de.robv.android.xposed.XposedBridge",
    "com.taobao.android.dexposed.DexposedBridge",
)
_HOOK_FRAMEWORK_PROBES = [
    ("de.robv.android.xposed.XposedBridge", "sHookedMethodCallbacks"),
    ("com.taobao.android.dexposed.DexposedBridge", "sHookedMethodCallbacks"),
    ("top.canyie.pine.Pine", "sHookListeners"),
    ("top.canyie.pine.PineConfig", None),
    ("me.weishu.epic.art.Epic", None),
    ("com.swift.sandhook.SandHook", None),
    ("org.lsposed.lsplant.LSPlant", None),
    ("org.lsposed.lspd.core.Main", None),
    ("io.github.libxposed.api.XposedInterface", None),
    ("lab.galaxy.yahfa.HookMain", None),
    ("com.exteragram.messenger.plugins.PythonPluginsEngine", None),
]

def _class_obj(cn):
    try:
        return jclass("java.lang.Class").forName(cn)
    except Exception:
        return None

def _probe_hook_frameworks():
    found = []
    for cn, fld in _HOOK_FRAMEWORK_PROBES:
        cls = _class_obj(cn)
        if cls is None:
            continue
        info = cn
        if fld:
            try:
                f = cls.getDeclaredField(fld); f.setAccessible(True); v = f.get(None)
                try: sz = v.size()
                except Exception:
                    try: sz = len(v)
                    except Exception: sz = "?"
                info += f" [{fld}={sz}]"
            except Exception as e:
                info += f" [{fld}:нет поля]"
        found.append(info)
    return found

def _safe_str(o):
    try: return str(o)
    except Exception:
        try: return o.toString()
        except Exception: return ""

def _plugin_classloaders():
    out = {}
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out[_safe_str(cl)] = pid
            except Exception: pass
    except Exception: pass
    return out

def _entryset_snapshot(m):
    last = None
    for _ in range(4):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _xposed_field_value():
    for cn in _XPOSED_BRIDGE_CLASSES:
        try:
            cls = _class_obj(cn)
            if cls is None: continue
            f = cls.getDeclaredField("sHookedMethodCallbacks")
            f.setAccessible(True)
            v = f.get(None)
            if v is not None: return v, cn
        except Exception: continue
    return None, None

def _cb_array(callbacks):
    for getter in ("getSnapshot", "toArray"):
        try:
            a = getattr(callbacks, getter)()
            if a is not None: return a
        except Exception: pass
    return []

def _build_hook_owner_map():
    res = {}
    m, _ = _xposed_field_value()
    if m is None:
        st = "lsplant-no-jmap" if _class_obj("de.robv.android.xposed.XposedBridge") is not None else "no-xposed"
        return res, 0, st
    try:
        clmap = _plugin_classloaders(); known = _load_known()
        for e in _entryset_snapshot(m):
            try:
                member = e.getKey(); callbacks = e.getValue()
                dcl = member.getDeclaringClass().getName()
                try: mname = member.getName()
                except Exception: mname = "<init>"
                key = dcl + "." + mname
                owner = None
                for cb in _cb_array(callbacks):
                    try:
                        cl = cb.getClass().getClassLoader(); rep = _safe_str(cl)
                        if rep in clmap: owner = clmap[rep]; break
                        owner = _map_stack_to_id(rep, known) or _map_stack_to_id(cb.getClass().getName(), known)
                        if owner: break
                    except Exception: pass
                res[key] = owner
            except Exception: pass
    except Exception:
        return res, len(res), "err"
    return res, len(res), "ok"

def _hook_owner_for_frames(frames):
    if not _BLOCK4A_ON: return None, None, None, {"status": "off"}
    omap, n, status = _build_hook_owner_map()
    meta = {"n": n, "status": status}
    if not omap: return None, None, None, meta
    for fr in frames:
        if fr in omap and omap[fr]: return omap[fr], fr, "exact", meta
    simple = {}
    for k, v in omap.items():
        try:
            cls, mth = k.rsplit(".", 1); simple[(_simple(cls), mth)] = (v, k)
        except Exception: pass
    for fr in frames:
        try:
            cls, mth = fr.rsplit(".", 1); t = (_simple(cls), mth)
            if t in simple and simple[t][0]: return simple[t][0], simple[t][1], "simple", meta
        except Exception: pass
    by_method = {}
    for k, v in omap.items():
        if not v: continue
        try: mth = k.rsplit(".", 1)[1]
        except Exception: continue
        by_method.setdefault(mth, set()).add((v, k))
    for fr in frames:
        if not _is_hook_frame(fr): continue
        try: mth = fr.rsplit(".", 1)[1]
        except Exception: continue
        hits = by_method.get(mth)
        if hits and len(hits) == 1:
            v, k = next(iter(hits))
            return v, k, "hook-method", meta
    for fr in frames:
        if fr in omap: return None, fr, "method-only", meta
    return None, None, None, meta

def _plugin_loaders():
    out = []
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out.append((cl, _safe_str(cl), pid))
            except Exception: pass
    except Exception: pass
    return out

def _classloader_culprit(frames):
    if not _BLOCK4B_ON: return None, None, {"status": "off"}
    loaders = _plugin_loaders()
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    repr2pids = {}
    for (cl, rep, pid) in loaders:
        repr2pids.setdefault(rep, set()).add(pid)
    ambig = 0
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (cl, rep, pid) in loaders:
            try:
                kls = cl.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is None: continue
            pids = repr2pids.get(drep)
            if not pids: continue
            if len(pids) == 1:
                if ambig: meta["ambiguous"] = ambig
                return next(iter(pids)), fr, meta
            ambig += 1; break
    if ambig: meta["ambiguous"] = ambig
    return None, None, meta

def _b16_push_verdict(kind, rec):
    if not _B16_ON: return
    try:
        conf = rec.get("confidence")
        if conf not in ("high", "medium"): return
        e = {"kind": kind, "culprit": rec.get("culprit"), "confidence": conf,
             "where": rec.get("where"), "exc_cls": rec.get("exc_cls"),
             "exc_msg": rec.get("exc_msg"), "py_file": rec.get("py_file"),
             "py_line": rec.get("py_line"), "ts": rec.get("ts") or int(time.time() * 1000)}
        with _RECENT_VERDICTS_LOCK:
            _RECENT_VERDICTS.append(e)
            if len(_RECENT_VERDICTS) > _RECENT_MAX:
                del _RECENT_VERDICTS[:-_RECENT_MAX]
    except Exception:
        pass

def _b16_disk_candidates():
    out = []
    try:
        srcs = (("cb", _cb_verdict_path), ("bg", _bg_verdict_path), ("ui", _ui_verdict_path), ("fut", _fut_verdict_path), ("async", _async_verdict_path), ("pyerr", _pyerr_verdict_path))
    except Exception:
        srcs = ()
    for kind, pathfn in srcs:
        try:
            p = pathfn()
            _rp = _rc_read_path(p) if p else None
            if not _rp: continue
            with open(_rp, "r", encoding="utf-8") as f:
                arr = list(json.load(f))
            for r in arr[-12:]:
                try:
                    out.append({"kind": kind, "culprit": r.get("culprit"),
                                "confidence": r.get("confidence"), "where": r.get("where"),
                                "exc_cls": r.get("exc_cls"), "exc_msg": r.get("exc_msg"),
                                "py_file": r.get("py_file"), "py_line": r.get("py_line"),
                                "ts": r.get("ts")})
                except Exception: pass
        except Exception:
            pass
    return out

def _b16_exc_match(crash_exc_cls, crash_exc_msg, v_exc_cls, v_exc_msg):
    cm = str(crash_exc_msg or "")
    vm = str(v_exc_msg or "")
    vc = str(v_exc_cls or "")
    if vm and (vm == cm or vm in cm or cm.endswith(vm)):
        return True
    combo = ("%s: %s" % (vc, vm)) if vm else vc
    if combo and (combo == cm or combo in cm or cm.endswith(combo)):
        return True
    return False

def _b19_exc_ring_put(exc):
    try: _ec = type(exc).__name__
    except Exception: _ec = None
    try: _em = str(exc)
    except Exception: _em = None
    if not _ec: return
    try:
        with _B19_EXC_RING_LOCK:
            _B19_EXC_RING.append((int(time.time() * 1000), _ec, _em))
            if len(_B19_EXC_RING) > _B19_EXC_RING_MAX:
                del _B19_EXC_RING[0:len(_B19_EXC_RING) - _B19_EXC_RING_MAX]
    except Exception: pass

def _b19_exc_ring_lookup(crash_ts, window_ms):
    best = None; best_dt = None
    try:
        with _B19_EXC_RING_LOCK:
            _snap = list(_B19_EXC_RING)
    except Exception:
        _snap = []
    for _ts, _ec, _em in _snap:
        try: _dt = abs(int(crash_ts) - int(_ts))
        except Exception: continue
        if _dt <= window_ms and (best_dt is None or _dt < best_dt):
            best = (_ec, _em); best_dt = _dt
    return best


def _b16_correlate(rec):
    try:
        if not _B16_ON or not isinstance(rec, dict): return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        if (not cx or str(cx).strip() in ("", "?")) and (not cm or str(cm).strip() == ""):
            _enr = _b19_exc_ring_lookup(crash_ts, _B16_CORR_WINDOW_MS)
            if _enr:
                rec["exc_cls"] = _enr[0]
                if _enr[1]: rec["exc_msg"] = _enr[1]
                rec["exc_from"] = "b19_ring+window"
                cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        cands = []
        try:
            with _RECENT_VERDICTS_LOCK:
                cands = list(_RECENT_VERDICTS)
        except Exception:
            cands = []
        try:
            cands = cands + _b16_disk_candidates()
        except Exception:
            pass
        top_pid = None
        try:
            nm = rec.get("native_mem")
            if isinstance(nm, dict): top_pid = nm.get("top_pid")
        except Exception:
            top_pid = None
        try:
            frames = rec.get("stack_top") or []
        except Exception:
            frames = []
        best = None; best_ts = -1
        best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high": continue
                vts = v.get("ts")
                if vts is None: continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS: continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        try:
            if best is None:
                _op = _classify_orphan_proxy(cx, cm, frames)
                if _op is not None:
                    _oown, _oconf, _osrc = _orphan_proxy_owner(_op.get("proxy_class"), crash_ts)
                    if _oown:
                        rec["correlated"] = {"from": "orphan_proxy", "culprit": _oown, "confidence": _oconf,
                                             "where": "proxy.invoke/fromJava", "proxy_class": _op.get("proxy_class"),
                                             "attr": _op.get("attr"), "match": _osrc}
                        cur_pid = rec.get("crashed_plugin_id"); cur_conf = rec.get("confidence")
                        _jl_tidm = (rec.get("src") == "tid" and str(rec.get("thread") or "").strip().lower().startswith("main"))
                        if _jl_tidm: rec["tid_candidate"] = cur_pid
                        weak = ((cur_conf != "high") or _jl_tidm or (not cur_pid) or (cur_pid == "unknown")
                                or (isinstance(cur_pid, str) and (cur_pid.startswith("<python>") or cur_pid.startswith("$Proxy"))))
                        if weak:
                            rec["crashed_plugin_id_native"] = cur_pid
                            rec["crashed_plugin_id"] = _oown
                            rec["confidence"] = _oconf
                            rec["src"] = str(_osrc or ("orphan_proxy/" + str(_op.get("proxy_class"))))
                        return rec
        except Exception: pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            try:
                cms = str(cm or "")
                if "_chaquopyGetDict" in cms or "_chaquopyGetType" in cms:
                    q1 = cms.find("'") + 1
                    q2 = cms.find("'", q1) if q1 > 0 else -1
                    cls_name = cms[q1:q2] if (q1 > 0 and q2 > q1) else None
                    if cls_name:
                        entry = _B14_IFACE_OWNER.get(cls_name)
                        if entry:
                            zowner, zts = entry
                            if abs(int(crash_ts) - int(zts)) < _B16_ZOMBIE_WINDOW_MS:
                                rec["correlated"] = {
                                    "from": "zombie_proxy",
                                    "culprit": zowner,
                                    "confidence": "medium",
                                    "where": "proxy.invoke/fromJava",
                                    "proxy_class": cls_name,
                                    "match": "iface_owner+window",
                                    "age_ms": abs(int(crash_ts) - int(zts))}
                                cur_pid = rec.get("crashed_plugin_id")
                                cur_conf = rec.get("confidence")
                                weak = (
                                    (cur_conf != "high") or
                                    (rec.get("src") == "tid" and str(rec.get("thread") or "").strip().lower().startswith("main")) or
                                    (not cur_pid) or
                                    (cur_pid == "unknown") or
                                    (isinstance(cur_pid, str) and
                                     cur_pid.startswith("<python>"))
                                )
                                if weak:
                                    rec["crashed_plugin_id_native"] = cur_pid
                                    rec["crashed_plugin_id"] = zowner
                                    rec["confidence"] = "medium"
                                    rec["src"] = "zombie_proxy/" + cls_name
            except Exception: pass
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown": return rec
        sig = ["exc", "window"]
        try:
            if top_pid and top_pid == culprit: sig.append("top_pid")
        except Exception: pass
        try:
            for fr in frames:
                if isinstance(fr, str) and culprit in fr:
                    sig.append("stack"); break
        except Exception: pass
        rec["correlated"] = {
            "from": (best.get("kind") or "cb") + "_verdict", "culprit": culprit,
            "confidence": best.get("confidence"), "where": best.get("where"),
            "py_file": best.get("py_file"), "py_line": best.get("py_line"),
            "match": "+".join(sig), "age_ms": abs(int(crash_ts) - best_ts),
        }
        cur_pid = rec.get("crashed_plugin_id")
        cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if weak:
            rec["crashed_plugin_id_native"] = cur_pid
            rec["crashed_plugin_id"] = culprit
            rec["confidence"] = "high"
            rec["src"] = "correlated/" + (best.get("kind") or "cb")
        return rec
    except Exception:
        return rec

def _b16_correlate_boot(rec, cands):
    try:
        if not _B16_ON or not isinstance(rec, dict) or not cands:
            return rec
        cur_pid = rec.get("crashed_plugin_id"); cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if not weak:
            return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        if (not cx or str(cx).strip() in ("", "?")) and (not cm or str(cm).strip() == ""):
            _enr = _b19_exc_ring_lookup(crash_ts, _B16_CORR_WINDOW_MS)
            if _enr:
                rec["exc_cls"] = _enr[0]
                if _enr[1]: rec["exc_msg"] = _enr[1]
                rec["exc_from"] = "b19_ring+window"
                cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        best = None; best_ts = -1; best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high":
                    continue
                vts = v.get("ts")
                if vts is None:
                    continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS:
                    continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown":
            return rec
        rec["crashed_plugin_id_native"] = cur_pid
        rec["crashed_plugin_id"] = culprit
        rec["confidence"] = "high"
        rec["src"] = "correlated-boot/" + (best.get("kind") or "py")
        rec["correlated"] = {"from": (best.get("kind") or "py") + "_verdict", "culprit": culprit,
                             "confidence": best.get("confidence"), "where": best.get("where"),
                             "py_file": best.get("py_file"), "py_line": best.get("py_line"),
                             "match": "boot+window", "age_ms": abs(int(crash_ts) - int(best_ts))}
        return rec
    except Exception:
        return rec


_ORPHAN_PROXY_ATTRS = ("_chaquopyGetType", "_chaquopyGetDict")
_ORPHAN_PROXY_FRAMES = ("fromJavaNative", "DynamicProxyClass", "PyInvocationHandler", "j2p", "chaquopy")
def _classify_orphan_proxy(exc_cls, exc_msg, frames):
    try:
        cm = str(exc_msg or "")
        attr = None
        for a in _ORPHAN_PROXY_ATTRS:
            if a in cm:
                attr = a; break
        if attr is None:
            return None
        if ("AttributeError" not in cm) and ("AttributeError" not in str(exc_cls or "")):
            return None
        fr_hit = False
        for fr in (frames or []):
            for mk in _ORPHAN_PROXY_FRAMES:
                if mk in fr:
                    fr_hit = True; break
            if fr_hit:
                break
        if not fr_hit:
            return None
        cls_name = None
        q1 = cm.find("'") + 1
        q2 = cm.find("'", q1) if q1 > 0 else -1
        if q1 > 0 and q2 > q1:
            cls_name = cm[q1:q2]
        return {"proxy_class": cls_name, "attr": attr}
    except Exception:
        return None
def _orphan_proxy_owner(cls_name, crash_ts):
    try:
        if _POST_NATIVE_ACTIVE and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_orphan_owner"):
            _oage = ctypes.c_int64(0)
            _oidx = int(_NLIB.cd_orphan_owner(ctypes.byref(_oage)))
            _oam = int(_oage.value)
            if _oidx >= 0 and 0 <= _oam <= _B16_ZOMBIE_WINDOW_MS:
                _onm = _resolve_idx(_oidx)
                if not (isinstance(_onm, str) and _onm):
                    _onm = _resolve_idx_durable(_oidx)
                if isinstance(_onm, str) and _onm:
                    return _onm, "high", "orphan-proxy/handler-post-native"
    except Exception:
        pass
    try:
        if cls_name:
            keys = [cls_name]
            try:
                for k in (cls_name.lstrip("_"), cls_name.rsplit("$", 1)[-1]):
                    if k and k not in keys:
                        keys.append(k)
            except Exception:
                pass
            for key in keys:
                entry = _B14_IFACE_OWNER.get(key)
                if entry:
                    zowner, zts = entry
                    try:
                        fresh = abs(int(crash_ts) - int(zts)) < _B16_ZOMBIE_WINDOW_MS
                    except Exception:
                        fresh = False
                    if fresh and zowner:
                        return zowner, "medium", "orphan-proxy/iface-owner+" + str(key)
        try:
            pp, _ = _b28_proxy_producer()
        except Exception:
            pp = None
        if pp:
            return pp, "low", "orphan-proxy/proxy-producer"
    except Exception:
        pass
    return None, None, None
def _capture_crash(thread, ex):
    crash_ts = int(time.time() * 1000)
    tid = None
    if _NATIVE_OK and _NLIB is not None:
        try: tid = int(_NLIB.cd_gettid())
        except Exception: tid = None
    if tid is None:
        try: tid = int(thread.getId())
        except Exception: tid = None
    idx_tid = _reg_get(tid)
    pid_tid = _resolve_idx(idx_tid) if (idx_tid is not None and idx_tid >= 0) else None
    crumb_raw = None
    try:
        crumb_raw = _CRUMB.read_prev() if _CRUMB is not None else None
    except Exception:
        crumb_raw = None
    pid_crumb = None; crumb_fresh = False; crumb_age = None
    if crumb_raw:
        try:
            parts = crumb_raw.split("\t")
            pid_crumb = parts[0]; cts = int(parts[2]); crumb_age = crash_ts - cts
            if 0 <= crumb_age <= _CRUMB_FRESH_MS: crumb_fresh = True
        except Exception:
            pid_crumb = crumb_raw.split("\t")[0] if "\t" in crumb_raw else crumb_raw
    frames = []
    try:
        st = ex.getStackTrace()
        if st is not None:
            for el in st:
                try: frames.append(el.getClassName() + "." + el.getMethodName())
                except Exception: pass
    except Exception:
        pass
    via_hook = any(_is_hook_frame(f) for f in frames)
    hooked_method = None
    if via_hook:
        for f in frames:
            if _is_hook_frame(f) and "LSPHooker_" in f:
                try: hooked_method = f.rsplit(".", 1)[1]
                except Exception: hooked_method = _short_method(f)
                break
        if not hooked_method:
            for f in frames:
                if f.startswith("org.telegram."):
                    hooked_method = _short_method(f); break
    culprit_frame = _stack_culprit(frames)
    pid_stack = _map_stack_to_id(culprit_frame, _known_union()) if culprit_frame else None
    pid_4a = None; hook4a_method = None; hook4a_kind = None; hook4a_meta = {}
    try:
        pid_4a, hook4a_method, hook4a_kind, hook4a_meta = _hook_owner_for_frames(frames)
    except Exception as _e4a:
        hook4a_meta = {"status": "err:%s" % _e4a}
    pid_4b = None; cl4b_frame = None; cl4b_meta = {}
    try:
        pid_4b, cl4b_frame, cl4b_meta = _classloader_culprit(frames)
    except Exception as _e4b:
        cl4b_meta = {"status": "err:%s" % _e4b}
    pid_4c = None; cl4c_frame = None; cl4c_meta = {}
    try:
        pid_4c, cl4c_frame, cl4c_meta = _loader_culprit(frames)
    except Exception as _e4c:
        cl4c_meta = {"status": "err:%s" % _e4c}
    pid_stack_strong = pid_stack if (pid_stack and culprit_frame and not _is_obfuscated(culprit_frame)) else None
    if pid_tid:
        pid = pid_tid; src = "tid"; conf = "high"
    elif pid_stack_strong:
        pid = pid_stack_strong; src = "stack"; conf = "high"
    elif pid_4c:
        pid = pid_4c; src = "loader"; conf = "high"
    elif pid_4b:
        pid = pid_4b; src = "classloader"; conf = "high"
    elif pid_4a:
        pid = pid_4a; src = "hookmap"; conf = "high"
    elif pid_stack:
        pid = pid_stack; src = "stack"; conf = "medium"
    elif culprit_frame:
        pid = _pkg_of(culprit_frame); src = "stack-pkg"; conf = "low"
    elif crumb_fresh and pid_crumb:
        pid = pid_crumb; src = "breadcrumb"; conf = "low"
    else:
        pid = "unknown"; src = ("hook-obfuscated" if via_hook else "none"); conf = "none"
    _opan = None
    try:
        if _frames_hit_anim(frames):
            _opan = _b20_owner_from_op_in_domains(_GPU_OP_WINDOW_MS, ("anim",))
    except Exception:
        _opan = None
    exc_cls = ""; exc_msg = ""; tname = ""
    try: exc_cls = ex.getClass().getName()
    except Exception: pass
    try:
        m = ex.getMessage(); exc_msg = str(m) if m is not None else ""
    except Exception: pass
    try: tname = thread.getName()
    except Exception: pass
    nat = None
    if _NATIVE_OK and _NLIB is not None:
        try:
            b = ctypes.c_int64(0)
            ti = int(_NLIB.cd_top1(ctypes.byref(b)))
            nat = {"top_idx": ti, "top_pid": (_resolve_idx(ti) if ti >= 0 else None),
                   "top_bytes": int(b.value), "total": int(_NLIB.cd_total())}
        except Exception:
            nat = None
    try: _reg_backend = registry_info().get("backend")
    except Exception: _reg_backend = None
    rec = {
        "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
        "exc_cls": exc_cls, "exc_msg": exc_msg, "thread": tname,
        "via_hook": via_hook, "hooked_method": hooked_method,
        "pid_tid": pid_tid, "reg_idx": idx_tid, "reg_backend": _reg_backend,
        "pid_stack": pid_stack, "culprit_frame": culprit_frame,
        "pid_4a": pid_4a, "hook4a_method": hook4a_method, "hook4a_kind": hook4a_kind, "hook4a_meta": hook4a_meta,
        "pid_4b": pid_4b, "cl4b_frame": cl4b_frame, "cl4b_meta": cl4b_meta,
        "pid_4c": pid_4c, "cl4c_frame": cl4c_frame, "cl4c_meta": cl4c_meta,
        "pid_crumb": pid_crumb, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age, "crumb": crumb_raw,
        "stack_top": frames[:40], "native_mem": nat, "op_anim": _opan, "ts": crash_ts,
    }
    if _is_py_memoryerror(exc_cls, exc_msg):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON
    try:
        _odp = _classify_orphan_proxy(exc_cls, exc_msg, frames)
        if _odp is not None:
            rec["cause"] = "orphaned_dynamic_proxy_runnable"
            rec["proxy_class"] = _odp.get("proxy_class")
            rec["proxy_attr"] = _odp.get("attr")
            _own, _oconf, _osrc = _orphan_proxy_owner(_odp.get("proxy_class"), crash_ts)
            _cur = rec.get("crashed_plugin_id")
            _tid_main = (rec.get("src") == "tid" and str(tname or "").strip().lower().startswith("main"))
            if _tid_main: rec["tid_candidate"] = _cur
            _weak = (rec.get("confidence") in (None, "low", "none")) or (not _cur) or _tid_main or \
                    (isinstance(_cur, str) and (_cur.startswith("$Proxy") or _cur == "unknown"))
            _pcls = _odp.get("proxy_class") or "?"
            if _own:
                rec["reason"] = "осиротевший dynamic-proxy Runnable сработал после teardown/reload (владелец: %s; Chaquopy proxy-binding утерян: %s)" % (_own, _pcls)
                if _weak:
                    rec["crashed_plugin_id_native"] = _cur
                    rec["crashed_plugin_id"] = _own
                    rec["confidence"] = _oconf
                    rec["src"] = _osrc
                    if _tid_main and _own == _cur:
                        rec["confidence"] = "high"
