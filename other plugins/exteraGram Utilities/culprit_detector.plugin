                    rec["culprit_basis"] = ("native SIGSEGV NULL_DEREF entirely in ART/JNI runtime (top_so=%s) = uncaught PyException unwind; re-attributed from %s to correlated pyerr culprit %r (age=%dms)" % (_ig_top or "runtime", (("registry-scope guess %r" % rec.get("pid_native_scope")) if rec.get("pid_native_scope") is not None else "unresolved native (pid=none)"), _ig_cul, abs(int(_ig_ts) - _ig_best_ts)))
                    rec["ig_correlated"] = {"from": (_ig_best.get("kind") or "pyerr") + "_verdict", "culprit": _ig_cul, "py_file": _ig_best.get("py_file"), "py_line": _ig_best.get("py_line"), "age_ms": abs(int(_ig_ts) - _ig_best_ts)}
                    _log("Block#4C +IH: runtime NULL_DEREF (top_so=%s) reassigned prior=%r -> pyerr culprit %r (conf=medium)" % (_ig_top or "runtime", rec.get("pid_native_scope"), _ig_cul))
                elif _ig_cul and _ig_cul == rec.get("pid"):
