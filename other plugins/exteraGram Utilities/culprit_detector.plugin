def _pm_is_programmatic_restart(pyframes, owner_pid):
    try:
        if not pyframes or not owner_pid or owner_pid == "unknown": return False
        _names = ("restart", "reload", "relaunch", "soft_restart", "do_restart", "_restart")
        for _fr in list(pyframes)[:8]:
