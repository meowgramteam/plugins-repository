                        rec["stack_overflow"] = True
                        rec["managed_interpreter_fault"] = False
                        _log("Block#4C +SO: abort_message=StackOverflowError -> native_subtype=stack_overflow (перекрывает frame-scan %r)" % _mt_cls)
                    elif _mt_cls and not rec.get("native_subtype"):
                        rec["native_subtype"] = _mt_cls
                        rec["managed_interpreter_fault"] = True
                    rec["tombstone_debuggerd"] = {
                        "thread_name": _tb.get("thread_name"), "tid": _tb.get("tid"),
                        "pid": _tb.get("pid"), "process": _tb.get("process"),
                        "abi": _tb.get("abi"), "build_fingerprint": _tb.get("build_fingerprint"),
                        "total_frames": _tb.get("total_frames"), "frames": _mt_sym,
                        "fault_addr": _tb.get("fault_addr"), "signo": _tb.get("signo"),
                        "code": _tb.get("code"),
                        "event_ts": _tb.get("logcat_ts"),
                    }
                    try:
                        _mt_cts = rec.get("crash_ts") or rec.get("ts")
                        if _tb.get("logcat_ts") is not None and _mt_cts is not None:
                            rec["tombstone_time_age_ms"] = abs(int(_tb["logcat_ts"]) - int(_mt_cts))
                        if _tb.get("match_score") is not None:
                            rec["tombstone_match_score"] = int(_tb["match_score"])
                    except Exception:
                        pass
                    rec["tombstone_norm_version"] = 2
                    _log("Block#4C +MT: debuggerd tombstone symbolized (thread=%r top=%r frames=%d skew=%s subtype=%r)"
                         % (rec.get("crash_thread_name"), rec.get("tombstone_top_symbol"),
                            len(_mt_sym), rec.get("inproc_base_skew_hex"), rec.get("native_subtype")))
                elif rec.get("corroboration") is None:
                    rec["corroboration"] = "inprocess_only"
        except Exception as _emt:
            _log("Block#4C +MT tombstone-mine err: %s" % _emt)
        try:
            if rec.get("confidence") is None and rec.get("culprit_kind") == "system" and rec.get("pid") is None:
                _resolved_any = any(("+0x" in _fr) for _fr in (rec.get("frames") or []))
                if rec.get("symbolized_by") == "debuggerd":
                    _tsym = rec.get("tombstone_top_symbol") or "?"
                    _tthr = rec.get("crash_thread_name") or "?"
                    if rec.get("managed_interpreter_fault"):
                        _ureason = "managed-metadata corruption: fault in ART interpreter (%s) on thread %r -- corrupted class/field pointer (native/JNI/hook misuse), not plugin-attributable [debuggerd-symbolized]" % (_tsym, _tthr)
                    else:
                        _ureason = "system native fault in %s on thread %r -- not plugin-attributable [debuggerd-symbolized]" % (_tsym, _tthr)
                elif rec.get("maps_trunc"):
                    _ureason = "unresolved-native: maps snapshot truncated (maps_n=%s) -- raise CD_MAPS_MAX" % rec.get("maps_n")
                elif not _resolved_any:
                    _ureason = "unresolved-native: no frame resolved to a module (anon/JIT/unmapped)"
                else:
                    _ureason = "unresolved-native: top fault frame unmapped"
                rec["confidence"] = "low"
                rec["unattributed_reason"] = _ureason
                try:
                    _ha_top = (rec.get("top_so") or "").lower()
                    _ha_managed = bool(rec.get("managed_frame")) or bool(rec.get("managed_mod")) or any(_x in _ha_top for _x in (".oat", ".art", ".odex", "dalvik-cache"))
                    _ha_inproc = (rec.get("corroboration") == "inprocess_only") or (rec.get("tombstone_source") == "inprocess_native_dump")
                    if _ha_managed:
                        rec["advisory_kind"] = "managed_art_sigsegv"
                        rec["native_advisory"] = ("вероятно ART/managed SIGSEGV (top_so=%s%s) -- краш внутри среды ART, не в нативном коде плагина%s" % (rec.get("top_so") or "?", (", managed_mod=%s" % rec.get("managed_mod")) if rec.get("managed_mod") else "", " [только in-process дамп: logcat запечатан хостом]" if _ha_inproc else ""))
                        _log("Block#4C +HA: managed/ART SIGSEGV advisory -> %s" % rec["native_advisory"])
                except Exception as _eha:
                    try: _log("Block#4C +HA advisory err: %s" % _eha)
                    except Exception: pass
                _log("Block#4C +DK: неатрибутированный нативный краш -> conf=low (%s; signo=%s cause=%s frames=%d maps_n=%s maps_trunc=%s)"
                     % (_ureason, rec.get("signo"), rec.get("cause"), len(rec.get("frames") or []), rec.get("maps_n"), rec.get("maps_trunc")))
        except Exception as _edk:
            _log("Block#4C +DK annotate err: %s" % _edk)
        try:
            if rec.get("abort_family") == "art_heap_corruption" and rec.get("pid") is None:
                _is_managed_heap_corruption(rec)
        except Exception as _eis:
            _log("Block#4C +IS heap-corruption err: %s" % _eis)
        try:
            _attach_heap_corruption_leads(rec)
        except Exception as _ehl:
            _log("Block#4C +KG heap-corruption-leads err: %s" % _ehl)
        try:
            if rec.get("pid") is None and rec.get("pid_resolve_src") == "bridge_scope_miss":
                _io_bridge_crash_attribute(rec)
        except Exception as _eio:
            _log("Block#4C +IO bridge-attrib err: %s" % _eio)
        try:
            _ncvp = _native_crash_verdict_path()
            if _ncvp:
                _atomic_json_write(_ncvp, rec)
                _log("Block#4C: native_crash_verdict.json записан (kind=%s plugin=%r host_so=%r signo=%s cause=%s)"
                     % (rec.get("culprit_kind"), rec.get("pid"), rec.get("host_so"), rec.get("signo"), rec.get("cause")))
        except Exception as _env:
            _log("native_crash_verdict write err: %s" % _env)
        try:
            _nhp = File(_DIR, _NATIVE_CRASH_HISTORY_NAME).getAbsolutePath()
            _nhist = []
            _nhrp = _rc_read_path(_nhp)
            if _nhrp:
                try:
                    with open(_nhrp, "r", encoding="utf-8") as _fnh: _nhist = list(json.load(_fnh))
                except Exception: _nhist = []
            _rts = rec.get("ts")
            if not any(isinstance(_h, dict) and _h.get("ts") == _rts for _h in _nhist):
                _nhist.append(rec)
                _atomic_json_write(_nhp, _nhist[-_NATIVE_CRASH_HISTORY_MAX:], _NATIVE_CRASH_HISTORY_MAX)
                _log("Block#4C +GO: native_crash_history.json дополнен (signo=%s cause=%s -> всего=%d)"
                     % (rec.get("signo"), rec.get("cause"), min(len(_nhist), _NATIVE_CRASH_HISTORY_MAX)))
        except Exception as _enh:
            _log("native_crash_history write err: %s" % _enh)

        try: os.remove(_rp)
        except Exception: pass
        return rec
    except Exception as e:
        _log(f"native crash read err: {e}")
        return None
    finally:
        if "_rp" in locals() and _rp:
            try: os.remove(_rp)
            except Exception: pass

def _get_declared_methods(cls, label=""):
    if cls is None: return []
    try:
        return list(cls.getDeclaredMethods())
    except Exception:
        try:
            return list(cls.getMethods())
        except Exception as e:
            _log(f"getDeclaredMethods failed for {label}: {e}"); return []

import sys as _sys, functools as _functools, gc as _gc

_ENTRY_CBS = (
    "on_plugin_load", "on_plugin_unload", "on_settings_changed", "create_settings",
    "on_send_message_hook", "pre_request_hook", "post_request_hook",
    "on_update_hook", "on_updates_hook", "on_app_event", "on_app_update",
)
_B_TAGGED_FLAG = "__culprit_scoped__"

def _canonical_pid(obj):
    mod_name = getattr(type(obj), "__module__", None)
    mod = _sys.modules.get(mod_name) if mod_name else None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    return pid or mod_name or "unknown"

def _pid_of_module(mod_name):
    if not mod_name: return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    if mod is None: return None
    pid = getattr(mod, "__id__", None)
    if isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__:
        return pid
    return None

def _pid_of_module_pkg(mod_name):
    pid = _pid_of_module(mod_name)
    if pid:
        return pid
    nm = mod_name or ""
    seen = 0
    while "." in nm and seen < 16:
        seen += 1
        nm = nm.rpartition(".")[0]
        if not nm:
            break
        pid = _pid_of_module(nm)
        if pid:
            return pid
    return None

def _pid_of_callable(fn):
    try:
        return _pid_of_module(getattr(fn, "__module__", None))
    except Exception:
        return None

def _provenance_pid(thread_obj=None, depth=0):
    try:
        if thread_obj is not None:
            tgt = getattr(thread_obj, "_target", None)
            if tgt is not None:
                pid = _pid_of_callable(tgt)
                if pid: return pid
            pid = _pid_of_module(getattr(type(thread_obj), "__module__", None))
            if pid: return pid
    except Exception:
        pass
    try:
        f = _sys._getframe(1 + int(depth))
    except Exception:
        f = None
    seen = 0
    while f is not None and seen < 40:
        try:
            g = f.f_globals
            pid = _pid_of_module(g.get("__name__"))
            if pid is None:
                _id = g.get("__id__")
                if isinstance(_id, str) and _id and _id != _SELF_ID and _id != __id__:
                    pid = _id
            if pid:
                return pid
        except Exception:
            pass
        try: f = f.f_back
        except Exception: f = None
        seen += 1
    return None

_UI_CB_ATTRS = ("on_click", "on_change", "on_value_change", "on_toggle", "callback", "on_select", "on_long_click")
_UI_CONTAINER_ATTRS = ("elements", "children", "items", "rows", "cells", "views", "subviews", "content", "body")
_UI_FACTORY_ATTRS = ("create_sub_fragment", "create_fragment", "build_fragment", "create_page", "sub_fragment")
def _wrap_ui_callbacks(pid, items, _depth=0, _seen=None):
    if _depth > 8: return
    if _seen is None: _seen = set()
    try:
        if items is None: return
        seq = list(items) if isinstance(items, (list, tuple)) else [items]
    except Exception:
        seq = None
    if not seq: return
    for it in seq:
        if it is None: continue
        try:
            k = id(it)
            if k in _seen: continue
            _seen.add(k)
        except Exception:
            pass
        for attr in _UI_CB_ATTRS:
            try:
                cb = getattr(it, attr, None)
            except Exception:
                cb = None
            if cb is None or not callable(cb): continue
            if getattr(cb, _B_TAGGED_FLAG, False): continue
            try: setattr(it, attr, _wrap_entry(pid, cb, attr in _UI_CLICK_ATTRS))
            except Exception: pass
        for fattr in _UI_FACTORY_ATTRS:
            try:
                fac = getattr(it, fattr, None)
            except Exception:
                fac = None
            if fac is None or not callable(fac): continue
            if getattr(fac, _B_TAGGED_FLAG, False): continue
            try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
            except Exception: pass
        for cattr in _UI_CONTAINER_ATTRS:
            try:
                child = getattr(it, cattr, None)
            except Exception:
                child = None
            if child is None or callable(child): continue
            if isinstance(child, (str, bytes)): continue
            try: _wrap_ui_callbacks(pid, child, _depth + 1, _seen)
            except Exception: pass

def _wrap_settings_factory(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            items = fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
        try: _wrap_ui_callbacks(pid, items)
        except Exception: pass
        return items
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

def _wrap_entry(pid, fn, ui_click=False):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        if ui_click:
            try: _ui_click_enter(pid)
            except Exception: pass
        try:
            return fn(*a, **kw)
        finally:
            if ui_click:
                try: _ui_click_leave()
                except Exception: pass
            if pushed: _scoped_clear()
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

_SETTINGS_CTOR_HOOKED = False
_SETTINGS_ITEM_CLASSNAMES = ("Text", "Switch", "Selector", "Input", "Slider", "Header", "Divider", "Category", "Card", "Custom", "Toggle", "Button")
_SETTINGS_PATCHED = []


def _seed_settings_item(it):
    try:
        pid = _provenance_pid(None, 1)
    except Exception:
        pid = None
    if not pid or pid == _SELF_ID or pid == __id__:
        return
    for attr in _UI_CB_ATTRS:
        try: cb = getattr(it, attr, None)
        except Exception: cb = None
        if cb is None or not callable(cb): continue
        if getattr(cb, _B_TAGGED_FLAG, False): continue
        try: setattr(it, attr, _wrap_entry(pid, cb, attr in _UI_CLICK_ATTRS))
        except Exception: pass
    for fattr in _UI_FACTORY_ATTRS:
        try: fac = getattr(it, fattr, None)
        except Exception: fac = None
        if fac is None or not callable(fac): continue
        if getattr(fac, _B_TAGGED_FLAG, False): continue
        try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
        except Exception: pass
def _install_settings_ctor_scope():
    global _SETTINGS_CTOR_HOOKED
    if _SETTINGS_CTOR_HOOKED:
        return
    uis = None
    try:
        uis = _sys.modules.get("ui.settings")
        if uis is None:
            import ui.settings as uis
    except Exception as e:
        _log("Gap8 settings-ctor: ui.settings unavailable: %r" % e)
        return
    n = 0
    for nm in dir(uis):
        try: cls = getattr(uis, nm, None)
        except Exception: cls = None
        if not isinstance(cls, type):
            continue
        mod = getattr(cls, "__module__", "") or ""
        if not (mod.startswith("ui.settings") or nm in _SETTINGS_ITEM_CLASSNAMES):
            continue
        orig = cls.__dict__.get("_culprit_orig_init", None)
        if orig is None:
            orig = cls.__dict__.get("__init__", None)
            if orig is None:
                continue
            try: cls._culprit_orig_init = orig
            except Exception: pass
        def _make(orig_init):
            def _patched(self, *a, **kw):
                orig_init(self, *a, **kw)
                try: _seed_settings_item(self)
                except Exception: pass
            return _patched
        try:
            _w = _make(orig)
            cls.__init__ = _w
            try: _SETTINGS_PATCHED.append((cls, orig, _w))
            except Exception: pass
            n += 1
        except Exception:
            pass
    _SETTINGS_CTOR_HOOKED = True
    _log("Gap8/+BH settings-ctor scope: обёрнуто классов ui.settings=%d (on_change/on_click/create_sub_fragment тегируются в источнике)" % n)

