                    if _mt_top:
                        rec["tombstone_top_symbol"] = _mt_top
                    _mt_skew = _tombstone_base_skew(rec.get("frames"), _tb)
                    if _mt_skew is not None:
                        rec["inproc_base_skew"] = int(_mt_skew)
                        rec["inproc_base_skew_hex"] = hex(int(_mt_skew) & ((1 << 64) - 1))
                    _mt_cls = _tombstone_symbol_class(_tb.get("frames"))
                    _so_msg = (rec.get("abort_message") or rec.get("abort_msg") or "")
                    if "stackoverflow" in _so_msg.lower():
