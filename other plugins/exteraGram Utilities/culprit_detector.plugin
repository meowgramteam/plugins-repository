def _appev_pid_from_args(args):
    if not args: return None
    try: n = len(args)
    except Exception: return None
    for i in range(n):
        a = args[i]
        if a is None: continue
        try: s = str(a)
        except Exception: continue
        if (not s) or len(s) > 80: continue
        if (s in _REGISTRY) or (s in _PID_IDX): return s
    for i in range(n):
        a = args[i]
        if a is None: continue
        for attr in ("getId", "getPluginId", "id"):
            try:
                v = getattr(a, attr, None)
                v = v() if callable(v) else v
                if v is None: continue
                sv = str(v)
                if sv and len(sv) <= 80 and ((sv in _REGISTRY) or (sv in _PID_IDX)): return sv
            except Exception:
                pass
    return None

