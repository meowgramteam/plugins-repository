def _b30_start():
    global _B30_STARTED
    if not _BLOCK30_ON: return
    if not (_B30_OK and _NATIVE_OK and _NLIB is not None):
        _log("Block#30: nativ/simvoly nedostupny -- propusk"); return
    if _B30_STARTED: return
    p = _kg_sentinel_path()
    if not p:
        _log("Block#30: put killguard.txt nedostupen -- propusk"); return
    _pw = _aw_mirror_path(p) or p
    try:
        rc = int(_NLIB.cd_kg_start(_pw.encode("utf-8")))
    except Exception as e:
        _log("Block#30 cd_kg_start err: %s" % e); return
    if rc < 0:
        _log("Block#30: cd_kg_start vernul %d -- libc kill/exit ne zacepilis" % rc); return
    _B30_STARTED = True
    _log("Block#30: kill-guard установлен (libc kill/tgkill/exit/_exit/_Exit), хуков=%d -> %s" % (rc, _pw))
    try: _b30_read_sentinel("post-start")
    except Exception: pass

def _b30_stop():
    global _B30_STARTED
    if not _B30_STARTED: return
    try:
        if _NLIB is not None: _NLIB.cd_kg_stop()
    except Exception: pass
    _B30_STARTED = False
    _log("Block#30: snjat (cd_kg_stop)")

def _kg_crash_corroborate(idx, ts, name):
    try:
        _unres = (not name) or (name == "unknown") or name.startswith("#") or name.startswith("idx#")
        _best = None
        for _pf in (_crash_verdict_durable_path, _crash_path):
            try: _p = _pf()
            except Exception: _p = None
            if not _p: continue
            try:
                if not os.path.exists(_p): continue
                with open(_p, "r", encoding="utf-8") as _f:
                    _crec = json.load(_f)
            except Exception:
                continue
            if not isinstance(_crec, dict): continue
            _nm = _crec.get("crashed_plugin_id")
            if not (isinstance(_nm, str) and _nm and _nm != "unknown"): continue
            if _nm.startswith("#") or _nm.startswith("idx#") or _nm.startswith("$Proxy"): continue
            try: _rts = int(_crec.get("ts") or 0)
            except Exception: _rts = 0
            if (not _rts) or abs(int(ts) - _rts) > 3000: continue
            try: _ridx = int(_crec.get("reg_idx"))
            except Exception: _ridx = -1
            if _ridx >= 0 and idx >= 0 and _ridx == idx:
                return (_nm, "crash-corr/idx+ts", name)
            if _unres and _crec.get("confidence") == "high" and _best is None:
                _best = (_nm, "crash-corr/ts-window", name)
        return _best
    except Exception:
        return None

def _b30_parse_sentinel(text):
    rec = {}
    try:
        for line in text.splitlines():
            line = line.strip()
            if not line or line in ("CULPRIT_KILLGUARD", "END"): continue
            for tok in line.split(" "):
                if "=" in tok:
                    k, v = tok.split("=", 1)
                    rec[k] = v
    except Exception:
        pass
    return rec

def _b30_read_sentinel(tag):
    if not _BLOCK30_ON: return None
    p = _kg_sentinel_path()
    if not p: return None
    _rp = _rc_take_path(p)
    if not _rp: return None
    try:
        with open(_rp, "r", encoding="utf-8", errors="replace") as f:
            text = f.read()
    except Exception:
        return None
    finally:
        try: os.remove(_rp)
        except Exception: pass
    rec = _b30_parse_sentinel(text)
    if not rec: return None
    owner_id = rec.get("owner_id") or ""
    if owner_id in ("(?)", ""): owner_id = ""
    try: idx = int(rec.get("owner_idx", "-1"))
    except Exception: idx = -1
    name = owner_id or _resolve_idx_durable(idx) or (("idx#%d" % idx) if idx >= 0 else "unknown")
    name = _deidx_name(name)
    api = rec.get("api", "?")
    try: sig = int(rec.get("signal", "0"))
    except Exception: sig = 0
    try: ts = int(rec.get("ts", "0"))
    except Exception: ts = int(time.time() * 1000)
    _kgc = _kg_crash_corroborate(idx, ts, name)
    if _kgc: name = _kgc[0]
    low = name.lower()
    dropper = ("netprotector" in low) or ("netblocker" in low) or ("shikatu" in low)
    vector = "Process.killProcess(myPid)" if api in ("kill", "tgkill") else "System.exit"
    verdict = {
        "event_type": "selfkill_blocked", "dropbox_tag": "self_protection", "tombstone_norm_version": 1,
        "kind": "self_kill_blocked", "culprit": name, "owner_idx": idx,
        "api": api, "signal": sig, "vector": vector,
        "dropper_signature": dropper, "neutralized": True,
        "confidence": "high", "detector": "Block#30 native kill-guard",
        "version": __version__, "ts": ts, "tag": tag,
    }
    verdict["owner_id_raw"] = owner_id or None
    if not _kgc:
        verdict["culprit_src"] = "sidecar-owner-id" if owner_id else ("idx-durable" if idx >= 0 else "unresolved")
    if _kgc:
        verdict["culprit_src"] = _kgc[1]
        if _kgc[2] != _kgc[0]: verdict["culprit_sidecar"] = _kgc[2]
    vp = _kg_verdict_path()
    if vp:
        try:
            if not _atomic_json_write(vp, verdict):
                _log("Block#30 verdict write returned False")
        except Exception as e:
            _log("Block#30 verdict write err: %s" % e)
    try:
        _kh = _kg_history_path()
        if _kh:
            _khist = []
            try:
                if os.path.exists(_kh):
                    with open(_kh, "r", encoding="utf-8") as _khf:
                        _khist = list(json.load(_khf))
            except Exception:
                _khist = []
            _khist.append(verdict)
            _atomic_json_write(_kh, _khist, 40)
    except Exception as _ekh:
        try: _log("Block#30 history append err: %s" % _ekh)
        except Exception: pass
    try: _kg_tid = int(rec.get("tid", ""))
    except Exception: _kg_tid = None
    try: globals()["_B30_LAST_BLOCKED"] = {"ts": ts, "culprit": name, "vector": vector, "dropper": dropper, "tid": _kg_tid}
    except Exception: pass
    _log("=============== SELF-KILL NEUTRALIZED (Block#30) ===============")
    _log("  culprit=%s api=%s signal=%d vector=%s dropper=%s" % (name, api, sig, vector, dropper))
    _log("  detector survived; verdict -> %s" % _KG_VERDICT_NAME)
    _log("===============================================================")
    try:
        _b16_push_verdict("self_kill_blocked", {"culprit": name, "confidence": "high", "where": vector, "ts": ts})
    except Exception:
        pass
    return verdict

