from base_plugin import BasePlugin, MethodHookfrom hook_utils import find_classfrom ui.settings import Header, Switch, Divider__id__ = "hide_paid_reactions"__name__ = "Hide Paid Reactions"__description__ = "Скрывает платные реакции (звёзды) в сообщениях"__author__ = "@AzureStrike"__version__ = "1.3.1"__icon__ = "exteraPlugins/1"__min_version__ = "11.12.0"def is_paid(reaction_obj):    try:        cname = reaction_obj.getClass().getName()        return "reactionpaid" in cname.lower() or "TL_reactionPaid" in cname    except Exception:        return Falsedef remove_paid(results):    if results is None:        return    try:        to_remove = [results.get(i) for i in range(results.size())                     if results.get(i) is not None                     and results.get(i).reaction is not None                     and is_paid(results.get(i).reaction)]        for rc in to_remove:            results.remove(rc)    except Exception:        passdef patch_msg(msg_obj, plugin):    if not plugin.get_setting("enabled", True) or msg_obj is None:        return    try:        owner = msg_obj.messageOwner        if owner is None or owner.reactions is None:            return        remove_paid(owner.reactions.results)        remove_paid(owner.reactions.recentReactions)    except Exception:        passclass SetMessageHook(MethodHook):    def __init__(self, plugin):        self.plugin = plugin    def before_hooked_method(self, param):        try:            patch_msg(param.args[0], self.plugin)        except Exception:            passclass LayoutHook(MethodHook):    def __init__(self, plugin):        self.plugin = plugin    def before_hooked_method(self, param):        try:            obj = param.thisObject            if obj is None:                return            for field in ("messageObject", "currentMessageObject"):                try:                    patch_msg(getattr(obj, field), self.plugin)                except Exception:                    pass        except Exception:            passclass HidePaidReactionsPlugin(BasePlugin):    def on_plugin_load(self):        set_hook    = SetMessageHook(self)        layout_hook = LayoutHook(self)        total       = 0        for class_name, method_name, hook in [            ("org.telegram.ui.Cells.ChatMessageCell",               "setMessageObject", set_hook),            ("org.telegram.ui.Components.ReactionsLayoutInBubble",  "setMessage",       set_hook),            ("org.telegram.ui.Components.ReactionsContainerLayout", "setMessage",       set_hook),            ("com.exteragram.messenger.ui.Cells.ChatMessageCell",   "setMessageObject", set_hook),            ("org.telegram.ui.Components.ReactionsLayoutInBubble",  "onMeasure",        layout_hook),            ("org.telegram.ui.Components.ReactionsLayoutInBubble",  "layout",           layout_hook),            ("org.telegram.ui.Components.ReactionsLayoutInBubble",  "measure",          layout_hook),            ("org.telegram.ui.Components.ReactionsLayoutInBubble",  "requestLayout",    layout_hook),            ("org.telegram.ui.Components.ReactionsContainerLayout", "onMeasure",        layout_hook),            ("org.telegram.ui.Components.ReactionsContainerLayout", "measure",          layout_hook),        ]:            cls = find_class(class_name)            if cls is None:                continue            res = self.hook_all_methods(cls, method_name, hook)            if res:                total += len(res)        self.log(f"[HPR] hooks: {total}, enabled: {self.get_setting('enabled', True)}")    def create_settings(self):        return [            Header(text="Hide Paid Reactions"),            Switch(                key="enabled",                text="Скрывать звёзды",                default=True,                subtext="Вкл — платные реакции скрыты. Выкл — видны.",                icon="msg_block",            ),            Divider(text="Изменение применяется к новым сообщениям сразу"),        ]