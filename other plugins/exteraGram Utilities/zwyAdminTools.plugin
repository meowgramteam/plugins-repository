            safe_set_subtext(
                Text(
                    text=L.prefs_fed_list,
                    icon="msg_topics",
                    create_sub_fragment=cls._gen_feds_list_subfragment
                ),
                L.prefs_fed_list_hint
            ) if PrefsUtils.get_active_fed_type() == FederationType.LOCAL else None,
            Divider()
        ]

    @classmethod
    def _gen_feds_list_subfragment(cls) -> List:
        async def create_fed():
            if fed_name := await UI.StringInputDialog.show(L.prefs_feds_new_alert_title, hint=L.prefs_feds_new_alert_hint):
                fed_name = fed_name.strip()
                feds_controller.create_new(fed_name)
                SettingsManager.reload()

        def show_popup(view: View, fed_name: str):
            def _show_delete_alert():
                def _delete_fed():
                    feds_controller.delete(fed_name)
                    SettingsManager.reload()
                    bulletin.show_success(L.prefs_fed_del_success(name=fed_name))

                run_on_ui_thread(UI.AlertDialog(
                    L.prefs_feds_header,
                    L.prefs_fed_del_main(name=fed_name),
                    [
                        UI.AlertButton(L.prefs_im_sure, lambda _, __: _delete_fed(), red=True),
                        UI.AlertButton(L.popup_close_button, type=AlertDialogBuilder.BUTTON_NEGATIVE),
                    ]
                ).show)

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_feds_delete, icon="msg_delete", on_click=_show_delete_alert, is_red=True))
            builder.show()

        feds_entries = []
        for federation_name in feds_controller.cache.content:
            feds_entries.append(Text(
                text=federation_name,
                icon="msg_discuss",
                create_sub_fragment=lambda fed_name=federation_name: cls._gen_fed_subfragment(fed_name),
                on_long_click=lambda v, fed_name=federation_name: show_popup(v, fed_name)
            ))

        return [
            Text(
                text=L.prefs_feds_new_alert_title,
                icon="msg_topic_create",
                accent=True,
                on_click=lambda _: run_async(create_fed())
            ),
            *([Divider()] + feds_entries if feds_entries else []),
            Divider(L.prefs_feds_list_fragment_hint),
        ]

    @classmethod
    def _gen_fed_subfragment(cls, federation_name: str) -> List:
        async def connect_chat():
            try:
                print(federation.chats)
                picked = await zwylib.DialogPicker.pick_dialogs(federation.chats, chats_only=True)
            except Exception as e:
                if not "cancelled" in str(e).lower():
                    show_general_error(exc=True)
                return

            federation.chats = []

            not_admin_in_some_chats = False
            for cid in picked.chats:
                if not await can_use_command(cid, allow_channels=True):
                    not_admin_in_some_chats = True
                    continue
                federation.add_chat(cid)

            if not_admin_in_some_chats:
                bulletin.show_error(L.not_admin_in_some_chats)

            SettingsManager.reload()

        def show_popup(view: View, cid: int):
            def _open_chat():
                open_chat(cid)
                logger.debug(f"Opened '{safe_get_chat_title(cid)}' chat.")

            def _disconnect_chat():
                feds_controller.get(federation_name).remove_chat(cid)
                SettingsManager.reload()

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_feds_view_chat, icon="msg_viewintopic", on_click=_open_chat))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_feds_disconnect_chat, icon="msg_delete", on_click=_disconnect_chat, is_red=True))
            builder.show()

        federation = feds_controller.get(federation_name)
        if SUPPORTS_NEW_CELLS_STYLE:
            feds_entries = [
                custom_user_cell(
                    peer_id=-chat_id,
                    text=safe_get_chat_title(chat := get_chat(chat_id)),
                    subtext=get_participants_safe(chat),
                    on_click=lambda _, __, ___, v, cid=chat_id: show_popup(v, cid),
                    on_long_click=lambda _, __, ___, v, cid=chat_id: show_popup(v, cid),
                ) for chat_id in federation.chats
            ]
        else:
            feds_entries = [
                Text(
                    text=safe_get_chat_title(chat_id),
                    icon="msg_discuss",
                    on_click=lambda v, cid=chat_id: show_popup(v, cid),
                    on_long_click=lambda v, cid=chat_id: show_popup(v, cid),
                ) for chat_id in federation.chats
            ]

        return [
            Text(
                text=L.prefs_feds_connect_chat,
                icon="msg2_chats_add",
                accent=True,
                on_click=lambda _: run_async(connect_chat())
            ),
            *( [Divider()] + feds_entries if feds_entries else [] ),
            Divider(L.prefs_feds_subfragment_hint)
        ]

    @classmethod
    def _gen_regex_chat_sublist(cls) -> List:
        async def add_chat():
            try:
                picked = await zwylib.DialogPicker.pick_dialogs(chats_only=True)
            except Exception as e:
                if not "cancelled" in str(e).lower():
                    show_general_error(exc=True)
                return

            cannot_add_some_chats = False
            for cid in picked.chats:
                if not await can_use_command(cid, check_can_restrict=True):
                    cannot_add_some_chats = True
                    continue
                regex_filters_manager.add_chat(cid)

            if cannot_add_some_chats:
                bulletin.show_error(L.not_admin_in_some_chats)

            SettingsManager.reload()

        def show_popup(view: View, cid: int):
            def remove_chat():
                def _remove_chat():
                    regex_filters_manager.remove_chat(cid)
                    SettingsManager.reload()

                buttons = [
                    UI.AlertButton(L.prefs_im_sure, lambda _, __: _remove_chat(), red=True),
                    UI.AlertButton(L.popup_close_button, type=AlertDialogBuilder.BUTTON_NEGATIVE),
                ]
                run_on_ui_thread(UI.AlertDialog(L.prefs_regex, L.prefs_regex_rem_chat_main, buttons).show)

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_remove_chat, icon="msg_delete", on_click=remove_chat, is_red=True))
            builder.show()

        if not S.regex_popup_on_first_enter.get():
            run_on_ui_thread(UI.AlertDialog(
                title=L.prefs_regex,
                text=L.regex_alert_warning_text,
                buttons=[UI.AlertButton(L.popup_i_understand_button)]
            ).show)
            S.regex_popup_on_first_enter.set(True)

        main_entries_switch = [
            S.regex_filters.as_switch(
                text=L.prefs_regex_system_switch,
            ),
            S.regex_auto_delete_target_msg.as_switch(
                text=L.prefs_regex_delete_after_restrict_label,
                subtext=L.prefs_regex_delete_after_restrict_hint,
            ),
        ]

        if not S.regex_filters.get():
            return main_entries_switch

        all_filters = regex_filters_manager.get_all()
        if SUPPORTS_NEW_CELLS_STYLE:
            chat_entries = [
                custom_user_cell(
                    peer_id=-cid,
                    text=safe_get_chat_title(cid),
                    subtext="{} {}".format(
                        (cnt := len(regex_filters_manager.get_filters(cid))),
                        L.plural("filters", cnt)
                    ),
                    create_sub_fragment=lambda cid=cid: cls._gen_regex_chat(cid),
                    on_long_click=lambda _, __, ___, v, cid=cid: show_popup(v, cid),
                ) for cid in all_filters
            ]
        else:
            chat_entries = [
                Text(
                    text=safe_get_chat_title(cid),
                    icon="msg_discuss",
                    create_sub_fragment=lambda cid=cid: cls._gen_regex_chat(cid),
                    on_long_click=lambda v, cid=cid: show_popup(v, cid),
                ) for cid in all_filters
            ]

        entries = [
            *main_entries_switch,
            Divider(),
            *(chat_entries + [Divider()] if chat_entries else []),
            Text(
                L.prefs_regex_add_chat,
                icon="msg2_chats_add",
                accent=True,
                on_click=lambda _: run_async(add_chat())
            ),
            Divider(L.prefs_regex_chat_list_hint),
        ]

        return entries

    @classmethod
    def _gen_regex_chat(cls, chat_id: int) -> List:
        async def add_regex():
            if (edit_result := await RegexFilterDialog.show()) is not None:
                regex_filters_manager.add_filter(chat_id, edit_result)
                SettingsManager.reload()

        def show_popup(view: View, cid: int, regex: RegexFilter):
            async def _edit_regex():
                edit_result = await RegexFilterDialog.show(
                    alert_title=L.regex_alert_edit_title,
                    initial_text=regex.text,
                    initial_case=regex.case_insensitive,
                )

                if edit_result is None:
                    return

                new_filter = RegexFilter.copy(regex)
                new_filter.text = edit_result.text
                new_filter.case_insensitive = edit_result.case_insensitive

                regex_filters_manager.replace_filter(chat_id, regex, new_filter)
                SettingsManager.reload()
                bulletin.show_success(L.prefs_regex_filter_edit_success)

            async def _edit_time():
                got_time = await UI.StringInputDialog.show(L.regex_alert_edit_time_title, hint=L.regex_alert_edit_time_hint)
                got_time = (got_time or "").strip()

                if (parsed := TimeUtils.parse_duration(got_time)) == 0:
                    bulletin.show_error(L.regex_incorrect_time)
                    return

                new_filter = RegexFilter.copy(regex)
                new_filter.restrict_time = parsed

                regex_filters_manager.replace_filter(cid, regex, new_filter)
                SettingsManager.reload()
                bulletin.show_success(L.prefs_regex_filter_edit_success)

            async def _edit_reply_text():
                text = await UI.StringInputDialog.show(
                    L.regex_alert_edit_reply_text_title,
                    hint=L.regex_alert_edit_reply_text_hint,
                    initial_text=regex.reply_text
                )

                if text is None:
                    return

                if not (text := text.strip()):
                    bulletin.show_error(L.prefs_regex_filter_edit_error)
                    return

                new_filter = RegexFilter.copy(regex)
                new_filter.reply_text = text

                regex_filters_manager.replace_filter(cid, regex, new_filter)
                SettingsManager.reload()
                bulletin.show_success(L.prefs_regex_filter_edit_success)

            async def _edit_action():
                picked = await UI.SelectorDialog.show(
                    title=L.regex_alert_restrictions_title,
                    items=[str(i.value) for i in REGEX_ACTIONS],
                    current_index=REGEX_ACTIONS.index(regex.restrict_action)
                )
                if not picked:
                    return

                new_filter = RegexFilter.copy(regex)
                new_filter.restrict_action = REGEX_ACTIONS[picked]

                regex_filters_manager.replace_filter(cid, regex, new_filter)
                SettingsManager.reload()
                bulletin.show_success(L.prefs_regex_filter_edit_success)

            def _delete_regex():
                regex_filters_manager.remove_filter(cid, regex)
                SettingsManager.reload()

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_edit_filter, icon="menu_tag_edit", on_click=lambda: run_async(_edit_regex())))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_edit_action, icon="msg_admins", on_click=lambda: run_async(_edit_action())))
            if is_action_timed(regex.restrict_action):
                builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_edit_time, icon="msg_mute_1h", on_click=lambda: run_async(_edit_time())))
            if regex.restrict_action == OtherCommands.REPLY:
                builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_edit_reply_text, icon="menu_reply", on_click=lambda: run_async(_edit_reply_text())))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_regex_remove_filter, icon="msg_delete", on_click=_delete_regex, is_red=True))
            builder.show()

        entries: List = [
            Text(
                text=L.prefs_regex_add_filter,
                icon="menu_tag_plus",
                accent=True,
                on_click=lambda _: run_async(add_regex())
            ),
            Divider(),
        ]

        for f in regex_filters_manager.get_filters(chat_id):
            entries.append(Text(
                text=f.text,
                on_click=lambda v, cid=chat_id, regex=f: show_popup(v, cid, regex)
            ))

        entries.append(Divider(L.prefs_regex_list_hint))
        return entries

    @classmethod
    def _gen_ai_checker(cls) -> List:
        return [
            Header(L.prefs_ai_checker_header),
            Text(
                text=L.prefs_api_key_guide_label,
                icon="msg_permissions",
                accent=True,
                on_click=lambda _: open_api_key_guide_message()
            ),
            S.look_in_all_topics.as_switch(
                text=L.prefs_look_in_all_topics_label,
                subtext=L.prefs_look_in_all_topics_hint,
            ),
            Divider(),
            safe_set_subtext(
                Text(
                    text=L.prefs_cr_header,
                    icon="msg_topics",
                    create_sub_fragment=cls._gen_chat_rules
                ),
                L.prefs_cr_header_subtext
            ),
            Divider(),
        ]

    @classmethod
    def _gen_chat_rules(cls) -> List:
        def show_popup(view: View, cr: ChatRules):
            def open_rules():
                if cr.message_id:
                    run_async(zwylib.safe_open_message(-cr.chat_id, cr.message_id, cr.topic_id, cr.chat_username))
                else:
                    run_on_ui_thread(UI.AlertDialog(
                        title=L.prefs_chat_rules(name=safe_get_chat_title(cr.chat_id)),
                        text=cr.text,
                        buttons=[UI.AlertButton(L.popup_close_button)],
                    ).show)

            def delete_rules():
                chat_rules_manager.remove(cr.chat_id)
                SettingsManager.reload()

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_cr_view_rules, icon="msg_viewintopic" if cr.message_id else "msg_message", on_click=open_rules))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_cr_remove, icon="msg_delete", on_click=delete_rules, is_red=True))
            builder.show()

        strictnesses_names = [L.get(i) for i in AIChecker.strictnesses]
        all_chat_rules = chat_rules_manager.get_all()
        last_index = len(all_chat_rules) - 1

        entries: List = [
            S.same_strictness_mode.as_switch(
                text=L.prefs_same_strictness_for_all_label,
                subtext=L.prefs_same_strictness_for_all_hint,
            ),
            S.strictness_level.as_selector(
                text=L.prefs_strictness,
                items=[L.get(i) for i in AIChecker.strictnesses],
                icon=get_strictness_icon(S.strictness_level.get()),
            ) if S.same_strictness_mode.get() else None,
            Divider(L.prefs_strictness_hint),
        ]

        if not all_chat_rules:
            return entries

        entries.append(Header(L.prefs_cr_header))

        for index, chat_rules in enumerate(all_chat_rules):
            chat_title = safe_get_chat_title(chat_rules.chat_id)

            if SUPPORTS_NEW_CELLS_STYLE:
                entries.append(custom_user_cell(
                    peer_id=-chat_rules.chat_id,
                    text=chat_title,
                    subtext=L.prefs_cr_view_message if chat_rules.message_id else L.prefs_cr_view_text,
                    on_click=lambda _, __, ___, v, cr=chat_rules: show_popup(v, cr),
                    on_long_click=lambda _, __, ___, v, cr=chat_rules: show_popup(v, cr),
                ))
            else:
                entries.append(Text(
                    text=chat_title,
                    icon="msg_discuss",
                    on_click=lambda v, cr=chat_rules: show_popup(v, cr),
                    on_long_click=lambda v, cr=chat_rules: show_popup(v, cr),
                ))

            if not S.same_strictness_mode.get():
                key = f"strictness_level_{chat_rules.chat_id}"
                val = SettingsManager.get(key, S.strictness_level.default)

                entries.append(Selector(
                    key=key,
                    text=L.prefs_strictness,
                    default=S.strictness_level.default,
                    items=strictnesses_names,
                    icon=get_strictness_icon(val),
                ))

                if index != last_index:
                    entries.append(Divider())

        entries.append(Divider(L.prefs_cr_subfragment_hint))
        return entries

    @classmethod
    def _gen_menu_items(cls) -> List:
        ctx_buttons_setting_entries = [
            S.ban_context_menu,
            S.fban_context_menu,
            S.kick_context_menu,
            S.mute_context_menu,
            S.set_rules_context_menu,
            S.edit_rights_context_menu,
            S.delete_all_from_context_menu,
        ]

        enabled: List[SettingEntry] = []
        disabled: List[SettingEntry] = []

        for entry in ctx_buttons_setting_entries:
            if entry.get():
                enabled.append(entry)
            else:
                disabled.append(entry)

        def toggle(item: SettingEntry, value: bool):
            SettingsManager.set(item, value)
            register_context_menu_items()

        return [
            Header(L.prefs_enabled_menu_items) if enabled else None,
            *[
                Text(
                    text=L.get(entry.key),
                    icon=entry.icon,
                    on_click=lambda _, item=entry: toggle(item, False),
                ) for entry in enabled
            ],
            Divider() if enabled and disabled else None,
            Header(L.prefs_disabled_menu_items) if disabled else None,
            *[
                Text(
                    text=L.get(entry.key),
                    icon=entry.icon,
                    on_click=lambda _, item=entry: toggle(item, True),
                ) for entry in disabled
            ],
            Divider(L.prefs_edit_menu_items_hint),
        ]

    @classmethod
    def _gen_autolog_chats(cls) -> List:
        async def add_chat():
            try:
                picked = await zwylib.DialogPicker.pick_dialogs(chats_only=True)
            except Exception as e:
                if not "cancelled" in str(e).lower():
                    show_general_error(exc=True)
                return

            cannot_add_some_chats = False
            for cid in picked.chats:
                if not await can_use_command(cid):
                    cannot_add_some_chats = True
                    continue
                action_log_manager.add_chat(cid)

            if cannot_add_some_chats:
                bulletin.show_error(L.not_admin_in_some_chats)

            SettingsManager.reload()

        def show_popup(view: View, cid: int):
            async def _connect_chat():
                try:
                    picked = await zwylib.DialogPicker.pick_chat(topics=True)
                except Exception as e:
                    if not "cancelled" in str(e).lower():
                        show_general_error(exc=True)
                    return

                action_log_manager.set_log_chat(cid, TopicKey(picked.dialog_id, picked.topic_id))
                SettingsManager.reload()
                bulletin.show_success(L.prefs_autolog_set_success)

            def _remove_chat():
                action_log_manager.remove(cid)
                SettingsManager.reload()

            builder = UI.PopupMenuBuilder(view)
            builder.add_item(UI.PopupMenuItem(text=L.prefs_autolog_open_chat, icon="msg_viewintopic", on_click=lambda: open_chat(cid)))
            if topic_key := action_log_manager.get_for(chat_id):
                builder.add_item(UI.PopupMenuItem(text=L.prefs_autolog_open_log_chat, icon="msg_viewintopic", on_click=lambda: open_chat(topic_key.chat_id)))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_autolog_set_log_chat, icon="msg2_chats_add", on_click=lambda: run_async(_connect_chat())))
            builder.add_item(UI.PopupMenuItem(text=L.prefs_autolog_remove, icon="msg_delete", on_click=_remove_chat, is_red=True))
            builder.show()

        chats_entries = []
        for chat_id in action_log_manager.get_all():
            chat_title = safe_get_chat_title(chat_id)

            if SUPPORTS_NEW_CELLS_STYLE:
                status_text = L.prefs_yes if action_log_manager.get_for(chat_id) else L.prefs_no
                chats_entries.append(custom_user_cell(
                    peer_id=-chat_id,
                    text=chat_title,
                    subtext=f"{L.prefs_autolog_connect_status}: {status_text}",
                    on_click=lambda _, __, ___, v, cid=chat_id: show_popup(v, cid),
                    on_long_click=lambda _, __, ___, v, cid=chat_id: show_popup(v, cid),
                ))
            else:
                chats_entries.append(Text(
                    text=chat_title,
                    icon="msg_discuss",
                    on_click=lambda v, cid=chat_id: show_popup(v, cid),
                    on_long_click=lambda v, cid=chat_id: show_popup(v, cid),
                ))

        return [
            Text(
                text=L.prefs_autolog_connect_chat,
                icon="msg2_chats_add",
                accent=True,
                on_click=lambda _: run_async(add_chat()),
            ),
            Divider() if chats_entries else None,
            *chats_entries,
        ]

    @classmethod
    def _gen_other(cls) -> List:
        dp = zwylib.command_manager.get_dispatcher(__id__)

        def change_prefix(new_prefix: str):
            if not dp.validate_prefix(new_prefix):
                S.prefix.get()
                bulletin.show_error(L.invalid_prefix)
                return
            dp.set_prefix(new_prefix)

        def switch_debug_mode(new_value: bool):
            logger.setLevel(logging.DEBUG if new_value else logging.INFO)
            logger.info(f"Set '{logging.getLevelName(logger.level)}' level.")

        return [
            Header(L.prefs_other_header),
            S.prefix.as_input(
                text=L.prefs_prefix_label,
                on_change=lambda value: change_prefix(value),
            ),
            S.allow_restrict_admins_set_by_me.as_switch(
                text=L.prefs_restrict_admins,
                subtext=L.prefs_restrict_admins_hint,
            ),
            S.debug_mode.as_switch(
                text=L.debug_mode_title,
                subtext=L.debug_mode_hint,
                on_change=lambda value: switch_debug_mode(value)
            ),
            Divider()
        ]


class DeleteServiceMessagesQueue:
    @dataclass
    class Task:
        chat_id: int
        user_id: int

    def __init__(self):
        self.tasks: List[DeleteServiceMessagesQueue.Task] = []

    def request_deletion(self, chat_id: int, user_id: int):
        self.tasks.append(self.Task(chat_id, user_id))
        logger.debug(f"Requested deletion of a service message for chat '{chat_id}' and user '{user_id}'.")

    def remove_task(self, chat_id: int, user_id: int):
        for index, task in enumerate(self.tasks):
            if task.user_id == user_id and task.chat_id == chat_id:
                self.tasks.pop(index)
                break
        logger.debug(f"Removed deletion task for chat '{chat_id}' and user '{user_id}'.")

    def has_task(self, chat_id: int, user_id: int) -> bool:
        for task in self.tasks:
            if task.user_id == user_id and task.chat_id == chat_id:
                return True
        return False

    @staticmethod
    def delete_queued_service_message(account: int, update):
        try:
            if get_user_config().selectedAccount != account:
                return

            message: Optional[TLRPC.TL_message] = getattr(update, "message", None)
            if not isinstance(message, TLRPC.TL_messageService):
                return

            if not isinstance(message.action, TLRPC.TL_messageActionChatDeleteUser):
                return

            user_id = message.action.user_id
            chat_id = message.peer_id.chat_id or message.peer_id.channel_id

            if not delete_service_msgs_queue.has_task(chat_id, user_id):
                return

            Requests.delete_messages([message.id], -chat_id, MessageObject.getTopicId(account, message))
            delete_service_msgs_queue.remove_task(chat_id, user_id)
            logger.debug("Service message of user removal was deleted.")
        except Exception:
            show_general_error(exc=True)


def get_topic_id_from_msg(account: int, msg: TLRPC.TL_message) -> int:
    return MessageObject.getTopicId(account, msg)


def handle_update(account: int, update):
    handlers: List[Callable[[int, Any], Union[Awaitable[None], None]]] = [
        delete_service_msgs_queue.delete_queued_service_message,
        regex_filters_manager.check_regex_filters if S.regex_filters.get() else None
    ]

    def run(_handler: Callable[[int, Any], Union[Awaitable[None], None]]):
        try:
            if inspect.iscoroutinefunction(_handler):
                run_async(_handler(account, update))
            else:
                _handler(account, update)
        except Exception:
            show_general_error(exc=True)

    for handler in filter(lambda i: i is not None, handlers):
        run_on_queue(lambda h=handler: run(_handler=h))


@dataclass
class RegexFilter:
    text: str
    case_insensitive: bool
    restrict_time: int
    restrict_action: Union[AdminCommands, "OtherCommands"]
    reply_text: Optional[str] = None
    pattern: Optional[re.Pattern] = field(init=False, repr=False, compare=False)

    def __post_init__(self):
        self.compile()

    def compile(self):
        flags = re.IGNORECASE if self.case_insensitive else 0
        try:
            self.pattern = re.compile(self.text, flags)
        except re.error as e:
            logger.error(f"Failed to compile regex '{self.text}': {e}")
            self.pattern = None

    def to_dict(self) -> Dict:
        return {
            "text": self.text,
            "case_insensitive": self.case_insensitive,
            "restrict_time": self.restrict_time,
            "restrict_action": REGEX_ACTIONS.index(self.restrict_action),
            "reply_text": self.reply_text,
        }

    @classmethod
    def from_dict(cls, data: Dict) -> "RegexFilter":
        return cls(
            text=data.get("text", ""),
            case_insensitive=data.get("case_insensitive", False),
            restrict_time=data.get("restrict_time", 0),
            restrict_action=REGEX_ACTIONS[data.get("restrict_action", 0)],
            reply_text=data.get("reply_text", None),
        )

    @classmethod
    def copy(cls, another: "RegexFilter") -> "RegexFilter":
        return cls.from_dict(another.to_dict())


class RegexFiltersManager:
    def __init__(self):
        self._storage = zwylib.JsonCacheFile("admintools__filters_db", {})
        self._cache: Dict[int, List[RegexFilter]] = {}

    def get_all(self) -> Dict[int, List[str]]:
        return {int(k): v for k, v in self._storage.content.items()}

    def get_filters(self, chat_id: int) -> List[RegexFilter]:
        if chat_id not in self._cache:
            raw_filters = self._storage.content.get(str(chat_id), [])
            self._cache[chat_id] = [RegexFilter.from_dict(f) for f in raw_filters]
        return self._cache[chat_id]

    def _save_chat_filters(self, chat_id: int):
        filters = self.get_filters(chat_id)
        self._storage.content[str(chat_id)] = [f.to_dict() for f in filters]
        self._storage.write()

    def add_filter(self, chat_id: int, result: "RegexFilterResult"):
        filters = self.get_filters(chat_id)

        if any(f.text == result.text for f in filters):
            logger.warning(f"Filter '{result.text}' already exists in '{safe_get_chat_title(chat_id)}'")
            return

        new_filter = RegexFilter(
            text=result.text,
            case_insensitive=result.case_insensitive,
            restrict_time=30 * 60 * 60 * 24,
            restrict_action=AdminCommands.MUTE,
        )
        filters.append(new_filter)

        self._save_chat_filters(chat_id)
        logger.debug(f"Added new filter for '{safe_get_chat_title(chat_id)}': {result.text}")

    def remove_filter(self, chat_id: int, regex: RegexFilter):
        filters = self.get_filters(chat_id)
        original_len = len(filters)

        self._cache[chat_id] = [f for f in filters if f != regex]

        if len(self._cache[chat_id]) == original_len:
            logger.debug(f"Regex '{regex.text}' not found in chat '{chat_id}'!")
            return

        self._save_chat_filters(chat_id)
        logger.debug(f"Removed filter for '{chat_id}': {regex.text}")

    def replace_filter(self, chat_id: int, old_filter: RegexFilter, new_filter: RegexFilter):
        filters = self.get_filters(chat_id)
        self._cache[chat_id] = [RegexFilter.copy(new_filter) if f == old_filter else f for f in filters]
        self._save_chat_filters(chat_id)
        logger.debug(f"Edited filter for '{safe_get_chat_title(chat_id)}': {old_filter} -> {new_filter}")

    def add_chat(self, chat_id: int):
        if self.get_filters(chat_id):
            logger.debug(f"Chat '{chat_id}' already added!")
            return
        self._cache[chat_id] = []
        self._save_chat_filters(chat_id)
        logger.debug(f"Chat '{chat_id}' was added!")

    def remove_chat(self, chat_id: int):
        self._storage.content.pop(str(chat_id), None)
        self._storage.write()
        self._cache.pop(chat_id, None)
        logger.debug(f"Chat '{chat_id}' was removed!")

    async def check_regex_filters(self, account: int, update):
        if get_user_config().selectedAccount != account:
            return

        message: Optional[TLRPC.TL_message] = getattr(update, "message", None)
        text = getattr(message, "message", None)

        if not isinstance(message, TLRPC.TL_message) or not text:
            return

        chat_id = message.peer_id.channel_id or message.peer_id.chat_id
        if not chat_id:
            return

        if message.out:
            return

        if not (filters := self.get_filters(chat_id)):
            return

        target = Target.from_peer(message.from_id)
        if not await can_use_command(chat_id, target, check_can_restrict=True, notify=False):
            return

        for f in filters:
            if not f.pattern or not f.pattern.search(text):
                continue

            if isinstance(f.restrict_action, AdminCommands):
                action_info = ActionInfo(
                    action=f.restrict_action,
                    target=target,
                    seconds=f.restrict_time,
                    reason=L.regex_restriction_reason(regex=escape_markdown(f.text)),
                    delete=S.regex_auto_delete_target_msg.get(),
                    message_id_to_delete=message.id,
                )
                params = SendParams(-chat_id, topic_id=get_topic_id_from_msg(account, message))

                await RestrictUtils.execute_admin_action(action_info, params)
            elif f.restrict_action == OtherCommands.REPLY:
                SendParams(
                    -chat_id,
                    f.reply_text,
                    topic_id=get_topic_id_from_msg(account, message),
                    reply_to=MessageObject(get_user_config().selectedAccount, message, False, False),
                ).send()
            return


@dataclass
class RegexFilterResult:
    text: str
    case_insensitive: bool


class RegexFilterDialog(UI.BaseInputDialog[RegexFilterResult]):
    @classmethod
    async def show(cls, alert_title="", initial_text="", initial_case=False) -> Optional[RegexFilterResult]:
        instance = cls()
        case_cell: Any = None

        def build_extra_views(container, context, _):
            nonlocal case_cell
            case_cell = instance.create_checkbox(context, L.regex_alert_case_insensitive, initial_case, True)
            container.addView(case_cell, LayoutHelper.createLinear(MATCH_PARENT, WRAP_CONTENT))

        def collect_result():
            return RegexFilterResult(
                text=instance.edit_text.getText().toString().strip(),
                case_insensitive=case_cell.isChecked()
            )

        return await instance._show_impl(
            title=alert_title or L.regex_alert_new_title,
            initial_text=initial_text,
            hint=L.regex_alert_regex_field_hint,
            on_build_view=build_extra_views,
            get_result=collect_result
        )


SUPPORTS_NEW_CELLS_STYLE = zwylib.is_client_version_sufficient("12.5.1")

if SUPPORTS_NEW_CELLS_STYLE:
    try:
        from ui.settings import Custom
        from extera_utils.classes import Base, java_subclass, joverride, jfield
        from com.exteragram.messenger.plugins.models import CustomSetting

        @dataclass
        class UserCellData:
            peer_id: int
            text: str
            subtext: Optional[str]
            on_click: Optional[Callable[["UserCellSettingFactory", Plugin, UItem, View], None]]
            on_long_click: Optional[Callable[["UserCellSettingFactory", Plugin, UItem, View], None]]


        @java_subclass(jclass("java.lang.Object"))
        class PyObjectWrapper(Base):
            hold_object = jfield("com.chaquo.python.PyObject")


        # noinspection PyPep8Naming,PyUnusedLocal,PyAttributeOutsideInit
        @java_subclass(CustomSetting.Factory)
        class UserCellSettingFactory(Base):
            @joverride()
            def create(self, plugin: Plugin, setting: CustomSetting, args):
                if not args:
                    return None

                item = UItem.ofFactory(self.getClass())
                item.object = args
                return item

            @joverride()
            def createView(self, context, list_view, current_account, class_guid, resources_provider):
                view = UserCell(context, 12, 0, False)
                set_private_field(view, "disableFilter", False)
                return view

            @joverride()
            def bindView(self, view, item, divider, adapter, list_view):
                data: UserCellData = item.object.hold_object
                view.setData(
                    get_user(data.peer_id) or get_chat(-data.peer_id),
                    data.text, data.subtext, 0
                )

            @joverride()
            def onClick(self, plugin, item, view):
                data: UserCellData = item.object.hold_object
                if on_click := data.on_click:
                    on_click(self, plugin, item, view)

            @joverride()
            def onLongClick(self, plugin, item, view):
                data: UserCellData = item.object.hold_object
                if on_long_click := data.on_long_click:
                    on_long_click(self, plugin, item, view)
                return True


        def custom_user_cell(
                peer_id: int,
                text: str,
                subtext: str = None,
                on_click: Callable[["UserCellSettingFactory", Plugin, UItem, View], None] = None,
                on_long_click: Callable[["UserCellSettingFactory", Plugin, UItem, View], None] = None,
                create_sub_fragment: Optional[Callable[[], List]] = None,
        ) -> Optional[Custom]:
            try:
                wrapped_data = PyObjectWrapper.new_instance().java
                wrapped_data.hold_object = UserCellData(peer_id, text, subtext, on_click, on_long_click)
                return Custom(
                    factory=user_cell_factory_instance,
                    factory_args=wrapped_data,
                    create_sub_fragment=create_sub_fragment
                )
            except Exception:
                show_general_error(zwylib.format_exc())
            return None


        user_cell_factory_instance = UserCellSettingFactory.new_instance().java
        UItem.UItemFactory.setup(user_cell_factory_instance)
    except Exception:
        traceback.print_exc()


def get_participants_safe(chat: TLRPC.Chat):
    is_channel = ChatObject.isChannel(chat) and not chat.megagroup
    if chat.participants_count != 0:
        return LocaleController.formatPluralStringComma("Subscribers" if is_channel else "Members", chat.participants_count)
    elif not ChatObject.isPublic(chat):
        return LocaleController.getString("ChannelPrivate" if is_channel else "MegaPrivate")
    else:
        return LocaleController.getString("ChannelPublic" if is_channel else "MegaPublic")


class CustomEncoder(json.JSONEncoder):
    def default(self, obj):
        try:
            return json.JSONEncoder.default(self, obj)
        except TypeError:
            return str(obj)


def pretty_dump_json(obj: dict) -> str:
    return json.dumps(obj, indent=2, cls=CustomEncoder, ensure_ascii=False)


