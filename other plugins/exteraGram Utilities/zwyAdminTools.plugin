        await RestrictUtils.handle_command(AdminCommands.UNWARN, j_params, *args, silent=silent, delete=delete)

    @dp.register_command("slowmode")
    async def slowmode(j_params, _: int, selected_time: Optional[str]) -> None:
        logger.debug("Executing slowmode command...")

        params = SendParams.from_java(j_params)
        chat_id = -params.peer
        valid_seconds = (0, 5, 10, 30, 60, 60 * 5, 60 * 15, 60 * 60)

        if not await can_use_command(chat_id, check_change_info_right=True):
            return

        seconds = CommandUtils.extract_time(wrap_argument(selected_time), clamp=False)
        nearest_valid = min(valid_seconds, key=lambda x: abs(x - seconds))

        if seconds != nearest_valid:
            seconds = nearest_valid
            bulletin.show_info(L.slowmode_time_warn)

        try:
            await Requests.change_slowmode(chat_id, seconds=seconds)
        except Exception as e:
            if "CHAT_NOT_MODIFIED" in str(e):
                pass
            else:
                show_general_error(zwylib.format_exc())

        params.text = L.slowmode_disabled if seconds == 0 else L.slowmode_success(time=TimeUtils.format_time(seconds))
        params.send()

    @dp.register_command("promote")
    async def promote(j_params, _: int, user: Optional[str], *__) -> None:
        logger.debug("Executing promote command...")

        param = SendParams.from_java(j_params)
        chat_id = -param.peer
        target = CommandUtils.extract_target(param, wrap_argument(user))
        await open_promote_activity(chat_id, target)

    @dp.register_command("demote")
    async def demote(j_params, _: int, user: Optional[str], *__) -> None:
        logger.debug("Executing demote command...")

        chat_id = -j_params.peer
        target = CommandUtils.extract_target(SendParams.from_java(j_params), wrap_argument(user))

        if target is None or not await can_use_command(chat_id, target, check_can_add_admins=True, require_target_is_admin_set_by_me=True):
            return

        if not target.user:
            bulletin.show_error(L.target_is_not_user)
            return

        def on_success():
            Requests.reload_admins(chat_id)
            bulletin.show_success(L.demote_success)

        def on_error(error: TLRPC.TL_error):
            logger.error(error.text)
            bulletin.show_error_with_copy(L.request_error, error.text)
            return False

        get_messages_controller().setUserAdminRole(
            -j_params.peer,
            target.user,
            TLRPC.TL_chatAdminRights(),
            "",
            False,
            get_last_fragment(),
            False,
            False,
            None,
            JRunnable(on_success),
            ErrorDelegate(on_error)
        )

    @dp.register_command("warns")
    async def warns(j_params, _: int, user: Optional[str]) -> None:
        logger.debug("Executing warns command...")

        param = SendParams.from_java(j_params)
        chat_id = -param.peer
        target = CommandUtils.extract_target(param, wrap_argument(user))
        max_warns_count = PrefsUtils.get_warns_until_punish()
        user_warns = warns_controller.get_user_warns(chat_id, target.id)

        if not target or not await can_use_command(chat_id, target, check_can_restrict=True):
            return

        if len(user_warns) == 0:
            message_string = L.no_warns_message(user=target.mention())
        else:
            message_string = L.warns_message(
                user=target.mention(),
                warns_count=f"{len(user_warns)}/{max_warns_count}"
            )

            for index, user_warn in enumerate(user_warns, 1):
                message_string += L.warn_info(
                    index=index,
                    max_count=max_warns_count,
                    date=TimeUtils.format_datetime(datetime.fromtimestamp(user_warn.timestamp)),
                    reason=user_warn.reason or L.no_reason_specified
                )

        param.text = message_string
        param.send()

    @dp.register_command("purge")
    async def purge(j_params, _: int, count: int) -> None:
        logger.debug("Executed purge command.")

        chat_id = -j_params.peer
        topic_id = get_last_fragment().getTopicId()

        if count < 1:
            bulletin.show_error(L.purge_chosen_too_few_msgs)
            return

        nfl_plugin = PluginUtils.get_plugin("zwyNoForwardLimit")
        if count > 100 and (not nfl_plugin or not nfl_plugin.isEnabled()):
            bulletin.show_error_with_post_redirect(
                L.purge_chosen_too_much_msgs,
                L.install_button,
                -NFL_CHANNEL_ID,
                NFL_MSG_ID
            )
            return

        try:
            logger.debug("Getting messages...")
            response = await Requests.search_messages(
                -chat_id,
                top_msg_id=topic_id,
                limit=count
            )
        except Exception as e:
            logger.error("An error occurred:", exc_info=True)
            bulletin.show_error_with_copy(L.request_error, zwylib.format_exc_from(e))
            return

        if not response:
            bulletin.show_error(L.no_messages_found)
            return

        messages = zwylib.arraylist_to_list(response.messages)
        Requests.delete_messages([message.id for message in messages], -chat_id, topic_id)
        bulletin.show_success(L.purge_success(
            count=count,
            msgs=L.plural("messages", count)
        ))

    @purge.register_error_handler
    def purge_error_handler(_, __: int, exc: Exception) -> HookResult:
        if isinstance(exc, (zwylib.CannotCastError, zwylib.WrongArgumentAmountError)):
            bulletin.show_error(L.purge_command_usage_hint(prefix=dp.prefix, count=L.prefs_count_arg))
        else:
            show_general_error(zwylib.format_exc_from(exc))
        return HookResult(strategy=HookStrategy.CANCEL)

    at = dp.register_stub_command("at")

    @at.subcommand("setrules")
    async def at_set_rules(j_params, _, *args: str) -> None:
        logger.debug("at setrules command called.")

        params = SendParams.from_java(j_params)
        chat_id = -params.peer
        reply_msg = params.reply_to

        if not await can_use_command(chat_id, None):
            return

        if reply_msg and reply_msg.messageOwner.message:
            msg_id: int = reply_msg.getId()
            chat_rules_manager.set_message(chat_id, msg_id)
            bulletin.show_success(L.rules_set_success)
            return

        if not args:
            logger.warning("No arguments were given.")
            bulletin.show_error(L.rules_set_hint)
            return

        if len(args) == 1:
            link = args[0]
            link_pattern = r"^(?:https?://)?t\.me/(?:c/(\d+)|([\w_]+))/(?:(\d+)/)?(\d+)$"
            match = re.match(link_pattern, link)

            if match:
                __chat_id, chat_username, topic_id, message_id = match.groups()
                logger.debug(
                    f"Parsed link: {link} -> "
                    f"Chat ID: {__chat_id}, "
                    f"Chat Username: {chat_username}, "
                    f"Topic ID: {topic_id}, "
                    f"Message ID: {message_id}."
                )

                chat_rules_manager.set_message(chat_id, int(message_id), int(topic_id), chat_username)
                bulletin.show_success(L.rules_set_success)
                return

            logger.debug(f"Link: {link} was not parsed.")
            bulletin.show_error(L.rules_invalid_link)
            return

        rules_text = " ".join(args)
        chat_rules_manager.set(chat_id, rules_text)
        bulletin.show_success(L.rules_set_success)

    @at.subcommand("aicheck")
    async def at_ai_check(j_params, _, *args: str) -> None:
        logger.debug("at aicheck command called.")

        parts = list(args)
        params = SendParams.from_java(j_params)
        params.topic_id = get_last_fragment().getTopicId()
        chat_id = -params.peer
        target = CommandUtils.extract_target(params, parts if len(parts) == 2 else wrap_argument(""))
        messages_count = (parts or [None])[0]

        if not target:
            logger.error("No target was specified.")
            bulletin.show_error(L.no_target_specified)
            return

        try:
            messages_count = int(messages_count)
        except TypeError:
            logger.warning("Invalid messages_count given.")
            bulletin.show_error(L.aicheck_cmd_usage)
            return

        if not chat_rules_manager.has(chat_id):
            logger.warning(f"Chat '{chat_id}' rules are not set.")
            bulletin.show_error(L.chat_rules_not_set)
            return

        if not await can_use_command(chat_id, target, check_can_restrict=True):
            return

        await ai_checker.send_ai_request(params, target, messages_count)


