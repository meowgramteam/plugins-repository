class HelpFlow:
    def __init__(self, main_text: str, cmds_text: Optional[str] = None):
        buttons = [
            UI.AlertButton(
                L.popup_commands_button,
                lambda _, __: self.cmds_popup.show(),
                type=AlertDialogBuilder.BUTTON_NEUTRAL
            )
        ] if cmds_text else []
        buttons.append(UI.AlertButton(L.popup_close_button))

        self.main_popup = UI.AlertDialog(L.usage_popup_title, main_text, buttons)

        if cmds_text:
            secondary_buttons = [UI.AlertButton(L.popup_close_button)]
            self.cmds_popup = UI.AlertDialog(L.usage_popup_title, cmds_text, secondary_buttons)

    def start(self, _view=None):
        self.main_popup.show()


def safe_get_chat_title(chat_data: Union[int, TLRPC.Chat]) -> str:
    if isinstance(chat_data, TLRPC.Chat):
        chat_id, chat = chat_data.id, chat_data
    else:
        chat_id, chat = chat_data, get_chat(chat_data)
    return getattr(chat, "title", None) or str(chat_id)


class PrefsUtils:
    @classmethod
    def execute_migrations(cls):
        logger.debug("Checking if settings need any migration...")

        try:
            # warns_punish_action migration (str -> Enum item index)
            warns_punish_action = S.warns_punish_action.get()
            action = None
            is_invalid = (
                    warns_punish_action is not None
                    and not isinstance(warns_punish_action, int)
            )
            needs_migration = (
                    is_invalid
                    and isinstance(warns_punish_action, str)
                    and (action_key := warns_punish_action.strip().upper()) in AdminCommands.__members__
                    and (action := AdminCommands[action_key]) in PUNISH_ACTIONS
            )

            if is_invalid and not needs_migration:
                logger.debug("Found invalid warns_punish_action. Removing key from config.")
                SettingsManager.remove_setting(S.warns_punish_action.key)
            elif needs_migration:
                logger.debug("Migration of warns_punish_action setting needed.")
                SettingsManager.set(S.warns_punish_action.key, PUNISH_ACTIONS.index(action))

            # max_warns_until_punish migration (str -> index)
            max_warns_until_punish: Union[str, int] = S.max_warns_until_punish.get()
            is_invalid = isinstance(max_warns_until_punish, str)
            needs_migration = (
                    is_invalid
                    and max_warns_until_punish.isdigit()
                    and max_warns_until_punish in PUNISH_COUNT_OPTIONS
            )

            if is_invalid and not needs_migration:
                logger.debug("Found invalid max_warns_until_punish. Removing key from config.")
                SettingsManager.remove_setting(S.max_warns_until_punish.key)
            elif needs_migration:
                logger.debug("Migration of max_warns_until_punish setting needed.")
                SettingsManager.set(S.max_warns_until_punish.key, PUNISH_COUNT_OPTIONS.index(max_warns_until_punish))

            # delete unnecessary keys
            logger.debug("Removing unnecessary config keys...")

            entries_to_delete = [S.gemini_api_key, S.gemini_model]
            for entry in entries_to_delete:
                if entry.get() != entry.default:
                    SettingsManager.remove_setting(entry.key)
        except Exception:
            show_general_error(exc=True)

    @classmethod
    def get_warns_until_punish(cls) -> int:
        return PUNISH_COUNT_OPTIONS[S.max_warns_until_punish.get()]

    @staticmethod
    def get_active_fed_type() -> FederationType:
        active_fed_type_index = S.active_federation_type.get()
        return FederationType.from_index(active_fed_type_index)


class PrefsGenerator:
    @classmethod
    def generate_entries(cls) -> List[Header | Input | Switch | Text | Selector | Divider | EditText | None]:
        logger.debug("Generating settings entries...")

        try:
            stuff = [
                cls._gen_help(),
                cls._gen_time_format(),
                cls._gen_warns(),
                cls._gen_independent_texts(),
                cls._gen_feds(),
                cls._gen_ai_checker(),
                cls._gen_other()
            ]

            return [item for sublist in stuff for item in sublist]
        except Exception as e:
            logger.error("An error occurred while generating settings:", exc_info=True)
            trace = zwylib.format_exc_from(e)
            return [
                Divider(
                    text="An error occurred while generating settings:\n" + zwylib.format_exc_only(e)
                ),
                Text(
                    text="Copy full traceback",
                    icon="msg_copy",
                    on_click=lambda v: copy_to_clipboard(trace)
                )
            ]

    @classmethod
    def _gen_help(cls) -> List:
        dp = zwylib.command_manager.get_dispatcher()

        fmt = {
            "required_arg": L.required_arg,
            "optional_arg": L.optional_arg,
            "user_arg": L.prefs_user_arg,
            "time_arg": L.prefs_time_arg,
            "reason_arg": L.prefs_reason_arg,
            "name_arg": L.prefs_name_arg,
            "rules_arg": L.prefs_rules_arg,
            "count_arg": L.prefs_count_arg,

            "commands_label": L.prefs_commands,
            "examples_label": L.prefs_examples,
            "prefix": dp.prefix,
            "action": L.action,

            "s_prefix_hint": L.prefs_s_prefix_hint,
            "d_prefix_hint": L.prefs_d_prefix_hint,
            "aliases_hint": L.prefs_aliases_hint,
            "available_actions": L.prefs_available_actions,

            "slowmode_hint": L.prefs_slowmode_hint,
            "promote_hint": L.prefs_promote_hint,
            "demote_hint": L.prefs_demote_hint,
            "warns_hint": L.prefs_warns_hint,
            "purge_hint": L.prefs_purge_hint,
            "fban_hint": L.prefs_fban_hint,
            "funban_hint": L.prefs_funban_hint,
            "setrules_hint": L.prefs_setrules_hint,
            "aicheck_hint": L.prefs_aicheck_hint,
        }

        topics = [
            (L.prefs_restrict_cmds_header, L.help_restrict_main, "help_restrict_cmds"),
            (L.prefs_admin_cmds_header, L.help_admin_main, "help_admin_cmds"),
            (L.prefs_feds_rose_info_header, L.help_feds_rose_main, "help_feds_cmds"),
            (L.prefs_feds_local_info_header, L.help_feds_local_main, "help_feds_cmds"),
            (L.prefs_ai_checker_info_header, L.help_ai_main, "help_ai_cmds"),
            (L.prefs_regex_info_header, L.regex_alert_warning_text, None),
        ]

        entries: List[Header | Text | Divider] = [Header(L.prefs_help)]
        for title, main_text, cmds_key in topics:
            cmds_text = format_shared(cmds_key, fmt) if cmds_key else None

            if "fed" in (cmds_key or ""):
                main_text = f"{L.help_feds_shared}\n\n" + main_text

            flow = HelpFlow(main_text, cmds_text)
            entries.append(Text(text=title, icon="msg_info", on_click=flow.start))

        entries.append(Divider())
        return entries

    @classmethod
    def _gen_time_format(cls) -> List:
        date_instead_of_time: bool = S.date_instead_of_time.get()

        settings_entries = [
            Header(L.prefs_time_formatting_header),
            S.date_instead_of_time.as_switch(
                text=L.prefs_date_instead_of_time_label,
                subtext=L.prefs_date_instead_of_time_hint(
                    date=TimeUtils.format_datetime(example_time),
                    n_days=prefs_example_days
                ),
                icon="msg_calendar2_solar" if date_instead_of_time else "msg_recent_solar",
            ),
        ]

        if not date_instead_of_time:
            return settings_entries + [Divider()]

        return settings_entries + [
            S.swap_day_and_month.as_switch(
                text=L.prefs_swap_day_and_month_label,
                subtext=L.prefs_swap_day_and_month_hint(
                    date_md=TimeUtils.format_datetime(example_time, add_time=False, swap_day_and_month=True),
                    date_dm=TimeUtils.format_datetime(example_time, add_time=False, swap_day_and_month=False),
                ),
            ),
            S.add_seconds_to_date.as_switch(
                text=L.prefs_add_seconds_to_date_label,
                subtext=L.prefs_add_seconds_to_date_hint(
                    t=TimeUtils.format_datetime(example_time, add_date=False, add_seconds=False),
                    t_seconds=TimeUtils.format_datetime(example_time, add_date=False, add_seconds=True)
                ),
            ),
            S.use_12h_time_format.as_switch(
                text=L.prefs_use_12h_time_format_label,
                subtext=L.prefs_use_12h_time_format_hint(
                    t=TimeUtils.format_datetime(example_time, add_date=False, use_12h=False),
                    t_12h=TimeUtils.format_datetime(example_time, add_date=False, use_12h=True)
                ),
            ),
            Divider()
        ]

    @classmethod
    def _gen_warns(cls) -> List:
