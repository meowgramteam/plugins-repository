def safe_set_subtext(text_item: Text, subtext: str) -> Text:
    # clients on pre 12.5.1 version have no subtext field and will
    # raise an exception if we pass subtext directly to constructor
    setattr(text_item, "subtext", subtext)
    return text_item


class OtherCommands(BaseCommands):
    REPLY = "reply"


_empty = object()


@dataclass
class TopicKey:
    chat_id: int
    topic_id: Optional[int] = None

    def to_dict(self) -> Dict:
        return {
            "chat_id": self.chat_id,
            "topic_id": self.topic_id,
        }

    @classmethod
    def from_dict(cls, data: Dict) -> "TopicKey":
        return cls(
            chat_id=data.get("chat_id", 0),
            topic_id=data.get("topic_id", None),
        )


class ActionLogManager:
    def __init__(self):
        self._storage = zwylib.JsonCacheFile("admintools__autolog_db", {})
        self._cache: Dict[int, Optional[TopicKey]] = {}

    def has(self, chat_id: int) -> bool:
        return str(chat_id) in self._storage.content

    def get_all(self) -> Dict[int, List[str]]:
        return {int(k): v for k, v in self._storage.content.items()}

    def get_for(self, chat_id: int) -> Optional[TopicKey]:
        if chat_id not in self._cache:
            if (topic_key := self._storage.content.get(str(chat_id), None)) is not None:
                topic_key = TopicKey.from_dict(topic_key)
            self._cache[chat_id] = topic_key
        return self._cache[chat_id]

    def _save(self, chat_id: int):
        topic_key = self._cache.get(chat_id, _empty)
        if topic_key == _empty:
            self._storage.content.pop(str(chat_id), None)
        else:
            self._storage.content[str(chat_id)] = topic_key.to_dict() if topic_key else None
        self._storage.write()

    def add_chat(self, chat_id: int):
        if self.has(chat_id):
            logger.warning(f"Chat '{safe_get_chat_title(chat_id)}' is already in list.")
            return
        self._cache[chat_id] = None
        self._save(chat_id)
        logger.debug(f"Added chat '{safe_get_chat_title(chat_id)}' to list.")

    def set_log_chat(self, chat_id: int, related_chat: TopicKey):
        self._cache[chat_id] = related_chat
        self._save(chat_id)
        logger.debug(f"Set log chat for '{safe_get_chat_title(chat_id)}': {related_chat}.")

    def remove(self, chat_id: int):
        self._cache.pop(chat_id, None)
        self._save(chat_id)
        logger.debug(f"Removed log chat for '{safe_get_chat_title(chat_id)}'.")

    def send_admin_action_log(self, action_info: ActionInfo, chat_id: int, warn: bool = None):
        try:
            if not (topic_key := self.get_for(chat_id)):
                return

            if not ChatObject.canWriteToChat(chat := get_chat(chat_id)):
                logger.debug(f"Cannot send messages to log chat of '{safe_get_chat_title(chat)}'.")
                bulletin.show_error(L.autolog_cant_send_msgs)
                return

            if warn is not None:
                action_text = "WARN" if warn else "UNWARN"
            else:
                action_text = action_info.action.name.upper()
            flags = f"{' (silent)' if action_info.silent else ''}{' (delete)' if action_info.delete else ''}"
            target_type = action_info.target.type.name.lower()
            text = (
                f"#{action_text}{flags}\n"
                f"In: `{escape_markdown(safe_get_chat_title(chat_id))}` (ID: `{chat_id}`)\n"
                f"Restricted {target_type}: {action_info.target.mention()} (ID: `{action_info.target.get_accurate_id()}`)"
            )

            if action_info.is_time_specified:
                if S.date_instead_of_time.get():
                    word = "Until"
                    time_text = TimeUtils.format_datetime(datetime.now() + timedelta(seconds=action_info.seconds))
                else:
                    word = "For"
                    time_text = TimeUtils.format_time(action_info.seconds)
                text += f"\n{word}: {escape_markdown(time_text)}"
            if action_info.reason:
                text += f"\nReason: {escape_markdown(action_info.reason)}"

            SendParams(-topic_key.chat_id, text, topic_id=topic_key.topic_id).send()
        except Exception:
            show_general_error(exc=True)


