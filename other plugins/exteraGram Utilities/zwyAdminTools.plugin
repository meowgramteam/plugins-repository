        self.add_hook("updateNewMessage", match_substring=True)
        self.add_hook("updateNewChannelMessage", match_substring=True)
        logger.debug("Hooked.")

        self.register_context_menu_items()

        logger.info("Loaded.")

    def on_plugin_unload(self):
        popups = [info_alert_popup, commands_alert_popup]
        for popup in popups:
            popup.dismiss()
        logger.info("Unloaded.")

    def create_settings(self):
        return PrefsGenerator.generate_entries()

    def register_context_menu_items(self):
        for menu_item_id in self.context_menu_items:
            if menu_item_id:
                self.remove_menu_item(menu_item_id)

        shared_condition = (
            "chat.admin_rights != null"
            "&& (chat.megagroup || chat.forum)"
            "&& !message.messageOwner.post"
        )
        restrict_commands_condition = shared_condition + (
            "&& message != null"
            "&& !message.isOut()"
            "&& chat.admin_rights.ban_users"
            "&& chat.admin_rights.delete_messages"
        )

        self.context_menu_items = [
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                text=__name__,
                icon="msg_settings",
                on_click=lambda _: PluginsController.openPluginSettings(__id__),
            )),
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.ban_context_menu,
                icon=S.ban_context_menu.icon,
                priority=999,
                condition=restrict_commands_condition,
                on_click=lambda ctx: run_async(RestrictUtils.handle_menu_action(
                    ctx,
                    AdminCommands.BAN,
                    AdminCommands.UNBAN,
                    check_if_in_chat=True
                ))
            )) if S.ban_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.fban_context_menu,
                icon=S.fban_context_menu.icon,
                priority=999,
                condition=restrict_commands_condition,
                on_click=lambda ctx: run_async(RestrictUtils.handle_menu_action(
                    ctx,
                    AdminCommands.FBAN,
                    AdminCommands.FUNBAN,
                    check_if_in_chat=True
                ))
            )) if S.fban_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.kick_context_menu,
                icon=S.kick_context_menu.icon,
                priority=999,
                condition=restrict_commands_condition,
                on_click=lambda ctx: run_async(RestrictUtils.handle_menu_action(ctx, AdminCommands.KICK))
            )) if S.kick_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.mute_context_menu,
                icon=S.mute_context_menu.icon,
                priority=999,
                condition=restrict_commands_condition,
                on_click=lambda ctx: run_async(RestrictUtils.handle_menu_action(
                    ctx,
                    AdminCommands.MUTE,
                    AdminCommands.UNMUTE,
                    check_if_restricted=True
                ))
            )) if S.mute_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.setrules_context_menu,
                icon=S.set_rules_context_menu.icon,
                priority=999,
                condition=shared_condition + (
                    "&& message != null"
                    "&& message.messageOwner.message != null"
                    "&& !message.messageOwner.message.isEmpty()"
                ),
                on_click=lambda ctx: run_async(set_rules_from_context_menu(ctx))
            )) if S.set_rules_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.edit_admin_rights_context_menu,
                icon=S.edit_rights_context_menu.icon,
                priority=999,
                condition=shared_condition + "&& !message.isOut()",
                on_click=lambda ctx: run_async(open_promote_activity(
                    ctx.get("chatId"), CommandUtils.extract_target(SendParams.from_ctx(ctx))
                ))
            )) if S.edit_rights_context_menu.get() else None,
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=L.delete_all_from_context_menu,
                icon=S.delete_all_from_context_menu.icon,
                priority=999,
                condition=shared_condition,
                on_click=lambda ctx: run_async(open_delete_all_from_request(ctx))
            )) if S.delete_all_from_context_menu.get() else None,
        ]

    def on_updates_hook(self, container_name: str, account: int, updates_container) -> HookResult:
        if updates := getattr(updates_container, "updates", None):
            for update in updates.toArray():
                handle_update(account, update)
        return HookResult()

    def on_update_hook(self, update_name: str, account: int, update) -> HookResult:
        handle_update(account, update)
        return HookResult()
