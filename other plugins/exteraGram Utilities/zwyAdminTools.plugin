async def open_delete_all_from_request(ctx):
    chat_id: int = ctx.get("chatId")
    target = Target.from_peer(ctx.get("message").messageOwner.from_id)

    if not target or not await can_use_command(chat_id, target, allow_self=True):
        return

    try:
        response = await Requests.search_messages(
            -chat_id,
            from_id=target.get_accurate_id(),
            limit=1,
            top_msg_id=get_last_fragment().getTopicId()
        )
    except Exception:
        show_general_error(exc=True)
        return

    def execute():
        delete_all_messages_from_target(chat_id, target)
        bulletin.show_success(LocaleController.formatPluralStringComma("MessagesDeletedHint", response.count) + "!")

    def proceed():
        if target.id == get_user_config().getClientUserId():
            run_on_ui_thread(UI.AlertDialog(
                title=LocaleController.formatPluralStringComma("DeleteOptionsTitle", response.count),
                text=L.alert_delete_all_from_self_main,
                buttons=[
                    UI.AlertButton(L.prefs_im_absolutely_sure, lambda _, __: execute(), red=True),
                    UI.AlertButton(L.popup_close_button, type=AlertDialogBuilder.BUTTON_NEGATIVE),
                ]
            ).show)
        else:
            execute()

    run_on_ui_thread(UI.AlertDialog(
        title=LocaleController.formatPluralStringComma("DeleteOptionsTitle", response.count),
        text=L.alert_delete_all_from_main(name=target.name),
        buttons=[
            UI.AlertButton(L.prefs_im_sure, lambda _, __: proceed(), red=True),
            UI.AlertButton(L.popup_close_button, type=AlertDialogBuilder.BUTTON_NEGATIVE),
        ]
    ).show)


