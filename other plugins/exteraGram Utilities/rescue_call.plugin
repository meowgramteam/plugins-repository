import time
import random
import ctypes
import base64
import os
from typing import Any

def jcolor(val: int) -> int:
    return ctypes.c_int32(val).value

def get_voice_audio_path() -> str:
    try:
        from org.telegram.messenger import ApplicationLoader
        context = ApplicationLoader.applicationContext
        cache_dir = context.getCacheDir().getAbsolutePath()
        ogg_path = os.path.join(cache_dir, "allodakuda.ogg")
        if not os.path.exists(ogg_path) or os.path.getsize(ogg_path) == 0:
            if 'VOICE_AUDIO_BASE64' in globals() and VOICE_AUDIO_BASE64:
                ogg_bytes = base64.b64decode(VOICE_AUDIO_BASE64)
                with open(ogg_path, "wb") as f:
                    f.write(ogg_bytes)
        return ogg_path
    except Exception:
        plugin_dir = os.path.dirname(os.path.abspath(__file__))
        return os.path.join(plugin_dir, "allodakuda.ogg")

from base_plugin import BasePlugin, MenuItemData, MenuItemType

from alib import (
    State, VBox, Card, Toggle, RowItem, main_thread, 
    background_thread, run_main, SimpleDB, show_bottom_sheet,
    Header, ActionRow, Selector
)

try:
    from extera_utils.classes import Base, java_subclass, joverride
    from java import jint, jboolean
except ImportError:
    class Base:
        @classmethod
        def new_java_instance(cls, *args, **kwargs):
            return cls()
        @classmethod
        def new_instance(cls, *args, **kwargs):
            return cls()
    def java_subclass(*args, **kwargs):
        return lambda cls: cls
    def joverride(*args, **kwargs):
        return lambda func: func
    def jint(val): return val
    def jboolean(val): return val

from java import dynamic_proxy
from android.app import Dialog
from android.view import Gravity, WindowManager, View
from android.widget import FrameLayout, LinearLayout, ImageView, TextView
from android.graphics import Color, Typeface
from android.graphics.drawable import GradientDrawable
from android.hardware import SensorManager, Sensor
from android.media import RingtoneManager, MediaPlayer
from android.os import Vibrator
from org.telegram.messenger import AndroidUtilities

try:
    from hook_utils import find_class, get_private_field
    from client_utils import get_last_fragment
except ImportError:
    def find_class(*args, **kwargs): return None
    def get_private_field(*args, **kwargs): return None
    def get_last_fragment(*args, **kwargs): return None

__id__ = "rescue_call"
__name__ = "RescueCall"
__description__ = "Имитация входящего вызова по таймеру или встряхиванию"
__author__ = "@mraniv & @anivdev"
__version__ = "1.0.0"
__icon__ = "ToxicDuck/33"
__min_version__ = "12.5.1"
__settings__ = False
__requirements__ = ["exteragram-alib"]

class RescueCallPlugin(BasePlugin):

    def on_plugin_load(self) -> None:
        self.log("RescueCall загружен")
        self.db = SimpleDB("rescue_call_settings")

        self.caller_name = State(self.db.get("caller_name", "Важный звонок"))
        self.call_type = State(self.db.get("call_type", 0))
        self.delay_seconds = State(self.db.get("delay_seconds", 10))
        self.enable_shake = State(self.db.get("enable_shake", False))

        self.sensor_manager = None
        self.shake_listener = None
        self.timer_active = State(False)
        self.timer_status = State("Запланировать")
        self.active_sheet = None
        self.context_peer = None
        self.context_caller_name = None
        self.sheet_selector_state = State(2)

        self.caller_name.add_listener(lambda v: self.db.set("caller_name", v))
        self.call_type.add_listener(lambda v: self.db.set("call_type", v))
        self.delay_seconds.add_listener(lambda v: self.db.set("delay_seconds", v))
        self.enable_shake.add_listener(self._on_shake_toggle_changed)

        if self.enable_shake.get():
            self._register_shake_listener()

        try:
            self.menu_id = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Ложный вызов",
                    on_click=self._on_menu_click,
                    icon="msg_call",
                    priority=50,
                )
            )
            self.log("RescueCall кнопка быстрого запуска добавлена в меню чата")
        except Exception as e:
            self.log(f"Ошибка регистрации пункта меню: {e}")

    def on_plugin_unload(self) -> None:
        self._unregister_shake_listener()
        active_dlg = getattr(self, "active_dialog", None)
        if active_dlg:
            try:
                active_dlg.dismiss()
            except Exception: pass
            self.active_dialog = None
        if hasattr(self, "menu_id") and self.menu_id:
            try:
                self.remove_menu_item(self.menu_id)
                self.log("RescueCall кнопка меню удалена")
            except Exception as e:
                self.log(f"Ошибка удаления пункта меню: {e}")
        self.log("RescueCall выгружен")

    def _on_shake_toggle_changed(self, enabled: bool) -> None:
        self.db.set("enable_shake", enabled)
        if enabled:
            self._register_shake_listener()
        else:
            self._unregister_shake_listener()

    def _register_shake_listener(self) -> None:
        try:
            from org.telegram.messenger import ApplicationLoader
            context = ApplicationLoader.applicationContext
            if not context:
                return

            self.sensor_manager = context.getSystemService(context.SENSOR_SERVICE)
            accelerometer = self.sensor_manager.getDefaultSensor(Sensor.TYPE_ACCELEROMETER)

            SensorEventListenerClass = find_class("android.hardware.SensorEventListener")

            class ShakeListener(dynamic_proxy(SensorEventListenerClass)):
                def __init__(self, plugin):
                    super().__init__()
                    self.plugin = plugin
                    self.last_update = 0

                def onSensorChanged(self, event):
                    if getattr(self.plugin, "active_dialog", None) is not None:
                        return
                    now = time.time()
                    if (now - self.last_update) > 0.1:
                        self.last_update = now
                        x = event.values[0]
                        y = event.values[1]
                        z = event.values[2]

                        sum_sq = x*x + y*y + z*z
                        if sum_sq > 475.68:
                            self.plugin.log("Детекция встряхивания (Shake detected)!")
                            self.plugin.trigger_call_now()

                def onAccuracyChanged(self, sensor, accuracy):
                    pass

            self.shake_listener = ShakeListener(self)
            self.sensor_manager.registerListener(
                self.shake_listener, 
                accelerometer, 
                SensorManager.SENSOR_DELAY_NORMAL
            )
            self.log("Слушатель акселерометра успешно зарегистрирован")
        except Exception as e:
            self.log(f"Ошибка регистрации акселерометра: {e}")

    def _unregister_shake_listener(self) -> None:
        if self.sensor_manager and self.shake_listener:
            try:
                self.sensor_manager.unregisterListener(self.shake_listener)
                self.log("Слушатель акселерометра выгружен")
            except Exception as e:
                self.log(f"Ошибка выгрузки акселерометра: {e}")
            self.shake_listener = None
            self.sensor_manager = None

    def _on_menu_click(self, ctx: Any) -> None:
        fragment = ctx.get("fragment")
        if not fragment:
            return

        dialog_id = self._get_dialog_id_from_context(ctx)
        self.context_peer = None
        self.context_caller_name = None

        if dialog_id != 0:
            try:
                from org.telegram.messenger import MessagesController, UserConfig, UserObject
                current_account = UserConfig.selectedAccount
                controller = MessagesController.getInstance(current_account)

                if dialog_id > 0:
                    user = controller.getUser(dialog_id)
                    if user:
                        self.context_peer = user
                        self.context_caller_name = UserObject.getUserName(user)
                else:
                    chat = controller.getChat(-dialog_id)
                    if chat:
                        self.context_peer = chat
                        self.context_caller_name = chat.title
            except Exception as e:
                self.log(f"Ошибка получения инфо из чата: {e}")

        sheet_layout = VBox(
            padding=[0, 0, 0, 16],
            children=[
                Header(text="Быстрый ложный вызов"),
                Card(
                    children=[
                        ActionRow(
                            title="Позвонить",
                            subtext="Запустить отложенный звонок",
                            button_text="Старт",
                            icon="chat_calls_voice",
                            on_button_click=lambda _: self._quick_trigger_selected()
                        ),
                        Selector(
                            text="Задержка вызова",
                            items=["5 секунд", "10 секунд", "30 секунд", "1 минута", "2 минуты", "5 минут"],
                            value=self.sheet_selector_state,
                            icon="msg_stories_timer",
                            on_change=lambda idx: self.sheet_selector_state.set(idx)
                        ),
                        Selector(
                            text="Тип вызова",
                            items=["Аудиозвонок", "Видеозвонок"],
                            value=self.call_type,
                            icon="msg_settings",
                            on_change=lambda idx: self.call_type.set(idx)
                        ),
                        RowItem(
                            title="Запуск при встряхивании",
                            subtext="Активация акселерометра",
                            icon="msg_retry",
                            right_widget=Toggle(value=self.enable_shake)
                        )
                    ]
                )
            ]
        )

        def show():
            self.active_sheet = show_bottom_sheet(fragment, "RescueCall Control", sheet_layout, center_header=True, height_pct=0.54)

        run_main(show)

    def _quick_trigger_selected(self) -> None:
        idx = self.sheet_selector_state.get()
        delays = [5, 10, 30, 60, 120, 300]
        delay_sec = delays[idx] if idx < len(delays) else 30
        self._quick_trigger(delay_sec)

    def _get_dialog_id_from_context(self, context: Any) -> int:
        if isinstance(context, dict):

            val = context.get("dialog_id")
            if val:
                try:
                    return int(val)
                except Exception: pass

            fragment = context.get("fragment")
            if fragment:
                try:
                    val = get_private_field(fragment, "dialog_id")
                    if val:
                        return int(val)
                except Exception: pass

        try:
            fragment = get_last_fragment()
            if fragment and str(fragment.getClass().getName()) == "org.telegram.ui.ChatActivity":
                val = get_private_field(fragment, "dialog_id")
                if val:
                    return int(val)
        except Exception:
            pass

        return 0

    def _quick_trigger(self, delay_sec: int) -> None:

        if self.active_sheet:
            try:
                self.active_sheet.dismiss()
            except Exception: pass
            self.active_sheet = None

        self.timer_active.set(True)
        self.timer_status.set(f"Звонок через {delay_sec} сек...")
        self._deferred_trigger(delay_sec * 1000)

    def start_timer_trigger(self) -> None:
        if self.timer_active.get():
            return

        self.timer_active.set(True)
        delay_sec = int(self.delay_seconds.get())
        self.timer_status.set(f"Звонок через {delay_sec} сек...")
        self._deferred_trigger(delay_sec * 1000)

    @background_thread
    def _deferred_trigger(self, delay_ms: int) -> None:
        time.sleep(delay_ms / 1000.0)
        self.trigger_call_now()

    @main_thread
    def trigger_call_now(self) -> None:
        self.timer_active.set(False)
        self.timer_status.set("Запланировать")

        if getattr(self, "active_dialog", None) is not None:
            self.log("Симуляция вызова уже запущена или активна")
            return

        try:
            from org.telegram.ui import LaunchActivity
            context = LaunchActivity.instance
            if not context:
                self.log("Ошибка: LaunchActivity.instance равен None. Не удалось запустить симуляцию вызова (требуется активная Activity).")
                return

            if not getattr(self, "context_peer", None):
                dialog_id = self._get_dialog_id_from_context(None)
                if dialog_id != 0:
                    try:
                        from org.telegram.messenger import MessagesController, UserConfig, UserObject
                        current_account = UserConfig.selectedAccount
                        controller = MessagesController.getInstance(current_account)

                        if dialog_id > 0:
                            user = controller.getUser(dialog_id)
                            if user:
                                self.context_peer = user
                                self.context_caller_name = UserObject.getUserName(user)
                        else:
                            chat = controller.getChat(-dialog_id)
                            if chat:
                                self.context_peer = chat
                                self.context_caller_name = chat.title
                    except Exception as ce:
                        self.log(f"Ошибка автоопределения чата при запуске вызова: {ce}")

            FakeCallDialog.caller_name_param = getattr(self, "context_caller_name", None) or self.caller_name.get()
            FakeCallDialog.call_type_param = self.call_type.get()
            FakeCallDialog.plugin_param = self
            FakeCallDialog.peer_param = getattr(self, "context_peer", None)

            dialog = FakeCallDialog.new_java_instance(context, jint(16973840))
            self.active_dialog = dialog
            dialog.show()

            self.context_caller_name = None
            self.context_peer = None
        except Exception as e:
            self.log(f"Не удалось запустить симуляцию вызова: {e}")

@java_subclass(Dialog)
class FakeCallDialog(Base):
    caller_name_param = ""
    call_type_param = 0
    plugin_param = None
    peer_param = None

    @joverride()
    def onStart(self) -> None:
        super().onStart()
        self.caller_name = FakeCallDialog.caller_name_param
        self.call_type = FakeCallDialog.call_type_param
        self.plugin = FakeCallDialog.plugin_param
        self.peer = FakeCallDialog.peer_param

        self.ringtone = None
        self.vibrator = None
        self.voice_player = None
        self.call_active = False
        self.ringing = True

        self.calling_photo_view = None
        self.bg_provider = None
        self.gradient_layout = None

        context = self.getContext()
        self.setup_window()
        self.setup_ui(context)
        self.start_haptics(context)
        self._run_ringing_waves()

    @joverride()
    def onStop(self) -> None:
        self.ringing = False
        self.call_active = False
        self.stop_haptics()
        if self.plugin:
            self.plugin.active_dialog = None
        super().onStop()

    def setup_window(self) -> None:
        window = self.getWindow()
        window.addFlags(
            WindowManager.LayoutParams.FLAG_LAYOUT_IN_SCREEN | 
            WindowManager.LayoutParams.FLAG_SHOW_WHEN_LOCKED |
            WindowManager.LayoutParams.FLAG_DISMISS_KEYGUARD |
            WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON |
            WindowManager.LayoutParams.FLAG_TURN_SCREEN_ON
        )
        from android.os import Build
        if Build.VERSION.SDK_INT >= 28:
            lp = window.getAttributes()
            lp.layoutInDisplayCutoutMode = WindowManager.LayoutParams.LAYOUT_IN_DISPLAY_CUTOUT_MODE_SHORT_EDGES
            window.setAttributes(lp)

        if Build.VERSION.SDK_INT >= 21:
            window.addFlags(WindowManager.LayoutParams.FLAG_DRAWS_SYSTEM_BAR_BACKGROUNDS)
            window.setStatusBarColor(0)
            window.setNavigationBarColor(0)

    def setup_ui(self, context: Any) -> None:

        self.root_layout = FrameLayout(context)

        try:
            from org.telegram.ui.Components.voip import VoIPBackgroundProvider, VoIpGradientLayout
            self.bg_provider = VoIPBackgroundProvider()
            self.gradient_layout = VoIpGradientLayout(context, False, self.bg_provider)
            self.root_layout.addView(self.gradient_layout, FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT
            ))
        except Exception as e:
            self.plugin.log(f"Не удалось инициализировать VoIpGradientLayout: {e}")

            bg_drawable = GradientDrawable(
                GradientDrawable.Orientation.TOP_BOTTOM,
                [Color.parseColor("#0F172A"), Color.parseColor("#090D16")]
            )
            self.root_layout.setBackground(bg_drawable)

        self.incoming_view = FrameLayout(context)
        self.incoming_view.setLayoutParams(FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT
        ))

        self.avatar_container = FrameLayout(context)
        avatar_container_params = FrameLayout.LayoutParams(
            AndroidUtilities.dp(204), AndroidUtilities.dp(204)
        )
        avatar_container_params.gravity = Gravity.TOP | Gravity.CENTER_HORIZONTAL
        avatar_container_params.topMargin = AndroidUtilities.dp(93)
        self.avatar_container.setLayoutParams(avatar_container_params)

        self.avatar_drawable = None
        try:
            from org.telegram.ui.Components import AvatarDrawable
            self.avatar_drawable = AvatarDrawable()
            if self.peer:
                self.avatar_drawable.setInfo(self.peer)
            else:
                self.avatar_drawable.setInfo(jint(1), self.caller_name, "")
        except Exception as ae:
            self.plugin.log(f"Не удалось инициализировать AvatarDrawable: {ae}")

        try:
            from org.telegram.ui.Components.voip import ImageWithWavesView
            from org.telegram.messenger import ImageLocation, UserConfig

            self.calling_photo_view = ImageWithWavesView(context)

            image_location = None
            if self.peer:
                current_account = UserConfig.selectedAccount
                image_location = ImageLocation.getForUserOrChat(current_account, self.peer, 0)

            self.calling_photo_view.setImage(image_location, None, self.avatar_drawable, self.peer)
            self.calling_photo_view.setRoundRadius(AndroidUtilities.dp(135) // 2)

            self.avatar_container.addView(self.calling_photo_view, FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT
            ))
        except Exception as iwe:
            self.plugin.log(f"Не удалось инициализировать ImageWithWavesView: {iwe}")

            fallback_avatar = ImageView(context)
            if self.avatar_drawable:
                fallback_avatar.setImageDrawable(self.avatar_drawable)
            else:
                drawable = GradientDrawable()
                drawable.setShape(GradientDrawable.OVAL)
                drawable.setColor(Color.parseColor("#334155"))
                fallback_avatar.setBackground(drawable)

            fallback_size = AndroidUtilities.dp(135)
            fallback_params = FrameLayout.LayoutParams(fallback_size, fallback_size)
            fallback_params.gravity = Gravity.CENTER
            fallback_avatar.setLayoutParams(fallback_params)
            self.avatar_container.addView(fallback_avatar)

        self.status_layout = LinearLayout(context)
        self.status_layout.setOrientation(LinearLayout.VERTICAL)
        self.status_layout.setGravity(Gravity.CENTER_HORIZONTAL)

        status_layout_params = FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT
        )
        status_layout_params.gravity = Gravity.TOP | Gravity.CENTER_HORIZONTAL
        status_layout_params.topMargin = AndroidUtilities.dp(321)
        self.status_layout.setLayoutParams(status_layout_params)

        self.name_txt = TextView(context)
        self.name_txt.setText(self.caller_name)
        self.name_txt.setTextSize(30)
        self.name_txt.setTextColor(Color.WHITE)
        self.name_txt.setTypeface(Typeface.DEFAULT_BOLD)
        self.name_txt.setGravity(Gravity.CENTER_HORIZONTAL)
        self.status_layout.addView(self.name_txt)

        self.status_txt = TextView(context)
        self.status_txt.setText("Видеовызов Telegram..." if self.call_type == 1 else "Аудиовызов Telegram...")
        self.status_txt.setTextSize(16)
        self.status_txt.setTextColor(Color.parseColor("#94A3B8"))
        self.status_txt.setGravity(Gravity.CENTER_HORIZONTAL)

        status_txt_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT
        )
        status_txt_params.topMargin = AndroidUtilities.dp(8)
        self.status_txt.setLayoutParams(status_txt_params)
        self.status_layout.addView(self.status_txt)

        has_adv = False
        try:
            from org.telegram.ui.Components.voip import AcceptDeclineView
            from hook_utils import find_class

            self.accept_decline_view = AcceptDeclineView(context)

            class AcceptDeclineListener(dynamic_proxy(find_class("org.telegram.ui.Components.voip.AcceptDeclineView$Listener"))):
                def __init__(self, dialog_py, ctx):
                    super().__init__()
                    self.dialog_py = dialog_py
                    self.ctx = ctx
                def onAccept(self):
                    self.dialog_py.accept_call(self.ctx)
                def onDecline(self):
                    self.dialog_py.dismiss_call()

            self.accept_decline_view.setListener(AcceptDeclineListener(self, context))
            self.accept_decline_view.setRetryMod(False)

            ad_params = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(180))
            ad_params.gravity = Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL
            ad_params.bottomMargin = AndroidUtilities.dp(40)
            self.accept_decline_view.setLayoutParams(ad_params)
            has_adv = True
        except Exception as adve:
            self.plugin.log(f"Не удалось инициализировать AcceptDeclineView: {adve}")

        self.incoming_view.addView(self.avatar_container)
        self.incoming_view.addView(self.status_layout)

        if has_adv:
            self.incoming_view.addView(self.accept_decline_view)
        else:

            btn_layout = LinearLayout(context)
            btn_layout.setOrientation(LinearLayout.HORIZONTAL)
            btn_layout.setGravity(Gravity.CENTER)

            btn_params = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(60))
            btn_params.gravity = Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL
            btn_params.bottomMargin = AndroidUtilities.dp(60)
            btn_layout.setLayoutParams(btn_params)

            decline = TextView(context)
            decline.setText("Сбросить")
            decline.setTextColor(Color.WHITE)
            decline.setTextSize(18)
            decline.setGravity(Gravity.CENTER)
            decline.setPadding(AndroidUtilities.dp(30), AndroidUtilities.dp(15), AndroidUtilities.dp(30), AndroidUtilities.dp(15))

            dec_bg = GradientDrawable()
            dec_bg.setShape(GradientDrawable.RECTANGLE)
            dec_bg.setCornerRadius(float(AndroidUtilities.dp(30)))
            dec_bg.setColor(Color.parseColor("#EF4444"))
            decline.setBackground(dec_bg)

            dec_params = LinearLayout.LayoutParams(AndroidUtilities.dp(140), AndroidUtilities.dp(60))
            dec_params.rightMargin = AndroidUtilities.dp(20)
            decline.setLayoutParams(dec_params)

            from hook_utils import find_class
            class DeclineClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                def __init__(self, dialog_py):
                    super().__init__()
                    self.dialog_py = dialog_py
                def onClick(self, view):
                    self.dialog_py.dismiss_call()
            decline.setOnClickListener(DeclineClickListener(self))

            accept = TextView(context)
            accept.setText("Принять")
            accept.setTextColor(Color.WHITE)
            accept.setTextSize(18)
            accept.setGravity(Gravity.CENTER)
            accept.setPadding(AndroidUtilities.dp(30), AndroidUtilities.dp(15), AndroidUtilities.dp(30), AndroidUtilities.dp(15))

            acc_bg = GradientDrawable()
            acc_bg.setShape(GradientDrawable.RECTANGLE)
            acc_bg.setCornerRadius(float(AndroidUtilities.dp(30)))
            acc_bg.setColor(Color.parseColor("#10B981"))
            accept.setBackground(acc_bg)

            acc_params = LinearLayout.LayoutParams(AndroidUtilities.dp(140), AndroidUtilities.dp(60))
            acc_params.leftMargin = AndroidUtilities.dp(20)
            accept.setLayoutParams(acc_params)

            class AcceptClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                def __init__(self, dialog_py):
                    super().__init__()
                    self.dialog_py = dialog_py
                def onClick(self, view):
                    self.dialog_py.accept_call(context)
            accept.setOnClickListener(AcceptClickListener(self))

            btn_layout.addView(decline)
            btn_layout.addView(accept)
            self.incoming_view.addView(btn_layout)

        self.root_layout.addView(self.incoming_view)
        self.setContentView(self.root_layout)

        window = self.getWindow()
        window.setLayout(WindowManager.LayoutParams.MATCH_PARENT, WindowManager.LayoutParams.MATCH_PARENT)

    def start_haptics(self, context: Any) -> None:
        try:

            ring_uri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_RINGTONE)
            self.ringtone = RingtoneManager.getRingtone(context, ring_uri)
            if self.ringtone:
                self.ringtone.play()
        except Exception as e:
            self.plugin.log(f"Ошибка рингтона: {e}")

        try:

            self.vibrator = context.getSystemService(context.VIBRATOR_SERVICE)
            if self.vibrator:
                pattern = [0, 1000, 1000]
                from android.os import Build
                if Build.VERSION.SDK_INT >= 26:
                    from android.os import VibrationEffect
                    try:
                        effect = VibrationEffect.createWaveform(pattern, 0)
                        self.vibrator.vibrate(effect)
                    except Exception:
                        self.vibrator.vibrate(pattern, 0)
                else:
                    self.vibrator.vibrate(pattern, 0)
        except Exception as e:
            self.plugin.log(f"Ошибка вибратора: {e}")

    def stop_haptics(self) -> None:
        if self.ringtone:
            try:
                self.ringtone.stop()
            except Exception: pass
        if self.vibrator:
            try:
                self.vibrator.cancel()
            except Exception: pass
        if getattr(self, "voice_player", None) is not None:
            try:
                self.voice_player.stop()
                self.voice_player.release()
            except Exception: pass
            self.voice_player = None

    @background_thread
    def _run_ringing_waves(self) -> None:
        if not self.calling_photo_view:
            return
        import random
        while self.ringing:
            time.sleep(0.15)
            amp = random.uniform(5.0, 15.0)
            self._update_waves_amplitude(amp)

    @main_thread
    def _update_waves_amplitude(self, amp: float) -> None:
        if self.ringing and self.calling_photo_view:
            try:
                self.calling_photo_view.setAmplitude(amp)
            except Exception: pass

    def accept_call(self, context: Any) -> None:
        self.ringing = False
        self.stop_haptics()
        self.call_active = True

        try:
            ogg_path = get_voice_audio_path()
            if os.path.exists(ogg_path) and os.path.getsize(ogg_path) > 0:
                self.voice_player = MediaPlayer()
                self.voice_player.setDataSource(ogg_path)
                self.voice_player.prepare()
                self.voice_player.start()
            else:
                self.plugin.log(f"Файл {ogg_path} не найден или пуст!")
        except Exception as pe:
            self.plugin.log(f"Ошибка воспроизведения голосового: {pe}")

        self.incoming_view.setVisibility(View.GONE)

        self.active_view = FrameLayout(context)
        self.active_view.setLayoutParams(FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT
        ))

        self.incoming_view.removeView(self.avatar_container)
        self.incoming_view.removeView(self.status_layout)

        if self.calling_photo_view:
            try:
                self.calling_photo_view.setMute(True, False)
            except Exception: pass

        self.status_txt.setText("00:00")
        self.status_txt.setTextColor(Color.WHITE)
        self.timer_view = self.status_txt

        from org.telegram.messenger import R
        from org.telegram.ui.Components.voip import VoIPToggleButton
        from hook_utils import find_class

        bottom_layout = LinearLayout(context)
        bottom_layout.setOrientation(LinearLayout.VERTICAL)
        bottom_layout.setGravity(Gravity.CENTER_HORIZONTAL)

        bot_params = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT)
        bot_params.gravity = Gravity.BOTTOM
        bot_params.bottomMargin = AndroidUtilities.dp(60)
        bottom_layout.setLayoutParams(bot_params)

        actions_row = LinearLayout(context)
        actions_row.setOrientation(LinearLayout.HORIZONTAL)
        actions_row.setGravity(Gravity.CENTER)

        row_params = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        row_params.bottomMargin = AndroidUtilities.dp(40)
        actions_row.setLayoutParams(row_params)

        w_params = LinearLayout.LayoutParams(0, AndroidUtilities.dp(100), 1.0)

        mute_btn = VoIPToggleButton(context, 52.0)
        mute_btn.setData(R.drawable.calls_unmute, -1, jcolor(0x20FFFFFF), "Звук", False, False)

        class MuteClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
            def __init__(self, btn):
                super().__init__()
                self.btn = btn
                self.muted = False
            def onClick(self, view):
                self.muted = not self.muted
                self.btn.setChecked(self.muted, True)
                self.btn.setData(R.drawable.calls_unmute, jcolor(0xFF000000) if self.muted else -1, jcolor(0xFFFFFFFF) if self.muted else jcolor(0x20FFFFFF), "Звук", self.muted, True)

        mute_btn.setOnClickListener(MuteClickListener(mute_btn))

        video_btn = VoIPToggleButton(context, 52.0)
        video_btn.setData(R.drawable.calls_video, -1, jcolor(0x20FFFFFF), "Камера", False, False)

        class VideoClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
            def __init__(self, btn):
                super().__init__()
                self.btn = btn
                self.video_active = False
            def onClick(self, view):
                self.video_active = not self.video_active
                self.btn.setChecked(self.video_active, True)
                self.btn.setData(R.drawable.calls_video, jcolor(0xFF000000) if self.video_active else -1, jcolor(0xFFFFFFFF) if self.video_active else jcolor(0x20FFFFFF), "Камера", self.video_active, True)

        video_btn.setOnClickListener(VideoClickListener(video_btn))

        speaker_btn = VoIPToggleButton(context, 52.0)
        speaker_btn.setData(R.drawable.calls_speaker, -1, jcolor(0x20FFFFFF), "Динамик", False, False)

        class SpeakerClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
            def __init__(self, btn):
                super().__init__()
                self.btn = btn
                self.speaker_active = False
            def onClick(self, view):
                self.speaker_active = not self.speaker_active
                self.btn.setChecked(self.speaker_active, True)
                self.btn.setData(R.drawable.calls_speaker, jcolor(0xFF000000) if self.speaker_active else -1, jcolor(0xFFFFFFFF) if self.speaker_active else jcolor(0x20FFFFFF), "Динамик", self.speaker_active, True)

        speaker_btn.setOnClickListener(SpeakerClickListener(speaker_btn))

        actions_row.addView(mute_btn, w_params)
        actions_row.addView(video_btn, w_params)
        actions_row.addView(speaker_btn, w_params)

        end_call_btn = VoIPToggleButton(context, 64.0)
        end_call_btn.setData(R.drawable.calls_decline, -1, jcolor(0xFFF01D2C), "Сбросить", False, False)

        class HangupClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
            def __init__(self, dialog_py):
                super().__init__()
                self.dialog_py = dialog_py
            def onClick(self, view):
                self.dialog_py.dismiss_call()

        end_call_btn.setOnClickListener(HangupClickListener(self))

        end_call_params = LinearLayout.LayoutParams(AndroidUtilities.dp(100), AndroidUtilities.dp(120))
        end_call_params.gravity = Gravity.CENTER_HORIZONTAL
        end_call_btn.setLayoutParams(end_call_params)

        bottom_layout.addView(actions_row)
        bottom_layout.addView(end_call_btn)

        self.active_view.addView(self.avatar_container)
        self.active_view.addView(self.status_layout)
        self.active_view.addView(bottom_layout)

        self.root_layout.addView(self.active_view)

        self._run_call_timer()

    @background_thread
    def _run_call_timer(self) -> None:
        start_time = time.time()
        while self.call_active:
            time.sleep(1.0)
            elapsed = int(time.time() - start_time)
            mins = elapsed // 60
            secs = elapsed % 60
            time_str = f"{mins:02d}:{secs:02d}"

            self._update_timer_ui(time_str)

    @main_thread
    def _update_timer_ui(self, time_str: str) -> None:
        if self.call_active and hasattr(self, 'timer_view'):
            self.timer_view.setText(time_str)

    def dismiss_call(self) -> None:
        self.ringing = False
        self.call_active = False
        self.stop_haptics()
        self.dismiss()
        self.plugin.log("Ложный вызов сброшен")

VOICE_AUDIO_BASE64 = ""
