KEY_UP = 1
KEY_DOWN = 2
KEY_LEFT = 3
KEY_RIGHT = 4
KEY_STRAFE_L = 5
KEY_STRAFE_R = 6
KEY_FIRE = 7
KEY_USE = 8
KEY_ESCAPE = 9
KEY_ENTER = 10
KEY_TAB = 11
KEY_RUN = 12
KEY_ALT = 13
DOOM_WAD_PICKER_REQ = 6407


def signed_color(value):
    return value if value < 0x80000000 else value - 0x100000000


class ClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
    def __init__(self, fn):
        super().__init__()
        self.fn = fn

    def onClick(self, view):
        self.fn()


class TouchListener(dynamic_proxy(find_class("android.view.View$OnTouchListener"))):
    def __init__(self, fn):
        super().__init__()
        self.fn = fn

    def onTouch(self, view, event):
        return self.fn(view, event)


class NativeLinker:
    def __init__(self):
        self.open_ext = None
        self.Info = None
        try:
            self.libc = ctypes.CDLL("libc.so", mode=2 | 0x100)
        except Exception:
            self.libc = None
        try:
            self.libdl = ctypes.CDLL("libdl.so")
            self.open_ext = self.libdl.android_dlopen_ext

            class Info(ctypes.Structure):
                _fields_ = [
                    ("flags", ctypes.c_uint64),
                    ("reserved_addr", ctypes.c_void_p),
                    ("reserved_size", ctypes.c_size_t),
                    ("relro_fd", ctypes.c_int),
                    ("library_fd", ctypes.c_int),
                    ("library_fd_offset", ctypes.c_uint64),
                    ("library_namespace", ctypes.c_void_p),
                ]

            self.Info = Info
            self.open_ext.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.POINTER(self.Info)]
            self.open_ext.restype = ctypes.c_void_p
        except Exception:
            self.open_ext = None
            self.Info = None

    def load(self, path):
        if not path or not os.path.exists(path) or os.path.getsize(path) < 1024:
            return None
        try:
            Build = find_class("android.os.Build")
            if int(Build.VERSION.SDK_INT) >= 29 and self.open_ext and self.Info:
                fd = os.open(path, os.O_RDONLY)
                try:
                    info = self.Info(flags=0x10, library_fd=fd)
                    handle = self.open_ext(path.encode("utf-8"), 2 | 0x100, ctypes.byref(info))
                    if handle:
                        return ctypes.CDLL(path, handle=handle)
                finally:
                    try:
                        os.close(fd)
                    except Exception:
                        pass
        except Exception as exc:
            log("exteraDoom android_dlopen_ext failed: %s" % exc)
        try:
            return ctypes.CDLL(path, mode=2 | 0x100)
        except Exception as exc:
            log("exteraDoom ctypes load failed: %s" % exc)
            return None


class ExteraDoomPlugin(BasePlugin):
    STRINGS = {
        "ru": {
            "pick_wad": "Выбрать WAD",
            "saved_wads": "Сохраненные WAD",
            "clear_list": "Очистить список",
            "run": "Запустить",
            "delete": "Удалить из списка",
        },
        "en": {
            "pick_wad": "Choose WAD",
            "saved_wads": "Saved WADs",
            "clear_list": "Clear list",
            "run": "Launch",
            "delete": "Remove from list",
        },
    }

    def __init__(self):
        super().__init__()
        self.dialog = None
        self.activity = None
        self.orig_orient = None
        self.orig_vol_stream = None
        self.running = False
        self.loop_thread = None
        self.lib = None
        self.native_started = False
        self.wad_path = None
        self.pwad_path = None
        self.bitmap = None
        self.image = None
        self.c_pixels = None
        self.java_pixels = None
        self.width = 320
        self.height = 200
        self.total_pixels = 320 * 200
        self.back_ts = 0
        self._activity_result_hooked = False
        self._activity_result_hook_ref = None
        self._pending_file_pick = False
        self._session_lib_path = None
        self._telegram_picker_ref = None
        self._frame_bytes = None
        self._frame_buffer = None
        self._byte_buffer_cls = None
        self._native_lock = threading.RLock()
        self._ui_refs = []

    def _lang_key(self):
        try:
            lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
        except Exception:
            try:
                lang = LocaleController.getInstance().getCurrentLocaleInfo().shortName
            except Exception:
                lang = "en"
        return "ru" if str(lang).lower().startswith("ru") else "en"

    def _s(self, key):
        return self.STRINGS.get(self._lang_key(), self.STRINGS["en"]).get(key, key)

    def create_settings(self):
        items = [
            Text(text=self._s("pick_wad"), icon="msg_media_doc2", accent=True, on_click=lambda _: self.launch_game()),
        ]
        saved = self._saved_wads()
        if saved:
            items.append(Divider())
            items.append(Header(text=self._s("saved_wads")))
            for entry in saved:
                name = entry.get("name") or os.path.basename(entry.get("path") or "") or "WAD"
                path = entry.get("path") or ""
                items.append(Text(
                    text=name,
                    icon="filter_game",
                    create_sub_fragment=lambda p=path, n=name: self._create_wad_entry_settings(p, n)
                ))
            items.append(Divider())
            items.append(Text(text=self._s("clear_list"), icon="msg_delete", red=True, on_click=lambda _: self._clear_saved_wads()))
        return items

    def _create_wad_entry_settings(self, path, name):
        return [
            Text(text=self._s("run"), icon="filter_game", accent=True, on_click=lambda _: self.launch_saved_wad(path)),
            Text(text=self._s("delete"), icon="msg_delete", red=True, on_click=lambda _: self._remove_saved_wad(path)),
        ]

    def on_plugin_load(self):
        self._install_activity_result_hook()

    def on_plugin_unload(self):
        self._pending_file_pick = False
        try:
            if self._activity_result_hook_ref:
                self.unhook_method(self._activity_result_hook_ref)
        except Exception:
            pass
        self._activity_result_hook_ref = None
        self._activity_result_hooked = False
        self.stop_game()

    def launch_game(self):
        run_on_ui_thread(self._launch_game_ui)

    def launch_saved_wad(self, path):
        run_on_ui_thread(lambda p=path: self._start_game_with_wad(p))

    def _saved_wads(self):
        try:
            data = json.loads(self.get_setting("saved_wads", "[]") or "[]")
            if isinstance(data, list):
                result = []
                seen = set()
                for entry in data:
                    if not isinstance(entry, dict):
                        continue
                    path = str(entry.get("path") or "")
                    if not path or path in seen:
                        continue
                    seen.add(path)
                    result.append({
                        "name": str(entry.get("name") or os.path.basename(path) or "WAD"),
                        "path": path,
                        "size": int(entry.get("size") or 0),
                        "kind": str(entry.get("kind") or self._wad_kind(path)),
                    })
                return result[:12]
        except Exception as exc:
            log("exteraDoom saved WAD list read failed: %s" % exc)
        return []

    def _save_wads(self, entries):
        try:
            self.set_setting("saved_wads", json.dumps(entries[:12], ensure_ascii=False), reload_settings=True)
            try:
                self.notify_settings_changed()
            except Exception:
                pass
        except Exception as exc:
            log("exteraDoom saved WAD list write failed: %s" % exc)

    def _remember_wad(self, path):
        try:
            if not path:
                return
            name = os.path.basename(path) or "WAD"
            size = os.path.getsize(path) if os.path.exists(path) else 0
            kind = self._wad_kind(path)
            saved = [x for x in self._saved_wads() if x.get("path") != path]
            saved.insert(0, {"name": name, "path": path, "size": size, "kind": kind})
            self._save_wads(saved)
        except Exception as exc:
            log("exteraDoom remember WAD failed: %s" % exc)

    def _remove_saved_wad(self, path):
        saved = [x for x in self._saved_wads() if x.get("path") != path]
        self._save_wads(saved)

    def _clear_saved_wads(self):
        self._save_wads([])

    def _launch_game_ui(self):
        try:
            fragment = get_last_fragment()
            activity = fragment and fragment.getParentActivity()
            if not activity:
                return
            self._ensure_payloads()
            self._install_activity_result_hook()
            self._open_wad_picker(activity)
        except Exception as exc:
            log("exteraDoom launch failed: %s\n%s" % (exc, traceback.format_exc()))
            self._show_error("Launch failed: %s" % exc)

    def _start_game_with_wad(self, wad_path):
        try:
            fragment = get_last_fragment()
            activity = fragment and fragment.getParentActivity()
            if not activity:
                return
            if not wad_path or not os.path.exists(wad_path):
                log("exteraDoom missing selected WAD: %s" % wad_path)
                return
            self._ensure_payloads()
            kind = self._wad_kind(wad_path)
            iwad_path = wad_path
            pwad_path = None
            if kind == "PWAD":
                iwad_path = self._find_saved_iwad(exclude_path=wad_path, pwad_path=wad_path) or self._find_wad(pwad_path=wad_path)
                if not iwad_path:
                    self._show_error("Для этого WAD нужен базовый IWAD: DOOM.WAD, DOOM2.WAD или FREEDM.WAD.")
                    return
                pwad_path = wad_path
                log("exteraDoom launching PWAD: iwad=%s pwad=%s" % (iwad_path, pwad_path))
            elif kind != "IWAD":
                self._show_error("Это не Doom WAD.")
                return
            compat_error = self._wad_preflight_error(wad_path, kind, iwad_path if pwad_path else None)
            if compat_error:
                self._show_error(compat_error)
                return
            self.stop_game()
            self.wad_path = iwad_path
            self.pwad_path = pwad_path
            self.native_started = False
            self.lib = None
            if not self._load_native(activity, fresh=True):
                return
            self._build_dialog(activity)
            self.running = True
            self.loop_thread = threading.Thread(target=self._game_loop, daemon=True)
            self.loop_thread.start()
        except Exception as exc:
            log("exteraDoom start failed: %s\n%s" % (exc, traceback.format_exc()))
            self._show_error("Start failed: %s" % exc)

    def _app_dirs(self):
        ctx = ApplicationLoader.applicationContext
        files_dir = str(ctx.getFilesDir().getAbsolutePath())
        internal = os.path.join(files_dir, "extera_doom")
        external = None
        try:
            ext = ctx.getExternalFilesDir(None)
            if ext:
                external = os.path.join(str(ext.getAbsolutePath()), "extera_doom")
        except Exception:
            pass
        plugin_dir = os.path.dirname(os.path.realpath(__file__))
        for path in (internal, external):
            if path:
                os.makedirs(path, exist_ok=True)
        return internal, external, plugin_dir

    def _write_b64_file(self, target, data_b64, expected_sha, executable=False):
        if os.path.exists(target):
            try:
                with open(target, "rb") as handle:
                    if hashlib.sha256(handle.read()).hexdigest() == expected_sha:
                        if executable:
                            os.chmod(target, 0o755)
                        return
            except Exception:
                pass
        tmp = target + ".tmp"
        data = base64.b64decode(data_b64.encode("ascii"))
        if hashlib.sha256(data).hexdigest() != expected_sha:
            raise RuntimeError("embedded payload checksum mismatch")
        with open(tmp, "wb") as handle:
            handle.write(data)
        os.replace(tmp, target)
        if executable:
            os.chmod(target, 0o755)

    def _ensure_payloads(self):
        internal, external, _ = self._app_dirs()
        lib_dir = os.path.join(internal, "lib")
        os.makedirs(lib_dir, exist_ok=True)
        self.lib_path = os.path.join(lib_dir, "libexdoom.so")
        self._write_b64_file(self.lib_path, LIBEXDOOM_B64, LIBEXDOOM_SHA256, executable=True)
        self._write_b64_file(os.path.join(internal, "exdoom_source.zip"), SOURCE_ZIP_B64, SOURCE_ZIP_SHA256)
        if external:
            marker = os.path.join(external, "PUT_DOOM_WAD_HERE.txt")
            if not os.path.exists(marker):
                with open(marker, "w", encoding="utf-8") as handle:
                    handle.write("Place DOOM.WAD, DOOM1.WAD, doom.wad or doom1.wad here and launch exteraDoom again.\n")
        log("exteraDoom payload ready: %s" % self.lib_path)

    def _install_activity_result_hook(self):
        if self._activity_result_hooked:
            return
        try:
            plugin_ref = self
            try:
                fragment = get_last_fragment()
                activity = fragment.getParentActivity() if fragment else None
            except Exception:
                activity = None
            if activity is None:
                log("exteraDoom activity result hook skipped: no activity")
                return

            class _DoomActivityResultHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        req = int(param.args[0])
                        res = int(param.args[1])
                        data = param.args[2]
                    except Exception:
                        return
                    try:
                        if (req & 0xFFFF) != DOOM_WAD_PICKER_REQ:
                            return
                        if not plugin_ref._pending_file_pick:
                            return
                        plugin_ref._pending_file_pick = False
                        if int(res) != -1 or data is None:
                            return
                        try:
                            uri = data.getData()
                        except Exception:
                            uri = None
                        if uri is None:
                            return
                        log("exteraDoom WAD picker result: %s" % uri)
                        threading.Thread(target=plugin_ref._process_wad_uri, args=(uri,), daemon=True).start()
                    except Exception as exc:
                        log("exteraDoom activity result failed: %s" % exc)

            Integer = find_class("java.lang.Integer")
            Intent = find_class("android.content.Intent")
            cls = activity.getClass()
            method = None
            while cls is not None and method is None:
                try:
                    method = cls.getDeclaredMethod("onActivityResult", Integer.TYPE, Integer.TYPE, Intent)
                except Exception:
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
            if method is None:
                raise RuntimeError("onActivityResult method not found")
            self._activity_result_hook_ref = self.hook_method(method, _DoomActivityResultHook())
            self._activity_result_hooked = True
            log("exteraDoom activity result hook installed on %s" % activity.getClass().getName())
        except Exception as exc:
            log("exteraDoom activity result hook install failed: %s" % exc)

    def _open_wad_picker(self, activity):
        if self._open_telegram_wad_picker(activity):
            return
        self._open_android_wad_picker(activity)

    def _open_telegram_wad_picker(self, activity):
        try:
            fragment = get_last_fragment()
            if not fragment:
                return False
            ChatAttachAlert = find_class("org.telegram.ui.Components.ChatAttachAlert")
            DelegateClass = find_class("org.telegram.ui.Components.ChatAttachAlertDocumentLayout$DocumentSelectActivityDelegate")
            Boolean = find_class("java.lang.Boolean")
            if not ChatAttachAlert or not DelegateClass:
                return False
            plugin_ref = self

            class _TelegramDocumentDelegate(dynamic_proxy(DelegateClass)):
                def didSelectFiles(self, files, caption, captionEntities, fmessages, notify, scheduleDate, scheduleRepeatPeriod, effectId, invertMedia, payStars):
                    try:
                        plugin_ref._pending_file_pick = False
                        if files is None or int(files.size()) <= 0:
                            return
                        path = str(files.get(0))
                        log("exteraDoom Telegram WAD picker result: %s" % path)
                        try:
                            if plugin_ref._telegram_picker_ref:
                                plugin_ref._telegram_picker_ref[0].dismiss()
                        except Exception:
                            pass
                        threading.Thread(target=plugin_ref._process_wad_path, args=(path,), daemon=True).start()
                    except Exception as exc:
                        log("exteraDoom Telegram picker result failed: %s" % exc)

                def didSelectPhotos(self, photos, notify, scheduleDate, scheduleRepeatPeriod, payStars):
                    return

                def startDocumentSelectActivity(self):
                    try:
                        if plugin_ref._telegram_picker_ref:
                            plugin_ref._telegram_picker_ref[0].dismiss()
                    except Exception:
                        pass
                    plugin_ref._open_android_wad_picker(activity)

                def startMusicSelectActivity(self):
                    return

            delegate = _TelegramDocumentDelegate()
            try:
                alert = ChatAttachAlert(activity, fragment, False, False, False, None)
            except Exception:
                alert = ChatAttachAlert(activity, fragment, False, False)
            try:
                alert.setAllowEnterCaption(True)
            except Exception as exc:
                log("exteraDoom Telegram picker allow files failed: %s" % exc)
            alert.setDocumentsDelegate(delegate)
            self._telegram_picker_ref = (alert, delegate)
            self._pending_file_pick = True
            alert.show()
            try:
                method = alert.getClass().getDeclaredMethod("openDocumentsLayout", Boolean.TYPE)
                method.setAccessible(True)
                method.invoke(alert, True)
            except Exception as exc:
                log("exteraDoom Telegram document layout open failed: %s" % exc)
            return True
        except Exception as exc:
            log("exteraDoom Telegram picker failed: %s" % exc)
            self._telegram_picker_ref = None
            return False

    def _open_android_wad_picker(self, activity):
        self._pending_file_pick = True
        try:
            Intent = find_class("android.content.Intent")
            intent = Intent(Intent.ACTION_OPEN_DOCUMENT)
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            intent.setType("*/*")
            try:
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                intent.addFlags(Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION)
            except Exception:
                pass
            activity.startActivityForResult(intent, DOOM_WAD_PICKER_REQ)
            return
        except Exception as exc:
            log("exteraDoom ACTION_OPEN_DOCUMENT failed: %s" % exc)
        try:
            Intent = find_class("android.content.Intent")
            intent = Intent(Intent.ACTION_GET_CONTENT)
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            intent.setType("*/*")
            try:
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
            except Exception:
                pass
            activity.startActivityForResult(intent, DOOM_WAD_PICKER_REQ)
        except Exception as exc:
            self._pending_file_pick = False
            log("exteraDoom file picker failed: %s" % exc)
            self._show_dialog(activity, "exteraDoom", "Не удалось открыть выбор WAD-файла: %s" % exc)

    def _process_wad_uri(self, uri):
        try:
            path = self._copy_wad_from_uri(uri)
            self._remember_wad(path)
            run_on_ui_thread(lambda p=path: self._start_game_with_wad(p))
        except Exception as exc:
            log("exteraDoom WAD import failed: %s\n%s" % (exc, traceback.format_exc()))
            self._show_error("Ошибка чтения WAD: %s" % exc)

    def _process_wad_path(self, source_path):
        try:
            path = self._copy_wad_from_path(source_path)
            self._remember_wad(path)
            run_on_ui_thread(lambda p=path: self._start_game_with_wad(p))
        except Exception as exc:
            log("exteraDoom WAD path import failed: %s\n%s" % (exc, traceback.format_exc()))
            self._show_error("Ошибка чтения WAD: %s" % exc)

    def _copy_wad_from_uri(self, uri):
        ctx = ApplicationLoader.applicationContext
        resolver = ctx.getContentResolver()
        try:
            Intent = find_class("android.content.Intent")
            take = int(Intent.FLAG_GRANT_READ_URI_PERMISSION) | int(Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION)
            resolver.takePersistableUriPermission(uri, take)
        except Exception:
            pass
        target_dir = self._external_wad_cache_dir()
        os.makedirs(target_dir, exist_ok=True)
        file_name = self._name_from_uri(uri)
        if not file_name.lower().endswith((".wad", ".iwad")):
            file_name += ".wad"
        target = self._unique_target_path(target_dir, file_name)
        inp = resolver.openInputStream(uri)
        if inp is None:
            raise RuntimeError("openInputStream returned null")
        FileOutputStream = find_class("java.io.FileOutputStream")
        out = FileOutputStream(target)
        buf = jarray(jbyte)([0] * 65536)
        total = 0
        try:
            while True:
                n = inp.read(buf)
                if n is None or int(n) <= 0:
                    break
                out.write(buf, 0, int(n))
                total += int(n)
        finally:
            try:
                inp.close()
            except Exception:
                pass
            try:
                out.close()
            except Exception:
                pass
        if total < 1024 * 1024:
            try:
                os.remove(target)
            except Exception:
                pass
            raise RuntimeError("выбранный файл слишком маленький для Doom WAD")
        log("exteraDoom selected WAD copied: %s bytes=%d" % (target, total))
        return target

    def _copy_wad_from_path(self, source_path):
        source_path = str(source_path or "")
        if not source_path or not os.path.exists(source_path):
            raise RuntimeError("выбранный файл недоступен")
        target_dir = self._external_wad_cache_dir()
        os.makedirs(target_dir, exist_ok=True)
        file_name = self._safe_file_name(os.path.basename(source_path) or "selected.wad")
        if not file_name.lower().endswith((".wad", ".iwad")):
            file_name += ".wad"
        target = self._unique_target_path(target_dir, file_name)
        if os.path.abspath(source_path) == os.path.abspath(target):
            return source_path
        shutil.copyfile(source_path, target)
        size = os.path.getsize(target)
        if size < 1024 * 1024:
            try:
                os.remove(target)
            except Exception:
                pass
            raise RuntimeError("выбранный файл слишком маленький для Doom WAD")
        log("exteraDoom selected WAD copied from path: %s bytes=%d" % (target, size))
        return target

    def _external_wad_cache_dir(self):
        internal, external, _ = self._app_dirs()
        return os.path.join(external or internal, "selected_wads")

    def _name_from_uri(self, uri):
        name = "selected.wad"
        try:
            ctx = ApplicationLoader.applicationContext
            resolver = ctx.getContentResolver()
            cursor = resolver.query(uri, None, None, None, None)
            try:
                if cursor and cursor.moveToFirst():
                    try:
                        OpenableColumns = find_class("android.provider.OpenableColumns")
                        idx = cursor.getColumnIndex(OpenableColumns.DISPLAY_NAME)
                    except Exception:
                        idx = cursor.getColumnIndex("_display_name")
                    if int(idx) >= 0:
                        display = cursor.getString(idx)
                        if display:
                            name = str(display)
                            return self._safe_file_name(name)
            finally:
                try:
                    if cursor:
                        cursor.close()
                except Exception:
                    pass
        except Exception as exc:
            log("exteraDoom display name read failed: %s" % exc)
        try:
            raw = str(uri.getPath() or "").split("/")[-1]
            if ":" in raw:
                raw = raw.split(":")[-1]
            if raw:
                name = raw
        except Exception:
            pass
        return self._safe_file_name(name)

    def _safe_file_name(self, name):
        safe = []
        for ch in str(name):
            if ch.isalnum() or ch in (".", "_", "-"):
                safe.append(ch)
            else:
                safe.append("_")
        return "".join(safe).strip("._") or "selected.wad"

    def _unique_target_path(self, directory, file_name):
        file_name = self._safe_file_name(file_name)
        target = os.path.join(directory, file_name)
        if not os.path.exists(target):
            return target
        stem, ext = os.path.splitext(file_name)
        for idx in range(2, 1000):
            candidate = os.path.join(directory, "%s_%d%s" % (stem, idx, ext))
            if not os.path.exists(candidate):
                return candidate
        return os.path.join(directory, "%d_%s" % (int(time.time() * 1000), file_name))

    def _find_wad(self, pwad_path=None):
        internal, external, plugin_dir = self._app_dirs()
        names = ["DOOM.WAD", "doom.wad", "DOOM1.WAD", "doom1.wad", "DOOM2.WAD", "doom2.wad", "FREEDM.WAD", "freedm.wad", "freedoom1.wad", "FREEDOOM1.WAD", "freedoom2.wad", "FREEDOOM2.WAD"]
        candidates = []
        for directory in (self._external_wad_cache_dir(), internal, external, plugin_dir):
            if not directory:
                continue
            for name in names:
                path = os.path.join(directory, name)
                if os.path.exists(path) and os.path.getsize(path) > 1024 * 1024 and self._wad_kind(path) == "IWAD":
                    candidates.append(path)
        if not candidates:
            return None
        candidates.sort(key=lambda p: self._iwad_score_for_pwad(p, pwad_path), reverse=True)
        return candidates[0]

    def _find_saved_iwad(self, exclude_path=None, pwad_path=None):
        exclude_abs = os.path.abspath(exclude_path) if exclude_path else ""
        candidates = []
        for entry in self._saved_wads():
            path = entry.get("path") or ""
            if not path or not os.path.exists(path):
                continue
            if exclude_abs and os.path.abspath(path) == exclude_abs:
                continue
            if self._wad_kind(path) == "IWAD":
                candidates.append(path)
        if not candidates:
            return None
        candidates.sort(key=lambda p: self._iwad_score_for_pwad(p, pwad_path), reverse=True)
        return candidates[0]

    def _iwad_score_for_pwad(self, iwad_path, pwad_path=None):
        name = os.path.basename(iwad_path or "").lower()
        score = 1
        if not pwad_path:
            return score
        style = self._pwad_map_style(pwad_path)
        if style == "doom2":
            if "doom2" in name or "freedm" in name or "freedoom2" in name:
                score += 20
            if "doom1" in name or "freedoom1" in name:
                score -= 8
        elif style == "doom1":
            if "doom1" in name or name == "doom.wad" or "freedoom1" in name:
                score += 20
            if "doom2" in name or "freedoom2" in name or "freedm" in name:
                score -= 8
        return score

    def _pwad_map_style(self, path):
        try:
            lumps = self._wad_lump_names(path)
            if any(re.match(r"^MAP[0-9][0-9]$", name) for name in lumps):
                return "doom2"
            if any(re.match(r"^E[0-9]M[0-9]$", name) for name in lumps):
                return "doom1"
        except Exception as exc:
            log("exteraDoom PWAD map style failed: %s" % exc)
        return ""

    def _wad_lump_names(self, path):
        return [entry["name"] for entry in self._wad_lump_entries(path)]

    def _wad_lump_entries(self, path):
        names = []
        with open(path, "rb") as handle:
            header = handle.read(12)
            if len(header) != 12 or header[:4] not in (b"IWAD", b"PWAD"):
                return names
            count, table_ofs = struct.unpack("<ii", header[4:12])
            if count <= 0 or count > 50000 or table_ofs <= 0:
                return names
            handle.seek(table_ofs)
            for _ in range(count):
                entry = handle.read(16)
                if len(entry) != 16:
                    break
                lump_ofs, lump_size = struct.unpack("<ii", entry[:8])
                raw = entry[8:16].split(b"\0", 1)[0]
                try:
                    name = raw.decode("ascii", "ignore").upper()
                except Exception:
                    name = ""
                names.append({"name": name, "offset": lump_ofs, "size": lump_size})
        return names

    def _read_lump_data(self, path, lump_name):
        want = str(lump_name).upper()
        entries = self._wad_lump_entries(path)
        for entry in reversed(entries):
            if entry["name"] != want:
                continue
            size = int(entry["size"])
            if size <= 0 or size > 16 * 1024 * 1024:
                return b""
            with open(path, "rb") as handle:
                handle.seek(int(entry["offset"]))
                return handle.read(size)
        return b""

    def _pnames_count(self, path):
        data = self._read_lump_data(path, "PNAMES")
        if len(data) < 4:
            return -1
        count = struct.unpack("<i", data[:4])[0]
        if count < 0 or count > 100000:
            return -1
        return count

    def _texture_error(self, wad_path, iwad_path=None):
        pnames = self._pnames_count(wad_path)
        if pnames < 0 and iwad_path:
            pnames = self._pnames_count(iwad_path)
        if pnames < 0:
            return None
        for lump_name in ("TEXTURE1", "TEXTURE2"):
            data = self._read_lump_data(wad_path, lump_name)
            if not data:
                continue
            if len(data) < 4:
                return "%s поврежден: слишком маленький lump." % lump_name
            tex_count = struct.unpack("<i", data[:4])[0]
            if tex_count < 0 or tex_count > 20000 or 4 + tex_count * 4 > len(data):
                return "%s имеет неподдерживаемую/поврежденную таблицу текстур." % lump_name
            for idx in range(tex_count):
                offset = struct.unpack("<i", data[4 + idx * 4:8 + idx * 4])[0]
                if offset < 0 or offset + 22 > len(data):
                    return "%s имеет битый offset текстуры #%d." % (lump_name, idx)
                patch_count = struct.unpack("<h", data[offset + 20:offset + 22])[0]
                if patch_count < 0 or patch_count > 256:
                    return "%s имеет неподдерживаемую текстуру #%d." % (lump_name, idx)
                patch_table = offset + 22
                if patch_table + patch_count * 10 > len(data):
                    return "%s имеет обрезанную patch table." % lump_name
                for patch_idx in range(patch_count):
                    pos = patch_table + patch_idx * 10 + 4
                    patch_num = struct.unpack("<h", data[pos:pos + 2])[0]
                    if patch_num < 0 or patch_num >= pnames:
                        return "%s ссылается на patch #%d, но PNAMES содержит только %d. Этот WAD не совместим с vanilla Doom без merge/другого порта." % (lump_name, patch_num, pnames)
        return None

    def _wad_preflight_error(self, wad_path, kind, iwad_path=None):
        try:
            names = set(self._wad_lump_names(wad_path))
            if kind == "IWAD":
                required = ("PLAYPAL", "COLORMAP", "PNAMES", "TEXTURE1", "S_START", "S_END", "F_START", "F_END")
                missing = [name for name in required if name not in names]
                if missing:
                    return "Этот IWAD неполный или не от Doom: нет %s." % ", ".join(missing[:4])
                return None
            if kind != "PWAD":
                return "Это не Doom WAD."

            unsupported = sorted(names.intersection({
                "TEXTMAP", "BEHAVIOR", "SCRIPTS", "ZMAPINFO", "MAPINFO",
                "DECORATE", "ZSCRIPT", "GLDEFS", "LOADACS", "EMAPINFO",
                "ANIMDEFS", "SNDINFO", "SNDSEQ", "MODELDEF"
            }))
            if unsupported:
                return "Этот PWAD требует Boom/GZDoom/ZDoom-совместимый порт: %s. Текущее ядро - оригинальный Doom." % ", ".join(unsupported[:4])

            has_map = any(re.match(r"^(MAP[0-9][0-9]|E[0-9]M[0-9])$", name) for name in names)
            if not has_map:
                return "В этом PWAD нет обычных vanilla Doom карт MAPxx/E#M#."

            style = self._pwad_map_style(wad_path)
            iwad_name = os.path.basename(iwad_path or "").lower()
            if style == "doom2" and ("doom1" in iwad_name or "freedoom1" in iwad_name):
                return "Этот PWAD сделан под Doom II, нужен DOOM2.WAD или FREEDM.WAD."
            if style == "doom1" and ("doom2" in iwad_name or "freedoom2" in iwad_name or "freedm" in iwad_name):
                return "Этот PWAD сделан под Doom 1, нужен DOOM.WAD или DOOM1.WAD."

            texture_error = self._texture_error(wad_path, iwad_path)
            if texture_error:
                return texture_error
        except Exception as exc:
            log("exteraDoom WAD preflight failed: %s\n%s" % (exc, traceback.format_exc()))
        return None

    def _wad_kind(self, path):
        try:
            with open(path, "rb") as handle:
                magic = handle.read(4)
            if magic == b"IWAD":
                return "IWAD"
            if magic == b"PWAD":
                return "PWAD"
            return "BAD"
        except Exception:
            return "UNKNOWN"

    def _load_native(self, activity, fresh=False):
        try:
            Build = find_class("android.os.Build")
            abis = [str(x) for x in Build.SUPPORTED_ABIS]
            if "arm64-v8a" not in abis:
                self._show_dialog(activity, "exteraDoom", "Сейчас вшита только arm64-v8a библиотека. ABI устройства: %s" % ", ".join(abis))
                return False
        except Exception:
            pass
        load_path = self.lib_path
        if fresh:
            internal, _, _ = self._app_dirs()
            session_dir = os.path.join(internal, "lib")
            os.makedirs(session_dir, exist_ok=True)
            load_path = os.path.join(session_dir, "libexdoom_session_%d.so" % int(time.time() * 1000))
            shutil.copyfile(self.lib_path, load_path)
            os.chmod(load_path, 0o755)
            self._session_lib_path = load_path
        elif self.lib:
            return True
        linker = NativeLinker()
        self.lib = linker.load(load_path)
        if not self.lib:
            self._show_dialog(activity, "exteraDoom", "Не удалось загрузить libexdoom.so. Пришли logcat по тегу PyObject/exteraDoom.")
            return False
        self.lib.exdoom_init.argtypes = [ctypes.c_char_p, ctypes.c_char_p]
        self.lib.exdoom_init.restype = ctypes.c_int
        self.lib.exdoom_init_pwad.argtypes = [ctypes.c_char_p, ctypes.c_char_p, ctypes.c_char_p]
        self.lib.exdoom_init_pwad.restype = ctypes.c_int
        self.lib.exdoom_tick.argtypes = [ctypes.POINTER(ctypes.c_uint32), ctypes.c_int]
        self.lib.exdoom_tick.restype = ctypes.c_int
        self.lib.exdoom_key.argtypes = [ctypes.c_int, ctypes.c_int]
        self.lib.exdoom_key.restype = None
        self.lib.exdoom_width.restype = ctypes.c_int
        self.lib.exdoom_height.restype = ctypes.c_int
        self.lib.exdoom_last_error.restype = ctypes.c_int
        self.lib.exdoom_last_error_text.restype = ctypes.c_char_p
        self.width = int(self.lib.exdoom_width())
        self.height = int(self.lib.exdoom_height())
        self.total_pixels = self.width * self.height
        PixelArray = ctypes.c_uint32 * self.total_pixels
        self.c_pixels = PixelArray()
        self.java_pixels = jarray(jint)([signed_color(0xFF000000)] * self.total_pixels)
        self._frame_bytes = None
        self._frame_buffer = None
        self._byte_buffer_cls = None
        log("exteraDoom native lib loaded: %s framebuffer=%dx%d" % (load_path, self.width, self.height))
        return True

    def _build_dialog(self, activity):
        Dialog = find_class("android.app.Dialog")
        Window = find_class("android.view.Window")
        WindowManager = find_class("android.view.WindowManager")
        FrameLayout = find_class("android.widget.FrameLayout")
        LinearLayout = find_class("android.widget.LinearLayout")
        ImageView = find_class("android.widget.ImageView")
        TextView = find_class("android.widget.TextView")
        Gravity = find_class("android.view.Gravity")
        Color = find_class("android.graphics.Color")
        GradientDrawable = find_class("android.graphics.drawable.GradientDrawable")
        Bitmap = find_class("android.graphics.Bitmap")
        AudioManager = find_class("android.media.AudioManager")
        AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
        MotionEvent = find_class("android.view.MotionEvent")
        OnDismiss = find_class("android.content.DialogInterface$OnDismissListener")
        OnKey = find_class("android.content.DialogInterface$OnKeyListener")
        SysUi = find_class("android.view.View$OnSystemUiVisibilityChangeListener")
        System = find_class("java.lang.System")
        Toast = find_class("android.widget.Toast")

        self.activity = activity
        self.orig_orient = activity.getRequestedOrientation()
        self.orig_vol_stream = activity.getVolumeControlStream()
        activity.setRequestedOrientation(0)
        activity.setVolumeControlStream(AudioManager.STREAM_MUSIC)

        class Dismiss(dynamic_proxy(OnDismiss)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin

            def onDismiss(self, dialog):
                self.plugin.running = False
                try:
                    if self.plugin.activity:
                        if self.plugin.orig_orient is not None:
                            self.plugin.activity.setRequestedOrientation(self.plugin.orig_orient)
                        if self.plugin.orig_vol_stream is not None:
                            self.plugin.activity.setVolumeControlStream(self.plugin.orig_vol_stream)
                except Exception:
                    pass
                self.plugin.dialog = None
                self.plugin.activity = None
                self.plugin._ui_refs = []

        class KeyListener(dynamic_proxy(OnKey)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin

            def onKey(self, dialog, code, event):
                if code == 4 and event.getAction() == 1:
                    now = System.currentTimeMillis()
                    if (now - self.plugin.back_ts) < 1200:
                        return False
                    self.plugin.back_ts = now
                    self.plugin._send_key(KEY_ESCAPE, True)
                    self.plugin._send_key(KEY_ESCAPE, False)
                    Toast.makeText(activity, "Back again closes exteraDoom", 0).show()
                    return True
                return False

        class SysListener(dynamic_proxy(SysUi)):
            def __init__(self, decor, flags):
                super().__init__()
                self.decor = decor
                self.flags = flags

            def onSystemUiVisibilityChange(self, vis):
                if (vis & 4) == 0:
                    self.decor.setSystemUiVisibility(self.flags)

        dialog = Dialog(activity, 16974122)
        dialog.requestWindowFeature(Window.FEATURE_NO_TITLE)
        dismiss_listener = Dismiss(self)
        key_listener = KeyListener(self)
        self._ui_refs = [dismiss_listener, key_listener]
        dialog.setOnDismissListener(dismiss_listener)
        dialog.setOnKeyListener(key_listener)

        root = FrameLayout(activity)
        root.setBackgroundColor(Color.BLACK)

        self.bitmap = Bitmap.createBitmap(self.width, self.height, Bitmap.Config.ARGB_8888)
        self.image = ImageView(activity)
        self.image.setScaleType(ImageView.ScaleType.FIT_CENTER)
        self.image.setBackgroundColor(Color.BLACK)
        self.bitmap.setPixels(self.java_pixels, 0, self.width, 0, 0, self.width, self.height)
        self.image.setImageBitmap(self.bitmap)
        root.addView(self.image, FrameLayout.LayoutParams(-1, -1))

        controls = LinearLayout(activity)
        controls.setOrientation(LinearLayout.HORIZONTAL)
        controls.setGravity(Gravity.CENTER)
        controls.setClickable(True)
        controls.setFocusable(False)
        try:
            controls.setMotionEventSplittingEnabled(True)
        except Exception:
            pass
        controls.setBackgroundColor(signed_color(0x55000000))
        controls.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))

        left = LinearLayout(activity)
        left.setOrientation(LinearLayout.VERTICAL)
        left.setGravity(Gravity.CENTER)
        controls.addView(left, LinearLayout.LayoutParams(0, -1, 1.0))
        right = LinearLayout(activity)
        right.setOrientation(LinearLayout.VERTICAL)
        right.setGravity(Gravity.CENTER)
        controls.addView(right, LinearLayout.LayoutParams(0, -1, 1.0))
        for group in (left, right):
            group.setClickable(True)
            group.setFocusable(False)
            try:
                group.setMotionEventSplittingEnabled(True)
            except Exception:
                pass

        row1 = LinearLayout(activity); row1.setGravity(Gravity.CENTER); left.addView(row1, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(60)))
        row2 = LinearLayout(activity); row2.setGravity(Gravity.CENTER); left.addView(row2, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(60)))
        row3 = LinearLayout(activity); row3.setGravity(Gravity.CENTER); right.addView(row3, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(54)))
        row4 = LinearLayout(activity); row4.setGravity(Gravity.CENTER); right.addView(row4, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(66)))
        for row in (row1, row2, row3, row4):
            row.setClickable(True)
            row.setFocusable(False)
            try:
                row.setMotionEventSplittingEnabled(True)
            except Exception:
                pass

        def control_bg(fill, stroke=0x66FFFFFF):
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setColor(signed_color(fill))
            bg.setStroke(AndroidUtilities.dp(1), signed_color(stroke))
            bg.setCornerRadius(AndroidUtilities.dp(14))
            return bg

        def press_key(key, label):
            state = {"down": False}
            def handler(view, event):
                try:
                    action = event.getActionMasked()
                except Exception:
                    action = event.getAction()
                try:
                    view.getParent().requestDisallowInterceptTouchEvent(True)
                except Exception:
                    pass
                if action in (MotionEvent.ACTION_DOWN, MotionEvent.ACTION_POINTER_DOWN):
                    if not state["down"]:
                        state["down"] = True
                        log("exteraDoom touch down: %s" % label)
                        self._send_key(key, True)
                    return True
                if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_POINTER_UP, MotionEvent.ACTION_CANCEL):
                    if state["down"]:
                        state["down"] = False
                        log("exteraDoom touch up: %s" % label)
                        self._send_key(key, False)
                    return True
                return True
            return handler

        def button(text, parent, key, width_dp=74, height_dp=52, fill=0x77181818, text_size=13):
            b = TextView(activity)
            b.setText(text)
            b.setTextSize(text_size)
            b.setTextColor(Color.WHITE)
            b.setGravity(Gravity.CENTER)
            b.setIncludeFontPadding(False)
            b.setClickable(True)
            b.setFocusable(False)
            b.setMinHeight(AndroidUtilities.dp(height_dp))
            b.setBackground(control_bg(fill))
            lp = LinearLayout.LayoutParams(AndroidUtilities.dp(width_dp), AndroidUtilities.dp(height_dp))
            lp.setMargins(AndroidUtilities.dp(4), AndroidUtilities.dp(3), AndroidUtilities.dp(4), AndroidUtilities.dp(3))
            parent.addView(b, lp)
            listener = TouchListener(press_key(key, text))
            b.setOnTouchListener(listener)
            self._ui_refs.append(listener)
            return b

        button("▲", row1, KEY_UP, 104, 54, 0x7723262F, 20)
        button("◀", row2, KEY_LEFT, 82, 54, 0x7723262F, 20)
        button("▼", row2, KEY_DOWN, 82, 54, 0x7723262F, 20)
        button("▶", row2, KEY_RIGHT, 82, 54, 0x7723262F, 20)
        button("SL", row3, KEY_STRAFE_L, 64, 48, 0x77313642, 12)
        button("RUN", row3, KEY_RUN, 76, 48, 0x77313642, 12)
        button("SR", row3, KEY_STRAFE_R, 64, 48, 0x77313642, 12)
        button("START", row3, KEY_ENTER, 92, 48, 0x77543E2F, 12)
        button("FIRE", row4, KEY_FIRE, 128, 60, 0xAA8C1D18, 15)
        button("USE", row4, KEY_USE, 92, 60, 0xAA1E5F74, 14)
        button("MENU", row4, KEY_ESCAPE, 82, 60, 0x77313642, 12)

        controls_lp = FrameLayout.LayoutParams(-1, AndroidUtilities.dp(144))
        controls_lp.gravity = Gravity.BOTTOM
        root.addView(controls, controls_lp)
        controls.bringToFront()

        close = TextView(activity)
        close.setText("X")
        close.setTextColor(Color.WHITE)
        close.setTextSize(18)
        close.setGravity(Gravity.CENTER)
        close.setBackground(control_bg(0x99000000))
        close_listener = ClickListener(lambda: dialog.dismiss())
        self._ui_refs.append(close_listener)
        close.setOnClickListener(close_listener)
        close_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(40))
        close_lp.gravity = Gravity.TOP | Gravity.RIGHT
        close_lp.topMargin = AndroidUtilities.dp(8)
        close_lp.rightMargin = AndroidUtilities.dp(10)
        root.addView(close, close_lp)
        close.bringToFront()

        dialog.setContentView(root)
        dialog.show()
        window = dialog.getWindow()
        if window:
            window.setLayout(-1, -1)
            window.addFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
            flags = 5894
            decor = window.getDecorView()
            decor.setSystemUiVisibility(flags)
            sys_listener = SysListener(decor, flags)
            self._ui_refs.append(sys_listener)
            decor.setOnSystemUiVisibilityChangeListener(sys_listener)
        self.dialog = dialog

    def _send_key(self, key, pressed):
        try:
            if self.lib:
                with self._native_lock:
                    self.lib.exdoom_key(int(key), 1 if pressed else 0)
        except Exception as exc:
            log("exteraDoom key failed: %s" % exc)

    def _game_loop(self):
        try:
            if not self.native_started:
                internal, _, _ = self._app_dirs()
                with self._native_lock:
                    if self.pwad_path:
                        ok = self.lib.exdoom_init_pwad(self.wad_path.encode("utf-8"), self.pwad_path.encode("utf-8"), internal.encode("utf-8"))
                    else:
                        ok = self.lib.exdoom_init(self.wad_path.encode("utf-8"), internal.encode("utf-8"))
                if not ok:
                    err = self.lib.exdoom_last_error()
                    text = self._native_error_text()
                    self.running = False
                    self._show_error("Doom init failed: %s%s" % (err, ("\n" + text) if text else ""))
                    return
                self.native_started = True
                log("exteraDoom engine initialized with IWAD: %s PWAD: %s" % (self.wad_path, self.pwad_path or ""))
            while self.running:
                with self._native_lock:
                    ret = self.lib.exdoom_tick(self.c_pixels, self.total_pixels)
                if ret <= 0:
                    text = self._native_error_text()
                    self.running = False
                    self._show_error("Doom stopped: %s%s" % (ret, ("\n" + text) if text else ""))
                    return
                try:
                    self._frame_bytes = ctypes.string_at(ctypes.addressof(self.c_pixels), self.total_pixels * 4)
                except Exception:
                    for i in range(self.total_pixels):
                        self.java_pixels[i] = self._raw_pixel_to_argb(int(self.c_pixels[i]))
                    self._frame_bytes = None
                run_on_ui_thread(self._apply_frame)
                time.sleep(1.0 / 24.0)
        except Exception as exc:
            log("exteraDoom loop failed: %s\n%s" % (exc, traceback.format_exc()))
            self.running = False
            self._show_error("Loop failed: %s" % exc)

    def _native_error_text(self):
        try:
            if not self.lib:
                return ""
            raw = self.lib.exdoom_last_error_text()
            if not raw:
                return ""
            return raw.decode("utf-8", "replace") if hasattr(raw, "decode") else str(raw)
        except Exception:
            return ""

    def _apply_frame(self):
        try:
            if not self.running or not self.bitmap or not self.image:
                return
            if self._frame_bytes is not None:
                try:
                    if self._byte_buffer_cls is None:
                        self._byte_buffer_cls = find_class("java.nio.ByteBuffer")
                    self._frame_buffer = self._byte_buffer_cls.wrap(self._frame_bytes)
                    self.bitmap.copyPixelsFromBuffer(self._frame_buffer)
                except Exception as exc:
                    log("exteraDoom raw frame apply failed, fallback: %s" % exc)
                    for i in range(self.total_pixels):
                        self.java_pixels[i] = self._raw_pixel_to_argb(int(self.c_pixels[i]))
                    self.bitmap.setPixels(self.java_pixels, 0, self.width, 0, 0, self.width, self.height)
                    self._frame_bytes = None
            else:
                self.bitmap.setPixels(self.java_pixels, 0, self.width, 0, 0, self.width, self.height)
            self.image.invalidate()
        except Exception as exc:
            log("exteraDoom apply frame failed: %s\n%s" % (exc, traceback.format_exc()))

    def _raw_pixel_to_argb(self, value):
        value = int(value) & 0xffffffff
        return signed_color(0xff000000 | ((value & 0xff) << 16) | (value & 0xff00) | ((value >> 16) & 0xff))

    def stop_game(self):
        self.running = False
        t = self.loop_thread
        self.loop_thread = None
        try:
            if t and t is not threading.current_thread():
                t.join(0.35)
        except Exception:
            pass
        d = self.dialog
        self.dialog = None
        if d:
            try:
                d.dismiss()
            except Exception:
                pass

    def _show_wad_missing(self, activity):
        internal, external, _ = self._app_dirs()
        paths = [internal]
        if external:
            paths.append(external)
        self._show_dialog(activity, "exteraDoom", message)

    def _show_error(self, message):
        def run():
            fragment = get_last_fragment()
            activity = fragment and fragment.getParentActivity()
            if activity:
                self._show_dialog(activity, "exteraDoom", message)
        run_on_ui_thread(run)

    def _show_dialog(self, activity, title, message):
        try:
            Builder = find_class("android.app.AlertDialog$Builder")
            builder = Builder(activity)
            builder.setTitle(title)
            builder.setMessage(message)
            builder.setPositiveButton("OK", None)
            builder.show()
        except Exception as exc:
            log("exteraDoom dialog failed: %s; message=%s" % (exc, message))
