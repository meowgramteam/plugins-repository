class _ChannelCellDrawHook(MethodHook):
    def __init__(self, plugin):
        self.p = weakref.ref(plugin)
        self._paint_bmp = None
        self._paint_darken = None

    def before_hooked_method(self, param):
        p = self.p()
        if p is None:
            return
        try:
            if not p._cb_get_bool(p.SETTINGS_CB_ENABLE, False):
                return
            cell = param.thisObject
            canvas = param.args[0]
            if cell is None or canvas is None:
                return
            if not p._cb_current_channel_key:
                return
            key = p._cb_current_channel_key
            bmp = p._cb_ensure_bitmap(key)
            if bmp is None:
                return
            w = cell.getMeasuredWidth()
            h = cell.getMeasuredHeight()
            if w <= 0 or h <= 0:
                return

            eff = p._cb_get_str(p.SETTINGS_CB_EFFECT, "blur_darken")
            bmp_d = p._cb_get_blurred(key, bmp) if p._cb_has_blur(eff) else bmp
            if bmp_d is None:
                
                bmp_d = bmp
            bw = bmp_d.getWidth()
            bh = bmp_d.getHeight()
            if bw <= 0 or bh <= 0:
                return

            scale = max(w / float(bw), h / float(bh))
            tx = (w - bw * scale) / 2.0
            ty = (h - bh * scale) / 2.0

            mat = Matrix()
            mat.postScale(float(scale), float(scale))
            mat.postTranslate(float(tx), float(ty))

            sid = canvas.save()
            try:
                canvas.clipRect(0, 0, int(w), int(h))
                if self._paint_bmp is None:
                    self._paint_bmp = Paint()
                    self._paint_bmp.setFilterBitmap(True)
                canvas.drawBitmap(bmp_d, mat, self._paint_bmp)
                if p._cb_has_darken(eff):
                    a = int(255 * p._cb_get_percent(p.SETTINGS_CB_DARKEN, 55) / 100.0)
                    if a > 0:
                        if self._paint_darken is None:
                            self._paint_darken = Paint()
                            self._paint_darken.setStyle(Paint.Style.FILL)
                        self._paint_darken.setARGB(a, 0, 0, 0)
                        canvas.drawRect(0, 0, float(w), float(h), self._paint_darken)
            finally:
                try:
                    canvas.restoreToCount(sid)
                except Exception:
                    try:
                        canvas.restore()
                    except Exception:
                        pass
        except Exception as e:
            log(f"{_CB_TAG} draw error: {e}")

    def after_hooked_method(self, param):
        p = self.p()
        if p is None:
            return
        try:
            if not p._cb_get_bool(p.SETTINGS_CB_ENABLE, False):
                return
            cell = param.thisObject
            if cell is None or not p._cb_current_channel_key:
                return
            if p._cb_ensure_bitmap(p._cb_current_channel_key) is None:
                return
            p._cb_tint_views_white(cell)
        except Exception:
            pass

class _ChannelProfileReadyHook(MethodHook):
    def __init__(self, plugin):
        self.p = weakref.ref(plugin)

    def after_hooked_method(self, param):
        p = self.p()
        if p is None:
            return
        try:
            frag = param.thisObject
            if frag is not None and "ProfileActivity" in frag.getClass().getName():
                p._cb_on_profile_ready(frag)
        except Exception:
            pass

class _ChannelProfilePauseHook(MethodHook):
    def __init__(self, plugin):
        self.p = weakref.ref(plugin)

    def before_hooked_method(self, param):
        p = self.p()
        if p is None:
            return
        try:
            frag = param.thisObject
            if frag is not None and "ProfileActivity" in frag.getClass().getName():
                p._cb_current_channel_key = None
                p._cb_original_colors.clear()
        except Exception:
            pass

class _ChannelLayoutHook(MethodHook):
    def __init__(self, plugin):
        self.p = weakref.ref(plugin)

    def after_hooked_method(self, param):
        p = self.p()
        if p is None:
            return
        try:
            lv = param.thisObject
            if lv is not None:
                p._cb_scan_children(lv)
        except Exception:
            pass

class _ChannelARHook(MethodHook):
    """Обработчик выбора файла для баннера канала."""
    def __init__(self, plugin, key):
        self.p = plugin
        self.key = key

    def before_hooked_method(self, param):
        try:
            if int(param.args[0]) != self.p.CB_FILE_PICKER_CODE:
                return
            param.setResult(None)
            if int(param.args[1]) == Activity.RESULT_OK and param.args[2] is not None:
                uri = param.args[2].getData()
                if uri is not None:
                    threading.Thread(
                        target=self.p._cb_save_uri,
                        args=(uri, self.key),
                        daemon=True,
                    ).start()
            try:
                if self.p._cb_activity_hook:
                    self.p.unhook_method(self.p._cb_activity_hook)
                    self.p._cb_activity_hook = None
            except Exception:
                pass
        except Exception:
            pass

class _ThemeGetColorIntHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def before_hooked_method(self, param):
        try:
            mode, fragment = self.p._current_profile_textmode()
            if not mode:
                return
            clsname = fragment.getClass().getName() if fragment else ""
            if "ProfileActivity" not in clsname:
                return
            key_int = int(param.args[0])
            name_color, sub_color = self.p._resolve_text_colors(mode)
            k = self.p._theme_keys
            if key_int == k.get("key_profile_title"):
                param.setResult(name_color)
            elif key_int in (k.get("key_avatar_subtitleInProfileBue"), k.get("key_avatar_subtitleInProfileBlue")):
                param.setResult(sub_color)
        except Exception:
            return

class _ThemeGetColorStrHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def before_hooked_method(self, param):
        try:
            mode, fragment = self.p._current_profile_textmode()
            if not mode:
                return
            clsname = fragment.getClass().getName() if fragment else ""
            if "ProfileActivity" not in clsname:
                return
            key_str = str(param.args[0] or "").strip()
            if not key_str:
                return
            name_color, sub_color = self.p._resolve_text_colors(mode)
            if key_str == "profile_title":
                param.setResult(name_color)
            elif key_str in ("avatar_subtitleInProfileBue", "avatar_subtitleInProfileBlue"):
                param.setResult(sub_color)
        except Exception:
            return

class _TopViewOnDrawHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin
        self._cached_outer_id = None
        self._cached_key = None
        self._cached_mode = ""
        self._field_cache: dict = {}

    def _get_key(self, outer):
        oid = id(outer)
        if oid != self._cached_outer_id:
            self._cached_outer_id = oid
            try:
                self._cached_key = self.p._get_profile_key_from_fragment(outer)
            except Exception:
                self._cached_key = "unknown"
            try:
                self._cached_mode = self.p._get_profile_text_mode(self._cached_key)
            except Exception:
                self._cached_mode = ""
        return self._cached_key or "unknown"

    def before_hooked_method(self, param):
        try:
            if not self.p._enable_cached:
                return
            topview = param.thisObject
            if topview is None:
                return
            outer = None
            try:
                f = topview.getClass().getDeclaredField("this$0")
                f.setAccessible(True)
                outer = f.get(topview)
            except Exception:
                pass
            if outer is None:
                return
            key = self._get_key(outer)
            if self._cached_mode:
                self.p._apply_text_colors(topview, outer, self._cached_mode, self._field_cache)
        except Exception:
            pass

    def after_hooked_method(self, param):
        try:
            if not self.p._enable_cached:
                return
            topview = param.thisObject
            canvas = param.args[0]
            if canvas is None or topview is None:
                return
            outer = None
            try:
                f = topview.getClass().getDeclaredField("this$0")
                f.setAccessible(True)
                outer = f.get(topview)
            except Exception:
                pass
            key = self._get_key(outer) if outer is not None else "unknown"
            bmp = self.p._ensure_bitmap_for_key(key)
            if bmp is None or bmp.isRecycled():
                return
            
            if bmp.isRecycled():
                return

            try:
                effect = self.p._get_profile_effect(key)
            except Exception:
                effect = self.p._get_effect_str(self.p.SETTINGS_EFFECT_DEFAULT, "blur")
            if effect not in ("blur", "darken", "blur_darken", "none"):
                effect = "blur"
            y1 = None
            progress = 0.0
            try:
                actionBar = outer.getActionBar() if outer is not None else None
                status = AndroidUtilities.statusBarHeight
                try:
                    ab_h = JActionBar.getCurrentActionBarHeight()
                except Exception:
                    ab_h = AndroidUtilities.dp(56)
                height = ab_h + (status if (actionBar is not None and actionBar.getOccupyStatusBar()) else 0)
                extraHeight = searchTransitionOffset = mediaHeaderAnimationProgress = 0.0
                for fname in ("extraHeight", "searchTransitionOffset", "mediaHeaderAnimationProgress"):
                    try:
                        ff = outer.getClass().getDeclaredField(fname)
                        ff.setAccessible(True)
                        val = ff.get(outer)
                        if fname == "extraHeight":
                            extraHeight = float(val)
                        elif fname == "searchTransitionOffset":
                            searchTransitionOffset = float(val)
                        else:
                            mediaHeaderAnimationProgress = float(val)
                    except Exception:
                        pass
                progress = max(0.0, min(1.0, float(mediaHeaderAnimationProgress)))
                y1 = int(float(extraHeight + height + searchTransitionOffset) * (1.0 - progress))
            except Exception:
                pass
            if y1 is None or y1 <= 0:
                y1 = AndroidUtilities.dp(240)
            try:
                tvh = topview.getMeasuredHeight()
                if tvh > 0:
                    y1 = min(int(y1), int(tvh))
            except Exception:
                pass
            w = topview.getMeasuredWidth()
            if w <= 0 or y1 <= 0:
                return
            
            if effect in ("blur", "blur_darken"):
                blurred = self.p._get_blurred_bitmap_for_key(key, bmp)
                if blurred is None or blurred.isRecycled():
                    return
                bmp_draw = blurred
            else:
                if bmp is None or bmp.isRecycled():
                    return
                bmp_draw = bmp

            bw = bmp_draw.getWidth()
            bh = bmp_draw.getHeight()
            if bw <= 0 or bh <= 0:
                return
            if 1.0 - progress <= 0.02:
                return
            
            scale = max(w / float(bw), y1 / float(bh)) * 1.02
            matrix = Matrix()
            matrix.reset()
            matrix.postScale(float(scale), float(scale))
            matrix.postTranslate((w - bw * scale) * 0.5, (y1 - bh * scale) * 0.5)
            
            save_id = canvas.save()
            try:
                try:
                    canvas.clipRect(0, 0, int(w), int(y1))
                except Exception:
                    canvas.clipRect(int(0), int(0), int(w), int(y1))
                if self.p._paint_bmp is None:
                    self.p._paint_bmp = Paint()
                    self.p._paint_bmp.setFilterBitmap(True)
                    self.p._paint_bmp.setDither(True)
                self.p._paint_bmp.setAlpha(255)
                canvas.drawBitmap(bmp_draw, matrix, self.p._paint_bmp)
                if effect in ("darken", "blur_darken"):
                    try:
                        darken_percent = self.p._get_percent(self.p.SETTINGS_DARKEN_INTENSITY, 65)
                        overlay_alpha = int(255 * (darken_percent / 100.0))
                        if overlay_alpha > 0:
                            if self.p._paint_darken is None:
                                self.p._paint_darken = Paint()
                                self.p._paint_darken.setStyle(Paint.Style.FILL)
                                self.p._paint_darken.setDither(True)
                                self.p._paint_darken.setAntiAlias(True)
                            self.p._paint_darken.setARGB(overlay_alpha, 0, 0, 0)
                            canvas.drawRect(0, 0, w, y1, self.p._paint_darken)
                    except Exception:
                        pass
                fade_alpha = int(max(0, min(255, self.p._get_int(self.p.SETTINGS_FADE, 90) * (1.0 - progress))))
                if fade_alpha > 0:
                    grad_h = int(max(1, y1 * 0.35))
                    if self.p._paint_fade is None:
                        self.p._paint_fade = Paint()
                    fade_key = (y1, grad_h, fade_alpha)
                    if getattr(self.p, "_last_fade_key", None) != fade_key:
                        self.p._last_fade_key = fade_key
                        self.p._paint_fade.setShader(LinearGradient(
                            0, y1 - grad_h, 0, y1,
                            Color.argb(0, 0, 0, 0),
                            Color.argb(fade_alpha, 0, 0, 0),
                            Shader.TileMode.CLAMP
                        ))
                    canvas.drawRect(0, y1 - grad_h, w, y1, self.p._paint_fade)
            finally:
                try:
                    canvas.restoreToCount(save_id)
                except Exception:
                    try:
                        canvas.restore()
                    except Exception:
                        pass
        except Exception:
            pass

class _FragmentResumeHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def after_hooked_method(self, param):
        try:
            fragment = param.thisObject
            if not fragment:
                return
            fragment_class_name = fragment.getClass().getName()
            if fragment_class_name in self.p.AB_BLACKLISTED_FRAGMENTS:
                if hasattr(fragment, "getActionBar") and (ab := fragment.getActionBar()):
                    ab.setBackgroundDrawable(ColorDrawable(Color.TRANSPARENT))
                return
            if "TopicsFragment" in fragment_class_name:
                self.p._make_topics_transparent(fragment)
            self.p._request_banner_update(fragment)
        except Exception as e:
            log(f"{_TAG} FragmentResumeHook error: {e}\n{traceback.format_exc()}")

class _ProfileResumeHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def after_hooked_method(self, param):
        try:
            fragment = param.thisObject
            if fragment is None:
                return
            def _attach():
                try:
                    topview = self.p._find_topview_instance(fragment)
                    if topview is not None:
                        self.p._ensure_hook_on_topview_instance(topview)
                        self.p._invalidate_profile_view(fragment)
                except Exception:
                    pass
            run_on_ui_thread(_attach)
        except Exception:
            pass

class _ActionBarActivityResultHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def before_hooked_method(self, param):
        req_code, res_code, data = param.args
        if req_code == self.p.AB_FILE_PICKER_CODE:
            param.setResult(None)
            self.p._handle_ab_file_picker_result(res_code, data)




class _TFSetBackgroundHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if param.args and param.args[0] is not None:
                param.args[0] = None
            view = param.thisObject
            if view is not None:
                view.setWillNotDraw(False)
        except Exception:
            pass


class _TFSetBackgroundColorHook(MethodHook):
