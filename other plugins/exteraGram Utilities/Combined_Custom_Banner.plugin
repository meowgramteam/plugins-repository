            if fragment is not None:
                self.plugin._oldfolders_register_topbubbles_hook(fragment)
                run_on_ui_thread(lambda: self.plugin._oldfolders_apply_now(fragment))
        except Exception:
            pass


class ProfileHeaderImagePlugin(BasePlugin):

    SETTINGS_ENABLE = "profileHeader.enable"
    SETTINGS_SOURCE_GLOBAL = "profileHeader.source"
    SETTINGS_FADE = "profileHeader.fade"
    SETTINGS_BLUR_INTENSITY = "profileHeader.blurIntensity"
    SETTINGS_DARKEN_INTENSITY = "profileHeader.darkenIntensity"
    SETTINGS_EFFECT_DEFAULT = "profileHeader.defaultEffect"
    SETTINGS_AVATAR_BANNER_ENABLE = "profileHeader.avatarBanner.enable"
    SETTINGS_AVATAR_BANNER_EFFECT = "profileHeader.avatarBanner.effect"
    TEXTMODE_PREFIX = "profileHeader.textMode."
    EFFECT_PREFIX = "profileHeader.effect."
    FILE_PICKER_REQUEST_CODE = 33101

    SETTINGS_AB_ENABLE = "actionBarBanner.enable"
    SETTINGS_AB_PATH = "actionBarBanner.path"
    SETTINGS_AB_EVERYWHERE = "actionBarBanner.everywhere"
    SETTINGS_AB_USE_AVATARS = "actionBarBanner.useAvatars"
    SETTINGS_AB_BLUR_AVATARS = "actionBarBanner.blurAvatars"
    SETTINGS_AB_LOAD_HQ = "actionBarBanner.loadHQ"
    SETTINGS_AB_BLUR_BANNER = "actionBarBanner.blurBanner"
    SETTINGS_AB_BLUR_INTENSITY = "actionBarBanner.blurIntensity"
    SETTINGS_AB_DARKEN_INTENSITY = "actionBarBanner.darkenIntensity"
    SETTINGS_AB_CROP_STYLE = "actionBarBanner.cropStyle"
    SETTINGS_AB_EXTEND_TO_TABS = "actionBarBanner.extendToTabs"
    AB_FILE_PICKER_CODE = 33102

    SETTINGS_CB_ENABLE   = "cb.enable"
    SETTINGS_CB_AUTO     = "cb.autoAvatar"      
    SETTINGS_CB_EFFECT   = "cb.effect"
    SETTINGS_CB_DARKEN   = "cb.darken"
    SETTINGS_CB_BLUR     = "cb.blur"
    CB_SOURCE_PREFIX     = "cb.src."
    CB_FILE_PICKER_CODE  = 44201
    SETTINGS_LANGUAGE    = "ccb.language"

    
    SETTINGS_OLDF_ENABLE = "oldfolders.enable"
    AB_BLACKLISTED_FRAGMENTS = {
        "org.telegram.ui.ProfileActivity",
        "org.telegram.ui.PremiumPreviewFragment",
        "org.telegram.ui.Stars.StarsIntroActivity",
    }

    MAX_BMP_CACHE = 3
    MAX_PROFILE_BITMAP_SIDE = 1536
    MAX_BLUR_BITMAP_SIDE = 640
    MAX_ACTIONBAR_BITMAP_SIDE = 1600
    MAX_ACTIONBAR_BITMAP_HEIGHT = 512
    MAX_BOX_BLUR_PIXELS = 262144

    def __init__(self):
        super().__init__()
        self._last_target_fragment_ref = None
        self._activity_hook = None
        self._bmp_map: dict = {}
        self._bmp_blur_map: dict = {}
        self._bmp_order: deque = deque()
        self._src_map: dict = {}
        self._plugin_dir = ""
        self._hook_on_draw_ref = None
        self._hooked_topview_classname = None
        self._profile_resume_hook_ref = None
        self._watcher_stop = False
        self._theme_hook_refs: list = []
        self._theme_keys: dict = {}
        self._last_blur_percent = None
        self._enable_cached = False
        self._paint_bmp = None
        self._paint_darken = None
        self._paint_fade = None
        try:
            self._CanvasClass = find_class("android.graphics.Canvas")
        except Exception:
            self._CanvasClass = None
        self._ab_hook_refs: list = []
        self._ab_activity_hook = None
        self._ab_bitmap_cache: Dict[str, Bitmap] = {}
        self._ab_cache_order: deque = deque()
        self._AB_MAX_BMP_CACHE = 2
        self._ab_cache_lock = threading.RLock()
        self._ab_inflight_keys: set = set()
        self._avatar_polling_keys: set = set()
        self._ab_fragments_to_ignore: set = set()
        self._ab_loading_hq_dialog_id = 0
        self._ab_is_processing_file = False
        self._ab_avatar_container_field = None
        self._ab_BackupImageViewClass = None
        self._ab_filter_tabs_field_cache: dict = {}
        self._ab_search_field_cache: dict = {}
        self._ab_scroll_listeners: dict = {}
        self._ab_banner_visible: dict = {}
        self.main_handler: Optional[Handler] = None

        self._cb_bmp_map: dict = {}            
        self._cb_bmp_blur_map: dict = {}       
        self._cb_src_map: dict = {}            
        self._cb_last_blur_pct = None
        self._cb_hooked_cells: dict = {}       
        self._cb_original_colors: dict = {}
        self._cb_set_user_info_hook_ref = None
        self._cb_activity_hook = None
        self._cb_current_channel_key: Optional[str] = None
        self._cb_profile_menu_id: Optional[str] = None
        self._profile_menu_id: Optional[str] = None
        self._cb_last_frag_ref = None
        self._cb_watcher_stop = False
        try:
            self._cb_CanvasCls = find_class("android.graphics.Canvas")
        except Exception:
            self._cb_CanvasCls = None
        self._cb_avatar_inflight: set = set()   
        self._cb_blur_inflight: set = set()     
        self._cb_bmp_order: deque = deque()     
        self._CB_MAX_BMP = 4                    
        self._cb_MAX_AVATAR_SIDE = 640          
        self._cb_watcher_event = threading.Event()
        self._watcher_event = threading.Event()
        self._cb_current_profile_uid: int = 0


        self._oldfolders_hooks: list = []
        self._oldfolders_topbubbles_hook_done = False

    def on_plugin_load(self):
        self._ensure_defaults()
        self._ensure_plugin_dir()
        self._enable_cached = self._get_bool(self.SETTINGS_ENABLE, False)
        self.main_handler = Handler(Looper.getMainLooper())
        try:
            _pmid = f"{self.id}.profile.custombg"
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.PROFILE_ACTION_MENU,
                text=self._t("menu_custom_bg"),
                icon="msg_gallery",
                on_click=self._menu_set_custom_bg,
                priority=1000,
                item_id=_pmid,
            ))
            self._profile_menu_id = _pmid
        except Exception:
            pass
        self._install_theme_hooks()
        self._hook_profile_resume()
        threading.Thread(target=self._watcher_loop, name="ExteraProfileWatcher", daemon=True).start()
        if self._get_bool(self.SETTINGS_AB_ENABLE, True):
            for cls_name in (
                "org.telegram.ui.DialogsActivity",
                "org.telegram.ui.ChatActivity",
                "org.telegram.ui.TopicsFragment",
                "com.exteragram.messenger.preferences.MainPreferencesActivity",
                "com.radolyn.ayugram.ui.preferences.AyuMainPreferencesActivity",
            ):
                self._hook_fragment_resume(cls_name)

        try:
            self._cb_ensure_defaults()
            self._cb_add_menu()
            self._cb_hook_set_user_info()
            threading.Thread(target=self._cb_watcher, daemon=True, name="CBWatcher").start()
        except Exception as e:
            log(f"{_CB_TAG} init error: {e}")


        self._oldfolders_ensure_defaults()
        if self._get_bool(self.SETTINGS_OLDF_ENABLE, False):
            self._oldfolders_install_hooks()

    def on_plugin_unload(self):
        self._watcher_stop = True
        self._cb_watcher_stop = True
        try:
            self._watcher_event.set()
        except Exception:
            pass
        try:
            self._cb_watcher_event.set()
        except Exception:
            pass
        try:
            self._reset_theme_colors()
        except Exception:
            pass
        if self._profile_resume_hook_ref:
            try:
                self.unhook_method(self._profile_resume_hook_ref)
            except Exception:
                pass
            self._profile_resume_hook_ref = None
        if self._hook_on_draw_ref:
            try:
                self.unhook_method(self._hook_on_draw_ref)
            except Exception:
                pass
            self._hook_on_draw_ref = None
        self._hooked_topview_classname = None
        for ref in self._theme_hook_refs:
            try:
                if ref:
                    self.unhook_method(ref)
            except Exception:
                pass
        self._theme_hook_refs = []
        if self._activity_hook:
            try:
                self._activity_hook.unhook()
            except Exception:
                pass
            self._activity_hook = None
        for ref in self._ab_hook_refs:
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._ab_hook_refs.clear()
        if self._ab_activity_hook:
            try:
                self.unhook_method(self._ab_activity_hook)
            except Exception:
                pass
            self._ab_activity_hook = None
        if self.main_handler:
            self.main_handler.removeCallbacksAndMessages(None)
        try:
            fragment = get_last_fragment()
            if fragment and hasattr(fragment, "getActionBar"):
                ab = fragment.getActionBar()
                if ab:
                    clsname = fragment.getClass().getName()
                    d = (ColorDrawable(Color.TRANSPARENT) if clsname in self.AB_BLACKLISTED_FRAGMENTS
                         else ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                    run_on_ui_thread(lambda: ab.setBackgroundDrawable(d))
        except Exception:
            pass
        try:
            frag = get_last_fragment()
            if frag:
                run_on_ui_thread(lambda: self._reset_tabs_background(frag))
        except Exception:
            pass
        with self._ab_cache_lock:
            self._ab_bitmap_cache.clear()
            self._ab_cache_order.clear()
            self._ab_inflight_keys.clear()
        for bmp in list(self._bmp_map.values()):
            try:
                if bmp and not bmp.isRecycled():
                    bmp.recycle()
            except Exception:
                pass
        for entry in list(self._bmp_blur_map.values()):
            try:
                old_bmp = entry[0] if isinstance(entry, tuple) else entry
                if old_bmp and not old_bmp.isRecycled():
                    old_bmp.recycle()
            except Exception:
                pass
        self._bmp_map.clear()
        self._bmp_blur_map.clear()
        self._avatar_polling_keys.clear()
        self._ab_filter_tabs_field_cache.clear()
        self._ab_search_field_cache.clear()

        for ref in (self._cb_set_user_info_hook_ref, self._cb_activity_hook):
            if ref:
                try:
                    self.unhook_method(ref)
                except Exception:
                    pass
        self._cb_set_user_info_hook_ref = None
        self._cb_activity_hook = None
        seen = set()
        for ref in list(self._cb_hooked_cells.values()):
            if id(ref) in seen:
                continue
            seen.add(id(ref))
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._cb_hooked_cells.clear()
        for bmp in list(self._cb_bmp_map.values()):
            try:
                if bmp and not bmp.isRecycled():
                    bmp.recycle()
            except Exception:
                pass
        for entry in list(self._cb_bmp_blur_map.values()):
            try:
                cb = entry[0] if isinstance(entry, tuple) else entry
                if cb and not cb.isRecycled():
                    cb.recycle()
            except Exception:
                pass
        self._cb_bmp_map.clear()
        self._cb_bmp_blur_map.clear()
        self._cb_src_map.clear()
        self._cb_original_colors.clear()
        self._cb_avatar_inflight.clear()
        self._cb_blur_inflight.clear()
        self._cb_bmp_order.clear()

    def create_settings(self):
        return self._build_settings()

    def _build_settings(self):
        try:
            blur_percent   = self._get_percent(self.SETTINGS_BLUR_INTENSITY, 20)
            darken_percent = self._get_percent(self.SETTINGS_DARKEN_INTENSITY, 65)
            is_ab_enabled  = self._get_bool(self.SETTINGS_AB_ENABLE, True)
            is_ab_extend   = self._get_bool(self.SETTINGS_AB_EXTEND_TO_TABS, True)
            is_avatar_banner_enabled = self._get_bool(self.SETTINGS_AVATAR_BANNER_ENABLE, True)

            effect_options = [self._t("eff_blur"), self._t("eff_darken"),
                              self._t("eff_blur_darken"), self._t("eff_none")]
            effect_values  = ["blur", "darken", "blur_darken", "none"]
            cur_eff = self._get_effect_str(self.SETTINGS_AVATAR_BANNER_EFFECT, "darken")
            try:
                eff_idx = effect_values.index(cur_eff)
            except ValueError:
                eff_idx = 0

            ab_path = self._get_str(self.SETTINGS_AB_PATH, "")
            ab_file_info = (os.path.basename(ab_path)
                            if ab_path and os.path.exists(ab_path)
                            else self._t("ab_no_image"))

            lang_idx = 0
            try:
                lang_idx = int(self.get_setting(self.SETTINGS_LANGUAGE, 0))
                if lang_idx not in (0, 1):
                    lang_idx = 0
            except Exception:
                pass

            rows = [
                Header(text=self._t("lang_header")),
                Selector(
                    key=self.SETTINGS_LANGUAGE,
                    text=self._t("lang_selector"),
                    default=lang_idx,
                    items=[self._t("lang_ru"), self._t("lang_en")],
                    icon="msg_language",
                    on_change=self._on_language_changed,
                ),
                Divider(text=self._t("lang_note")),
                Header(text=self._t("ab_header")),
                Switch(
                    key=self.SETTINGS_AB_ENABLE,
                    text=self._t("ab_enable_text"),
                    subtext=self._t("ab_enable_sub"),
                    default=is_ab_enabled,
                    icon="msg_channel",
                    on_change=self._on_ab_enable_changed,
                ),
            ]
            if is_ab_enabled:
                rows += [
                    Switch(
                        key=self.SETTINGS_AB_EXTEND_TO_TABS,
                        text=self._t("ab_extend_text"),
                        subtext=self._t("ab_extend_sub"),
                        default=is_ab_extend,
                        icon="msg_folders",
                        on_change=self._on_ab_settings_change,
                    ),
                    Switch(key=self.SETTINGS_AB_EVERYWHERE,
                           text=self._t("ab_everywhere_text"),
                           subtext=self._t("ab_everywhere_sub"),
                           default=False, icon="msg_chats",
                           on_change=self._on_ab_settings_change),
                    Switch(key=self.SETTINGS_AB_USE_AVATARS,
                           text=self._t("ab_use_avatars_text"),
                           subtext=self._t("ab_use_avatars_sub"),
                           default=False, icon="msg_channel",
                           on_change=self._on_ab_settings_change),
                    Switch(key=self.SETTINGS_AB_BLUR_AVATARS,
                           text=self._t("ab_blur_avatars_text"),
                           default=False, icon="msg_blur_radial",
                           on_change=self._on_ab_settings_change),
                    Switch(key=self.SETTINGS_AB_LOAD_HQ,
                           text=self._t("ab_load_hq_text"),
                           default=True, icon="msg_data"),
                    Text(text=self._t("ab_select_image_text"), icon="msg_gallery",
                         on_click=self._launch_ab_file_picker),
                    Switch(key=self.SETTINGS_AB_BLUR_BANNER,
                           text=self._t("ab_blur_banner_text"),
                           default=False, icon="msg_blur_radial",
                           on_change=self._on_ab_settings_change),
                    Input(key=self.SETTINGS_AB_BLUR_INTENSITY,
                          text=self._t("ab_blur_int_text"),
                          subtext=self._t("ab_blur_int_sub"),
                          default=str(self._get_percent(self.SETTINGS_AB_BLUR_INTENSITY, 15)),
                          on_change=self._on_ab_blur_changed),
                    Input(key=self.SETTINGS_AB_DARKEN_INTENSITY,
                          text=self._t("ab_dark_int_text"),
                          subtext=self._t("ab_dark_int_sub"),
                          default=str(self._get_percent(self.SETTINGS_AB_DARKEN_INTENSITY, 40)),
                          on_change=self._on_ab_darken_changed),
                    Selector(key=self.SETTINGS_AB_CROP_STYLE,
                             text=self._t("ab_crop_text"), default=1,
                             items=[self._t("ab_crop_top"), self._t("ab_crop_center"),
                                    self._t("ab_crop_bottom")],
                             icon="msg_crop", on_change=self._on_ab_settings_change),
                    Divider(text=self._t("ab_file_label").format(ab_file_info)),
                    Text(text=self._t("ab_delete_text"), icon="msg_delete", red=True,
                         on_click=self._delete_ab_image),
                ]

            rows += [
                Header(text=self._t("profile_header")),
                Input(key=self.SETTINGS_BLUR_INTENSITY,
                      text=self._t("profile_blur_text"),
                      subtext=self._t("profile_blur_sub"),
                      default=str(blur_percent),
                      on_change=self._on_blur_intensity_changed),
                Input(key=self.SETTINGS_DARKEN_INTENSITY,
                      text=self._t("profile_dark_text"),
                      subtext=self._t("profile_dark_sub"),
                      default=str(darken_percent),
                      on_change=self._on_darken_intensity_changed),
                Header(text=self._t("avatar_header")),
                Switch(key=self.SETTINGS_AVATAR_BANNER_ENABLE,
                       text=self._t("avatar_enable_text"),
                       subtext=self._t("avatar_enable_sub"),
                       default=is_avatar_banner_enabled,
                       on_change=self._on_avatar_banner_enable_changed),
            ]
            if is_avatar_banner_enabled:
                rows.append(Text(
                    text=self._t("avatar_effect_text").format(effect_options[eff_idx]),
                    on_click=lambda view: self._show_effect_choice_dialog()
                ))
            rows += [
                Divider(text=self._t("avatar_priority_note")),
            ]

            cb_enabled  = self._cb_get_bool(self.SETTINGS_CB_ENABLE, False)
            cb_auto     = self._cb_get_bool(self.SETTINGS_CB_AUTO, True)
            cb_effect   = self._cb_get_str(self.SETTINGS_CB_EFFECT, "blur_darken")
            cb_eff_vals = ["blur_darken", "blur", "darken", "none"]
            cb_eff_items = [self._t("eff_bd_short"), self._t("eff_blur_short"),
                            self._t("eff_dark_short"), self._t("eff_none_short")]
            try:
                cb_eff_idx = cb_eff_vals.index(cb_effect)
            except ValueError:
                cb_eff_idx = 0

            rows += [
                Header(text=self._t("cb_header")),
                Switch(
                    key=self.SETTINGS_CB_ENABLE,
                    text=self._t("cb_enable_text"),
                    subtext=self._t("cb_enable_sub"),
                    default=cb_enabled,
                    icon="msg_channel",
                    on_change=lambda v: (
                        self.set_setting(self.SETTINGS_CB_ENABLE, bool(v)),
                        self._cb_bmp_blur_map.clear(),
                    ),
                ),
            ]
            if cb_enabled:
                rows += [
                    Switch(
                        key=self.SETTINGS_CB_AUTO,
                        text=self._t("cb_auto_text"),
                        subtext=self._t("cb_auto_sub"),
                        default=cb_auto,
                        icon="msg_addphoto",
                        on_change=lambda v: (
                            self.set_setting(self.SETTINGS_CB_AUTO, bool(v)),
                            self._cb_bmp_map.clear(),
                            self._cb_bmp_blur_map.clear(),
                            self._cb_src_map.clear(),
                        ),
                    ),
                    Selector(
                        key=self.SETTINGS_CB_EFFECT,
                        text=self._t("cb_effect_text"),
                        default=cb_eff_idx,
                        items=cb_eff_items,
                        icon="msg_theme",
                        on_change=lambda idx: (
                            self.set_setting(self.SETTINGS_CB_EFFECT, cb_eff_vals[idx]),
                            self._cb_bmp_blur_map.clear(),
                        ),
                    ),
                    Input(
                        key=self.SETTINGS_CB_BLUR,
                        text=self._t("cb_blur_text"),
                        default=str(self._cb_get_percent(self.SETTINGS_CB_BLUR, 25)),
                        on_change=lambda v: (
                            self.set_setting(self.SETTINGS_CB_BLUR,
                                             max(1, min(100, int(str(v or 50).strip())))),
                            self._cb_bmp_blur_map.clear(),
                        ),
                    ),
                    Input(
                        key=self.SETTINGS_CB_DARKEN,
                        text=self._t("cb_dark_text"),
                        default=str(self._cb_get_percent(self.SETTINGS_CB_DARKEN, 55)),
                        on_change=lambda v: self.set_setting(
                            self.SETTINGS_CB_DARKEN,
                            max(1, min(100, int(str(v or 55).strip()))),
                        ),
                    ),
                ]

            oldf_enabled = self._get_bool(self.SETTINGS_OLDF_ENABLE, False)
            rows += [
                Header(text=self._t("oldf_header")),
                Switch(
                    key=self.SETTINGS_OLDF_ENABLE,
                    text=self._t("oldf_enable_text"),
                    subtext=self._t("oldf_enable_sub"),
                    default=oldf_enabled,
                    icon="msg_folders",
                    on_change=self._oldfolders_on_enable_changed,
                ),
            ]
            if oldf_enabled:
                rows += [
                    Divider(text=self._t("oldf_restart_note")),
                ]

            rows += [
                Divider(text=self._t("authors_header")),
                Text(text="@gemeguardian", subtext="Custom Profile", accent=True,
                     on_click=lambda v: self._open_tg_link("gemeguardian")),
                Text(text="@RooniRN", subtext="Custom Top Banner", accent=True,
                     on_click=lambda v: self._open_tg_link("RooniRN")),
                Text(text="@optimist_opti", subtext="Channel Banner", accent=True,
                     on_click=lambda v: self._open_tg_link("optimist_opti")),
                Text(text="@Vernyak6", subtext="TransparentFolders", accent=True,
                     on_click=lambda v: self._open_tg_link("Vernyak6")),
            ]

            return rows
        except Exception:
            return [Header("Combined Banner Profile"), Text(self._t("settings_error"))]
    def _on_ab_blur_changed(self, value):
        try:
            v = max(1, min(100, int(str(value).strip())))
            self.set_setting(self.SETTINGS_AB_BLUR_INTENSITY, v)
            self._on_ab_settings_change()
        except (ValueError, TypeError):
            pass

    def _on_ab_darken_changed(self, value):
        try:
            v = max(0, min(100, int(str(value).strip())))
            self.set_setting(self.SETTINGS_AB_DARKEN_INTENSITY, v)
            self._on_ab_settings_change()
        except (ValueError, TypeError):
            pass

    def _get_filter_tabs_view(self, fragment):
        try:
            cls = fragment.getClass()
            cls_name = cls.getName()
            if cls_name not in self._ab_filter_tabs_field_cache:
                found = None
                for fname in ("filterTabsView", "tabsView", "pagesScrollView", "folder", "filterView", "foldersView", "categoriesView", "sidebarView"):
                    try:
                        f = cls.getDeclaredField(fname)
                        f.setAccessible(True)
                        found = f
                        break
                    except Exception:
                        pass
                self._ab_filter_tabs_field_cache[cls_name] = found
            field = self._ab_filter_tabs_field_cache.get(cls_name)
            return field.get(fragment) if field is not None else None
        except Exception:
            return None

    def _get_search_container_view(self, fragment):
        try:
            cls = fragment.getClass()
            cls_name = cls.getName()
            if cls_name not in self._ab_search_field_cache:
                found = None
                for fname in (
                    "searchContainer", "actionBarSearch", "searchViewContainer",
                    "filterSearchView", "searchViewPager", "searchViewLayout",
                    "filterContainerView", "searchFieldContainer", "searchView",
                    "searchBar", "headerContainer", "toolbarContainer",
                ):
                    try:
                        f = cls.getDeclaredField(fname)
                        f.setAccessible(True)
                        v = f.get(fragment)
                        if v is not None:
                            found = f
                            break
                    except Exception:
                        pass
                self._ab_search_field_cache[cls_name] = found
            field = self._ab_search_field_cache.get(cls_name)
            if field is not None:
                return field.get(fragment)
            return self._find_search_view_by_position(fragment)
        except Exception:
            return None

    def _find_search_view_by_position(self, fragment):
        try:
            root = fragment.getFragmentView()
            if root is None or not isinstance(root, ViewGroup):
                return None
            ab = fragment.getActionBar()
            ab_h = ab.getHeight() if ab else 0
            if ab_h <= 0:
                return None
            tabs = self._get_filter_tabs_view(fragment)
            tabs_top = tabs.getTop() if tabs is not None else ab_h
            if tabs_top <= ab_h:
                return None
            for i in range(root.getChildCount()):
                child = root.getChildAt(i)
                try:
                    ct = child.getTop()
                    cb = child.getBottom()
                    ch = child.getMeasuredHeight()
                    if ch <= 0:
                        continue
                    if ct >= ab_h and cb <= tabs_top + 8:
                        return child
                except Exception:
                    pass
        except Exception:
            pass
        return None

    def _should_probe_overlay_children(self, cls_name: str) -> bool:
        try:
            name = cls_name or ""
            if any(x in name for x in ("ChatActivity", "TopicsFragment", "Forward", "Share", "Send")):
                return False
            hints = (
                "DialogsActivity",
                "MainActivity",
                "MainPreferencesActivity",
                "AyuMainPreferencesActivity",
                "Plugins",
                "Plugin",
            )
            return any(h in name for h in hints)
        except Exception:
            return False

    def _get_extension_heights(self, fragment):
        if not self._get_bool(self.SETTINGS_AB_EXTEND_TO_TABS, True):
            return 0, 0
        try:
            ab = fragment.getActionBar() if hasattr(fragment, "getActionBar") else None
            ab_h = ab.getHeight() if ab else 0
            if ab_h <= 0:
                return 0, 0

            try:
                _MAX_SEARCH_H = AndroidUtilities.dp(96)
                _MAX_TABS_H = AndroidUtilities.dp(64)
                _MAX_EXT_TOTAL = AndroidUtilities.dp(160)
            except Exception:
                _MAX_SEARCH_H = 240
                _MAX_TABS_H = 160
                _MAX_EXT_TOTAL = 400

            def _is_view_visible(v):
                try:
                    if v is None:
                        return False
                    if hasattr(v, "getVisibility") and v.getVisibility() != View.VISIBLE:
                        return False
                    return True
                except Exception:
                    return True

            search_h = 0
            search = self._get_search_container_view(fragment)
            if search is not None and _is_view_visible(search):
                try:
                    sb = max(search.getBottom(), search.getTop() + search.getMeasuredHeight())
                    raw_search_h = max(0, sb - ab_h)
                    search_h = min(raw_search_h, _MAX_SEARCH_H)
                except Exception:
                    pass

            tabs_h = 0
            tabs = self._get_filter_tabs_view(fragment)
            if tabs is not None and _is_view_visible(tabs):
                try:
                    tb = max(tabs.getBottom(), tabs.getTop() + tabs.getMeasuredHeight())
                    tabs_h = tabs.getMeasuredHeight()
                    if tabs_h <= 0:
                        tabs_h = max(0, tabs.getBottom() - tabs.getTop())
                    if tabs_h <= 0:
                        tabs_h = AndroidUtilities.dp(44)
                    tabs_h = min(tabs_h, _MAX_TABS_H)
                    total_ext = max(0, tb - ab_h)
                    search_h = max(search_h, min(max(0, total_ext - tabs_h), _MAX_SEARCH_H))
                except Exception:
                    pass

            if search_h <= 0 and tabs_h <= 0 and self._should_probe_overlay_children(fragment.getClass().getName() if fragment else ""):
                try:
                    root = fragment.getFragmentView()
                    if root is not None and isinstance(root, ViewGroup):
                        extra_bottom = 0
                        max_probe_bottom = ab_h + AndroidUtilities.dp(220)
                        for i in range(root.getChildCount()):
                            child = root.getChildAt(i)
                            try:
                                if child is None:
                                    continue
                                tag = child.getTag()
                                if tag is not None and str(tag) == _BANNER_TAG:
                                    continue
                                ct = max(0, child.getTop())
                                cb = max(child.getBottom(), ct + child.getMeasuredHeight())
                                if cb <= ab_h:
                                    continue
                                if ct <= ab_h + AndroidUtilities.dp(96):
                                    extra_bottom = max(extra_bottom, min(cb, max_probe_bottom))
                            except Exception:
                                pass
                        if extra_bottom > ab_h:
                            search_h = max(search_h, min(extra_bottom - ab_h, _MAX_SEARCH_H))
                except Exception:
                    pass

            if (search_h + tabs_h) > _MAX_EXT_TOTAL:
                search_h = max(0, _MAX_EXT_TOTAL - tabs_h)
            return max(0, search_h), max(0, tabs_h)
        except Exception:
            return 0, 0

    def _is_overlay_banner_fragment(self, cls_name: str, search_h=0, tabs_h=0) -> bool:
        try:
            name = cls_name or ""
            if any(x in name for x in ("ChatActivity", "TopicsFragment")):
                return False
            hints = (
                "DialogsActivity",
                "MainActivity",
                "MainPreferencesActivity",
                "AyuMainPreferencesActivity",
                "Plugins",
                "Plugin",
            )


            forward_hints = (
                "Forward",
                "Share",
                "Send",
            )

            if any(h in name for h in hints):
                return True

            if any(h in name for h in forward_hints):
                return True

            return False
        except Exception:
            return False

    def _apply_dialogs_overlay_banner(self, fragment, unified_bmp, search_h=0, tabs_h=0):
        try:
            if not fragment or fragment.isFinishing() or unified_bmp is None or unified_bmp.isRecycled():
                return
            cls_name = fragment.getClass().getName()
            if cls_name in self.AB_BLACKLISTED_FRAGMENTS:
                return
            root = fragment.getFragmentView()
            if root is None:
                return
            ab = fragment.getActionBar()
            ab_h = ab.getHeight() if ab else 0
            if ab_h <= 0:
                return
            total_h = ab_h + max(0, search_h) + max(0, tabs_h)

            try:
                if any(x in cls_name for x in ("Forward", "Share", "Send")):
                    total_h = min(total_h, ab_h + AndroidUtilities.dp(64))
            except Exception:
                pass


            try:
                root_view = fragment.getFragmentView()
                root_h = root_view.getMeasuredHeight() if root_view is not None else 0
                hard_cap = ab_h + AndroidUtilities.dp(160)
                if root_h > 0:
                    hard_cap = min(hard_cap, int(root_h * 0.35))
                if total_h > hard_cap and hard_cap >= ab_h:
                    total_h = hard_cap
            except Exception:
                pass

            overlay = None
            for i in range(root.getChildCount()):
                child = root.getChildAt(i)
                try:
                    tag = child.getTag()
                    if tag is not None and str(tag) == _BANNER_TAG:
                        overlay = child
                        break
                except Exception:
                    pass
            
            if overlay is None:
                overlay = ImageView(root.getContext())

                try:
                    root.setClipChildren(False)
                    root.setClipToPadding(False)
                except Exception:
                    pass
                overlay.setTag(_BANNER_TAG)
                overlay.setClickable(False)
                overlay.setFocusable(False)

                try:
                    overlay.setClipToOutline(False)
                except Exception:
                    pass

                try:
                    overlay.setClipBounds(None)
                except Exception:
                    pass
                
                try:
                    overlay.setElevation(0.0)
                except Exception:
                    pass
                
                try:
                    overlay.setBackgroundColor(Color.TRANSPARENT)
                except Exception:
                    pass

                lp = FrameLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT,
                    total_h
                )
                lp.gravity = Gravity.TOP
                
                root.addView(overlay, 0, lp)

                try:
                    root.setClipChildren(True)
                except Exception:
                    pass
            else:
                lp = overlay.getLayoutParams()
                if lp is not None and lp.height != total_h:
                    lp.height = total_h
                    overlay.setLayoutParams(lp)
                
                current_idx = root.indexOfChild(overlay)
                if current_idx != 0:
                    root.removeView(overlay)
                    root.addView(overlay, 0, lp)

            overlay.setScaleType(ImageView.ScaleType.FIT_XY)
            try:
                res = root.getResources()
                bmp_drawable = BitmapDrawable(res, unified_bmp)
                bmp_drawable.setGravity(Gravity.FILL)
                bg_col = Theme.getColor(Theme.key_windowBackgroundWhite)
                fade_h = max(AndroidUtilities.dp(56), min(AndroidUtilities.dp(104), int(total_h * 0.42)))
                fade_drawable = GradientDrawable(
                    GradientDrawable.Orientation.TOP_BOTTOM,
                    jarray(jint)([
                        Color.TRANSPARENT,
                        Color.argb(120, Color.red(bg_col), Color.green(bg_col), Color.blue(bg_col)),
                        bg_col
                    ])
                )
                layered = LayerDrawable(jarray(Drawable)([bmp_drawable, fade_drawable]))
                layered.setLayerInset(1, 0, max(0, total_h - fade_h), 0, 0)
                overlay.setImageDrawable(layered)
            except Exception:
                overlay.setImageBitmap(unified_bmp)
            
            if ab:
                ab.setBackgroundDrawable(ColorDrawable(Color.TRANSPARENT))
                try:
                    ab.setElevation(0.0)
                except Exception:
                    pass
            try:
                sv = self._get_search_container_view(fragment)
                if sv is not None:
                    sv.setBackground(None)
                    try:
                        sv.setElevation(0.0)
                    except Exception:
                        pass
            except Exception:
                pass
            try:
                tabs = self._get_filter_tabs_view(fragment)
                if tabs is not None:
                    tabs.setBackground(None)
                    self._hide_tabs_shadow_views(fragment)
            except Exception:
                pass
            
            self._setup_transparent_pill_button(fragment)
            self._setup_scroll_hide_listener(fragment, overlay)
        except Exception as e:
            log(f"{_TAG} _apply_dialogs_overlay_banner error: {e}")

    def _setup_transparent_pill_button(self, fragment):
        try:
            root = fragment.getFragmentView()
            if root is None or not isinstance(root, ViewGroup):
                return
            for i in range(root.getChildCount()):
                child = root.getChildAt(i)
                try:
                    cls_name = child.getClass().getName()
                    if "FloatingActionButton" in cls_name or "RLottieImageView" in cls_name:
                        lp = child.getLayoutParams()
                        if lp and hasattr(lp, "gravity"):
                            grav = lp.gravity
                            if (grav & Gravity.END) != 0 or (grav & Gravity.RIGHT) != 0:
                                child.setBackgroundColor(Color.TRANSPARENT)
                                try:
                                    child.setElevation(0)
                                except Exception:
                                    pass
                                break
                except Exception:
                    pass
        except Exception as e:
            log(f"{_TAG} _setup_transparent_pill_button error: {e}")

    def _setup_scroll_hide_listener(self, fragment, overlay):
        try:
            if dynamic_proxy is None:
                return
            
            frag_id = id(fragment)
            if frag_id in self._ab_scroll_listeners:
                return 
            
            root = fragment.getFragmentView()
            if root is None or not isinstance(root, ViewGroup):
                return
            
            recycler_view = None
            for i in range(root.getChildCount()):
                child = root.getChildAt(i)
                try:
                    cls_name = child.getClass().getName()
                    if "RecyclerListView" in cls_name or "RecyclerView" in cls_name or "ViewPager" in cls_name:
                        recycler_view = child
                        break
                except Exception:
                    pass
            
            if recycler_view is None:
                return
            
            plugin_ref = self
            overlay_ref = weakref.ref(overlay)

            search_view_ref = None
            tabs_view_ref = None
            try:
                sv = self._get_search_container_view(fragment)
                if sv is not None:
                    search_view_ref = weakref.ref(sv)
            except Exception:
                pass

            try:
                tv = self._get_filter_tabs_view(fragment)
                if tv is not None:
                    tabs_view_ref = weakref.ref(tv)
            except Exception:
                pass
            
            try:
                OnScrollListenerClass = find_class("androidx.recyclerview.widget.RecyclerView$OnScrollListener")
                if OnScrollListenerClass is None:
                    return
                
                class _ScrollHideListener(dynamic_proxy(OnScrollListenerClass)):
                    def __init__(self):
                        super().__init__()
                        self.last_dy = 0
                        self.is_hidden = False
                    
                    def onScrolled(self, recyclerView, dx, dy):
                        try:
                            ov = overlay_ref()
                            if ov is None:
                                return
                            
                            sv = search_view_ref() if search_view_ref is not None else None
                            tv = tabs_view_ref() if tabs_view_ref is not None else None

                            search_offset = 0
                            if sv is not None:
                                try:
                                    search_offset = max(sv.getMeasuredHeight(), sv.getHeight())
                                except Exception:
                                    pass

                            if dy > 5:
                                if not self.is_hidden:
                                    try:
                                        ov.animate().translationY(-ov.getHeight()).setDuration(220).start()
                                    except Exception:
                                        ov.setTranslationY(-ov.getHeight())

                                    if sv is not None:
                                        try:
                                            sv.animate().translationY(-search_offset).setDuration(220).start()
                                        except Exception:
                                            sv.setTranslationY(-search_offset)

                                    if tv is not None:
                                        try:

                                            tv.animate().translationY(-search_offset).setDuration(220).start()
                                        except Exception:
                                            tv.setTranslationY(-search_offset)

                                    self.is_hidden = True
                            elif dy < -5:
                                if self.is_hidden:
                                    try:
                                        ov.animate().translationY(0).setDuration(220).start()
                                    except Exception:
                                        ov.setTranslationY(0)

                                    if sv is not None:
                                        try:
                                            sv.animate().translationY(0).setDuration(220).start()
                                        except Exception:
                                            sv.setTranslationY(0)

                                    if tv is not None:
                                        try:
                                            tv.animate().translationY(0).setDuration(220).start()
                                        except Exception:
                                            tv.setTranslationY(0)

                                    self.is_hidden = False
                            
                            self.last_dy = dy
                        except Exception as e:
                            log(f"{_TAG} onScrolled error: {e}")
                
                listener = _ScrollHideListener()
                recycler_view.addOnScrollListener(listener)
                plugin_ref._ab_scroll_listeners[frag_id] = listener
                plugin_ref._ab_banner_visible[frag_id] = True
                
            except Exception as e:
                log(f"{_TAG} Failed to create scroll listener: {e}")
                
        except Exception as e:
            log(f"{_TAG} _setup_scroll_hide_listener error: {e}")

    def _hide_tabs_shadow_views(self, fragment):
        try:
            root = fragment.getFragmentView()
            if root is None or not isinstance(root, ViewGroup):
                return
            
            tabs = self._get_filter_tabs_view(fragment)
            if tabs is None:
                return

            try:
                tabs.setElevation(0.0)
            except Exception:
                pass
            
            tabs_top = tabs.getTop()
            tabs_bottom = tabs.getBottom()
            
            for i in range(root.getChildCount()):
                child = root.getChildAt(i)
                try:
                    tag = child.getTag()
                    if tag is not None and str(tag) == _BANNER_TAG:
                        continue
                    
                    child_top = child.getTop()
                    child_bottom = child.getBottom()
                    
                    if child_top <= tabs_bottom and child_bottom >= tabs_top:
                        cls_name = child.getClass().getName()
                        if "shadow" in cls_name.lower() or "Shadow" in cls_name:
                            child.setVisibility(View.GONE)
                            continue
                        
                        try:
                            bg = child.getBackground()
                            if bg is not None:
                                bg_cls = bg.getClass().getName()
                                if "Gradient" in bg_cls:
                                    child.setBackground(None)
                        except Exception:
                            pass
                except Exception:
                    pass
        except Exception as e:
            log(f"{_TAG} _hide_tabs_shadow_views error: {e}")

    def _apply_unified_banner(self, fragment, unified_bmp, search_h=0, tabs_h=0):
        try:
            if not fragment or fragment.isFinishing() or unified_bmp is None or unified_bmp.isRecycled():
                return
            cls_name = fragment.getClass().getName()
            if cls_name in self.AB_BLACKLISTED_FRAGMENTS:
                return
            is_main = any(x in cls_name for x in ("DialogsActivity", "MainActivity"))
            is_chat = any(x in cls_name for x in ("ChatActivity", "TopicsFragment"))
            is_chats_list = "ChatsFragment" in cls_name
            use_overlay = self._is_overlay_banner_fragment(cls_name, search_h, tabs_h)
            if is_main or use_overlay or is_chats_list:
                self._apply_dialogs_overlay_banner(fragment, unified_bmp, search_h, tabs_h)
                return
            if is_chat:
                parent = fragment.getParentActivity()
                ab = fragment.getActionBar() if hasattr(fragment, "getActionBar") else None
                if not parent or not ab:
                    return
                try:
                    self._reset_tabs_background(fragment)
                except Exception:
                    pass
                def_col = Theme.getColor(Theme.key_actionBarDefault)
                ab_d, _, _ = self._build_unified_drawables(
                    parent,
                    unified_bmp,
                    ab.getHeight(),
                    0,
                    0,
                    def_col
                )
                if ab_d:
                    self._apply_ab_drawable(fragment, ab_d)
                return
            parent = fragment.getParentActivity()
            ab = fragment.getActionBar() if hasattr(fragment, "getActionBar") else None
            if parent and ab:
                def_col = Theme.getColor(Theme.key_actionBarDefault)
                ab_d, _, _ = self._build_unified_drawables(
                    parent,
                    unified_bmp,
                    ab.getHeight(),
                    0,
                    0,
                    def_col
                )
                if ab_d:
                    self._apply_ab_drawable(fragment, ab_d)
        except Exception as e:
            log(f"{_TAG} _apply_unified_banner router error: {e}")

    def _build_unified_drawables(self, parent, unified_bmp, ab_h, search_h, tabs_h, def_col):
        try:
            res = parent.getResources()
            tw = unified_bmp.getWidth()
            total = unified_bmp.getHeight()
            scrim = 0x4D000000
            safe_ab_h = max(1, min(ab_h, total))
            ab_bmp = Bitmap.createBitmap(unified_bmp, 0, 0, tw, safe_ab_h)
            ab_img = BitmapDrawable(res, ab_bmp)
            ab_img.setGravity(Gravity.FILL)
            ab_scrim = ColorDrawable(scrim)
            has_ext = (search_h + tabs_h) > 0
            if has_ext:
                ab_d = LayerDrawable(jarray(Drawable)([ab_img, ab_scrim]))
            else:
                ab_grad = GradientDrawable(
                    GradientDrawable.Orientation.TOP_BOTTOM,
                    jarray(jint)([Color.TRANSPARENT, def_col])
                )
                ab_d = LayerDrawable(jarray(Drawable)([ab_img, ab_scrim, ab_grad]))
            search_d = None
            cur_y = safe_ab_h
            if search_h > 0 and total > cur_y:
                actual_sh = min(search_h, total - cur_y)
                s_bmp = Bitmap.createBitmap(unified_bmp, 0, cur_y, tw, actual_sh)
                s_img = BitmapDrawable(res, s_bmp)
                s_img.setGravity(Gravity.FILL)
                s_scrim = ColorDrawable(scrim)
                search_d = LayerDrawable(jarray(Drawable)([s_img, s_scrim]))
                cur_y += actual_sh
            tabs_d = None
            if tabs_h > 0 and total > cur_y:
                actual_th = total - cur_y
                t_bmp = Bitmap.createBitmap(unified_bmp, 0, cur_y, tw, actual_th)
                t_img = BitmapDrawable(res, t_bmp)
                t_img.setGravity(Gravity.FILL)
                t_scrim = ColorDrawable(scrim)
                tabs_d = LayerDrawable(jarray(Drawable)([t_img, t_scrim]))
            return ab_d, search_d, tabs_d
        except Exception as e:
            log(f"{_TAG} _build_unified_drawables error: {e}")
            return None, None, None

    def _reset_tabs_background(self, fragment):
        try:
            frag_id = id(fragment)
            if frag_id in self._ab_scroll_listeners:
                listener = self._ab_scroll_listeners.pop(frag_id)
                try:
                    root = fragment.getFragmentView()
                    if root and isinstance(root, ViewGroup):
                        for i in range(root.getChildCount()):
                            child = root.getChildAt(i)
                            try:
                                cls_name = child.getClass().getName()
                                if "RecyclerListView" in cls_name or "RecyclerView" in cls_name:
                                    child.removeOnScrollListener(listener)
                                    break
                            except Exception:
                                pass
                except Exception:
                    pass
                self._ab_banner_visible.pop(frag_id, None)
            
            root = fragment.getFragmentView()
            if root is not None:
                for i in range(root.getChildCount() - 1, -1, -1):
                    child = root.getChildAt(i)
                    try:
                        tag = child.getTag()
                        if tag is not None and str(tag) == _BANNER_TAG:
                            root.removeViewAt(i)
                            break
                    except Exception:
                        pass
        except Exception:
            pass
        try:
            ab = fragment.getActionBar()
            if ab:
                ab.setBackgroundDrawable(
                    ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
        except Exception:
            pass

    def _hook_profile_resume(self):
        try:
            cls = find_class("org.telegram.ui.ProfileActivity")
            if not cls:
                return
            method = cls.getDeclaredMethod("onResume")
            method.setAccessible(True)
            ref = self.hook_method(method, _ProfileResumeHook(self))
            if ref:
                self._profile_resume_hook_ref = ref
        except Exception as e:
            log(f"{_TAG} Failed to hook ProfileActivity.onResume: {e}")

    def _hook_fragment_resume(self, class_name: str):
        try:
            cls = find_class(class_name)
            if not cls:
                return
            method = None
            try:
                method = cls.getDeclaredMethod("onResume")
            except Exception:
                try:
                    method = cls.getClass().getDeclaredMethod("onResume")
                except Exception:
                    method = None
            if method is None:
                return
            method.setAccessible(True)
            ref = self.hook_method(method, _FragmentResumeHook(self))
            if ref:
                self._ab_hook_refs.append(ref)
        except Exception as e:
            log(f"{_TAG} Failed to hook {class_name}: {e}")

    def _on_ab_enable_changed(self, v):
        self.set_setting(self.SETTINGS_AB_ENABLE, bool(v))
        self._reload_plugin_settings()

    def _on_ab_settings_change(self, _=None):
        self._ab_fragments_to_ignore.clear()
        with self._ab_cache_lock:
            self._ab_bitmap_cache.clear()
            self._ab_cache_order.clear()
        try:
            frag = get_last_fragment()
            if frag:
                run_on_ui_thread(lambda: self._reset_tabs_background(frag))
        except Exception:
            pass
        self._request_banner_update()

    def _request_banner_update(self, fragment=None, _=None):
        if not self._get_bool(self.SETTINGS_AB_ENABLE, True):
            return
        target = fragment if fragment else get_last_fragment()
        if not target or not self.main_handler:
            return
        plugin_ref = self
        if dynamic_proxy is not None and Runnable is not None:
            class _UpdateRunnable(dynamic_proxy(Runnable)):
                def __init__(self, frag):
                    super().__init__()
                    self.frag = frag
                def run(self):
                    plugin_ref._update_ab_banner_for_fragment(self.frag)
            self.main_handler.postDelayed(_UpdateRunnable(target), 50)
        else:
            run_on_ui_thread(lambda: self._update_ab_banner_for_fragment(target))

    def _make_topics_transparent(self, fragment):
        def _do():
            for fname in ("contentView", "avatarContainer"):
                try:
                    f = fragment.getClass().getDeclaredField(fname)
                    f.setAccessible(True)
                    v = f.get(fragment)
                    if v:
                        v.setBackgroundColor(Color.TRANSPARENT)
                except Exception:
                    pass
        run_on_ui_thread(_do)

    def _get_ab_avatar_drawable(self, fragment):
        try:
            if not self._ab_avatar_container_field:
                f = fragment.getClass().getDeclaredField("avatarContainer")
                f.setAccessible(True)
                self._ab_avatar_container_field = f
            container = self._ab_avatar_container_field.get(fragment)
            if container and isinstance(container, ViewGroup):
                if not self._ab_BackupImageViewClass:
                    self._ab_BackupImageViewClass = find_class("org.telegram.ui.Components.BackupImageView")
                if not self._ab_BackupImageViewClass:
                    return None
                for i in range(container.getChildCount()):
                    child = container.getChildAt(i)
                    if isinstance(child, self._ab_BackupImageViewClass):
                        d = child.getImageReceiver().getDrawable()
                        if d and not isinstance(d, AvatarDrawable):
                            return d
        except Exception:
            pass
        return None

    def _drawable_to_bitmap(self, drawable) -> Optional[Bitmap]:
        try:
            if isinstance(drawable, BitmapDrawable):
                bmp = drawable.getBitmap()
                if bmp and not bmp.isRecycled():
                    return bmp.copy(bmp.getConfig(), True)
            w, h = drawable.getIntrinsicWidth(), drawable.getIntrinsicHeight()
            if w <= 0 or h <= 0:
                return None
            bmp = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888)
            c = Canvas(bmp)
            drawable.setBounds(0, 0, c.getWidth(), c.getHeight())
            drawable.draw(c)
            return bmp
        except Exception:
            return None

    def _ab_gravity(self) -> int:
        idx = self.get_setting(self.SETTINGS_AB_CROP_STYLE, 1)
        if idx == 0:
            return Gravity.TOP
        if idx == 2:
            return Gravity.BOTTOM
        return Gravity.CENTER

    def _update_ab_banner_for_fragment(self, fragment):
        try:
            if not fragment or not hasattr(fragment, "getActionBar"):
                return
            cls_name = fragment.getClass().getName()
            if cls_name in self.AB_BLACKLISTED_FRAGMENTS:
                return

            eff_frag = fragment
            if "DialogsActivity" in cls_name:
                for attr in ("getChatActivity", "getTopicsFragment"):
                    if hasattr(fragment, attr):
                        try:
                            r = getattr(fragment, attr)()
                            if r:
                                eff_frag = r
                                break
                        except Exception:
                            pass

            target_fragment = eff_frag if eff_frag is not None else fragment
            if not hasattr(target_fragment, "getActionBar") or target_fragment.getActionBar() is None:
                target_fragment = fragment
            ab = target_fragment.getActionBar() if target_fragment else None
            if not ab:
                return
            if ab.getWidth() <= 0:
                run_on_ui_thread(lambda: self._update_ab_banner_for_fragment(fragment), 150)
                return
            if cls_name in self._ab_fragments_to_ignore and target_fragment is fragment:
                ab.setBackgroundDrawable(ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                return
            try:
                if ab.isActionModeShowed():
                    ab.setBackgroundDrawable(ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                    return
            except Exception:
                pass
            try:
                if not ab.getOccupyStatusBar():
                    ab.setBackgroundDrawable(ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                    return
            except Exception:
                pass
            eff_cls = target_fragment.getClass().getName()
            is_chat = any(x in eff_cls for x in ("ChatActivity", "TopicsFragment"))
            search_h, tabs_h = self._get_extension_heights(target_fragment)
            is_overlay_target = self._is_overlay_banner_fragment(eff_cls, search_h, tabs_h)
            if not (is_chat or is_overlay_target or self._get_bool(self.SETTINGS_AB_EVERYWHERE, False)):
                self._ab_fragments_to_ignore.add(cls_name)
                ab.setBackgroundDrawable(ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                return
            dialog_id = 0
            if hasattr(target_fragment, "getDialogId"):
                try:
                    dialog_id = target_fragment.getDialogId()
                except Exception:
                    pass
            source_drawable = None
            source_path = ""
            if self._get_bool(self.SETTINGS_AB_USE_AVATARS, False) and is_chat:
                source_drawable = self._get_ab_avatar_drawable(target_fragment)
            if not source_drawable:
                self._ab_loading_hq_dialog_id = 0
                source_path = self._get_str(self.SETTINGS_AB_PATH, "")
                if not source_path or not File(source_path).exists():
                    ab.setBackgroundDrawable(ColorDrawable(Theme.getColor(Theme.key_actionBarDefault)))
                    return
            should_blur = (self._get_bool(self.SETTINGS_AB_BLUR_AVATARS, False) if source_drawable
                           else self._get_bool(self.SETTINGS_AB_BLUR_BANNER, False))
            cache_part = str(dialog_id) if source_drawable else source_path
            blur_percent = self._get_percent(self.SETTINGS_AB_BLUR_INTENSITY, 15) if should_blur else 0
            darken_percent = self._get_percent(self.SETTINGS_AB_DARKEN_INTENSITY, 40)
            ext_h = search_h + tabs_h
            cache_key = (
                f"{eff_cls}_{cache_part}_{ab.getWidth()}x{ab.getHeight()}+{ext_h}_{self._ab_gravity()}"
                f"_blur{blur_percent}_dark{darken_percent}"
            )
            with self._ab_cache_lock:
                cached = self._ab_bitmap_cache.get(cache_key)
            if cached and not cached.isRecycled():
                _cached, _sh, _th = cached, search_h, tabs_h
                run_on_ui_thread(lambda: self._apply_unified_banner(target_fragment, _cached, _sh, _th))
                return
            _search_h, _tabs_h = search_h, tabs_h
            with self._ab_cache_lock:
                if cache_key in self._ab_inflight_keys:
                    return
                self._ab_inflight_keys.add(cache_key)
            run_on_queue(lambda: self._process_ab_bitmap(
                target_fragment, source_drawable, source_path, cache_key, should_blur, _search_h, _tabs_h))
            if (source_drawable and self._get_bool(self.SETTINGS_AB_LOAD_HQ, True)
                    and not should_blur and dialog_id != 0
                    and self._ab_loading_hq_dialog_id != dialog_id):
                self._load_ab_hq_avatar(target_fragment, dialog_id)
        except Exception as e:
            log(f"{_TAG} _update_ab_banner_for_fragment error: {e}\n{traceback.format_exc()}")

    def _apply_ab_drawable(self, fragment, drawable):
        try:
            if not fragment or fragment.isFinishing() or not fragment.getParentActivity():
                return
            cls_name = fragment.getClass().getName()
            if cls_name in self.AB_BLACKLISTED_FRAGMENTS:
                return
            ab = fragment.getActionBar()
            if not ab:
                return
            try:
                ab.setBackgroundColor(Color.TRANSPARENT)
            except Exception:
                pass
            ab.setBackgroundDrawable(drawable)
        except Exception as e:
            log(f"{_TAG} _apply_ab_drawable error: {e}")

    def _process_ab_bitmap(self, fragment, drawable, path, cache_key, should_blur, search_h=0, tabs_h=0):
        try:
            if fragment.isFinishing():
                return
            ab = fragment.getActionBar()
            if not ab:
                return
            tw = ab.getWidth()
            th = ab.getHeight()
            total_h = th + max(0, search_h) + max(0, tabs_h)
            if tw <= 0 or total_h <= 0:
                return
            src_bmp = None
            if drawable:
                src_bmp = self._drawable_to_bitmap(drawable)
                if src_bmp is not None and not src_bmp.isRecycled():
                    src_bmp = self._cap_bitmap_size(
                        src_bmp,
                        max(self.MAX_ACTIONBAR_BITMAP_SIDE, tw * 2),
                        max(self.MAX_ACTIONBAR_BITMAP_HEIGHT, total_h * 2)
                    )
            elif path:
                try:
                    src_bmp = self._decode_bitmap_file(
                        str(path),
                        max(1, tw * 2),
                        max(1, total_h * 2),
                        prefer_rgb565=True
                    )
                except Exception:
                    pass
            if not src_bmp or src_bmp.isRecycled():
                return
            
            if should_blur:
                blur_percent = self._get_percent(self.SETTINGS_AB_BLUR_INTENSITY, 15)
                radius = max(2, min(25, int(blur_percent / 4))) 
                try:
                    Utilities.stackBlurBitmap(src_bmp, radius)
                except Exception:
                    pass
            gravity = self._ab_gravity()
            bw, bh = src_bmp.getWidth(), src_bmp.getHeight()
            scale = max(float(tw) / bw, float(total_h) / bh)
            dx = (tw - bw * scale) / 2.0
            dy = (total_h - bh * scale) / 2.0
            if gravity == Gravity.TOP:
                dy = 0.0
            elif gravity == Gravity.BOTTOM:
                dy = total_h - bh * scale
            m = Matrix()
            m.setScale(scale, scale)
            m.postTranslate(round(dx), round(dy))
            unified_bmp = Bitmap.createBitmap(tw, total_h, Bitmap.Config.ARGB_8888)
            c = Canvas(unified_bmp)
            img_pnt = Paint(Paint.ANTI_ALIAS_FLAG | Paint.FILTER_BITMAP_FLAG | Paint.DITHER_FLAG)
            c.drawBitmap(src_bmp, m, img_pnt)
            if not src_bmp.isRecycled():
                src_bmp.recycle()
            
            darken_percent = self._get_percent(self.SETTINGS_AB_DARKEN_INTENSITY, 40)
            overlay_alpha = int(255 * (darken_percent / 100.0))
            
            scrim_pnt = Paint()
            scrim_pnt.setStyle(Paint.Style.FILL)
            scrim_pnt.setARGB(overlay_alpha, 0, 0, 0)
            c.drawRect(0.0, 0.0, float(tw), float(total_h), scrim_pnt)
            
            with self._ab_cache_lock:
                self._ab_bitmap_cache[cache_key] = unified_bmp
                if cache_key in self._ab_cache_order:
                    self._ab_cache_order = deque(k for k in self._ab_cache_order if k != cache_key)
                self._ab_cache_order.append(cache_key)
                while len(self._ab_cache_order) > self._AB_MAX_BMP_CACHE:
                    evict_key = self._ab_cache_order.popleft()
                    self._ab_bitmap_cache.pop(evict_key, None)
            _sh, _th = search_h, tabs_h
            run_on_ui_thread(lambda: self._apply_unified_banner(fragment, unified_bmp, _sh, _th))
        except Exception as e:
            log(f"{_TAG} _process_ab_bitmap error: {e}\n{traceback.format_exc()}")
        finally:
            try:
                with self._ab_cache_lock:
                    self._ab_inflight_keys.discard(cache_key)
            except Exception:
                pass

    def _load_ab_hq_avatar(self, fragment, dialog_id):
        self._ab_loading_hq_dialog_id = dialog_id
        user = chat = None
        if hasattr(fragment, "getCurrentUser"):
            try:
                user = fragment.getCurrentUser()
            except Exception:
                pass
        if hasattr(fragment, "getCurrentChat"):
            try:
                chat = fragment.getCurrentChat()
            except Exception:
                pass
        image_loc = None
        if user and hasattr(user, "photo") and user.photo:
            image_loc = ImageLocation.getForUser(user, ImageLocation.TYPE_BIG)
        elif chat and hasattr(chat, "photo") and chat.photo:
            image_loc = ImageLocation.getForChat(chat, ImageLocation.TYPE_BIG)
        if not image_loc:
            self._ab_loading_hq_dialog_id = 0
            return
        plugin_ref = self
        if dynamic_proxy is None:
            return
        class _HQDelegate(dynamic_proxy(ImageReceiver.ImageReceiverDelegate)):
            def __init__(self, frag, dlg_id):
                super().__init__()
                self.frag = frag
                self.dlg_id = dlg_id
            def _process(self, drawable):
                if not drawable or self.frag.isFinishing():
                    return
                ab = self.frag.getActionBar()
                if not ab or ab.getWidth() <= 0:
                    return
                search_h, tabs_h = plugin_ref._get_extension_heights(self.frag)
                ext_h = search_h + tabs_h
                should_blur = plugin_ref._get_bool(plugin_ref.SETTINGS_AB_BLUR_AVATARS, False)
                blur_percent = plugin_ref._get_percent(plugin_ref.SETTINGS_AB_BLUR_INTENSITY, 15) if should_blur else 0
                darken_percent = plugin_ref._get_percent(plugin_ref.SETTINGS_AB_DARKEN_INTENSITY, 40)
                ck = (
                    f"{self.dlg_id}_{ab.getWidth()}x{ab.getHeight()}+{ext_h}_{plugin_ref._ab_gravity()}"
                    f"_blur{blur_percent}_dark{darken_percent}"
                )
                plugin_ref._process_ab_bitmap(self.frag, drawable, None, ck, should_blur, search_h, tabs_h)
                if plugin_ref._ab_loading_hq_dialog_id == self.dlg_id:
                    plugin_ref._ab_loading_hq_dialog_id = 0
            def didSetImage(self, receiver, set_val, thumb, memCache):
                if set_val:
                    d = receiver.getDrawable()
                    if d:
                        self._process(d)
            def didSetImageBitmap(self, tag, key, drawable):
                if drawable:
                    self._process(drawable)
        receiver = ImageReceiver(fragment.getFragmentView())
        receiver.setDelegate(_HQDelegate(fragment, dialog_id))
        receiver.setImage(image_loc, "200_200", None, "png", 0, 1)

    def _launch_ab_file_picker(self, view=None):
        if self._ab_is_processing_file:
            BulletinHelper.show_error(self._t("bul_wait"))
            return
        self._ab_is_processing_file = True
        try:
            fragment = get_last_fragment()
            if not fragment:
                raise RuntimeError(self._t("bul_no_screen"))
            activity = fragment.getParentActivity()
            if not activity:
                raise RuntimeError(self._t("bul_no_activity"))
            if self._ab_activity_hook:
                try:
                    self.unhook_method(self._ab_activity_hook)
                except Exception:
                    pass
            IntTYPE = find_class("java.lang.Integer").TYPE
            method = activity.getClass().getDeclaredMethod(
                "onActivityResult", IntTYPE, IntTYPE, find_class("android.content.Intent"))
            self._ab_activity_hook = self.hook_method(method, _ActionBarActivityResultHook(self))
            intent = Intent(Intent.ACTION_GET_CONTENT).setType("image/*")
            activity.startActivityForResult(
                Intent.createChooser(intent, self._t("bul_choose_image")),
                self.AB_FILE_PICKER_CODE
            )
        except Exception as e:
            if self._ab_activity_hook:
                try:
                    self.unhook_method(self._ab_activity_hook)
                except Exception:
                    pass
                self._ab_activity_hook = None
            BulletinHelper.show_error(self._t("bul_picker_err").format(e))
            self._ab_is_processing_file = False

    def _handle_ab_file_picker_result(self, res_code, data):
        if self._ab_activity_hook:
            try:
                self.unhook_method(self._ab_activity_hook)
            except Exception:
                pass
            self._ab_activity_hook = None
        if res_code == Activity.RESULT_OK and data and data.getData():
            run_on_queue(lambda: self._handle_ab_file_uri(data.getData()))
        else:
            self._ab_is_processing_file = False

    def _handle_ab_file_uri(self, uri):
        istream = ostream = None
        try:
            istream = ApplicationLoader.applicationContext.getContentResolver().openInputStream(uri)
            if not istream:
                raise IOError("Не удалось открыть файл.")
            dest = os.path.join(self._plugin_dir, "ab_banner_image.png")
            ostream = FileOutputStream(dest)
            if jbyte is not None:
                buf = jarray(jbyte)(8192)
            else:
                buf = bytearray(8192)
            n = istream.read(buf)
            while n != -1:
                ostream.write(buf, 0, n)
                n = istream.read(buf)
            ostream.flush()
            run_on_ui_thread(lambda: self._on_ab_file_success(dest))
        except Exception as e:
            log(f"{_TAG} _handle_ab_file_uri error: {e}")
            run_on_ui_thread(lambda: BulletinHelper.show_error(self._t("bul_file_err")))
        finally:
            for s in (istream, ostream):
                try:
                    if s:
                        s.close()
                except Exception:
                    pass
            self._ab_is_processing_file = False

    def _on_ab_file_success(self, path: str):
        self.set_setting(self.SETTINGS_AB_PATH, path, reload_settings=True)
        BulletinHelper.show_success(self._t("bul_image_set"))
        self._on_ab_settings_change()

    def _delete_ab_image(self, view=None):
        path = self._get_str(self.SETTINGS_AB_PATH, "")
        if path and os.path.exists(path):
            try:
                os.remove(path)
            except OSError:
                pass
        self.set_setting(self.SETTINGS_AB_PATH, "", reload_settings=True)
        BulletinHelper.show_success(self._t("bul_image_deleted"))
        self._on_ab_settings_change()

    def _show_effect_choice_dialog(self):
        try:
            fragment = get_last_fragment()
            parent = fragment.getParentActivity() if fragment else None
            if parent is None:
                self._notify(self._t("bul_dlg_no_screen"))
                return
            effect_options = [self._t("eff_blur"), self._t("eff_darken"),
                              self._t("eff_blur_darken"), self._t("eff_none")]
            effect_values = ["blur", "darken", "blur_darken", "none"]
            def on_selected(dlg, idx):
                try:
                    self.set_setting(self.SETTINGS_AVATAR_BANNER_EFFECT, effect_values[idx])
                    self._reload_plugin_settings()
                    self._notify(self._t("bul_effect_set").format(effect_options[idx]))
                except Exception:
                    pass
            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_effect_title"))
            b.set_items(effect_options, on_selected)
            b.set_negative_button(self._t("dlg_cancel"), None)
            b.show()
        except Exception:
            pass

    def _menu_set_custom_bg(self, ctx):
        try:
            fragment = ctx.get("fragment")
            if fragment is None:
                self._alert("", self._t("err_no_fragment"))
                return
            self._last_target_fragment_ref = weakref.ref(fragment)
            key = self._get_profile_key_from_fragment(fragment)
            if key is None:
                self._alert("", self._t("err_no_profile"))
                return
            parent = fragment.getParentActivity()
            if parent is None:
                self._alert("", self._t("err_no_activity"))
                return
            builder = AlertDialogBuilder(parent)
            builder.set_title(self._t("dlg_profile_bg_title"))
            def on_top_option(dlg, which):
                if which == 0:
                    self._show_local_banner_menu(parent, key, fragment)
                elif which == 1:
                    try:
                        self.delete_setting(self._k_src(key))
                    except Exception:
                        self._set_profile_source(key, "")
                    self._set_profile_text_mode(key, "")
                    try:
                        self.delete_setting(self._k_effect(key))
                    except Exception:
                        self._set_profile_effect(key, "none")
                    self._drop_bitmap_cache_for_key(key)
                    self._notify(self._t("bul_bg_deleted"))
            builder.set_items([self._t("dlg_local_banner"), self._t("dlg_delete_bg")], on_top_option)
            builder.set_negative_button(self._t("dlg_cancel"), None)
            builder.show()
        except Exception:
            pass

    def _show_local_banner_menu(self, parent, key, fragment):
        try:
            def on_local(dlg, which):
                if which == 0:
                    self._show_url_input_dialog(parent, key)
                elif which == 1:
                    self._launch_file_picker(key)
                elif which == 2:
                    self._set_profile_source(key, f"avatar://{key}")
                    try:
                        self.delete_setting(self._k_effect(key))
                    except Exception:
                        pass
                    self._drop_bitmap_cache_for_key(key)
                    self._invalidate_profile_view(fragment)
                    self._notify(self._t("bul_avatar_set"))
            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_local_banner"))
            b.set_items([self._t("dlg_specify_path"), self._t("dlg_gallery"),
                         self._t("dlg_avatar_banner")], on_local)
            b.set_negative_button(self._t("dlg_back"), None)
            b.show()
        except Exception:
            pass

    def _show_url_input_dialog(self, parent, key):
        try:
            et = EditText(parent)
            et.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_VARIATION_URI)
            current = self._get_profile_source(key) or ""
            if not str(current).startswith("avatar://") and current:
                try:
                    et.setText(current)
                    et.setSelection(len(current))
                except Exception:
                    pass
            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_profile_bg_title"))
            b.set_message(self._t("dlg_profile_key_msg").format(key))
            b.set_view(et)
            b.set_positive_button(self._t("dlg_apply"), lambda dlg, which: self._apply_menu_input_for_key(et, key))
            b.set_negative_button(self._t("dlg_cancel"), None)
            b.show()
        except Exception:
            pass

    def _apply_menu_input_for_key(self, et, key):
        try:
            value = str(et.getText()).strip()
            if not value:
                self._notify(self._t("bul_empty_source"))
                return
            self._set_profile_source(key, value)
            self._set_bool(self.SETTINGS_ENABLE, True)
            self._enable_cached = True
            self._drop_bitmap_cache_for_key(key)
            self._notify(self._t("bul_source_saved"))
            self._invalidate_profile_view(self._safe_get_fragment())
            run_on_ui_thread(lambda: self._prompt_effect_choice(
                key, then=lambda: self._prompt_text_mode_choice(key)))
        except Exception:
            pass

    class _ActivityResultHook(MethodHook):
        def __init__(self, plugin, profile_key):
            self.plugin = plugin
            self.profile_key = profile_key
        def before_hooked_method(self, param):
            try:
                request_code, result_code, data = param.args
                if request_code == self.plugin.FILE_PICKER_REQUEST_CODE:
                    param.setResult(None)
                    if result_code == Activity.RESULT_OK and data is not None:
                        uri = data.getData()
                        if uri is not None:
                            threading.Thread(
                                target=self.plugin._handle_file_uri_for_key,
                                args=(uri, self.profile_key),
                                daemon=True
                            ).start()
                    try:
                        if self.plugin._activity_hook:
                            self.plugin._activity_hook.unhook()
                            self.plugin._activity_hook = None
                    except Exception:
                        pass
            except Exception:
                pass

    def _launch_file_picker(self, profile_key):
        try:
            fragment = self._safe_get_fragment()
            activity = fragment.getParentActivity() if fragment else None
            if not activity:
                BulletinHelper.show("Не удалось получить текущий экран.")
                return
            if self._activity_hook:
                try:
                    self._activity_hook.unhook()
                except Exception:
                    pass
                self._activity_hook = None
            IntTYPE = find_class("java.lang.Integer").TYPE
            method = activity.getClass().getDeclaredMethod("onActivityResult", IntTYPE, IntTYPE, Intent)
            self._activity_hook = self.hook_method(method, self._ActivityResultHook(self, profile_key))
            intent = Intent(Intent.ACTION_GET_CONTENT)
            intent.setType("image/*")
            activity.startActivityForResult(
                Intent.createChooser(intent, "Выберите изображение"),
                self.FILE_PICKER_REQUEST_CODE
            )
        except Exception:
            pass

    def _handle_file_uri_for_key(self, uri, profile_key: str):
        ins = None
        try:
            cr = ApplicationLoader.applicationContext.getContentResolver()
            ins = cr.openInputStream(uri)
            if not ins:
                run_on_ui_thread(lambda: BulletinHelper.show("Не удалось открыть файл"))
                return
            mime_type = cr.getType(uri) or ""
            if "video" in mime_type or "mp4" in mime_type:
                run_on_ui_thread(lambda: BulletinHelper.show("Видео-файлы не поддерживаются."))
                return
            out_path = os.path.join(self._plugin_dir, f"profile_{self._sanitize_key(profile_key)}.jpg")
            self._drop_bitmap_cache_for_key(profile_key)
            try:
                opts = BitmapFactory.Options()
                opts.inJustDecodeBounds = True
                tmp_in = cr.openInputStream(uri)
                BitmapFactory.decodeStream(tmp_in, None, opts)
                tmp_in.close()
                scale = 1
                max_dim = 1280
                if opts.outWidth > max_dim or opts.outHeight > max_dim:
                    scale = int(max(opts.outWidth, opts.outHeight) / max_dim)
                opts.inJustDecodeBounds = False
                opts.inSampleSize = scale
                real_in = cr.openInputStream(uri)
                bmp = BitmapFactory.decodeStream(real_in, None, opts)
                real_in.close()
                if bmp is not None:
                    out = FileOutputStream(out_path)
                    bmp.compress(Bitmap.CompressFormat.JPEG, 85, out)
                    out.close()
                    bmp.recycle()
                else:
                    raise Exception("Failed to decode image")
            except Exception:
                out = FileOutputStream(out_path)
                try:
                    ins_fb = cr.openInputStream(uri)
                    buf = bytearray(8192)
                    while True:
                        r = ins_fb.read(buf)
                        if r == -1:
                            break
                        out.write(buf, 0, r)
                    ins_fb.close()
                finally:
                    out.close()
            self._set_profile_source(profile_key, out_path)
            self._set_bool(self.SETTINGS_ENABLE, True)
            self._enable_cached = True
            def _done_ui():
                self._notify("Изображение сохранено и применено")
                self._invalidate_profile_view(self._safe_get_fragment())
                self._prompt_effect_choice(profile_key, then=lambda: self._prompt_text_mode_choice(profile_key))
            run_on_ui_thread(_done_ui)
        except Exception:
            run_on_ui_thread(lambda: BulletinHelper.show("Ошибка обработки файла"))
        finally:
            if ins is not None:
                try:
                    ins.close()
                except Exception:
                    pass

    def _prompt_text_mode_choice(self, key: str):
        try:
            fragment = self._safe_get_fragment()
            parent = fragment.getParentActivity() if fragment else None
            if parent is None:
                return
            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_text_style_title"))
            b.set_message(self._t("dlg_text_style_msg"))
            b.set_positive_button(self._t("dlg_text_light"), lambda dlg, w: self._apply_text_mode_choice(key, "light"))
            b.set_negative_button(self._t("dlg_text_dark"), lambda dlg, w: self._apply_text_mode_choice(key, "dark"))
            b.set_neutral_button(self._t("dlg_text_default"), lambda dlg, w: self._apply_text_mode_choice(key, ""))
            b.show()
        except Exception:
            pass

    def _apply_text_mode_choice(self, key: str, mode: str):
        try:
            self._set_profile_text_mode(key, mode)
            if not mode:
                self._reset_theme_colors()
            self._invalidate_profile_view(self._safe_get_fragment())
            msgs = {"light": self._t("bul_text_light"),
                    "dark":  self._t("bul_text_dark"),
                    "":      self._t("bul_text_default")}
            self._notify(msgs.get(mode, ""))
        except Exception:
            pass

    def _get_profile_text_mode(self, key: str) -> str:
        try:
            v = self.get_setting(self._k_textmode(key), "")
            s = "" if v is None else str(v).strip().lower()
            return s if s in ("light", "dark") else ""
        except Exception:
            return ""

    def _set_profile_text_mode(self, key: str, value: str):
        try:
            value = (value or "").strip().lower()
            self.set_setting(self._k_textmode(key), value if value in ("light", "dark") else "")
        except Exception:
            pass

    def _k_textmode(self, key: str) -> str:
        return f"{self.TEXTMODE_PREFIX}{key}"

    def _sanitize_effect(self, value: str) -> str:
        s = (value or "").strip().lower()
        return s if s in ("none", "blur", "darken", "blur_darken") else "none"

    def _prompt_effect_choice(self, key: str, then=None):
        try:
            fragment = self._safe_get_fragment()
            parent = fragment.getParentActivity() if fragment else None
            if parent is None:
                if then:
                    then()
                return
            items = [self._t("eff_blur"), self._t("eff_darken"),
                     self._t("eff_blur_darken"), self._t("eff_none")]
            vals = ["blur", "darken", "blur_darken", "none"]
            def _on_item(dlg, idx):
                try:
                    self._apply_effect_choice(key, vals[idx], then)
                except Exception:
                    pass
            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_effect_bg_title"))
            b.set_message(self._t("dlg_effect_bg_msg"))
            b.set_items(items, _on_item)
            b.set_negative_button(self._t("dlg_cancel"), lambda dlg, w: then() if then else None)
            b.show()
        except Exception:
            try:
                if then:
                    then()
            except Exception:
                pass

    def _apply_effect_choice(self, key: str, effect: str, then=None):
        try:
            self._set_profile_effect(key, effect)
            self._drop_bitmap_cache_for_key(key)
            self._invalidate_profile_view(self._safe_get_fragment())
            self._notify(self._t("bul_effect_set").format(self._eff_name(effect)))
        except Exception:
            pass
        finally:
            try:
                if then:
                    then()
            except Exception:
                pass

    def _k_effect(self, key: str) -> str:
        return f"{self.EFFECT_PREFIX}{key}"

    def _get_profile_effect(self, key: str) -> str:
        try:
            src = self._get_profile_source(key)
            is_avatar = str(src).startswith("avatar://")
            v = self.get_setting(self._k_effect(key), None)
            if v is not None and str(v).strip():
                s = self._sanitize_effect(v)
                if is_avatar and s == "none":
                    return self._get_effect_str(self.SETTINGS_AVATAR_BANNER_EFFECT, "darken")
                return s
            if is_avatar:
                return self._get_effect_str(self.SETTINGS_AVATAR_BANNER_EFFECT, "darken")
            return self._get_effect_str(self.SETTINGS_EFFECT_DEFAULT, "blur")
        except Exception:
            return self._get_effect_str(self.SETTINGS_EFFECT_DEFAULT, "blur")

    def _set_profile_effect(self, key: str, value: str):
        try:
            self.set_setting(self._k_effect(key), self._sanitize_effect(value))
        except Exception:
            pass

    def _alloc_int_array(self, n: int):
        if JAVA_ARRAY_AVAILABLE:
            try:
                return jarray('i')(int(n))
            except Exception:
                try:
                    return jarray('I')(int(n))
                except Exception:
                    pass
        try:
            IntTYPE = find_class("java.lang.Integer").TYPE
            Array = find_class("java.lang.reflect.Array")
            return Array.newInstance(IntTYPE, int(n))
        except Exception:
            return None

    def _array_get(self, arr, i: int) -> int:
        try:
            return int(arr[i])
        except Exception:
            try:
                return int(find_class("java.lang.reflect.Array").get(arr, int(i)))
            except Exception:
                return 0

    def _array_set(self, arr, i: int, val: int) -> bool:
        try:
            arr[i] = int(val)
            return True
        except Exception:
            try:
                find_class("java.lang.reflect.Array").set(arr, int(i), int(val))
                return True
            except Exception:
                return False

    def _get_blurred_bitmap_for_key(self, key: str, bmp):
        try:
            if bmp is None or bmp.isRecycled():
                return None
            blur_percent = self._get_percent(self.SETTINGS_BLUR_INTENSITY, 20)
            if self._last_blur_percent != blur_percent:
                for k, (old_bmp, _) in self._bmp_blur_map.items():
                    if old_bmp and not old_bmp.isRecycled():
                        old_bmp.recycle()
                self._bmp_blur_map.clear()
                self._last_blur_percent = blur_percent
            cached = self._bmp_blur_map.get(key)
            if cached:
                cb, cp = cached
                if cp == blur_percent and cb is not None and not cb.isRecycled():
                    return cb
            bw, bh = bmp.getWidth(), bmp.getHeight()
            if bw <= 2 or bh <= 2:
                return bmp
            ratio = max(1, min(100, int(blur_percent))) / 100.0
            max_side = max(bw, bh)
            target_side = min(
                int(max(240, max_side * max(0.28, min(0.60, 0.60 - 0.32 * ratio)))),
                self.MAX_BLUR_BITMAP_SIDE
            )
            scale = min(1.0, float(target_side) / float(max_side))
            sw, sh = max(2, int(bw * scale)), max(2, int(bh * scale))
            small = Bitmap.createScaledBitmap(bmp, sw, sh, True)
            radius = max(2, min(int(5 + ratio * 22), max(2, min(sw, sh) // 2 - 1)))
            passes = 2 if blur_percent < 75 else 3
            rs_radius = min(20.0, float(max(2.0, radius * 0.8)))
            rs_passes = 1 if blur_percent < 85 else 2
            blurred_small = None
            try:
                blurred_small = self._renderscript_blur(small, radius=rs_radius, passes=rs_passes)
            except Exception:
                pass
            if blurred_small is None:
                blurred_small = self._box_blur_bitmap(small, radius=radius, passes=passes)
            if blurred_small is None:
                return bmp
            try:
                blurred = Bitmap.createScaledBitmap(blurred_small, sw, sh, True)
            except Exception:
                blurred = blurred_small
            try:
                if blurred_small is not None and blurred_small != blurred and not blurred_small.isRecycled():
                    blurred_small.recycle()
            except Exception:
                pass
            self._bmp_blur_map[key] = (blurred, blur_percent)
            return blurred
        except Exception:
            return bmp

    def _box_blur_bitmap(self, bmp, radius=10, passes=2):
        try:
            if bmp is None or bmp.isRecycled():
                return bmp
            w, h = bmp.getWidth(), bmp.getHeight()
            if w <= 1 or h <= 1:
                return bmp
            radius = max(1, min(24, int(radius)))
            passes = max(1, min(3, int(passes)))
            work = None
            total = w * h
            if total > self.MAX_BOX_BLUR_PIXELS:
                scale = (self.MAX_BOX_BLUR_PIXELS / float(total)) ** 0.5
                nw, nh = max(2, int(w * scale)), max(2, int(h * scale))
                work = Bitmap.createScaledBitmap(bmp, nw, nh, True)
            else:
                try:
                    work = bmp.copy(Bitmap.Config.ARGB_8888, True)
                except Exception:
                    work = Bitmap.createScaledBitmap(bmp, w, h, True)
            if work is None or work.isRecycled():
                return bmp
            for _ in range(passes):
                try:
                    Utilities.stackBlurBitmap(work, radius)
                except Exception:
                    return bmp
            return work
        except Exception:
            return bmp

    def _watcher_loop(self):
        self._watcher_event.clear()
        in_profile = False
        while not self._watcher_stop:
            try:
                fragment = get_last_fragment()
                now_in_profile = (
                    fragment is not None
                    and fragment.getClass().getName().endswith(".ProfileActivity")
                )
                if now_in_profile:
                    in_profile = True
                    topview = self._find_topview_instance(fragment)
                    if topview is not None:
                        self._ensure_hook_on_topview_instance(topview)
                else:
                    in_profile = False
            except Exception:
                pass

            self._watcher_event.wait(timeout=0.6 if in_profile else 1.5)
            self._watcher_event.clear()

    def _find_topview_instance(self, fragment):
        try:
            cls = fragment.getClass()
            for fname in ("topView", "mTopView"):
                try:
                    f = cls.getDeclaredField(fname)
                    f.setAccessible(True)
                    v = f.get(fragment)
                    if v is not None:
                        return v
                except Exception:
                    pass
        except Exception:
            pass
        try:
            root = fragment.getFragmentView()
            if root is None:
                return None
            stack = [root]
            while stack:
                v = stack.pop()
                try:
                    name = v.getClass().getName()
                    if "ProfileActivity$TopView" in name:
                        return v
                except Exception:
                    pass
                if isinstance(v, ViewGroup):
                    for i in range(v.getChildCount() - 1, -1, -1):
                        try:
                            stack.append(v.getChildAt(i))
                        except Exception:
                            pass
        except Exception:
            pass
        return None

    def _ensure_hook_on_topview_instance(self, topview):
        try:
            cls = topview.getClass()
            clsname = cls.getName()
            if self._hook_on_draw_ref is not None and self._hooked_topview_classname == clsname:
                return
            if self._hook_on_draw_ref is not None:
                try:
                    self.unhook_method(self._hook_on_draw_ref)
                except Exception:
                    pass
                self._hook_on_draw_ref = None
                self._hooked_topview_classname = None
            canvas_param = JCanvas if JCanvas is not None else self._CanvasClass
            if canvas_param is None:
                return
            ondraw = cls.getDeclaredMethod("onDraw", canvas_param)
            ondraw.setAccessible(True)
            self._hook_on_draw_ref = self.hook_method(ondraw, _TopViewOnDrawHook(self))
            self._hooked_topview_classname = clsname
        except Exception:
            pass

    def _load_avatar_bitmap(self, key: str):
        try:
            if key.startswith("uid_"):
                is_user, entity_id = True, int(key[4:])
            elif key.startswith("cid_"):
                is_user, entity_id = False, int(key[4:])
            else:
                return None
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            acc = UserConfig.selectedAccount
            controller = find_class("org.telegram.messenger.MessagesController").getInstance(acc)
            obj = controller.getUser(entity_id) if is_user else controller.getChat(abs(entity_id))
            if obj is None:
                return None
            try:
                BackupImageView = find_class("org.telegram.ui.Components.BackupImageView")
                context = ApplicationLoader.applicationContext
                biv = BackupImageView(context)
                AvatarDrawable2 = find_class("org.telegram.ui.Components.AvatarDrawable")
                av_dr = AvatarDrawable2()
                av_dr.setInfo(acc, obj)
                biv.setForUserOrChat(obj, av_dr)
                ir = biv.getImageReceiver()
                if ir is not None and ir.hasImageSet():
                    bmp = ir.getBitmap()
                    if bmp is not None and not bmp.isRecycled():
                        return bmp
                    bh2 = ir.getBitmapSafe()
                    if bh2 is not None:
                        return bh2.bitmap
            except Exception:
                pass
            try:
                photo = getattr(obj, "photo", None)
                if photo is None:
                    return None
                file_location = getattr(photo, "photo_big", None)
                if file_location is None:
                    return None
                FileLoader = find_class("org.telegram.messenger.FileLoader")
                avatar_file = FileLoader.getInstance(acc).getPathToAttach(file_location, True)
                if avatar_file is not None and avatar_file.exists():
                    opts = BitmapFactory.Options()
                    opts.inJustDecodeBounds = True
                    BitmapFactory.decodeFile(avatar_file.getAbsolutePath(), opts)
                    opts.inSampleSize = self._calc_in_sample_size(
                        opts.outWidth,
                        opts.outHeight,
                        self.MAX_PROFILE_BITMAP_SIDE,
                        self.MAX_PROFILE_BITMAP_SIDE
                    )
                    opts.inJustDecodeBounds = False
                    opts.inPreferredConfig = Bitmap.Config.RGB_565
                    return BitmapFactory.decodeFile(avatar_file.getAbsolutePath(), opts)
            except Exception:
                pass
            return None
        except Exception:
            return None

    def _ensure_bitmap_for_key(self, key: str):
        if not self._enable_cached:
            return None
        src = self._get_profile_source(key)
        if not src:
            return None
        cached = self._bmp_map.get(key)
        if cached is not None and self._src_map.get(key) == src and not cached.isRecycled():
            return cached
        bmp = None
        try:
            if str(src).startswith("avatar://"):
                try:
                    bmp = self._load_avatar_bitmap(key)
                    if bmp is not None:
                        bmp = self._cap_bitmap_size(
                                bmp,
                                self.MAX_PROFILE_BITMAP_SIDE,
                                self.MAX_PROFILE_BITMAP_SIDE
                            )
                        old = self._bmp_map.get(key)
                        if old and not old.isRecycled():
                            old.recycle()
                        self._bmp_map[key] = bmp
                        self._src_map[key] = str(src)
                        self._evict_bmp_cache(key)
                        return bmp
                except Exception:
                    pass
                if key not in self._avatar_polling_keys:
                    self._avatar_polling_keys.add(key)
                    _key = key
                    _src = str(src)
                    def _poll_avatar():
                        for _ in range(300):
                            try:
                                bmp2 = self._load_avatar_bitmap(_key)
                                if bmp2 is not None:
                                    bmp2 = self._cap_bitmap_size(
                                        bmp2,
                                        self.MAX_PROFILE_BITMAP_SIDE,
                                        self.MAX_PROFILE_BITMAP_SIDE
                                    )
                                    old = self._bmp_map.get(_key)
                                    if old and not old.isRecycled():
                                        old.recycle()
                                    self._bmp_map[_key] = bmp2
                                    self._src_map[_key] = _src
                                    self._evict_bmp_cache(_key)
                                    run_on_ui_thread(lambda: self._invalidate_profile_view(None))
                                    break
                            except Exception:
                                pass
                            time.sleep(0.05)
                        try:
                            self._avatar_polling_keys.discard(_key)
                        except Exception:
                            pass
                    threading.Thread(target=_poll_avatar, daemon=True).start()
                global_src = self._get_str(self.SETTINGS_SOURCE_GLOBAL, "").strip()
                if global_src and not global_src.startswith("avatar://"):
                    src = global_src
                else:
                    return None
            if str(src).startswith("file://"):
                try:
                    p = Uri.parse(src).getPath()
                    src = p if p else src[7:]
                except Exception:
                    src = src[7:]
            if str(src).startswith("http://") or str(src).startswith("https://"):
                self._alert("Ошибка", "URL-источники не поддерживаются. Используйте локальный файл или галерею.")
                return None
            elif str(src).startswith("content://"):
                try:
                    stream = ApplicationLoader.applicationContext.getContentResolver().openInputStream(
                        Uri.parse(str(src)))
                    if stream is not None:
                        bis = BufferedInputStream(stream)
                        bmp = BitmapFactory.decodeStream(bis)
                        try:
                            bis.close(); stream.close()
                        except Exception:
                            pass
                except Exception:
                    self._alert("Ошибка чтения URI", "Не удалось открыть контент")
            else:
                bmp = self._decode_bitmap_file(
                    str(src),
                    self.MAX_PROFILE_BITMAP_SIDE,
                    self.MAX_PROFILE_BITMAP_SIDE
                )
            if bmp is None:
                self._alert("Картинка", "Не удалось декодировать изображение")
                return None
            bmp = self._cap_bitmap_size(
                bmp,
                self.MAX_PROFILE_BITMAP_SIDE,
                self.MAX_PROFILE_BITMAP_SIDE
            )
            old = self._bmp_map.get(key)
            if old and not old.isRecycled():
                old.recycle()
            self._bmp_map[key] = bmp
            self._src_map[key] = str(src)
            self._evict_bmp_cache(key)
            return bmp
        except Exception:
            return None

    def _evict_bmp_cache(self, new_key):
        try:
            if new_key in self._bmp_order:
                self._bmp_order = deque(k for k in self._bmp_order if k != new_key)
            self._bmp_order.append(new_key)
            while len(self._bmp_order) > self.MAX_BMP_CACHE:
                oldest = self._bmp_order.popleft()
                old_bmp = self._bmp_map.pop(oldest, None)
                self._bmp_blur_map.pop(oldest, None)
                self._src_map.pop(oldest, None)
                if old_bmp is not None and not old_bmp.isRecycled():
                    old_bmp.recycle()
        except Exception:
            pass

    def _calc_in_sample_size(self, width, height, req_w=0, req_h=0):
        try:
            width = max(1, int(width or 1))
            height = max(1, int(height or 1))
            req_w = max(1, int(req_w or 1))
            req_h = max(1, int(req_h or 1))
            sample = 1
            while (width // (sample * 2)) >= req_w and (height // (sample * 2)) >= req_h:
                sample *= 2
            return max(1, sample)
        except Exception:
            return 1

    def _decode_bitmap_file(self, path, req_w=0, req_h=0, prefer_rgb565=False):
        try:
            if not path:
                return None
            if not File(path).exists():
                return None
            opts = BitmapFactory.Options()
            if req_w or req_h:
                opts.inJustDecodeBounds = True
                BitmapFactory.decodeFile(path, opts)
                opts.inSampleSize = self._calc_in_sample_size(opts.outWidth, opts.outHeight, req_w, req_h)
                opts.inJustDecodeBounds = False
            opts.inPreferredConfig = Bitmap.Config.RGB_565 if prefer_rgb565 else Bitmap.Config.ARGB_8888
            return BitmapFactory.decodeFile(path, opts)
        except Exception:
            return None

    def _cap_bitmap_size(self, bmp, max_w=2048, max_h=2048):
        try:
            w, h = bmp.getWidth(), bmp.getHeight()
            if w <= max_w and h <= max_h:
                return bmp
            scale = min(max_w / float(max(1, w)), max_h / float(max(1, h)))
            nw, nh = max(1, int(w * scale)), max(1, int(h * scale))
            scaled = Bitmap.createScaledBitmap(bmp, nw, nh, True)
            if scaled != bmp:
                if not bmp.isRecycled():
                    bmp.recycle()
            return scaled
        except Exception:
            return bmp

    def _ensure_plugin_dir(self):
        try:
            base_dir = ApplicationLoader.getFilesDirFixed()
            if base_dir:
                plugin_folder = File(base_dir, self.id)
                if not plugin_folder.exists():
                    plugin_folder.mkdirs()
                self._plugin_dir = plugin_folder.getAbsolutePath()
        except Exception:
            pass

    def _get_profile_source(self, key: str) -> str:
        per_str = str(self.get_setting(self._k_src(key), "") or "").strip()
        if per_str == "none":
            return ""
        if per_str:
            return per_str
        if self._get_bool(self.SETTINGS_AVATAR_BANNER_ENABLE, True):
            global_src = self._get_str(self.SETTINGS_SOURCE_GLOBAL, "").strip()
            if global_src and not global_src.startswith("avatar://"):
                return global_src
            return f"avatar://{key}"
        return self._get_str(self.SETTINGS_SOURCE_GLOBAL, "").strip()

    def _set_profile_source(self, key: str, value: str):
        self.set_setting(self._k_src(key), value)

    def _k_src(self, key: str) -> str:
        return f"profileHeader.source.{key}"

    def _sanitize_key(self, key: str) -> str:
        return re.sub(r"[^a-zA-Z0-9_\-\.]", "_", key)

    def _drop_bitmap_cache_for_key(self, key: str):
        try:
            old = self._bmp_map.pop(key, None)
            if old and not old.isRecycled():
                old.recycle()
            old_blur = self._bmp_blur_map.pop(key, None)
            if old_blur and not old_blur[0].isRecycled():
                old_blur[0].recycle()
            self._src_map.pop(key, None)
        except Exception:
            pass

    def _safe_get_fragment(self):
        try:
            if self._last_target_fragment_ref:
                f = self._last_target_fragment_ref()
                if f is not None:
                    return f
        except Exception:
            pass
        try:
            return get_last_fragment()
        except Exception:
            return None

    def _invalidate_profile_view(self, fragment):
        try:
            if fragment is None:
                fragment = get_last_fragment()
            if fragment is not None and fragment.getClass().getName().endswith(".ProfileActivity"):
                view = fragment.getFragmentView()
                if view is not None:
                    run_on_ui_thread(lambda: view.invalidate())
        except Exception:
            pass

    def _get_profile_key_from_fragment(self, fragment) -> str:
        try:
            cls = fragment.getClass()
            try:
                m = cls.getDeclaredMethod("getDialogId")
                m.setAccessible(True)
                did = m.invoke(fragment)
                if did is not None:
                    val = int(did)
                    return f"cid_{-val}" if val < 0 else f"uid_{val}"
            except Exception:
                pass
            for name in ("dialogId", "dialog_id"):
                try:
                    f = cls.getDeclaredField(name)
                    f.setAccessible(True)
                    val = f.get(fragment)
                    if val is not None:
                        val = int(val)
                        return f"cid_{-val}" if val < 0 else f"uid_{val}"
                except Exception:
                    pass
            uid = cid = None
            for name in ("userId", "user_id"):
                try:
                    f = cls.getDeclaredField(name)
                    f.setAccessible(True)
                    uid = int(f.get(fragment))
                    break
                except Exception:
                    pass
            for name in ("chatId", "chat_id"):
                try:
                    f = cls.getDeclaredField(name)
                    f.setAccessible(True)
                    cid = int(f.get(fragment))
                    break
                except Exception:
                    pass
            if cid and cid > 0:
                return f"cid_{cid}"
            if uid and uid > 0:
                return f"uid_{uid}"
        except Exception:
            pass
        return "unknown"

    def _install_theme_hooks(self):
        try:
            ThemeClass = find_class("org.telegram.ui.ActionBar.Theme")
            StringClass = find_class("java.lang.String")
            IntTYPE = find_class("java.lang.Integer").TYPE
            RPClass = None
            try:
                RPClass = find_class("org.telegram.ui.ActionBar.Theme$ResourcesProvider")
            except Exception:
                pass
            self._theme_keys = {}
            for name in ("key_profile_title", "key_avatar_subtitleInProfileBue", "key_avatar_subtitleInProfileBlue"):
                try:
                    f = ThemeClass.getDeclaredField(name)
                    f.setAccessible(True)
                    self._theme_keys[name] = int(f.get(None))
                except Exception:
                    pass
            methods_to_hook = []
            for sig in ((("getColor", (IntTYPE,)), ("int",)),
                        (("getColor", (IntTYPE, bool)), ("int",)),
                        (("getColorOrDefault", (IntTYPE,)), ("int",))):
                try:
                    m_name, m_args = sig[0]
                    methods_to_hook.append(("int", ThemeClass.getDeclaredMethod(m_name, *m_args)))
                except Exception:
                    pass
            if RPClass is not None:
                for sig in (("getColor", (IntTYPE, RPClass)), ("getColorOrDefault", (IntTYPE, RPClass))):
                    try:
                        methods_to_hook.append(("int", ThemeClass.getDeclaredMethod(sig[0], *sig[1])))
                    except Exception:
                        pass
            for sig in (("getColor", (StringClass,)), ("getColorOrDefault", (StringClass,))):
                try:
                    methods_to_hook.append(("str", ThemeClass.getDeclaredMethod(sig[0], *sig[1])))
                except Exception:
                    pass
            if RPClass is not None:
                for sig in (("getColor", (StringClass, RPClass)), ("getColorOrDefault", (StringClass, RPClass))):
                    try:
                        methods_to_hook.append(("str", ThemeClass.getDeclaredMethod(sig[0], *sig[1])))
                    except Exception:
                        pass
            self._theme_hook_refs = []
            for kind, method in methods_to_hook:
                try:
                    Hook = _ThemeGetColorIntHook if kind == "int" else _ThemeGetColorStrHook
                    ref = self.hook_method(method, Hook(self))
                    if ref:
                        self._theme_hook_refs.append(ref)
                except Exception:
                    pass
        except Exception:
            pass

    def _resolve_text_colors(self, mode: str):
        if mode == "light":
            return (Color.WHITE, Color.argb(230, 255, 255, 255))
        return (Color.BLACK, Color.argb(210, 0, 0, 0))

    def _current_profile_textmode(self):
        try:
            fragment = get_last_fragment()
            if fragment is None:
                return ("", None)
        except Exception:
            return ("", None)
        try:
            name = fragment.getClass().getName()
            if "ProfileActivity" not in name:
                return ("", fragment)
            key = self._get_profile_key_from_fragment(fragment)
            return (self._get_profile_text_mode(key), fragment)
        except Exception:
            return ("", fragment)

    def _reset_theme_colors(self):
        try:
            ThemeClass = find_class("org.telegram.ui.ActionBar.Theme")
            StringClass = find_class("java.lang.String")
            IntTYPE = find_class("java.lang.Integer").TYPE
        except Exception:
            return
        key_names = ("profile_title", "avatar_subtitleInProfileBue", "avatar_subtitleInProfileBlue")
        try:
            m = ThemeClass.getDeclaredMethod("removeCustomColors", StringClass)
            m.setAccessible(True)
            for kn in key_names:
                try:
                    m.invoke(None, kn)
                except Exception:
                    pass
        except Exception:
            pass
        try:
            m_set = ThemeClass.getDeclaredMethod("setColor", StringClass, IntTYPE, bool)
            m_set.setAccessible(True)
            m_def = ThemeClass.getDeclaredMethod("getDefaultColor", StringClass)
            m_def.setAccessible(True)
            for kn in key_names:
                try:
                    m_set.invoke(None, kn, int(m_def.invoke(None, kn)), False)
                except Exception:
                    pass
        except Exception:
            pass
        try:
            m_set = ThemeClass.getDeclaredMethod("setColor", IntTYPE, IntTYPE, bool)
            m_set.setAccessible(True)
            m_def = ThemeClass.getDeclaredMethod("getDefaultColor", IntTYPE)
            m_def.setAccessible(True)
            for kn, ikey in self._theme_keys.items():
                if ikey is None:
                    continue
                try:
                    m_set.invoke(None, int(ikey), int(m_def.invoke(None, int(ikey))), False)
                except Exception:
                    pass
        except Exception:
            pass

    def _apply_text_colors(self, topview, outer, mode: str, field_cache: dict = None):
        try:
            if not mode:
                return
            if field_cache is None:
                field_cache = {}
            name_color, sub_color = self._resolve_text_colors(mode)
            use_shadow = (mode == "light")
            shadow_color = Color.argb(110, 0, 0, 0) if use_shadow else Color.argb(0, 0, 0, 0)
            def _set_tv(item, is_primary: bool):
                item.setTextColor(name_color if is_primary else sub_color)
                if use_shadow:
                    radius = 2.0 if is_primary else 1.5
                    dy = 1.0 if is_primary else 0.5
                    item.setShadowLayer(radius, 0.0, dy, shadow_color)
                else:
                    item.setShadowLayer(0.0, 0.0, 0.0, 0)
            def _apply_to_tv_or_array(val, is_primary: bool):
                try:
                    try:
                        _set_tv(val, is_primary)
                        return
                    except Exception:
                        pass
                    length = None
                    try:
                        length = len(val)
                    except Exception:
                        try:
                            length = val.length
                        except Exception:
                            pass
                    JArray = None
                    if length is None:
                        try:
                            JArray = find_class("java.lang.reflect.Array")
                            length = JArray.getLength(val)
                        except Exception:
                            return
                    for i in range(int(length)):
                        try:
                            item = JArray.get(val, i) if JArray is not None else val[i]
                            if item is not None:
                                _set_tv(item, is_primary)
                        except Exception:
                            pass
                except Exception:
                    pass
            for host in (topview, outer):
                if host is None:
                    continue
                cls = host.getClass()
                cls_id = id(cls)
                if cls_id not in field_cache:
                    field_cache[cls_id] = {}
                cf = field_cache[cls_id]
                for fname in ("nameTextView", "titleTextView", "nameView", "titleView"):
                    try:
                        if fname not in cf:
                            f = cls.getDeclaredField(fname)
                            f.setAccessible(True)
                            cf[fname] = f
                        val = cf[fname].get(host) if cf[fname] else None
                        if val is not None:
                            _apply_to_tv_or_array(val, True)
                    except Exception:
                        cf[fname] = None
                for fname in ("onlineTextView", "statusTextView", "subtitleTextView", "subtitleView"):
                    try:
                        if fname not in cf:
                            f = cls.getDeclaredField(fname)
                            f.setAccessible(True)
                            cf[fname] = f
                        val = cf[fname].get(host) if cf[fname] else None
                        if val is not None:
                            _apply_to_tv_or_array(val, False)
                    except Exception:
                        cf[fname] = None
        except Exception:
            pass

    def _ensure_defaults(self):
        try:
            for key, value in [
                (self.SETTINGS_ENABLE, True),
                (self.SETTINGS_SOURCE_GLOBAL, ""),
                (self.SETTINGS_FADE, 90),
                (self.SETTINGS_BLUR_INTENSITY, 20),
                (self.SETTINGS_DARKEN_INTENSITY, 65),
                (self.SETTINGS_EFFECT_DEFAULT, "blur"),
                (self.SETTINGS_AVATAR_BANNER_ENABLE, True),
                (self.SETTINGS_AVATAR_BANNER_EFFECT, "darken"),
                (self.SETTINGS_AB_ENABLE, True),
                (self.SETTINGS_AB_EXTEND_TO_TABS, True),
                (self.SETTINGS_AB_BLUR_INTENSITY, 15),
                (self.SETTINGS_AB_DARKEN_INTENSITY, 40),
                (self.SETTINGS_LANGUAGE, 0),
            ]:
                if self.get_setting(key, _SENTINEL) is _SENTINEL:
                    self.set_setting(key, value)
            self._last_blur_percent = self._get_percent(self.SETTINGS_BLUR_INTENSITY, 20)
        except Exception:
            pass

    def _get_bool(self, key, default=False):
        try:
            v = self.get_setting(key, default)
            if v is default:
                return default
            if isinstance(v, bool):
                return v
            if isinstance(v, int):
                return v != 0
            if isinstance(v, str):
                return v.strip().lower() in ("1", "true", "yes", "on", "y")
            return bool(v)
        except Exception:
            return default

    def _set_bool(self, key, value: bool):
        try:
            self.set_setting(key, bool(value))
        except Exception:
            pass

    def _get_str(self, key, default=""):
        try:
            v = self.get_setting(key, default)
            return "" if v is None else str(v)
        except Exception:
            return default

    def _get_int(self, key, default=0):
        try:
            v = self.get_setting(key, default)
            if v is default:
                return default
            return int(v)
        except Exception:
            return default

    def _set_int(self, key, value: int):
        try:
            self.set_setting(key, int(value))
        except Exception:
            pass

    def _get_percent(self, key, default=50):
        try:
            return max(1, min(100, int(self.get_setting(key, default))))
        except Exception:
            return default

    def _get_effect_str(self, key, default="none"):
        try:
            v = self.get_setting(key, default)
            s = ("" if v is None else str(v)).strip().lower()
            return s if s in ("none", "blur", "darken", "blur_darken") else default
        except Exception:
            return default

    def _notify(self, text):
        def _do():
            try:
                BulletinHelper.show(text)
                return
            except Exception:
                pass
            try:
                Toast = find_class("android.widget.Toast")
                ctx = ApplicationLoader.applicationContext
                Toast.makeText(ctx, str(text), int(getattr(Toast, "LENGTH_SHORT", 0))).show()
            except Exception:
                pass
        run_on_ui_thread(_do)

    def _alert(self, title, message):
        self._notify(f"{title}: {message}")

    def _open_tg_link(self, username: str):
        try:
            ctx = ApplicationLoader.applicationContext
            intent = Intent(Intent.ACTION_VIEW, Uri.parse(f"https://t.me/{username}"))
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            for pkg in ("org.telegram.messenger", "com.exteragram.messenger", "com.radolyn.ayugram"):
                try:
                    intent.setPackage(pkg)
                    ctx.startActivity(intent)
                    return
                except Exception:
                    pass
            intent.setPackage(None)
            ctx.startActivity(intent)
        except Exception as e:
            log(f"{_TAG} open link error: {e}")

    def _reload_plugin_settings(self):
        try:
            PC = find_class("com.exteragram.messenger.plugins.PluginsController")
            inst = PC.getInstance()
            try:
                inst.loadPluginSettings(self.id)
            except Exception:
                inst.loadPluginSettings()
        except Exception:
            pass


    def _t(self, key: str) -> str:
        """Return a localised string for *key* based on SETTINGS_LANGUAGE."""
        try:
            idx = int(self.get_setting(self.SETTINGS_LANGUAGE, 0))
            lang = "en" if idx == 1 else "ru"
        except Exception:
            lang = "ru"
        return _CCB_STRINGS.get(lang, _CCB_STRINGS["ru"]).get(key, key)

    def _eff_name(self, eff: str) -> str:
        _map = {
            "none":       "eff_name_none",
            "blur":       "eff_name_blur",
            "darken":     "eff_name_darken",
            "blur_darken":"eff_name_blur_darken",
        }
        return self._t(_map.get(eff, "eff_name_none"))

    def _on_language_changed(self, idx):
        try:
            self.set_setting(self.SETTINGS_LANGUAGE, int(idx))
            if self._profile_menu_id:
                try:
                    self.remove_menu_item(self._profile_menu_id)
                except Exception:
                    pass
            _pmid = f"{self.id}.profile.custombg"
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.PROFILE_ACTION_MENU,
                text=self._t("menu_custom_bg"),
                icon="msg_gallery",
                on_click=self._menu_set_custom_bg,
                priority=1000,
                item_id=_pmid,
            ))
            self._profile_menu_id = _pmid
            self._cb_add_menu()
            self._reload_plugin_settings()
        except Exception:
            pass
    def _renderscript_blur(self, bmp, radius=12.0, passes=1):
        try:
            RS = find_class("android.renderscript.RenderScript")
            Alloc = find_class("android.renderscript.Allocation")
            SIB = find_class("android.renderscript.ScriptIntrinsicBlur")
            Elem = find_class("android.renderscript.Element")
        except Exception:
            return None
        try:
            rs = RS.create(ApplicationLoader.applicationContext)
        except Exception:
            return None
        out_bmp = None
        try:
            in_bmp = bmp
            r = max(0.1, min(25.0, float(radius)))
            for _ in range(max(1, int(passes))):
                try:
                    inp = Alloc.createFromBitmap(rs, in_bmp)
                    out = Alloc.createTyped(rs, inp.getType())
                    script = SIB.create(rs, Elem.U8_4(rs))
                    script.setRadius(r)
                    script.setInput(inp)
                    script.forEach(out)
                    tmp = Bitmap.createBitmap(in_bmp.getWidth(), in_bmp.getHeight(), Bitmap.Config.ARGB_8888)
                    out.copyTo(tmp)
                    try:
                        script.destroy(); inp.destroy(); out.destroy()
                    except Exception:
                        pass
                    if in_bmp != bmp and in_bmp is not None and not in_bmp.isRecycled():
                        in_bmp.recycle()
                    in_bmp = tmp
                    out_bmp = tmp
                except Exception:
                    out_bmp = None
                break
        finally:
            try:
                rs.destroy()
            except Exception:
                pass
        return out_bmp

    def _on_blur_intensity_changed(self, value):
        try:
            v = max(1, min(100, int(str(value).strip())))
            self.set_setting(self.SETTINGS_BLUR_INTENSITY, v)
            for key, (bmp, _) in list(self._bmp_blur_map.items()):
                if bmp and not bmp.isRecycled():
                    bmp.recycle()
            self._bmp_blur_map.clear()
            self._last_blur_percent = v
            run_on_ui_thread(lambda: self._invalidate_profile_view(None))
        except (ValueError, TypeError):
            pass

    def _on_darken_intensity_changed(self, value):
        try:
            v = max(1, min(100, int(str(value).strip())))
            self.set_setting(self.SETTINGS_DARKEN_INTENSITY, v)
            run_on_ui_thread(lambda: self._invalidate_profile_view(None))
        except (ValueError, TypeError):
            pass

    def _on_avatar_banner_enable_changed(self, new_value):
        try:
            self.set_setting(self.SETTINGS_AVATAR_BANNER_ENABLE, bool(new_value))
            self._reload_plugin_settings()
        except Exception:
            pass

    def _cb_ensure_defaults(self):
        S = object()
        for k, v in [
            (self.SETTINGS_CB_ENABLE, False),
            (self.SETTINGS_CB_AUTO,   True),     
            (self.SETTINGS_CB_EFFECT, "blur_darken"),
            (self.SETTINGS_CB_BLUR,   25),
            (self.SETTINGS_CB_DARKEN, 55),
        ]:
            if self.get_setting(k, S) is S:
                self.set_setting(k, v)

    def _cb_hook_set_user_info(self):
        try:
            PA   = find_class("org.telegram.ui.ProfileActivity")
            User = find_class("org.telegram.tgnet.TLRPC$User")
            BF   = find_class("org.telegram.ui.ActionBar.BaseFragment")


            try:
                m = PA.getDeclaredMethod("setUserInfo", User)
                m.setAccessible(True)
                self._cb_set_user_info_hook_ref = self.hook_method(m, _ChannelProfileReadyHook(self))
            except Exception:
                pass


            for mname in ("onBecomeFullyVisible", "onTransitionAnimationEnd", "onResume"):
                try:
                    refs = self.hook_all_methods(BF, mname, _ChannelProfileReadyHook(self))
                    if refs:
                        self._cb_hooked_cells[f"_bf_{mname}"] = refs
                except Exception:
                    pass


            for mname in ("onPause", "onFragmentDestroy"):
                try:
                    refs = self.hook_all_methods(BF, mname, _ChannelProfilePauseHook(self))
                    if refs:
                        self._cb_hooked_cells[f"_bf_pause_{mname}"] = refs
                except Exception:
                    pass
        except Exception as e:
            log(f"{_CB_TAG} hook_set_user_info error: {e}")

    def _cb_on_profile_ready(self, frag):
        try:
            if frag is None:
                return
            key = self._cb_get_channel_key(frag)
            if not key:
                return
            self._cb_current_channel_key = key
            self._cb_last_frag_ref = weakref.ref(frag)

            def _wait_and_scan(f=frag, k=key):
                for attempt in range(60):
                    try:
                        root = f.getFragmentView()
                        if root is not None:
                            run_on_ui_thread(lambda r=root, fr=f: self._cb_scan_and_hook(r, fr))
                            return
                    except Exception:
                        pass
                    time.sleep(0.05)

            threading.Thread(target=_wait_and_scan, daemon=True).start()
        except Exception:
            pass

    def _cb_watcher(self):
        self._cb_watcher_event.clear()
        _last_key = None
        while not self._cb_watcher_stop:
            try:
                frag = get_last_fragment()
                if frag is not None and "ProfileActivity" in frag.getClass().getName():
                    key = self._cb_get_channel_key(frag)
                    if key:
                        uid = self._cb_extract_uid_from_frag(frag)
                        if uid != 0:
                            self._cb_current_profile_uid = uid
                        self._cb_current_channel_key = key
                        if key != _last_key:
                            _last_key = key
                            self._cb_on_profile_ready(frag)
                else:
                    if _last_key is not None:
                        _last_key = None
                        self._cb_current_channel_key = None
                        self._cb_current_profile_uid = 0
                        self._cb_original_colors.clear()
            except Exception:
                pass

            self._cb_watcher_event.wait(
                timeout=0.7 if _last_key else 1.5
            )
            self._cb_watcher_event.clear()

    def _cb_scan_and_hook(self, root, frag=None):
        try:
            if frag is None:
                frag = get_last_fragment()
            if frag is None:
                return
            lv = self._cb_get_list_view(frag) or self._cb_find_biggest_vg(root)
            if lv is None:
                return
            self._cb_hook_list_layout(lv)
        except Exception as e:
            log(f"{_CB_TAG} scan error: {e}")

    def _cb_get_list_view(self, frag):
        try:
            Array = find_class("java.lang.reflect.Array")
            cls = frag.getClass()
            while cls is not None:
                if "java.lang" in cls.getName():
                    break
                try:
                    fields = cls.getDeclaredFields()
                    for i in range(int(Array.getLength(fields))):
                        try:
                            f = Array.get(fields, i)
                            if any(kw in str(f.getName()).lower()
                                   for kw in ("listview", "recyclerview", "list_view")):
                                f.setAccessible(True)
                                v = f.get(frag)
                                if v is not None and isinstance(v, ViewGroup):
                                    return v
                        except Exception:
                            pass
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    break
        except Exception:
            pass
        return None

    def _cb_find_biggest_vg(self, root):
        best, best_h = None, 0
        try:
            stack = [root]
            while stack:
                v = stack.pop()
                if not isinstance(v, ViewGroup):
                    continue
                try:
                    w = v.getMeasuredWidth()
                    h = v.getMeasuredHeight()
                    if w >= 900 and h > best_h:
                        best, best_h = v, h
                except Exception:
                    pass
                for i in range(v.getChildCount() - 1, -1, -1):
                    try:
                        stack.append(v.getChildAt(i))
                    except Exception:
                        pass
        except Exception:
            pass
        return best

    def _cb_hook_list_layout(self, list_view):
        cn = list_view.getClass().getName()
        key = f"layout_{cn}"
        if key in self._cb_hooked_cells:
            self._cb_scan_children(list_view)
            return

        cls = list_view.getClass()
        while cls is not None:
            cname = cls.getName()
            if "java.lang" in cname:
                break
            try:
                BT = find_class("java.lang.Boolean").TYPE
                IT = find_class("java.lang.Integer").TYPE
                m = cls.getDeclaredMethod("onLayout", BT, IT, IT, IT, IT)
                m.setAccessible(True)
                ref = self.hook_method(m, _ChannelLayoutHook(self))
                if ref:
                    self._cb_hooked_cells[key] = ref
                break
            except Exception:
                pass
            try:
                cls = cls.getSuperclass()
            except Exception:
                break
        self._cb_scan_children(list_view)

    def _cb_scan_children(self, list_view):
        try:
            for i in range(list_view.getChildCount()):
                try:
                    child = list_view.getChildAt(i)
                    cn = child.getClass().getName()
                    w = child.getMeasuredWidth()
                    h = child.getMeasuredHeight()
                    if not self._cb_is_channel_cell(cn, w, h):
                        continue
                    try:
                        child.setBackground(None)
                    except Exception:
                        pass
                    if cn not in self._cb_hooked_cells:
                        self._cb_hook_cell_draw(child, cn)
                    try:
                        child.invalidate()
                    except Exception:
                        pass
                except Exception:
                    pass
        except Exception:
            pass

    def _cb_is_channel_cell(self, cn: str, w: int, h: int) -> bool:
        if any(s in cn for s in ("ProfileChannelCell", "ProfileChannel")):
            return True
        if any(s in cn for s in (
            "AboutLinkCell", "TextDetailCell", "TextInfoPrivacy",
            "ShadowSection", "Button", "HintView", "UndoView",
            "AnimatedStatus", "StarRating", "RLottie", "BackupImage",
        )):
            return False
        if "ListAdapter$" in cn and w >= 1000 and 220 < h < 360:
            return True
        return False

    def _cb_hook_cell_draw(self, cell, cn: str):
        if cn in self._cb_hooked_cells:
            return
        cc = _CBJCanvas if _CBJCanvas is not None else self._cb_CanvasCls
        if cc is None:
            return
        STOP = {
            "android.view.ViewGroup", "android.view.View",
            "android.widget.FrameLayout", "android.widget.LinearLayout",
            "android.widget.RelativeLayout", "java.lang.Object",
        }
        cls = cell.getClass()
        while cls is not None:
            cname = cls.getName()
            if cname in STOP:
                break
            if cname in self._cb_hooked_cells:
                self._cb_hooked_cells[cn] = self._cb_hooked_cells[cname]
                return
            for mn in ("dispatchDraw", "onDraw"):
                try:
                    m = cls.getDeclaredMethod(mn, cc)
                    m.setAccessible(True)
                    ref = self.hook_method(m, _ChannelCellDrawHook(self))
                    if ref:
                        self._cb_hooked_cells[cname] = ref
                        self._cb_hooked_cells[cn] = ref
                    return
                except Exception:
                    pass
            try:
                cls = cls.getSuperclass()
            except Exception:
                break

    def _cb_tint_views_white(self, container):
        try:
            from android.widget import TextView
            stack = [container]
            while stack:
                v = stack.pop()
                try:
                    if isinstance(v, TextView):
                        vid = id(v)
                        if vid not in self._cb_original_colors:
                            try:
                                self._cb_original_colors[vid] = v.getCurrentTextColor()
                            except Exception:
                                self._cb_original_colors[vid] = Color.BLACK
                            v.setTextColor(Color.WHITE)
                            try:

                                v.setShadowLayer(
                                    float(AndroidUtilities.dp(6)),
                                    0.0,
                                    0.0,
                                    Color.argb(255, 0, 0, 0),
                                )
                            except Exception:
                                try:
                                    v.setShadowLayer(6.0, 0.0, 0.0, Color.BLACK)
                                except Exception:
                                    pass
                except Exception:
                    pass
                if isinstance(v, ViewGroup):
                    for i in range(v.getChildCount()):
                        try:
                            stack.append(v.getChildAt(i))
                        except Exception:
                            pass
        except Exception:
            pass

    def _cb_get_channel_key(self, frag) -> str:
        try:
            cls = frag.getClass()
            try:
                m = cls.getDeclaredMethod("getDialogId")
                m.setAccessible(True)
                did = int(float(str(m.invoke(frag))))
                if did < 0 and self._cb_is_channel(-did):
                    return f"ch_{-did}"
            except Exception:
                pass
            for fn in ("dialogId", "dialog_id", "chatId", "chat_id"):
                try:
                    f = cls.getDeclaredField(fn)
                    f.setAccessible(True)
                    val = int(float(str(f.get(frag))))
                    if val < 0 and self._cb_is_channel(-val):
                        return f"ch_{-val}"
                except Exception:
                    pass

            uid = 0
            for fn in ("userId", "user_id"):
                try:
                    f = cls.getDeclaredField(fn)
                    f.setAccessible(True)
                    uid = int(float(str(f.get(frag))))
                    if uid != 0:
                        break
                except Exception:
                    pass
            if uid == 0:
                try:
                    UC = find_class("org.telegram.messenger.UserConfig")
                    uid = int(UC.getInstance(UC.selectedAccount).getClientUserId())
                except Exception:
                    pass
            if uid != 0:
                return self._cb_personal_channel(uid)
        except Exception as e:
            log(f"{_CB_TAG} get_channel_key: {e}")
        return ""

    def _cb_is_channel(self, chat_id: int) -> bool:
        try:
            UC = find_class("org.telegram.messenger.UserConfig")
            MC = find_class("org.telegram.messenger.MessagesController")
            chat = MC.getInstance(UC.selectedAccount).getChat(chat_id)
            if chat is None:
                return False
            if "TL_channel" in chat.getClass().getName():
                try:
                    if chat.megagroup:
                        return False
                except Exception:
                    pass
                return True
        except Exception:
            pass
        return False

    def _cb_personal_channel(self, uid: int) -> str:
        try:
            UC = find_class("org.telegram.messenger.UserConfig")
            MC = find_class("org.telegram.messenger.MessagesController")
            ctrl = MC.getInstance(UC.selectedAccount)
            try:
                uf = ctrl.getUserFull(uid)
                if uf is not None:
                    k = self._cb_chan_from_uf(uf)
                    if k:
                        return k
            except Exception:
                pass
            try:
                f = ctrl.getClass().getDeclaredField("chats")
                f.setAccessible(True)
                cm = f.get(ctrl)
                if cm is not None:
                    Array = find_class("java.lang.reflect.Array")
                    vals = cm.values().toArray()
                    for i in range(int(Array.getLength(vals))):
                        try:
                            c = Array.get(vals, i)
                            if c is None or "TL_channel" not in c.getClass().getName():
                                continue
                            try:
                                if c.megagroup:
                                    continue
                            except Exception:
                                pass
                            try:
                                if c.creator:
                                    return f"ch_{abs(int(float(str(c.id))))}"
                            except Exception:
                                pass
                        except Exception:
                            pass
            except Exception:
                pass
        except Exception:
            pass
        return ""

    def _cb_chan_from_uf(self, uf) -> str:
        try:
            Array = find_class("java.lang.reflect.Array")
            cls = uf.getClass()
            while cls is not None:
                if "java.lang" in cls.getName():
                    break
                try:
                    fields = cls.getDeclaredFields()
                    for i in range(int(Array.getLength(fields))):
                        try:
                            field = Array.get(fields, i)
                            fn = str(field.getName()).lower()
                            if "channel" not in fn and "personal" not in fn:
                                continue
                            field.setAccessible(True)
                            val = field.get(uf)
                            if val is None:
                                continue
                            try:
                                cid = int(float(str(val)))
                                if cid != 0:
                                    return f"ch_{abs(cid)}"
                            except Exception:
                                try:
                                    cid = int(float(str(val.id)))
                                    if cid != 0:
                                        return f"ch_{abs(cid)}"
                                except Exception:
                                    pass
                        except Exception:
                            pass
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    break
        except Exception:
            pass
        return ""

    def _cb_add_menu(self):
        try:
            iid = f"{self.id}.cb.menu"
            if self._cb_profile_menu_id:
                try:
                    self.remove_menu_item(self._cb_profile_menu_id)
                except Exception:
                    pass
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.PROFILE_ACTION_MENU,
                text=self._t("menu_channel_banner"),
                icon="msg_channel",
                on_click=self._cb_on_menu,
                priority=999,
                item_id=iid,
            ))
            self._cb_profile_menu_id = iid
        except Exception:
            pass

    def _cb_on_menu(self, ctx):
        try:
            frag = ctx.get("fragment")
            if frag is None:
                return
            self._cb_last_frag_ref = weakref.ref(frag)
            key = self._cb_get_channel_key(frag)
            if not key:
                BulletinHelper.show_error(self._t("bul_ch_not_found"))
                return
            parent = frag.getParentActivity()
            if not parent:
                return
            src = self._cb_get_raw_src(key)
            has_custom = bool(src and src != "none" and not str(src).startswith("avatar://"))
            opts = [self._t("dlg_ch_gallery"), self._t("dlg_ch_avatar")]
            if has_custom or str(src).startswith("avatar://"):
                opts.append(self._t("dlg_ch_reset"))

            def pick(dlg, idx):
                if idx == 0:
                    self._cb_pick(key)
                elif idx == 1:
                    self._cb_set_src(key, f"avatar://{key}")
                    self._cb_set_bool(self.SETTINGS_CB_ENABLE, True)
                    self._cb_drop_cache(key)
                    try:
                        frag2 = self._cb_frag()
                        if frag2 is not None:
                            view = frag2.getFragmentView()
                            if view is not None:
                                run_on_ui_thread(lambda: view.invalidate())
                    except Exception:
                        pass
                    BulletinHelper.show_success(self._t("bul_ch_avatar"))
                elif idx == 2:
                    self._cb_set_src(key, "none")
                    self._cb_drop_cache(key)
                    try:
                        frag2 = self._cb_frag()
                        if frag2 is not None:
                            view = frag2.getFragmentView()
                            if view is not None:
                                run_on_ui_thread(lambda: view.invalidate())
                    except Exception:
                        pass
                    BulletinHelper.show_success(self._t("bul_ch_reset"))

            b = AlertDialogBuilder(parent)
            b.set_title(self._t("dlg_ch_title"))
            b.set_items(opts, pick)
            b.set_negative_button(self._t("dlg_cancel"), None)
            b.show()
        except Exception as e:
            log(f"{_CB_TAG} menu: {e}")

    def _cb_pick(self, key):
        try:
            frag = self._cb_frag()
            act = frag.getParentActivity() if frag else None
            if not act:
                return
            if self._cb_activity_hook:
                try:
                    self.unhook_method(self._cb_activity_hook)
                except Exception:
                    pass
                self._cb_activity_hook = None
            IT = find_class("java.lang.Integer").TYPE
            m = act.getClass().getDeclaredMethod("onActivityResult", IT, IT, Intent)
            self._cb_activity_hook = self.hook_method(m, _ChannelARHook(self, key))
            intent = Intent(Intent.ACTION_GET_CONTENT)
            intent.setType("image/*")
            act.startActivityForResult(
                Intent.createChooser(intent, self._t("dlg_ch_picker")),
                self.CB_FILE_PICKER_CODE,
            )
        except Exception as e:
            log(f"{_CB_TAG} pick: {e}")

    def _cb_save_uri(self, uri, key):
        try:
            cr = ApplicationLoader.applicationContext.getContentResolver()
            ins = cr.openInputStream(uri)
            if not ins:
                run_on_ui_thread(lambda: BulletinHelper.show_error(self._t("bul_file_open_err")))
                return
            path = os.path.join(self._plugin_dir, f"cb_{self._cb_san(key)}.img")
            out = FileOutputStream(path)
            try:
                if jbyte is not None:
                    buf = jarray(jbyte)(8192)
                else:
                    buf = bytearray(8192)
                n = ins.read(buf)
                while n != -1:
                    out.write(buf, 0, n)
                    n = ins.read(buf)
            finally:
                try:
                    ins.close()
                except Exception:
                    pass
                try:
                    out.close()
                except Exception:
                    pass
            self._cb_set_src(key, path)
            self._cb_set_bool(self.SETTINGS_CB_ENABLE, True)
            self._cb_drop_cache(key)
            run_on_ui_thread(lambda: BulletinHelper.show_success(self._t("bul_ch_set")))
            try:
                frag2 = self._cb_frag()
                if frag2 is not None:
                    view = frag2.getFragmentView()
                    if view is not None:
                        run_on_ui_thread(lambda: view.invalidate())
            except Exception:
                pass
        except Exception as e:
            run_on_ui_thread(lambda: BulletinHelper.show_error(self._t("bul_save_err")))
            log(f"{_CB_TAG} save_uri: {e}")

    def _cb_get_raw_src(self, key) -> str:
        try:
            v = self.get_setting(f"{self.CB_SOURCE_PREFIX}{key}", "")
            return "" if v is None else str(v).strip()
        except Exception:
            return ""

    def _cb_get_src(self, key) -> str:
        raw = self._cb_get_raw_src(key)
        if raw == "none":
            return ""
        if raw:
            return raw
        if self._cb_get_bool(self.SETTINGS_CB_AUTO, True):
            return f"avatar://{key}"
        return ""

    def _cb_set_src(self, key, val):
        try:
            self.set_setting(f"{self.CB_SOURCE_PREFIX}{key}", val)
        except Exception:
            pass

    def _cb_ensure_bitmap(self, key: str):
        if not self._cb_get_bool(self.SETTINGS_CB_ENABLE, False):
            return None
        src = self._cb_get_src(key)
        if not src:
            return None
        cached = self._cb_bmp_map.get(key)
        if cached is not None and self._cb_src_map.get(key) == src:
            try:
                if not cached.isRecycled():
                    return cached
            except Exception:
                return cached

        if key in self._cb_avatar_inflight:
            return None
        bmp = None
        try:
            if src.startswith("avatar://"):
                bmp = self._cb_load_channel_avatar(key)
                if bmp is None:
                    _k = key
                    _src = src
                    self._cb_avatar_inflight.add(_k)
                    def _poll_avatar():
                        try:
                            for _ in range(80):
                                if self._cb_watcher_stop:
                                    break
                                try:
                                    b2 = self._cb_load_channel_avatar(_k)
                                    if b2 is not None:
                                        b2 = self._cap_bitmap_size(
                                            b2,
                                            self._cb_MAX_AVATAR_SIDE,
                                            self._cb_MAX_AVATAR_SIDE,
                                        )
                                        self._cb_bmp_map[_k] = b2
                                        self._cb_src_map[_k] = _src
                                        self._cb_evict_bmp_cache(_k)
                                        try:
                                            frag2 = self._cb_frag()
                                            if frag2 is not None:
                                                view = frag2.getFragmentView()
                                                if view is not None:
                                                    run_on_ui_thread(lambda: view.invalidate())
                                        except Exception:
                                            pass
                                        break
                                except Exception:
                                    pass
                                time.sleep(0.05)
                        finally:
                            self._cb_avatar_inflight.discard(_k)
                    threading.Thread(target=_poll_avatar, daemon=True, name="CB_AvatarPoll").start()
                    return None
            else:
                p = src[7:] if src.startswith("file://") else src
                if File(p).exists():
                    opts = BitmapFactory.Options()
                    opts.inPreferredConfig = Bitmap.Config.ARGB_8888
                    bmp = BitmapFactory.decodeFile(p, opts)
        except Exception:
            return None
        if bmp is None:
            return None
        bmp = self._cap_bitmap_size(
            bmp, self._cb_MAX_AVATAR_SIDE, self._cb_MAX_AVATAR_SIDE
        )
        self._cb_bmp_map[key] = bmp
        self._cb_src_map[key] = src
        self._cb_evict_bmp_cache(key)
        return bmp

    def _cb_evict_bmp_cache(self, new_key: str):
        try:
            self._cb_bmp_order = deque(k for k in self._cb_bmp_order if k != new_key)
            self._cb_bmp_order.append(new_key)
            while len(self._cb_bmp_order) > self._CB_MAX_BMP:
                oldest = self._cb_bmp_order.popleft()
                old_bmp = self._cb_bmp_map.pop(oldest, None)
                self._cb_bmp_blur_map.pop(oldest, None)
                self._cb_src_map.pop(oldest, None)
                try:
                    if old_bmp is not None and not old_bmp.isRecycled():
                        old_bmp.recycle()
                except Exception:
                    pass
        except Exception:
            pass

    def _cb_load_channel_avatar(self, key: str):
        try:
            if not key.startswith("ch_"):
                return None
            chat_id = int(key[3:])
            if self._cb_channel_has_avatar(chat_id):
                return self._load_avatar_bitmap(f"cid_{chat_id}")

            uid = self._cb_current_profile_uid
            if uid != 0:
                bmp = self._load_avatar_bitmap(f"uid_{uid}")
                if bmp is not None:
                    return bmp
            return self._load_avatar_bitmap(f"cid_{chat_id}")
        except Exception:
            return None

    def _cb_channel_has_avatar(self, chat_id: int) -> bool:
        try:
            UC = find_class("org.telegram.messenger.UserConfig")
            MC = find_class("org.telegram.messenger.MessagesController")
            chat = MC.getInstance(UC.selectedAccount).getChat(chat_id)
            if chat is None:
                return False
            photo = getattr(chat, "photo", None)
            if photo is None:
                return False

            cls_name = photo.getClass().getName()
            if "Empty" in cls_name or "chatPhotoEmpty" in cls_name:
                return False

            try:
                ps = getattr(photo, "photo_small", None)
                pb = getattr(photo, "photo_big", None)
                if ps is None and pb is None:
                    return False
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _cb_extract_uid_from_frag(self, frag) -> int:
        try:
            cls = frag.getClass()
            for fn in ("userId", "user_id"):
                try:
                    f = cls.getDeclaredField(fn)
                    f.setAccessible(True)
                    val = int(float(str(f.get(frag))))
                    if val > 0:
                        return val
                except Exception:
                    pass

            try:
                args = frag.getArguments()
                if args is not None:
                    for k in ("user_id", "userId"):
                        try:
                            val = int(args.getLong(k, 0))
                            if val > 0:
                                return val
                        except Exception:
                            pass
            except Exception:
                pass
        except Exception:
            pass
        return 0

    def _cb_get_blurred(self, key: str, bmp):
        pct = self._cb_get_percent(self.SETTINGS_CB_BLUR, 25)
        if self._cb_last_blur_pct != pct:

            for _key, entry in list(self._cb_bmp_blur_map.items()):
                try:
                    cb = entry[0] if isinstance(entry, tuple) else entry
                    if cb is not None and not cb.isRecycled():
                        cb.recycle()
                except Exception:
                    pass
            self._cb_bmp_blur_map.clear()
            self._cb_blur_inflight.clear()
            self._cb_last_blur_pct = pct

        cached = self._cb_bmp_blur_map.get(key)
        if cached:
            cb, cp = cached
            try:
                if cp == pct and cb is not None and not cb.isRecycled():
                    return cb
            except Exception:
                if cp == pct and cb is not None:
                    return cb

        if key in self._cb_blur_inflight:
            return None
        self._cb_blur_inflight.add(key)

        _k = key
        _pct = pct
        _bmp_ref = bmp  

        def _do_blur():
            try:
                work_bmp = _bmp_ref
                if work_bmp.getConfig() != Bitmap.Config.ARGB_8888:
                    try:
                        tmp = work_bmp.copy(Bitmap.Config.ARGB_8888, False)
                        if tmp is not None:
                            work_bmp = tmp
                    except Exception:
                        pass

                r = max(1, int(_pct * 25 / 100))
                passes = 2 if _pct >= 60 else 1
                blurred = self._cb_rs_blur(work_bmp, r, passes)
                if blurred is None:
                    try:
                        work = work_bmp.copy(Bitmap.Config.ARGB_8888, True)
                        if work is not None:
                            Utilities.stackBlurBitmap(work, max(1, min(24, r)))
                            blurred = work
                    except Exception:
                        pass
                if blurred is None:
                    blurred = _bmp_ref
                self._cb_bmp_blur_map[_k] = (blurred, _pct)

                try:
                    frag2 = self._cb_frag()
                    if frag2 is not None:
                        view = frag2.getFragmentView()
                        if view is not None:
                            run_on_ui_thread(lambda: view.invalidate())
                        try:
                            lv = self._cb_get_list_view(frag2)
                            if lv is not None:
                                run_on_ui_thread(lambda: lv.invalidate())
                        except Exception:
                            pass
                except Exception:
                    pass
            except Exception as e:
                log(f"{_CB_TAG} blur error: {e}")
            finally:
                self._cb_blur_inflight.discard(_k)

        threading.Thread(target=_do_blur, daemon=True, name="CB_Blur").start()
        return None

    def _cb_rs_blur(self, bmp, radius=12, passes=1):
        try:
            RS  = find_class("android.renderscript.RenderScript")
            Al  = find_class("android.renderscript.Allocation")
            SIB = find_class("android.renderscript.ScriptIntrinsicBlur")
            El  = find_class("android.renderscript.Element")
            ctx = ApplicationLoader.applicationContext


            MAX_RS_SIDE = 320
            bw, bh = bmp.getWidth(), bmp.getHeight()
            max_side = max(bw, bh)
            if max_side > MAX_RS_SIDE:
                sc = MAX_RS_SIDE / float(max_side)
                sw, sh = max(2, int(bw * sc)), max(2, int(bh * sc))
                try:
                    work = Bitmap.createScaledBitmap(bmp, sw, sh, True)
                except Exception:
                    work = bmp
            else:
                work = bmp

            rs = RS.create(ctx)
            r  = float(min(25, max(1, radius)))
            cur = work
            out = None
            for _ in range(passes):
                try:
                    inp  = Al.createFromBitmap(rs, cur)
                    outp = Al.createTyped(rs, inp.getType())
                    sc_  = SIB.create(rs, El.U8_4(rs))
                    sc_.setRadius(r)
                    sc_.setInput(inp)
                    sc_.forEach(outp)
                    tmp = Bitmap.createBitmap(
                        cur.getWidth(), cur.getHeight(), Bitmap.Config.ARGB_8888
                    )
                    outp.copyTo(tmp)
                    try:
                        sc_.destroy(); inp.destroy(); outp.destroy()
                    except Exception:
                        pass
                    if cur is not bmp and cur is not work and cur is not tmp:
                        try:
                            if not cur.isRecycled():
                                cur.recycle()
                        except Exception:
                            pass
                    cur = tmp
                    out = tmp
                except Exception:
                    break
            try:
                rs.destroy()
            except Exception:
                pass
            if work is not bmp and work is not out:
                try:
                    if not work.isRecycled():
                        work.recycle()
                except Exception:
                    pass
            return out
        except Exception:
            return None

    def _cb_drop_cache(self, key: str):
        try:
            old = self._cb_bmp_map.pop(key, None)
            if old is not None and not old.isRecycled():
                try:
                    old.recycle()
                except Exception:
                    pass
        except Exception:
            pass
        try:
            old_blur = self._cb_bmp_blur_map.pop(key, None)
            if old_blur is not None:
                bmp = old_blur[0] if isinstance(old_blur, tuple) else old_blur
                if bmp is not None and not bmp.isRecycled():
                    try:
                        bmp.recycle()
                    except Exception:
                        pass
        except Exception:
            pass
        self._cb_src_map.pop(key, None)
        self._cb_avatar_inflight.discard(key)
        self._cb_blur_inflight.discard(key)
        try:
            self._cb_bmp_order = deque(k for k in self._cb_bmp_order if k != key)
        except Exception:
            pass

    def _cb_get_bool(self, key, default=False):
        try:
            v = self.get_setting(key, default)
            if isinstance(v, bool): return v
            if isinstance(v, int):  return v != 0
            if isinstance(v, str):  return v.lower() in ("1", "true", "yes", "on")
            return bool(v)
        except Exception:
            return default

    def _cb_set_bool(self, key, val):
        try:
            self.set_setting(key, bool(val))
        except Exception:
            pass

    def _cb_get_str(self, key, default=""):
        try:
            v = self.get_setting(key, default)
            return "" if v is None else str(v)
        except Exception:
            return default

    def _cb_get_percent(self, key, default=50):
        try:
            return max(0, min(100, int(self.get_setting(key, default))))
        except Exception:
            return default

    def _cb_has_blur(self, e):   return e in ("blur", "blur_darken")
    def _cb_has_darken(self, e): return e in ("darken", "blur_darken")
    def _cb_san(self, s):        return re.sub(r"[^a-zA-Z0-9_\-\.]", "_", s)

    def _cb_frag(self):
        try:
            if self._cb_last_frag_ref:
                f = self._cb_last_frag_ref()
                if f:
                    return f
        except Exception:
            pass
        try:
            return get_last_fragment()
        except Exception:
            return None





    def _oldfolders_ensure_defaults(self):
        S = object()
        for k, v in [(self.SETTINGS_OLDF_ENABLE, False)]:
            if self.get_setting(k, S) is S:
                self.set_setting(k, v)

    def _oldfolders_register_topbubbles_hook(self, fragment):
        if self._oldfolders_topbubbles_hook_done:
            return
        try:
            classLoader = fragment.getClass().getClassLoader()
            from java.lang import Class
            topBubblesClass = Class.forName(
                "org.telegram.ui.Components.DialogsActivityTopBubblesFadeView", True, classLoader
            )
            if topBubblesClass is not None:
                Canvas = Class.forName("android.graphics.Canvas", True, classLoader)
                method = topBubblesClass.getDeclaredMethod("onDraw", Canvas)
                method.setAccessible(True)
                ref = self.hook_method(method, _TFTopBubblesFadeViewOnDrawHook(self))
                if ref:
                    self._oldfolders_hooks.append(ref)
                self._oldfolders_topbubbles_hook_done = True
        except Exception as e:
            log(f"{_OLDF_TAG} Error registering TopBubblesFadeView hook: {e}")

    def _oldfolders_apply_now(self, fragment=None):
        try:
            if fragment is None:
                fragment = get_last_fragment()
            if fragment is None or fragment.getClass().getName() != "org.telegram.ui.DialogsActivity":
                return
            view = get_private_field(fragment, "filterTabsView")
            if view is not None:
                try:
                    view.setWillNotDraw(False)
                except Exception:
                    pass
                try:
                    view.setBackground(None)
                except Exception:
                    pass
                try:
                    view.setBackgroundDrawable(None)
                except Exception:
                    pass
                try:
                    view.setBlurredBackground(None)
                except Exception:
                    pass
                view.invalidate()
            topBubblesFadeView = get_private_field(fragment, "topBubblesFadeView")
            if topBubblesFadeView is not None:
                topBubblesFadeView.invalidate()
        except Exception as e:
            log(f"{_OLDF_TAG} Error in apply_now: {e}")

    def _oldfolders_restore_now(self):
        try:
            fragment = get_last_fragment()
            if fragment is None or fragment.getClass().getName() != "org.telegram.ui.DialogsActivity":
                return
            view = get_private_field(fragment, "filterTabsView")
            if view is not None:
                drawable = get_private_field(view, "blurredBackgroundDrawable")
                if drawable is not None:
                    try:
                        view.setBackground(drawable)
                    except Exception:
                        pass
                view.invalidate()
            topBubblesFadeView = get_private_field(fragment, "topBubblesFadeView")
            if topBubblesFadeView is not None:
                try:
                    topBubblesFadeView.setVisibility(View.VISIBLE)
                except Exception:
                    pass
                topBubblesFadeView.invalidate()
        except Exception as e:
            log(f"{_OLDF_TAG} Error in restore_now: {e}")

    def _oldfolders_install_hooks(self):
        if not self._get_bool(self.SETTINGS_OLDF_ENABLE, False):
            return
        try:
            FilterTabsView = find_class("org.telegram.ui.Components.FilterTabsView")
            if FilterTabsView is None:
                log(f"{_OLDF_TAG} FilterTabsView class not found")
                return
            for method_name, hook_cls in [
                ("setBackground",         _TFSetBackgroundHook),
                ("setBackgroundDrawable", _TFSetBackgroundHook),
                ("setBackgroundColor",    _TFSetBackgroundColorHook),
                ("setBlurredBackground",  _TFSetBlurredBackgroundHook),
            ]:
                try:
                    refs = self.hook_all_methods(FilterTabsView, method_name, hook_cls(self))
                    if refs:
                        self._oldfolders_hooks.extend(refs)
                except Exception as e:
                    log(f"{_OLDF_TAG} Hook {method_name} error: {e}")
            try:
                refs = self.hook_all_constructors(FilterTabsView, _TFConstructorHook(self))
                if refs:
                    self._oldfolders_hooks.extend(refs)
            except Exception as e:
                log(f"{_OLDF_TAG} Hook constructors error: {e}")
            try:
                from java.lang import Class
                ActionBarClass = Class.forName("org.telegram.ui.ActionBar.ActionBar", True,
                                               FilterTabsView.getClass().getClassLoader())
                CanvasClass = Class.forName("android.graphics.Canvas", True,
                                            FilterTabsView.getClass().getClassLoader())
                method = ActionBarClass.getDeclaredMethod("dispatchDraw", CanvasClass)
                method.setAccessible(True)
                ref = self.hook_method(method, _TFActionBarDispatchDrawHook(self))
                if ref:
                    self._oldfolders_hooks.append(ref)
            except Exception as e:
                log(f"{_OLDF_TAG} Hook ActionBar.dispatchDraw error: {e}")
            try:
                from java.lang import Class
                DAClass = Class.forName("org.telegram.ui.DialogsActivity", True,
                                        FilterTabsView.getClass().getClassLoader())
                method = DAClass.getDeclaredMethod("onResume")
                method.setAccessible(True)
                ref = self.hook_method(method, _TFDialogsActivityOnResumeHook(self))
                if ref:
                    self._oldfolders_hooks.append(ref)
            except Exception as e:
                log(f"{_OLDF_TAG} Hook DialogsActivity.onResume error: {e}")
            try:
                frag = get_last_fragment()
                if frag is not None and frag.getClass().getName() == "org.telegram.ui.DialogsActivity":
                    self._oldfolders_register_topbubbles_hook(frag)
            except Exception:
                pass
            run_on_ui_thread(self._oldfolders_apply_now)
            log(f"{_OLDF_TAG} Loaded successfully")
        except Exception as e:
            log(f"{_OLDF_TAG} Load error: {e}")

    def _oldfolders_uninstall_hooks(self):
        for ref in self._oldfolders_hooks:
            try:
                ref.unhook()
            except Exception:
                pass
        self._oldfolders_hooks.clear()
        self._oldfolders_topbubbles_hook_done = False
        run_on_ui_thread(self._oldfolders_restore_now)
        log(f"{_OLDF_TAG} Unloaded")

    def _oldfolders_on_enable_changed(self, val):
        self.set_setting(self.SETTINGS_OLDF_ENABLE, bool(val))
        if bool(val):
            self._oldfolders_install_hooks()
        else:
            self._oldfolders_uninstall_hooks()


Plugin = ProfileHeaderImagePlugin