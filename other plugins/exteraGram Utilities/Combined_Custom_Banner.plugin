class _TFConstructorHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            view = param.thisObject
            if view is None:
                return
            view.setWillNotDraw(False)
            view.setBackground(None)
        except Exception as e:
            log(f"{_OLDF_TAG} Error in constructor: {e}")


class _TFActionBarDispatchDrawHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
        self._orig_blurred_map = {}

    def before_hooked_method(self, param):
        try:
            actionBar = param.thisObject
            if actionBar is not None:
                parentFragment = get_private_field(actionBar, "parentFragment")
                if parentFragment is not None and parentFragment.getClass().getName() == "org.telegram.ui.DialogsActivity":
                    orig = get_private_field(actionBar, "blurredBackground")
                    if orig is not None:
                        self._orig_blurred_map[id(param)] = orig
                        set_private_field(actionBar, "blurredBackground", False)
        except Exception as e:
            log(f"{_OLDF_TAG} Error in ActionBar.dispatchDraw before: {e}")

    def after_hooked_method(self, param):
        try:
            actionBar = param.thisObject
            if actionBar is not None:
                pid = id(param)
                if pid in self._orig_blurred_map:
                    orig = self._orig_blurred_map.pop(pid)
                    set_private_field(actionBar, "blurredBackground", orig)
        except Exception:
            pass


class _TFTopBubblesFadeViewOnDrawHook(MethodHook):
    def __init__(self, plugin):
