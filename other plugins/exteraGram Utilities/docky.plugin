        self.PillRegistry = find_class("com.exteragram.messenger.pillstack.core.PillRegistry")
        self.PillInfo = find_class("com.exteragram.messenger.pillstack.core.PillRegistry$PillInfo")
        self.PillCreator = find_class("com.exteragram.messenger.pillstack.core.PillRegistry$PillCreator")
        self.PillStackConfig = find_class("com.exteragram.messenger.pillstack.core.PillStackConfig")
        self.WeatherPill = find_class("com.exteragram.messenger.pillstack.ui.pills.weather.WeatherPill")
        self.ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")

    def create_settings(self):
        return [
            Divider(text=self._settings_home_welcome_text()),
            Switch(
                key="chats_enabled",
                text=self._tr("settings_enable"),
                default=True,
                subtext=self._tr("settings_enable_sub"),
                icon="menu_sidebar",
            ),
            Switch(
                key="docky_widget_enabled",
                text=self._tr("settings_widget"),
                default=False,
                subtext=self._tr("settings_widget_sub"),
                icon="msg_topics_solar",
                on_change=lambda v: self._on_widget_enabled_changed(v),
            ),
            Divider(),
            Text(
                text=self._tr("settings_panel"),
                icon="msg_media_solar",
                create_sub_fragment=self._create_panel_subfragment,
                link_alias="docky_panel_subfragment",
            ),
            Divider(),
            Text(
                text=self._tr("settings_about"),
                icon="msg2_reactions2",
                on_click=self._on_about_click,
            ),
        ]

    def on_plugin_load(self):
        try:
            self.add_on_send_message_hook()
        except Exception as e:
            self._dlog("send hook register fail: {0}".format(e))
        self._hook_chat_activity()
        self._hook_dialogs_activity()
        self._load_telemetry_queue()
        self._telemetry_track_opt_in_transition()
        try:
            if self._stats_opt_in_enabled():
                self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                if not bool(self.get_setting("docky_stats_install_event_sent_v1", False)):
                    self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                    self.set_setting("docky_stats_install_event_sent_v1", True)
        except Exception:
            pass
        self._register_widget_pill()
        self._setup_settings_header_hook()
        self._add_menu_items()
        self._dlog("plugin load hooks={0}".format(len(self._refs)))
        if False:
            run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("plugin_loaded")))
        try:
            if not bool(self.get_setting("docky_welcome_shown_v1", False)):
                self.set_setting("docky_welcome_shown_v1", True)
                AndroidUtilities.runOnUIThread(lambda: self._show_about_sheet(None), 700)
                self._dlog("first install welcome scheduled")
        except Exception as e:
            self._dlog("first install welcome fail: {0}".format(e))

    def on_plugin_unload(self):
        for r in list(self._refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._refs = []
        try:
            run_on_ui_thread(self._detach_sidebar)
        except Exception:
            pass
        try:
            run_on_ui_thread(self._detach_dialogs_widget)
        except Exception:
            pass
        try:
            if self._chat_menu_item:
                self.remove_menu_item(self._chat_menu_item)
                self._chat_menu_item = None
        except Exception:
            pass
        try:
            if self._settings_header_hook is not None:
                self.unhook_method(self._settings_header_hook)
                self._settings_header_hook = None
        except Exception:
            pass
        self._dlog("plugin unload")

    def _enabled(self):
        try:
            return bool(self.get_setting("chats_enabled", True))
        except Exception:
            return True

    def _debug_enabled(self):
        try:
            return bool(self.get_setting("chats_debug_logs", True))
        except Exception:
            return True

    def _stats_opt_in_enabled(self):
        try:
            v = self.get_setting("docky_stats_opt_in", None)
            if v is None:
                return False
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            return bool(v)
        except Exception:
            return False

    def _on_stats_opt_in_changed(self, _v=None):
        try:
            self._telemetry_track_opt_in_transition()
            if self._stats_opt_in_enabled():
                self._telemetry_flush_async()
        except Exception:
            pass

    def _telemetry_track_opt_in_transition(self):
        try:
            cur = bool(self._stats_opt_in_enabled())
            prev_raw = self.get_setting("docky_stats_opt_in_prev_state_v1", None)
            if prev_raw is None:
                self.set_setting("docky_stats_opt_in_prev_state_v1", bool(cur))
                if cur:
                    self._telemetry_queue_event("opt_in_enabled", feature="", count=1, force_flush=True)
                    self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                    if not bool(self.get_setting("docky_stats_install_event_sent_v1", False)):
                        self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                        self.set_setting("docky_stats_install_event_sent_v1", True)
                return
            prev = bool(prev_raw)
            if cur and (not prev):
                self._telemetry_queue_event("opt_in_enabled", feature="", count=1, force_flush=True)
                self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                if not bool(self.get_setting("docky_stats_install_event_sent_v1", False)):
                    self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                    self.set_setting("docky_stats_install_event_sent_v1", True)
            self.set_setting("docky_stats_opt_in_prev_state_v1", bool(cur))
        except Exception:
            pass

    def _load_telemetry_queue(self):
        try:
            raw = self.get_setting("docky_stats_queue_v1", "[]")
            arr = raw if isinstance(raw, list) else self._safe_json_loads(raw, [])
            self._telemetry_queue = arr if isinstance(arr, list) else []
        except Exception:
            self._telemetry_queue = []

    def _save_telemetry_queue(self):
        try:
            self.set_setting("docky_stats_queue_v1", json.dumps(list(self._telemetry_queue or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _telemetry_install_id_get(self):
        try:
            if self._telemetry_install_id:
                return str(self._telemetry_install_id)
            cached = str(self.get_setting("docky_stats_install_id", "") or "").strip()
            if cached:
                self._telemetry_install_id = cached
                return cached
            sid = "dky_{0:x}{1:x}".format(int(time.time() * 1000), random.randint(0, 0xFFFFFF))
            self.set_setting("docky_stats_install_id", sid)
            self._telemetry_install_id = sid
            return sid
        except Exception:
            return "dky_unknown"

    def _telemetry_app_snapshot(self):
        out = {
            "app_id": "unknown",
            "app_variant": "unknown",
            "app_version": "unknown",
            "plugin_version": str(__version__),
            "mode": "common",
        }
        try:
            from org.telegram.messenger import ApplicationLoader
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return out
            pkg = str(ctx.getPackageName() or "unknown").strip() or "unknown"
            out["app_id"] = pkg
            l = pkg.lower()
            if "ayu" in l:
                out["app_variant"] = "ayugram"
            elif "extera" in l:
                out["app_variant"] = "exteragram"
            else:
                out["app_variant"] = "telegram"
            try:
                pm = ctx.getPackageManager()
                pi = pm.getPackageInfo(pkg, 0)
                out["app_version"] = str(getattr(pi, "versionName", "") or getattr(pi, "versionCode", "unknown"))
            except Exception:
                pass
        except Exception:
            pass
        return out

    def _telemetry_queue_event(self, event_name, feature=None, count=1, force_flush=False):
        try:
            if not self._stats_opt_in_enabled():
                return
            name = str(event_name or "").strip()
            if not name:
                return
            ev = {
                "ts": int(time.time()),
                "event": name,
                "feature": str(feature or "").strip(),
                "count": int(count or 1),
            }
            with self._telemetry_lock:
                q = list(self._telemetry_queue or [])
                q.append(ev)
                if len(q) > 220:
                    q = q[-220:]
                self._telemetry_queue = q
            self._save_telemetry_queue()
            now_ts = int(time.time())
            if force_flush or (now_ts - int(self._telemetry_last_flush_ts or 0) >= 25):
                self._telemetry_flush_async()
        except Exception:
            pass

    def _telemetry_flush_async(self):
        try:
            if not self._stats_opt_in_enabled():
                return
            with self._telemetry_lock:
                if self._telemetry_sending:
                    return
                queue = list(self._telemetry_queue or [])
                if not queue:
                    return
                self._telemetry_sending = True
            install_id = self._telemetry_install_id_get()
            app = self._telemetry_app_snapshot()
            payload = {
                "plugin": "docky",
                "install_id": install_id,
                "sent_at": int(time.time()),
                "app": app,
                "events": queue[:120],
            }

            def _worker():
                ok = False
                try:
                    ok = self._telemetry_post(payload)
                except Exception:
                    ok = False
                try:
                    with self._telemetry_lock:
                        if ok:
                            cur = list(self._telemetry_queue or [])
                            drop = min(len(cur), len(payload.get("events", []) or []))
                            self._telemetry_queue = cur[drop:]
                            self._telemetry_last_flush_ts = int(time.time())
                            self._save_telemetry_queue()
                        self._telemetry_sending = False
                except Exception:
                    try:
                        self._telemetry_sending = False
                    except Exception:
                        pass

            self._run_bg(_worker, "telemetry_flush")
        except Exception:
            try:
                self._telemetry_sending = False
            except Exception:
                pass

    def _telemetry_post(self, payload):
        try:
            raw = json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
            headers = {
                "Content-Type": "application/json",
                "Cache-Control": "no-cache",
            }
            token = str(GEEKSTATS_INGEST_TOKEN or "").strip()
            if token:
                headers["X-Ingest-Token"] = token
            code, _ = self._http_request(GEEKSTATS_INGEST_URL, method="POST", headers=headers, data=raw, timeout=6)
            return bool(code) and 200 <= int(code) < 300
        except Exception as e:
            self._dlog("stats post fail: {0}".format(e))
            return False

    def _preview_enabled(self):
        try:
            return bool(self.get_setting("chats_preview", False))
        except Exception:
            return False

    def _widget_enabled(self):
        try:
            return bool(self.get_setting("docky_widget_enabled", False))
        except Exception:
            return False

    def _compact_enabled(self):
        try:
            return bool(self.get_setting("chats_compact", False))
        except Exception:
            return False

    def _docky_invert_side_enabled(self):
        try:
            return bool(self.get_setting("docky_invert_side", False))
        except Exception:
            return False

    def _chat_nav_mode(self):
        try:
            v = int(self.get_setting("docky_chat_nav_mode", 0) or 0)
        except Exception:
            v = 0
        if v < 0:
            v = 0
        if v > 1:
            v = 1
        return int(v)

    def _chat_nav_control_enabled(self):
        return int(self._chat_nav_mode()) == 0

    def _chat_nav_swipe_enabled(self):
        return int(self._chat_nav_mode()) == 1

    def _show_private_enabled(self):
        try:
            return bool(self.get_setting("docky_show_private", False))
        except Exception:
            return False

    def _show_channels_enabled(self):
        try:
            return bool(self.get_setting("docky_show_channels", False))
        except Exception:
            return False

    def _show_topics_enabled(self):
        try:
            return bool(self.get_setting("docky_show_topics", False))
        except Exception:
            return False

    def _show_bots_enabled(self):
        try:
            return bool(self.get_setting("docky_show_bots", False))
        except Exception:
            return False

    def _show_secret_enabled(self):
        try:
            return bool(self.get_setting("docky_show_secret", False))
        except Exception:
            return False

    def _is_preview_fragment(self, fragment):
        try:
            if fragment is None:
                return False
            try:
                return bool(fragment.isInPreviewMode())
            except Exception:
                pass
            cls = fragment.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField("inPreviewMode")
                    fld.setAccessible(True)
                    return bool(fld.getBoolean(fragment))
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
        except Exception:
            pass
        return False

    def _open_plugin_settings(self):
        try:
            if not self._action_debounce_ok("open_plugin_settings", 500):
                return False
            fragment = get_last_fragment()
            if fragment is None:
                return False
            controller = PluginsController.getInstance()
            plugin = controller.plugins.get(self.id) if controller else None
            if plugin is None:
                return False
            fragment.presentFragment(PluginSettingsActivity(plugin))
            try:
                self._telemetry_queue_event("feature_use", feature="settings_open", count=1, force_flush=False)
            except Exception:
                pass
            return True
        except Exception as e:
            self._dlog("open settings fail: {0}".format(e))
            return False

    def _on_widget_enabled_changed(self, value):
        try:
            self.set_setting("docky_widget_enabled", bool(value))
        except Exception:
            pass
        try:
            self._ensure_widget_pill_enabled()
        except Exception as e:
            self._dlog("widget switch update fail: {0}".format(e))

    def _find_dialogs_fragment(self):
        try:
            try:
                frag = self._dialogs_fragment
                if frag is not None and "DialogsActivity" in str(frag.getClass().getName()):
                    root = self._get_fragment_view(frag)
                    if root is not None:
                        return frag
            except Exception:
                pass
            candidates = []
            try:
                frag = get_last_fragment()
                if frag is not None:
                    candidates.append(frag)
            except Exception:
                pass
            try:
                LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
                if LaunchActivity is not None:
                    frag = LaunchActivity.getSafeLastFragment()
                    if frag is not None:
                        candidates.append(frag)
            except Exception:
                pass
            for frag in candidates:
                try:
                    if frag is not None and "DialogsActivity" in str(frag.getClass().getName()):
                        return frag
                except Exception:
                    pass
            for frag in candidates:
                try:
                    pf = frag.getClass().getSuperclass().getDeclaredField("parentLayout")
                    pf.setAccessible(True)
                    parent_layout = pf.get(frag)
                except Exception:
                    parent_layout = None
                if parent_layout is None:
                    continue
                stack = _pf(parent_layout, "fragmentsStack", None)
                if stack is None:
                    continue
                try:
                    for i in range(int(stack.size()) - 1, -1, -1):
                        item = stack.get(i)
                        if item is not None and "DialogsActivity" in str(item.getClass().getName()):
                            return item
                except Exception:
                    pass
            return None
        except Exception:
            return None

    def _register_widget_pill(self):
        try:
            if not self.PillRegistry or not self.PillInfo or not self.PillCreator or not self.WeatherPill:
                return
            plugin = self
            TAG_KEY = jint(0x444F434B)

            class DockyCreator(dynamic_proxy(self.PillCreator)):
                def create(self_obj, context, resourcesProvider):
                    try:
                        pill = plugin.WeatherPill(context, resourcesProvider)
                        pill.setTag(TAG_KEY, jint(DOCKY_WIDGET_PILL_ID))
                        tv = _pf(pill, "textView")
                        if tv is not None:
                            tv.setText(plugin._tr("widget_title"))
                        iv = _pf(pill, "iconView")
                        if iv is not None:
                            try:
                                ctx = pill.getContext()
                                res = ctx.getResources()
                                icon_res = res.getIdentifier("menu_sidebar", "drawable", ctx.getPackageName())
                                if icon_res != 0:
                                    iv.setImageResource(icon_res)
                            except Exception:
                                pass
                        return pill
                    except Exception as e:
                        plugin._dlog("widget create fail: {0}".format(e))
                        return None

            ctx = self.ApplicationLoader.applicationContext if self.ApplicationLoader is not None else None
            if ctx is None:
                return
            res = ctx.getResources()
            icon_res = res.getIdentifier("menu_sidebar", "drawable", ctx.getPackageName())
            pill_info = self.PillInfo(
                jint(DOCKY_WIDGET_PILL_ID),
                "Docky",
                jint(icon_res),
                jint(-11565578),
                jint(-13276952),
                DockyCreator()
            )
            try:
                self.PillRegistry.register(pill_info)
            except Exception:
                pass

            class GetIdHook(MethodHook):
                def before_hooked_method(self_obj, param):
                    try:
                        tag = param.thisObject.getTag(TAG_KEY)
                        if tag and int(tag) == DOCKY_WIDGET_PILL_ID:
                            param.setResult(jint(DOCKY_WIDGET_PILL_ID))
                    except Exception:
                        pass

            class InteractionHook(MethodHook):
                def before_hooked_method(self_obj, param):
                    try:
                        tag = param.thisObject.getTag(TAG_KEY)
                        if not tag or int(tag) != DOCKY_WIDGET_PILL_ID:
                            return
                        method_name = param.method.getName()
                        if method_name == "onPillClicked":
                            plugin._toggle_dialogs_widget_from_pill()
                            param.setResult(None)
                        elif method_name == "onPillLongClicked":
                            plugin._open_plugin_settings()
                            param.setResult(True)
                        elif method_name in ["onUpdateData", "setData"]:
                            tv = _pf(param.thisObject, "textView")
                            if tv is not None:
                                tv.setText(plugin._tr("widget_title"))
                            param.setResult(None)
                    except Exception:
                        pass

            self.hook_all_methods(self.WeatherPill, "getPillId", GetIdHook())
            self.hook_all_methods(self.WeatherPill, "onPillClicked", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "onPillLongClicked", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "onUpdateData", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "setData", InteractionHook())
            self._ensure_widget_pill_enabled()
        except Exception as e:
            self._dlog("register widget pill fail: {0}".format(e))

    def _ensure_widget_pill_enabled(self):
        try:
            if self.PillStackConfig is None:
                return
            active = self.PillStackConfig.activePills
            enabled = bool(self._widget_enabled())
            found_index = -1
            for i in range(active.size()):
                if int(active.get(i)) == int(DOCKY_WIDGET_PILL_ID):
                    found_index = i
                    break
            if enabled and found_index < 0:
                active.add(jint(DOCKY_WIDGET_PILL_ID))
                self.PillStackConfig.savePillsLayout()
                run_on_ui_thread(self.PillStackConfig.notifySettingsChanged)
            elif (not enabled) and found_index >= 0:
                active.remove(found_index)
                self.PillStackConfig.savePillsLayout()
                run_on_ui_thread(self.PillStackConfig.notifySettingsChanged)
                run_on_ui_thread(self._detach_dialogs_widget)
        except Exception as e:
            self._dlog("ensure widget pill fail: {0}".format(e))

    def _add_menu_items(self):
        try:
            if self._chat_menu_item:
                try:
                    self.remove_menu_item(self._chat_menu_item)
                except Exception:
                    pass
                self._chat_menu_item = None
            self._chat_menu_item = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Docky",
                    icon="menu_sidebar",
                    priority=5,
                    on_click=lambda _ctx: run_on_ui_thread(self._open_plugin_settings),
                )
            )
        except Exception as e:
            self._dlog("add menu item fail: {0}".format(e))

    def _is_our_settings_activity(self, activity):
        try:
            if activity is None:
                return False
            p = None
            try:
                p = _pf(activity, "plugin", None)
            except Exception:
                p = None
            if not p:
                return False
            pid = ""
            try:
                pid = str(p.getId() or "").strip().lower()
            except Exception:
                pid = ""
            if pid == str(__id__).strip().lower():
                return True
            try:
                nm = str(p.getName() or "").strip().lower()
            except Exception:
                nm = ""
            return nm == str(__name__).strip().lower()
        except Exception:
            return False

    def _download_asset(self, url, out_path):
        try:
            if not url or not out_path:
                return False
            os.makedirs(os.path.dirname(out_path), exist_ok=True)
            _code, data = self._http_request(url, headers={}, timeout=12)
            if not data:
                return False
            with open(out_path, "wb") as f:
                f.write(data)
            return True
        except Exception as e:
            self._dlog("asset download fail {0}: {1}".format(str(url), e))
            return False

    def _ensure_settings_header_assets(self):
        try:
            now = int(time.time())
            if int(now - int(self._assets_last_sync_ts or 0)) < 300:
                return
            if bool(self._assets_syncing):
                return
            self._assets_last_sync_ts = now
            self._assets_syncing = True

            def _worker():
                try:
                    bust = str(int(time.time() / 60))
                    targets = [
                        ("{0}?v={1}".format(DOCKY_HEADER_IMAGE_URL_DARK, bust), HEADER_IMAGE_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(DOCKY_HEADER_IMAGE_URL_LIGHT, bust), HEADER_IMAGE_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(SUPPORT_ICON_URL, bust), SUPPORT_ICON_CACHE_FILE),
                        ("{0}?v={1}".format(SPONSOR_ICON_URL, bust), SPONSOR_ICON_CACHE_FILE),
                        ("{0}?v={1}".format(SPONSOR_BANNER_URL, bust), SPONSOR_BANNER_CACHE_FILE),
                        ("{0}?v={1}".format(TOP_ICON_URL_DARK, bust), TOP_ICON_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(TOP_ICON_URL_LIGHT, bust), TOP_ICON_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(EXTENDED_ICON_URL_DARK, bust), EXTENDED_ICON_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(EXTENDED_ICON_URL_LIGHT, bust), EXTENDED_ICON_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(ABOUT_AVATAR_URL, bust), ABOUT_AVATAR_CACHE_FILE),
                    ]
                    for url, path in targets:
                        try:
                            self._download_asset(url, path)
                        except Exception:
                            pass
                    for url, path in (
                        ("{0}?v={1}".format(NAV_UP_ICON_URL, bust), NAV_UP_ICON_CACHE_FILE),
                        ("{0}?v={1}".format(NAV_DOWN_ICON_URL, bust), NAV_DOWN_ICON_CACHE_FILE),
                    ):
                        try:
                            self._download_asset(url, path)
                        except Exception:
                            pass
                finally:
                    self._assets_syncing = False

            try:
                self._fetch_async(_worker, on_done=None, label="assets_sync")
            except Exception:
                self._assets_syncing = False
        except Exception:
            self._assets_syncing = False

    def _dismiss_keyboard_focus(self, ctx):
        try:
            from android.view.inputmethod import InputMethodManager
            imm = ctx.getSystemService(ctx.INPUT_METHOD_SERVICE)
            if imm is not None:
                view = None
                try:
                    frag = get_last_fragment()
                    view = frag.getParentActivity().getCurrentFocus() if frag and frag.getParentActivity() else None
                except Exception:
                    view = None
                if view is not None:
                    imm.hideSoftInputFromWindow(view.getWindowToken(), 0)
        except Exception:
            pass

    def _get_user_first_name(self):
        try:
            UC = jclass("org.telegram.messenger.UserConfig")
            account = int(getattr(UC, "selectedAccount", 0))
            uc = UC.getInstance(account) if UC is not None else None
            user = uc.getCurrentUser() if uc is not None else None
            if user is not None:
                name = str(getattr(user, "first_name", "") or "").strip()
                if name:
                    return name
        except Exception:
            pass
        return "User"

    def _open_dotted_chat(self):
        try:
            if not self._action_debounce_ok("open_dotted_chat", 400):
                return
            get_messages_controller().openByUserName("DottedChat", get_last_fragment(), 1)
        except Exception:
            try:
                self.open_url("https://t.me/DottedChat")
            except Exception:
                pass

    def _open_extera_channel(self):
        try:
            if not self._action_debounce_ok("open_extera_channel", 400):
                return
            get_messages_controller().openByUserName("exteraDevPlugins", get_last_fragment(), 1)
        except Exception:
            try:
                self.open_url("https://t.me/exteraDevPlugins")
            except Exception:
                pass

    def _open_docky_docs(self):
        try:
            if not self._action_debounce_ok("open_docky_docs", 400):
                return
            get_messages_controller().openByUserName("ApplePlugins", get_last_fragment(), 1)
        except Exception:
            try:
                self.open_url("https://t.me/ApplePlugins")
            except Exception:
                pass

    def _open_github_sponsors(self):
        try:
            if not self._action_debounce_ok("open_github_sponsors", 400):
                return
            Browser = find_class("org.telegram.messenger.browser.Browser")
            ctx = None
            try:
                act = getattr(self, "_settings_activity_ref", None)
                if act is not None and hasattr(act, "getContext"):
                    ctx = act.getContext()
            except Exception:
                ctx = None
            if ctx is None:
                try:
                    frag = get_last_fragment()
                    ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
                except Exception:
                    ctx = None
            if Browser is not None and ctx is not None:
                Browser.openUrl(ctx, GITHUB_SPONSOR_URL)
                return
            self.open_url(GITHUB_SPONSOR_URL)
        except Exception:
            pass

    def _open_username(self, username):
        try:
            if not self._action_debounce_ok("open_supporter_username", 250):
                return
            uname = str(username or "").strip().lstrip("@")
            if not uname:
                return
            get_messages_controller().openByUserName(uname, get_last_fragment(), 1)
        except Exception:
            try:
                self.open_url("https://t.me/{0}".format(str(username or "").strip().lstrip("@")))
            except Exception:
                pass

    def _open_supporters_subfragment(self):
        try:
            if not self._action_debounce_ok("open_supporters_subfragment", 500):
                return
            self._ensure_settings_header_assets()
            self._refresh_supporters_async()
            fragment = get_last_fragment()
            controller = PluginsController.getInstance()
            plugin = controller.plugins.get(self.id) if controller else None
            if not plugin or fragment is None:
                return
            self._supporters_open_pending = True
            fragment.presentFragment(PluginSettingsActivity(plugin))
        except Exception as e:
            self._dlog("open supporters subfragment fail: {0}".format(e))

    def _read_json_file(self, path):
        return self._read_json_disk(path, None)

    def _supporters_payload(self):
        try:
            candidates = [
                SUPPORTERS_CACHE_FILE,
                os.path.join(os.getcwd(), SUPPORTERS_PLUGIN_FILE),
                os.path.join(os.path.dirname(os.path.abspath(__file__)), SUPPORTERS_PLUGIN_FILE),
            ]
            seen = set()
            for p in candidates:
                try:
                    if not p or p in seen or not os.path.isfile(p):
                        continue
                    seen.add(p)
                except Exception:
                    continue
                data = self._read_json_file(p)
                if isinstance(data, (dict, list)):
                    return data
        except Exception:
            pass
        return {"supporters": []}

    def _supporters_list(self):
        try:
            data = self._supporters_payload()
            arr = []
            if isinstance(data, list):
                arr = data
            elif isinstance(data, dict):
                for key in ("supporters", "items", "data"):
                    if isinstance(data.get(key), list):
                        arr = data.get(key, [])
                        break
            out = []
            for it in arr:
                if not isinstance(it, dict):
                    continue
                name = str(it.get("name", "") or "").strip()
                username = str(it.get("username", "") or "").strip()
                avatar = str(it.get("avatar", "") or "").strip()
                if not name and not username and not avatar:
                    continue
                out.append({"name": name, "username": username, "avatar": avatar})
            return out
        except Exception:
            return []

    def _refresh_supporters_async(self, on_done=None):
        try:
            if bool(self._supporters_refreshing):
                return
            self._supporters_refreshing = True

            def _finish():
                try:
                    self._supporters_refreshing = False
                except Exception:
                    pass
                try:
                    if callable(on_done):
                        run_on_ui_thread(on_done)
                except Exception:
                    pass
                try:
                    self._refresh_supporters_subfragment_view()
                except Exception:
                    pass

            def _worker():
                try:
                    os.makedirs(_CACHE_DIR, exist_ok=True)
                    _code, raw = self._http_request(
                        "{0}?v={1}".format(SUPPORTERS_URL, str(int(time.time() / 60))),
                        headers={"Cache-Control": "no-cache", "Pragma": "no-cache"},
                        timeout=8,
                        decode="utf-8-sig",
                    )
                    data = json.loads(str(raw or ""))
                    if isinstance(data, (dict, list)):
                        with open(SUPPORTERS_CACHE_FILE, "w", encoding="utf-8") as f:
                            json.dump(data, f, ensure_ascii=False, indent=2)
                except Exception as e:
                    self._dlog("supporters refresh fail: {0}".format(e))
                finally:
                    _finish()

            try:
                self._fetch_async(_worker, on_done=None, label="supporters_refresh")
            except Exception:
                self._supporters_refreshing = False
        except Exception:
            self._supporters_refreshing = False

    def _create_supporters_subfragment(self, parent_view=None):
        try:
            return [Header(text=self._tr("supporters_title"))]
        except Exception:
            return [Header(text="Supporters")]

    def _start_supporter_card_anim(self, view, idx):
        try:
            from android.animation import ValueAnimator
            dist = float(AndroidUtilities.dp(4))
            anim = ValueAnimator.ofFloat(0.0, 1.0)
            anim.setDuration(int(1900 + (idx % 3) * 180 + (idx // 3) * 60))
            anim.setRepeatCount(-1)
            anim.setRepeatMode(ValueAnimator.REVERSE)
            try:
                anim.setStartDelay(int((idx % 3) * 110))
            except Exception:
                pass

            class _Upd(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                def onAnimationUpdate(self_obj, va):
                    try:
                        t = float(va.getAnimatedValue() or 0.0)
                        view.setTranslationY(float((0.5 - t) * dist))
                    except Exception:
                        pass

            anim.addUpdateListener(_Upd())
            anim.start()
            self._supporters_anim_refs.append(anim)
        except Exception:
            pass

    def _render_supporters_grid(self, ctx, grid):
        try:
            from android.widget import LinearLayout, TextView
            from android.view import Gravity, View
            from android.util import TypedValue
            if grid is None:
                return
            try:
                grid.removeAllViews()
            except Exception:
                pass
            self._supporters_anim_refs = []
            items = self._supporters_list()
            if not items:
                empty = TextView(ctx)
                empty.setText(self._tr("supporters_empty"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                empty.setGravity(Gravity.CENTER)
                try:
                    empty.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                except Exception:
                    pass
                lp_empty = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_empty.topMargin = AndroidUtilities.dp(18)
                grid.addView(empty, lp_empty)
                return

            try:
                c_name = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                c_name = 0xFFFFFFFF
            try:
                c_user = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                c_user = 0xB3FFFFFF

            for start in range(0, len(items), 3):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.TOP)
                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(12 if start > 0 else 4)
                grid.addView(row, lp_row)

                chunk = items[start:start + 3]
                for rel_idx in range(3):
                    cell = LinearLayout(ctx)
                    cell.setOrientation(LinearLayout.VERTICAL)
                    cell.setGravity(Gravity.TOP | Gravity.CENTER_HORIZONTAL)
                    cell.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
                    lp_cell = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    if rel_idx < 2:
                        lp_cell.rightMargin = AndroidUtilities.dp(2)
                    row.addView(cell, lp_cell)
                    if rel_idx >= len(chunk):
                        cell.setVisibility(View.INVISIBLE)
                        continue

                    item = chunk[rel_idx]
                    avatar = BackupImageView(ctx)
                    avatar.setRoundRadius(AndroidUtilities.dp(18))
                    try:
                        avatar.setAspectFit(False)
                    except Exception:
                        pass
                    try:
                        url = str(item.get("avatar", "") or "").strip()
                        if url:
                            avatar.setImage(url, "120_120", None)
                        else:
                            avatar.setImageDrawable(AvatarDrawable())
                    except Exception:
                        try:
                            avatar.setImageDrawable(AvatarDrawable())
                        except Exception:
                            pass
                    cell.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

                    name = TextView(ctx)
                    name.setText(str(item.get("name", "") or "").strip() or "Supporter")
                    name.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                    try:
                        name.setTextColor(c_name)
                    except Exception:
                        pass
                    name.setGravity(Gravity.CENTER)
                    name.setSingleLine(True)
                    try:
                        name.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                    except Exception:
                        pass
                    lp_name = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_name.topMargin = AndroidUtilities.dp(8)
                    cell.addView(name, lp_name)

                    user = TextView(ctx)
                    user.setText(str(item.get("username", "") or "").strip())
                    user.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    user.setGravity(Gravity.CENTER)
                    user.setSingleLine(True)
                    try:
                        user.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                    except Exception:
                        pass
                    try:
                        user.setTextColor(c_user)
                        user.setAlpha(0.82)
                    except Exception:
                        pass
                    lp_user = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_user.topMargin = AndroidUtilities.dp(2)
                    cell.addView(user, lp_user)

                    uname = str(item.get("username", "") or "").strip()
                    if uname:
                        cell.setClickable(True)
                        cell.setFocusable(True)
                        cell.setOnClickListener(self._click_listener(lambda _v=None, u=uname: self._open_username(u), key="supporter_card_open", min_interval_ms=250))
                    self._start_supporter_card_anim(cell, start + rel_idx)
        except Exception as e:
            self._dlog("render supporters grid fail: {0}".format(e))

    def _build_supporters_subfragment_view(self, ctx):
        try:
            from android.widget import LinearLayout, TextView, ImageView
            from android.view import Gravity
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.graphics import BitmapFactory
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(18))
            root.setBackgroundColor(0x00000000)

            banner = ImageView(ctx)
            try:
                banner.setScaleType(ImageView.ScaleType.CENTER_CROP)
            except Exception:
                pass
            try:
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                bg.setColor(0x00000000)
                banner.setBackground(bg)
                banner.setClipToOutline(True)
            except Exception:
                pass
            try:
                if os.path.exists(SPONSOR_BANNER_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(SPONSOR_BANNER_CACHE_FILE)
                    if bmp is not None:
                        banner.setImageBitmap(bmp)
            except Exception:
                pass
            root.addView(banner, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(124)))

            divider_row = LinearLayout(ctx)
            divider_row.setOrientation(LinearLayout.HORIZONTAL)
            divider_row.setGravity(Gravity.CENTER_VERTICAL)
            lp_div = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_div.topMargin = AndroidUtilities.dp(14)
            root.addView(divider_row, lp_div)

            try:
                base_line = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
                line_color = int((base_line & 0x00FFFFFF) | (0x66 << 24))
                text_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                line_color = 0x66FFFFFF
                text_color = 0xB3FFFFFF
            line_l = ImageView(ctx)
            line_l.setBackgroundColor(line_color)
            divider_row.addView(line_l, LinearLayout.LayoutParams(0, AndroidUtilities.dp(1), 1.0))
            thanks = TextView(ctx)
            thanks.setText(self._tr("supporters_thanks"))
            thanks.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            thanks.setGravity(Gravity.CENTER)
            try:
                thanks.setTextColor(text_color)
                thanks.setAlpha(0.88)
            except Exception:
                pass
            lp_thanks = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_thanks.leftMargin = AndroidUtilities.dp(10)
            lp_thanks.rightMargin = AndroidUtilities.dp(10)
            divider_row.addView(thanks, lp_thanks)
            line_r = ImageView(ctx)
            line_r.setBackgroundColor(line_color)
            divider_row.addView(line_r, LinearLayout.LayoutParams(0, AndroidUtilities.dp(1), 1.0))

            sponsor_wrap = LinearLayout(ctx)
            sponsor_wrap.setOrientation(LinearLayout.HORIZONTAL)
            sponsor_wrap.setGravity(Gravity.CENTER_HORIZONTAL)
            lp_sw = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sw.topMargin = AndroidUtilities.dp(14)
            root.addView(sponsor_wrap, lp_sw)
            sponsor_btn = TextView(ctx)
            sponsor_btn.setText(self._tr("supporters_github_button"))
            sponsor_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            sponsor_btn.setGravity(Gravity.CENTER)
            sponsor_btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            try:
                c_primary = int(Theme.getColor(Theme.key_featuredStickers_addButton))
                c_primary_text = int(Theme.getColor(Theme.key_featuredStickers_buttonText))
            except Exception:
                c_primary = 0xFF4E9BFF
                c_primary_text = 0xFFFFFFFF
            try:
                bg_btn = GradientDrawable()
                bg_btn.setCornerRadius(float(AndroidUtilities.dp(14)))
                bg_btn.setColor(c_primary)
                sponsor_btn.setBackground(bg_btn)
                sponsor_btn.setTextColor(c_primary_text)
            except Exception:
                pass
            sponsor_btn.setClickable(True)
            sponsor_btn.setFocusable(True)
            sponsor_btn.setOnClickListener(self._click_listener(lambda _v=None: self._open_github_sponsors(), key="github_sponsors_button", min_interval_ms=400))
            sponsor_wrap.addView(sponsor_btn)

            grid = LinearLayout(ctx)
            grid.setOrientation(LinearLayout.VERTICAL)
            lp_grid = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_grid.topMargin = AndroidUtilities.dp(14)
            root.addView(grid, lp_grid)
            self._supporters_view_ref = root
            self._supporters_grid_ref = grid
            self._render_supporters_grid(ctx, grid)
            return root
        except Exception as e:
            self._dlog("build supporters subfragment fail: {0}".format(e))
            return None

    def _refresh_supporters_subfragment_view(self):
        try:
            grid = getattr(self, "_supporters_grid_ref", None)
            root = getattr(self, "_supporters_view_ref", None)
            if grid is None or root is None:
                return
            ctx = root.getContext() if hasattr(root, "getContext") else None
            if ctx is None:
                return
            run_on_ui_thread(lambda: self._render_supporters_grid(ctx, grid))
        except Exception:
            pass

    def _inject_supporters_subfragment(self, activity, items):
        try:
            ctx = activity.getContext() if hasattr(activity, "getContext") else None
            if ctx is None:
                return
            UItem = find_class("org.telegram.ui.Components.UItem")
            if UItem is None:
                return
            try:
                items.clear()
            except Exception:
                pass
            self._ensure_settings_header_assets()
            view = self._build_supporters_subfragment_view(ctx)
            if view is None:
                return
            it = UItem.asCustom(view)
            try:
                it.object2 = "__docky_supporters_subfragment__"
            except Exception:
                pass
            try:
                it.setTransparent(True)
            except Exception:
                pass
            items.add(it)
            self._refresh_supporters_async()
        except Exception as e:
            self._dlog("inject supporters subfragment fail: {0}".format(e))

    def _build_settings_header_view(self, ctx):
        try:
            from java import dynamic_proxy
            from android.widget import LinearLayout, TextView, FrameLayout, ImageView
            from android.view import View, Gravity, ViewOutlineProvider
            from android.graphics.drawable import GradientDrawable
            from android.graphics import BitmapFactory, Color

