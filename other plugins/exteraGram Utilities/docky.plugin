            lp_sponsor = FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.TOP | Gravity.END)
            lp_sponsor.topMargin = AndroidUtilities.dp(10)
            lp_sponsor.rightMargin = AndroidUtilities.dp(44)
            hero.addView(sponsor_icon, lp_sponsor)

            row = LinearLayout(ctx)
