def _pf(obj, name, default=None):
    try:
        cls = obj.getClass()
        while cls is not None:
            try:
                f = cls.getDeclaredField(name)
                f.setAccessible(True)
                return f.get(obj)
            except Exception:
                cls = cls.getSuperclass()
    except Exception:
        pass
    return default


class _ChatCreateHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            self.plugin._dlog("hook createView")
            run_on_ui_thread(lambda: self.plugin._on_chat_fragment_ready(param.thisObject))
        except Exception as e:
