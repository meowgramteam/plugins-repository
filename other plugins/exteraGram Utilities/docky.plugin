    def _open_nav_button_color_picker(self, _=None):
        try:
            frag = get_last_fragment()
            if not frag:
                return
            act = frag.getParentActivity()
            if not act:
                return
            try:
                resources_provider = frag.getResourceProvider()
            except Exception:
                resources_provider = None
            initial_hex = str(self.get_setting("docky_nav_button_color", "#{:06X}".format(int(self._nav_button_color()) & 0xFFFFFF)) or "#{:06X}".format(int(self._nav_button_color()) & 0xFFFFFF))
            try:
                initial_color = Color.parseColor(initial_hex)
            except Exception:
                initial_color = int(self._nav_button_color())

            try:
                from org.telegram.ui.Components.Paint import ColorPickerBottomSheet
                from androidx.core.util import Consumer
                PipetteDelegate = find_class("org.telegram.ui.Components.Paint.ColorPickerBottomSheet$PipetteDelegate")
                PipetteDelegateProxy = dynamic_proxy(PipetteDelegate)

                class _PipetteDelegate(PipetteDelegateProxy):
                    def __init__(self):
                        super().__init__()
                    def onStartColorPipette(self): return None
                    def onStopColorPipette(self): return None
                    def getContainerView(self): return None
                    def getSnapshotDrawingView(self): return None
                    def onDrawImageOverCanvas(self, bitmap, canvas): return None
                    def isPipetteVisible(self): return False
                    def isPipetteAvailable(self): return False
                    def onColorSelected(self, color): return None

                ConsumerProxy = dynamic_proxy(Consumer)

                class _ColorConsumer(ConsumerProxy):
                    def __init__(self, plugin):
                        super().__init__()
                        self._plugin = plugin
                    def accept(self, color):
                        try:
                            color_int = int(color)
                        except Exception:
                            return
                        self._plugin.set_setting("docky_nav_button_color", "#{:06X}".format(color_int & 0xFFFFFF))
                        self._plugin._refresh_nav_panels_only()
                        BulletinHelper.show_success(self._plugin._tr("settings_nav_button_color_done"))

                self._docky_nav_button_picker_pipette = _PipetteDelegate()
                self._docky_nav_button_picker_consumer = _ColorConsumer(self)

                sheet = ColorPickerBottomSheet(act, resources_provider)
                try:
                    sheet.setCanceledOnTouchOutside(False)
                except Exception:
                    pass
                sheet.setPipetteDelegate(self._docky_nav_button_picker_pipette)
                sheet.setColor(initial_color)
                sheet.setColorListener(self._docky_nav_button_picker_consumer)
                return run_on_ui_thread(sheet.show)
            except Exception:
                pass

            from org.telegram.ui.Components import ColorPicker
            ColorPickerDelegate = find_class("org.telegram.ui.Components.ColorPicker$ColorPickerDelegate")
            selected = {"color": initial_color}
            ColorPickerDelegateProxy = dynamic_proxy(ColorPickerDelegate)

            class _PickerDelegate(ColorPickerDelegateProxy):
                def __init__(self):
                    super().__init__()
                def setColor(self, color, num, applyNow):
                    try:
                        selected["color"] = int(color)
                    except Exception:
                        pass

            self._docky_nav_button_picker_delegate = _PickerDelegate()
            picker = ColorPicker(act, False, self._docky_nav_button_picker_delegate)
            try:
                picker.setColor(initial_color, 0)
            except Exception:
                pass

            def _save_and_close(b, _w):
                try:
                    b.dismiss()
                except Exception:
                    pass
                self.set_setting("docky_nav_button_color", "#{:06X}".format(int(selected["color"]) & 0xFFFFFF))
                self._refresh_nav_panels_only()
                BulletinHelper.show_success(self._tr("settings_nav_button_color_done"))

            builder = AlertDialogBuilder(act).set_title(self._tr("settings_nav_button_color")).set_view(picker)
            builder.set_positive_button("OK", _save_and_close)
            builder.set_negative_button(self._tr("cancel"), lambda b, _w: b.dismiss() if b else None)
            builder.show()
        except Exception as e:
            self._dlog("nav button color picker fail: {0}".format(e))

    def _build_row(self, ctx, target, selected=False):
        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.VERTICAL)
        row.setGravity(Gravity.CENTER_HORIZONTAL)
        lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(8)
        row.setLayoutParams(lp)
        try:
            if bool(selected):
                sb = GradientDrawable()
                sb.setShape(GradientDrawable.RECTANGLE)
                sb.setCornerRadius(float(AndroidUtilities.dp(10)))
                try:
                    ac = int(Theme.getColor(Theme.key_dialogTextBlue2))
                except Exception:
                    ac = 0xFF66B4FF
                sb.setColor(self._i32((0x2B << 24) | (ac & 0x00FFFFFF)))
                row.setBackground(sb)
                row.setPadding(AndroidUtilities.dp(2), AndroidUtilities.dp(4), AndroidUtilities.dp(2), AndroidUtilities.dp(4))
        except Exception:
            pass

        av = BackupImageView(ctx)
        av.setRoundRadius(AndroidUtilities.dp(18))
        alp = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
        row.addView(av, alp)
        try:
            kind, obj = self._resolve_target_peer(target)
            if obj is not None:
                av.setForUserOrChat(obj, AvatarDrawable(obj))
                self._dlog("row avatar set ok kind={0} target={1}".format(str(kind), str(target)))
            else:
                av.setImageDrawable(AvatarDrawable())
                self._dlog("row avatar fallback target={0}".format(str(target)))
        except Exception:
            self._dlog("row avatar exception target={0}".format(str(target)))
            pass

        if not self._compact_enabled():
            name = TextView(ctx)
            resolved_name = self._display_name_target(target)
            self._dlog("row name resolved={0} target={1}".format(str(resolved_name), str(target)))
            name.setText(resolved_name)
            name.setTextSize(11.0)
            name.setMaxLines(2)
            name.setGravity(Gravity.CENTER)
            try:
                if bool(selected):
                    name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlue2))))
                else:
                    name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlack))))
            except Exception:
                name.setTextColor(self._i32(0xFFD6E2F5))
            nlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nlp.topMargin = AndroidUtilities.dp(4)
            row.addView(name, nlp)

        row.setOnClickListener(self._click_listener(lambda _v=None: self._open_target(target)))

        OnLongClickListener = jclass("android.view.View$OnLongClickListener")

        class _Long(dynamic_proxy(OnLongClickListener)):
            def onLongClick(self_obj, _v):
                try:
                    self._remove_favorite(target)
                    return True
                except Exception:
                    return False

        row.setOnLongClickListener(_Long())
        return row

    def _build_add_button(self, ctx):
        add = TextView(ctx)
        add.setText("+")
        add.setGravity(Gravity.CENTER)
        add.setTextSize(20.0)
        try:
            add.setTextColor(self._i32(0xFFF2F6FF))
        except Exception:
            pass
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.OVAL)
        bg.setColor(self._i32(0xFFFF214E))
        add.setBackground(bg)
        lp = LinearLayout.LayoutParams(AndroidUtilities.dp(38), AndroidUtilities.dp(38))
        lp.gravity = Gravity.CENTER_HORIZONTAL
        lp.topMargin = AndroidUtilities.dp(10)
        add.setLayoutParams(lp)
        add.setOnClickListener(self._click_listener(lambda _v=None: self._open_add_dialog(), key="docky_add_button", min_interval_ms=400))

        OnLongClickListener = jclass("android.view.View$OnLongClickListener")

        class _Long(dynamic_proxy(OnLongClickListener)):
            def onLongClick(self_obj, _v):
                try:
                    t = self._current_target(self._current_fragment)
                    if not t:
                        BulletinHelper.show_info("No active chat id")
                        return True
                    self._add_favorite_target(t)
                    return True
                except Exception:
                    return False

        add.setOnLongClickListener(_Long())
        return add

    def _build_nav_button(self, ctx, text, on_click):
        b = TextView(ctx)
        b.setText(str(text))
        b.setTextSize(12.0)
        b.setGravity(Gravity.CENTER)
        b.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(4), AndroidUtilities.dp(8), AndroidUtilities.dp(4))
        try:
            b.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlue2))))
        except Exception:
            b.setTextColor(self._i32(0xFF66B4FF))
        b.setOnClickListener(self._click_listener(on_click))
        return b

    def _setup_icon_settings_hold(self, holder, child=None):
        try:
            if holder is None:
                return
            OnTouchListener = jclass("android.view.View$OnTouchListener")
            MotionEvent = jclass("android.view.MotionEvent")

            class _Touch(dynamic_proxy(OnTouchListener)):
                def onTouch(self_obj, _v, ev):
                    try:
                        act = int(ev.getActionMasked())
                        if act == int(MotionEvent.ACTION_DOWN):
                            self._icon_settings_fired = False
                            if self._icon_settings_runnable is None:
                                self._icon_settings_runnable = lambda: self._fire_icon_settings_hold()
                            try:
                                AndroidUtilities.cancelRunOnUIThread(self._icon_settings_runnable)
                            except Exception:
                                pass
                            AndroidUtilities.runOnUIThread(self._icon_settings_runnable, 2000)
                            return False
                        if act == int(MotionEvent.ACTION_UP) or act == int(MotionEvent.ACTION_CANCEL):
                            try:
                                if self._icon_settings_runnable is not None:
                                    AndroidUtilities.cancelRunOnUIThread(self._icon_settings_runnable)
                            except Exception:
                                pass
                            fired = bool(self._icon_settings_fired)
                            self._icon_settings_fired = False
                            return bool(fired)
                        return False
                    except Exception:
                        return False

            touch = _Touch()
            holder.setOnTouchListener(touch)
            try:
                if child is not None:
                    child.setOnTouchListener(touch)
            except Exception:
                pass
        except Exception as e:
            self._dlog("icon hold setup fail: {0}".format(e))

    def _fire_icon_settings_hold(self):
        try:
            self._icon_settings_fired = True
            self._open_plugin_settings()
        except Exception as e:
            self._dlog("icon hold fire fail: {0}".format(e))

    def _create_row_holder(self, ctx):
        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.VERTICAL)
        row.setGravity(Gravity.CENTER_HORIZONTAL)
        lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(8)
        row.setLayoutParams(lp)

        av = BackupImageView(ctx)
        av.setRoundRadius(AndroidUtilities.dp(18))
        alp = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
        row.addView(av, alp)

        name = None
        if not self._compact_enabled():
            name = TextView(ctx)
            name.setTextSize(11.0)
            name.setMaxLines(2)
            name.setGravity(Gravity.CENTER)
            nlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nlp.topMargin = AndroidUtilities.dp(4)
            row.addView(name, nlp)

        holder = {"root": row, "avatar": av, "name": name, "target": None, "target_key": "", "selected": False}
        row.setOnClickListener(self._click_listener(lambda _v=None, h=holder: self._on_row_holder_click(h)))

        OnLongClickListener = jclass("android.view.View$OnLongClickListener")

        class _Long(dynamic_proxy(OnLongClickListener)):
            def onLongClick(self_obj, _v):
                try:
                    return bool(self._on_row_holder_long_click(holder))
                except Exception:
                    return False

        row.setOnLongClickListener(_Long())
        return holder

    def _on_row_holder_click(self, holder):
        try:
            target = holder.get("target") if isinstance(holder, dict) else None
            if target:
                self._open_target(dict(target))
        except Exception:
            pass

    def _on_row_holder_long_click(self, holder):
        try:
            target = holder.get("target") if isinstance(holder, dict) else None
            if not target:
                return False
            self._remove_favorite(dict(target))
            return True
        except Exception:
            return False

    def _resolve_cached_target_peer(self, target):
        try:
            key = self._target_key(target)
            if key in self._peer_cache:
                cached = self._peer_cache.get(key)
                try:
                    ckind, cobj = cached
                except Exception:
                    ckind, cobj = (None, None)
                if cobj is not None:
                    return cached
                try:
                    if int((target or {}).get("user_id", 0) or 0) <= 0:
                        return cached
                except Exception:
                    return cached
            resolved = self._resolve_target_peer(target)
            if key:
                self._peer_cache[key] = resolved
            try:
                kind, obj = resolved
                self._seed_target_runtime_cache(target, kind=kind, obj=obj)
            except Exception:
                pass
            return resolved
        except Exception:
            return (None, None)

    def _resolve_cached_display_name(self, target):
        try:
            key = self._target_key(target)
            direct_name = str((target or {}).get("name", "") or "").strip()
            if direct_name:
                if key:
                    self._name_cache[key] = direct_name
                    self._update_target_meta_cache(target, resolved_name=direct_name)
                return direct_name
            if key in self._name_cache:
                return self._name_cache.get(key)
            meta_name = ""
            try:
                meta_name = str((self._meta_cache.get(key) or {}).get("name", "") or "").strip()
            except Exception:
                meta_name = ""
            if meta_name:
                self._name_cache[key] = meta_name
                return meta_name
            resolved_name = self._display_name_target(target)
            if key:
                self._name_cache[key] = resolved_name
                self._update_target_meta_cache(target, resolved_name=resolved_name)
            return resolved_name
        except Exception:
            return ""

    def _resolve_cached_avatar_drawable(self, target, obj):
        try:
            key = self._target_key(target)
            if key in self._avatar_cache:
                return self._avatar_cache.get(key)
            drawable = AvatarDrawable(obj) if obj is not None else AvatarDrawable()
            if key:
                self._avatar_cache[key] = drawable
                self._update_target_meta_cache(target, obj=obj)
            return drawable
        except Exception:
            return AvatarDrawable()

    def _set_row_selected_style(self, row, selected):
        try:
            if bool(selected):
                sb = GradientDrawable()
                sb.setShape(GradientDrawable.RECTANGLE)
                sb.setCornerRadius(float(AndroidUtilities.dp(10)))
                try:
                    ac = int(Theme.getColor(Theme.key_dialogTextBlue2))
                except Exception:
                    ac = 0xFF66B4FF
                sb.setColor(self._i32((0x2B << 24) | (ac & 0x00FFFFFF)))
                row.setBackground(sb)
                row.setPadding(AndroidUtilities.dp(2), AndroidUtilities.dp(4), AndroidUtilities.dp(2), AndroidUtilities.dp(4))
            else:
                row.setBackground(None)
                row.setPadding(0, 0, 0, 0)
        except Exception:
            pass

    def _bind_row_holder(self, holder, target, selected=False):
        try:
            if not isinstance(holder, dict):
                return
            row = holder.get("root")
            av = holder.get("avatar")
            name = holder.get("name")
            new_target = dict(target) if isinstance(target, dict) else None
            new_key = self._target_key(new_target)
            same_target = bool(new_key and new_key == str(holder.get("target_key") or ""))
            same_selected = bool(holder.get("selected")) == bool(selected)
            holder["target"] = new_target
            holder["target_key"] = str(new_key or "")
            holder["selected"] = bool(selected)
            if row is None:
                return
            self._set_row_selected_style(row, bool(selected))

            if same_target:
                if name is not None and not same_selected:
                    try:
                        custom = int(self._docky_text_color() or 0)
                        if custom:
                            name.setTextColor(self._i32(custom))
                        elif bool(selected):
                            name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlue2))))
                        else:
                            name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlack))))
                    except Exception:
                        name.setTextColor(self._i32(0xFFD6E2F5))
                return

            try:
                kind, obj = self._resolve_cached_target_peer(new_target)
                avatar_drawable = self._resolve_cached_avatar_drawable(new_target, obj)
                if obj is not None:
                    av.setForUserOrChat(obj, avatar_drawable)
                    self._dlog("row avatar set ok kind={0} target={1}".format(str(kind), str(new_target)))
                else:
                    av.setImageDrawable(avatar_drawable)
                    self._dlog("row avatar fallback target={0}".format(str(new_target)))
            except Exception:
                self._dlog("row avatar exception target={0}".format(str(new_target)))

            if name is not None:
                resolved_name = self._resolve_cached_display_name(new_target)
                self._dlog("row name resolved={0} target={1}".format(str(resolved_name), str(new_target)))
                try:
                    current_text = str(name.getText().toString() if name.getText() is not None else "")
                except Exception:
                    current_text = ""
                if current_text != str(resolved_name):
                    name.setText(resolved_name)
                try:
                    custom = int(self._docky_text_color() or 0)
                    if custom:
                        name.setTextColor(self._i32(custom))
                    elif bool(selected):
                        name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlue2))))
                    else:
                        name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlack))))
                except Exception:
                    name.setTextColor(self._i32(0xFFD6E2F5))
        except Exception as e:
            self._dlog("bind row fail: {0}".format(e))

    def _build_sidebar_once(self):
        try:
            if self._sidebar_list is None:
                return
            self._row_views = []
            self._row_holders = []
            self._add_button = None
            self._icon_wrap = None
            self._icon_image = None

            if self._current_fragment is not None:
                ico_wrap = FrameLayout(self._sidebar_list.getContext())
                self._icon_wrap = ico_wrap
                if self._compact_enabled():
                    ilp = LinearLayout.LayoutParams(AndroidUtilities.dp(64), AndroidUtilities.dp(64))
                    ilp.gravity = Gravity.CENTER_HORIZONTAL
                else:
                    ilp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(40))
                    ilp.bottomMargin = AndroidUtilities.dp(6)
                self._sidebar_list.addView(ico_wrap, ilp)
                if not self._compact_enabled():
                    ico_wrap.setBackground(self._icon_chip_bg())

                ico = ImageView(self._sidebar_list.getContext())
                try:
                    R_drawable = jclass("org.telegram.messenger.R$drawable")
                    ico.setImageResource(int(R_drawable.menu_sidebar))
                except Exception:
                    pass
                try:
                    ico.setColorFilter(self._i32(int(self._docky_icon_color())))
                except Exception:
                    pass
                ico_wrap.addView(ico, FrameLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20), Gravity.CENTER))
                self._icon_image = ico
                ico.setOnClickListener(self._click_listener(lambda _v=None: self._toggle_compact(), key="toggle_compact", min_interval_ms=250))
                self._setup_icon_settings_hold(ico_wrap, ico)

            if not self._compact_enabled():
                for _ in range(3):
                    holder = self._create_row_holder(self._sidebar_list.getContext())
                    self._row_holders.append(holder)
                    self._row_views.append(holder.get("root"))
                    self._sidebar_list.addView(holder.get("root"))
                self._add_button = self._build_add_button(self._sidebar_list.getContext())
                self._sidebar_list.addView(self._add_button)

            self._apply_chat_nav_interaction_mode()
            self._setup_drag_handlers()
            self._build_sidebar_nav_once()
            try:
                total = len(self._favorites())
                self._update_sidebar_nav_state(total)
            except Exception:
                pass
            try:
                self._sidebar_list.post(lambda: self._update_sidebar_nav_state(len(self._favorites())))
            except Exception:
                pass
        except Exception as e:
            self._dlog("build sidebar once fail: {0}".format(e))

    def _build_sidebar_nav_once(self):
        try:
            if self._compact_enabled():
                return
            if self._root_view is None or self._sidebar_view is None:
                return
            if self._sidebar_nav_panel is not None:
                return
            self._ensure_settings_header_assets()
            ctx = self._root_view.getContext()
            from android.graphics import BitmapFactory

            panel = LinearLayout(ctx)
            panel.setOrientation(LinearLayout.VERTICAL)
            panel.setGravity(Gravity.CENTER)
            panel.setVisibility(View.VISIBLE)
            try:
                panel.setBackground(self._nav_panel_bg())
            except Exception:
                pass
            panel.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6))

            self._sidebar_nav_up = self._build_mini_control_button(ctx, NAV_UP_ICON_CACHE_FILE, "⌃", lambda _v=None: self._set_page(self._page_index - 1))
            self._sidebar_nav_down = self._build_mini_control_button(ctx, NAV_DOWN_ICON_CACHE_FILE, "⌄", lambda _v=None: self._set_page(self._page_index + 1))

            up_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
            down_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
            down_lp.topMargin = AndroidUtilities.dp(6)
            panel.addView(self._sidebar_nav_up, up_lp)
            panel.addView(self._sidebar_nav_down, down_lp)

            try:
                root_w = int(self._root_view.getWidth() or 0)
            except Exception:
                root_w = 0
            panel_w = int(AndroidUtilities.dp(36))
            edge_margin = int(AndroidUtilities.dp(12))
            if self._docky_invert_side_enabled():
                initial_x = int(edge_margin)
            elif root_w > 0:
                initial_x = int(max(AndroidUtilities.dp(8), root_w - panel_w - edge_margin))
            else:
                initial_x = int((self._sidebar_lp.leftMargin if self._sidebar_lp is not None else AndroidUtilities.dp(8)) + (self._sidebar_card_lp.width if self._sidebar_card_lp is not None else AndroidUtilities.dp(74)) + AndroidUtilities.dp(8))
            initial_y = int((self._sidebar_lp.topMargin if self._sidebar_lp is not None else AndroidUtilities.dp(8)) + AndroidUtilities.dp(120))
            lp = FrameLayout.LayoutParams(AndroidUtilities.dp(36), FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.START | Gravity.TOP)
            lp.leftMargin = int(initial_x)
            lp.topMargin = int(max(AndroidUtilities.dp(8), initial_y))
            self._root_view.addView(panel, lp)
            self._sidebar_nav_panel = panel
            self._dlog("sidebar nav panel created")
            try:
                self._update_sidebar_nav_state(len(self._favorites()))
            except Exception:
                pass
            try:
                self._sidebar_view.post(lambda: self._update_sidebar_nav_state(len(self._favorites())))
            except Exception:
                pass
        except Exception as e:
            self._dlog("build sidebar nav fail: {0}".format(e))

    def _schedule_sidebar_nav_sync(self):
        try:
            if self._sidebar_view is None:
                return
            def _run():
                try:
                    self._update_sidebar_nav_state(len(self._favorites()))
                except Exception:
                    pass
            try:
                self._sidebar_view.post(_run)
            except Exception:
                pass
            for delay in (30, 120, 260, 420):
                try:
                    AndroidUtilities.runOnUIThread(_run, int(delay))
                except Exception:
                    pass
        except Exception:
            pass

    def _update_sidebar_nav_position(self):
        try:
            if self._sidebar_nav_panel is None or self._sidebar_view is None or self._root_view is None or self._compact_enabled():
                return False
            try:
                if int(self._sidebar_view.getHeight() or 0) <= 0:
                    try:
                        self._sidebar_view.post(lambda: self._update_sidebar_nav_state(len(self._favorites())))
                    except Exception:
                        pass
                    return False
            except Exception:
                return False
            try:
                root_w = int(self._root_view.getWidth() or 0)
            except Exception:
                root_w = 0
            panel_w = int(AndroidUtilities.dp(36))
            edge_margin = int(AndroidUtilities.dp(12))
            if self._docky_invert_side_enabled():
                base_x = int(edge_margin)
            elif root_w > 0:
                base_x = int(max(AndroidUtilities.dp(8), root_w - panel_w - edge_margin))
            else:
                base_x = int((self._sidebar_lp.leftMargin if self._sidebar_lp is not None else AndroidUtilities.dp(8)) + (self._sidebar_card_lp.width if self._sidebar_card_lp is not None else AndroidUtilities.dp(74)) + AndroidUtilities.dp(8))
            target_y = int((self._sidebar_lp.topMargin if self._sidebar_lp is not None else AndroidUtilities.dp(8)) + AndroidUtilities.dp(120))
            lp = self._sidebar_nav_panel.getLayoutParams()
            if lp is None:
                return False
            lp.leftMargin = int(base_x)
            lp.topMargin = max(AndroidUtilities.dp(8), int(target_y))
            self._sidebar_nav_panel.setLayoutParams(lp)
            try:
                self._sidebar_nav_panel.bringToFront()
            except Exception:
                pass
            return True
        except Exception as e:
            self._dlog("sidebar nav pos fail: {0}".format(e))
            return False

    def _update_sidebar_nav_state(self, total):
        try:
            if self._sidebar_nav_panel is None:
                return
            if self._compact_enabled() or not self._chat_nav_control_enabled():
                if int(self._sidebar_nav_panel.getVisibility()) != int(View.GONE):
                    self._sidebar_nav_panel.setVisibility(View.GONE)
                return
            if int(self._sidebar_nav_panel.getVisibility()) != int(View.VISIBLE):
                self._sidebar_nav_panel.setVisibility(View.VISIBLE)
            max_page = max(0, int(total) - 3)
            can_up = int(self._page_index) > 0
            can_down = int(self._page_index) < int(max_page)

            def _apply_btn(btn, enabled):
                if btn is None:
                    return
                btn.setEnabled(bool(enabled))
                btn.setClickable(bool(enabled))
                btn.setAlpha(1.0 if bool(enabled) else 0.35)

            _apply_btn(self._sidebar_nav_up, can_up)
            _apply_btn(self._sidebar_nav_down, can_down)
            self._update_sidebar_nav_position()
        except Exception as e:
            self._dlog("sidebar nav state fail: {0}".format(e))

    def _build_dialogs_widget_nav_once(self):
        try:
            if self._dialogs_widget_root is None or self._dialogs_widget_view is None:
                return
            if self._dialogs_widget_nav_panel is not None:
                return
            self._ensure_settings_header_assets()
            ctx = self._dialogs_widget_root.getContext()
            from android.graphics import BitmapFactory
            panel = LinearLayout(ctx)
            panel.setOrientation(LinearLayout.VERTICAL)
            panel.setGravity(Gravity.CENTER)
            panel.setVisibility(View.VISIBLE)
            try:
                panel.setBackground(self._nav_panel_bg())
            except Exception:
                pass
            panel.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6))

            self._dialogs_widget_nav_up = self._build_mini_control_button(ctx, NAV_UP_ICON_CACHE_FILE, "⌃", lambda _v=None: self._set_dialogs_widget_page(self._dialogs_widget_page_index - 1))
            self._dialogs_widget_nav_down = self._build_mini_control_button(ctx, NAV_DOWN_ICON_CACHE_FILE, "⌄", lambda _v=None: self._set_dialogs_widget_page(self._dialogs_widget_page_index + 1))
            up_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
            down_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
            down_lp.topMargin = AndroidUtilities.dp(6)
            panel.addView(self._dialogs_widget_nav_up, up_lp)
            panel.addView(self._dialogs_widget_nav_down, down_lp)
            lp = FrameLayout.LayoutParams(AndroidUtilities.dp(36), FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.TOP | Gravity.START)
            try:
                root_w = int(self._dialogs_widget_root.getWidth() or 0)
            except Exception:
                root_w = 0
            widget_w = int(AndroidUtilities.dp(82))
            panel_w = int(AndroidUtilities.dp(36))
            gap = int(AndroidUtilities.dp(8))
            right_margin = int(self._dialogs_widget_lp.rightMargin if self._dialogs_widget_lp is not None else AndroidUtilities.dp(8))
            top_margin = int(self._dialogs_widget_lp.topMargin if self._dialogs_widget_lp is not None else AndroidUtilities.dp(8))
            if root_w > 0:
                lp.leftMargin = int(max(AndroidUtilities.dp(8), root_w - right_margin - widget_w - gap - panel_w))
            else:
                lp.leftMargin = int(AndroidUtilities.dp(8))
            lp.topMargin = int(max(AndroidUtilities.dp(8), top_margin + AndroidUtilities.dp(72)))
            self._dialogs_widget_root.addView(panel, lp)
            self._dialogs_widget_nav_panel = panel
            try:
                self._update_dialogs_widget_nav_state(len(self._favorites()))
            except Exception:
                pass
            try:
                self._dialogs_widget_view.post(lambda: self._update_dialogs_widget_nav_state(len(self._favorites())))
            except Exception:
                pass
        except Exception as e:
            self._dlog("build widget nav fail: {0}".format(e))

    def _update_dialogs_widget_nav_position(self):
        try:
            if self._dialogs_widget_nav_panel is None or self._dialogs_widget_view is None or self._dialogs_widget_root is None:
                return False
            try:
                root_w = int(self._dialogs_widget_root.getWidth() or 0)
                if root_w <= 0:
                    return False
            except Exception:
                return False
            widget_w = int(AndroidUtilities.dp(82))
            panel_w = int(AndroidUtilities.dp(36))
            gap = int(AndroidUtilities.dp(8))
            right_margin = int(self._dialogs_widget_lp.rightMargin if self._dialogs_widget_lp is not None else AndroidUtilities.dp(8))
            top_margin = int(self._dialogs_widget_lp.topMargin if self._dialogs_widget_lp is not None else AndroidUtilities.dp(8))
            base_x = int(max(AndroidUtilities.dp(8), root_w - right_margin - widget_w - gap - panel_w))
            target_y = int(max(AndroidUtilities.dp(8), top_margin + AndroidUtilities.dp(72)))
            lp = self._dialogs_widget_nav_panel.getLayoutParams()
            if lp is None:
                return False
            lp.leftMargin = int(max(AndroidUtilities.dp(8), base_x))
            lp.topMargin = int(max(AndroidUtilities.dp(8), target_y))
            self._dialogs_widget_nav_panel.setLayoutParams(lp)
            try:
                self._dialogs_widget_nav_panel.bringToFront()
            except Exception:
                pass
            return True
        except Exception as e:
            self._dlog("widget nav pos fail: {0}".format(e))
            return False

    def _update_dialogs_widget_nav_state(self, total):
        try:
            if self._dialogs_widget_nav_panel is None:
                return
            if int(total) <= 5:
                if int(self._dialogs_widget_nav_panel.getVisibility()) != int(View.GONE):
                    self._dialogs_widget_nav_panel.setVisibility(View.GONE)
                return
            if int(self._dialogs_widget_nav_panel.getVisibility()) != int(View.VISIBLE):
                self._dialogs_widget_nav_panel.setVisibility(View.VISIBLE)
            max_page = max(0, int(total) - 5)
            can_up = int(self._dialogs_widget_page_index) > 0
            can_down = int(self._dialogs_widget_page_index) < int(max_page)
            for btn, enabled in ((self._dialogs_widget_nav_up, can_up), (self._dialogs_widget_nav_down, can_down)):
                if btn is None:
                    continue
                btn.setEnabled(bool(enabled))
                btn.setClickable(bool(enabled))
                btn.setAlpha(1.0 if bool(enabled) else 0.35)
            self._update_dialogs_widget_nav_position()
        except Exception as e:
            self._dlog("widget nav state fail: {0}".format(e))

    def _set_dialogs_widget_page(self, p):
        try:
            new_page = max(0, int(p))
            if int(new_page) == int(self._dialogs_widget_page_index):
                return
            self._dialogs_widget_page_index = int(new_page)
            self._update_dialogs_widget_state()
        except Exception:
            pass

    def _schedule_dialogs_widget_nav_sync(self):
        try:
            if self._dialogs_widget_view is None:
                return
            def _run():
                try:
                    self._update_dialogs_widget_nav_state(len(self._favorites()))
                except Exception:
                    pass
            try:
                self._dialogs_widget_view.post(_run)
            except Exception:
                pass
            for delay in (30, 120, 260, 420):
                try:
                    AndroidUtilities.runOnUIThread(_run, int(delay))
                except Exception:
                    pass
        except Exception:
            pass

    def _update_sidebar_state(self):
        try:
            if self._sidebar_list is None:
                return
            self._swipe_triggered = False
            self._swipe_tracking = False
            self._swipe_start_y = 0
            self._refresh_sidebar_bg_only()
            self._apply_chat_nav_interaction_mode()

            items = self._favorites()
            total = len(items)
            page_size = 3
            max_page = max(0, int(total) - int(page_size))
            if self._page_index > max_page:
                self._page_index = max_page
            start = int(self._page_index)
            end = int(min(total, start + page_size))
            visible_items = items[start:end]

            active_fragment = None
            try:
                active_fragment = get_last_fragment()
            except Exception:
                active_fragment = self._current_fragment
            active_key = self._target_key(self._current_target(active_fragment))
            try:
                visible_sig = tuple("{0}|{1}".format(self._target_key(x), "1" if bool(self._target_key(x) and self._target_key(x) == active_key) else "0") for x in visible_items)
                state_sig = (int(self._page_index), int(total), str(active_key or ""), visible_sig, int(bool(self._compact_enabled())))
            except Exception:
                state_sig = None
            if state_sig is not None and state_sig == self._sidebar_state_sig:
                self._update_sidebar_nav_state(total)
                return
            self._sidebar_state_sig = state_sig

            for idx, holder in enumerate(self._row_holders):
                row = holder.get("root")
                if row is None:
                    continue
                if idx < len(visible_items):
                    item = dict(visible_items[idx])
                    key = self._target_key(item)
                    self._bind_row_holder(holder, item, selected=bool(key and key == active_key))
                    if int(row.getVisibility()) != int(View.VISIBLE):
                        row.setVisibility(View.VISIBLE)
                else:
                    holder["target"] = None
                    if int(row.getVisibility()) != int(View.GONE):
                        row.setVisibility(View.GONE)

            if self._add_button is not None:
                desired_visibility = View.VISIBLE if not self._compact_enabled() else View.GONE
                if int(self._add_button.getVisibility()) != int(desired_visibility):
                    self._add_button.setVisibility(desired_visibility)

            self._update_sidebar_nav_state(total)

            self._dlog("sidebar refresh count={0} page={1}".format(total, self._page_index))
        except Exception as e:
            self._dlog("update sidebar state fail: {0}".format(e))

    def _sidebar_top_dp(self):
        try:
            return int(self.get_setting("chats_sidebar_top_dp", 104))
        except Exception:
            return 104

    def _set_sidebar_top_dp(self, dp):
        try:
            self.set_setting("chats_sidebar_top_dp", int(max(36, min(560, int(dp)))))
        except Exception:
            pass

    def _estimate_top_overlay_bottom(self, root):
        # Keep the sidebar anchored to the chat content root itself.
        # Native top panels (pinned/translate/etc.) already manage chat paddings.
        return int(AndroidUtilities.dp(8))

    def _apply_adaptive_top(self):
        try:
            if self._sidebar_lp is None:
                return
            root = self._root_view
            min_top = int(self._estimate_top_overlay_bottom(root))
            target_top = int(min_top if min_top > 0 else AndroidUtilities.dp(8))
            # Bottom avoidance following ChatActivity flow (IME + input bubble).
            bottom_avoid = int(self._estimate_bottom_avoidance_px())
            if root is not None:
                try:
                    rh = int(root.getHeight() or 0)
                except Exception:
                    rh = 0
                try:
                    sh = int(self._sidebar_view.getHeight() or 0) if self._sidebar_view is not None else 0
                except Exception:
                    sh = 0
                if rh > 0 and sh > 0:
                    max_top = int(rh - sh - bottom_avoid - AndroidUtilities.dp(6))
                    if max_top > 0:
                        target_top = int(min(target_top, max_top))
            target_top = max(AndroidUtilities.dp(8), min(AndroidUtilities.dp(560), target_top))
            if int(self._sidebar_lp.topMargin) == int(target_top):
                self._apply_top_overlay_side_offset()
                self._apply_chat_content_side_inset()
                return
            self._sidebar_lp.topMargin = int(target_top)
            if self._sidebar_view is not None:
                self._sidebar_view.setLayoutParams(self._sidebar_lp)
            self._adaptive_last_top = int(target_top)
            self._apply_top_overlay_side_offset()
            self._apply_chat_content_side_inset()
        except Exception as e:
            self._dlog("adaptive top fail: {0}".format(e))

    def _layout_signature(self, root):
        try:
            rw = int(root.getWidth() or 0) if root is not None else 0
        except Exception:
            rw = 0
        try:
            rh = int(root.getHeight() or 0) if root is not None else 0
        except Exception:
            rh = 0
        try:
            sh = int(self._sidebar_view.getHeight() or 0) if self._sidebar_view is not None else 0
        except Exception:
            sh = 0
        try:
            bottom = int(self._estimate_bottom_avoidance_px())
        except Exception:
            bottom = 0
        try:
            compact = 1 if self._compact_enabled() else 0
        except Exception:
            compact = 0
        try:
            top_margin = int(self._sidebar_lp.topMargin) if self._sidebar_lp is not None else 0
        except Exception:
            top_margin = 0
        return (int(rw), int(rh), int(sh), int(bottom), int(compact), int(top_margin))

    def _run_adaptive_top_scheduled(self):
        try:
            root = self._root_view
            if root is None:
                return
            sig = self._layout_signature(root)
            if sig == self._layout_sig:
                return
            self._layout_sig = sig
            self._apply_adaptive_top()
        except Exception:
            pass

    def _schedule_adaptive_top(self, delay_ms=32):
        try:
            if self._adaptive_runnable is None:
                self._adaptive_runnable = lambda: self._run_adaptive_top_scheduled()
            try:
                AndroidUtilities.cancelRunOnUIThread(self._adaptive_runnable)
            except Exception:
                pass
            AndroidUtilities.runOnUIThread(self._adaptive_runnable, int(delay_ms or 0))
        except Exception:
            try:
                self._run_adaptive_top_scheduled()
            except Exception:
                pass

    def _estimate_bottom_avoidance_px(self):
        try:
            frag = None
            try:
                frag = get_last_fragment()
            except Exception:
                frag = None
            if frag is None:
                frag = self._current_fragment
            if frag is None:
                return 0
            ime = 0.0
            bubble = 0.0
            cls = frag.getClass()
            while cls is not None:
                try:
                    f = cls.getDeclaredField("windowInsetsStateHolder")
                    f.setAccessible(True)
                    holder = f.get(frag)
                    if holder is not None:
                        try:
                            ime = float(holder.getAnimatedMaxBottomInset())
                        except Exception:
                            try:
                                ime = float(holder.getCurrentMaxBottomInset())
                            except Exception:
                                pass
                except Exception:
                    pass
                try:
                    f2 = cls.getDeclaredField("chatActivityEnterView")
                    f2.setAccessible(True)
                    cev = f2.get(frag)
                    if cev is not None:
                        try:
                            bubble = float(cev.getInputBubbleHeight())
                        except Exception:
                            pass
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return int(max(0.0, ime + bubble + float(AndroidUtilities.dp(9))))
        except Exception:
            return 0

    def _apply_top_overlay_side_offset(self):
        try:
            frag = self._current_fragment
            if frag is None:
                return
            side_width = int(AndroidUtilities.dp(64 + 7))
            side_gap = int(AndroidUtilities.dp(12))
            side_enabled = bool(self._enabled() and self._sidebar_view is not None)

            top_panel = self._get_declared_field_value(frag, "topPanelLayout")
            floating_date = self._get_declared_field_value(frag, "floatingDateView")
            floating_sep = self._get_declared_field_value(frag, "floatingTopicSeparator")
            empty_view = self._get_declared_field_value(frag, "emptyViewContainer")

            if top_panel is not None:
                self._cache_view_layout_margins("top_panel_lp", top_panel)
                base_lp = self._native_view_state_cache.get("top_panel_lp")
                if base_lp is not None:
                    lp = top_panel.getLayoutParams()
                    if lp is not None:
                        if self._docky_invert_side_enabled():
                            desired_left = int(base_lp[0])
                            desired_right = int(base_lp[2]) + (side_width + side_gap if side_enabled else 0)
                        else:
                            desired_left = int(base_lp[0]) + (side_width + side_gap if side_enabled else 0)
                            desired_right = int(base_lp[2])
                        cache_key = "top_panel_applied"
                        prev = self._overlay_margin_cache.get(cache_key)
                        if prev == (desired_left, desired_right):
                            lp = None
                        if hasattr(lp, "leftMargin"):
                            lp.leftMargin = int(desired_left)
                        if hasattr(lp, "rightMargin"):
                            lp.rightMargin = int(desired_right)
                        if lp is not None:
                            top_panel.setLayoutParams(lp)
                            self._overlay_margin_cache[cache_key] = (desired_left, desired_right)

            for key, view in (
                ("floating_date", floating_date),
                ("floating_sep", floating_sep),
                ("empty_view", empty_view),
            ):
                if view is None:
                    continue
                if key not in self._native_view_state_cache:
                    try:
                        self._native_view_state_cache[key] = float(view.getTranslationX())
                    except Exception:
                        self._native_view_state_cache[key] = 0.0
                try:
                    shift = float(side_width / 2.0 if side_enabled else 0.0)
                    target_tx = float(-shift if self._docky_invert_side_enabled() else shift)
                    cache_key = key + "_tx"
                    if float(self._overlay_margin_cache.get(cache_key, -99999.0)) != float(target_tx):
                        view.setTranslationX(float(target_tx))
                        self._overlay_margin_cache[cache_key] = float(target_tx)
                except Exception:
                    pass
        except Exception as e:
            self._dlog("top overlay side offset fail: {0}".format(e))

    def _restore_top_overlay_side_offset(self):
        try:
            frag = self._current_fragment
            if frag is None:
                return
            top_panel = self._get_declared_field_value(frag, "topPanelLayout")
            floating_date = self._get_declared_field_value(frag, "floatingDateView")
            floating_sep = self._get_declared_field_value(frag, "floatingTopicSeparator")
            empty_view = self._get_declared_field_value(frag, "emptyViewContainer")

            self._restore_view_layout_margins("top_panel_lp", top_panel)
            for key, view in (
                ("floating_date", floating_date),
                ("floating_sep", floating_sep),
                ("empty_view", empty_view),
            ):
                if view is None:
                    continue
                try:
                    base_tx = float(self._native_view_state_cache.get(key, 0.0) or 0.0)
                    if float(self._overlay_margin_cache.get(key + "_tx", -99999.0)) != float(base_tx):
                        view.setTranslationX(float(base_tx))
                except Exception:
                    pass
        except Exception:
            pass
        self._overlay_margin_cache = {}

    def _apply_chat_content_side_inset(self):
        return

    def _restore_chat_content_side_inset(self):
        pass
        self._chatlist_translation_cache = {}
        self._native_view_state_cache = {}

    def _get_declared_field_value(self, obj, name):
        try:
            if obj is None:
                return None
            cls = obj.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField(name)
                    fld.setAccessible(True)
                    return fld.get(obj)
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return None
        except Exception:
            return None

    def _set_declared_field_value(self, obj, name, value):
        try:
            if obj is None:
                return False
            cls = obj.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField(name)
                    fld.setAccessible(True)
                    fld.set(obj, value)
                    return True
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return False
        except Exception:
            return False

    def _set_declared_boolean_field(self, obj, name, value):
        try:
            if obj is None:
                return False
            cls = obj.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField(name)
                    fld.setAccessible(True)
                    fld.setBoolean(obj, bool(value))
                    return True
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return False
        except Exception:
            return False

    def _set_declared_float_field(self, obj, name, value):
        try:
            if obj is None:
                return False
            cls = obj.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField(name)
                    fld.setAccessible(True)
                    fld.setFloat(obj, float(value))
                    return True
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return False
        except Exception:
            return False

    def _set_declared_int_field(self, obj, name, value):
        try:
            if obj is None:
                return False
            cls = obj.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField(name)
                    fld.setAccessible(True)
                    fld.setInt(obj, int(value))
                    return True
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return False
        except Exception:
            return False

    def _cache_view_padding(self, key, view):
        try:
            if view is None or key in self._native_view_state_cache:
                return
            self._native_view_state_cache[key] = (
                int(view.getPaddingLeft()),
                int(view.getPaddingTop()),
                int(view.getPaddingRight()),
                int(view.getPaddingBottom()),
            )
        except Exception:
            pass

    def _cache_view_layout_margins(self, key, view):
        try:
            if view is None or key in self._native_view_state_cache:
                return
            lp = view.getLayoutParams()
            if lp is None:
                return
            left = int(getattr(lp, "leftMargin", 0))
            top = int(getattr(lp, "topMargin", 0))
            right = int(getattr(lp, "rightMargin", 0))
            bottom = int(getattr(lp, "bottomMargin", 0))
            self._native_view_state_cache[key] = (left, top, right, bottom)
        except Exception:
            pass

    def _restore_view_padding(self, key, view):
        try:
            if view is None:
                return
            state = self._native_view_state_cache.get(key)
            if not state:
                return
            view.setPadding(int(state[0]), int(state[1]), int(state[2]), int(state[3]))
        except Exception:
            pass

    def _restore_view_layout_margins(self, key, view):
        try:
            if view is None:
                return
            state = self._native_view_state_cache.get(key)
            if not state:
                return
            lp = view.getLayoutParams()
            if lp is None:
                return
            if hasattr(lp, "leftMargin"):
                lp.leftMargin = int(state[0])
            if hasattr(lp, "topMargin"):
                lp.topMargin = int(state[1])
            if hasattr(lp, "rightMargin"):
                lp.rightMargin = int(state[2])
            if hasattr(lp, "bottomMargin"):
                lp.bottomMargin = int(state[3])
            view.setLayoutParams(lp)
        except Exception:
            pass

    def _apply_native_side_menu_state(self):
        try:
            frag = self._current_fragment
            if frag is None:
                return
            side_width = int(AndroidUtilities.dp(64 + 7))
            side_gap = int(AndroidUtilities.dp(12))
            side_alpha = 1.0
            side_enabled = bool(self._enabled() and self._sidebar_view is not None)

            chat_list = self._get_declared_field_value(frag, "chatListView")
            top_panel = self._get_declared_field_value(frag, "topPanelLayout")
            floating_date = self._get_declared_field_value(frag, "floatingDateView")
            floating_sep = self._get_declared_field_value(frag, "floatingTopicSeparator")
            empty_view = self._get_declared_field_value(frag, "emptyViewContainer")

            if top_panel is not None:
                self._cache_view_layout_margins("top_panel_lp", top_panel)
                base_lp = self._native_view_state_cache.get("top_panel_lp")
                if base_lp is not None:
                    lp = top_panel.getLayoutParams()
                    if lp is not None:
                        if hasattr(lp, "leftMargin"):
                            lp.leftMargin = int(base_lp[0]) + (side_width + side_gap if side_enabled else 0)
                        if hasattr(lp, "rightMargin"):
                            lp.rightMargin = int(base_lp[2])
                        top_panel.setLayoutParams(lp)

            for key, view in (
                ("floating_date", floating_date),
                ("floating_sep", floating_sep),
                ("empty_view", empty_view),
            ):
                if view is None:
                    continue
                if key not in self._native_view_state_cache:
                    try:
                        self._native_view_state_cache[key] = float(view.getTranslationX())
                    except Exception:
                        self._native_view_state_cache[key] = 0.0
                try:
                    view.setTranslationX(float(side_width / 2.0 if side_enabled else 0.0))
                except Exception:
                    pass

            if chat_list is None:
                return

            try:
                cnt = int(chat_list.getChildCount())
            except Exception:
                cnt = 0
            for i in range(cnt):
                try:
                    view = chat_list.getChildAt(i)
                except Exception:
                    view = None
                if view is None:
                    continue
                name = str(view.getClass().getName())
                if name.endswith("ChatMessageCell"):
                    self._set_declared_boolean_field(view, "isAllChats", False)
                    self._set_declared_boolean_field(view, "isSideMenued", bool(side_enabled))
                    old_enabled = self._get_declared_field_value(view, "isSideMenuEnabled")
                    self._set_declared_boolean_field(view, "isSideMenuEnabled", bool(side_enabled))
                    self._set_declared_float_field(view, "sideMenuAlpha", float(side_alpha))
                    self._set_declared_int_field(view, "sideMenuWidth", int(side_width if side_enabled else 0))
                    try:
                        if bool(old_enabled) != bool(side_enabled):
                            view.relayout()
                    except Exception:
                        pass
                    try:
                        view.updateTranslation()
                    except Exception:
                        pass
                    try:
                        view.invalidate()
                    except Exception:
                        pass
                elif name.endswith("ChatActionCell"):
                    self._set_declared_boolean_field(view, "isAllChats", False)
                    self._set_declared_boolean_field(view, "isSideMenued", bool(side_enabled))
                    self._set_declared_boolean_field(view, "isSideMenuEnabled", bool(side_enabled))
                    self._set_declared_float_field(view, "sideMenuAlpha", float(side_alpha))
                    self._set_declared_int_field(view, "sideMenuWidth", int(side_width if side_enabled else 0))
                    try:
                        view.invalidate()
                    except Exception:
                        pass
                elif name.endswith("ChatUnreadCell"):
                    try:
                        tv = view.getTextView()
                        if tv is not None:
                            tv.setTranslationX(float(side_width / 2.0 if side_enabled else 0.0))
                    except Exception:
                        pass
                elif name.endswith("BotAskCell") or name.endswith("BotHelpCell"):
                    try:
                        view.invalidate()
                    except Exception:
                        pass
            self._dlog("native side state applied enabled={0} width={1}".format(side_enabled, side_width if side_enabled else 0))
        except Exception as e:
            self._dlog("native side state exception: {0}".format(e))

    def _restore_native_side_menu_state(self):
        try:
            frag = self._current_fragment
            if frag is None:
                return
            chat_list = self._get_declared_field_value(frag, "chatListView")
            top_panel = self._get_declared_field_value(frag, "topPanelLayout")
            floating_date = self._get_declared_field_value(frag, "floatingDateView")
            floating_sep = self._get_declared_field_value(frag, "floatingTopicSeparator")
            empty_view = self._get_declared_field_value(frag, "emptyViewContainer")

            self._restore_view_layout_margins("top_panel_lp", top_panel)
            for key, view in (
                ("floating_date", floating_date),
                ("floating_sep", floating_sep),
                ("empty_view", empty_view),
            ):
                if view is None:
                    continue
                try:
                    view.setTranslationX(float(self._native_view_state_cache.get(key, 0.0) or 0.0))
                except Exception:
                    pass

            if chat_list is None:
                return
            try:
                cnt = int(chat_list.getChildCount())
            except Exception:
                cnt = 0
            for i in range(cnt):
                try:
                    view = chat_list.getChildAt(i)
                except Exception:
                    view = None
                if view is None:
                    continue
                name = str(view.getClass().getName())
                if name.endswith("ChatMessageCell"):
                    self._set_declared_boolean_field(view, "isSideMenued", False)
                    self._set_declared_boolean_field(view, "isSideMenuEnabled", False)
                    self._set_declared_float_field(view, "sideMenuAlpha", 0.0)
                    self._set_declared_int_field(view, "sideMenuWidth", 0)
                    try:
                        view.relayout()
                    except Exception:
                        pass
                    try:
                        view.updateTranslation()
                    except Exception:
                        pass
                    try:
                        view.invalidate()
                    except Exception:
                        pass
                elif name.endswith("ChatActionCell"):
                    self._set_declared_boolean_field(view, "isSideMenued", False)
                    self._set_declared_boolean_field(view, "isSideMenuEnabled", False)
                    self._set_declared_float_field(view, "sideMenuAlpha", 0.0)
                    self._set_declared_int_field(view, "sideMenuWidth", 0)
                    try:
                        view.invalidate()
                    except Exception:
                        pass
                elif name.endswith("ChatUnreadCell"):
                    try:
                        tv = view.getTextView()
                        if tv is not None:
                            tv.setTranslationX(0.0)
                    except Exception:
                        pass
        except Exception:
            pass

    def _setup_global_layout_listener(self, root):
        try:
            self._remove_global_layout_listener()
            if root is not None:
                self._root_view = root
            self._dlog("global layout listener disabled: passive overlay mode")
        except Exception as e:
            self._dlog("global layout listener fail: {0}".format(e))

    def _remove_global_layout_listener(self):
        try:
            root = self._root_view
            listener = self._global_layout_listener
            if root is not None and listener is not None:
                obs = root.getViewTreeObserver()
                if obs is not None and obs.isAlive():
                    try:
                        obs.removeOnGlobalLayoutListener(listener)
                    except Exception:
                        try:
                            obs.removeGlobalOnLayoutListener(listener)
                        except Exception:
                            pass
            self._root_view = None
            self._global_layout_listener = None
        except Exception:
            self._root_view = None
            self._global_layout_listener = None

    def _setup_drag_handlers(self):
        # Disabled: fixed native position only.
        return

    def _clear_page_swipe_handlers(self):
        try:
            if self._sidebar_list is not None:
                try:
                    self._sidebar_list.setOnTouchListener(None)
                except Exception:
                    pass
            for holder in self._row_holders:
                try:
                    holder.get("root").setOnTouchListener(None)
                except Exception:
                    pass
            self._swipe_triggered = False
            self._swipe_tracking = False
            self._swipe_start_y = 0
        except Exception:
            pass

    def _apply_chat_nav_interaction_mode(self):
        try:
            if self._chat_nav_swipe_enabled():
                self._setup_page_swipe_handlers()
            else:
                self._clear_page_swipe_handlers()
            try:
                self._update_sidebar_nav_state(len(self._favorites()))
            except Exception:
                pass
        except Exception as e:
            self._dlog("apply chat nav mode fail: {0}".format(e))

    def _setup_page_swipe_handlers(self):
        try:
            if self._sidebar_list is None or self._compact_enabled():
                return
            if not self._chat_nav_swipe_enabled():
                self._clear_page_swipe_handlers()
                return
            OnTouchListener = jclass("android.view.View$OnTouchListener")
            MotionEvent = jclass("android.view.MotionEvent")

            if self._swipe_touch_listener is None:
                class _Swipe(dynamic_proxy(OnTouchListener)):
                    def onTouch(self_obj, _v, ev):
                        try:
                            if self._drag_armed:
                                return False
                            act = int(ev.getActionMasked())
                            y = int(ev.getRawY())
                            if act == int(MotionEvent.ACTION_DOWN):
                                self._swipe_start_y = int(y)
                                self._swipe_tracking = True
                                self._swipe_triggered = False
                                return False
                            if act == int(MotionEvent.ACTION_UP):
                                if not self._swipe_tracking:
                                    return False
                                dy = int(y - self._swipe_start_y)
                                self._swipe_tracking = False
                                self._swipe_start_y = 0
                                if abs(int(dy)) < int(AndroidUtilities.dp(36)):
                                    self._swipe_triggered = False
                                    return False
                                self._swipe_triggered = True
                                items = self._favorites()
                                page_size = 3
                                max_page = max(0, int((max(0, len(items) - 1)) / page_size))
                                if dy < 0 and self._page_index < max_page:
                                    self._page_index += 1
                                    self._update_sidebar_state()
                                    return True
                                if dy > 0 and self._page_index > 0:
                                    self._page_index -= 1
                                    self._update_sidebar_state()
                                    return True
                            if act == int(MotionEvent.ACTION_CANCEL):
                                self._swipe_triggered = False
                                self._swipe_tracking = False
                                self._swipe_start_y = 0
                            return False
                        except Exception:
                            return False

                self._swipe_touch_listener = _Swipe()

            sw = self._swipe_touch_listener
            self._sidebar_list.setOnTouchListener(sw)
            for holder in self._row_holders:
                try:
                    holder.get("root").setOnTouchListener(sw)
                except Exception:
                    pass
            self._dlog("swipe handlers attached")
        except Exception as e:
            self._dlog("swipe setup fail: {0}".format(e))

    def _set_page(self, p):
        try:
            self._swipe_triggered = False
            self._swipe_tracking = False
            self._swipe_start_y = 0
            new_page = max(0, int(p))
            if int(new_page) == int(self._page_index):
                return
            self._page_index = int(new_page)
            self._update_sidebar_state()
        except Exception:
            pass

    def _toggle_compact(self):
        try:
            now = not self._compact_enabled()
            self.set_setting("chats_compact", bool(now))
            self._dlog("compact={0}".format(now))
            self._attach_sidebar(self._current_fragment)
        except Exception as e:
            self._dlog("toggle compact fail: {0}".format(e))

    def _attach_sidebar(self, fragment):
        try:
            if not self._enabled():
                self._detach_sidebar()
                return
            if self._is_preview_fragment(fragment):
                self._dlog("attach skipped: preview fragment")
                return
            if not self._docky_context_allowed(fragment):
                self._dlog("attach skipped: context disabled")
                self._detach_sidebar()
                return
            root = self._get_fragment_view(fragment)
            if root is None:
                self._dlog("attach aborted: root none")
                return
            self._current_fragment = fragment

            self._detach_sidebar()

            ctx = fragment.getParentActivity() if fragment and fragment.getParentActivity() else None
            if ctx is None:
                self._dlog("attach aborted: ctx none")
                return

            panel = FrameLayout(ctx)
            panel.setClickable(True)
            panel.setLongClickable(True)
            panel.setFocusable(False)
            panel.setBackgroundColor(self._i32(0x00000000))

            card = LinearLayout(ctx)
            card.setOrientation(LinearLayout.VERTICAL)
            card.setGravity(Gravity.CENTER_HORIZONTAL)
            card.setBackground(self._compact_chip_bg() if self._compact_enabled() else self._pill_bg())
            if self._compact_enabled():
                card.setPadding(0, 0, 0, 0)
            else:
                card.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            card_lp = FrameLayout.LayoutParams(
                AndroidUtilities.dp(74) if not self._compact_enabled() else AndroidUtilities.dp(64),
                AndroidUtilities.dp(64) if self._compact_enabled() else FrameLayout.LayoutParams.WRAP_CONTENT,
                (Gravity.END | Gravity.TOP) if self._docky_invert_side_enabled() else (Gravity.START | Gravity.TOP),
            )
            panel.addView(card, card_lp)

            self._sidebar_list = LinearLayout(ctx)
            self._sidebar_list.setOrientation(LinearLayout.VERTICAL)
            self._sidebar_list.setGravity(Gravity.CENTER_HORIZONTAL)
            card.addView(
                self._sidebar_list,
                LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.MATCH_PARENT if self._compact_enabled() else LinearLayout.LayoutParams.WRAP_CONTENT,
                ),
            )

            plp = FrameLayout.LayoutParams(
                AndroidUtilities.dp(82) if not self._compact_enabled() else AndroidUtilities.dp(68),
                FrameLayout.LayoutParams.WRAP_CONTENT,
            )
            if self._docky_invert_side_enabled():
                plp.gravity = Gravity.END | Gravity.TOP
                plp.rightMargin = AndroidUtilities.dp(8)
                plp.leftMargin = 0
            else:
                plp.gravity = Gravity.START | Gravity.TOP
                plp.leftMargin = AndroidUtilities.dp(8)
                plp.rightMargin = 0
            plp.topMargin = AndroidUtilities.dp(8)
            root.addView(panel, plp)

            self._sidebar_view = panel
            self._sidebar_card = card
            self._sidebar_lp = plp
            self._sidebar_card_lp = card_lp
            self._root_view = root
            self._setup_drag_handlers()
            self._setup_global_layout_listener(root)
            self._dlog("sidebar attached")
            self._apply_adaptive_top()
            self._schedule_adaptive_top(120)
            self._schedule_adaptive_top(260)
            self._schedule_adaptive_top(420)
            self._build_sidebar_once()
            self._update_sidebar_state()
            self._schedule_sidebar_nav_sync()
            try:
                did = int(self._normalize_dialog_id(self._get_dialog_id(fragment)) or 0)
                if did != 0 and int(self._normalize_dialog_id(self._preview_expand_attach_dialog_id) or 0) == did:
                    self._preview_expand_attach_dialog_id = 0
            except Exception:
                pass
        except Exception as e:
            self._dlog("attach fail: {0}".format(e))

    def _detach_sidebar(self):
        try:
            self._remove_global_layout_listener()
            self._restore_top_overlay_side_offset()
            self._restore_chat_content_side_inset()
            for v in (self._sidebar_nav_panel, self._sidebar_view):
                if v is not None:
                    p = v.getParent()
                    if p is not None:
                        p.removeView(v)
        except Exception:
            pass
        self._sidebar_view = None
        self._sidebar_card = None
        self._sidebar_list = None
        self._sidebar_lp = None
        self._sidebar_card_lp = None
        self._icon_wrap = None
        self._icon_image = None
        self._sidebar_nav_panel = None
        self._sidebar_nav_up = None
        self._sidebar_nav_down = None
        self._row_holders = []
        self._add_button = None
        self._swipe_touch_listener = None
        self._drag_armed = False
        self._drag_moved = False
        self._drag_down_ts = 0
        self._adaptive_last_top = -1
        self._layout_sig = None
        self._sidebar_state_sig = None
        try:
            if self._adaptive_runnable is not None:
                AndroidUtilities.cancelRunOnUIThread(self._adaptive_runnable)
        except Exception:
            pass
        self._row_views = []

    def _refresh_sidebar(self):
        try:
            if self._sidebar_view is None and self._dialogs_widget_view is None:
                return
            self._update_sidebar_state()
            self._update_dialogs_widget_state()
        except Exception as e:
            self._dlog("refresh fail: {0}".format(e))

    def _toggle_dialogs_widget_from_pill(self):
        try:
            if not self._action_debounce_ok("toggle_dialogs_widget_from_pill", 400):
                return
            if not self._widget_enabled():
                return
            frag = self._find_dialogs_fragment()
            if frag is None:
                try:
                    lf = get_last_fragment()
                    if lf is not None and "DialogsActivity" in str(lf.getClass().getName()):
                        frag = lf
                except Exception:
                    frag = None
            if frag is None:
                BulletinHelper.show_info(self._tr("widget_unavailable"))
                return
            if self._dialogs_widget_view is not None and self._dialogs_widget_fragment == frag:
                self._detach_dialogs_widget()
            else:
                self._attach_dialogs_widget(frag)
            try:
                self._telemetry_queue_event("feature_use", feature="docky_widget_toggle", count=1, force_flush=False)
            except Exception:
                pass
        except Exception as e:
            self._dlog("toggle dialogs widget fail: {0}".format(e))

    def _resolve_dialogs_widget_top(self, fragment, root):
        try:
            top = int(AndroidUtilities.dp(8))
            top_panel = self._get_declared_field_value(fragment, "topPanelLayout")
            if top_panel is not None:
                try:
                    top = max(top, int(top_panel.getBottom()) + int(AndroidUtilities.dp(8)))
                except Exception:
                    pass
            view_pages = self._get_declared_field_value(fragment, "viewPages")
            if view_pages is not None:
                try:
                    for page in view_pages:
                        if page is None:
                            continue
                        list_view = self._get_declared_field_value(page, "listView")
                        if list_view is None:
                            continue
                        try:
                            vis = int(list_view.getVisibility())
                        except Exception:
                            vis = int(View.VISIBLE)
                        if vis == int(View.VISIBLE):
                            top = max(top, int(list_view.getTop()) + int(AndroidUtilities.dp(8)))
                            break
                except Exception:
                    pass
            return int(top)
        except Exception:
            return int(AndroidUtilities.dp(8))

    def _create_widget_row_holder(self, ctx):
        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.VERTICAL)
        row.setGravity(Gravity.CENTER_HORIZONTAL)
        lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(8)
        row.setLayoutParams(lp)

        av = BackupImageView(ctx)
        av.setRoundRadius(AndroidUtilities.dp(18))
        alp = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
        row.addView(av, alp)

        name = TextView(ctx)
        name.setTextSize(11.0)
        name.setMaxLines(2)
        name.setGravity(Gravity.CENTER)
        nlp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        nlp.topMargin = AndroidUtilities.dp(4)
        row.addView(name, nlp)
        holder = {"root": row, "avatar": av, "name": name, "target": None, "target_key": "", "selected": False}
        row.setOnClickListener(self._click_listener(lambda _v=None, h=holder: self._on_widget_row_click(h)))
        return holder

    def _on_widget_row_click(self, holder):
        try:
            target = holder.get("target") if isinstance(holder, dict) else None
            if target:
                self._open_target_from_widget(dict(target))
        except Exception:
            pass

    def _open_target_from_widget(self, target):
        try:
            if not isinstance(target, dict):
                return
            chat_id = int(target.get("chat_id", 0) or 0)
            user_id = int(target.get("user_id", 0) or 0)
            if chat_id == 0 and user_id == 0:
                return
            frag = self._dialogs_widget_fragment or self._find_dialogs_fragment()
            if frag is None:
                BulletinHelper.show_info(self._tr("failed_open_chat"))
                return
            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            if chat_id != 0:
                args.putLong("chat_id", int(chat_id))
            else:
                args.putLong("user_id", int(user_id))
            nf = ChatActivity(args)

            opened = False
            try:
                frag.presentFragment(nf)
                opened = True
            except Exception:
                pass
            if not opened:
                try:
                    pf = frag.getClass().getSuperclass().getDeclaredField("parentLayout")
                    pf.setAccessible(True)
                    pl = pf.get(frag)
                    if pl is not None:
                        pl.presentFragment(nf)
                        opened = True
                except Exception:
                    opened = False
            if opened:
                self._detach_dialogs_widget()
                self._dlog("widget open target={0}".format(str(target)))
                try:
                    self._telemetry_queue_event("feature_use", feature="docky_widget_open", count=1, force_flush=False)
                except Exception:
                    pass
            else:
                BulletinHelper.show_info(self._tr("failed_open_chat"))
        except Exception as e:
            self._dlog("open from widget fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_chat"))

    def _bind_widget_row_holder(self, holder, target):
        try:
            if not isinstance(holder, dict):
                return
            row = holder.get("root")
            av = holder.get("avatar")
            name = holder.get("name")
            new_target = dict(target) if isinstance(target, dict) else None
            new_key = self._target_key(new_target)
            same_target = bool(new_key and new_key == str(holder.get("target_key") or ""))
            holder["target"] = new_target
            holder["target_key"] = str(new_key or "")
            if row is None:
                return
            if same_target:
                return
            kind, obj = self._resolve_cached_target_peer(new_target)
            avatar_drawable = self._resolve_cached_avatar_drawable(new_target, obj)
            if obj is not None:
                av.setForUserOrChat(obj, avatar_drawable)
            else:
                av.setImageDrawable(avatar_drawable)
            resolved_name = self._resolve_cached_display_name(new_target)
            try:
                current_text = str(name.getText().toString() if name.getText() is not None else "")
            except Exception:
                current_text = ""
            if current_text != str(resolved_name):
                name.setText(resolved_name)
            try:
                custom = int(self._docky_text_color() or 0)
                if custom:
                    name.setTextColor(self._i32(custom))
                else:
                    name.setTextColor(self._i32(int(Theme.getColor(Theme.key_dialogTextBlack))))
            except Exception:
                name.setTextColor(self._i32(0xFFD6E2F5))
        except Exception as e:
            self._dlog("bind widget row fail: {0}".format(e))

    def _setup_dialogs_widget_swipe_handlers(self):
        try:
            if self._dialogs_widget_list is None:
                return
            OnTouchListener = jclass("android.view.View$OnTouchListener")
            MotionEvent = jclass("android.view.MotionEvent")
            plugin = self

            class _Swipe(dynamic_proxy(OnTouchListener)):
                def onTouch(self_obj, _v, ev):
                    try:
                        act = int(ev.getActionMasked())
                        y = int(ev.getRawY())
                        if act == int(MotionEvent.ACTION_DOWN):
                            plugin._swipe_start_y = int(y)
                            plugin._swipe_tracking = True
                            plugin._swipe_triggered = False
                            return False
                        if act == int(MotionEvent.ACTION_UP):
                            if not plugin._swipe_tracking:
                                return False
                            dy = int(y - plugin._swipe_start_y)
                            plugin._swipe_tracking = False
                            plugin._swipe_start_y = 0
                            if abs(int(dy)) < int(AndroidUtilities.dp(36)):
                                return False
                            total = len(plugin._favorites())
                            page_size = 5
                            max_page = max(0, int((max(0, total - 1)) / page_size))
                            if dy < 0 and plugin._dialogs_widget_page_index < max_page:
                                plugin._dialogs_widget_page_index += 1
                                plugin._update_dialogs_widget_state()
                                return True
                            if dy > 0 and plugin._dialogs_widget_page_index > 0:
                                plugin._dialogs_widget_page_index -= 1
                                plugin._update_dialogs_widget_state()
                                return True
                        return False
                    except Exception:
                        return False

            sw = _Swipe()
            self._dialogs_widget_swipe_touch_listener = sw
            self._dialogs_widget_list.setOnTouchListener(sw)
            for holder in self._dialogs_widget_row_holders:
                try:
                    holder.get("root").setOnTouchListener(sw)
                except Exception:
                    pass
        except Exception as e:
            self._dlog("widget swipe setup fail: {0}".format(e))

    def _build_dialogs_widget_once(self):
        try:
            if self._dialogs_widget_list is None:
                return
            self._dialogs_widget_row_holders = []
            ctx = self._dialogs_widget_list.getContext()
            ico_wrap = FrameLayout(ctx)
            ilp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(40))
            ilp.bottomMargin = AndroidUtilities.dp(6)
            self._dialogs_widget_list.addView(ico_wrap, ilp)
            ico_wrap.setBackground(self._icon_chip_bg())
            ico = ImageView(ctx)
            try:
                R_drawable = jclass("org.telegram.messenger.R$drawable")
                ico.setImageResource(int(R_drawable.menu_sidebar))
            except Exception:
                pass
            try:
                ico.setColorFilter(self._i32(int(self._docky_icon_color())))
            except Exception:
                pass
            ico_wrap.addView(ico, FrameLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20), Gravity.CENTER))
            ico_wrap.setOnClickListener(self._click_listener(lambda _v=None: self._detach_dialogs_widget(), key="detach_dialogs_widget", min_interval_ms=250))
            for _ in range(5):
                holder = self._create_widget_row_holder(ctx)
                self._dialogs_widget_row_holders.append(holder)
                self._dialogs_widget_list.addView(holder.get("root"))
            self._setup_dialogs_widget_swipe_handlers()
            self._build_dialogs_widget_nav_once()
        except Exception as e:
            self._dlog("build dialogs widget fail: {0}".format(e))

    def _update_dialogs_widget_state(self):
        try:
            if self._dialogs_widget_list is None:
                return
            items = self._favorites()
            total = len(items)
            page_size = 5
            max_page = max(0, int(total) - int(page_size))
            if self._dialogs_widget_page_index > max_page:
                self._dialogs_widget_page_index = max_page
            start = int(self._dialogs_widget_page_index)
            end = int(min(total, start + page_size))
            visible_items = items[start:end]
            try:
                visible_sig = tuple(self._target_key(x) for x in visible_items)
                state_sig = (int(self._dialogs_widget_page_index), int(total), visible_sig)
            except Exception:
                state_sig = None
            if state_sig is not None and state_sig == self._dialogs_widget_state_sig:
                self._update_dialogs_widget_nav_state(total)
                return
            self._dialogs_widget_state_sig = state_sig
            for idx, holder in enumerate(self._dialogs_widget_row_holders):
                row = holder.get("root")
                if row is None:
                    continue
                if idx < len(visible_items):
                    self._bind_widget_row_holder(holder, visible_items[idx])
                    if int(row.getVisibility()) != int(View.VISIBLE):
                        row.setVisibility(View.VISIBLE)
                else:
                    holder["target"] = None
                    holder["target_key"] = ""
                    if int(row.getVisibility()) != int(View.GONE):
                        row.setVisibility(View.GONE)
            self._update_dialogs_widget_nav_state(total)
        except Exception as e:
            self._dlog("update dialogs widget fail: {0}".format(e))

    def _attach_dialogs_widget(self, fragment):
        try:
            if fragment is None or "DialogsActivity" not in str(fragment.getClass().getName()):
                return
            root = self._get_fragment_view(fragment)
            if root is None:
                return
            self._detach_dialogs_widget()
            ctx = fragment.getParentActivity() if fragment.getParentActivity() else None
            if ctx is None:
                return
            panel = FrameLayout(ctx)
            panel.setClickable(True)
            panel.setFocusable(False)
            panel.setBackgroundColor(self._i32(0x00000000))
            card = LinearLayout(ctx)
            card.setOrientation(LinearLayout.VERTICAL)
            card.setGravity(Gravity.CENTER_HORIZONTAL)
            card.setBackground(self._pill_bg())
            card.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            panel.addView(card, FrameLayout.LayoutParams(AndroidUtilities.dp(74), FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.START | Gravity.TOP))
            lst = LinearLayout(ctx)
            lst.setOrientation(LinearLayout.VERTICAL)
            lst.setGravity(Gravity.CENTER_HORIZONTAL)
            card.addView(lst, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            plp = FrameLayout.LayoutParams(AndroidUtilities.dp(82), FrameLayout.LayoutParams.WRAP_CONTENT)
            plp.gravity = Gravity.END | Gravity.TOP
            plp.rightMargin = AndroidUtilities.dp(8)
            plp.topMargin = int(self._resolve_dialogs_widget_top(fragment, root) + AndroidUtilities.dp(6))
            root.addView(panel, plp)
            self._dialogs_widget_view = panel
            self._dialogs_widget_card = card
            self._dialogs_widget_list = lst
            self._dialogs_widget_root = root
            self._dialogs_widget_fragment = fragment
            self._dialogs_widget_lp = plp
            self._dialogs_widget_page_index = 0
            self._build_dialogs_widget_once()
            self._update_dialogs_widget_state()
            self._schedule_dialogs_widget_nav_sync()
        except Exception as e:
            self._dlog("attach dialogs widget fail: {0}".format(e))

    def _detach_dialogs_widget(self):
        try:
            for v in (self._dialogs_widget_nav_panel, self._dialogs_widget_view):
                if v is not None:
                    p = v.getParent()
                    if p is not None:
                        p.removeView(v)
        except Exception:
            pass
        self._dialogs_widget_view = None
        self._dialogs_widget_card = None
        self._dialogs_widget_list = None
        self._dialogs_widget_lp = None
        self._dialogs_widget_nav_panel = None
        self._dialogs_widget_nav_up = None
        self._dialogs_widget_nav_down = None
        self._dialogs_widget_root = None
        self._dialogs_widget_fragment = None
        self._dialogs_widget_page_index = 0
        self._dialogs_widget_row_holders = []
        self._dialogs_widget_swipe_touch_listener = None
        self._dialogs_widget_state_sig = None
    def _open_add_dialog(self):
        try:
            if not self._action_debounce_ok("open_add_dialog", 400):
                return
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("favorites_unavailable"))
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(8), AndroidUtilities.dp(20), AndroidUtilities.dp(8))
            inp = EditTextBoldCursor(ctx)
            inp.setHint(self._tr("open_add_hint"))
            inp.setInputType(InputType.TYPE_CLASS_TEXT)
            inp.setSingleLine(True)
            inp.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            try:
                bg_c = int(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                bg_c = 0xFF223043
            try:
                tx_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                tx_c = 0xFFF2F5FA
            try:
                hint_c = int(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                hint_c = 0xFFA6B0BE
            try:
                stroke_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText4))
            except Exception:
                stroke_c = 0xFF6C7B8E
            try:
                inp.setTextColor(self._i32(tx_c))
                inp.setHintTextColor(self._i32(hint_c))
                bgd = GradientDrawable()
                bgd.setCornerRadius(float(AndroidUtilities.dp(12)))
                bgd.setColor(self._i32(bg_c))
                bgd.setStroke(max(1, int(AndroidUtilities.dp(1))), self._i32(stroke_c))
                inp.setBackground(bgd)
            except Exception:
                pass
            root.addView(inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("open_add_title"))
            b.set_message(self._tr("open_add_message"))
            b.set_view(root)

            def _save(d, _w):
                try:
                    txt = str(inp.getText().toString() if inp.getText() is not None else "").strip()
                    did = int(self._normalize_dialog_id(txt or "0"))
                    if did == 0:
                        BulletinHelper.show_info(self._tr("invalid_dialog_id"))
                        return
                    t = {"user_id": int(did)} if did > 0 else {"chat_id": int(-did)}
                    if self._add_favorite_target(t):
                        if d:
                            d.dismiss()
                except Exception:
                    BulletinHelper.show_info(self._tr("invalid_dialog_id"))

            b.set_positive_button("OK", _save)
            b.set_negative_button(self._tr("cancel"), lambda d, _w: d.dismiss() if d else None)
            b.show()
        except Exception as e:
            self._dlog("open add dialog fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_add"))

    def _open_favorites_manager(self):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("favorites_unavailable"))
                return
            from org.telegram.ui.ActionBar import BottomSheet

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("favorites_title"))
            title.setTextSize(16.0)
            root.addView(title)

            for it in self._favorites():
                did = int(it.get("user_id", 0) or (0 - int(it.get("chat_id", 0) or 0)))
                row = TextView(ctx)
                row.setText("{0} ({1})".format(self._display_name(did), did))
                row.setTextSize(14.0)
                row.setPadding(0, AndroidUtilities.dp(10), 0, AndroidUtilities.dp(10))
                row.setOnClickListener(self._click_listener(lambda _v=None, x=dict(it): self._open_target(x)))

                OnLongClickListener = jclass("android.view.View$OnLongClickListener")
                t_ref = dict(it)

                class _Long(dynamic_proxy(OnLongClickListener)):
                    def onLongClick(self_obj, _v):
                        try:
                            self._remove_favorite(t_ref)
                            return True
                        except Exception:
                            return False

                row.setOnLongClickListener(_Long())
                root.addView(row)

            add = TextView(ctx)
            add.setText(self._tr("favorites_add"))
            add.setTextSize(14.0)
            add.setPadding(0, AndroidUtilities.dp(12), 0, 0)
            add.setOnClickListener(self._click_listener(lambda _v=None: self._open_add_dialog(), key="favorites_manager_add", min_interval_ms=400))
            root.addView(add)

            sh = BottomSheet(ctx, True)
            sh.setCustomView(root)
            sh.show()
        except Exception as e:
            self._dlog("favorites manager fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_manager"))

    def _preview_menu(self, fragment):
        try:
            ActionBarPopupLayout = jclass("org.telegram.ui.ActionBar.ActionBarPopupWindow$ActionBarPopupWindowLayout")
            ActionBarMenuSubItem = jclass("org.telegram.ui.ActionBar.ActionBarMenuSubItem")
            R_drawable = jclass("org.telegram.messenger.R$drawable")
            ctx = None
            try:
                ctx = fragment.getContext()
            except Exception:
                pass
            if ctx is None:
                try:
                    ctx = fragment.getParentActivity()
                except Exception:
                    ctx = None
            if ctx is None:
                return None
            flags = int(getattr(ActionBarPopupLayout, "FLAG_SHOWN_FROM_BOTTOM", 0) or 0)
            rp = None
            try:
                if hasattr(fragment, "getResourceProvider"):
                    rp = fragment.getResourceProvider()
            except Exception:
                rp = None
            popup_bg = 0
            for drawable_name in ("popup_fixed_alert4", "popup_fixed_alert", "popup_fixed", "popup"):
                try:
                    popup_bg = int(getattr(R_drawable, drawable_name, 0) or 0)
                except Exception:
                    popup_bg = 0
                if popup_bg > 0:
                    break
            menu = ActionBarPopupLayout(ctx, int(popup_bg), rp, flags)

            open_item = ActionBarMenuSubItem(ctx, False, False)
            open_item.setTextAndIcon(self._tr("preview_open_chat"), int(R_drawable.msg_discussion))
            open_item.setMinimumWidth(160)
            open_item.setOnClickListener(self._click_listener(lambda _v=None: self._expand_preview(fragment), key="preview_menu_open", min_interval_ms=350))
            menu.addView(open_item)

            if self._preview_enabled():
                reply_item = ActionBarMenuSubItem(ctx, False, False)
                kb_icon = int(getattr(R_drawable, "input_keyboard", 0) or 0)
                if kb_icon <= 0:
                    kb_icon = int(getattr(R_drawable, "msg_edit", 0) or 0)
                reply_item.setTextAndIcon(self._tr("peek_preview_go_chat"), kb_icon)
                reply_item.setMinimumWidth(160)
                reply_item.setOnClickListener(self._click_listener(lambda _v=None: self._open_floating_reply_input(int(self._preview_dialog_id(fragment))), key="preview_menu_reply", min_interval_ms=350))
                menu.addView(reply_item)

            close_item = ActionBarMenuSubItem(ctx, False, False)
            close_item.setTextAndIcon(self._tr("preview_close"), int(R_drawable.msg_clear))
            close_item.setMinimumWidth(160)
            close_item.setOnClickListener(self._click_listener(lambda _v=None: self._close_preview(fragment), key="preview_menu_close", min_interval_ms=250))
            menu.addView(close_item)
            return menu
        except Exception as e:
            self._dlog("preview menu fail: {0}".format(e))
            return None
    def _open_target_preview(self, target):
        try:
            if not self._action_debounce_ok("open_target_preview", 500):
                return
            if not isinstance(target, dict):
                return
            chat_id = int(target.get("chat_id", 0) or 0)
            user_id = int(target.get("user_id", 0) or 0)
            if chat_id == 0 and user_id == 0:
                return
            frag = get_last_fragment()
            if frag is None:
                BulletinHelper.show_info(self._tr("no_active_chat"))
                return

            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            if chat_id != 0:
                args.putLong("chat_id", int(chat_id))
            else:
                args.putLong("user_id", int(user_id))
            preview_fragment = ChatActivity(args)

            try:
                allow_field = preview_fragment.getClass().getDeclaredField("allowExpandPreviewByClick")
                allow_field.setAccessible(True)
                allow_field.setBoolean(preview_fragment, False)
            except Exception:
                pass

            menu = self._preview_menu(frag)
            if menu is None:
                BulletinHelper.show_info(self._tr("preview_menu_unavailable"))
                return
            try:
                self._detach_sidebar()
            except Exception:
                pass
            frag.presentFragmentAsPreviewWithMenu(preview_fragment, menu)
            self._dlog("preview opened target={0}".format(str(target)))
            try:
                self._telemetry_queue_event("feature_use", feature="docky_preview_open", count=1, force_flush=False)
            except Exception:
                pass
        except Exception as e:
            self._dlog("open preview fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_preview"))

    def _open_target_direct(self, target):
        try:
            if not self._action_debounce_ok("open_target_direct", 350):
                return
            if not isinstance(target, dict):
                return
            chat_id = int(target.get("chat_id", 0) or 0)
            user_id = int(target.get("user_id", 0) or 0)
            if chat_id == 0 and user_id == 0:
                return
            frag = get_last_fragment()
            if frag is None:
                BulletinHelper.show_info(self._tr("no_active_chat"))
                return
            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            if chat_id != 0:
                args.putLong("chat_id", int(chat_id))
            else:
                args.putLong("user_id", int(user_id))
            nf = ChatActivity(args)

            opened = False
            try:
                frag.presentFragment(nf)
                opened = True
            except Exception:
                pass
            if not opened:
                try:
                    pf = frag.getClass().getSuperclass().getDeclaredField("parentLayout")
                    pf.setAccessible(True)
                    pl = pf.get(frag)
                    if pl is not None:
                        pl.presentFragment(nf)
                        opened = True
                except Exception:
                    opened = False
            if opened:
                self._dlog("direct open target={0}".format(str(target)))
            else:
                BulletinHelper.show_info(self._tr("failed_open_chat"))
        except Exception as e:
            self._dlog("open direct fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_chat"))

    def _open_target(self, target):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="docky_open_favorite", count=1, force_flush=False)
            except Exception:
                pass
            if self._preview_enabled():
                self._open_target_preview(target)
            else:
                self._open_target_direct(target)
        except Exception:
            self._open_target_preview(target)

    def _on_chat_fragment_ready(self, fragment):
        try:
            if fragment is None:
                return
            try:
                pending_did = int(self._normalize_dialog_id(self._preview_expand_attach_dialog_id) or 0)
            except Exception:
                pending_did = 0
            try:
                frag_did = int(self._normalize_dialog_id(self._get_dialog_id(fragment)) or 0)
            except Exception:
                frag_did = 0
            if pending_did != 0 and frag_did == pending_did:
                self._attach_sidebar_after_preview_exit(fragment, pending_did)
                return
            self._attach_sidebar(fragment)
        except Exception:
            pass

    def _attach_sidebar_after_preview_exit(self, fragment, dialog_id):
        try:
            target_did = int(self._normalize_dialog_id(dialog_id) or 0)
            if target_did == 0:
                self._attach_sidebar(fragment)
                return
            try:
                frag_did = int(self._normalize_dialog_id(self._get_dialog_id(fragment)) or 0)
            except Exception:
                frag_did = 0
            if frag_did != target_did:
                return
            if self._is_preview_fragment(fragment):
                def _retry():
                    self._attach_sidebar_after_preview_exit(fragment, target_did)
                for delay in (120, 260, 420, 620, 860):
                    try:
                        AndroidUtilities.runOnUIThread(_retry, int(delay))
                    except Exception:
                        pass
                return
            self._attach_sidebar(fragment)
            self._preview_expand_attach_dialog_id = 0
        except Exception:
            pass

    def _attach_expanded_preview_target(self, source_fragment, dialog_id):
        try:
            target_did = int(self._normalize_dialog_id(dialog_id) or 0)
            if target_did == 0:
                return
            for frag in (source_fragment, get_last_fragment()):
                try:
                    if frag is None:
                        continue
                    frag_did = int(self._normalize_dialog_id(self._get_dialog_id(frag)) or 0)
                    if frag_did != target_did:
                        continue
                    self._attach_sidebar_after_preview_exit(frag, target_did)
                    return
                except Exception:
                    pass
        except Exception:
            pass

    def _expand_preview(self, fragment):
        try:
            if not self._action_debounce_ok("expand_preview", 450):
                return
            try:
                self._preview_expand_attach_dialog_id = int(self._preview_dialog_id(fragment) or 0)
            except Exception:
                self._preview_expand_attach_dialog_id = 0
            parent_layout = None
            try:
                pf = fragment.getClass().getSuperclass().getDeclaredField("parentLayout")
                pf.setAccessible(True)
                parent_layout = pf.get(fragment)
            except Exception:
                parent_layout = None
            if parent_layout is not None:
                parent_layout.expandPreviewFragment()
                try:
                    def _attach_after():
                        self._attach_expanded_preview_target(fragment, self._preview_expand_attach_dialog_id)
                    for delay in (120, 220, 360, 520, 760, 1100, 1450):
                        AndroidUtilities.runOnUIThread(_attach_after, int(delay))
                except Exception:
                    pass
        except Exception:
            pass

    def _close_preview(self, fragment):
        try:
            fragment.finishPreviewFragment()
        except Exception:
            pass
        try:
            AndroidUtilities.runOnUIThread(lambda: self._attach_sidebar(get_last_fragment()), 120)
            AndroidUtilities.runOnUIThread(lambda: self._attach_sidebar(get_last_fragment()), 260)
        except Exception:
            pass

    def _preview_dialog_id(self, fragment):
        try:
            args = fragment.getArguments() if fragment is not None else None
            if args is not None:
                try:
                    cid = int(args.getLong("chat_id", 0))
                except Exception:
                    cid = 0
                if cid != 0:
                    return int(-cid)
                try:
                    uid = int(args.getLong("user_id", 0))
                except Exception:
                    uid = 0
                if uid != 0:
                    return int(uid)
            return int(self._get_dialog_id(fragment))
        except Exception:
            return 0

    def _open_floating_reply_input(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                BulletinHelper.show_info(self._tr("peek_reply_unavailable"))
                return
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("peek_reply_unavailable"))
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.text import InputType
            from android.util import TypedValue

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp = EditTextBoldCursor(ctx)
            inp.setHint(self._tr("peek_reply_hint"))
            inp.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_MULTI_LINE)
            inp.setSingleLine(False)
            inp.setMinLines(3)
            inp.setMaxLines(6)
            inp.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            try:
                bg_c = int(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                bg_c = 0xFF223043
            try:
                tx_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                tx_c = 0xFFF2F5FA
            try:
                hint_c = int(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                hint_c = 0xFFA6B0BE
            try:
                stroke_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText4))
            except Exception:
                stroke_c = 0xFF6C7B8E
            try:
                inp.setTextColor(self._i32(tx_c))
                inp.setHintTextColor(self._i32(hint_c))
                bgd = GradientDrawable()
                bgd.setCornerRadius(float(AndroidUtilities.dp(12)))
                bgd.setColor(self._i32(bg_c))
                bgd.setStroke(max(1, int(AndroidUtilities.dp(1))), self._i32(stroke_c))
                inp.setBackground(bgd)
                inp.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(11), AndroidUtilities.dp(14), AndroidUtilities.dp(11))
            except Exception:
                pass
            root.addView(inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("peek_reply_title"))
            b.set_view(root)

            def _send(d, _w):
                try:
                    out = str(inp.getText().toString() if inp.getText() is not None else "").strip()
                    if not out:
                        BulletinHelper.show_info(self._tr("message_empty"))
                        return
                    ok = self._send_plain_message(int(did), out)
                    if ok:
                        BulletinHelper.show_success(self._tr("peek_reply_sent"))
                        if d:
                            d.dismiss()
                    else:
                        BulletinHelper.show_info(self._tr("peek_reply_failed"))
                except Exception:
                    BulletinHelper.show_info(self._tr("peek_reply_failed"))

            b.set_positive_button(self._tr("send"), _send)
            b.set_negative_button(self._tr("cancel"), lambda d, _w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("peek_reply_unavailable"))

    def _send_plain_message(self, dialog_id, text):
        try:
            payload = str(text or "").strip()
            if not payload:
                return False
            send_message({"peer": int(dialog_id), "message": payload})
            return True
        except Exception as e:
            self._dlog("send plain fail: {0}".format(e))
            return False

    def on_send_message_hook(self, account, params):
        try:
            txt = str(getattr(params, "message", "") or "").strip()
            if not txt:
                return HookResult(strategy=HookStrategy.DEFAULT)
            low = txt.lower()
            if low == "!fav":
                t = self._current_target(get_last_fragment())
                if not t:
                    BulletinHelper.show_info(self._tr("no_active_chat_id"))
                else:
                    self._add_favorite_target(t)
                return HookResult(strategy=HookStrategy.CANCEL)
            if low.startswith("!fav "):
                try:
                    did = int(str(txt.split(" ", 1)[1]).strip())
                    t = {"user_id": int(did)} if did > 0 else {"chat_id": int(-did)}
                    self._add_favorite_target(t)
                except Exception:
                    BulletinHelper.show_info(self._tr("invalid_id"))
                return HookResult(strategy=HookStrategy.CANCEL)
            if low.startswith("!favdel "):
                try:
                    did = int(str(txt.split(" ", 1)[1]).strip())
                    t = {"user_id": int(did)} if did > 0 else {"chat_id": int(-did)}
                    self._remove_favorite(t)
                except Exception:
                    BulletinHelper.show_info(self._tr("invalid_id"))
                return HookResult(strategy=HookStrategy.CANCEL)
            return HookResult(strategy=HookStrategy.DEFAULT)
        except Exception:
            return HookResult(strategy=HookStrategy.DEFAULT)
