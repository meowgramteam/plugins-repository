    def _open_sidebar_bg_color_picker(self, _=None):
        try:
            frag = get_last_fragment()
            if not frag:
                return
            act = frag.getParentActivity()
            if not act:
                return
            try:
                resources_provider = frag.getResourceProvider()
            except Exception:
                resources_provider = None
            initial_hex = str(self.get_setting("docky_sidebar_bg_color", "#243247") or "#243247")
            try:
                initial_color = Color.parseColor(initial_hex)
            except Exception:
                initial_color = int(Theme.getColor(Theme.key_dialogBackground))

            try:
                from org.telegram.ui.Components.Paint import ColorPickerBottomSheet
                from androidx.core.util import Consumer
                PipetteDelegate = find_class("org.telegram.ui.Components.Paint.ColorPickerBottomSheet$PipetteDelegate")
                PipetteDelegateProxy = dynamic_proxy(PipetteDelegate)

                class _PipetteDelegate(PipetteDelegateProxy):
                    def __init__(self):
                        super().__init__()
                    def onStartColorPipette(self): return None
                    def onStopColorPipette(self): return None
                    def getContainerView(self): return None
                    def getSnapshotDrawingView(self): return None
                    def onDrawImageOverCanvas(self, bitmap, canvas): return None
                    def isPipetteVisible(self): return False
                    def isPipetteAvailable(self): return False
                    def onColorSelected(self, color): return None

                ConsumerProxy = dynamic_proxy(Consumer)

                class _ColorConsumer(ConsumerProxy):
                    def __init__(self, plugin):
                        super().__init__()
                        self._plugin = plugin
                    def accept(self, color):
                        try:
                            color_int = int(color)
                        except Exception:
                            return
                        self._plugin.set_setting("docky_sidebar_bg_color", "#{:06X}".format(color_int & 0xFFFFFF))
                        self._plugin._refresh_sidebar_bg_only()
                        BulletinHelper.show_success(self._plugin._tr("settings_sidebar_bg_done"))

                self._docky_color_picker_pipette = _PipetteDelegate()
                self._docky_color_picker_consumer = _ColorConsumer(self)

                sheet = ColorPickerBottomSheet(act, resources_provider)
                try:
                    sheet.setCanceledOnTouchOutside(False)
                except Exception:
                    pass
                sheet.setPipetteDelegate(self._docky_color_picker_pipette)
                sheet.setColor(initial_color)
                sheet.setColorListener(self._docky_color_picker_consumer)
                return run_on_ui_thread(sheet.show)
            except Exception:
                pass

            from org.telegram.ui.Components import ColorPicker
            ColorPickerDelegate = find_class("org.telegram.ui.Components.ColorPicker$ColorPickerDelegate")
            selected = {"color": initial_color}
            ColorPickerDelegateProxy = dynamic_proxy(ColorPickerDelegate)

            class _PickerDelegate(ColorPickerDelegateProxy):
                def __init__(self):
                    super().__init__()
                def setColor(self, color, num, applyNow):
                    try:
                        selected["color"] = int(color)
                    except Exception:
                        pass

            self._docky_color_picker_delegate = _PickerDelegate()
            picker = ColorPicker(act, False, self._docky_color_picker_delegate)
            try:
                picker.setColor(initial_color, 0)
            except Exception:
                pass

            def _save_and_close(b, _w):
                try:
                    b.dismiss()
                except Exception:
                    pass
                self.set_setting("docky_sidebar_bg_color", "#{:06X}".format(int(selected["color"]) & 0xFFFFFF))
                self._refresh_sidebar_bg_only()
                BulletinHelper.show_success(self._tr("settings_sidebar_bg_done"))

            builder = AlertDialogBuilder(act).set_title(self._tr("settings_sidebar_bg")).set_view(picker)
            builder.set_positive_button("OK", _save_and_close)
            builder.set_negative_button(self._tr("cancel"), lambda b, _w: b.dismiss() if b else None)
            builder.show()
        except Exception as e:
            self._dlog("sidebar color picker fail: {0}".format(e))

