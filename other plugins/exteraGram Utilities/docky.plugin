    def _favorites(self):
        try:
            raw = self.get_setting("chats_favorites", [])
            if not isinstance(raw, list):
                return []
            try:
                sig = json.dumps(raw, ensure_ascii=True, sort_keys=True, separators=(",", ":"))
            except Exception:
                sig = str(raw)
            if sig == str(self._favorites_cache_sig or "") and isinstance(self._favorites_cache_list, list):
                return [dict(x) for x in self._favorites_cache_list]
            out = []
            for item in raw:
                try:
                    if not isinstance(item, dict):
                        continue
                    did = int(item.get("dialog_id", 0) or 0)
                    nm = str(item.get("name", "") or "").strip()
                    meta = {}
                    try:
                        meta = dict(self._meta_cache.get(self._target_key(item)) or {})
                    except Exception:
                        meta = {}
                    if did < 0:
                        cid = int(self._dialog_to_chat_id(did) or 0)
                        cpeer = int(self._i32(cid) if cid > 0 else 0)
                        if cid <= 0:
                            cid = int(item.get("chat_id", 0) or 0)
                        if cid <= 0:
                            cid = int(meta.get("chat_id", 0) or 0)
                        if cpeer == 0:
                            cpeer = int(item.get("chat_peer", 0) or 0)
                        if cpeer == 0:
                            cpeer = int(meta.get("chat_peer", 0) or 0)
                        if not nm:
                            nm = str(meta.get("name", "") or "").strip()
                        if cid > 0:
                            it = {"chat_id": int(cid), "dialog_id": int(did)}
                            if cpeer != 0:
                                it["chat_peer"] = int(cpeer)
                            if nm:
                                it["name"] = nm
                            out.append(it)
                        continue
                    if did > 0:
                        uid = int(self._dialog_to_user_id(did) or 0)
                        if uid <= 0:
                            uid = int(item.get("user_id", 0) or 0)
                        if uid <= 0:
                            uid = int(meta.get("user_id", 0) or 0)
                        if not nm:
                            nm = str(meta.get("name", "") or "").strip()
                        if uid > 0:
                            it = {"user_id": int(uid), "dialog_id": int(did)}
                            if nm:
                                it["name"] = nm
                            out.append(it)
                        continue
                    if int(item.get("chat_id", 0) or 0) > 0:
                        it = {"chat_id": int(item.get("chat_id", 0))}
                        if not nm:
                            nm = str(meta.get("name", "") or "").strip()
                        if nm:
                            it["name"] = nm
                        out.append(it)
                        continue
                    if int(item.get("user_id", 0) or 0) > 0:
                        it = {"user_id": int(item.get("user_id", 0))}
                        if not nm:
                            nm = str(meta.get("name", "") or "").strip()
                        if nm:
                            it["name"] = nm
                        out.append(it)
                except Exception:
                    pass
            # dedupe keeping order
            seen = set()
            dedup = []
            for it in out:
                if int(it.get("dialog_id", 0) or 0) != 0:
                    key = ("dialog_id", int(it.get("dialog_id", 0)))
                else:
                    key = ("chat_id", int(it.get("chat_id", 0))) if int(it.get("chat_id", 0)) != 0 else ("user_id", int(it.get("user_id", 0)))
                if key in seen:
                    continue
                seen.add(key)
                dedup.append(dict(it))
            dedup = dedup[:20]
            self._favorites_cache_sig = sig
            self._favorites_cache_list = [dict(x) for x in dedup]
            return [dict(x) for x in dedup]
        except Exception:
            return []

    def _save_favorites(self, items):
        try:
            for it in list(items or []):
                try:
                    self._update_target_meta_cache(dict(it), resolved_name=str(it.get("name", "") or "").strip())
                except Exception:
                    pass
            self.set_setting("chats_favorites", list(items or []))
            self._invalidate_favorites_cache()
        except Exception:
            pass

    def _add_favorite_target(self, target):
        try:
            if not isinstance(target, dict):
                return False
            source_fragment = None
            try:
                source_fragment = self._current_fragment
            except Exception:
                source_fragment = None
            chat_id = int(target.get("chat_id", 0) or 0)
            user_id = int(target.get("user_id", 0) or 0)
            dialog_id = int(target.get("dialog_id", 0) or 0)
            if chat_id == 0 and user_id == 0:
                return False
            items = self._favorites()
            for it in items:
                if chat_id != 0 and int(it.get("chat_id", 0) or 0) == chat_id:
                    BulletinHelper.show_info(self._tr("already_added"))
                    return False
                if user_id != 0 and int(it.get("user_id", 0) or 0) == user_id:
                    BulletinHelper.show_info(self._tr("already_added"))
                    return False
            if chat_id != 0:
                it = {"chat_id": int(chat_id)}
                it["chat_peer"] = int(self._i32(chat_id))
            else:
                it = {"user_id": int(user_id)}
            if dialog_id != 0:
                it["dialog_id"] = int(dialog_id)
            nm = str(target.get("name", "") or "").strip()
            if user_id != 0 and not nm and source_fragment is not None:
                try:
                    mc = get_messages_controller()
                except Exception:
                    mc = None
                try:
                    uobj = self._resolve_fragment_user(source_fragment, user_id, mc=mc)
                except Exception:
                    uobj = None
                nm = self._user_display_name_from_obj(uobj)
                if nm:
                    it["name"] = str(nm)
                    self._seed_target_runtime_cache(it, kind="user", obj=uobj, resolved_name=nm)
            if not nm:
                nm = self._resolve_target_name(it)
            if (not nm) and dialog_id != 0:
                nm = self._dialog_title_by_id(dialog_id)
            if nm:
                it["name"] = str(nm)
            if user_id != 0 and source_fragment is not None:
                try:
                    mc = get_messages_controller()
                except Exception:
                    mc = None
                try:
                    uobj = self._resolve_fragment_user(source_fragment, user_id, mc=mc)
                except Exception:
                    uobj = None
                if uobj is not None:
                    self._seed_target_runtime_cache(it, kind="user", obj=uobj, resolved_name=nm)
                else:
                    self._update_target_meta_cache(it, resolved_name=nm)
            else:
                self._update_target_meta_cache(it, resolved_name=nm)
            items.append(it)
            self._save_favorites(items)
            self._dlog("favorite added target={0}".format(str(items[-1])))
            BulletinHelper.show_success(self._tr("favorite_added"))
            try:
                hint_setting = str(self._favorite_visibility_hint_setting(it, source_fragment) or "").strip()
                if hint_setting:
                    BulletinHelper.show_info(str(self._tr("visibility_enable_hint_fmt")).format(setting=hint_setting))
            except Exception:
                pass
            try:
                self._telemetry_queue_event("feature_use", feature="docky_favorite_add", count=1, force_flush=False)
            except Exception:
                pass
            self._refresh_sidebar()
            return True
        except Exception as e:
            self._dlog("add favorite fail: {0}".format(e))
            return False

    def _remove_favorite(self, target):
        try:
            if not isinstance(target, dict):
                return
            chat_id = int(target.get("chat_id", 0) or 0)
            user_id = int(target.get("user_id", 0) or 0)
            items = self._favorites()
            if chat_id != 0:
                out = [x for x in items if int(x.get("chat_id", 0) or 0) != chat_id]
            else:
                out = [x for x in items if int(x.get("user_id", 0) or 0) != user_id]
            self._save_favorites(out)
            self._remove_target_meta_cache(target)
            self._dlog("favorite removed target={0}".format(str(target)))
            BulletinHelper.show_info(self._tr("favorite_removed"))
            try:
                self._telemetry_queue_event("feature_use", feature="docky_favorite_remove", count=1, force_flush=False)
            except Exception:
                pass
            self._refresh_sidebar()
        except Exception as e:
            self._dlog("remove favorite fail: {0}".format(e))

    def _hook_chat_activity(self):
        try:
            cls = JClass.forName("org.telegram.ui.ChatActivity")
        except Exception as e:
            self._dlog("ChatActivity resolve fail: {0}".format(e))
            return
        try:
            ctx_cls = self._resolve_class("android.content.Context")
            if ctx_cls is None:
                self._dlog("hook createView skipped: Context class unavailable")
            else:
                m = cls.getDeclaredMethod("createView", ctx_cls)
                m.setAccessible(True)
                r = self.hook_method(m, _ChatCreateHook(self))
                if r is not None:
                    self._refs.append(r)
        except Exception as e:
            self._dlog("hook createView fail: {0}".format(e))
        try:
            m = cls.getDeclaredMethod("onResume")
            m.setAccessible(True)
            r = self.hook_method(m, _ChatResumeHook(self))
            if r is not None:
                self._refs.append(r)
        except Exception as e:
            self._dlog("hook onResume fail: {0}".format(e))
        try:
            m = cls.getDeclaredMethod("onPause")
            m.setAccessible(True)
            r = self.hook_method(m, _ChatPauseHook(self))
            if r is not None:
                self._refs.append(r)
        except Exception as e:
            self._dlog("hook onPause fail: {0}".format(e))

    def _hook_dialogs_activity(self):
        try:
            cls = JClass.forName("org.telegram.ui.DialogsActivity")
        except Exception as e:
            self._dlog("DialogsActivity resolve fail: {0}".format(e))
            return
        try:
            ctx_cls = self._resolve_class("android.content.Context")
            if ctx_cls is None:
                self._dlog("dialogs hook createView skipped: Context class unavailable")
            else:
                m = cls.getDeclaredMethod("createView", ctx_cls)
                m.setAccessible(True)
                r = self.hook_method(m, _DialogsCreateHook(self))
                if r is not None:
                    self._refs.append(r)
        except Exception as e:
            self._dlog("dialogs hook createView fail: {0}".format(e))
        try:
            m = cls.getDeclaredMethod("onResume")
            m.setAccessible(True)
            r = self.hook_method(m, _DialogsResumeHook(self))
            if r is not None:
                self._refs.append(r)
        except Exception as e:
            self._dlog("dialogs hook onResume fail: {0}".format(e))
        try:
            m = cls.getDeclaredMethod("onPause")
            m.setAccessible(True)
            r = self.hook_method(m, _DialogsPauseHook(self))
            if r is not None:
                self._refs.append(r)
        except Exception as e:
            self._dlog("dialogs hook onPause fail: {0}".format(e))

    def _remember_dialogs_fragment(self, fragment):
        try:
            if fragment is None:
                return
            if "DialogsActivity" not in str(fragment.getClass().getName()):
                return
            self._enter_non_chat_idle_mode()
            self._dialogs_fragment = fragment
            self._dlog("dialogs fragment remembered")
        except Exception:
            pass

    def _forget_dialogs_fragment(self, fragment):
        try:
            if fragment is None:
                return
            if self._dialogs_fragment == fragment:
                self._dialogs_fragment = None
                self._detach_dialogs_widget()
                self._dlog("dialogs fragment forgotten")
        except Exception:
            pass

    def _enter_non_chat_idle_mode(self):
        try:
            self._detach_sidebar()
        except Exception:
            pass
        try:
            self._current_fragment = None
        except Exception:
            pass
        try:
            if self._adaptive_runnable is not None:
                AndroidUtilities.cancelRunOnUIThread(self._adaptive_runnable)
        except Exception:
            pass

    def _get_fragment_view(self, fragment):
        try:
            if fragment is None:
                return None
            try:
                cls = fragment.getClass()
                while cls is not None:
                    try:
                        fld = cls.getDeclaredField("contentView")
                        fld.setAccessible(True)
                        v = fld.get(fragment)
                        if v is not None:
                            return v
                    except Exception:
                        pass
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
            except Exception:
                pass
            try:
                v = fragment.getFragmentView()
                if v is not None:
                    return v
            except Exception:
                pass
            cls = fragment.getClass()
            while cls is not None:
                try:
                    fld = cls.getDeclaredField("fragmentView")
                    fld.setAccessible(True)
                    v = fld.get(fragment)
                    if v is not None:
                        return v
                except Exception:
                    pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return None
        except Exception:
            return None

    def _get_dialog_id(self, fragment):
        try:
            if fragment is None:
                return 0
            try:
                if hasattr(fragment, "getDialogId"):
                    did = int(fragment.getDialogId())
                    if did != 0:
                        return int(did)
            except Exception:
                pass
            cls = fragment.getClass()
            while cls is not None:
                for name in ("dialog_id", "dialogId"):
                    try:
                        fld = cls.getDeclaredField(name)
                        fld.setAccessible(True)
                        return int(fld.getLong(fragment))
                    except Exception:
                        pass
                try:
                    cls = cls.getSuperclass()
                except Exception:
                    cls = None
            return 0
        except Exception:
            return 0

    def _dialog_to_chat_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did <= -1000000000000:
                cid = int(abs(did) - 1000000000000)
                return int(cid) if cid > 0 else 0
            if did < 0:
                return int(abs(did))
            return 0
        except Exception:
            return 0

    def _dialog_to_user_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did <= 0:
                return 0
            # packed dialog_id: low 32 bits store peer id
            if did > 2147483647:
                low = int(did & 0xFFFFFFFF)
                if low >= 0x80000000:
                    low -= 0x100000000
                return int(low) if low > 0 else 0
            return int(did)
        except Exception:
            return 0

    def _resolve_target_peer(self, target):
        try:
            if not isinstance(target, dict):
                return (None, None)
            mc = None
            try:
                mc = get_messages_controller()
            except Exception:
                mc = None
            if mc is None:
                UserConfig = jclass("org.telegram.messenger.UserConfig")
                MessagesController = jclass("org.telegram.messenger.MessagesController")
                account = int(UserConfig.selectedAccount)
                mc = MessagesController.getInstance(account)

            def resolve_user(uid):
                try:
                    raw_uid = int(uid or 0)
                except Exception:
                    raw_uid = 0
                if raw_uid <= 0:
                    return None
                candidates = []
                try:
                    pjid = self._peer_java_int(raw_uid)
                    if pjid not in (None, 0):
                        candidates.append(int(pjid))
                except Exception:
                    pass
                try:
                    sjid = self._safe_java_int(raw_uid)
                    if sjid not in (None, 0):
                        candidates.append(int(sjid))
                except Exception:
                    pass
                candidates.append(int(raw_uid))
                seen = set()
                for cand in candidates:
                    if cand == 0 or cand in seen:
                        continue
                    seen.add(cand)
                    try:
                        user = mc.getUser(int(cand))
                        self._dlog("resolve user try cand={0} found={1}".format(int(cand), bool(user is not None)))
                        if user is not None:
                            return user
                    except Exception:
                        pass
                return None

            did = int(target.get("dialog_id", 0) or 0)
            self._dlog("resolve peer start target={0}".format(str(target)))
            if did < 0:
                cid = int(self._dialog_to_chat_id(did) or 0)
                cpeer = int(target.get("chat_peer", 0) or 0)
                candidates = []
                if cpeer != 0:
                    candidates.append(int(cpeer))
                if cid > 0:
                    candidates.append(int(cid))
                    pj = self._peer_java_int(cid)
                    if pj is not None:
                        candidates.append(int(pj))
                        candidates.append(int(-pj))
                    candidates.append(int(self._i32(cid)))
                    candidates.append(int(-self._i32(cid)))
                candidates.append(int(self._i32(abs(int(did)))))
                candidates.append(int(-self._i32(abs(int(did)))))
                self._dlog("resolve chat did={0} cid={1} cpeer={2} candidates={3}".format(int(did), int(cid), int(cpeer), str(candidates)))
                seen = set()
                for cand in candidates:
                    if cand == 0 or cand in seen:
                        continue
                    seen.add(cand)
                    try:
                        ch = mc.getChat(int(cand))
                        self._dlog("resolve chat try cand={0} found={1}".format(int(cand), bool(ch is not None)))
                        if ch is not None:
                            try:
                                self._dlog("resolve chat ok cand={0} title={1}".format(int(cand), str(getattr(ch, "title", "") or "")))
                            except Exception:
                                pass
                            return ("chat", ch)
                    except Exception:
                        self._dlog("resolve chat error cand={0}".format(int(cand)))
                        pass
                try:
                    ch_abs = mc.getChat(abs(int(did)))
                    self._dlog("resolve chat abs(did)={0} found={1}".format(abs(int(did)), bool(ch_abs is not None)))
                    if ch_abs is not None:
                        return ("chat", ch_abs)
                except Exception:
                    pass
            elif did > 0:
                uid = int(self._dialog_to_user_id(did) or 0)
                self._dlog("resolve user did={0} uid={1}".format(int(did), int(uid)))
                if uid > 0:
                    u = resolve_user(uid)
                    self._dlog("resolve user found={0}".format(bool(u is not None)))
                    if u is not None:
                        return ("user", u)

            cid = int(target.get("chat_id", 0) or 0)
            if cid > 0:
                ch = mc.getChat(self._peer_java_int(cid))
                self._dlog("resolve fallback chat_id={0} found={1}".format(int(cid), bool(ch is not None)))
                if ch is not None:
                    return ("chat", ch)

            uid = int(target.get("user_id", 0) or 0)
            if uid > 0:
                u = resolve_user(uid)
                self._dlog("resolve fallback user_id={0} found={1}".format(int(uid), bool(u is not None)))
                if u is not None:
                    return ("user", u)
            self._dlog("resolve peer none target={0}".format(str(target)))
            return (None, None)
        except Exception:
            try:
                self._dlog("resolve peer exception target={0}".format(str(target)))
            except Exception:
                pass
            return (None, None)

    def _dialog_title_by_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                return ""
            mc = None
            try:
                mc = get_messages_controller()
            except Exception:
                mc = None
            if mc is None:
                return ""
            if did < 0:
                cid = int(self._dialog_to_chat_id(did) or 0)
                chat = None
                if cid > 0:
                    try:
                        peer_cid = self._peer_java_int(cid)
                        chat = mc.getChat(peer_cid) if peer_cid is not None else None
                    except Exception:
                        chat = None
                if chat is None:
                    try:
                        peer_did = self._peer_java_int(abs(int(did)))
                        chat = mc.getChat(peer_did) if peer_did is not None else None
                    except Exception:
                        chat = None
                if chat is not None:
                    return str(getattr(chat, "title", "") or "").strip()
                return ""
            uid = int(self._dialog_to_user_id(did) or did)
            u = None
            try:
                peer_uid = self._peer_java_int(uid)
                u = mc.getUser(peer_uid) if peer_uid is not None else None
            except Exception:
                u = None
            if u is not None:
                return str(getattr(u, "first_name", "") or getattr(u, "username", "") or "").strip()
            return ""
        except Exception:
            return ""

    def _resolve_target_title(self, target):
        try:
            kind, obj = self._resolve_target_peer(target)
            if kind == "chat" and obj is not None:
                title = self._truncate(str(getattr(obj, "title", "") or "").strip(), 11)
                self._dlog("resolve title chat={0}".format(str(title)))
                return title
            if kind == "user" and obj is not None:
                nm = str(getattr(obj, "first_name", "") or getattr(obj, "username", "") or "").strip()
                out = self._truncate(nm, 11) if nm else ""
                self._dlog("resolve title user={0}".format(str(out)))
                return out
            self._dlog("resolve title empty target={0}".format(str(target)))
            return ""
        except Exception:
            try:
                self._dlog("resolve title exception target={0}".format(str(target)))
            except Exception:
                pass
            return ""

    def _user_display_name_from_obj(self, user):
        try:
            if user is None:
                return ""
            first = str(getattr(user, "first_name", "") or "").strip()
            last = str(getattr(user, "last_name", "") or "").strip()
            username = str(getattr(user, "username", "") or "").strip()
            full = "{0} {1}".format(first, last).strip()
            return full or first or username or ""
        except Exception:
            return ""

    def _current_target(self, fragment):
        try:
            if fragment is None:
                return None
            did = int(self._get_dialog_id(fragment) or 0)
            args = None
            try:
                args = fragment.getArguments()
            except Exception:
                args = None
            mc = None
            try:
                mc = get_messages_controller()
            except Exception:
                mc = None

            rich_uid = 0
            rich_user = None
            if args is not None:
                try:
                    rich_uid = int(args.getLong("user_id", 0))
                except Exception:
                    rich_uid = 0
            if did > 0 and rich_uid == 0:
                try:
                    rich_uid = int(self._dialog_to_user_id(did) or 0)
                except Exception:
                    rich_uid = 0
            if rich_uid > 0:
                try:
                    rich_user = self._resolve_fragment_user(fragment, rich_uid, mc=mc)
                except Exception:
                    rich_user = None

            if did != 0:
                t = {"dialog_id": int(did)}
                if did > 0:
                    uid = int(rich_uid or self._dialog_to_user_id(did) or 0)
                    if uid > 0:
                        t["user_id"] = int(uid)
                        nm = self._user_display_name_from_obj(rich_user)
                        if nm:
                            t["name"] = nm
                            self._seed_target_runtime_cache(t, kind="user", obj=rich_user, resolved_name=nm)
                if did < 0:
                    cid = int(self._dialog_to_chat_id(did) or 0)
                    if cid > 0:
                        t["chat_id"] = int(cid)
                return t
            if args is not None:
                try:
                    cid = int(args.getLong("chat_id", 0))
                except Exception:
                    cid = 0
                if cid != 0:
                    t = {"chat_id": int(cid)}
                    if did != 0:
                        t["dialog_id"] = int(did)
                    return t
                try:
                    uid = int(args.getLong("user_id", 0))
                except Exception:
                    uid = 0
                if uid != 0:
                    t = {"user_id": int(uid)}
                    if did != 0:
                        t["dialog_id"] = int(did)
                    user = None
                    try:
                        user = rich_user if int(rich_uid or 0) == int(uid) else self._resolve_fragment_user(fragment, uid, mc=mc)
                    except Exception:
                        user = None
                    nm = self._user_display_name_from_obj(user)
                    if nm:
                        t["name"] = nm
                        self._seed_target_runtime_cache(t, kind="user", obj=user, resolved_name=nm)
                    return t
            if did > 0:
                uid = int(rich_uid or self._dialog_to_user_id(did) or 0)
                if uid > 0:
                    t = {"user_id": int(uid), "dialog_id": int(did)}
                    nm = self._user_display_name_from_obj(rich_user)
                    if nm:
                        t["name"] = nm
                        self._seed_target_runtime_cache(t, kind="user", obj=rich_user, resolved_name=nm)
                    return t
            if did < 0:
                cid = int(self._dialog_to_chat_id(did) or 0)
                if cid > 0:
                    return {"chat_id": int(cid), "dialog_id": int(did)}
                if abs(int(did)) <= 2147483647:
                    return {"chat_id": int(-did), "dialog_id": int(did)}
            return None
        except Exception:
            return None

    def _encrypted_chat_id(self, fragment):
        try:
            if fragment is None:
                return 0
            args = None
            try:
                args = fragment.getArguments()
            except Exception:
                args = None
            if args is None:
                return 0
            for key in ("enc_id", "encrypted_chat_id"):
                try:
                    val = int(args.getInt(key, 0))
                except Exception:
                    val = 0
                if val != 0:
                    return int(val)
            return 0
        except Exception:
            return 0

    def _resolve_fragment_user(self, fragment, uid, mc=None):
        try:
            user = None
            if mc is not None:
                try:
                    safe_uid = self._peer_java_int(uid)
                    user = mc.getUser(safe_uid) if safe_uid is not None and safe_uid != 0 else None
                except Exception:
                    user = None
            if user is not None:
                return user
            if fragment is not None:
                cls = fragment.getClass()
                while cls is not None:
                    for field_name in ("currentUser", "user"):
                        try:
                            fld = cls.getDeclaredField(field_name)
                            fld.setAccessible(True)
                            user = fld.get(fragment)
                            if user is not None:
                                return user
                        except Exception:
                            pass
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
            return None
        except Exception:
            return None

    def _resolve_fragment_chat(self, fragment, cid, mc=None):
        try:
            chat = None
            if mc is not None:
                try:
                    safe_cid = self._peer_java_int(cid)
                    chat = mc.getChat(safe_cid) if safe_cid is not None and safe_cid != 0 else None
                except Exception:
                    chat = None
            if chat is not None:
                return chat
            if fragment is not None:
                cls = fragment.getClass()
                while cls is not None:
                    for field_name in ("currentChat", "chat"):
                        try:
                            fld = cls.getDeclaredField(field_name)
                            fld.setAccessible(True)
                            chat = fld.get(fragment)
                            if chat is not None:
                                return chat
                        except Exception:
                            pass
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
            return None
        except Exception:
            return None

    def _docky_context_allowed(self, fragment):
        try:
            if fragment is None:
                return False
            enc_id = int(self._encrypted_chat_id(fragment) or 0)
            if enc_id != 0:
                return bool(self._show_secret_enabled())

            mc = None
            try:
                mc = get_messages_controller()
            except Exception:
                mc = None
            if mc is None:
                UserConfig = jclass("org.telegram.messenger.UserConfig")
                MessagesController = jclass("org.telegram.messenger.MessagesController")
                account = int(UserConfig.selectedAccount)
                mc = MessagesController.getInstance(account)

            target = self._current_target(fragment)
            if not isinstance(target, dict):
                target = {}

            uid = int(target.get("user_id", 0) or self._dialog_to_user_id(self._get_dialog_id(fragment)) or 0)
            cid = int(target.get("chat_id", 0) or self._dialog_to_chat_id(self._get_dialog_id(fragment)) or 0)

            user = self._resolve_fragment_user(fragment, uid, mc)
            if user is not None:
                is_bot = False
                try:
                    UserObject = jclass("org.telegram.messenger.UserObject")
                    try:
                        is_bot = bool(UserObject.isBot(user))
                    except Exception:
                        is_bot = bool(getattr(user, "bot", False))
                except Exception:
                    is_bot = bool(getattr(user, "bot", False))
                self._dlog("context user detected bot={0} uid={1}".format(bool(is_bot), int(getattr(user, "id", uid) or 0)))
                if is_bot:
                    return bool(self._show_bots_enabled())
                return bool(self._show_private_enabled())

            chat = self._resolve_fragment_chat(fragment, cid, mc)
            if chat is not None:
                is_forum = False
                is_channel = False
                try:
                    ChatObject = jclass("org.telegram.messenger.ChatObject")
                    try:
                        is_forum = bool(ChatObject.isForum(chat))
                    except Exception:
                        is_forum = bool(getattr(chat, "forum", False))
                    try:
                        is_channel = bool(ChatObject.isChannel(chat))
                    except Exception:
                        is_channel = bool(getattr(chat, "broadcast", False))
                except Exception:
                    is_forum = bool(getattr(chat, "forum", False))
                    is_channel = bool(getattr(chat, "broadcast", False))
                is_megagroup = bool(getattr(chat, "megagroup", False))
                self._dlog("context chat detected forum={0} channel={1} megagroup={2} cid={3}".format(bool(is_forum), bool(is_channel), bool(is_megagroup), int(getattr(chat, "id", cid) or 0)))
                if is_forum:
                    return bool(self._show_topics_enabled())
                if is_channel and not is_megagroup:
                    return bool(self._show_channels_enabled())
                return True

            if uid != 0:
                self._dlog("context fallback private uid={0}".format(int(uid)))
                return bool(self._show_private_enabled())
            if cid != 0:
                self._dlog("context fallback group/chat cid={0}".format(int(cid)))
                return True

            return True
        except Exception:
            return True

    def _favorite_visibility_hint_setting(self, target, fragment=None):
        try:
            if not isinstance(target, dict):
                return ""
            if fragment is not None:
                try:
                    enc_id = int(self._encrypted_chat_id(fragment) or 0)
                except Exception:
                    enc_id = 0
                if enc_id != 0 and not self._show_secret_enabled():
                    return str(self._tr("settings_secret") or "")

            mc = None
            try:
                mc = get_messages_controller()
            except Exception:
                mc = None

            uid = int(target.get("user_id", 0) or 0)
            if uid > 0:
                user = None
                try:
                    user = self._resolve_fragment_user(fragment, uid, mc=mc) if fragment is not None else None
                except Exception:
                    user = None
                if user is None:
                    try:
                        _kind, user = self._resolve_target_peer(target)
                    except Exception:
                        user = None
                is_bot = False
                try:
                    UserObject = jclass("org.telegram.messenger.UserObject")
                    try:
                        is_bot = bool(UserObject.isBot(user))
                    except Exception:
                        is_bot = bool(getattr(user, "bot", False))
                except Exception:
                    is_bot = bool(getattr(user, "bot", False))
                if is_bot and not self._show_bots_enabled():
                    return str(self._tr("settings_bots") or "")
                if not self._show_private_enabled():
                    return str(self._tr("settings_private") or "")
                return ""

            cid = int(target.get("chat_id", 0) or 0)
            if cid > 0:
                chat = None
                try:
                    chat = self._resolve_fragment_chat(fragment, cid, mc=mc) if fragment is not None else None
                except Exception:
                    chat = None
                if chat is None:
                    try:
                        _kind, chat = self._resolve_target_peer(target)
                    except Exception:
                        chat = None
                if chat is not None:
                    is_forum = False
                    is_channel = False
                    try:
                        ChatObject = jclass("org.telegram.messenger.ChatObject")
                        try:
                            is_forum = bool(ChatObject.isForum(chat))
                        except Exception:
                            is_forum = bool(getattr(chat, "forum", False))
                        try:
                            is_channel = bool(ChatObject.isChannel(chat))
                        except Exception:
                            is_channel = bool(getattr(chat, "broadcast", False))
                    except Exception:
                        is_forum = bool(getattr(chat, "forum", False))
                        is_channel = bool(getattr(chat, "broadcast", False))
                    is_megagroup = bool(getattr(chat, "megagroup", False))
                    if is_forum and not self._show_topics_enabled():
                        return str(self._tr("settings_topics") or "")
                    if is_channel and not is_megagroup and not self._show_channels_enabled():
                        return str(self._tr("settings_channels") or "")
            return ""
        except Exception:
            return ""

    def _normalize_dialog_id(self, did):
        try:
            v = int(did or 0)
            if v == 0:
                return 0
            # If app provides packed dialog_id (64-bit), extract peer id from low 32 bits.
            if v > 2147483647 or v < -2147483648:
                low = int(v & 0xFFFFFFFF)
                if low >= 0x80000000:
                    low -= 0x100000000
                if low != 0:
                    return int(low)
            return int(v)
        except Exception:
            return 0

    def _safe_java_int(self, v):
        try:
            x = int(v)
            if x > 2147483647 or x < -2147483648:
                return None
            return int(x)
        except Exception:
            return None

    def _peer_java_int(self, v):
        try:
            x = int(v)
            if -2147483648 <= x <= 2147483647:
                return int(x)
            y = int(self._i32(x))
            return int(y) if y != 0 else None
        except Exception:
            return None

    def _truncate(self, text, n):
        t = str(text or "").strip()
        if len(t) <= int(n):
            return t
        return t[: max(1, int(n) - 3)] + "..."

    def _i32(self, v):
        try:
            x = int(v) & 0xFFFFFFFF
            if x >= 0x80000000:
                x -= 0x100000000
            return int(x)
        except Exception:
            return 0

    def _display_name(self, dialog_id):
        did = int(self._normalize_dialog_id(dialog_id))
        if did == 0:
            return "?"
        try:
            cached = self._dialog_name_cache.get("d:{0}".format(int(did)))
            if cached:
                return self._truncate(str(cached), 11)
            if did > 0:
                cached = self._dialog_name_cache.get("u:{0}".format(int(did)))
                if cached:
                    return self._truncate(str(cached), 11)
            else:
                cached = self._dialog_name_cache.get("c:{0}".format(int(-did)))
                if cached:
                    return self._truncate(str(cached), 11)
        except Exception:
            pass
        try:
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            MessagesController = jclass("org.telegram.messenger.MessagesController")
            account = int(UserConfig.selectedAccount)
            mc = MessagesController.getInstance(account)
            if did > 0:
                try:
                    uid = self._peer_java_int(did)
                    u = mc.getUser(uid) if uid is not None else None
                    if u is not None:
                        nm = str(getattr(u, "first_name", "") or getattr(u, "username", "") or "")
                        if nm.strip():
                            self._dialog_name_cache["d:{0}".format(int(did))] = str(nm).strip()
                            self._dialog_name_cache["u:{0}".format(int(did))] = str(nm).strip()
                            return self._truncate(nm, 11)
                except Exception:
                    pass
                return self._truncate("U{0}".format(did), 11)
            cid = int(-did)
            try:
                chat_id = self._peer_java_int(cid)
                ch = mc.getChat(chat_id) if chat_id is not None else None
                if ch is not None:
                    nm = str(getattr(ch, "title", "") or "")
                    if nm.strip():
                        self._dialog_name_cache["d:{0}".format(int(did))] = str(nm).strip()
                        self._dialog_name_cache["c:{0}".format(int(cid))] = str(nm).strip()
                        return self._truncate(nm, 11)
            except Exception:
                pass
            return self._truncate("C{0}".format(cid), 11)
        except Exception:
            return self._truncate(str(did), 11)

    def _display_name_target(self, target):
        try:
            if not isinstance(target, dict):
                return "?"
            nm = str(target.get("name", "") or "").strip()
            if nm:
                return self._truncate(nm, 11)
            rt = self._resolve_target_title(target)
            if rt:
                return rt
            if int(target.get("chat_id", 0) or 0) != 0:
                did = int(target.get("dialog_id", 0) or 0)
                if did < 0:
                    chat_name = self._display_name(int(did))
                    if chat_name and not str(chat_name).startswith(("U", "C")):
                        return chat_name
                return ""
            if int(target.get("user_id", 0) or 0) != 0:
                return self._display_name(int(target.get("user_id", 0)))
            return ""
        except Exception:
            return ""

    def _resolve_target_name(self, target):
        try:
            rt = self._resolve_target_title(target)
            if rt:
                return rt
            t = self._display_name_target(target)
            if str(t).startswith(("U", "C")):
                return ""
            return t
        except Exception:
            return ""

    def _target_key(self, target):
        try:
            if not isinstance(target, dict):
                return ""
            did = int(target.get("dialog_id", 0) or 0)
            if did != 0:
                return "d:{0}".format(int(did))
            cid = int(target.get("chat_id", 0) or 0)
            if cid != 0:
                return "c:{0}".format(int(cid))
            uid = int(target.get("user_id", 0) or 0)
            if uid != 0:
                return "u:{0}".format(int(uid))
            return ""
        except Exception:
            return ""

    def _pill_bg(self):
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(18)))
        try:
            c = int(self._sidebar_bg_color())
        except Exception:
            c = 0xCC1C2A3A
        try:
            bg.setColor(self._i32((0xDD << 24) | (c & 0x00FFFFFF)))
        except Exception as e:
            self._dlog("pill bg color fail: {0}".format(e))
        return bg

    def _icon_chip_bg(self):
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        try:
            c = int(self._sidebar_bg_color())
        except Exception:
            c = 0xFF243247
        bg.setColor(self._i32((0x66 << 24) | (c & 0x00FFFFFF)))
        return bg

    def _compact_chip_bg(self):
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(22)))
        try:
            c = int(self._sidebar_bg_color())
        except Exception:
            c = 0xFF243247
        bg.setColor(self._i32((0xCC << 24) | (c & 0x00FFFFFF)))
        return bg

    def _sidebar_bg_color(self):
        try:
            raw = str(self.get_setting("docky_sidebar_bg_color", "") or "").strip()
            if raw:
                return int(Color.parseColor(raw))
        except Exception:
            pass
        try:
            return int(Theme.getColor(Theme.key_dialogBackground))
        except Exception:
            return 0xFF243247

    def _docky_icon_color(self):
        try:
            raw = str(self.get_setting("docky_icon_color", "") or "").strip()
            if raw:
                return int(Color.parseColor(raw))
        except Exception:
            pass
        try:
            return int(Theme.getColor(Theme.key_dialogTextBlue2))
        except Exception:
            return 0xFF66B4FF

    def _docky_text_color(self):
        try:
            raw = str(self.get_setting("docky_text_color", "") or "").strip()
            if raw:
                return int(Color.parseColor(raw))
        except Exception:
            pass
        try:
            return int(Theme.getColor(Theme.key_dialogTextBlack))
        except Exception:
            return 0xFFD6E2F5

    def _nav_bg_color(self):
        try:
            raw = str(self.get_setting("docky_nav_bg_color", "") or "").strip()
            if raw:
                return int(Color.parseColor(raw))
        except Exception:
            pass
        return int(self._sidebar_bg_color())

    def _nav_button_color(self):
        try:
            raw = str(self.get_setting("docky_nav_button_color", "") or "").strip()
            if raw:
                return int(Color.parseColor(raw))
        except Exception:
            pass
        try:
            return int(Theme.getColor(Theme.key_dialogBackground))
        except Exception:
            return 0xFFFFFFFF

    def _nav_button_icon_color(self):
        try:
            c = int(self._nav_button_color()) & 0x00FFFFFF
            r = (c >> 16) & 0xFF
            g = (c >> 8) & 0xFF
            b = c & 0xFF
            luminance = ((299 * r) + (587 * g) + (114 * b)) / 1000.0
            return 0xFF111111 if luminance > 180 else 0xFFFFFFFF
        except Exception:
            try:
                return int(self._docky_icon_color())
            except Exception:
                return 0xFFFFFFFF

    def _nav_panel_bg(self):
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(18)))
        try:
            c = int(self._nav_bg_color())
        except Exception:
            c = int(self._sidebar_bg_color())
        bg.setColor(self._i32((0xDD << 24) | (c & 0x00FFFFFF)))
        return bg

    def _nav_button_bg(self):
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.OVAL)
        try:
            c = int(self._nav_button_color())
        except Exception:
            c = 0xFFFFFFFF
        bg.setColor(self._i32(c))
        return bg

    def _refresh_nav_panels_only(self):
        try:
            for panel in (self._sidebar_nav_panel, self._dialogs_widget_nav_panel):
                if panel is not None:
                    panel.setBackground(self._nav_panel_bg())
            for btn in (self._sidebar_nav_up, self._sidebar_nav_down, self._dialogs_widget_nav_up, self._dialogs_widget_nav_down):
                if btn is None:
                    continue
                try:
                    btn.setBackground(self._nav_button_bg())
                except Exception:
                    pass
                try:
                    child_count = int(btn.getChildCount()) if hasattr(btn, "getChildCount") else 0
                except Exception:
                    child_count = 0
                for i in range(child_count):
                    try:
                        child = btn.getChildAt(i)
                    except Exception:
                        child = None
                    if child is None:
                        continue
                    try:
                        if isinstance(child, ImageView):
                            child.setColorFilter(self._i32(int(self._nav_button_icon_color())))
                        elif isinstance(child, TextView):
                            child.setTextColor(self._i32(int(self._nav_button_icon_color())))
                    except Exception:
                        pass
        except Exception as e:
            self._dlog("refresh nav panels fail: {0}".format(e))

    def _build_mini_control_button(self, ctx, cache_file, fallback_char, on_click):
        try:
            from android.graphics import BitmapFactory
            wrap = FrameLayout(ctx)
            wrap.setBackground(self._nav_button_bg())
            img = ImageView(ctx)
            img.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
            try:
                if os.path.exists(cache_file):
                    bmp = BitmapFactory.decodeFile(cache_file)
                    if bmp is not None:
                        img.setImageBitmap(bmp)
                img.setColorFilter(self._i32(int(self._nav_button_icon_color())))
            except Exception:
                pass
            txt = None
            try:
                if img.getDrawable() is None:
                    txt = TextView(ctx)
                    txt.setText(str(fallback_char))
                    txt.setTextSize(18.0)
                    txt.setGravity(Gravity.CENTER)
                    txt.setTextColor(self._i32(int(self._nav_button_icon_color())))
            except Exception:
                txt = None
            wrap.addView(img, FrameLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18), Gravity.CENTER))
            if txt is not None:
                wrap.addView(txt, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
            wrap.setOnClickListener(self._click_listener(on_click))
            return wrap
        except Exception as e:
            self._log_fail("build mini control button", e)
            return None

    def _refresh_sidebar_bg_only(self):
        try:
            if self._sidebar_card is not None:
                self._sidebar_card.setBackground(self._compact_chip_bg() if self._compact_enabled() else self._pill_bg())
            if self._icon_wrap is not None:
                if self._compact_enabled():
                    self._icon_wrap.setBackground(None)
                else:
                    self._icon_wrap.setBackground(self._icon_chip_bg())
            if self._icon_image is not None:
                self._icon_image.setColorFilter(self._i32(int(self._docky_icon_color())))
            self._refresh_nav_panels_only()
        except Exception as e:
            self._dlog("refresh bg fail: {0}".format(e))

    def _reset_sidebar_bg_color(self):
        try:
            self.set_setting("docky_sidebar_bg_color", "")
            self._refresh_sidebar_bg_only()
            BulletinHelper.show_success(self._tr("settings_sidebar_bg_reset_done"))
        except Exception as e:
            self._dlog("reset bg fail: {0}".format(e))

