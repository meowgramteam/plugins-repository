            card.addView(hero, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(228)))
            outer.addView(card, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            return outer
        except Exception as e:
            self._dlog("build settings header fail: {0}".format(e))
            return None

    def _build_settings_version_view(self, ctx):
        try:
            from android.widget import FrameLayout, TextView
            from android.view import Gravity
            wrap = FrameLayout(ctx)
            wrap.setBackgroundColor(0x00000000)
            wrap.setPadding(0, AndroidUtilities.dp(2), 0, AndroidUtilities.dp(4))
            tv = TextView(ctx)
            tv.setText("\nDocky • v{0}".format(str(__version__)))
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(13)
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2)))
            except Exception:
                pass
            wrap.addView(tv, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.CENTER))
            return wrap
        except Exception as e:
            self._dlog("build version view fail: {0}".format(e))
            return None

    def _inject_settings_header(self, activity, items):
        try:
            if not self._is_our_settings_activity(activity):
                return
            self._settings_activity_ref = activity
            if bool(getattr(self, "_supporters_open_pending", False)):
                self._supporters_open_pending = False
                self._inject_supporters_subfragment(activity, items)
                return
            try:
                self._inject_panel_nav_mode_slide(activity, items)
            except Exception as e:
                self._dlog("inject panel nav mode fail: {0}".format(e))
            try:
                cb = _pf(activity, "createSubFragmentCallback", None)
                if cb is not None:
                    return
            except Exception:
                pass
            has_header = False
            has_version = False
            for i in range(items.size()):
                try:
                    it = items.get(i)
                    mk = str(getattr(it, "object2", "") or "")
                    if mk == "__docky_settings_header__":
                        has_header = True
                    elif mk == "__docky_settings_version__":
                        has_version = True
                except Exception:
                    pass
            ctx = activity.getContext() if hasattr(activity, "getContext") else None
            if not ctx:
                return
            self._ensure_settings_header_assets()
            UItem = find_class("org.telegram.ui.Components.UItem")
            if UItem is None:
                return
            if not has_header:
                view = self._build_settings_header_view(ctx)
                if view is not None:
                    hi = UItem.asCustom(view)
                    hi.object2 = "__docky_settings_header__"
                    try:
                        hi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(0, hi)
            if not has_version:
                view = self._build_settings_version_view(ctx)
                if view is not None:
                    vi = UItem.asCustom(view)
                    vi.object2 = "__docky_settings_version__"
                    try:
                        vi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(vi)
        except Exception as e:
            self._dlog("inject settings header fail: {0}".format(e))

    def _is_panel_settings_items(self, items):
        try:
            if items is None:
                return False
            for i in range(items.size()):
                try:
                    it = items.get(i)
                    key = str(self._get_uitem_setting_key(it) or "").strip().lower()
                    txt = str(self._get_uitem_text(it) or "").strip().lower()
                    if key == "docky_invert_side" or txt in ("invert side", "inverter lado"):
                        return True
                except Exception:
                    pass
        except Exception:
            pass
        return False

    def _inject_panel_nav_mode_slide(self, activity, items):
        try:
            if not self._is_panel_settings_items(items):
                return
            for i in range(items.size()):
                try:
                    if str(self._get_uitem_setting_key(items.get(i)) or "") == "__docky_chat_nav_mode_slide__":
                        return
                except Exception:
                    pass
            UItem = self._resolve_class("org.telegram.ui.Components.UItem")
            Utilities = self._resolve_class("org.telegram.messenger.Utilities")
            String = self._resolve_class("java.lang.String")
            if UItem is None or Utilities is None or String is None:
                return
            insert_idx = -1
            for i in range(items.size()):
                try:
                    if str(self._get_uitem_setting_key(items.get(i)) or "") == "docky_invert_side":
                        insert_idx = i + 1
                        break
                except Exception:
                    pass
            if insert_idx < 0:
                return
            labels = [self._tr("settings_chat_nav_control"), self._tr("settings_chat_nav_swipe")]
            current = int(self._chat_nav_mode())
            CallbackInterface = Utilities.Callback
            plugin = self

            class _ChatNavSlideCallback(dynamic_proxy(CallbackInterface)):
                def run(self_cb, value):
                    try:
                        v = int(str(value))
                    except Exception:
                        v = 0
                    if v < 0:
                        v = 0
                    if v > 1:
                        v = 1
                    try:
                        plugin.set_setting("docky_chat_nav_mode", int(v))
                    except Exception:
                        pass
                    try:
                        plugin._apply_chat_nav_interaction_mode()
                    except Exception:
                        pass

            header = UItem.asShadow(self._tr("settings_chat_nav_mode"))
            header.object2 = "__docky_chat_nav_mode_divider__"
            slide_items = jarray(String)(labels)
            slide = UItem.asSlideView(slide_items, current, _ChatNavSlideCallback())
            slide.object2 = "__docky_chat_nav_mode_slide__"
            items.add(insert_idx, header)
            items.add(insert_idx + 1, slide)
            try:
                items.add(insert_idx + 2, UItem.asShadow())
            except Exception:
                pass
        except Exception as e:
            self._dlog("inject panel nav slide fail: {0}".format(e))

    def _get_uitem_setting_key(self, it):
        try:
            if it is None:
                return ""
            for name in ("object2", "object"):
                try:
                    v = getattr(it, name, None)
                    if isinstance(v, str):
                        return v
                    if v is not None:
                        s = str(v)
                        if s and s != "null":
                            return s
                except Exception:
                    pass
        except Exception:
            pass
        return ""

    def _get_uitem_text(self, it):
        try:
            if it is None:
                return ""
            try:
                v = getattr(it, "text", None)
                if v:
                    return str(v)
            except Exception:
                pass
            try:
                m = it.getClass().getMethod("getText")
                m.setAccessible(True)
                v = m.invoke(it)
                if v:
                    return str(v)
            except Exception:
                pass
            try:
                f = it.getClass().getDeclaredField("text")
                f.setAccessible(True)
                v = f.get(it)
                if v:
                    return str(v)
            except Exception:
                pass
        except Exception:
            pass
        return ""

    def _setup_settings_header_hook(self):
        try:
            PSA = self._resolve_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            if PSA is None:
                return
            arr_cls = self._resolve_class("java.util.ArrayList")
            ua_cls = self._resolve_class("org.telegram.ui.Components.UniversalAdapter")
            if arr_cls is None or ua_cls is None:
                self._dlog("settings header hook skipped: dependency class unavailable")
                return
            m = PSA.getClass().getDeclaredMethod("fillItems", arr_cls, ua_cls)
            m.setAccessible(True)
            self._settings_header_hook = self.hook_method(m, _SettingsHeaderHook(self))
            self._dlog("settings header hook ok")
        except Exception as e:
            self._dlog("settings header hook fail: {0}".format(e))

    def _show_about_sheet(self, ctx_override=None):
        try:
            from java import dynamic_proxy
            from android.widget import LinearLayout, TextView, ImageView
            from android.view import Gravity, View, ViewOutlineProvider
            from android.graphics import BitmapFactory
            from android.graphics.drawable import GradientDrawable
            from org.telegram.ui.ActionBar import Theme, BottomSheet
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else ctx_override
            if ctx is None:
                return
            self._ensure_settings_header_assets()
            self._dismiss_keyboard_focus(ctx)
            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                root_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                root.setBackground(root_bg)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            avatar = ImageView(ctx)
            try:
                avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                av_bg = GradientDrawable()
                av_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                av_bg.setColor(0x00000000)
                avatar.setBackground(av_bg)
                avatar.setClipToOutline(True)
                avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                if os.path.exists(ABOUT_AVATAR_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(ABOUT_AVATAR_CACHE_FILE)
                    if bmp:
                        avatar.setImageBitmap(bmp)
                avatar.setCameraDistance(float(AndroidUtilities.dp(800)))
                avatar.setAlpha(0.0)
                avatar.setTranslationY(float(AndroidUtilities.dp(26)))
                avatar.setRotationY(-120.0)
            except Exception:
                pass
            row.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            try:
                desc.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_desc.leftMargin = AndroidUtilities.dp(10)
            row.addView(desc, lp_desc)
            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            btn = TextView(ctx)
            btn.setText(self._tr("about_button"))
            btn.setGravity(Gravity.CENTER)
            btn.setTextSize(16)
            try:
                btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            extended_btn = ImageView(ctx)
            try:
                extended_btn.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                is_dark = bool(Theme.isCurrentThemeDark())
                icon_path = EXTENDED_ICON_CACHE_FILE_DARK if is_dark else EXTENDED_ICON_CACHE_FILE_LIGHT
                if os.path.exists(icon_path):
                    bmp = BitmapFactory.decodeFile(icon_path)
                    if bmp:
                        extended_btn.setImageBitmap(bmp)
                extended_btn.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            except Exception:
                pass

            class _AboutOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        get_messages_controller().openByUserName("AGeekApple", get_last_fragment(), 1)
                    except Exception:
                        try:
                            self.open_url("https://t.me/AGeekApple")
                        except Exception:
                            pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            btn.setOnClickListener(_AboutOpen())

            class _ExtendedOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self.open_url("tg://resolve?domain=ApplesBio&post=4")
                    except Exception:
                        try:
                            get_messages_controller().openByUserName("ApplesBio", get_last_fragment(), 1)
                        except Exception:
                            try:
                                self.open_url("https://t.me/ApplesBio/4")
                            except Exception:
                                pass

            extended_btn.setOnClickListener(_ExtendedOpen())
            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_actions.topMargin = AndroidUtilities.dp(10)
            lp_ext = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
            lp_ext.rightMargin = AndroidUtilities.dp(8)
            actions.addView(extended_btn, lp_ext)
            actions.addView(btn, LinearLayout.LayoutParams(AndroidUtilities.dp(140), LinearLayout.LayoutParams.WRAP_CONTENT))
            root.addView(actions, lp_actions)
            outer.addView(root, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            sheet.setCustomView(outer)
            sheet.show()
            try:
                avatar.post(lambda: avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start())
            except Exception:
                try:
                    avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start()
                except Exception:
                    pass
        except Exception as e:
            self._dlog("about sheet fail: {0}".format(e))

    def _on_about_click(self, _view=None):
        try:
            if not self._action_debounce_ok("show_about_sheet", 500):
                return
            run_on_ui_thread(lambda: self._show_about_sheet(None))
        except Exception:
            self._show_about_sheet(None)

    def _dlog(self, msg):
        try:
            if self._debug_enabled():
                log("[Docky] {0}".format(str(msg)))
        except Exception:
            pass

    def _log_fail(self, label, err):
        try:
            self._dlog("{0} fail: {1}".format(str(label), err))
        except Exception:
            pass

    def _log_missing(self, what):
        try:
            self._dlog("{0} unavailable".format(str(what)))
        except Exception:
            pass

    # Execution helpers
    def _ui_safe(self, fn, delay=0):
        try:
            if int(delay or 0) > 0:
                AndroidUtilities.runOnUIThread(fn, int(delay))
            else:
                run_on_ui_thread(fn)
        except Exception:
            try:
                fn()
            except Exception:
                pass

    def _run_bg(self, fn, label="bg_task"):
        try:
            threading.Thread(target=fn, daemon=True, name="docky_{0}".format(str(label))).start()
            return True
        except Exception as e:
            self._dlog("{0} spawn fail: {1}".format(str(label), e))
            try:
                fn()
            except Exception as ie:
                self._dlog("{0} inline fail: {1}".format(str(label), ie))
            return False

    def _fetch_async(self, worker, on_done=None, label="fetch"):
        try:
            def _run():
                result = None
                try:
                    result = worker()
                except Exception as e:
                    self._log_fail(str(label), e)
                if callable(on_done):
                    self._ui_safe(lambda: on_done(result))
            return self._run_bg(_run, str(label))
        except Exception as e:
            self._log_fail("{0} dispatch".format(str(label)), e)
            return False

    # State helpers
    def _action_debounce_ok(self, key, min_interval_ms=450):
        try:
            now = int(time.time() * 1000)
            k = str(key or "").strip()
            prev = int(self._action_debounce_ts.get(k, 0) or 0)
            if prev and (now - prev) < int(min_interval_ms):
                self._dlog("debounced action={0}".format(k))
                return False
            self._action_debounce_ts[k] = now
            if len(self._action_debounce_ts) > 64:
                cutoff = now - 30000
                self._action_debounce_ts = {kk: vv for kk, vv in self._action_debounce_ts.items() if int(vv or 0) >= cutoff}
            return True
        except Exception:
            return True

    def _click_listener(self, fn, key=None, min_interval_ms=0):
        try:
            def _run(_v=None):
                try:
                    if key and (not self._action_debounce_ok(key, int(min_interval_ms or 450))):
                        return
                    return fn(_v)
                except Exception as e:
                    self._log_fail("click {0}".format(str(key or getattr(fn, "__name__", "handler"))), e)
                    return None
            return OnClickListener(_run)
        except Exception:
            return OnClickListener(fn)

    # Cache helpers
    def _safe_json_loads(self, raw, fallback):
        try:
            data = json.loads(str(raw or ""))
            if isinstance(fallback, list):
                return data if isinstance(data, list) else list(fallback)
            if isinstance(fallback, dict):
                return data if isinstance(data, dict) else dict(fallback)
            return data
        except Exception:
            return fallback

    def _invalidate_favorites_cache(self):
        try:
            self._favorites_cache_sig = ""
            self._favorites_cache_list = []
            self._sidebar_state_sig = None
            self._dialogs_widget_state_sig = None
        except Exception:
            pass

    def _read_json_disk(self, path, fallback=None):
        try:
            if not path or not os.path.isfile(path):
                return fallback
            with open(path, "r", encoding="utf-8-sig") as f:
                data = json.load(f)
            return data
        except Exception as e:
            self._dlog("json read fail path={0} err={1}".format(str(path), e))
            return fallback

    def _resolve_class(self, name):
        try:
            cls = find_class(name)
            if cls is None:
                self._log_missing("class {0}".format(str(name)))
            return cls
        except Exception as e:
            self._log_fail("class resolve {0}".format(str(name)), e)
            return None

    # Network helpers
    def _http_request(self, url, method="GET", headers=None, data=None, timeout=12, decode=None):
        try:
            hdrs = {"User-Agent": "Docky/1.0"}
            if headers:
                try:
                    hdrs.update(dict(headers))
                except Exception:
                    pass
            req = Request(str(url), data=data, headers=hdrs, method=str(method or "GET"))
            with urlopen(req, timeout=int(timeout or 12)) as resp:
                raw = resp.read()
                code = int(getattr(resp, "status", 200) or 200)
            if decode:
                return code, raw.decode(str(decode), errors="replace")
            return code, raw
        except Exception as e:
            self._log_fail("http_request {0}".format(str(url)), e)
            return None, None

    def _lang(self):
        try:
            pidx = int(self.get_setting("docky_plugin_lang", 0) or 0)
            if pidx < 0 or pidx >= len(PLUGIN_LANG_OPTIONS):
                pidx = 0
            forced = str(PLUGIN_LANG_OPTIONS[pidx][1] or "system")
            if forced != "system":
                return forced
        except Exception:
            pass
        try:
            Locale = jclass("java.util.Locale")
            lang = str(Locale.getDefault().getLanguage() or "").lower()
            if lang.startswith("pt"):
                return "pt"
            if lang.startswith("ru"):
                return "ru"
            return "en"
        except Exception:
            return "en"

    def _tr(self, key):
        try:
            lang = self._lang()
            return str(STRINGS.get(lang, {}).get(key) or STRINGS["en"].get(key) or key)
        except Exception:
            return str(key)

    def _on_plugin_language_changed(self):
        try:
            self._lang_code_cache = None
        except Exception:
            pass
        try:
            run_on_ui_thread(lambda: self.reload_settings())
        except Exception:
            try:
                self.reload_settings()
            except Exception:
                pass

    def _load_meta_cache(self):
        try:
            data = self._read_json_disk(DOCKY_META_CACHE_FILE, None)
            if isinstance(data, dict):
                return dict(data)
            raw = self.get_setting("docky_meta_cache", {})
            return dict(raw) if isinstance(raw, dict) else {}
        except Exception:
            return {}

    def _save_meta_cache(self):
        try:
            self.set_setting("docky_meta_cache", dict(self._meta_cache or {}))
        except Exception:
            pass
        try:
            self._meta_cache_dirty = True
            now_ts = time.time()
            if now_ts - float(self._meta_cache_last_save or 0) < float(META_CACHE_SAVE_INTERVAL):
                return
            self._meta_cache_last_save = now_ts
            try:
                with open(DOCKY_META_CACHE_FILE, "w", encoding="utf-8") as f:
                    json.dump(dict(self._meta_cache or {}), f, ensure_ascii=False, separators=(",", ":"))
            except Exception as e:
                self._dlog("meta cache disk save fail: {0}".format(e))
                return
            self._meta_cache_dirty = False
        except Exception:
            pass

    def _avatar_signature(self, obj):
        try:
            if obj is None:
                return ""
            photo = getattr(obj, "photo", None)
            if photo is None:
                return ""
            for attr in ("photo_id", "id", "dc_id"):
                try:
                    val = getattr(photo, attr, None)
                    if val not in (None, 0, "0", ""):
                        return str(val)
                except Exception:
                    pass
            return str(photo)
        except Exception:
            return ""

    def _update_target_meta_cache(self, target, kind=None, obj=None, resolved_name=None):
        try:
            key = self._target_key(target)
            if not key:
                return
            current = dict(self._meta_cache.get(key) or {})
            updated = dict(current)
            for field in ("dialog_id", "chat_id", "user_id", "chat_peer"):
                try:
                    val = int(target.get(field, 0) or 0)
                except Exception:
                    val = 0
                if val:
                    updated[field] = int(val)
            if kind:
                updated["kind"] = str(kind)
            name = str(resolved_name or target.get("name", "") or "").strip()
            if name:
                updated["name"] = name
            avatar_sig = self._avatar_signature(obj)
            if avatar_sig:
                updated["avatar_sig"] = avatar_sig
            if updated != current:
                self._meta_cache[key] = updated
                try:
                    if str(updated.get("name", "") or "").strip():
                        did = int(updated.get("dialog_id", 0) or 0)
                        uid = int(updated.get("user_id", 0) or 0)
                        cid = int(updated.get("chat_id", 0) or 0)
                        nm = str(updated.get("name", "") or "").strip()
                        if did != 0:
                            self._dialog_name_cache["d:{0}".format(int(did))] = nm
                        if uid != 0:
                            self._dialog_name_cache["u:{0}".format(int(uid))] = nm
                        if cid != 0:
                            self._dialog_name_cache["c:{0}".format(int(cid))] = nm
                except Exception:
                    pass
                self._invalidate_favorites_cache()
                self._save_meta_cache()
        except Exception:
            pass

    def _seed_target_runtime_cache(self, target, kind=None, obj=None, resolved_name=None):
        try:
            key = self._target_key(target)
            if not key:
                return
            if obj is not None and kind:
                self._peer_cache[key] = (str(kind), obj)
                self._avatar_cache.pop(key, None)
            name = str(resolved_name or (target or {}).get("name", "") or "").strip()
            if name:
                self._name_cache[key] = name
                try:
                    did = int((target or {}).get("dialog_id", 0) or 0)
                    uid = int((target or {}).get("user_id", 0) or 0)
                    cid = int((target or {}).get("chat_id", 0) or 0)
                    if did != 0:
                        self._dialog_name_cache["d:{0}".format(int(did))] = name
                    if uid != 0:
                        self._dialog_name_cache["u:{0}".format(int(uid))] = name
                    if cid != 0:
                        self._dialog_name_cache["c:{0}".format(int(cid))] = name
                except Exception:
                    pass
            self._update_target_meta_cache(target, kind=kind, obj=obj, resolved_name=name)
        except Exception:
            pass

    def _remove_target_meta_cache(self, target):
        try:
            key = self._target_key(target)
            if key and key in self._meta_cache:
                self._meta_cache.pop(key, None)
                try:
                    did = int((target or {}).get("dialog_id", 0) or 0)
                    uid = int((target or {}).get("user_id", 0) or 0)
                    cid = int((target or {}).get("chat_id", 0) or 0)
                    if did != 0:
                        self._dialog_name_cache.pop("d:{0}".format(int(did)), None)
                    if uid != 0:
                        self._dialog_name_cache.pop("u:{0}".format(int(uid)), None)
                    if cid != 0:
                        self._dialog_name_cache.pop("c:{0}".format(int(cid)), None)
                except Exception:
                    pass
                self._invalidate_favorites_cache()
                self._save_meta_cache()
        except Exception:
            pass

