RUSSIAN_CHARS = set("йцукенгшщзхфывапролджэячсмитьбю")
ALLOWED_CHARS = RUSSIAN_CHARS | {" "}

TIME_OPTIONS = ["15 сек", "30 сек", "60 сек", "120 сек", "Custom"]
TIME_VALUES  = [15, 30, 60, 120, -1]

DEFAULT_WORDS = [
    "привет", "как", "дела", "хорошо", "спасибо",
    "да", "нет", "можно", "нужно", "время",
    "слово", "текст", "скорость", "печать", "тест",
    "буква", "строка", "пример", "мир", "дом",
    "вода", "небо", "земля", "огонь", "книга",
    "стол", "рука", "глаз", "голос", "день",
    "ночь", "утро", "вечер", "час", "друг",
    "путь", "мысль", "свет", "тень", "окно",
    "дверь", "город", "море", "река", "лес",
    "поле", "снег", "дождь", "ветер", "солнце",
    "работа", "жизнь", "любовь", "семья", "школа",
    "машина", "дорога", "народ", "страна", "место"
]

COLOR_PRESETS = {
    "Синий":       {"accent": "#2196F3", "correct": "#4CAF50", "wrong": "#F44336", "bg": "#0D0D0D", "card": "#111111", "text_dim": "#3A3A3A"},
    "Розовый":     {"accent": "#E91E8C", "correct": "#00BCD4", "wrong": "#FF5722", "bg": "#0D080D", "card": "#150B15", "text_dim": "#3A1A3A"},
    "Зелёный":     {"accent": "#00E676", "correct": "#69F0AE", "wrong": "#FF1744", "bg": "#080F0A", "card": "#0C1A0F", "text_dim": "#1A3A22"},
    "Оранжевый":   {"accent": "#FF6D00", "correct": "#AEEA00", "wrong": "#D50000", "bg": "#0F0A06", "card": "#1A1208", "text_dim": "#3A2A1A"},
    "Фиолетовый":  {"accent": "#AA00FF", "correct": "#00E5FF", "wrong": "#FF4081", "bg": "#0B080F", "card": "#150F1A", "text_dim": "#2A1A3A"},
    "Красный":     {"accent": "#FF1744", "correct": "#76FF03", "wrong": "#FF6D00", "bg": "#0F0808", "card": "#1A0C0C", "text_dim": "#3A1A1A"},
    "Бирюзовый":   {"accent": "#00BCD4", "correct": "#CCFF90", "wrong": "#FF5252", "bg": "#080E10", "card": "#0C181A", "text_dim": "#1A3A3A"},
    "Жёлтый":      {"accent": "#FFD600", "correct": "#69F0AE", "wrong": "#FF5252", "bg": "#0F0F08", "card": "#1A1A0C", "text_dim": "#3A3A1A"},
    "Коралловый":  {"accent": "#FF6B6B", "correct": "#96E6A1", "wrong": "#4A90D9", "bg": "#0F0909", "card": "#1A1010", "text_dim": "#3A2020"},
    "Мятный":      {"accent": "#26A69A", "correct": "#AED581", "wrong": "#EF5350", "bg": "#080F0E", "card": "#0C1A18", "text_dim": "#1A3A36"},
    "Лавандовый":  {"accent": "#B39DDB", "correct": "#80DEEA", "wrong": "#FFAB91", "bg": "#0C0B0F", "card": "#161420", "text_dim": "#2A2840"},
    "Белый":       {"accent": "#EEEEEE", "correct": "#69F0AE", "wrong": "#FF5252", "bg": "#0A0A0A", "card": "#141414", "text_dim": "#3A3A3A"},
}
COLOR_PRESET_NAMES = list(COLOR_PRESETS.keys())


def get_colors(plugin):
    idx = plugin.get_setting("color_preset", 0)
    if idx < 0 or idx >= len(COLOR_PRESET_NAMES):
        idx = 0
    return COLOR_PRESETS[COLOR_PRESET_NAMES[idx]]


def normalize_char(c):
    c = c.lower()
    if c == "ё":
        return "е"
    if c in ALLOWED_CHARS:
        return c
    return None


def dp(ctx, v):
    return int(TypedValue.applyDimension(
        TypedValue.COMPLEX_UNIT_DIP, v,
        ctx.getResources().getDisplayMetrics()
    ))


def make_bg(color_hex, radius_dp, ctx):
    gd = GradientDrawable()
    gd.setShape(GradientDrawable.RECTANGLE)
    gd.setColor(Color.parseColor(color_hex))
    gd.setCornerRadius(dp(ctx, radius_dp))
    return gd


def make_border_bg(fill_hex, stroke_hex, stroke_w_dp, radius_dp, ctx):
    gd = GradientDrawable()
    gd.setShape(GradientDrawable.RECTANGLE)
    gd.setColor(Color.parseColor(fill_hex))
    gd.setStroke(dp(ctx, stroke_w_dp), Color.parseColor(stroke_hex))
    gd.setCornerRadius(dp(ctx, radius_dp))
    return gd


def make_toggle_row(ctx, colors, label, subtext, current_val):
    row = LinearLayout(ctx)
    row.setOrientation(LinearLayout.HORIZONTAL)
    row.setGravity(Gravity.CENTER_VERTICAL)
    row.setBackground(make_bg(colors["card"], 10, ctx))
    row.setPadding(dp(ctx, 14), dp(ctx, 12), dp(ctx, 14), dp(ctx, 12))
    row.setLayoutParams(LinearLayout.LayoutParams(
        LinearLayout.LayoutParams.MATCH_PARENT,
        LinearLayout.LayoutParams.WRAP_CONTENT
    ))

    text_col = LinearLayout(ctx)
    text_col.setOrientation(LinearLayout.VERTICAL)
    text_col.setLayoutParams(LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

    lbl_tv = TextView(ctx)
    lbl_tv.setText(label)
    lbl_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14)
    lbl_tv.setTextColor(Color.parseColor("#CCCCCC"))
    text_col.addView(lbl_tv)

    if subtext:
        sub_tv = TextView(ctx)
        sub_tv.setText(subtext)
        sub_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
        sub_tv.setTextColor(Color.parseColor("#444444"))
        sub_p = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        sub_p.setMargins(0, dp(ctx, 2), 0, 0)
        sub_tv.setLayoutParams(sub_p)
        text_col.addView(sub_tv)

    row.addView(text_col)

    ind = TextView(ctx)
    ind.setText("ВКЛ" if current_val else "ВЫКЛ")
    ind.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12)
    ind.setTextColor(Color.parseColor(colors["correct"] if current_val else "#555555"))
    ind.setTypeface(Typeface.DEFAULT_BOLD)
    row.addView(ind)

    return row, ind


class RussianInputFilter(dynamic_proxy(InputFilter)):
    def filter(self, source, start, end, dest, dstart, dend):
        try:
            src_str = str(source)
            result = []
            for i in range(start, end):
                if i < len(src_str):
                    nc = normalize_char(src_str[i])
                    if nc is not None:
                        result.append(nc)
            filtered = "".join(result)
            original = src_str[start:end]
            if filtered == original:
                return None
            return filtered
        except Exception as e:
            log(f"InputFilter error: {e}")
            return ""


class PyTextWatcher(dynamic_proxy(TextWatcher)):
    def __init__(self, after_fn):
        super().__init__()
        self._fn = after_fn

    def afterTextChanged(self, s):
        try:
            self._fn(str(s.toString()))
        except Exception as e:
            log(f"TextWatcher error: {e}")

    def beforeTextChanged(self, s, start, count, after):
        pass

    def onTextChanged(self, s, start, before, count):
        pass


class WpmTestPlugin(BasePlugin):

    def on_plugin_load(self):
        self.log("WPM Test v5.2 загружен")

    def on_plugin_unload(self):
        self.log("WPM Test v5.2 выгружен")

    def _get_duration(self):
        idx = self.get_setting("time_selector", 2)
        if idx < 0 or idx >= len(TIME_VALUES):
            idx = 2
        val = TIME_VALUES[idx]
        if val == -1:
            try:
                val = int(str(self.get_setting("custom_time", "60")).strip())
            except Exception:
                val = 60
        return max(5, val)

    def _get_word_list(self):
        use_custom = self.get_setting("use_custom_words", False)
        if use_custom:
            raw = str(self.get_setting("custom_words", "")).strip()
            if raw:
                normalized = []
                for w in raw.replace("\n", " ").split():
                    chars = []
                    for c in w.lower():
                        if c == "ё":
                            chars.append("е")
                        elif c in RUSSIAN_CHARS:
                            chars.append(c)
                    word = "".join(chars)
                    if word:
                        normalized.append(word)
                if normalized:
                    return normalized
        return DEFAULT_WORDS

    def _open_wpm_test(self, view):
        run_on_ui_thread(self._show_wpm_dialog)

    def _make_divider_view(self, ctx):
        div = View(ctx)
        div.setBackground(make_bg("#1E1E1E", 0, ctx))
        div_p = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, dp(ctx, 1))
        div_p.setMargins(0, dp(ctx, 16), 0, dp(ctx, 12))
        div.setLayoutParams(div_p)
        return div

    def _make_section_lbl(self, ctx, text):
        tv = TextView(ctx)
        tv.setText(text)
        tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 10)
        tv.setTextColor(Color.parseColor("#555555"))
        tv.setPadding(dp(ctx, 2), 0, 0, dp(ctx, 8))
        return tv

    def _build_color_dialog(self):
        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return

        ctx = activity
        colors = get_colors(self)
        builder = AlertDialogBuilder(activity)
        builder.set_title("🎨  Цветовая тема")

        scroll = ScrollView(ctx)
        scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
        scroll.setVerticalScrollBarEnabled(False)

        outer = LinearLayout(ctx)
        outer.setOrientation(LinearLayout.VERTICAL)
        p = dp(ctx, 16)
        outer.setPadding(p, p, p, p)
        outer.setBackgroundColor(Color.parseColor(colors["bg"]))

        current_idx = self.get_setting("color_preset", 0)
        sel_holder = [current_idx]
        cards_data = []

        COLS = 2
        grid_row = None

        for i, name in enumerate(COLOR_PRESET_NAMES):
            c = COLOR_PRESETS[name]

            if i % COLS == 0:
                grid_row = LinearLayout(ctx)
                grid_row.setOrientation(LinearLayout.HORIZONTAL)
                gr_p = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                )
                gr_p.setMargins(0, 0, 0, dp(ctx, 8))
                grid_row.setLayoutParams(gr_p)
                outer.addView(grid_row)

            is_sel = (i == sel_holder[0])

            card = LinearLayout(ctx)
            card.setOrientation(LinearLayout.VERTICAL)
            card.setGravity(Gravity.CENTER)
            card_p = LinearLayout.LayoutParams(0, dp(ctx, 76), 1.0)
            if i % COLS == 0:
                card_p.setMargins(0, 0, dp(ctx, 5), 0)
            else:
                card_p.setMargins(dp(ctx, 5), 0, 0, 0)
            card.setLayoutParams(card_p)
            card.setBackground(make_border_bg(
                c["card"],
                c["accent"] if is_sel else "#222222",
                2 if is_sel else 1,
                12, ctx
            ))
            card.setPadding(dp(ctx, 8), dp(ctx, 8), dp(ctx, 8), dp(ctx, 8))

            dot_row = LinearLayout(ctx)
            dot_row.setOrientation(LinearLayout.HORIZONTAL)
            dot_row.setGravity(Gravity.CENTER)
            dot_rp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.WRAP_CONTENT,
                LinearLayout.LayoutParams.WRAP_CONTENT
            )
            dot_rp.setMargins(0, 0, 0, dp(ctx, 5))
            dot_row.setLayoutParams(dot_rp)

            for dot_col in [c["accent"], c["correct"], c["wrong"]]:
                dot = View(ctx)
                dot.setBackground(make_bg(dot_col, 5, ctx))
                dsz = dp(ctx, 10)
                dot_lp = LinearLayout.LayoutParams(dsz, dsz)
                dot_lp.setMargins(dp(ctx, 2), 0, dp(ctx, 2), 0)
                dot.setLayoutParams(dot_lp)
                dot_row.addView(dot)

            card.addView(dot_row)

            lbl = TextView(ctx)
            lbl.setText(name)
            lbl.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
            lbl.setTextColor(Color.parseColor("#FFFFFF" if is_sel else "#888888"))
            lbl.setGravity(Gravity.CENTER)
            lbl.setLayoutParams(LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT
            ))
            card.addView(lbl)

            cards_data.append((card, lbl))

            def on_card_click(v, idx=i):
                sel_holder[0] = idx
                self.set_setting("color_preset", idx)
                for j, (c2, l2) in enumerate(cards_data):
                    cc = COLOR_PRESETS[COLOR_PRESET_NAMES[j]]
                    sel2 = (j == idx)
                    c2.setBackground(make_border_bg(
                        cc["card"],
                        cc["accent"] if sel2 else "#222222",
                        2 if sel2 else 1,
                        12, ctx
                    ))
                    l2.setTextColor(Color.parseColor("#FFFFFF" if sel2 else "#888888"))

            card.setOnClickListener(OnClickListener(on_card_click))
            grid_row.addView(card)

        if len(COLOR_PRESET_NAMES) % COLS != 0 and grid_row is not None:
            spacer = View(ctx)
            spacer_p = LinearLayout.LayoutParams(0, dp(ctx, 76), 1.0)
            spacer_p.setMargins(dp(ctx, 5), 0, 0, 0)
            spacer.setLayoutParams(spacer_p)
            grid_row.addView(spacer)

        scroll.addView(outer)
        builder.set_view(scroll)
        builder.set_positive_button("Готово", lambda b, w: b.dismiss())
        builder.show()

    def _build_settings_dialog(self):
        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return

        ctx = activity
        colors = get_colors(self)
        builder = AlertDialogBuilder(activity)
        builder.set_title("⚙  Настройки теста")

        scr = ScrollView(ctx)
        scr.setOverScrollMode(View.OVER_SCROLL_NEVER)
        scr.setVerticalScrollBarEnabled(False)

        outer = LinearLayout(ctx)
        outer.setOrientation(LinearLayout.VERTICAL)
        p = dp(ctx, 20)
        outer.setPadding(p, p, p, p)
        outer.setBackgroundColor(Color.parseColor(colors["bg"]))

        outer.addView(self._make_section_lbl(ctx, "ДЛИТЕЛЬНОСТЬ"))

        btn_row = LinearLayout(ctx)
        btn_row.setOrientation(LinearLayout.HORIZONTAL)

        current_sel = self.get_setting("time_selector", 2)
        sel_holder = [current_sel]
        time_buttons = []

        custom_et = AndroidEditText(ctx)
        custom_et.setHint("Секунды (5–3600)")
        custom_et.setInputType(InputType.TYPE_CLASS_NUMBER)
        custom_et.setText(str(self.get_setting("custom_time", "60")))
        custom_et.setTextColor(Color.WHITE)
        custom_et.setHintTextColor(Color.parseColor("#444444"))
        custom_et.setTextSize(TypedValue.COMPLEX_UNIT_SP, 15)
        custom_et.setBackground(make_border_bg(colors["card"], colors["accent"], 1, 10, ctx))
        custom_et.setPadding(dp(ctx, 14), dp(ctx, 12), dp(ctx, 14), dp(ctx, 12))
        cep = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        cep.setMargins(0, dp(ctx, 10), 0, 0)
        custom_et.setLayoutParams(cep)
        custom_et.setVisibility(View.VISIBLE if TIME_VALUES[current_sel] == -1 else View.GONE)

        def make_time_btn(idx, label):
            btn = Button(ctx)
            btn.setText(label)
            btn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 13)
            is_sel = (idx == sel_holder[0])
            btn.setBackground(make_bg(colors["accent"] if is_sel else "#1E1E1E", 8, ctx))
            btn.setTextColor(Color.parseColor("#FFFFFF" if is_sel else "#666666"))
            prm = LinearLayout.LayoutParams(0, dp(ctx, 44), 1.0)
            prm.setMargins(dp(ctx, 3), 0, dp(ctx, 3), 0)
            btn.setLayoutParams(prm)

            def on_click(v, i=idx):
                sel_holder[0] = i
                for j, b in enumerate(time_buttons):
                    b.setBackground(make_bg(colors["accent"] if j == i else "#1E1E1E", 8, ctx))
                    b.setTextColor(Color.parseColor("#FFFFFF" if j == i else "#666666"))
                self.set_setting("time_selector", i)
                custom_et.setVisibility(View.VISIBLE if TIME_VALUES[i] == -1 else View.GONE)

            btn.setOnClickListener(OnClickListener(on_click))
            return btn

        for i, label in enumerate(["15с", "30с", "60с", "2м", "✎"]):
            b = make_time_btn(i, label)
            time_buttons.append(b)
            btn_row.addView(b)

        outer.addView(btn_row)
        outer.addView(custom_et)

        outer.addView(self._make_divider_view(ctx))
        outer.addView(self._make_section_lbl(ctx, "РЕЖИМ ТЕСТА"))

        no_acc_on = [self.get_setting("no_accuracy", False)]
        no_wpm_on = [self.get_setting("no_wpm", False)]

        no_acc_row, no_acc_ind = make_toggle_row(
            ctx, colors,
            "Без точности (No Accuracy)",
            "Только ВПМ, точность не отображается",
            no_acc_on[0]
        )
        nacc_mp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        nacc_mp.setMargins(0, 0, 0, dp(ctx, 8))
        no_acc_row.setLayoutParams(nacc_mp)

        no_wpm_row, no_wpm_ind = make_toggle_row(
            ctx, colors,
            "Без ВПМ (No WPM)",
            "Только точность, скорость не отображается",
            no_wpm_on[0]
        )

        def on_no_acc_click(v):
            no_acc_on[0] = not no_acc_on[0]
            self.set_setting("no_accuracy", no_acc_on[0])
            no_acc_ind.setText("ВКЛ" if no_acc_on[0] else "ВЫКЛ")
            no_acc_ind.setTextColor(Color.parseColor(colors["correct"] if no_acc_on[0] else "#555555"))
            if no_acc_on[0] and no_wpm_on[0]:
                no_wpm_on[0] = False
                self.set_setting("no_wpm", False)
                no_wpm_ind.setText("ВЫКЛ")
                no_wpm_ind.setTextColor(Color.parseColor("#555555"))

        def on_no_wpm_click(v):
            no_wpm_on[0] = not no_wpm_on[0]
            self.set_setting("no_wpm", no_wpm_on[0])
            no_wpm_ind.setText("ВКЛ" if no_wpm_on[0] else "ВЫКЛ")
            no_wpm_ind.setTextColor(Color.parseColor(colors["correct"] if no_wpm_on[0] else "#555555"))
            if no_wpm_on[0] and no_acc_on[0]:
                no_acc_on[0] = False
                self.set_setting("no_accuracy", False)
                no_acc_ind.setText("ВЫКЛ")
                no_acc_ind.setTextColor(Color.parseColor("#555555"))

        no_acc_row.setOnClickListener(OnClickListener(on_no_acc_click))
        no_wpm_row.setOnClickListener(OnClickListener(on_no_wpm_click))
        outer.addView(no_acc_row)
        outer.addView(no_wpm_row)

        outer.addView(self._make_divider_view(ctx))
        outer.addView(self._make_section_lbl(ctx, "ПОЛНОЭКРАННЫЙ РЕЖИМ"))

        fs_on = [self.get_setting("fullscreen_mode", False)]
        fs_row, fs_ind = make_toggle_row(ctx, colors, "Полноэкранный режим", None, fs_on[0])

        def on_fs_click(v):
            fs_on[0] = not fs_on[0]
            self.set_setting("fullscreen_mode", fs_on[0])
            fs_ind.setText("ВКЛ" if fs_on[0] else "ВЫКЛ")
            fs_ind.setTextColor(Color.parseColor(colors["correct"] if fs_on[0] else "#555555"))

        fs_row.setOnClickListener(OnClickListener(on_fs_click))
        outer.addView(fs_row)

        outer.addView(self._make_divider_view(ctx))
        outer.addView(self._make_section_lbl(ctx, "ЦВЕТОВАЯ ТЕМА"))

        color_idx = self.get_setting("color_preset", 0)
        color_name_now = COLOR_PRESET_NAMES[color_idx] if 0 <= color_idx < len(COLOR_PRESET_NAMES) else COLOR_PRESET_NAMES[0]

        color_btn = Button(ctx)
        color_btn.setText("🎨  " + color_name_now)
        color_btn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14)
        color_btn.setTextColor(Color.parseColor(colors["accent"]))
        color_btn.setBackground(make_border_bg(colors["card"], colors["accent"], 1, 10, ctx))
        cb_p = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            dp(ctx, 48)
        )
        color_btn.setLayoutParams(cb_p)
        color_btn.setOnClickListener(OnClickListener(
            lambda v: run_on_ui_thread(self._build_color_dialog)
        ))
        outer.addView(color_btn)

        scr.addView(outer)
        builder.set_view(scr)

        def on_save(bld, _):
            try:
                raw = str(custom_et.getText().toString()).strip()
                if raw:
                    self.set_setting("custom_time", str(max(5, int(raw))))
            except Exception:
                pass
            bld.dismiss()

        builder.set_positive_button("Сохранить", on_save)
        builder.set_negative_button("Отмена", lambda b, w: b.dismiss())
        builder.show()

    def _show_wpm_dialog(self):
        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return

        ctx = activity
        duration = self._get_duration()
        word_pool = self._get_word_list()
        test_words = [random.choice(word_pool) for _ in range(250)]
        colors = get_colors(self)
        fullscreen = self.get_setting("fullscreen_mode", False)
        no_accuracy = self.get_setting("no_accuracy", False)
        no_wpm = self.get_setting("no_wpm", False)

        state = {
            "started": False,
            "finished": False,
            "start_time": 0.0,
            "duration": duration,
            "test_words": test_words,
            "typed_words": [],
            "word_colors": {},
            "total_chars": 0,
            "keystroke_times": [],
            "prev_len": 0,
            "current_word_partial": "",
            "last_ui_update": 0.0,
            "pending_ui": False,
        }

        builder = AlertDialogBuilder(activity)
        builder.set_title(None)

        root = LinearLayout(ctx)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.parseColor(colors["bg"]))
        root.setPadding(dp(ctx, 16), dp(ctx, 16), dp(ctx, 16), dp(ctx, 16))
        if fullscreen:
            root.setMinimumHeight(dp(ctx, 960))
        else:
            root.setMinimumHeight(dp(ctx, 420))

        header_row = LinearLayout(ctx)
        header_row.setOrientation(LinearLayout.HORIZONTAL)
        header_row.setGravity(Gravity.CENTER_VERTICAL)
        header_row.setLayoutParams(LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        ))

        title_str = "ТЕСТ ВПМ"
        if no_accuracy:
            title_str = "ТЕСТ ВПМ  •  БЕЗ ТОЧНОСТИ"
        elif no_wpm:
            title_str = "ТЕСТ ВПМ  •  БЕЗ ВПМ"

        title_tv = TextView(ctx)
        title_tv.setText(title_str)
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
        title_tv.setTextColor(Color.parseColor("#444444"))
        title_tv.setTypeface(Typeface.DEFAULT_BOLD)
        title_tv.setLayoutParams(
            LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
        )
        header_row.addView(title_tv)

        use_custom = self.get_setting("use_custom_words", False)
        badge_tv = TextView(ctx)
        badge_tv.setText("свои" if use_custom else "стандарт")
        badge_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 10)
        badge_tv.setTextColor(Color.parseColor(colors["correct"] if use_custom else "#444444"))
        badge_tv.setBackground(make_bg(colors["card"], 6, ctx))
        badge_tv.setPadding(dp(ctx, 8), dp(ctx, 3), dp(ctx, 8), dp(ctx, 3))
        header_row.addView(badge_tv)

        settings_btn = Button(ctx)
        settings_btn.setText("⚙")
        settings_btn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16)
        settings_btn.setTextColor(Color.parseColor("#555555"))
        settings_btn.setBackground(make_bg(colors["card"], 6, ctx))
        sbp = LinearLayout.LayoutParams(dp(ctx, 40), dp(ctx, 36))
        sbp.setMargins(dp(ctx, 8), 0, 0, 0)
        settings_btn.setLayoutParams(sbp)
        settings_btn.setPadding(0, 0, 0, 0)
        settings_btn.setGravity(Gravity.CENTER)
        header_row.addView(settings_btn)

        root.addView(header_row)

        timer_container = LinearLayout(ctx)
        timer_container.setOrientation(LinearLayout.HORIZONTAL)
        timer_container.setGravity(Gravity.CENTER_VERTICAL)
        tcp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        tcp.setMargins(0, dp(ctx, 14), 0, 0)
        timer_container.setLayoutParams(tcp)

        timer_tv = TextView(ctx)
        timer_tv.setText(str(duration))
        timer_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 48)
        timer_tv.setTextColor(Color.parseColor(colors["accent"]))
        timer_tv.setTypeface(Typeface.DEFAULT_BOLD)
        timer_tv.setLayoutParams(
            LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
        )
        timer_container.addView(timer_tv)

        stats_col = LinearLayout(ctx)
        stats_col.setOrientation(LinearLayout.VERTICAL)
        stats_col.setGravity(Gravity.END)

        live_wpm_tv = TextView(ctx)
        if no_wpm:
            live_wpm_tv.setText("впм скрыто")
            live_wpm_tv.setTextColor(Color.parseColor("#333333"))
        else:
            live_wpm_tv.setText("— впм")
            live_wpm_tv.setTextColor(Color.parseColor(colors["accent"]))
        live_wpm_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 14)
        live_wpm_tv.setGravity(Gravity.END)
        stats_col.addView(live_wpm_tv)

        live_cpm_tv = TextView(ctx)
        live_cpm_tv.setText("— бпм")
        live_cpm_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12)
        live_cpm_tv.setTextColor(Color.parseColor("#FF9800"))
        live_cpm_tv.setGravity(Gravity.END)
        stats_col.addView(live_cpm_tv)

        live_bps_tv = TextView(ctx)
        live_bps_tv.setText("— б/с")
        live_bps_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
        live_bps_tv.setTextColor(Color.parseColor("#9C27B0"))
        live_bps_tv.setGravity(Gravity.END)
        stats_col.addView(live_bps_tv)

        timer_container.addView(stats_col)
        root.addView(timer_container)

        progress_bg = View(ctx)
        progress_bg.setBackground(make_bg("#1E1E1E", 2, ctx))
        pbg_p = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, dp(ctx, 3))
        pbg_p.setMargins(0, dp(ctx, 8), 0, 0)
        progress_bg.setLayoutParams(pbg_p)
        root.addView(progress_bg)

        progress_bar_ref = [None]
        progress_bar = View(ctx)
        progress_bar.setBackground(make_bg(colors["accent"], 2, ctx))
        pb_p = LinearLayout.LayoutParams(dp(ctx, 0), dp(ctx, 3))
        pb_p.setMargins(0, -dp(ctx, 3), 0, 0)
        progress_bar.setLayoutParams(pb_p)
        progress_bar_ref[0] = progress_bar
        root.addView(progress_bar)

        sep = View(ctx)
        sep.setBackground(make_bg("#1E1E1E", 0, ctx))
        sep_p = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, dp(ctx, 1))
        sep_p.setMargins(0, dp(ctx, 10), 0, dp(ctx, 10))
        sep.setLayoutParams(sep_p)
        root.addView(sep)

        tap_hint_tv = TextView(ctx)
        tap_hint_tv.setText("👆 нажмите на текст чтобы начать")
        tap_hint_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
        tap_hint_tv.setTextColor(Color.parseColor("#555555"))
        tap_hint_tv.setGravity(Gravity.CENTER)
        th_p = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        th_p.setMargins(0, 0, 0, dp(ctx, 6))
        tap_hint_tv.setLayoutParams(th_p)
        root.addView(tap_hint_tv)

        text_height_dp = 500 if fullscreen else 200

        text_frame = FrameLayout(ctx)
        tf_p = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            dp(ctx, text_height_dp)
        )
        text_frame.setLayoutParams(tf_p)
        text_frame.setBackground(make_border_bg(colors["card"], "#1E1E1E", 1, 14, ctx))

        text_scroll = ScrollView(ctx)
        text_scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
        text_scroll.setVerticalScrollBarEnabled(False)
        text_scroll.setLayoutParams(FrameLayout.LayoutParams(
            FrameLayout.LayoutParams.MATCH_PARENT,
            FrameLayout.LayoutParams.MATCH_PARENT
        ))

        text_size_sp = 24 if fullscreen else 18

        text_tv = TextView(ctx)
        text_tv.setText(" ".join(test_words))
        text_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, text_size_sp)
        text_tv.setTextColor(Color.parseColor(colors["text_dim"]))
        text_tv.setPadding(dp(ctx, 16), dp(ctx, 14), dp(ctx, 16), dp(ctx, 14))
        text_tv.setLineSpacing(dp(ctx, 6), 1.0)
        text_scroll.addView(text_tv)
        text_frame.addView(text_scroll)

        hidden_et = AndroidEditText(ctx)
        hidden_et.setTextSize(TypedValue.COMPLEX_UNIT_SP, 1)
        hidden_et.setTextColor(Color.TRANSPARENT)
        hidden_et.setBackground(None)
        hidden_et.setCursorVisible(False)
        hidden_et.setSingleLine(True)
        hidden_et.setInputType(
            InputType.TYPE_CLASS_TEXT |
            InputType.TYPE_TEXT_FLAG_NO_SUGGESTIONS |
            InputType.TYPE_TEXT_VARIATION_VISIBLE_PASSWORD
        )
        hidden_et.setFilters([RussianInputFilter()])
        hep = FrameLayout.LayoutParams(dp(ctx, 1), dp(ctx, 1))
        hidden_et.setLayoutParams(hep)
        text_frame.addView(hidden_et)

        root.addView(text_frame)

        status_tv = TextView(ctx)
        status_tv.setText("")
        status_tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
        status_tv.setTextColor(Color.parseColor("#333333"))
        status_tv.setGravity(Gravity.CENTER)
        st_p = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        st_p.setMargins(0, dp(ctx, 8), 0, 0)
        status_tv.setLayoutParams(st_p)
        root.addView(status_tv)

        builder.set_view(root)

        def on_exit(b, w):
            state["finished"] = True
            try:
                imm = ctx.getSystemService(ctx.INPUT_METHOD_SERVICE)
                imm.hideSoftInputFromWindow(hidden_et.getWindowToken(), 0)
            except Exception:
                pass
            b.dismiss()

        builder.set_negative_button("✕  Выйти", on_exit)

        screen_w_px = [dp(ctx, 340)]
        try:
            screen_w_px[0] = ctx.getResources().getDisplayMetrics().widthPixels
        except Exception:
            pass

        def show_keyboard():
            try:
                hidden_et.requestFocus()
                imm = ctx.getSystemService(ctx.INPUT_METHOD_SERVICE)
                imm.showSoftInput(hidden_et, 0)
                tap_hint_tv.setVisibility(View.GONE)
                text_frame.setBackground(make_border_bg(colors["card"], colors["accent"], 2, 14, ctx))
            except Exception as e:
                log(f"show_keyboard: {e}")

        scroll_pending = [False]
        last_scroll_line = [-1]

        def _do_text_update():
            state["pending_ui"] = False
            try:
                from android.text import SpannableStringBuilder, Spanned
                from android.text.style import ForegroundColorSpan, BackgroundColorSpan, UnderlineSpan

                words = state["test_words"]
                wcolors = state["word_colors"]
                cur = len(state["typed_words"])
                partial = state["current_word_partial"]

                ssb = SpannableStringBuilder()

                correct_color = Color.parseColor(colors["correct"])
                wrong_color = Color.parseColor(colors["wrong"])
                dim_color = Color.parseColor(colors["text_dim"])
                cur_bg_color = Color.parseColor("#1A2A3A")
                white_color = Color.parseColor("#FFFFFF")
                near_white_color = Color.parseColor("#E8E8E8")

                SPAN_EXCL = Spanned.SPAN_EXCLUSIVE_EXCLUSIVE

                for i, w in enumerate(words):
                    s = ssb.length()
                    ssb.append(w)
                    e = ssb.length()

                    if i in wcolors:
                        col_str = wcolors[i]
                        col_int = correct_color if col_str == colors["correct"] else wrong_color
                        ssb.setSpan(ForegroundColorSpan(col_int), s, e, SPAN_EXCL)
                    elif i == cur:
                        ssb.setSpan(BackgroundColorSpan(cur_bg_color), s, e, SPAN_EXCL)
                        wlen = len(w)
                        plen = len(partial)
                        for k in range(wlen):
                            cs = s + k
                            if k < plen:
                                char_col = near_white_color if partial[k] == w[k] else wrong_color
                            else:
                                char_col = white_color
                            ssb.setSpan(ForegroundColorSpan(char_col), cs, cs + 1, SPAN_EXCL)
                        uc = min(plen, wlen - 1)
                        ssb.setSpan(UnderlineSpan(), s + uc, s + uc + 1, SPAN_EXCL)
                    else:
                        ssb.setSpan(ForegroundColorSpan(dim_color), s, e, SPAN_EXCL)

                    if i < len(words) - 1:
                        ssb.append(" ")

                text_tv.setText(ssb)

                if not scroll_pending[0]:
                    char_pos = sum(len(words[j]) + 1 for j in range(cur))
                    lo = text_tv.getLayout()
                    if lo is not None:
                        safe = min(char_pos, max(0, ssb.length() - 1))
                        line = lo.getLineForOffset(safe)
                        if line != last_scroll_line[0]:
                            last_scroll_line[0] = line
                            line_top = lo.getLineTop(line)
                            text_scroll.smoothScrollTo(0, max(0, line_top - dp(ctx, 30)))

            except Exception as e:
                log(f"_do_text_update: {e}")

        UI_THROTTLE = 0.032

        def schedule_text_update():
            now = time.time()
            if state["pending_ui"]:
                return
            elapsed_since = now - state["last_ui_update"]
            if elapsed_since >= UI_THROTTLE:
                state["last_ui_update"] = now
                run_on_ui_thread(_do_text_update)
            else:
                state["pending_ui"] = True
                delay_ms = int((UI_THROTTLE - elapsed_since) * 1000)
                run_on_ui_thread(_do_text_update, delay_ms)
                state["last_ui_update"] = now + (UI_THROTTLE - elapsed_since)

        def update_progress(remaining):
            try:
                ratio = max(0.0, min(1.0, remaining / state["duration"]))
                full_w = screen_w_px[0] - dp(ctx, 32)
                new_w = int(full_w * ratio)
                lp = progress_bar_ref[0].getLayoutParams()
                lp.width = new_w
                progress_bar_ref[0].setLayoutParams(lp)
                col = colors["correct"] if ratio > 0.5 else "#FF9800" if ratio > 0.2 else colors["wrong"]
                progress_bar_ref[0].setBackground(make_bg(col, 2, ctx))
            except Exception as e:
                log(f"update_progress: {e}")

        def update_live_stats():
            try:
                if not state["started"]:
                    return
                elapsed = max(0.1, time.time() - state["start_time"])
                cpm = int(state["total_chars"] / (elapsed / 60.0))
                bps = state["total_chars"] / elapsed
                if not no_wpm:
                    wpm = int(len(state["typed_words"]) / (elapsed / 60.0))
                    live_wpm_tv.setText(f"{wpm} впм")
                live_cpm_tv.setText(f"{cpm} бпм")
                live_bps_tv.setText(f"{bps:.1f} б/с")
            except Exception as e:
                log(f"update_live_stats: {e}")

        def timer_loop():
            while True:
                if state["finished"]:
                    break
                elapsed = time.time() - state["start_time"]
                remaining = max(0.0, state["duration"] - elapsed)

                def _tick(r=remaining):
                    try:
                        if state["finished"]:
                            return
                        secs = int(r) + (1 if r % 1 > 0 else 0)
                        timer_tv.setText(str(secs))
                        if r <= 5:
                            timer_tv.setTextColor(Color.parseColor(colors["wrong"]))
                        elif r <= 15:
                            timer_tv.setTextColor(Color.parseColor("#FF9800"))
                        else:
                            timer_tv.setTextColor(Color.parseColor(colors["accent"]))
                        update_progress(r)
                        update_live_stats()
                    except Exception:
                        pass

                run_on_ui_thread(_tick)

                if remaining <= 0:
                    if not state["finished"]:
                        run_on_ui_thread(finish_test)
                    break

                time.sleep(0.25)

        def start_timer():
            if state["started"] or state["finished"]:
                return
            state["started"] = True
            state["start_time"] = time.time()
            threading.Thread(target=timer_loop, daemon=True).start()
            run_on_ui_thread(lambda: (
                status_tv.setText("⏱  идёт тест..."),
                status_tv.setTextColor(Color.parseColor(colors["accent"]))
            ))

        def finish_test():
            if state["finished"]:
                return
            state["finished"] = True
            try:
                imm = ctx.getSystemService(ctx.INPUT_METHOD_SERVICE)
                imm.hideSoftInputFromWindow(hidden_et.getWindowToken(), 0)
            except Exception:
                pass
            hidden_et.setEnabled(False)

            elapsed = max(0.1, time.time() - state["start_time"])
            typed = state["typed_words"]
            total = len(typed)
            correct = sum(
                1 for i, w in enumerate(typed)
                if i < len(state["test_words"]) and w == state["test_words"][i]
            )
            wpm = int(total / (elapsed / 60.0))
            acc = int(correct / total * 100) if total > 0 else 0
            total_chars = state["total_chars"]
            cpm = int(total_chars / (elapsed / 60.0))
            bps = total_chars / elapsed

            times = state["keystroke_times"]
            if len(times) >= 2:
                intervals = [
                    times[i] - times[i - 1]
                    for i in range(1, len(times))
                    if 0.02 < times[i] - times[i - 1] < 1.5
                ]
                avg_ms = int((sum(intervals) / len(intervals)) * 1000) if intervals else 0
            else:
                avg_ms = 0

            try:
                timer_tv.setText("✓")
                timer_tv.setTextColor(Color.parseColor(colors["correct"]))
                status_tv.setText("тест завершён!")
                status_tv.setTextColor(Color.parseColor(colors["correct"]))
                if not no_wpm:
                    live_wpm_tv.setText(f"{wpm} впм")
                live_cpm_tv.setText(f"{cpm} бпм")
                live_bps_tv.setText(f"{bps:.1f} б/с")
                update_progress(0)
            except Exception:
                pass

            show_result(wpm, acc, correct, total, int(elapsed), cpm, bps, avg_ms)

        def show_result(wpm, accuracy, correct, total, elapsed, cpm, bps, avg_ms):
            frag2 = get_last_fragment()
            if not frag2:
                return
            act2 = frag2.getParentActivity()
            if not act2:
                return

            rb = AlertDialogBuilder(act2)
            rb.set_title(None)

            res_scroll = ScrollView(act2)
            res_scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
            res_scroll.setVerticalScrollBarEnabled(False)

            rl = LinearLayout(act2)
            rl.setOrientation(LinearLayout.VERTICAL)
            rl.setBackgroundColor(Color.parseColor(colors["bg"]))
            rl.setPadding(dp(act2, 20), dp(act2, 20), dp(act2, 20), dp(act2, 12))

            top_row = LinearLayout(act2)
            top_row.setOrientation(LinearLayout.HORIZONTAL)
            top_row.setGravity(Gravity.CENTER_VERTICAL)

            if no_wpm:
                main_num = TextView(act2)
                main_num.setText(f"{accuracy}%")
                main_num.setTextSize(TypedValue.COMPLEX_UNIT_SP, 80)
                main_num.setTextColor(Color.parseColor(colors["accent"]))
                main_num.setTypeface(Typeface.DEFAULT_BOLD)
                top_row.addView(main_num)

                right_col = LinearLayout(act2)
                right_col.setOrientation(LinearLayout.VERTICAL)
                right_col.setGravity(Gravity.CENTER_VERTICAL)
                rcp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                )
                rcp.setMargins(dp(act2, 10), 0, 0, 0)
                right_col.setLayoutParams(rcp)

                lbl1 = TextView(act2)
                lbl1.setText("точность")
                lbl1.setTextSize(TypedValue.COMPLEX_UNIT_SP, 13)
                lbl1.setTextColor(Color.parseColor(colors["accent"]))
                right_col.addView(lbl1)

                lbl2 = TextView(act2)
                lbl2.setText("no wpm mode")
                lbl2.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
                lbl2.setTextColor(Color.parseColor("#555555"))
                right_col.addView(lbl2)

                top_row.addView(right_col)

            else:
                wpm_num = TextView(act2)
                wpm_num.setText(str(wpm))
                wpm_num.setTextSize(TypedValue.COMPLEX_UNIT_SP, 80)
                wpm_num.setTextColor(Color.parseColor(colors["accent"]))
                wpm_num.setTypeface(Typeface.DEFAULT_BOLD)
                top_row.addView(wpm_num)

                right_col = LinearLayout(act2)
                right_col.setOrientation(LinearLayout.VERTICAL)
                right_col.setGravity(Gravity.CENTER_VERTICAL)
                rcp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                )
                rcp.setMargins(dp(act2, 10), 0, 0, 0)
                right_col.setLayoutParams(rcp)

                wlbl = TextView(act2)
                wlbl.setText("слов/мин")
                wlbl.setTextSize(TypedValue.COMPLEX_UNIT_SP, 13)
                wlbl.setTextColor(Color.parseColor(colors["accent"]))
                right_col.addView(wlbl)

                if no_accuracy:
                    badge = TextView(act2)
                    badge.setText("no accuracy mode")
                    badge.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
                    badge.setTextColor(Color.parseColor("#555555"))
                    right_col.addView(badge)
                else:
                    acc_color = colors["correct"] if accuracy >= 90 else "#FF9800" if accuracy >= 70 else colors["wrong"]
                    acc_num = TextView(act2)
                    acc_num.setText(f"{accuracy}%")
                    acc_num.setTextSize(TypedValue.COMPLEX_UNIT_SP, 22)
                    acc_num.setTextColor(Color.parseColor(acc_color))
                    acc_num.setTypeface(Typeface.DEFAULT_BOLD)
                    right_col.addView(acc_num)

                    acc_lbl = TextView(act2)
                    acc_lbl.setText("точность")
                    acc_lbl.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11)
                    acc_lbl.setTextColor(Color.parseColor("#444444"))
                    right_col.addView(acc_lbl)

                top_row.addView(right_col)

            rl.addView(top_row)

            def make_sep_view():
                v = View(act2)
                v.setBackground(make_bg("#1E1E1E", 0, act2))
                mp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, dp(act2, 1))
                mp.setMargins(0, dp(act2, 14), 0, dp(act2, 10))
                v.setLayoutParams(mp)
                return v

            def section_lbl(txt):
                tv = TextView(act2)
                tv.setText(txt)
                tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 10)
                tv.setTextColor(Color.parseColor("#444444"))
                tv.setPadding(0, 0, 0, dp(act2, 6))
                return tv

            def stat_card(label, value, value_color="#CCCCCC"):
                row = LinearLayout(act2)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setBackground(make_bg(colors["card"], 10, act2))
                row.setPadding(dp(act2, 14), dp(act2, 10), dp(act2, 14), dp(act2, 10))
                rp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                )
                rp.setMargins(0, dp(act2, 4), 0, 0)
                row.setLayoutParams(rp)

                lv = TextView(act2)
                lv.setText(label)
                lv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 13)
                lv.setTextColor(Color.parseColor("#555555"))
                lv.setLayoutParams(
                    LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                )
                row.addView(lv)

                vv = TextView(act2)
                vv.setText(value)
                vv.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16)
                vv.setTextColor(Color.parseColor(value_color))
                vv.setTypeface(Typeface.DEFAULT_BOLD)
                row.addView(vv)
                return row

            rl.addView(make_sep_view())
            rl.addView(section_lbl("РЕЗУЛЬТАТ"))
            rl.addView(stat_card("Набрано слов", str(total)))
            rl.addView(stat_card("Время теста", f"{elapsed} сек"))
            if not no_accuracy:
                rl.addView(stat_card("Правильных слов", f"{correct} из {total}"))

            if not no_wpm:
                rl.addView(make_sep_view())
                rl.addView(section_lbl("СКОРОСТЬ ПЕЧАТИ"))
                rl.addView(stat_card("Слов в минуту", str(wpm), colors["accent"]))
                rl.addView(stat_card("Букв в минуту", str(cpm), "#FF9800"))
                rl.addView(stat_card("Букв в секунду", f"{bps:.2f}", "#9C27B0"))

            if avg_ms > 0:
                rl.addView(make_sep_view())
                rl.addView(section_lbl("СКОРОСТЬ ОДНОГО НАЖАТИЯ"))
                ms_col = colors["correct"] if avg_ms < 150 else "#FF9800" if avg_ms < 300 else colors["wrong"]
                rl.addView(stat_card("Среднее время нажатия", f"{avg_ms} мс", ms_col))
                kps = 1000.0 / avg_ms
                rl.addView(stat_card("Нажатий в секунду", f"{kps:.1f}", colors["accent"]))

                if avg_ms < 100:
                    grade, gcol = "🔥 Молния!", colors["wrong"]
                elif avg_ms < 150:
                    grade, gcol = "⚡ Очень быстро", "#FF9800"
                elif avg_ms < 250:
                    grade, gcol = "✅ Хорошо", colors["correct"]
                elif avg_ms < 400:
                    grade, gcol = "📝 Средне", "#888888"
                else:
                    grade, gcol = "🐢 Медленно", "#555555"

                rl.addView(stat_card("Оценка", grade, gcol))

            res_scroll.addView(rl)
            rb.set_view(res_scroll)
            rb.set_positive_button(
                "↻  Ещё раз",
                lambda b, w: (b.dismiss(), run_on_ui_thread(self._show_wpm_dialog))
            )
            rb.set_negative_button("Закрыть", lambda b, w: b.dismiss())
            rb.show()

        def on_text_changed(text: str):
            if state["finished"]:
                return

            now = time.time()
            new_len = len(text)
            prev_len = state["prev_len"]

            if new_len > prev_len:
                added = new_len - prev_len
                state["total_chars"] += added
                for _ in range(added):
                    state["keystroke_times"].append(now)

            state["prev_len"] = new_len
            state["current_word_partial"] = text.rstrip(" ")

            if not state["started"] and text.strip():
                threading.Thread(target=start_timer, daemon=True).start()

            if text.endswith(" "):
                word = text.strip()
                state["prev_len"] = 0
                state["current_word_partial"] = ""

                if word:
                    idx = len(state["typed_words"])
                    state["typed_words"].append(word)

                    if idx < len(state["test_words"]):
                        target = state["test_words"][idx]
                        ok = (word == target)
                        state["word_colors"][idx] = colors["correct"] if ok else colors["wrong"]

                    if len(state["typed_words"]) >= len(state["test_words"]):
                        run_on_ui_thread(finish_test)
                        return

                state["last_ui_update"] = 0.0
                state["pending_ui"] = False
                schedule_text_update()

                def _clear_field():
                    try:
                        w_ref = watcher_holder[0]
                        hidden_et.removeTextChangedListener(w_ref)
                        hidden_et.getText().clear()
                        hidden_et.addTextChangedListener(w_ref)
                        state["prev_len"] = 0
                    except Exception as e:
                        log(f"_clear_field: {e}")

                run_on_ui_thread(_clear_field)
            else:
                schedule_text_update()

        watcher_holder = [None]
        watcher = PyTextWatcher(on_text_changed)
        watcher_holder[0] = watcher
        hidden_et.addTextChangedListener(watcher)

        def on_text_area_click(v):
            if not state["finished"]:
                run_on_ui_thread(show_keyboard)

        text_frame.setOnClickListener(OnClickListener(on_text_area_click))
        text_tv.setOnClickListener(OnClickListener(on_text_area_click))
        text_scroll.setOnClickListener(OnClickListener(on_text_area_click))

        settings_btn.setOnClickListener(
            OnClickListener(lambda v: run_on_ui_thread(self._build_settings_dialog))
        )

        builder.set_cancelable(False)
        builder.show()

    def _on_no_accuracy_change(self, enabled: bool):
        if enabled:
            self.set_setting("no_wpm", False)
        self.set_setting("no_accuracy", enabled, reload_settings=True)

    def _on_no_wpm_change(self, enabled: bool):
        if enabled:
            self.set_setting("no_accuracy", False)
        self.set_setting("no_wpm", enabled, reload_settings=True)

    def _on_custom_words_toggle(self, enabled: bool):
        self.set_setting("use_custom_words", enabled, reload_settings=True)

    def _on_custom_words_change(self, value: str):
        self.log(f"Слов в списке: {len(value.split())}")

    def create_settings(self):
        use_custom = self.get_setting("use_custom_words", False)
        no_accuracy = self.get_setting("no_accuracy", False)
        no_wpm = self.get_setting("no_wpm", False)

        mode_hint = ""
        if no_accuracy:
            mode_hint = "  •  режим: без точности"
        elif no_wpm:
            mode_hint = "  •  режим: без впм"

        items = [
            Header(text="Тест ВПМ"),
            Text(
                text="Открыть тест",
                subtext="Нажмите, чтобы начать тест скорости набора" + mode_hint,
                icon="msg_search",
                accent=True,
                on_click=self._open_wpm_test
            ),
            Divider(),
            Header(text="Режим теста"),
            Switch(
                key="no_accuracy",
                text="Без точности (No Accuracy)",
                default=False,
                subtext="Показывать только ВПМ, точность не считается",
                icon="msg_stats",
                on_change=self._on_no_accuracy_change
            ),
            Switch(
                key="no_wpm",
                text="Без ВПМ (No WPM)",
                default=False,
                subtext="Показывать только точность, скорость не считается",
                icon="msg_stats",
                on_change=self._on_no_wpm_change
            ),
            Divider(),
            Header(text="Свои слова"),
            Switch(
                key="use_custom_words",
                text="Использовать свои слова",
                default=False,
                subtext="Тест будет использовать ваш список вместо стандартного",
                icon="msg_list",
                on_change=self._on_custom_words_toggle
            ),
        ]

        if use_custom:
            items += [
                EditText(
                    key="custom_words",
                    hint="Введите слова через пробел или Enter...",
                    default="",
                    multiline=True,
                    max_length=5000,
                    on_change=self._on_custom_words_change
                ),
                Divider(text="Слова нормализуются автоматически: ё→е, заглавные→строчные, чужие символы убираются."),
            ]
        else:
            items += [
                Divider(text="Включите выше, чтобы ввести свои слова для теста."),
            ]

        items.append(Divider(text="Version - Alpha, могут быть куча багов #🐢 черепаха одобряет (⚙)"))
        return items
