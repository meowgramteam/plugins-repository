__id__ = "number_in_profile_randomizer_rn"
__name__ = "Profile Number"
__description__ = "Позволяет скрыть реальный номер телефона в профиле (Полезно для скринов)"
__author__ = "@RnPlugins"
__version__ = "1.0.2"
__icon__ = "RnDev/12"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader, LocaleController
from hook_utils import find_class
from ui.settings import Input, Header, Divider

DEX_B64 = """"""

def get_localized_strings():
    lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
    
    strings = {
        "ru": {
            "settings_title": "Настройки Номера",
            "country_code": "Код страны",
            "country_code_sub": "Только цифры",
            "country_code_desc": "Код страны для генерации случайного номера (например, 7 или 380).",
            "operator_code": "Код оператора",
            "operator_code_sub": "Если пусто, будет случайным",
            "operator_code_desc": "Код оператора из 3 цифр (например, 912). Если пусто, генерируется случайно при старте.",
            "custom_numbers": "Кастомные номера",
            "custom_numbers_sub": "Номера через запятую",
            "custom_numbers_desc": "Если заполнено, плагин будет брать номера отсюда вместо генерации случайных.",
            "default_country_code": "7"
        },
        "uk": {
            "settings_title": "Налаштування Номера",
            "country_code": "Код країни",
            "country_code_sub": "Тільки цифри",
            "country_code_desc": "Код країни для генерації випадкового номера (наприклад, 7 або 380).",
            "operator_code": "Код оператора",
            "operator_code_sub": "Якщо порожньо, буде випадковим",
            "operator_code_desc": "Код оператора з 3 цифр (наприклад, 912). Якщо порожньо, генерується випадково при старті.",
            "custom_numbers": "Користувацькі номери",
            "custom_numbers_sub": "Номери через кому",
            "custom_numbers_desc": "Якщо заповнено, плагін братиме номери звідси замість генерації випадкових.",
            "default_country_code": "380"
        },
        "en": {
            "settings_title": "Number Settings",
            "country_code": "Country Code",
            "country_code_sub": "Digits only",
            "country_code_desc": "Country code for generating a random number (e.g., 7 or 380).",
            "operator_code": "Operator Code",
            "operator_code_sub": "If empty, will be random",
            "operator_code_desc": "3-digit operator code (e.g., 912). If empty, generated randomly on start.",
            "custom_numbers": "Custom Numbers",
            "custom_numbers_sub": "Numbers separated by commas",
            "custom_numbers_desc": "If filled, the plugin will use numbers from this list instead of generating random ones.",
            "default_country_code": "1"
        }
    }
    
    return strings.get(lang, strings["en"])

class RandomPhonePlugin(BasePlugin):
    def on_plugin_load(self):
        try:
            self.log("Loading Java ProfileNumberRandomizer module...")
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.profilenumber.ProfileNumberRandomizer")
            
            country_code = self.get_setting("country_code", "7")
            operator_code = self.get_setting("operator_code", "")
            custom_numbers = self.get_setting("custom_numbers", "")
            
            string_class = find_class("java.lang.String")
            update_method = self.dex_class.getMethod("updateSettings", string_class, string_class, string_class)
            update_method.invoke(None, country_code, operator_code, custom_numbers)
            
            start_method = self.dex_class.getMethod("start")
            start_method.invoke(None)
            self.log("Java ProfileNumberRandomizer module loaded and started successfully.")
        except Exception as e:
            self.log(f"Failed to load Java ProfileNumberRandomizer module: {e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading Java ProfileNumberRandomizer module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(None)
                self.log("Java ProfileNumberRandomizer module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
        except Exception as e:
            self.log(f"Failed to unload Java ProfileNumberRandomizer module: {e}")

    def create_settings(self):
        s = get_localized_strings()
        return [
            Input(
                key="country_code",
                text=s["country_code"],
                subtext=s["country_code_sub"],
                default=s["default_country_code"], 
                icon="msg_language"
            ),
            Divider(text=s["country_code_desc"]),
            
            Input(
                key="operator_code", 
                text=s["operator_code"], 
                subtext=s["operator_code_sub"],
                default="", 
                icon="input_bot2"
            ),
            Divider(text=s["operator_code_desc"]),
            
            Input(
                key="custom_numbers",
                text=s["custom_numbers"],
                subtext=s["custom_numbers_sub"],
                default="",
                icon="input_bot1"
            ),
            Divider(text=s["custom_numbers_desc"]),
        ]
