    def _apply_cfg(self, _=None):
        def _i(k, d):
            try:    return max(1, int(self.get_setting(k, str(d))))
            except: return d
        def _b(k, d=True):
            try:    return bool(self.get_setting(k, d))
            except: return d
        _effect.apply_cfg(
            spark_spawn=_i("spark_spawn",85),      spark_count=_i("spark_count",20),
            sun_pos_x=_i("sun_pos_x",82),          sun_pos_y=_i("sun_pos_y",12),
            sun_ray_speed=_i("sun_ray_speed",3),
            cloud_speed=_i("cloud_speed",11),      cloud_spawn=_i("cloud_spawn",97),
            cloud_count=_i("cloud_count",12),
            fog_speed=_i("fog_speed",6),           fog_spawn=_i("fog_spawn",88),
            fog_count=_i("fog_count",12),
            lrain_speed=_i("lrain_speed",35),      lrain_spawn=_i("lrain_spawn",80),
            lrain_count=_i("lrain_count",50),
            rain_speed=_i("rain_speed",55),        rain_spawn=_i("rain_spawn",55),
            rain_count=_i("rain_count",150),
            thunder_speed=_i("thunder_speed",75),  thunder_spawn=_i("thunder_spawn",45),
            lsnow_speed=_i("lsnow_speed",18),      lsnow_spawn=_i("lsnow_spawn",82),
            lsnow_count=_i("lsnow_count",40),
            snow_speed=_i("snow_speed",22),        snow_spawn=_i("snow_spawn",70),
            snow_count=_i("snow_count",100),
            hail_speed=_i("hail_speed",90),        hail_spawn=_i("hail_spawn",50),
            hail_count=_i("hail_count",120),
            lightning_intensity=_i("lightning_intensity",210),
            lightning_speed=_i("lightning_speed",18),
            opacity_clear=_i("opacity_clear",100),
            opacity_partly_cloudy=_i("opacity_partly_cloudy",100),
            opacity_cloudy=_i("opacity_cloudy",100),
            opacity_fog=_i("opacity_fog",100),
            opacity_light_rain=_i("opacity_light_rain",100),
            opacity_rain=_i("opacity_rain",100),
            opacity_thunder=_i("opacity_thunder",100),
            opacity_light_snow=_i("opacity_light_snow",100),
            opacity_snow=_i("opacity_snow",100),
            opacity_sleet=_i("opacity_sleet",100),
            opacity_hail=_i("opacity_hail",100),
            opacity_clear_night=_i("opacity_clear_night",100),
            opacity_partly_night=_i("opacity_partly_night",100),
            star_count=_i("star_count",60),
            moon_size=_i("moon_size",13),
            moon_phase=_i("moon_phase",5),
            shooting_star_interval=_i("shooting_star_interval",3600),
            star_twinkle_speed=_i("star_twinkle_speed",45),
            sun_ray_count=_i("sun_ray_count",8),
            show_sun=_b("show_sun"),       show_moon=_b("show_moon"),
            show_stars=_b("show_stars"),   show_clouds=_b("show_clouds"),
            show_sparks=_b("show_sparks"), show_rain=_b("show_rain"),
            show_snow=_b("show_snow"),     show_fog=_b("show_fog"),
            show_lightning=_b("show_lightning"), show_spring=_b("show_spring"),
                   show_rocket=_b("show_rocket",True), rocket_interval=_i("rocket_interval",7200),
            night_start=_i("night_start",20), day_start=_i("day_start",6),
            size_sun=_i("size_sun",100),     size_moon=_i("size_moon",100),
            size_stars=_i("size_stars",100), size_sparks=_i("size_sparks",100),
            size_clouds=_i("size_clouds",100), size_rain=_i("size_rain",100),
            size_snow=_i("size_snow",100),   size_fog=_i("size_fog",100),
            size_hail=_i("size_hail",100),   size_spring=_i("size_spring",100),
            cloud_max_y=_i("cloud_max_y",65),
        )

    def create_settings(self) -> List[Any]:
        return [
            Header(text="Dynamic Backgrounds"),
            Text(text="Предпросмотр", icon="msg_photos",
                 on_click=self._open_preview_chat),

            Switch(key="enabled", text="Включить эффект", default=True, icon="msg_settings"),
            Switch(key="effects_everywhere", text="Эффекты везде (не только в чате)",
                   icon="msg_filled_reactions", default=False,
                   on_change=lambda v: run_on_ui_thread(self._update_effect_overlay)),
            Divider(),
            Header(text="Температура"),
            Switch(key="show_temperature", text="Показывать температуру",
                   icon="msg_weather", default=True,
                   on_change=lambda v: (run_on_ui_thread(self._update_temp_overlay)
                                        if v else run_on_ui_thread(self._remove_temp_overlay))),
            Input(key="temp_font_size", text="Размер текста", default="12",
                  subtext="sp (8–24)", icon="msg_media",
                  on_change=lambda v: run_on_ui_thread(self._update_temp_overlay)),
            Selector(key="temp_tap_action", text="Действие по нажатию", default=0,
                     icon="msg_media",
                     items=["🔄 Обновить погоду", "🌗 День / Ночь", "👁 Скрыть/показать"],
                     on_change=lambda v: None),
            Text(text="Сбросить позицию температуры", icon="msg_retry",
                 on_click=self._reset_temp_pos),
            Divider(),
            Header(text="Погода"),
            Selector(
                key="startup_weather",
                text="Погода при запуске",
                default=0,
                items=["🔄 Авто (по GPS/IP)", "☀️ Ясно", "🌙 Ночь",
                       "🌸 Весна", "⛅ Перем. облачность", "☁️ Облачно",
                       "🌫 Туман", "🌦 Лёгкий дождь", "🌧 Дождь",
                       "⚡ Гроза", "🌨 Лёгкий снег", "❄️ Снег",
                       "🌧❄ Слякоть", "🌨🧊 Град"],
                icon="msg_schedule",
                on_change=self._on_startup_weather_change,
            ),
            Divider(text="Если выбрана конкретная погода — авто-определение отключается"),
            Input(key="city", text="Город (запасной)", default="",
                  subtext="Если задан — используется вместо GPS/IP. Пример: Moscow",
                  icon="msg_location",
                  on_change=lambda v: (self.set_setting("city", str(v).strip()),
                                       self._invalidate_cache())),
            Text(text="Обновить погоду сейчас", icon="media_repost",
                 on_click=self._force_refresh),
            Input(key="update_interval", text="Интервал обновления", default="30",
                  subtext="минут (минимум 5)", icon="msg_calendar2",
                  on_change=lambda v: self.set_setting("update_interval", str(max(5, int(v or 30))))),
            Divider(),
            Header(text="Время суток"),
            Input(key="night_start", text="Начало ночи", default="20",
                  subtext="часов (0–23), по умолч. 20:00", icon="msg_media", on_change=self._apply_cfg),
            Input(key="day_start", text="Начало дня", default="6",
                  subtext="часов (0–23), по умолч. 06:00", icon="msg_media", on_change=self._apply_cfg),
            Divider(),
            Header(text="Элементы эффектов"),
            Switch(key="show_sun",       text="☀️ Солнце",          default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_moon",      text="🌙 Луна",             default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_stars",     text="✨ Звёзды",           default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_sparks",    text="💫 Искры (ясно)",     default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_clouds",    text="☁️ Облака",           default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_rain",      text="🌧 Дождь / Слякоть",  default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_snow",      text="❄️ Снег",             default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_fog",       text="🌫 Туман",            default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_lightning", text="⚡ Молния",           default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_spring",    text="🌸 Весенние частицы", default=True, icon="msg_media", on_change=self._apply_cfg),
            Switch(key="show_rocket",    text="🚀 Ракета (ясно, ночь)", default=True, icon="msg_media", on_change=self._apply_cfg),

            Divider(),
            Header(text="Тонкая настройка"),
            Text(text="☀️ Ясно",                  icon="msg_list", create_sub_fragment=self._sub_clear),
            Text(text="⛅ Переменная облачность",  icon="msg_list", create_sub_fragment=self._sub_partly_cloudy),
            Text(text="☁️ Облачно / Пасмурно",    icon="msg_list", create_sub_fragment=self._sub_cloudy),
            Text(text="🌫 Туман",                  icon="msg_list", create_sub_fragment=self._sub_fog),
            Text(text="🌦 Лёгкий дождь / Морось",  icon="msg_list", create_sub_fragment=self._sub_light_rain),
            Text(text="🌧 Дождь",                  icon="msg_list", create_sub_fragment=self._sub_rain),
            Text(text="⚡ Гроза",                  icon="msg_list", create_sub_fragment=self._sub_thunder),
            Text(text="🌨 Лёгкий снег",            icon="msg_list", create_sub_fragment=self._sub_light_snow),
            Text(text="❄️ Снег / Буран + Слякоть", icon="msg_list", create_sub_fragment=self._sub_snow),
            Text(text="🌨 Ледяная крупа / Град",   icon="msg_list", create_sub_fragment=self._sub_hail),
            Divider(),
        ]

    # ── Preview (sub-fragment) ────────────────────────────────────────────────

    # ── Preview: открываем чат + вешаем overlay с кнопками ──────────────────

    _PREVIEW_WEATHERS = [
        ("☀️", "clear",         False, False),
        ("🌙", "clear",         True,  False),
        ("🌸", "clear",         False, True),
        ("⛅", "partly_cloudy", False, False),
        ("☁️", "cloudy",        False, False),
        ("🌫", "fog",           False, False),
        ("🌦", "light_rain",    False, False),
        ("🌧", "rain",          False, False),
        ("⚡", "thunder",       False, False),
        ("🌨", "light_snow",    False, False),
        ("❄️", "snow",          False, False),
        ("🌨❄", "sleet",        False, False),
        ("🌨🧊", "hail",        False, False),
    ]


    def _open_preview_chat(self, _):
        try:
            # 1. Сохраняем текущую погоду
            self._preview_saved_wt     = self._weather_type
            self._preview_saved_mode   = getattr(_effect, "_clear_mode", "auto")
            self._preview_saved_spring = getattr(_effect, "cfg_show_spring", True)

            # 2. Открываем чат @dynamicbackground по диплинку
            frag = get_last_fragment()
            act  = frag.getParentActivity() if frag else None
            if act:
                try:
                    i = Intent(Intent.ACTION_VIEW,
                               Uri.parse("tg://resolve?domain=dynamicbackground"))
                    i.setPackage(act.getPackageName())
                    act.startActivity(i)
                except Exception:
                    act.startActivity(Intent(Intent.ACTION_VIEW,
                        Uri.parse("https://t.me/dynamicbackground")))

            # 3. Через 600мс вешаем overlay-полосу поверх чата
            import threading
            threading.Timer(0.4, lambda: run_on_ui_thread(self._attach_preview_bar)).start()

        except Exception as e:
            self.log(f"{self.TAG} open_preview_chat: {e}")

    def _attach_preview_bar(self):
        try:
            frag = get_last_fragment()
            act  = frag.getParentActivity() if frag else None
            if not act: return

            deco = act.getWindow().getDecorView()
            self._detach_preview_bar(deco)

            bar = _LL(act)
            bar.setOrientation(_LL.HORIZONTAL)
            bar.setTag("dynbg_preview_bar")
            bar.setBackgroundColor(-16777216)  # #FF000000 чёрный

            # ── Горизонтальный скролл с эмодзи ───────────────────────────────
            from android.widget import HorizontalScrollView as _HSV
            hs = _HSV(act)
            hs.setHorizontalScrollBarEnabled(False)
            btn_row = _LL(act)
            btn_row.setOrientation(_LL.HORIZONTAL)

            # Кнопка 🔄 — сброс на реальную погоду
            reset_tv = _TV(act)
            reset_tv.setText("🔄")
            reset_tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 24)
            reset_tv.setGravity(_G.CENTER)
            reset_tv.setPadding(_AU.dp(10), _AU.dp(6), _AU.dp(10), _AU.dp(6))
            reset_tv.setClickable(True)

            def on_reset(v):
                try:
                    _effect._clear_mode     = getattr(self, "_preview_saved_mode", "auto")
                    _effect.cfg_show_spring = getattr(self, "_preview_saved_spring", True)
                    saved = getattr(self, "_preview_saved_wt", self._weather_type)
                    _effect.set_weather(saved)
                    self._weather_type = saved
                    if _effect.last_view:
                        try:    _effect.last_view.postInvalidateOnAnimation()
                        except: _effect.last_view.invalidate()
                except Exception as ex:
                    self.log(f"{self.TAG} bar reset: {ex}")

            reset_tv.setOnClickListener(OnClickListener(on_reset))
            btn_row.addView(reset_tv, _LH.createLinear(-2, -1))

            # Разделитель после 🔄
            sep0 = _View(act)
            sep0.setBackgroundColor(419430399)
            btn_row.addView(sep0, _LH.createLinear(1, -2, 0, _AU.dp(8), 0, _AU.dp(8)))

            for i, (emoji, wt, night, spring) in enumerate(self._PREVIEW_WEATHERS):
                # Разделитель перед каждым элементом кроме первого
                if i > 0:
                    sep = _View(act)
                    sep.setBackgroundColor(419430399)  # #18FFFFFF
                    btn_row.addView(sep, _LH.createLinear(1, -2, 0, _AU.dp(8), 0, _AU.dp(8)))

                tv = _TV(act)
                tv.setText(emoji)
                tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 24)
                tv.setGravity(_G.CENTER)
                tv.setPadding(_AU.dp(10), _AU.dp(6), _AU.dp(10), _AU.dp(6))
                tv.setClickable(True)

                def on_tap(v, w=wt, n=night, s=spring):
                    try:
                        _effect._clear_mode     = "moon" if n else "auto"
                        _effect.cfg_show_spring = s
                        _effect.set_weather(w)
                        self._weather_type = w
                        if _effect.last_view:
                            try:    _effect.last_view.postInvalidateOnAnimation()
                            except: _effect.last_view.invalidate()
                    except Exception as ex:
                        self.log(f"{self.TAG} bar tap: {ex}")

                tv.setOnClickListener(OnClickListener(on_tap))
                btn_row.addView(tv, _LH.createLinear(-2, -1))

            hs.addView(btn_row, _LH.createFrame(-2, -1))
            bar.addView(hs, _LH.createLinear(0, -1, 1.0))

            # Добавляем полосу снизу экрана
            from android.widget import FrameLayout as _FL2
            lp = _FL2.LayoutParams(-1, _AU.dp(56))
            lp.gravity = _G.BOTTOM | _G.START
            deco.addView(bar, lp)
            self._preview_bar_ref = bar

        except Exception as e:
            self.log(f"{self.TAG} attach_preview_bar: {e}")
            import traceback; self.log(traceback.format_exc())

    def _detach_preview_bar(self, deco=None):
        try:
            if deco is None:
                frag = get_last_fragment()
                act  = frag.getParentActivity() if frag else None
                if not act: return
                deco = act.getWindow().getDecorView()
            bar = getattr(self, "_preview_bar_ref", None)
            if bar is not None:
                try:
                    deco.removeView(bar)
                except Exception: pass
                self._preview_bar_ref = None
        except Exception as e:
            self.log(f"{self.TAG} detach_preview_bar: {e}")


    def _apply_startup_weather(self, wt: str):
        """Применяет стартовую погоду немедленно."""
        if wt == "clear_night":
            _effect._clear_mode = "moon"
            _effect.set_weather("clear")
            self._weather_type = "clear"
        elif wt == "spring":
            _effect._clear_mode = "auto"
            _effect.cfg_show_spring = True
            _effect.set_weather("clear")
            self._weather_type = "clear"
        else:
            _effect._clear_mode = "auto"
            _effect.set_weather(wt)
            self._weather_type = wt
        if _effect.last_view:
            try:    _effect.last_view.postInvalidateOnAnimation()
            except: _effect.last_view.invalidate()

    _STARTUP_VALUES = [
        "auto", "clear", "clear_night", "spring",
        "partly_cloudy", "cloudy", "fog", "light_rain",
        "rain", "thunder", "light_snow", "snow", "sleet", "hail",
    ]

    def _on_startup_weather_change(self, idx: int):
        try:
            # idx — целое число от Selector (0 = авто, 1+ = конкретная погода)
            wt = self._STARTUP_VALUES[idx] if 0 <= idx < len(self._STARTUP_VALUES) else "auto"
            self.set_setting("startup_weather", idx)  # сохраняем индекс
            if wt == "auto":
                self._last_update = 0.0
                self._cache.clear()
                run_on_queue(self._fetch_and_apply)
                BulletinHelper.show_info("🔄 Авто-погода включена")
            else:
                self._apply_startup_weather(wt)
                BulletinHelper.show_success(f"Стартовая погода: {wt}")
        except Exception as e:
            self.log(f"{self.TAG} startup_weather_change: {e}")

    def _update_temp_overlay(self):
        """Создаёт/обновляет температурный pill поверх DecorView."""
        try:
            temp = getattr(_effect, "_temp_celsius", None)
            if temp is None: return
            if not self.get_setting("show_temperature", True):
                self._remove_temp_overlay()
                return

            frag = get_last_fragment()
            act  = frag.getParentActivity() if frag else None
            if not act: return
            deco = act.getWindow().getDecorView()

            import struct as _st3
            def _sc3(c): return _st3.unpack('>i',_st3.pack('>I',c&0xFFFFFFFF))[0]

            # Иконка по температуре
            if temp <= -5:   icon = "❄"
            elif temp <= 10: icon = "🌤"
            elif temp <= 25: icon = "☀"
            else:            icon = "🔥"

            # Цвета пилла из темы TG: фон карточки + текст
            def _to_int3(v):
                v = int(v) & 0xFFFFFFFF
                return v - 0x100000000 if v >= 0x80000000 else v
            def _tc3(key, fallback):
                try:    return _to_int3(int(_Theme.getColor(getattr(_Theme, key))))
                except: return _to_int3(fallback)
            bg_col  = _tc3("key_actionBarActionModeDefault", 0xFF1C1C1E)
            txt_col = _tc3("key_windowBackgroundWhiteBlackText", 0xFFFFFFFF)

            sign = "+" if temp > 0 else ""
            font_size = max(8, min(24, int(self.get_setting("temp_font_size", "12") or 12)))
            label = f"{icon} {sign}{temp:.0f}°"

            if not getattr(self, "_temp_view", None):
                from android.widget import FrameLayout as _FL3
                from android.graphics.drawable import GradientDrawable as _GD3
                from android.graphics import Typeface as _TF3
                from java import dynamic_proxy
                tv = _TV(act)
                tv.setTag("dynbg_temp")
                tv.setGravity(_G.CENTER)
                tv.setSingleLine(True)
                try: tv.setTypeface(_TF3.create("sans-serif-medium", _TF3.NORMAL))
                except Exception: pass
                tv.setLetterSpacing(0.02)
                bg_dr = _GD3()
                bg_dr.setShape(_GD3.RECTANGLE)
                bg_dr.setCornerRadius(_AU.dp(16))
                tv.setBackground(bg_dr)
                tv.setPadding(_AU.dp(10), _AU.dp(5), _AU.dp(10), _AU.dp(5))
                # Позиция из настроек или дефолтная
                saved_x = int(self.get_setting("temp_pos_x", str(_AU.dp(2))))
                saved_y = int(self.get_setting("temp_pos_y", str(_AU.dp(80))))
                lp = _FL3.LayoutParams(-2, -2)
                lp.gravity = _G.TOP | _G.START
                lp.leftMargin = saved_x
                lp.topMargin  = saved_y
                deco.addView(tv, lp)
                self._temp_view = tv
                self._temp_lp   = lp
                self._temp_deco = deco

                # Touch: tap = действие, long press = drag
                _plugin_self = self
                OnTouchListener = dynamic_proxy(find_class("android.view.View$OnTouchListener"))
                class _TempTouch(OnTouchListener):
                    def __init__(self):
                        super().__init__()
                        self._dx = 0.0; self._dy = 0.0
                        self._down_x = 0.0; self._down_y = 0.0
                        self._dragging = False
                        self._down_t = 0.0
                    def onTouch(self, v, ev):
                        try:
                            import time as _tt
                            action = ev.getAction()
                            if action == 0:   # DOWN
                                self._down_x = ev.getRawX(); self._down_y = ev.getRawY()
                                self._down_t = _tt.monotonic()
                                self._dx = lp.leftMargin - ev.getRawX()
                                self._dy = lp.topMargin  - ev.getRawY()
                                self._dragging = False
                            elif action == 2: # MOVE
                                dx = abs(ev.getRawX() - self._down_x)
                                dy = abs(ev.getRawY() - self._down_y)
                                held = _tt.monotonic() - self._down_t > 0.35
                                if self._dragging or (held and (dx > 8 or dy > 8)):
                                    self._dragging = True
                                    lp.leftMargin = int(ev.getRawX() + self._dx)
                                    lp.topMargin  = int(ev.getRawY() + self._dy)
                                    v.setLayoutParams(lp)
                            elif action == 1: # UP
                                if self._dragging:
                                    _plugin_self.set_setting("temp_pos_x", str(lp.leftMargin))
                                    _plugin_self.set_setting("temp_pos_y", str(lp.topMargin))
                                else:
                                    # Tap — выполняем настроенное действие
                                    action_idx = int(_plugin_self.get_setting("temp_tap_action", 0) or 0)
                                    def _do_tap(idx=action_idx):
                                        try:
                                            if idx == 0:   # Обновить погоду
                                                _plugin_self._last_update = 0.0
                                                _plugin_self._cache.clear()
                                                run_on_queue(_plugin_self._fetch_and_apply)
                                                BulletinHelper.show_success("🔄 Обновление погоды...")
                                            elif idx == 1: # День ↔ Ночь
                                                cur = _plugin_self.get_setting("clear_mode", "auto")
                                                nxt = "moon" if cur != "moon" else "sun"
                                                _plugin_self.set_setting("clear_mode", nxt)
                                                _effect._clear_mode = nxt
                                                icon = "🌙" if nxt == "moon" else "☀️"
                                                BulletinHelper.show_success(f"{icon} Режим: {'ночь' if nxt=='moon' else 'день'}")
                                                if _effect.last_view:
                                                    try: _effect.last_view.postInvalidateOnAnimation()
                                                    except: pass
                                            elif idx == 2: # Скрыть/показать
                                                cur_show = _plugin_self.get_setting("show_temperature", True)
                                                _plugin_self.set_setting("show_temperature", not cur_show)
                                                if cur_show:
                                                    run_on_ui_thread(_plugin_self._remove_temp_overlay)

                                        except Exception as ex:
                                            log(f"[DynBG] temp tap: {ex}")
                                    run_on_ui_thread(_do_tap)
                        except Exception: pass
                        return True
                tv.setOnTouchListener(_TempTouch())

            tv = self._temp_view
            tv.setText(label)
            tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, font_size)
            tv.setTextColor(txt_col)
            try:
                tv.getBackground().setColor(bg_col)
            except Exception: pass
        except Exception as e:
            self.log(f"{self.TAG} temp_overlay: {e}")

    def _remove_temp_overlay(self):
        try:
            tv = getattr(self, "_temp_view", None)
            if tv:
                frag = get_last_fragment()
                act  = frag.getParentActivity() if frag else None
                if act:
                    act.getWindow().getDecorView().removeView(tv)
                self._temp_view = None
        except Exception: pass

    # ── Effect Overlay (режим везде) ──────────────────────────────────────────

    def _setup_effect_overlay(self):
        """Создаёт прозрачный View поверх DecorView и хукает его onDraw."""
        try:
            if getattr(self, "_effect_overlay", None) is not None:
                return  # уже создан
            frag = get_last_fragment()
            act  = frag.getParentActivity() if frag else None
            if not act: return
            deco = act.getWindow().getDecorView()
            from android.widget import FrameLayout as _FLO
            # Создаём обычный View
            view_cls = find_class("android.view.View")
            ov = view_cls(act)
            ov.setTag("dynbg_overlay")
            # Хукаем onDraw этого конкретного экземпляра через класс
            # Используем trick: хукаем View.onDraw и фильтруем по тегу
            hook = _OverlayDrawHook()
            hook._view = ov  # фиксируем конкретный экземпляр
            self.hook_all_methods(view_cls, "onDraw", hook)
            self._effect_overlay_hook = hook
            lp = _FLO.LayoutParams(-1, -1)  # MATCH_PARENT
            lp.gravity = 0  # TOP|LEFT
            deco.addView(ov, lp)
            self._effect_overlay = ov
            # Запускаем анимацию
            def _anim():
                try: ov.postInvalidateOnAnimation()
                except Exception: pass
            run_on_ui_thread(_anim)
            self.log(f"{self.TAG} effect overlay created")
        except Exception as e:
            self.log(f"{self.TAG} setup_effect_overlay: {e}")

    def _remove_effect_overlay(self):
        try:
            ov = getattr(self, "_effect_overlay", None)
            if ov:
                try:
                    p = ov.getParent()
                    if p: p.removeView(ov)
                except Exception: pass
                self._effect_overlay = None
                self.log(f"{self.TAG} effect overlay removed")
        except Exception: pass

    def _update_effect_overlay(self):
        """Переключает overlay в зависимости от настройки effects_everywhere."""
        everywhere = self.get_setting("effects_everywhere", False)
        if everywhere:
            run_on_ui_thread(self._setup_effect_overlay)
        else:
            run_on_ui_thread(self._remove_effect_overlay)

    def _reset_temp_pos(self, _=None):
        try:
            self.set_setting("temp_pos_x", str(_AU.dp(2)))
            self.set_setting("temp_pos_y", str(_AU.dp(80)))
            tv = getattr(self, "_temp_view", None)
            if tv:
                lp = getattr(self, "_temp_lp", None)
                if lp:
                    lp.leftMargin = _AU.dp(2)
                    lp.topMargin  = _AU.dp(80)
                    try: tv.setLayoutParams(lp)
                    except Exception: pass
            BulletinHelper.show_success("Позиция температуры сброшена")
        except Exception as e:
            self.log(f"{self.TAG} reset_temp_pos: {e}")

    def _force_refresh(self, _):
        self._last_update = 0.0
        self._cache.clear()
        run_on_queue(self._fetch_and_apply)
        BulletinHelper.show_info("Обновляем погоду…")

    def _invalidate_cache(self):
        self._cache.clear()
        self._last_update = 0.0

    def _create_settings_header_view(self, context):
        try:
            container = _FL(context)
            content   = _LL(context)
            content.setOrientation(_LL.VERTICAL)

            # Аватарка текущего пользователя
            try:
                from org.telegram.messenger import MessagesController, UserConfig
                from org.telegram.ui.Components import AvatarDrawable, BackupImageView
                account = int(getattr(UserConfig, "selectedAccount", 0))
                mc   = MessagesController.getInstance(account)
                uc   = UserConfig.getInstance(account)
                user = mc.getUser(uc.getClientUserId()) if mc and uc else None
                if user:
                    img = BackupImageView(context)
                    img.setRoundRadius(_AU.dp(40))
                    img.setForUserOrChat(user, AvatarDrawable(user))
                    content.addView(img, _LH.createLinear(80, 80, _G.CENTER_HORIZONTAL, 0, 20, 0, 12))
            except Exception as e:
                self.log(f"{self.TAG} avatar: {e}")

            title_tv = _TV(context)
            title_tv.setText("Dynamic Backgrounds")
            title_tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 22)
            title_tv.setGravity(_G.CENTER)
            title_tv.setTextColor(_tc(_Theme.key_windowBackgroundWhiteBlackText))
            try: title_tv.setTypeface(_AU.getTypeface(_AU.TYPEFACE_ROBOTO_MEDIUM))
            except Exception: pass
            content.addView(title_tv, _LH.createLinear(-2, -2, _G.CENTER_HORIZONTAL, 16, 0, 16, 4))

            desc_tv = _TV(context)
            desc_tv.setText("Динамический фон на основе реальной погоды")
            desc_tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 13)
            desc_tv.setGravity(_G.CENTER)
            desc_tv.setTextColor(_tc(_Theme.key_windowBackgroundWhiteGrayText))
            content.addView(desc_tv, _LH.createLinear(-2, -2, _G.CENTER_HORIZONTAL, 24, 0, 24, 12))

            authors_row = _LL(context)
            authors_row.setOrientation(_LL.HORIZONTAL)
            authors_row.setGravity(_G.CENTER)

            def make_link(name, username):
                tv = _TV(context)
                tv.setText(name)
                tv.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 13)
                tv.setTextColor(_tc(_Theme.key_windowBackgroundWhiteBlueText))
                tv.setClickable(True)
                tv.setOnClickListener(OnClickListener(
                    lambda v, u=username: self._open_profile(u)))
                return tv

            sep = _TV(context)
            sep.setText("  •  ")
            sep.setTextSize(_TypedValue.COMPLEX_UNIT_DIP, 13)
            sep.setTextColor(_tc(_Theme.key_windowBackgroundWhiteGrayText))

            authors_row.addView(make_link("@rei_plugins",  "rei_plugins"))
            authors_row.addView(sep)
            authors_row.addView(make_link("@optimist_opti", "optimist_opti"))
            content.addView(authors_row, _LH.createLinear(-2, -2, _G.CENTER_HORIZONTAL, 0, 0, 0, 20))

            container.addView(content, _LH.createFrame(-1, -2, _G.CENTER))
            return container
        except Exception as e:
            self.log(f"{self.TAG} header view: {e}")
            return None

    def _open_profile(self, username):
        try:
            frag = get_last_fragment()
            act  = frag.getParentActivity() if frag else None
            if act:
                try:
                    intent = Intent(Intent.ACTION_VIEW,
                                    Uri.parse(f"tg://resolve?domain={username}"))
                    intent.setPackage(act.getPackageName())
                    act.startActivity(intent)
                except Exception:
                    act.startActivity(Intent(Intent.ACTION_VIEW,
                        Uri.parse(f"https://t.me/{username}")))
        except Exception as e:
            self.log(f"{self.TAG} open_profile: {e}")

    def _open_api_site(self, _):
        try:
            fragment = get_last_fragment()
            if not fragment: return
            activity = fragment.getParentActivity()
            if not activity: return
            intent = Intent(Intent.ACTION_VIEW)
            intent.setData(Uri.parse("https://www.weatherapi.com/signup.aspx"))
            activity.startActivity(intent)
        except Exception as e:
            self.log(f"{self.TAG} open_api_site: {e}")

    # ── Commands ──────────────────────────────────────────────────────────────

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        msg = params.message
        if not isinstance(msg, str) or not msg.startswith(".bg"):
            return HookResult()
        cmd = msg.strip().lower()

        if cmd in (".bg", ".bg help"):
            params.message = (
                "🌦 Dynamic Backgrounds\n"
                "─────────────────────────\n"
                "☀️ clear — ясно (авто)\n"
                "  ☀️ clear sun — всегда солнце\n"
                "  🌙 clear moon — всегда луна\n"
                "─────────────────────────\n"
                "⛅ partly_cloudy — переменная (авто)\n"
                "  ☀️ partly_cloudy sun — всегда солнце\n"
                "  🌙 partly_cloudy moon — всегда луна\n"
                "─────────────────────────\n"
                "☁️ cloudy — облачно\n"
                "🌫 fog — туман\n"
                "🌦 light_rain — морось\n"
                "🌧 rain — дождь\n"
                "⚡ thunder — гроза\n"
                "🌨 light_snow — снежок\n"
                "❄️ snow — снег\n"
                "🌧 sleet — слякоть\n"
                "🌨 hail — град\n"
                "─────────────────────────\n"
                "🔄 .bg auto — обновить\n"
                "📍 .bg status — статус\n"
                "🔧 .bg debug — диагностика"
            )
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        if cmd == ".bg status":
            e    = _effect
            _sn  = _is_night_now()
            _sm  = getattr(e, "_clear_mode", "auto")
            _night_now = (_sm == "moon") or (_sm == "auto" and _sn)
            _partly_night = getattr(_effect, "_partly_night_mode", False)
            _partly_sun   = getattr(_effect, "_partly_sun_mode",   False)
            if self._weather_type == "clear" and _night_now:
                _weather_label = "🌙 Ясно (ночь)"
            elif self._weather_type == "clear" and _sm == "sun":
                _weather_label = "☀️ Ясно (день)"
            elif self._weather_type == "partly_cloudy" and _partly_sun:
                _weather_label = "☀️⛅ Переменная (день)"
            elif self._weather_type == "partly_cloudy" and (_partly_night or (_sn and _sm == "auto")):
                _weather_label = "🌙⛅ Переменная (ночь)"
            else:
                _weather_label = self._LABELS.get(self._weather_type, self._weather_type)
            params.message = (
                f"🌦 DynBG v7.0.0\n"
                f"Локация: {self._location_name}\n"
                f"Погода: {_weather_label}\n"
                f"Частиц: {len(e.particles)}\n"
                f"Анимация: {'▶️' if e.running else '⏸'}"
            )
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        if cmd == ".bg auto":
            # Сбрасываем все принудительные режимы — возвращаемся к авто
            _effect._clear_mode        = "auto"
            _effect._partly_night_mode = False
            _effect._partly_sun_mode   = False
            self.set_setting("clear_mode",        "auto")
            self.set_setting("partly_night_mode", False)
            self.set_setting("partly_sun_mode",   False)
            self._last_update = 0.0
            self._cache.clear()
            run_on_queue(self._fetch_and_apply)
            params.message = "🔄 Обновляю погоду…"
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        if cmd == ".bg debug":
            try:
                import android.os as _aos
                api = _aos.Build.VERSION.SDK_INT
                android_ver = f"Android {_aos.Build.VERSION.RELEASE} (API {api})"
            except Exception:
                android_ver = "неизвестно"
            try:
                from org.telegram.messenger import BuildConfig as _BC
                app_ver = getattr(_BC, "VERSION_NAME", "?")
            except Exception:
                app_ver = "?"
            # Проверяем какие классы найдены (без анализа методов — они могут быть в суперклассе)
            probe = [
                ("ChatActivityFragmentView", "org.telegram.ui.ChatActivity$ChatActivityFragmentView"),
                ("SizeNotifierFrameLayout",  "org.telegram.ui.Components.SizeNotifierFrameLayout"),
                ("ActionBarLayout",          "org.telegram.ui.ActionBar.ActionBarLayout"),
                ("BlurredFrameLayout",       "org.telegram.ui.Components.BlurredFrameLayout"),
                ("LaunchActivity",           "org.telegram.ui.LaunchActivity"),
            ]
            found_classes = []
            for short, full in probe:
                try:
                    c = find_class(full)
                    found_classes.append(f"✅ {short}" if c else f"❌ {short}")
                except Exception:
                    found_classes.append(f"❌ {short}")
            classes_str = "\n".join(found_classes)
            e = _effect
            draw_frames = e._draw_ok_count
            draw_err    = e._last_draw_error or "нет"
            hook_info   = getattr(self, "_hook_info", "?")
            lv = _effect.last_view
            _lv_name  = lv.getClass().getSimpleName() if lv else "None"
            geo_err     = self._last_geo_error or "нет"
            net_err     = self._last_net_error or "нет"
            enabled     = self.get_setting("enabled", True)
            last_upd    = time.time() - self._last_update
            upd_str     = f"{int(last_upd // 60)} мин назад" if self._last_update > 0 else "никогда"
            running     = e.running
            particles   = len(e.particles)
            weather     = self._weather_type
            location    = self._location_name
            city_manual = self.get_setting("city", "") or "нет"
            params.message = (
                "🔧 DynBG Debug\n"
                "─────────────────────────\n"
                f"📱 {android_ver}\n"
                f"📦 ExteraGram {app_ver}\n"
                "─────────────────────────\n"
                f"🪝 Draw hook: {hook_info}\n"
                f"🎨 Кадров отрисовано: {draw_frames}\n"
                f"❗ Ошибка on_draw: {draw_err}\n"
                "─────────────────────────\n"
                f"✅ Плагин включён: {enabled}\n"
                f"▶️  Анимация: {running}\n"
                f"🌤 Погода: {weather}\n"
                f"🌀 Частиц: {particles}\n"
                "─────────────────────────\n"
                f"📍 Локация: {location}\n"
                f"🏙 Город (ручной): {city_manual}\n"
                f"🕐 Последнее обновление: {upd_str}\n"
                f"❗ Ошибка геолокации: {geo_err}\n"
                f"❗ Ошибка сети: {net_err}\n"
                "─────────────────────────\n"
                f"🔍 Классы:\n{classes_str}"
            )
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        # .bg partly_cloudy moon
        if cmd == ".bg partly_cloudy moon":
            _effect._partly_night_mode = True
            _effect._partly_sun_mode   = False
            _effect._clear_mode = "auto"
            self.set_setting("partly_night_mode", True)
            self.set_setting("partly_sun_mode", False)
            self._weather_type  = "partly_cloudy"
            self._last_update   = time.time()
            run_on_ui_thread(self._sync)
            params.message = "🌙⛅ Переменная (ночь) — применён!"
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        # .bg partly_cloudy sun
        if cmd == ".bg partly_cloudy sun":
            _effect._partly_sun_mode   = True
            _effect._partly_night_mode = False
            _effect._clear_mode = "auto"
            self.set_setting("partly_sun_mode", True)
            self.set_setting("partly_night_mode", False)
            self._weather_type  = "partly_cloudy"
            self._last_update   = time.time()
            run_on_ui_thread(self._sync)
            params.message = "☀️⛅ Переменная (день) — применён!"
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        # .bg spring — ясно + весенние частицы
        if cmd == ".bg spring":
            _effect.set_weather("clear")
            _effect.cfg_show_spring = True
            self._weather_type = "clear"
            BulletinHelper.show_info("🌸 Весна! Ясно + листья и цветы")
            param.result = True
            return

        # .bg clear sun / .bg clear moon
        if cmd in (".bg clear sun", ".bg clear moon"):
            mode = "sun" if cmd.endswith("sun") else "moon"
            _effect._clear_mode = mode
            _effect.running = True
            self.set_setting("clear_mode", mode)
            if mode == "moon":
                _effect._shoot_timer = 180
            self._weather_type = "clear"
            self._last_update  = time.time()
            run_on_ui_thread(self._sync)
            def _force_redraw():
                if _effect.last_view:
                    try:    _effect.last_view.postInvalidateOnAnimation()
                    except: _effect.last_view.invalidate()
            run_on_ui_thread(_force_redraw)
            icon = "☀️" if mode == "sun" else "🌙"
            params.message = f"{icon} Ясно ({mode}) — применён!"
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        wt = self._CMDS.get(cmd)
        if wt is None:
            params.message = f"❓ Неизвестная команда: {cmd}\nНапиши .bg help"
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        _effect._clear_mode = "auto"
        _effect._partly_night_mode = False
        _effect._partly_sun_mode   = False
        self.set_setting("clear_mode", "auto")
        self.set_setting("partly_night_mode", False)
        self.set_setting("partly_sun_mode", False)
        self._weather_type  = wt
        self._last_update   = time.time()
        run_on_ui_thread(self._sync)
        params.message = f"{self._LABELS[wt]} — применён!"
        return HookResult(strategy=HookStrategy.MODIFY, params=params)

    # ── Hooks ─────────────────────────────────────────────────────────────────

    def _setup_hooks(self):
        try:
            # ── Resume/Pause хуки ────────────────────────────────────────────
            # Хукаем onResume на всех основных классах + BaseFragment
            for lc_cname in (
                "org.telegram.ui.LaunchActivity",
                "org.telegram.ui.ChatActivity",
            ):
                lc_cls = find_class(lc_cname)
                if not lc_cls: continue
                try:
                    r1 = self.hook_all_methods(lc_cls, "onResume", ResumeHook(self))
                    r2 = self.hook_all_methods(lc_cls, "onPause",  PauseHook(self))
                    hooked = (r1 and len(r1)>0) or (r2 and len(r2)>0)
                    if hooked:
                        self.log(f"{self.TAG} lifecycle hooked on {lc_cname}")
                except Exception as e:
                    self.log(f"{self.TAG} lifecycle hook {lc_cname}: {e}")

            # BaseFragment: хукаем onTransitionAnimationEnd (конец анимации перехода)
            # и onBecomeFullyVisible как fallback
            bf_cls = find_class("org.telegram.ui.ActionBar.BaseFragment")
            if bf_cls:
                hooked_bf = False
                for mname in ("onTransitionAnimationEnd", "onBecomeFullyVisible", "onResume"):
                    try:
                        res = self.hook_all_methods(bf_cls, mname, ResumeHook(self))
                        if res and len(res) > 0:
                            self.log(f"{self.TAG} BaseFragment.{mname} hooked ({len(res)})")
                            hooked_bf = True
                            break
                    except Exception as e:
                        self.log(f"{self.TAG} BaseFragment.{mname}: {e}")

            # ── Draw хуки ───────────────────────────────────────────────────
            # 1. chat_hook на ChatActivityFragmentView — пишет _chat_draw_t
            chat_hook = DrawHook(chat_only=True)
            chat_cls  = find_class("org.telegram.ui.ChatActivity$ChatActivityFragmentView")
            if chat_cls:
                for mname in ("dispatchDraw", "onDraw", "draw"):
                    try:
                        res = self.hook_all_methods(chat_cls, mname, chat_hook)
                        if res and len(res) > 0:
                            self.log(f"{self.TAG} chat hook: ChatActivityFragmentView.{mname}")
                            self._hook_info = f"ChatActivityFragmentView.{mname}"
                            break
                    except Exception as e:
                        self.log(f"{self.TAG} chat hook: {e}")

            # 2. overlay hook на View.onDraw (для режима effects_everywhere)
            # _OverlayDrawHook фильтрует по тегу "dynbg_overlay"
            # Хукаем android.view.View.onDraw
            view_cls = find_class("android.view.View")
            if view_cls:
                try:
                    res = self.hook_all_methods(view_cls, "onDraw", _OverlayDrawHook())
                    if res and len(res) > 0:
                        self.log(f"{self.TAG} overlay hook: View.onDraw ({len(res)})")
                except Exception as e:
                    self.log(f"{self.TAG} overlay hook: {e}")

            self._draw_hook = chat_hook  # для совместимости
            # Создаём overlay если нужно
            self._update_effect_overlay()
        except Exception as e:
            self.log(f"{self.TAG} _setup_hooks: {e}")

    def _on_resumed(self):
        if not self.get_setting("enabled", True):
            return
        def go():
            _effect.running = True
            _effect._clear_mode = self.get_setting("clear_mode", "auto")
            _effect._partly_night_mode = self.get_setting("partly_night_mode", False)
            _effect._partly_sun_mode   = self.get_setting("partly_sun_mode",   False)
            if _effect._draw_ok_count == 0 and "❌" in getattr(self, "_hook_info", "❌"):
                self.log(f"{self.TAG} retrying hook on resume")
                self._setup_hooks()
                return
            self._sync()
            self._update_effect_overlay()
            self.log(f"{self.TAG} resumed, weather={self._weather_type}")
        run_on_ui_thread(go)

    def _sync(self, force=False):
        wt = self._weather_type if self.get_setting("enabled", True) else "clear"
        _effect.set_weather(wt, force=force)

    # ── Weather loop ──────────────────────────────────────────────────────────

    def _get_update_interval(self) -> float:
        try:    return max(5, int(self.get_setting("update_interval", "30"))) * 60.0
        except: return UPDATE_SEC

    def _start_weather_loop(self):
        self._loop_running = True
        def loop():
            while self._loop_running:
                if time.time() - self._last_update >= self._get_update_interval():
                    self._fetch_and_apply()
                time.sleep(60)
        threading.Thread(target=loop, daemon=True, name="DynBG-loop").start()

    def _fetch_and_apply(self):
        if not self._fetch_lock.acquire(blocking=False):
            return
        try:
            # 1. Получаем координаты
            lat, lon, location_name = self._get_location()
            if lat is None:
                self.log(f"{self.TAG} location unavailable, skip")
                return

            # 2. Запрашиваем погоду Open-Meteo (бесплатно, без ключа)
            ck = f"{lat:.3f}_{lon:.3f}"
            if ck in self._cache:
                data, ts = self._cache[ck]
                if time.time() - ts < CACHE_SEC:
                    self.log(f"{self.TAG} cached ({location_name})")
                    wt = data
                    self._last_update  = time.time()
                    self._location_name = location_name
                    try:    _sw_idx3 = int(self.get_setting("startup_weather", 0))
                    except: _sw_idx3 = 0
                    if _sw_idx3 == 0:
                        self._weather_type = wt
                        run_on_ui_thread(self._sync)
                    return

            r = requests.get(
                "https://api.open-meteo.com/v1/forecast"
                f"?latitude={lat}&longitude={lon}"
                "&current=weather_code,temperature_2m"
                "&forecast_days=1",
                timeout=10,
                headers={"User-Agent": "DynamicBackgrounds/7.0"},
            )
            self.log(f"{self.TAG} Open-Meteo {r.status_code}")
            if r.status_code != 200:
                self.log(f"{self.TAG} error: {r.text[:200]}")
                return

            cur  = r.json().get("current", {})
            code = cur.get("weather_code", 0)
            temp = cur.get("temperature_2m")
            if temp is not None:
                _effect._temp_celsius = float(temp)
                run_on_ui_thread(self._update_temp_overlay)
            wt   = WMO.get(int(code), "clear")
            self.log(f"{self.TAG} WMO {code} → {wt} @ {location_name}")

            self._cache[ck]      = (wt, time.time())
            self._location_name  = location_name
            self._last_update    = time.time()
            # Если задана принудительная стартовая погода — не перебиваем её
            try:    _sw_idx2 = int(self.get_setting("startup_weather", 0))
            except: _sw_idx2 = 0
            if _sw_idx2 == 0:
                self._weather_type = wt
                run_on_ui_thread(self._sync)
            else:
                self.log(f"{self.TAG} real={wt}, kept startup idx={_sw_idx2}")
        except Exception as e:
            self._last_net_error = str(e)
            self.log(f"{self.TAG} _fetch_and_apply: {e}")
        finally:
            self._fetch_lock.release()

    def _get_location(self):
        """Возвращает (lat, lon, name). Приоритет: ручной город → GPS → IP."""
        # ── Попытка 0: ручной город из настроек (если задан) ─────────────────
        city = self.get_setting("city", "").strip()
        if city:
            try:
                r = requests.get(
                    "https://geocoding-api.open-meteo.com/v1/search"
                    f"?name={requests.utils.quote(city)}&count=1&language=ru",
                    timeout=8,
                    headers={"User-Agent": "DynamicBackgrounds/5.4"},
                )
                if r.status_code == 200:
                    results = r.json().get("results", [])
                    if results:
                        res  = results[0]
                        lat  = float(res["latitude"])
                        lon  = float(res["longitude"])
                        name = res.get("name", city)
                        self.log(f"{self.TAG} manual city '{city}' → {lat},{lon}")
                        return lat, lon, name
            except Exception as e:
                self.log(f"{self.TAG} manual geocoding: {e}")

        # ── Попытка 1: Android LocationManager ───────────────────────────────
        try:
            from android.content import Context
            from android.location import LocationManager
            from org.telegram.messenger import ApplicationLoader
            ctx = ApplicationLoader.applicationContext
            lm  = ctx.getSystemService(Context.LOCATION_SERVICE)
            best = None
            for provider in (LocationManager.GPS_PROVIDER,
                             LocationManager.NETWORK_PROVIDER):
                try:
                    if not lm.isProviderEnabled(provider):
                        continue
                    loc = lm.getLastKnownLocation(provider)
                    if loc is None:
                        continue
                    age = (time.time() * 1000 - loc.getTime()) / 1000
                    if age > 3600:   # не старше 1 часа
                        continue
                    if best is None or loc.getAccuracy() < best.getAccuracy():
                        best = loc
                except Exception:
                    continue
            if best is not None:
                lat = best.getLatitude()
                lon = best.getLongitude()
                name = self._reverse_geocode(lat, lon)
                self.log(f"{self.TAG} GPS location: {lat:.3f},{lon:.3f}")
                return lat, lon, name
        except Exception as e:
            self._last_geo_error = f"GPS: {e}"
            self.log(f"{self.TAG} LocationManager: {e}")

        # ── Попытка 2: ip-api.com (без ключа, ~1000 запросов/день) ──────────
        try:
            r = requests.get("http://ip-api.com/json/?fields=lat,lon,city,country",
                             timeout=6,
                             headers={"User-Agent": "DynamicBackgrounds/5.4"})
            if r.status_code == 200:
                d    = r.json()
                lat  = float(d["lat"])
                lon  = float(d["lon"])
                name = f"{d.get('city','?')}, {d.get('country','?')}"
                self.log(f"{self.TAG} IP location: {name}")
                return lat, lon, name
        except Exception as e:
            self._last_geo_error = f"IP: {e}"
            self.log(f"{self.TAG} ip-api: {e}")

        return None, None, "?"

    def _reverse_geocode(self, lat: float, lon: float) -> str:
        """Получаем название города по координатам через Open-Meteo geocoding."""
        try:
            r = requests.get(
                f"https://nominatim.openstreetmap.org/reverse"
                f"?lat={lat}&lon={lon}&format=json&zoom=10",
                timeout=5,
                headers={"User-Agent": "DynamicBackgrounds/5.4"},
            )
            if r.status_code == 200:
                addr = r.json().get("address", {})
                city = (addr.get("city") or addr.get("town")
                        or addr.get("village") or addr.get("county", "?"))
                country = addr.get("country_code", "").upper()
                return f"{city}, {country}"
        except Exception:
            pass
        return f"{lat:.2f},{lon:.2f}"
