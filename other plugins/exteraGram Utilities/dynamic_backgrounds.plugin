}

DP          = 3.0
ANGLE_DIFF  = math.pi / 3.0
UPDATE_SEC  = 30 * 60
CACHE_SEC   = 10 * 60

def _is_night_now() -> bool:
    """Определяет ночь по местному времени устройства (20:00–05:59)."""
    h = time.localtime().tm_hour
    return h >= 20 or h < 6

def _tc(key, fallback=0):
    try:    return _Theme.getColor(key)
    except: return fallback


# ─── Particle ─────────────────────────────────────────────────────────────────

class Particle:
    __slots__ = ("x","y","vx","vy","velocity","alpha","life_time",
                 "current_time","scale","ptype","angle","spin")

    def __init__(self):
        self.x = self.y = self.vx = self.vy = 0.0
        self.velocity = self.alpha = self.life_time = self.current_time = 0.0
        self.scale = 1.0
        self.ptype = 0
        self.angle = 0.0
        self.spin  = 0.0

    def reset(self):
        self.alpha = 0.0
        self.current_time = 0.0
        self.angle = 0.0
        self.spin  = 0.0


# ─── WeatherEffect ────────────────────────────────────────────────────────────

class WeatherEffect:

    FREE_POOL = 100

    def __init__(self):
        self.weather_type = "clear"
        self.running      = False
        self.last_view    = None
        self._last_draw_error: str = ""
        self._draw_ok_count: int   = 0

        self.particles: List[Particle] = []
        self._free: List[Particle]     = [Particle() for _ in range(50)]

        self._last_mono: float = 0.0
        self._lightning_alpha: int = 0
        self._lightning_timer: int = 0
        self._lightning_next:  int = random.randint(300, 600)
        self._lightning_spots: list = []
        self._sun_angle: float = 0.0
        # Настройка интенсивности молнии
        self.cfg_opacity       = {k: 1.0 for k in ("clear","partly_cloudy","cloudy","fog","light_rain","rain","thunder","light_snow","snow","sleet","hail")}
        # Раздельная прозрачность для дня и ночи (clear / partly_cloudy)
        self.cfg_opacity_clear_night   = 1.0
        self.cfg_opacity_partly_night  = 1.0
        self.cfg_star_count          = 60
        self.cfg_star_twinkle_speed  = 4.5
        self.cfg_moon_size     = 13    # dp
        self.cfg_moon_phase    = 5.0   # смещение тени (0=нет серпа, 13=полный серп)
        self.cfg_shooting_star_interval = 3600  # кадров (~1 мин при 60fps)
        self._clear_mode       = "auto"  # "auto" | "sun" | "moon"
        self._partly_night_mode = False  # True → partly_cloudy всегда с луной
        self._partly_sun_mode   = False  # True → partly_cloudy всегда с солнцем
        self.cfg_lightning_intensity = 120  # макс. яркость вспышки (0–255)
        self.cfg_lightning_speed     = 12   # скорость затухания (1–40)

        # ── cfg: ясно ─────────────────────────────────────────────
        self.cfg_spark_spawn   = 0.85
        self.cfg_spark_count   = 20
        self.cfg_sun_pos_x     = 0.82   # доля ширины
        self.cfg_sun_pos_y     = 0.12   # доля высоты
        self.cfg_sun_ray_speed = 0.0003
        # ── cfg: облачно ──────────────────────────────────────────
        self.cfg_cloud_speed   = 11.0
        self.cfg_cloud_spawn   = 0.97
        self.cfg_cloud_count   = 12
        # ── cfg: туман ────────────────────────────────────────────
        self.cfg_fog_speed     = 6.0
        self.cfg_fog_spawn     = 0.88
        self.cfg_fog_count     = 12
        # ── cfg: лёгкий дождь ─────────────────────────────────────
        self.cfg_lrain_speed   = 35.0
        self.cfg_lrain_spawn   = 0.80
        self.cfg_lrain_count   = 50
        # ── cfg: дождь ────────────────────────────────────────────
        self.cfg_rain_speed    = 55.0
        self.cfg_rain_spawn    = 0.55
        self.cfg_rain_count    = 150
        # ── cfg: гроза ────────────────────────────────────────────
        self.cfg_thunder_speed = 75.0
        self.cfg_thunder_spawn = 0.45
        # ── cfg: лёгкий снег ──────────────────────────────────────
        self.cfg_lsnow_speed   = 18.0
        self.cfg_lsnow_spawn   = 0.82
        self.cfg_lsnow_count   = 40
        # ── cfg: снег ─────────────────────────────────────────────
        self.cfg_snow_speed    = 22.0
        self.cfg_snow_spawn    = 0.70
        self.cfg_snow_count    = 100
        # ── cfg: grad ─────────────────────────────────────────────
        self.cfg_hail_speed    = 90.0
        self.cfg_hail_spawn    = 0.50
        self.cfg_hail_count    = 120

        # ── cfg: глобальный масштаб частиц ────────────────────────
        # 1.0 = по умолчанию, 0.5 = вдвое меньше, 2.0 = вдвое крупнее
        # ── cfg: включение/выключение отдельных элементов ─────────
        self.cfg_show_sun       = True
        self.cfg_show_moon      = True
        self.cfg_show_stars     = True
        self.cfg_show_clouds    = True
        self.cfg_show_sparks    = True
        self.cfg_show_rain      = True
        self.cfg_show_snow      = True
        self.cfg_show_fog       = True
        self.cfg_show_lightning = True
        self.cfg_show_rocket    = True
        self.cfg_rocket_interval = 7200

        # Paint объекты — один раз
        self._thick = Paint(Paint.ANTI_ALIAS_FLAG)
        self._thick.setStrokeCap(Paint.Cap.ROUND)
        self._thick.setStyle(Paint.Style.STROKE)

        self._thin = Paint(Paint.ANTI_ALIAS_FLAG)
        self._thin.setStrokeCap(Paint.Cap.ROUND)
        self._thin.setStyle(Paint.Style.STROKE)

        self._fill = Paint(Paint.ANTI_ALIAS_FLAG)
        self._fill.setStyle(Paint.Style.FILL)

        self._bg = Paint()
        self._bg.setStyle(Paint.Style.FILL)

        self._refresh_paint()
        self._temp_celsius: float = None  # температура с API

    # ── Helpers ───────────────────────────────────────────────────────────────

    @staticmethod
    def _argb(paint, c: int):
        paint.setARGB((c>>24)&0xFF, (c>>16)&0xFF, (c>>8)&0xFF, c&0xFF)

    def _refresh_paint(self):
        wt = self.weather_type
        if wt in ("rain","thunder","sleet","light_rain"):
            col = -6702115
        elif wt == "fog":
            col = -3355444
        elif wt == "clear":
            col = -8824
        elif wt in ("cloudy","partly_cloudy"):
            col = -2236946
        elif wt == "hail":
            col = -4469539
        else:
            col = -2232577
        self._argb(self._thick, col)
        self._argb(self._thin,  col)
        self._argb(self._fill,  col)
        self._thick.setStrokeWidth(DP * 1.5)
        self._thin.setStrokeWidth(DP * 0.5)

    def _alloc(self) -> Particle:
        p = self._free.pop() if self._free else Particle()
        p.reset()
        return p

    def _recycle(self, p: Particle):
        if len(self._free) < self.FREE_POOL:
            self._free.append(p)

    # ── Public API ────────────────────────────────────────────────────────────

    def set_weather(self, wt: str, force: bool = False):
        changed = self.weather_type != wt
        if not changed and not force:
            return
        self.weather_type = wt
        self._lightning_alpha = 0
        self._lightning_timer = 0
        self._lightning_next  = random.randint(300, 600)
        # Сбрасываем частицы только если погода реально сменилась
        # При force=True без смены погоды (resume) — не сбрасываем
        if changed:
            self._last_mono = 0.0
            for p in self.particles:
                self._recycle(p)
            self.particles.clear()
        self._refresh_paint()
        if self.last_view is not None:
            try:
                self.last_view.postInvalidateOnAnimation()
            except Exception:
                try:    self.last_view.invalidate()
                except: self.last_view = None

    def apply_cfg(self,
                  spark_spawn, spark_count, sun_pos_x, sun_pos_y, sun_ray_speed,
                  cloud_speed, cloud_spawn, cloud_count,
                  fog_speed, fog_spawn, fog_count,
                  lrain_speed, lrain_spawn, lrain_count,
                  rain_speed, rain_spawn, rain_count,
                  thunder_speed, thunder_spawn,
                  lsnow_speed, lsnow_spawn, lsnow_count,
                  snow_speed, snow_spawn, snow_count,
                  hail_speed, hail_spawn, hail_count,
                  lightning_intensity, lightning_speed,
                  opacity_clear=100, opacity_partly_cloudy=100, opacity_cloudy=100,
                  opacity_fog=100, opacity_light_rain=100, opacity_rain=100,
                  opacity_thunder=100, opacity_light_snow=100, opacity_snow=100,
                  opacity_sleet=100, opacity_hail=100,
                  opacity_clear_night=100, opacity_partly_night=100,
                  star_count=60, moon_size=13, moon_phase=5,
                  shooting_star_interval=3600,
                  star_twinkle_speed=45,
                  sun_ray_count=8,
                  show_sun=True, show_moon=True, show_stars=True,
                  show_clouds=True, show_sparks=True,
                  show_rain=True, show_snow=True,
                  show_fog=True, show_lightning=True, show_spring=True,
                  show_rocket=True, rocket_interval=7200,
                  night_start=20, day_start=6,
                  size_sun=100, size_moon=100, size_stars=100, size_sparks=100,
                  size_clouds=100, size_rain=100, size_snow=100,
                  size_fog=100, size_hail=100, size_spring=100,
                  cloud_max_y=65):
        def f(v): return max(1.0, float(v))
        def s(v): return max(0.01, min(0.99, float(v)/100.0))
        def i(v): return max(1, int(v))
        self.cfg_spark_spawn   = s(spark_spawn)
        self.cfg_spark_count   = i(spark_count)
        self.cfg_sun_pos_x     = max(0.1, min(0.95, float(sun_pos_x)/100.0))
        self.cfg_sun_pos_y     = max(0.01, min(0.5,  float(sun_pos_y)/100.0))
        self.cfg_sun_ray_speed = max(0.0, float(sun_ray_speed)/10000.0)
        self.cfg_cloud_speed   = f(cloud_speed)
        self.cfg_cloud_spawn   = s(cloud_spawn)
        self.cfg_cloud_count   = i(cloud_count)
        self.cfg_fog_speed     = f(fog_speed)
        self.cfg_fog_spawn     = s(fog_spawn)
        self.cfg_fog_count     = i(fog_count)
        self.cfg_lrain_speed   = f(lrain_speed)
        self.cfg_lrain_spawn   = s(lrain_spawn)
        self.cfg_lrain_count   = i(lrain_count)
        self.cfg_rain_speed    = f(rain_speed)
        self.cfg_rain_spawn    = s(rain_spawn)
        self.cfg_rain_count    = i(rain_count)
        self.cfg_thunder_speed = f(thunder_speed)
        self.cfg_thunder_spawn = s(thunder_spawn)
        self.cfg_lsnow_speed   = f(lsnow_speed)
        self.cfg_lsnow_spawn   = s(lsnow_spawn)
        self.cfg_lsnow_count   = i(lsnow_count)
        self.cfg_snow_speed    = f(snow_speed)
        self.cfg_snow_spawn    = s(snow_spawn)
        self.cfg_snow_count    = i(snow_count)
        self.cfg_hail_speed    = f(hail_speed)
        self.cfg_hail_spawn    = s(hail_spawn)
        self.cfg_hail_count          = i(hail_count)
        self.cfg_lightning_intensity  = max(0, min(255, int(lightning_intensity)))
        self.cfg_lightning_speed = max(1, int(lightning_speed))
        def _op(v): return max(0.0, min(1.0, float(v)/100.0))
        self.cfg_star_count             = max(1, int(star_count))
        self.cfg_moon_size              = max(5, int(moon_size))
        self.cfg_moon_phase             = max(0, min(13, float(moon_phase)))
        self.cfg_shooting_star_interval = max(300, int(shooting_star_interval))
        self.cfg_star_twinkle_speed     = max(0.5, float(star_twinkle_speed) / 10.0)
        self.cfg_sun_ray_count          = max(3, min(16, int(sun_ray_count)))
        # Сбрасываем кэш звёзд при смене количества
        if hasattr(self, "_star_positions") and len(self._star_positions) != self.cfg_star_count:
            del self._star_positions
        self.cfg_opacity = {"clear":_op(opacity_clear),"partly_cloudy":_op(opacity_partly_cloudy),"cloudy":_op(opacity_cloudy),"fog":_op(opacity_fog),"light_rain":_op(opacity_light_rain),"rain":_op(opacity_rain),"thunder":_op(opacity_thunder),"light_snow":_op(opacity_light_snow),"snow":_op(opacity_snow),"sleet":_op(opacity_sleet),"hail":_op(opacity_hail)}
        self.cfg_opacity_clear_night  = _op(opacity_clear_night)
        self.cfg_opacity_partly_night = _op(opacity_partly_night)
        self.cfg_show_sun       = bool(show_sun)
        self.cfg_show_moon      = bool(show_moon)
        self.cfg_show_stars     = bool(show_stars)
        self.cfg_show_clouds    = bool(show_clouds)
        self.cfg_show_sparks    = bool(show_sparks)
        self.cfg_show_rain      = bool(show_rain)
        self.cfg_show_snow      = bool(show_snow)
        self.cfg_show_fog       = bool(show_fog)
        self.cfg_show_lightning = bool(show_lightning)
        self.cfg_show_spring    = bool(show_spring)
        self.cfg_show_rocket    = bool(show_rocket)
        self.cfg_rocket_interval = max(60, int(rocket_interval))
        self.cfg_night_start    = max(0, min(23, int(night_start)))
        self.cfg_day_start      = max(0, min(23, int(day_start)))
        self.cfg_size_sun       = max(10, min(300, int(size_sun)))
        self.cfg_size_moon      = max(10, min(300, int(size_moon)))
        self.cfg_size_stars     = max(10, min(300, int(size_stars)))
        self.cfg_size_sparks    = max(10, min(300, int(size_sparks)))
        self.cfg_size_clouds    = max(10, min(300, int(size_clouds)))
        self.cfg_size_rain      = max(10, min(300, int(size_rain)))
        self.cfg_size_snow      = max(10, min(300, int(size_snow)))
        self.cfg_size_fog       = max(10, min(300, int(size_fog)))
        self.cfg_size_hail      = max(10, min(300, int(size_hail)))
        self.cfg_size_spring    = max(10, min(300, int(size_spring)))
        self.cfg_cloud_max_y    = max(10, min(100, int(cloud_max_y)))
        for p in self.particles:
            self._recycle(p)
        self.particles.clear()

    # ── Spawn ─────────────────────────────────────────────────────────────────

    def _spawn(self, w: int, h: int):
        wt = self.weather_type
        # Выбираем порог и лимит по типу
        if   wt == "clear":         thresh, limit = self.cfg_spark_spawn,   self.cfg_spark_count
        elif wt == "partly_cloudy": thresh, limit = self.cfg_cloud_spawn,   self.cfg_cloud_count
        elif wt == "cloudy":        thresh, limit = self.cfg_cloud_spawn,   self.cfg_cloud_count
        elif wt == "fog":           thresh, limit = self.cfg_fog_spawn,     self.cfg_fog_count
        elif wt == "light_rain":    thresh, limit = self.cfg_lrain_spawn,   self.cfg_lrain_count
        elif wt == "rain":          thresh, limit = self.cfg_rain_spawn,    self.cfg_rain_count
        elif wt == "thunder":       thresh, limit = self.cfg_thunder_spawn, self.cfg_rain_count
        elif wt == "light_snow":    thresh, limit = self.cfg_lsnow_spawn,   self.cfg_lsnow_count
        elif wt == "snow":          thresh, limit = self.cfg_snow_spawn,    self.cfg_snow_count
        elif wt == "sleet":         thresh, limit = self.cfg_snow_spawn,    self.cfg_snow_count
        elif wt == "hail":          thresh, limit = self.cfg_hail_spawn,    self.cfg_hail_count
        else:                       return

        if random.random() > thresh or len(self.particles) >= limit:
            return

        p = self._alloc()
        p.x = random.random() * w
        p.y = random.random() * h

        if wt == "clear":
            # Ночью (moon) — не спавним искры, звёзды рисуются отдельно
            _night = _is_night_now()
            _mode  = getattr(self, "_clear_mode", "auto")
            if _mode == "moon" or (_mode == "auto" and _night):
                self._recycle(p)
                return
            # Днём: 35% шанс весенней частицы (если включено), иначе искра
            if self.cfg_show_spring and random.random() < 0.35:
                rad = math.radians(random.randint(-35, 35) + 90)
                p.vx = math.cos(rad); p.vy = math.sin(rad)
                p.velocity  = 9.0 + random.random() * 7.0
                p.life_time = 6000.0 + random.randint(0, 3000)
                p.scale     = random.random() * 0.7 + 0.5
                p.spin      = random.random()
                p.angle     = random.uniform(0, math.pi * 2)
                p.ptype     = 8 if random.random() < 0.55 else 9
            else:
                p.vx = p.vy = p.velocity = 0.0
                p.life_time = 800.0 + random.randint(0, 600)
                p.scale     = random.random() * 0.8 + 0.3
                p.ptype     = 6

        elif wt in ("partly_cloudy", "cloudy"):
            # Облака плывут горизонтально, появляются сбоку
            max_y_frac = self.cfg_cloud_max_y / 100.0
            sc_c       = self.cfg_size_clouds  / 100.0
            d = 1 if random.random() > 0.5 else -1
            p.x = -120.0 * sc_c if d > 0 else w + 120.0 * sc_c
            p.y = random.random() * h * max_y_frac
            p.vx = float(d); p.vy = 0.0
            p.velocity  = self.cfg_cloud_speed + random.random() * 6.0
            p.life_time = 12000.0 + random.randint(0, 5000)
            p.scale     = (random.random() * 1.5 + 1.0) * sc_c
            p.ptype     = 4

        elif wt == "fog":
            # Клуб тумана — большое мягкое пятно, медленно дрейфует
            angle = random.uniform(0, math.pi * 2)  # любое направление
            p.vx  = math.cos(angle)
            p.vy  = math.sin(angle) * 0.3   # горизонтальный дрейф сильнее вертикального
            p.x   = random.random() * w
            p.y   = random.random() * h
            p.velocity  = self.cfg_fog_speed * 0.25 + random.random() * 0.8
            p.life_time = 12000.0 + random.randint(0, 8000)
            p.scale     = random.random() * 1.8 + 1.2   # радиус-множитель
            p.ptype     = 3

        elif wt == "light_rain":
            # Редкие тонкие капли, медленнее и прозрачнее
            rad = math.radians(random.randint(-15, 15) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            spd = self.cfg_lrain_speed + random.random() * 10.0
            p.velocity  = spd
            p.life_time = max(400.0, ((h-p.y)+80.0) / (spd*16.0/500.0) * 16.0)
            p.scale     = random.random() * 0.4 + 0.2
            p.ptype     = 2

        elif wt in ("rain", "thunder"):
            # Полноценный дождь
            rad = math.radians(random.randint(-20, 20) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            spd = (self.cfg_thunder_speed if wt == "thunder"
                   else self.cfg_rain_speed) + random.random() * 20.0
            p.velocity  = spd
            p.life_time = max(300.0, ((h-p.y)+80.0) / (spd*16.0/500.0) * 16.0)
            p.scale     = random.random() * 0.7 + 0.4
            p.ptype     = 2

        elif wt == "light_snow":
            # Редкие лёгкие снежинки, чуть крутит ветром
            rad = math.radians(random.randint(-25, 25) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            p.velocity  = self.cfg_lsnow_speed + random.random() * 3.0
            p.life_time = 3000.0 + random.randint(0, 500)
            p.scale     = random.random() * 0.7 + 0.15
            p.ptype     = random.randint(0, 1)

        elif wt == "snow":
            # Густой снег — крупные хлопья и шестиугольники
            rad = math.radians(random.randint(-20, 20) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            p.velocity  = self.cfg_snow_speed + random.random() * 4.0
            p.life_time = 2000.0 + random.randint(0, 100)
            p.scale     = random.random() * 1.2 + 0.2
            p.ptype     = random.randint(0, 1)

        elif wt == "sleet":
            # Слякоть = ~55% снежинки + ~45% дождь
            rad = math.radians(random.randint(-20, 20) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            if random.random() > 0.45:
                spd = self.cfg_snow_speed + random.random() * 4.0
                p.velocity  = spd
                p.life_time = 2000.0 + random.randint(0, 100)
                p.scale     = random.random() * 0.9 + 0.2
                p.ptype     = random.randint(0, 1)
            else:
                spd = self.cfg_rain_speed * 0.7 + random.random() * 10.0
                p.velocity  = spd
                p.life_time = max(300.0, ((h-p.y)+80.0) / (spd*16.0/500.0) * 16.0)
                p.scale     = random.random() * 0.5 + 0.3
                p.ptype     = 2

        elif wt == "hail":
            # Grad — почти вертикально, быстро, маленькие шарики
            rad = math.radians(random.randint(-8, 8) + 90)
            p.vx = math.cos(rad); p.vy = math.sin(rad)
            spd = self.cfg_hail_speed + random.random() * 30.0
            p.velocity  = spd
            p.life_time = max(200.0, ((h-p.y)+80.0) / (spd*16.0/500.0) * 16.0)
            p.scale     = random.random() * 0.6 + 0.35
            p.spin      = float(random.randint(0, 2))   # форма: 0=гекс, 1=ромб, 2=осколок
            p.angle     = random.uniform(0, math.pi)    # фиксированный поворот
            p.ptype     = 7

        self.particles.append(p)

    # ── Update ────────────────────────────────────────────────────────────────

    def _update(self, dt: float):
        k     = dt / 500.0
        alive = []
        for p in self.particles:
            p.current_time += dt
            ct = p.current_time
            lt = p.life_time
            if ct >= lt:
                self._recycle(p)
                continue
            if ct < 200.0:
                t = ct / 200.0
                p.alpha = t * t
            else:
                t = (ct - 200.0) / (lt - 200.0)
                p.alpha = 1.0 - t * t
            vk = p.velocity * k
            p.x += p.vx * vk
            p.y += p.vy * vk
            alive.append(p)
        self.particles = alive

    # ── Draw particle ─────────────────────────────────────────────────────────

    def _draw_particle(self, canvas, p: Particle, opacity: float = 1.0):
        a = int(255.0 * p.alpha * opacity)
        if a <= 0:
            return
        t = p.ptype
        ss_snow   = self.cfg_size_snow   / 100.0
        ss_rain   = self.cfg_size_rain   / 100.0
        ss_fog    = self.cfg_size_fog    / 100.0
        ss_cloud  = self.cfg_size_clouds / 100.0
        ss_spark  = self.cfg_size_sparks / 100.0
        ss_hail   = self.cfg_size_hail   / 100.0
        ss_spring = self.cfg_size_spring / 100.0

        if t == 0:
            # Снежный хлопок
            self._thick.setAlpha(a)
            self._thick.setStrokeWidth(DP * 1.5 * p.scale * ss_snow)
            canvas.drawPoint(p.x, p.y, self._thick)

        elif t == 1:
            # 6-лучевая снежинка
            self._thin.setAlpha(a)
            angle = -math.pi / 2.0
            sc = p.scale * ss_snow
            px  =  DP * 4.0  * sc
            px1 = -DP * 1.14 * sc
            py1 =  DP * 3.10 * sc
            x, y = p.x, p.y
            for _ in range(6):
                ca, sa = math.cos(angle), math.sin(angle)
                x1 = ca * px;  y1 = sa * px
                cx = x1 * 0.66; cy = y1 * 0.66
                canvas.drawLine(x, y, x+x1, y+y1, self._thin)
                a2 = angle - math.pi / 2.0
                c2, s2 = math.cos(a2), math.sin(a2)
                bx  =  c2*px1 - s2*py1;  by  = s2*px1 + c2*py1
                bx2 = -c2*px1 - s2*py1;  by2 = -s2*px1 + c2*py1
                canvas.drawLine(x+cx, y+cy, x+bx,  y+by,  self._thin)
                canvas.drawLine(x+cx, y+cy, x+bx2, y+by2, self._thin)
                angle += ANGLE_DIFF

        elif t == 2:
            # Дождевая капля — линия по вектору падения
            fast = p.velocity > 60
            self._thick.setAlpha(a)
            self._thick.setStrokeWidth(DP * (1.1 if fast else 0.8) * p.scale * ss_rain)
            ln = DP * (13.0 if fast else 8.0) * p.scale * ss_rain
            canvas.drawLine(p.x, p.y, p.x + p.vx*ln, p.y + p.vy*ln, self._thick)

        elif t == 3:
            # Туман — мягкое пятно из концентрических кругов
            base_r = DP * 60.0 * p.scale * ss_fog
            self._argb(self._fill, -1513240)
            rings = (
                (0.15, 0.10),
                (0.30, 0.08),
                (0.50, 0.06),
                (0.68, 0.04),
                (0.84, 0.02),
                (1.00, 0.01),
            )
            for r_frac, ring_frac in rings:
                ring_a = int(a * ring_frac)
                if ring_a <= 0: continue
                self._fill.setAlpha(ring_a)
                canvas.drawCircle(p.x, p.y, base_r * r_frac, self._fill)

        elif t == 4:
            # Облако — 5 перекрывающихся кругов
            self._argb(self._fill, -1118465)
            self._fill.setAlpha(min(a, 160))
            sc = p.scale * DP * 10.0 * ss_cloud
            for ox, oy, os in ((-2.0, 0.0, 0.8), (-0.8, -0.6, 1.0),
                                (0.6, -0.8, 1.2), (2.0, -0.4, 0.9), (1.2, 0.2, 0.7)):
                canvas.drawCircle(p.x + ox*sc, p.y + oy*sc, sc*os, self._fill)

        elif t == 6:
            # Солнечная искра — мерцает синусоидально
            flicker = 0.5 + 0.5 * math.sin(p.current_time * 0.015)
            self._argb(self._fill, -4472)
            self._fill.setAlpha(int(a * flicker))
            canvas.drawCircle(p.x, p.y, DP * 1.5 * p.scale * ss_spark, self._fill)

        elif t == 8:
            # Листик — заполненный овал через горизонтальные полосы + контур + прожилка
            rot = p.angle + p.current_time * 0.002 * (1.0 if p.spin > 0.5 else -1.0)
            seed_c = int(p.spin * 10) % 3
            if seed_c == 0:   fill_col, edge_col = -11163068, -13400013  # тёмно-зелёный
            elif seed_c == 1: fill_col, edge_col = -8926123, -12281549  # ярко-зелёный
            else:             fill_col, edge_col = -6697882, -11176158  # светло-зелёный
            base_l = DP * 8.0 * p.scale * ss_spring
            base_w = DP * 4.5 * p.scale * ss_spring
            cr = math.cos(rot); sr = math.sin(rot)
            # Заполнение: горизонтальные отрезки через эллипс (растровая заливка)
            self._thick.setStrokeWidth(DP * 1.2 * ss_spring)
            steps_fill = max(6, int(base_w / (DP * 1.2 * ss_spring) * 2))
            self._argb(self._thick, fill_col)
            self._thick.setAlpha(int(a * 0.88))
            for ki in range(steps_fill + 1):
                # t от -1 до 1 по ширине
                frac = (ki / steps_fill) * 2.0 - 1.0
                half_len = base_l * math.sqrt(max(0.0, 1.0 - frac * frac))
                # Локальные координаты: ось листа — cr/sr, ширина — перп
                px_off = (-sr) * frac * base_w
                py_off =  cr   * frac * base_w
                x1 = p.x + px_off + cr * (-half_len)
                y1 = p.y + py_off + sr * (-half_len)
                x2 = p.x + px_off + cr * half_len
                y2 = p.y + py_off + sr * half_len
                canvas.drawLine(x1, y1, x2, y2, self._thick)
            # Контур
            steps = 14
            pts = []
            for ki in range(steps):
                ang = ki * math.pi * 2 / steps
                lx = math.cos(ang) * base_l
                ly = math.sin(ang) * base_w
                pts.append((lx*cr - ly*sr + p.x, lx*sr + ly*cr + p.y))
            self._argb(self._thick, edge_col)
            self._thick.setAlpha(int(a * 0.95))
            self._thick.setStrokeWidth(DP * 0.7 * ss_spring)
            for ki in range(steps):
                x1,y1 = pts[ki]; x2,y2 = pts[(ki+1)%steps]
                canvas.drawLine(x1,y1, x2,y2, self._thick)
            # Прожилка
            self._thick.setAlpha(int(a * 0.5))
            self._thick.setStrokeWidth(DP * 0.5 * ss_spring)
            self._argb(self._thick, edge_col)
            canvas.drawLine(
                -cr*base_l*0.85 + p.x, -sr*base_l*0.85 + p.y,
                 cr*base_l*0.85 + p.x,  sr*base_l*0.85 + p.y,
                self._thick)

        elif t == 9:
            # Цветочек — 5 лепестков + жёлтый центр
            rot = p.angle + p.current_time * 0.0008
            seed_c = int(p.spin * 10) % 4
            if seed_c == 0:   col = -21812
            elif seed_c == 1: col = -8722
            elif seed_c == 2: col = -13091
            else:             col = -17443
            self._argb(self._fill, col)
            petal_r = DP * 3.5 * p.scale * ss_spring
            petal_d = DP * 4.0 * p.scale * ss_spring
            for ki in range(5):
                ang = rot + ki * (math.pi * 2 / 5)
                self._fill.setAlpha(int(a * 0.85))
                canvas.drawCircle(p.x + math.cos(ang)*petal_d,
                                  p.y + math.sin(ang)*petal_d, petal_r, self._fill)
            self._argb(self._fill, -4540)
            self._fill.setAlpha(int(a * 0.95))
            canvas.drawCircle(p.x, p.y, DP * 2.2 * p.scale * ss_spring, self._fill)

        elif t == 7:
            # Кубик льда — полупрозрачный многоугольник
            seed = int(p.spin) % 3
            base = DP * 4.0 * p.scale * ss_hail
            rot  = p.angle   # фиксированный угол поворота конкретной льдинки
            cx, cy = p.x, p.y

            # Заливка — очень прозрачный голубой
            self._argb(self._fill, -1714622721)
            self._fill.setAlpha(int(a * 0.45))

            # Контур — чуть ярче
            self._argb(self._thick, -861217281)
            self._thick.setAlpha(int(a * 0.75))
            self._thick.setStrokeWidth(DP * 0.7)

            if seed == 0:
                # Шестиугольник (гексагональный кристалл)
                pts = []
                for k in range(6):
                    ang = rot + k * math.pi / 3.0
                    pts.append((cx + math.cos(ang)*base, cy + math.sin(ang)*base))
                for k in range(6):
                    x1,y1 = pts[k]; x2,y2 = pts[(k+1)%6]
                    canvas.drawLine(x1,y1, x2,y2, self._thick)
                # Внутренние линии — звезда кристалла
                self._thick.setAlpha(int(a * 0.3))
                for k in range(6):
                    x1,y1 = pts[k]
                    canvas.drawLine(cx,cy, x1,y1, self._thick)

            elif seed == 1:
                # Ромб (уплощённый кристалл)
                w2 = base * 0.65
                h2 = base * 1.2
                cos_r = math.cos(rot); sin_r = math.sin(rot)
                verts = [
                    ( w2*cos_r - 0   *sin_r,  w2*sin_r + 0   *cos_r),
                    ( 0  *cos_r - h2 *sin_r,  0  *sin_r + h2 *cos_r),
                    (-w2*cos_r - 0   *sin_r, -w2*sin_r + 0   *cos_r),
                    ( 0  *cos_r + h2 *sin_r,  0  *sin_r - h2 *cos_r),
                ]
                self._thick.setAlpha(int(a * 0.75))
                for k in range(4):
                    x1,y1 = verts[k]; x2,y2 = verts[(k+1)%4]
                    canvas.drawLine(cx+x1,cy+y1, cx+x2,cy+y2, self._thick)
                # Диагонали
                self._thick.setAlpha(int(a * 0.3))
                canvas.drawLine(cx+verts[0][0],cy+verts[0][1], cx+verts[2][0],cy+verts[2][1], self._thick)
                canvas.drawLine(cx+verts[1][0],cy+verts[1][1], cx+verts[3][0],cy+verts[3][1], self._thick)

            else:
                # Неправильный пятиугольник (осколок льда)
                offsets = [
                    (1.0, 0.0), (0.3, -1.1), (-0.9, -0.8),
                    (-1.0, 0.4), (0.1, 1.0),
                ]
                cos_r = math.cos(rot); sin_r = math.sin(rot)
                pts = []
                for ox, oy in offsets:
                    rx = ox*cos_r - oy*sin_r
                    ry = ox*sin_r + oy*cos_r
                    pts.append((cx + rx*base, cy + ry*base))
                self._thick.setAlpha(int(a * 0.75))
                for k in range(5):
                    x1,y1 = pts[k]; x2,y2 = pts[(k+1)%5]
                    canvas.drawLine(x1,y1, x2,y2, self._thick)
                # Трещина
                self._thick.setAlpha(int(a * 0.25))
                canvas.drawLine(cx,cy, pts[2][0],pts[2][1], self._thick)

    # ── Солнце ────────────────────────────────────────────────────────────────

    def _draw_sun(self, canvas, w: int, h: int, dt: float, alpha: float = 1.0):
        """Рисует солнце. alpha=1.0 — ясно, 0.5 — за облаками (partly_cloudy)."""
        self._sun_angle += dt * self.cfg_sun_ray_speed
        cx = w * self.cfg_sun_pos_x
        cy = h * self.cfg_sun_pos_y
        ss = self.cfg_size_sun / 100.0

        # Ядро
        self._argb(self._fill, -13244)
        self._fill.setAlpha(int(220 * alpha))
        canvas.drawCircle(cx, cy, DP * 14.0 * ss, self._fill)

        # Мягкое свечение
        self._argb(self._fill, 0x55FFD966)
        self._fill.setAlpha(int(60 * alpha))
        canvas.drawCircle(cx, cy, DP * 22.0 * ss, self._fill)

        # Вращающиеся лучи
        n_rays = getattr(self, "cfg_sun_ray_count", 8)
        self._argb(self._thick, -13244)
        self._thick.setStrokeWidth(DP * 2.5 * ss)
        self._thick.setAlpha(int(180 * alpha))
        for i in range(n_rays):
            angle = self._sun_angle + i * (math.pi * 2.0 / n_rays)
            inner = DP * 18.0 * ss
            outer = DP * (28.0 + 4.0 * math.sin(self._sun_angle * 3 + i)) * ss
            canvas.drawLine(
                cx + math.cos(angle)*inner, cy + math.sin(angle)*inner,
                cx + math.cos(angle)*outer, cy + math.sin(angle)*outer,
                self._thick,
            )


    def _draw_night_sky(self, canvas, w: int, h: int, dt: float, opacity: float = 1.0):
        """Луна (полный диск + кратеры) + 4-лучевые звёзды + падающая звезда."""
        cx = w * self.cfg_sun_pos_x
        cy = h * self.cfg_sun_pos_y

        # ── Звёзды ──────────────────────────────────────────────────────────
        n = max(1, self.cfg_star_count)
        if not hasattr(self, '_star_positions') or len(self._star_positions) != n                 or getattr(self, '_star_ver', 0) < 3:
            rng = random.Random(42)
            self._star_positions = [
                (rng.random(), rng.random() * 0.95,  # Y: весь экран (5% отступ снизу)
                 rng.random() * 0.75 + 0.25,   # яркость 0.25–1.0
                 rng.random() * 0.9 + 0.3,      # скорость мерцания
                 rng.random() * 0.4 + 0.6,      # размер (0.6–1.0)
                 rng.random() * math.pi * 2)    # фаза мерцания (phase)
                for _ in range(n)
            ]
            self._star_ver = 3
        self._star_time = getattr(self, '_star_time', 0.0) + dt * 0.001

        for sx, sy, bright, speed, size, phase in self._star_positions:
            px = w * sx; py = h * sy
            if abs(px - cx) < DP * 24 and abs(py - cy) < DP * 24:
                continue
            spd = getattr(self, "cfg_star_twinkle_speed", 4.5)
            twinkle = abs(math.sin(self._star_time * speed * spd + phase))
            a = int(255 * bright * (0.2 + 0.8 * twinkle) * opacity)
            if a <= 0:
                continue
            r_long  = DP * (1.4 + size * 2.2) * (self.cfg_size_stars / 100.0)
            r_short = r_long * 0.32
            self._argb(self._thin, -1)
            self._thin.setStrokeWidth(DP * (0.5 + size * 0.5))
            self._thin.setAlpha(a)
            canvas.drawLine(px - r_long, py, px + r_long, py, self._thin)
            canvas.drawLine(px, py - r_long, px, py + r_long, self._thin)
            self._thin.setAlpha(a // 2)
            canvas.drawLine(px - r_short, py - r_short,
                            px + r_short, py + r_short, self._thin)
            canvas.drawLine(px - r_short, py + r_short,
                            px + r_short, py - r_short, self._thin)

        # ── Падающая звезда ─────────────────────────────────────────────────
        interval = max(300, self.cfg_shooting_star_interval)
        if not hasattr(self, '_shoot_timer'):
            self._shoot_timer    = random.randint(interval // 2, interval)
            self._shoot_active   = False
            self._shoot_progress = 0.0
            self._shoot_x0 = self._shoot_y0 = 0.0
            self._shoot_dx = self._shoot_dy = 0.0
            self._shoot_len = 0.0

        self._shoot_timer -= 1
        if self._shoot_timer <= 0 and not self._shoot_active:
            # Старт: случайная точка в верхней трети, не слишком близко к луне
            for _ in range(8):
                sx = random.uniform(0.05, 0.90)
                sy = random.uniform(0.02, 0.35)
                if abs(sx - self.cfg_sun_pos_x) > 0.15 or abs(sy - self.cfg_sun_pos_y) > 0.15:
                    break
            self._shoot_x0 = w * sx
            self._shoot_y0 = h * sy
            # Угол: 35–55° от горизонта вниз-вправо (иногда влево)
            direction = 1 if random.random() > 0.25 else -1
            ang = math.radians(random.uniform(35, 55))
            dist = w * random.uniform(0.28, 0.38)
            self._shoot_dx = math.cos(ang) * dist * direction
            self._shoot_dy = math.sin(ang) * dist
            self._shoot_len  = dist
            self._shoot_active   = True
            self._shoot_progress = 0.0
            self._shoot_timer    = interval + random.randint(-interval // 5, interval // 5)

        if self._shoot_active:
            self._shoot_progress += dt * 0.0022   # ~0.45 сек при 60fps
            t = self._shoot_progress
            if t >= 1.0:
                self._shoot_active = False
            else:
                # Головная точка
                hx = self._shoot_x0 + self._shoot_dx * t
                hy = self._shoot_y0 + self._shoot_dy * t
                # Хвост — 6 сегментов с нарастающей прозрачностью к началу
                tail_len = 0.22   # длина хвоста в долях от полного пути
                segments = 6
                for i in range(segments):
                    t1 = max(0.0, t - tail_len * (i + 1) / segments)
                    t2 = max(0.0, t - tail_len * i       / segments)
                    if t1 >= t2:
                        continue
                    x1 = self._shoot_x0 + self._shoot_dx * t1
                    y1 = self._shoot_y0 + self._shoot_dy * t1
                    x2 = self._shoot_x0 + self._shoot_dx * t2
                    y2 = self._shoot_y0 + self._shoot_dy * t2
                    # Яркость: голова ярче, хвост затухает + гаснет к концу полёта
                    bright = (1.0 - i / segments) ** 1.5
                    fade   = (1.0 - t) ** 0.6
                    a = int(240 * bright * fade * opacity)
                    if a <= 4:
                        continue
                    width = DP * (2.2 - i * 0.28)
                    self._argb(self._thick, -1)
                    self._thick.setStrokeWidth(max(DP * 0.4, width))
                    self._thick.setAlpha(a)
                    canvas.drawLine(x1, y1, x2, y2, self._thick)
                # Яркая искра в голове
                spark_a = int(255 * (1.0 - t) ** 0.4 * opacity)
                if spark_a > 0:
                    self._argb(self._fill, -1)
                    self._fill.setAlpha(spark_a)
                    canvas.drawCircle(hx, hy, DP * 2.0, self._fill)

        # ── Ракета 🚀 (старт управляется из on_draw) ────────────────────────
        # Запускаем если таймер сработал
        if self.cfg_show_rocket and getattr(self, '_rocket_timer', 999) <= 0                 and not getattr(self, '_rocket_active', False):
            self._rocket_x0 = w * random.uniform(0.2, 0.8)
            self._rocket_y0 = h * 0.92
            self._rocket_x1 = cx
            self._rocket_y1 = cy
            self._rocket_active   = True
            self._rocket_progress = 0.0
            _ri = max(60, self.cfg_rocket_interval)
            self._rocket_timer = _ri + random.randint(-_ri // 4, _ri // 4)

        if self.cfg_show_rocket and getattr(self, '_rocket_active', False):
            self._rocket_progress += dt * 0.00045   # ~2.2 сек полёт
            t = self._rocket_progress
            if t >= 1.0:
                self._rocket_active = False
            else:
                # Позиция ракеты (квадратичная кривая — дуга)
                mt = 1.0 - t
                mid_x = (self._rocket_x0 + self._rocket_x1) / 2 - w * 0.15
                mid_y = (self._rocket_y0 + self._rocket_y1) / 2 - h * 0.25
                rx = mt*mt*self._rocket_x0 + 2*mt*t*mid_x + t*t*self._rocket_x1
                ry = mt*mt*self._rocket_y0 + 2*mt*t*mid_y + t*t*self._rocket_y1
                # Направление для поворота корпуса
                drx = 2*(1-t)*(mid_x-self._rocket_x0) + 2*t*(self._rocket_x1-mid_x)
                dry = 2*(1-t)*(mid_y-self._rocket_y0) + 2*t*(self._rocket_y1-mid_y)
                # Угол вдоль вектора движения (нос вперёд по курсу)
                ang = math.atan2(dry, drx)  # угол вектора движения

                fade = min(1.0, min(t * 8, (1.0 - t) * 8))
                base_a = int(240 * fade * opacity)
                if base_a > 0:
                    mag = math.sqrt(drx*drx + dry*dry) or 1.0
                    ux = drx / mag; uy = dry / mag  # вперёд (нос)
                    px = -uy;       py = ux          # вправо перпендикулярно

                    L  = DP * 9.0   # полудлина корпуса
                    HW = DP * 2.2   # полуширина корпуса
                    nose_tip = (rx + ux*L*1.5, ry + uy*L*1.5)  # кончик носа

                    # ── Выхлоп (рисуем первым — под корпусом) ───────────────
                    flicker = 0.7 + 0.3 * math.sin(self._last_mono * 18.0)
                    for fi, (flen, fwid, fcol, falpha) in enumerate([
                        (2.5, 1.8, -8824,  1.00),  # белое ядро
                        (4.0, 1.4, -13244, 0.80),  # жёлтое
                        (5.5, 1.0, -21812, 0.55),  # оранжевое
                        (7.0, 0.6, -21812, 0.30),  # красноватый хвост
                    ]):
                        for si in range(3):  # 3 струи
                            spread = (si - 1) * 0.35
                            ex = rx - ux*(L + DP*flen*flicker) + px*(spread*DP*fwid*2)
                            ey = ry - uy*(L + DP*flen*flicker) + py*(spread*DP*fwid*2)
                            self._argb(self._fill, fcol)
                            self._fill.setAlpha(int(base_a * falpha))
                            canvas.drawCircle(ex, ey, DP * fwid * flicker, self._fill)

                    # ── Корпус (закруглённый прямоугольник) ─────────────────
                    self._argb(self._fill, -1)
                    self._fill.setAlpha(base_a)
                    # 4 вершины корпуса
                    pts = [
                        (rx - ux*L + px*HW, ry - uy*L + py*HW),
                        (rx + ux*L + px*HW, ry + uy*L + py*HW),
                        (rx + ux*L - px*HW, ry + uy*L - py*HW),
                        (rx - ux*L - px*HW, ry - uy*L - py*HW),
                    ]
                    path = Path()
                    path.moveTo(pts[0][0], pts[0][1])
                    for ptx, pty in pts[1:]: path.lineTo(ptx, pty)
                    path.close()
                    canvas.drawPath(path, self._fill)

                    # ── Нос (треугольник вперёд) ──────────────────────────────
                    path2 = Path()
                    path2.moveTo(pts[1][0], pts[1][1])      # правый перед
                    path2.lineTo(nose_tip[0], nose_tip[1])  # кончик
                    path2.lineTo(pts[2][0], pts[2][1])      # левый перед
                    path2.close()
                    self._argb(self._fill, -2280653)  # красный нос
                    self._fill.setAlpha(base_a)
                    canvas.drawPath(path2, self._fill)

                    # ── Стабилизаторы (два треугольника сзади) ────────────────
                    fin_len = DP * 5.0
                    for side in (1, -1):
                        fin = Path()
                        bx = rx - ux*L + px*HW*side; by = ry - uy*L + py*HW*side
                        fin.moveTo(bx, by)
                        fin.lineTo(bx + px*fin_len*side - ux*fin_len*0.5,
                                   by + py*fin_len*side - uy*fin_len*0.5)
                        fin.lineTo(rx - ux*(L*0.3) + px*HW*side,
                                   ry - uy*(L*0.3) + py*HW*side)
                        fin.close()
                        self._argb(self._fill, -3399134)  # тёмно-красный стаб
                        self._fill.setAlpha(int(base_a * 0.85))
                        canvas.drawPath(fin, self._fill)

                    # ── Иллюминатор ───────────────────────────────────────────
                    wx = rx + ux*(L*0.3); wy = ry + uy*(L*0.3)
                    self._argb(self._fill, -5579265)  # иллюминатор голубой
                    self._fill.setAlpha(int(base_a * 0.9))
                    canvas.drawCircle(wx, wy, DP * 1.4, self._fill)

        # ── Луна ────────────────────────────────────────────────────────────
        moon_r = DP * max(5.0, float(self.cfg_moon_size)) * (self.cfg_size_moon / 100.0)
        phase  = float(self.cfg_moon_phase)   # 0=полная, 13=тонкий серп
        offset = DP * phase * 0.85            # смещение тени вправо

        # Мягкое свечение (до saveLayer чтобы не обрезалось)
        for glow_r, glow_a in ((2.6, 10), (1.9, 18), (1.45, 28)):
            self._argb(self._fill, -3351041)
            self._fill.setAlpha(int(glow_a * opacity))
            canvas.drawCircle(cx, cy, moon_r * glow_r, self._fill)

        # Серп через saveLayer + DST_OUT — работает на hardware-accelerated canvas
        bounds = RectF(cx - moon_r - DP*2, cy - moon_r - DP*2,
                       cx + moon_r + offset + DP*2, cy + moon_r + DP*2)
        layer = canvas.saveLayer(bounds, None)

        # 1. Рисуем полный диск
        self._argb(self._fill, -2234128)
        self._fill.setAlpha(int(240 * opacity))
        canvas.drawCircle(cx, cy, moon_r, self._fill)

        # 2. Тёмный обод
        self._argb(self._thick, -7824965)
        self._thick.setStrokeWidth(DP * 2.5)
        self._thick.setAlpha(int(40 * opacity))
        canvas.drawCircle(cx, cy, moon_r - DP * 1.2, self._thick)

        # 3. Кратеры (смещены влево — в видимую зону серпа)
        craters = [
            (-0.28, -0.22, 0.12, False),
            (-0.48, +0.10, 0.09, False),
            (-0.15, +0.38, 0.08, True),
            (-0.38, -0.42, 0.07, False),
            (-0.55, -0.18, 0.06, True),
            (-0.10, -0.52, 0.05, False),
            (-0.42, +0.38, 0.06, True),
            (-0.20, +0.10, 0.04, False),
            (-0.32, +0.22, 0.05, True),
        ]
        for dx, dy, cr, hollow in craters:
            if math.hypot(dx, dy) + cr > 0.92:
                continue
            kx = cx + dx * moon_r
            ky = cy + dy * moon_r
            kr = cr * moon_r
            if hollow:
                self._argb(self._thick, -7824982)
                self._thick.setStrokeWidth(DP * 0.8)
                self._thick.setAlpha(int(110 * opacity))
                canvas.drawCircle(kx, ky, kr, self._thick)
                self._argb(self._thick, -10057558)
                self._thick.setStrokeWidth(DP * 0.5)
                self._thick.setAlpha(int(60 * opacity))
                canvas.drawCircle(kx + kr*0.1, ky + kr*0.1, kr * 0.7, self._thick)
            else:
                self._argb(self._fill, -4667176)
                self._fill.setAlpha(int(140 * opacity))
                canvas.drawCircle(kx, ky, kr, self._fill)
                self._argb(self._thick, -8939094)
                self._thick.setStrokeWidth(DP * 0.6)
                self._thick.setAlpha(int(90 * opacity))
                canvas.drawCircle(kx, ky, kr, self._thick)
                self._argb(self._fill, -1116673)
                self._fill.setAlpha(int(70 * opacity))
                canvas.drawCircle(kx - kr*0.28, ky - kr*0.28, kr*0.42, self._fill)

        # 4. DST_OUT — вырезаем «тень» серпа смещённым кругом
        if phase > 0.3:
            _xfer_paint = Paint(Paint.ANTI_ALIAS_FLAG)
            _xfer_paint.setStyle(Paint.Style.FILL)
            _xfer_paint.setXfermode(PorterDuffXfermode(PorterDuff.Mode.DST_OUT))
            _xfer_paint.setARGB(255, 0, 0, 0)
            canvas.drawCircle(cx + offset, cy, moon_r * 0.97, _xfer_paint)
            _xfer_paint.setXfermode(None)

        canvas.restoreToCount(layer)

        # 5. Ободок поверх (уже без layer)
        self._argb(self._thick, -5588020)
        self._thick.setStrokeWidth(DP * 0.8)
        self._thick.setAlpha(int(70 * opacity))
        canvas.drawCircle(cx, cy, moon_r, self._thick)


    def _draw_cloud_bg(self, canvas, w: int, h: int, opacity: float = 1.0):
        """Статичное фоновое облако вверху для cloudy/partly_cloudy."""
        sc_c  = self.cfg_size_clouds / 100.0
        cy_bg = h * (self.cfg_cloud_max_y / 1000.0)
        self._argb(self._fill, -2236946)
        sc = DP * 18.0 * sc_c
        for ox, oy, os, oa in (
            (-3.0,  0.0, 1.0, 55),
            (-1.0, -1.0, 1.3, 65),
            ( 1.0, -1.2, 1.5, 70),
            ( 3.0, -0.5, 1.1, 60),
            ( 2.0,  0.3, 0.8, 50),
        ):
            self._fill.setAlpha(int(oa * opacity))
            canvas.drawCircle(w*0.5+ox*sc, cy_bg+oy*sc, sc*os, self._fill)

    # ── on_draw ───────────────────────────────────────────────────────────────

    def on_draw(self, view, canvas):
        if not self.running:
            return
        wt      = self.weather_type
        opacity = self.cfg_opacity.get(wt, 1.0)
        if opacity <= 0.0: return
        try:
            w = view.getWidth()
            h = view.getHeight()
            if w <= 0 or h <= 0: return

            now = time.monotonic()
            dt  = min(32.0, (now - self._last_mono)*1000.0) if self._last_mono > 0 else 16.0
            self._last_mono = now

            needs_invalidate = False

            # Ракета: тикаем таймер каждый кадр независимо от погоды/времени суток
            if self.cfg_show_rocket:
                if not hasattr(self, '_rocket_timer'):
                    _ri0 = max(60, self.cfg_rocket_interval)
                    self._rocket_timer  = random.randint(max(1, _ri0 // 4), _ri0 // 2)
                    self._rocket_active = False
                self._rocket_timer -= 1

            _auto_night = _is_night_now()
            _mode = getattr(self, "_clear_mode", "auto")
            _is_night = (_mode == "moon") or (_mode == "auto" and _auto_night)

            if wt == "clear":
                opacity = self.cfg_opacity_clear_night if _is_night else self.cfg_opacity.get(wt, 1.0)
                if opacity <= 0.0:
                    pass
                elif _is_night:
                    if self.cfg_show_moon or self.cfg_show_stars:
                        self._draw_night_sky(canvas, w, h, dt, opacity=opacity)
                else:
                    if self.cfg_show_sun:
                        self._draw_sun(canvas, w, h, dt, alpha=opacity)
                if self.cfg_show_sparks:
                    for p in self.particles: self._draw_particle(canvas, p, opacity)
                self._spawn(w, h)
                self._update(dt)
                needs_invalidate = True

            elif wt == "partly_cloudy":
                _partly_night = getattr(self, "_partly_night_mode", False) or _is_night
                _partly_sun   = getattr(self, "_partly_sun_mode",   False)
                opacity = self.cfg_opacity_partly_night if _partly_night else self.cfg_opacity.get(wt, 1.0)
                if opacity > 0.0:
                    if _partly_sun:
                        if self.cfg_show_sun:
                            self._draw_sun(canvas, w, h, dt, alpha=opacity * 0.5)
                    elif _partly_night:
                        if self.cfg_show_moon or self.cfg_show_stars:
                            self._draw_night_sky(canvas, w, h, dt, opacity=opacity * 0.5)
                    else:
                        if self.cfg_show_sun:
                            self._draw_sun(canvas, w, h, dt, alpha=opacity * 0.5)
                    if self.cfg_show_clouds:
                        self._draw_cloud_bg(canvas, w, h, opacity=opacity)
                        for p in self.particles: self._draw_particle(canvas, p, opacity)
                self._spawn(w, h)
                self._update(dt)
                needs_invalidate = True

            elif wt == "cloudy":
                if self.cfg_show_clouds:
                    self._draw_cloud_bg(canvas, w, h, opacity=opacity)
                    for p in self.particles: self._draw_particle(canvas, p, opacity)
                self._spawn(w, h)
                self._update(dt)
                needs_invalidate = bool(self.particles)

            elif wt in ("fog","light_rain","rain","thunder",
                        "light_snow","snow","sleet","hail"):
                if wt == "thunder" and self.cfg_show_lightning:
                    self._lightning_timer += 1
                    if self._lightning_timer >= self._lightning_next:
                        self._lightning_alpha = self.cfg_lightning_intensity
                        self._lightning_timer = 0
                        self._lightning_next  = random.randint(300, 700)
                        self._lightning_spots = [
                            (random.random() * w, random.random() * h,
                             DP * (random.random() * 80 + 60))
                            for _ in range(random.randint(2, 4))
                        ]
                    elif self._lightning_alpha > 0:
                        self._lightning_alpha = max(0, self._lightning_alpha - self.cfg_lightning_speed)
                    if self._lightning_alpha > 0 and self._lightning_spots:
                        self._argb(self._fill, -18)
                        for sx, sy, sr in self._lightning_spots:
                            self._fill.setAlpha(int(self._lightning_alpha * opacity))
                            canvas.drawCircle(sx, sy, sr * 0.35, self._fill)
                            self._fill.setAlpha(int(self._lightning_alpha * opacity * 2 // 5))
                            canvas.drawCircle(sx, sy, sr * 0.65, self._fill)
                            self._fill.setAlpha(int(self._lightning_alpha * opacity // 6))
                            canvas.drawCircle(sx, sy, sr, self._fill)
                elif wt == "thunder":
                    self._lightning_alpha = 0

                _skip = False
                if wt in ("light_rain", "rain", "thunder", "sleet") and not self.cfg_show_rain:
                    _skip = True
                if wt in ("light_snow", "snow") and not self.cfg_show_snow:
                    _skip = True
                if wt == "sleet" and not self.cfg_show_rain and not self.cfg_show_snow:
                    _skip = True
                if wt == "fog" and not self.cfg_show_fog:
                    _skip = True
                if not _skip:
                    for p in self.particles: self._draw_particle(canvas, p, opacity)
                self._spawn(w, h)
                self._update(dt)
                needs_invalidate = bool(self.particles) or self._lightning_alpha > 0

            if needs_invalidate:
                self._draw_ok_count += 1
                try:
                    view.postInvalidateOnAnimation()
                except Exception:
                    view.invalidate()

        except Exception as e:
            self._last_draw_error = str(e)
            log(f"[DynBG] on_draw: {e}")



# ─── Settings header hook (как в morse_keyboard) ──────────────────────────────

class _SettingsHeaderHook(MethodHook):
    def __init__(self, plugin):
        self._plugin = plugin

    def before_hooked_method(self, param): return

    def after_hooked_method(self, param):
        try:
            activity = param.thisObject
            items    = param.args[0]
            if not items or items.size() == 0: return
            plugin_obj = get_private_field(activity, "plugin")
            if not plugin_obj or str(plugin_obj.getId()) != __id__: return
            callback = get_private_field(activity, "createSubFragmentCallback")
            if callback is not None: return
            header = self._plugin._create_settings_header_view(activity.getContext())
            if not header: return
            from org.telegram.ui.Components import UItem
            try:
                from com.exteragram.messenger.plugins.models import HeaderSetting
                item = UItem.asCustom(header)
                item.settingItem = HeaderSetting(f"{__id__}_header")
            except Exception:
                item = UItem.asCustom(header)
            try: item.setTransparent(True)
            except Exception: pass
            items.add(0, item)
        except Exception: pass


_effect = WeatherEffect()
_plugin_ref = None

# ─── Preview ──────────────────────────────────────────────────────────────────



# ─── Hooks ────────────────────────────────────────────────────────────────────

class DrawHook(MethodHook):
    """
    chat_only=True  → ChatActivityFragmentView, рисует всегда
    chat_only=False → SizeNotifierFrameLayout, рисует если h>=80%
                      и текущий view не является ChatActivityFragmentView
    """
    def __init__(self, chat_only=False):
        self._chat_only = chat_only

    def after_hooked_method(self, param):
        try:
            view   = param.thisObject
            canvas = param.args[0]
            if canvas is None: return
            if not (_plugin_ref and _plugin_ref.get_setting("enabled", True)): return
            w, h = view.getWidth(), view.getHeight()
            if w < 200 or h < 200: return
            if self._chat_only:
                # chat_hook: не рисуем если overlay уже покрывает всё
                if getattr(_plugin_ref, "_effect_overlay", None) is not None: return
            else:
                try:
                    rh = view.getRootView().getHeight()
                    if rh > 0 and h < rh * 0.80: return
                except Exception: pass
                lv = _effect.last_view
                if lv is not None:
                    try:
                        if "ChatActivity" in lv.getClass().getName(): return
                    except Exception: pass
            _effect.on_draw(view, canvas)
            _effect.last_view = view
            if _effect.running and _effect.weather_type:
                try:    view.postInvalidateOnAnimation()
                except: view.invalidate()
        except Exception as e:
            log(f"[DynBG] DrawHook: {e}")


class _OverlayDrawHook(MethodHook):
    def __init__(self): self._view = None  # устанавливается при создании overlay
    def after_hooked_method(self, param):
        try:
            view = param.thisObject
            if view is not self._view: return  # быстрая проверка по идентичности
            canvas = param.args[0]
            if canvas is None: return
            if not (_plugin_ref and _plugin_ref.get_setting("enabled", True)): return
            _effect.on_draw(view, canvas)
            _effect.last_view = view
            if _effect.running and _effect.weather_type:
                try:    view.postInvalidateOnAnimation()
                except: view.invalidate()
        except Exception as e:
            log(f"[DynBG] OverlayDrawHook: {e}")


class ResumeHook(MethodHook):
    def __init__(self, plugin): self._p = plugin
    def after_hooked_method(self, param):
        try:    self._p._on_resumed()
        except Exception as e: log(f"[DynBG] ResumeHook: {e}")


class PauseHook(MethodHook):
    def __init__(self, plugin=None): self._p = plugin
    def before_hooked_method(self, param):
        _effect.last_view = None
        if self._p is not None:
            try: run_on_ui_thread(self._p._detach_preview_bar)
            except Exception: pass


# ─── Plugin ───────────────────────────────────────────────────────────────────

class DynamicBackgroundsPlugin(BasePlugin):

    TAG = "[DynBG]"

    _CMDS = {
        ".bg clear":         "clear",
        ".bg partly_cloudy": "partly_cloudy",
        ".bg cloudy":        "cloudy",
        ".bg fog":           "fog",
        ".bg light_rain":    "light_rain",
        ".bg rain":          "rain",
        ".bg thunder":       "thunder",
        ".bg light_snow":    "light_snow",
        ".bg snow":          "snow",
        ".bg sleet":         "sleet",
        ".bg hail":          "hail",
        ".bg spring":        "clear",
    }
    _LABELS = {
        "clear":         "☀️ Ясно",
        "partly_cloudy": "⛅ Переменная облачность",
        "cloudy":        "☁️ Облачно",
        "fog":           "🌫 Туман",
        "light_rain":    "🌦 Лёгкий дождь",
        "rain":          "🌧 Дождь",
        "thunder":       "⛈ Гроза",
        "light_snow":    "🌨 Лёгкий снег",
        "snow":          "❄️ Снег",
        "sleet":         "🌧 Слякоть",
        "hail":          "🌨 Град",
    }

    def __init__(self):
        super().__init__()
        self._weather_type  = "clear"
        self._last_update   = 0.0
        self._cache         = {}
        self._loop_running  = False
        self._fetch_lock    = threading.Lock()
        self._location_name = "—"
        # debug
        self._hook_info      = "не установлен"
        self._last_geo_error = ""
        self._last_net_error = ""

    # ── Lifecycle ─────────────────────────────────────────────────────────────

    def on_plugin_load(self):
        global _plugin_ref
        _plugin_ref = self
        self.log(f"{self.TAG} v7.0.0 loading")
        self._setup_hooks()
        self._apply_cfg()
        _effect.running = True
        _effect._clear_mode        = self.get_setting("clear_mode", "auto")
        _effect._partly_night_mode = self.get_setting("partly_night_mode", False)
        _effect._partly_sun_mode   = self.get_setting("partly_sun_mode",   False)

        # Принудительная стартовая погода (если задана)
        try:
            _sw_idx = int(self.get_setting("startup_weather", 0))
        except (TypeError, ValueError):
            _sw_idx = 0
        if _sw_idx > 0 and _sw_idx < len(self._STARTUP_VALUES):
            _sw_wt = self._STARTUP_VALUES[_sw_idx]
            self._apply_startup_weather(_sw_wt)
            self.log(f"{self.TAG} startup weather: {_sw_wt}")

        self._start_weather_loop()
        self.add_on_send_message_hook()
        self._install_settings_header_hook()
        BulletinHelper.show_success("Dynamic Backgrounds 🌦")
        # Восстанавливаем температурный оверлей если данные уже есть
        if getattr(_effect, "_temp_celsius", None) is not None:
            run_on_ui_thread(self._update_temp_overlay)

    def _install_settings_header_hook(self):
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            if not PSA: return
            method = PSA.getClass().getDeclaredMethod(
                "fillItems",
                find_class("java.util.ArrayList"),
                find_class("org.telegram.ui.Components.UniversalAdapter"),
            )
            method.setAccessible(True)
            self.hook_method(method, _SettingsHeaderHook(self))
            self.log(f"{self.TAG} settings header hooked")
        except Exception as e:
            self.log(f"{self.TAG} header hook: {e}")

    def on_plugin_unload(self):
        self._loop_running = False
        _effect.running    = False

    # ── Settings subpages ─────────────────────────────────────────────────────

