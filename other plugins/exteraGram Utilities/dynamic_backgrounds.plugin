            I(key="size_spring",   text="Размер листьев/цветков", default="100", subtext="%", icon="msg_media", on_change=self._apply_cfg),
            D(),
            I(key="opacity_clear",       text="Прозрачность (день)", default="100", subtext="0–100%", icon="msg_media", on_change=self._apply_cfg),
            I(key="opacity_clear_night", text="Прозрачность (ночь)", default="100", subtext="0–100%", icon="msg_media", on_change=self._apply_cfg),
            D(),
