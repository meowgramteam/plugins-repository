        I = Input; D = Divider; H = Header
        return [
            H(text="Солнце (день)"),
            I(key="size_sun",      text="Размер солнца",      default="100", subtext="%", icon="msg_media", on_change=self._apply_cfg),
            I(key="sun_pos_x",     text="Позиция X",          default="82",  subtext="0–100%", icon="msg_media", on_change=self._apply_cfg),
            I(key="sun_pos_y",     text="Позиция Y",          default="12",  subtext="0–50%",  icon="msg_media", on_change=self._apply_cfg),
            I(key="sun_ray_speed", text="Скорость вращения",  default="3",   subtext="0=стоит, выше=быстрее", icon="msg_media", on_change=self._apply_cfg),
            I(key="sun_ray_count", text="Кол-во лучей",       default="8",   subtext="3–16", icon="msg_media", on_change=self._apply_cfg),
            D(),
            H(text="Искры (день)"),
            I(key="size_sparks",   text="Размер искр",        default="100", subtext="%", icon="msg_media", on_change=self._apply_cfg),
            I(key="spark_spawn",   text="Частота искр",       default="85",  subtext="0–100 (меньше = чаще)", icon="msg_media", on_change=self._apply_cfg),
            I(key="spark_count",   text="Макс. искр",         default="20",  subtext="штук", icon="msg_media", on_change=self._apply_cfg),
            D(),
            H(text="Луна (ночь)"),
            I(key="size_moon",     text="Размер луны",        default="100", subtext="%", icon="msg_media", on_change=self._apply_cfg),
            I(key="moon_size",     text="Базовый радиус",     default="13",  subtext="dp (5–30)", icon="msg_media", on_change=self._apply_cfg),
            I(key="moon_phase",    text="Фаза луны (серп)",   default="5",   subtext="0=полная, 13=тонкий серп", icon="msg_media", on_change=self._apply_cfg),
            D(),
            H(text="Звёзды (ночь)"),
            I(key="size_stars",    text="Размер звёзд",       default="100", subtext="%", icon="msg_media", on_change=self._apply_cfg),
