# ─── WMO weather codes → тип эффекта (Open-Meteo) ───────────────────────────
# https://open-meteo.com/en/docs#weathervariables (weathercode / weather_code)
WMO = {
    0:  "clear",        # Ясно
    1:  "clear",        # Преимущественно ясно
    2:  "partly_cloudy",# Переменная облачность
