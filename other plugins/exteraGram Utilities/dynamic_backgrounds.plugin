            I(key="star_twinkle_speed", text="Скорость мерцания", default="45", subtext="10=медленно, 45=норм, 80=быстро", icon="msg_media", on_change=self._apply_cfg),
            I(key="shooting_star_interval", text="Интервал падающей звезды", default="3600", subtext="кадров (~3600=раз в минуту)", icon="msg_media", on_change=self._apply_cfg),
            D(),
