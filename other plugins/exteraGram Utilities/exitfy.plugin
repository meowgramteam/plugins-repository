def _is_ru_token(v):
    try:
        s = str(v or "").strip().lower()
    except Exception:
        return False
    if not s:
        return False
    if s.startswith("ru") or s.startswith("—Ä—É—Ā"):
        return True
    if " ru" in (" " + s) or "ru_" in s or "ru-" in s:
        return True
    if "—Ä—É—Ā" in s:
        return True
    return False

def _is_ru_language():
    try:
        lc = LocaleController.getInstance()
        if lc is not None:
            for method_name in ("getCurrentLocaleInfo", "getCurrentLocale", "getCurrentLangCode", "getCurrentLanguageName"):
                try:
                    member = getattr(lc, method_name, None)
                    val = member() if callable(member) else member
                    if _is_ru_token(val):
                        return True
                    for attr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, attr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
            for attr in ("currentLocaleInfo", "currentLocale", "currentLangCode"):
                try:
                    val = getattr(lc, attr, None)
                    if _is_ru_token(val):
                        return True
                    for subattr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, subattr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
    except Exception:
        pass
    try:
        if _is_ru_token(Locale.getDefault().getLanguage()):
            return True
        if _is_ru_token(Locale.getDefault().toString()):
            return True
    except Exception:
        pass
    return False

def Z(key):
    idx = 0 if _is_ru_language() else 1
    try: return str(TRANSLATIONS.get(key, (key, key))[idx])
    except: return str(key)


class ConnState:
    DISCONNECTED = "disconnected"
    LOADING      = "loading"
    CONNECTING   = "connecting"
    CONNECTED    = "connected"
    ERROR        = "error"

_STATE_ICON = {
    ConnState.DISCONNECTED: "msg_block",
    ConnState.LOADING:      "msg_download",
    ConnState.CONNECTING:   "msg_clock",
    ConnState.CONNECTED:    "msg_check",
    ConnState.ERROR:        "msg_error",
}

_STATE_LABEL_KEY = {
    ConnState.DISCONNECTED: "st_disconnected",
    ConnState.LOADING:      "st_loading",
    ConnState.CONNECTING:   "st_connecting",
    ConnState.CONNECTED:    "st_connected",
    ConnState.ERROR:        "st_error",
}

def _state_icon(state):
    return _STATE_ICON.get(state, "msg_info")

def _state_label(state, detail=""):
    base = Z(_STATE_LABEL_KEY.get(state, "st_disconnected"))
    detail = str(detail or "").strip()
    return f"{base} ¬∑ {detail}" if detail else base

def _ui_run(fn):
    try:
        run_on_ui_thread(fn)
    except Exception as e:
        _safe_log(f"_ui_run failed: {e}")

def _safe_log(msg):
    try:
        log(f"[exitfy] {msg}")
    except Exception:
        pass

def _notify_error(msg, exc=None):
    text = str(msg or Z("st_error"))
    _safe_log("ERROR: " + text + (f" :: {exc!r}" if exc is not None else ""))
    _ui_run(lambda: BulletinHelper.show_error(text))

def _notify_ok(msg):
    text = str(msg or "")
    _safe_log("OK: " + text)
    _ui_run(lambda: BulletinHelper.show_success(text))

def _notify_info(msg):
    text = str(msg or "")
    _safe_log("INFO: " + text)
    try:
        _ui_run(lambda: BulletinHelper.show_info(text))
    except Exception:
        _ui_run(lambda: BulletinHelper.show_success(text))

def _prefs():
    return ApplicationLoader.applicationContext.getSharedPreferences("exitfy_prefs", 0)

def _get_or_create_hwid():
    try:
        custom = _pget_str("exitfy_hwid_custom", "")
        custom = str(custom or "").strip()
        if custom:
            return custom
        k = "exitfy_hwid"
        v = _pget_str(k, "")
        v = str(v or "").strip()
        if v:
            return v
        raw = os.urandom(8)
        hwid = binascii.hexlify(raw).decode("ascii")
        _pset_str(k, hwid)
        return hwid
    except Exception:
        return ""

def _pget_str(k, d=""):
    try: return str(_prefs().getString(k, str(d)) or "")
    except: return d

def _pset_str(k, v):
    try: ed = _prefs().edit(); ed.putString(k, str(v or "")); ed.commit()
    except: pass

def _to_int(v, d=0):
    try: return int(v)
    except: return int(d)

def _clean_vless_name(raw_name):
    try:
        s = str(raw_name or "")
    except:
        s = ""
    try:
        s = urllib.parse.unquote(s)
    except:
        pass
    s = s.strip()
    try:
        s = re.sub(r"\s{2,}", " ", s)
    except:
        pass
    if not s:
        s = Z("vless_node_default")
    return s

def _is_proxy_uri(s):
    try:
        return any(str(s).startswith(scheme) for scheme in _PROXY_SCHEMES)
    except:
        return False

def _find_proxy_scheme(s):
    for scheme in _PROXY_SCHEMES:
        idx = str(s).find(scheme)
        if idx >= 0:
            return scheme, idx
    return None, -1

def _sanitize_vless_uri(raw_uri):
    try:
        s = str(raw_uri or "")
    except:
        return ""
    try:
        s = unescape(s)
    except:
        pass
    s = s.replace("\n", "").replace("\r", "").strip()
    if not s:
        return ""
    try:
        scheme, idx = _find_proxy_scheme(s)
        if scheme and idx > 0:
            s = s[idx:]
    except:
        pass
    try:
        s = re.sub(r"[\s\)\]>,\.;]+$", "", s)
    except:
        pass
    if not _is_proxy_uri(s):
        return s
    if s.startswith("vmess://"):
        return s
    if "#" not in s:
        return s
    try:
        base, frag = s.split("#", 1)
        frag = urllib.parse.quote(urllib.parse.unquote(frag), safe="")
        return base + "#" + frag
    except:
        return s

def _normalize_sub_url(raw_url):
    try:
        s = str(raw_url or "").strip()
    except Exception:
        s = ""
    if not s:
        return ""
    try:
        p = urllib.parse.urlsplit(s)
        scheme = str(p.scheme or "").strip().lower()
        if scheme not in ("http", "https"):
            return s
        netloc = str(p.netloc or "").strip().lower()
        path = str(p.path or "").strip() or "/"
        if path != "/":
            path = path.rstrip("/")
            if not path:
                path = "/"
        query = str(p.query or "").strip()
        return urllib.parse.urlunsplit((scheme, netloc, path, query, ""))
    except Exception:
        return s

def _uri_dedup_key(raw_uri):
    try:
        u = _sanitize_vless_uri(raw_uri)
        if not u:
            return ""
        if "#" in u:
            u = u.split("#", 1)[0]
        u = u.strip()
        if not u:
            return ""
        if u.startswith("vmess://"):
            try:
                body = u[8:]
                if "#" in body:
                    body = body.split("#", 1)[0]
                body = body.strip().replace("-", "+").replace("_", "/")
                miss = len(body) % 4
                if miss:
                    body += "=" * (4 - miss)
                raw = base64.b64decode(body, validate=False)
                obj = json.loads(raw.decode("utf-8", errors="ignore"))
                if isinstance(obj, dict):
                    canon = json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
                    return "vmess://" + hashlib.sha256(canon.encode("utf-8")).hexdigest()
            except Exception:
                pass
            return u.strip()
        if u.startswith("ss://"):
            try:
                body = u[5:]
                if "#" in body:
                    body = body.split("#", 1)[0]
                body = body.strip()
                if "@" in body:
                    creds, server_part = body.split("@", 1)
                else:
                    b64 = body.split("?", 1)[0].strip().replace("-", "+").replace("_", "/")
                    miss = len(b64) % 4
                    if miss:
                        b64 += "=" * (4 - miss)
                    decoded = base64.b64decode(b64, validate=False).decode("utf-8", errors="ignore")
                    if "@" in decoded:
                        creds, server_part = decoded.split("@", 1)
                    else:
                        creds, server_part = decoded, ""
                server_part = server_part.split("?", 1)[0].strip().rstrip("/")
                host, port = "", ""
                if server_part.startswith("["):
                    rb = server_part.find("]")
                    if rb > 0:
                        host = server_part[: rb + 1].lower()
                        rest = server_part[rb + 1 :]
                        if rest.startswith(":"):
                            port = rest[1:]
                elif ":" in server_part:
                    host, port = server_part.rsplit(":", 1)
                    host = host.lower().strip()
                    port = str(port or "").strip()
                creds = str(creds or "").strip()
                if creds and host and port:
                    return f"ss://{creds}@{host}:{port}"
            except Exception:
                pass
            return u.strip()
        try:
            p = urllib.parse.urlsplit(u)
        except Exception:
            p = None
        if not p or not p.scheme:
            return u
        scheme = str(p.scheme or "").lower()
        if scheme == "trojan":
            try:
                scheme = "trojan"
            except Exception:
                pass
        netloc = str(p.netloc or "")
        path = str(p.path or "")
        query = str(p.query or "")
        if netloc and "@" in netloc:
            userinfo, hostport = netloc.rsplit("@", 1)
        else:
            userinfo, hostport = "", netloc
        host = hostport
        port = ""
        if hostport.startswith("["):
            try:
                rb = hostport.find("]")
                if rb > 0:
                    host = hostport[: rb + 1]
                    rest = hostport[rb + 1 :]
                    if rest.startswith(":"):
                        port = rest[1:]
            except Exception:
                host = hostport
        elif ":" in hostport:
            try:
                host, port = hostport.rsplit(":", 1)
            except Exception:
                host, port = hostport, ""
        host = str(host or "").lower().strip()
        port = str(port or "").strip()
        if userinfo:
            userinfo = str(userinfo).strip()
            try:
                userinfo = urllib.parse.quote(urllib.parse.unquote(userinfo), safe=":")
            except Exception:
                pass
            try:
                if scheme == "vless":
                    uu = urllib.parse.unquote(userinfo).strip()
                    if uu.startswith("{") and uu.endswith("}"):
                        uu = uu[1:-1].strip()
                    userinfo = urllib.parse.quote(str(uu).lower(), safe=":")
            except Exception:
                pass
        if path:
            path = str(path).rstrip("/")
        q_items = []
        if query:
            try:
                q_items = urllib.parse.parse_qsl(query, keep_blank_values=True)
            except Exception:
                q_items = []
        if q_items:
            try:
                q_items.sort(key=lambda kv: (str(kv[0]), str(kv[1])))
            except Exception:
                pass
            try:
                parts = []
                for kk, vv in q_items:
                    k2 = urllib.parse.quote(str(kk or ""), safe="")
                    v2 = urllib.parse.quote(str(vv or ""), safe="/:@")
                    parts.append(f"{k2}={v2}")
                query = "&".join(parts)
            except Exception:
                pass
        netloc2 = host
        if port:
            netloc2 = f"{host}:{port}"
        if userinfo:
            netloc2 = f"{userinfo}@{netloc2}"
        return urllib.parse.urlunsplit((scheme, netloc2, path, query, ""))
    except:
        return ""

def _device_model_header():
    try:
        manufacturer = str(getattr(Build, "MANUFACTURER", "") or "").strip()
    except Exception:
        manufacturer = ""
    try:
        model = str(getattr(Build, "MODEL", "") or "").strip()
    except Exception:
        model = ""
    if manufacturer and model:
        if model.lower().startswith(manufacturer.lower()):
            return model
        return f"{manufacturer} {model}"
    if model:
        return model
    if manufacturer:
        return manufacturer
    return "Android"

def _device_os_version_header():
    try:
        version_obj = getattr(Build, "VERSION", None)
        release = str(getattr(version_obj, "RELEASE", "") or "").strip() if version_obj else ""
        if release:
            return release
    except Exception:
        pass
    return "Android"

def _is_generic_node_name(raw_name):
    try:
        low = str(raw_name or "").strip().lower()
    except Exception:
        low = ""
    if not low:
        return True
    if low in ("proxy", "server", "node", "vless", "default", "—Ā–Ķ—Ä–≤–Ķ—Ä", "—É–∑–Ķ–Ľ", "–Ņ—Ä–ĺ–ļ—Ā–ł"):
        return True
    if re.fullmatch(r"proxy-\d+", low):
        return True
    return False

def _name_from_uri(raw_uri):
    try:
        u = _sanitize_vless_uri(raw_uri)
    except Exception:
        u = ""
    if not u:
        return ""
    try:
        if "#" in u:
            frag = u.split("#", 1)[1]
            n = _clean_vless_name(frag)
            if n and not _is_generic_node_name(n):
                return n
    except Exception:
        pass
    try:
        parsed = urllib.parse.urlsplit(u)
        q = urllib.parse.parse_qs(str(parsed.query or ""), keep_blank_values=False)
        for key in ("name", "ps", "remark", "remarks", "title"):
            vals = q.get(key) or q.get(key.upper())
            if not vals:
                continue
            n = _clean_vless_name(vals[0])
            if n and not _is_generic_node_name(n):
                return n
    except Exception:
        pass
    return ""

def _node_named_dedup_key(raw_uri, raw_name=""):
    name = ""
    try:
        name = str(raw_name or "").strip()
    except Exception:
        name = ""
    if not name or _is_generic_node_name(name):
        name = _name_from_uri(raw_uri)
    key = _node_soft_dedup_key(raw_uri, name)
    if key:
        return key
    return _node_dedup_key(raw_uri)

_LAST_VLESS_FETCH_DIAG = {}
_LAST_SUB_TITLE = {}

def _decode_sub_title(raw):
    s = str(raw or "").strip().strip('"').strip()
    if not s:
        return ""
    if s.lower().startswith("base64:"):
        try:
            b = s[7:].strip().replace("-", "+").replace("_", "/")
            pad = len(b) % 4
            if pad:
                b += "=" * (4 - pad)
            s = base64.b64decode(b).decode("utf-8", errors="ignore").strip()
        except Exception:
            pass
    for ext in (".txt", ".yaml", ".yml", ".json"):
        if s.lower().endswith(ext):
            s = s[: -len(ext)]
            break
    return s.strip()

def _sub_title_for_url(url):
    try:
        return str(_LAST_SUB_TITLE.get(str(url or ""), "") or "")
    except Exception:
        return ""

def _is_hitvpn_uri(value):
    try:
        raw = str(value or "").strip().lower()
    except:
        raw = ""
    return bool(
        raw.startswith(HITVPN_LINK_PREFIX)
        or raw.startswith(HITRAY_LINK_PREFIX)
        or raw.startswith(HITVPN_SCHEME_PREFIX)
    )

class _MiniCborReader:
    def __init__(self, data):
        self.data = bytes(data or b"")
        self.pos = 0

    def read(self):
        initial = self._take(1)[0]
        major = initial >> 5
        additional = initial & 0x1F
        if major == 0:
            return self._read_uint(additional)
        if major == 1:
            return -1 - self._read_uint(additional)
        if major == 2:
            return self._take(self._read_uint(additional))
        if major == 3:
            return self._take(self._read_uint(additional)).decode("utf-8", errors="ignore")
        if major == 4:
            return [self.read() for _ in range(self._read_uint(additional))]
        if major == 5:
            size = self._read_uint(additional)
            out = {}
            for _ in range(size):
                key = self.read()
                out[key] = self.read()
            return out
        if major == 6:
            self._read_uint(additional)
            return self.read()
        if major == 7:
            if additional == 20:
                return False
            if additional == 21:
                return True
            if additional == 22:
                return None
        raise ValueError("unsupported cbor")

    def _read_uint(self, additional):
        if additional < 24:
            return additional
        if additional == 24:
            return self._take(1)[0]
        if additional == 25:
            return int.from_bytes(self._take(2), "big")
        if additional == 26:
            return int.from_bytes(self._take(4), "big")
        if additional == 27:
            return int.from_bytes(self._take(8), "big")
        raise ValueError("unsupported cbor uint")

    def _take(self, size):
        if self.pos + int(size) > len(self.data):
            raise ValueError("unexpected end of cbor")
        chunk = self.data[self.pos:self.pos + int(size)]
        self.pos += int(size)
        return chunk

def _decode_base64_urlsafe_no_padding(data):
    normalized = str(data or "").replace("-", "+").replace("_", "/")
    padding = (-len(normalized)) % 4
    if padding:
        normalized += "=" * padding
    return base64.b64decode(normalized)

def _little_endian_int(data):
    return int.from_bytes(bytes(data or b""), "little")

def _hitvpn_xor_payload(salt, payload):
    base = hashlib.sha256()
    base.update(HITVPN_WRAP_HASH_KEY)
    base.update(bytes(salt or b""))
    current = base.copy().digest()
    index = 0
    for i in range(len(payload)):
        if index >= len(current):
            base.update(current[:8])
            current = base.copy().digest()
            index = 0
        payload[i] ^= current[index]
        index += 1

def _decode_hitvpn_wrapped_payload(encoded):
    decoded = _decode_base64_urlsafe_no_padding(encoded)
    if len(decoded) < 32:
        raise ValueError("too short hitvpn link")
    if decoded[0] != HITVPN_WRAP_TAG:
        raise ValueError("invalid hitvpn tag")
    salt = decoded[1:5]
    hash_prefix = decoded[5:9]
    payload = bytearray(decoded[9:])
    if _little_endian_int(salt) != 0:
        _hitvpn_xor_payload(salt, payload)
    digest = hashlib.sha256(payload).digest()
    if digest[:4] != hash_prefix:
        raise ValueError("hitvpn hash mismatch")
    root = _MiniCborReader(payload).read()
    if not isinstance(root, dict):
        raise ValueError("hitvpn root is not a map")
    configs = []
    for item in list(root.get(4, []) or []):
        if not isinstance(item, dict):
            continue
        try:
            proto = int(item.get(1, 0))
        except:
            proto = 0
        cfg_data = item.get(2, b"")
        if not isinstance(cfg_data, (bytes, bytearray)):
            continue
        configs.append({"proto": proto, "cfg_data": bytes(cfg_data)})
    return {"vid": int(root.get(1, 0) or 0), "configs": configs}

def _decode_hitvpn_vless_cfg(cfg_data, vid):
    root = _MiniCborReader(cfg_data).read()
    if not isinstance(root, dict):
        raise ValueError("hitvpn vless cfg is not a map")
    return {
        "vid": int(vid or 0),
        "uuid": bytes(root.get(1, b"") or b""),
        "server_pub_key": bytes(root.get(2, b"") or b""),
        "server_ip4": int(root.get(3, 0) or 0),
        "server_port": int(root.get(4, 0) or 0),
        "type": int(root.get(5, 0) or 0),
        "security": int(root.get(6, 0) or 0),
        "sni": str(root.get(7, "") or ""),
    }

def _hitvpn_ip4_to_string(value):
    try:
        return str(socket.inet_ntoa(struct.pack("!I", int(value or 0))))
    except:
        return ""

def _hitvpn_uuid_bytes_to_string(value):
    try:
        hexed = bytes(value or b"").hex()
    except:
        hexed = ""
    if len(hexed) != 32:
        return hexed
    return "%s-%s-%s-%s-%s" % (hexed[0:8], hexed[8:12], hexed[12:16], hexed[16:20], hexed[20:32])

def _hitvpn_to_client_vless_uri(data):
    uuid_text = _hitvpn_uuid_bytes_to_string(data.get("uuid"))
    address = _hitvpn_ip4_to_string(data.get("server_ip4"))
    try:
        port = int(data.get("server_port", 0) or 0)
    except:
        port = 0
    if not uuid_text or not address or port <= 0:
        return ""
    network = "udp" if int(data.get("type", 0) or 0) == 1 else "tcp"
    security = "reality" if int(data.get("security", 0) or 0) != 0 else "none"
    try:
        pbk = base64.urlsafe_b64encode(bytes(data.get("server_pub_key", b"") or b"")).decode("ascii").rstrip("=")
    except:
        pbk = ""
    return (
        "vless://%s@%s:%s?type=%s&security=%s&pbk=%s&sni=%s&fp=random&sid=42&spx=%%2F&flow=xtls-rprx-vision"
        % (
            uuid_text, address, str(port),
            urllib.parse.quote(str(network), safe=""),
            urllib.parse.quote(str(security), safe=""),
            urllib.parse.quote(str(pbk), safe=""),
            urllib.parse.quote(str(data.get("sni", "") or ""), safe=""),
        )
    )

def _decode_hitvpn_link_to_vless_uris(value):
    try:
        cleaned = str(value or "").strip()
    except:
        cleaned = ""
    low = cleaned.lower()
    if not cleaned:
        return []
    if low.startswith("vless://"):
        return [cleaned]
    if low.startswith(HITVPN_LINK_PREFIX):
        encoded = cleaned[len(HITVPN_LINK_PREFIX):]
    elif low.startswith(HITRAY_LINK_PREFIX):
        encoded = cleaned[len(HITRAY_LINK_PREFIX):]
    elif low.startswith(HITVPN_SCHEME_PREFIX):
        encoded = cleaned[len(HITVPN_SCHEME_PREFIX):]
    else:
        return []
    wrapped = _decode_hitvpn_wrapped_payload(encoded)
    results = []
    seen = set()
    for cfg in list(wrapped.get("configs", []) or []):
        try:
            if int(cfg.get("proto", 0) or 0) != HITVPN_PROTO_VLESS:
                continue
            generated = _hitvpn_to_client_vless_uri(_decode_hitvpn_vless_cfg(cfg.get("cfg_data", b""), wrapped.get("vid", 0)))
        except:
            generated = ""
        if not generated or generated in seen:
            continue
        seen.add(generated)
        results.append(generated)
    return results

def _subscription_request_headers(url):
    try:
        host = str(urllib.parse.urlparse(str(url or "")).netloc or "").strip()
    except:
        host = ""
    headers = {
        "Accept-Encoding": "gzip",
        "Connection": "close",
        "User-Agent": SUBSCRIPTION_USER_AGENT,
        "X-Device-Locale": "en",
        "X-Device-model": _device_model_header(),
        "X-Device-OS": "Android",
        "X-HWID": str(_get_or_create_hwid() or ""),
        "X-Ver-OS": _device_os_version_header(),
    }
    if host:
        headers["Host"] = host
    return headers

def _subscription_candidate_urls(url):
    try:
        target = str(url or "").strip()
    except:
        target = ""
    if not target:
        return []
    urls = [target]
    try:
        parsed = urllib.parse.urlparse(target)
        host = str(parsed.netloc or "").strip().lower()
        parts = [part for part in str(parsed.path or "").split("/") if part]
        if host == "raw.githubusercontent.com" and len(parts) >= 5 and parts[2] == "refs" and parts[3] == "heads":
            repo_owner = str(parts[0] or "").strip()
            repo_name = str(parts[1] or "").strip()
            branch_name = str(parts[4] or "").strip()
            tail_parts = list(parts[5:])
            canonical_path = "/" + "/".join([parts[0], parts[1], parts[4]] + parts[5:])
            canonical = urllib.parse.urlunparse((parsed.scheme or "https", parsed.netloc, canonical_path, "", parsed.query or "", ""))
            if canonical and canonical not in urls:
                urls.append(canonical)
            if repo_owner and repo_name and branch_name:
                jsd_path = "/gh/" + "/".join([repo_owner, repo_name + "@" + branch_name] + tail_parts)
                for jsd_host in ("cdn.jsdelivr.net", "gcore.jsdelivr.net", "fastly.jsdelivr.net"):
                    jsd = urllib.parse.urlunparse(("https", jsd_host, jsd_path, "", parsed.query or "", ""))
                    if jsd and jsd not in urls:
                        urls.append(jsd)
    except:
        pass
    return urls

def _decode_subscription_body(raw, encoding=""):
    data = bytes(raw or b"")
    enc = str(encoding or "").lower().strip()
    if data[:2] == b"\x1f\x8b" or "gzip" in enc:
        try:
            data = gzip.decompress(data)
        except:
            pass
    try:
        return data.decode("utf-8")
    except:
        return data.decode("utf-8", errors="ignore")

def _set_vless_fetch_diag(url, **kwargs):
    global _LAST_VLESS_FETCH_DIAG
    try:
        key = str(url or "").strip()
    except:
        key = ""
    if not key:
        return
    try:
        payload = dict(kwargs or {})
    except:
        payload = {}
    payload["url"] = key
    _LAST_VLESS_FETCH_DIAG[key] = payload

def _fetch_text_url_java(url, headers=None, timeout_sec=15.0):
    try:
        from java.net import URL
    except Exception:
        return None
    conn = None
    try:
        conn = URL(str(url or "")).openConnection()
        try:
            conn.setInstanceFollowRedirects(True)
        except Exception:
            pass
        try:
            ms = int(max(float(timeout_sec), 5.0) * 1000)
            conn.setConnectTimeout(ms)
            conn.setReadTimeout(ms)
        except Exception:
            pass
        hdrs = dict(headers or {})
        hdrs.setdefault("User-Agent", SUBSCRIPTION_USER_AGENT)
        for k, v in hdrs.items():
            if str(k).lower() in ("accept-encoding", "host", "connection"):
                continue
            try:
                conn.setRequestProperty(str(k), str(v))
            except Exception:
                pass
        try:
            code = int(conn.getResponseCode())
        except Exception:
            code = 0
        title = ""
        try:
            for hn in ("profile-title", "Profile-Title", "profile-web-page-url"):
                hv = conn.getHeaderField(hn)
                if hv:
                    title = _decode_sub_title(hv)
                    if title:
                        break
            if not title:
                cd = conn.getHeaderField("Content-Disposition")
                if cd:
                    m = re.search(r"filename\*?=(?:UTF-8'')?([^;]+)", str(cd), re.IGNORECASE)
                    if m:
                        title = _decode_sub_title(urllib.parse.unquote(m.group(1)))
        except Exception:
            title = ""
        stream = None
        try:
            stream = conn.getInputStream()
        except Exception:
            try:
                stream = conn.getErrorStream()
            except Exception:
                stream = None
        if stream is None or code <= 0 or code >= 400:
            return None, ""
        chunks = bytearray()
        buf = bytearray(8192)
        while True:
            try:
                n = int(stream.read(buf))
            except Exception:
                break
            if n <= 0:
                break
            chunks.extend(bytes(buf[:n]))
        try:
            stream.close()
        except Exception:
            pass
        if not chunks:
            return None, ""
        if len(chunks) >= 2 and chunks[0] == 0x1f and chunks[1] == 0x8b:
            try:
                chunks = bytearray(gzip.decompress(bytes(chunks)))
            except Exception:
                pass
        try:
            return bytes(chunks).decode("utf-8"), title
        except Exception:
            return bytes(chunks).decode("utf-8", errors="ignore"), title
    except Exception as e:
        _safe_log(f"java fetch failed for {url}: {e}")
        return None, ""
    finally:
        try:
            if conn is not None:
                conn.disconnect()
        except Exception:
            pass

def _fetch_text_url(url, timeout_sec=15.0):
    try:
        base_timeout = max(float(timeout_sec), 15.0)
    except:
        base_timeout = 15.0
    timeouts = []
    for item in (base_timeout, max(base_timeout, 30.0), max(base_timeout, 45.0)):
        try:
            value = float(item)
        except:
            continue
        if value not in timeouts:
            timeouts.append(value)
    errors = []
    candidate_urls = _subscription_candidate_urls(url)
    for candidate_url in candidate_urls:
        headers = _subscription_request_headers(candidate_url)
        try:
            jtext, jtitle = _fetch_text_url_java(candidate_url, headers=headers, timeout_sec=base_timeout)
        except Exception:
            jtext, jtitle = None, ""
        if jtext:
            if jtitle:
                _LAST_SUB_TITLE[str(url or "")] = jtitle
            _set_vless_fetch_diag(url, stage="fetched", via="java", fetched_url=str(candidate_url or ""), tried=len(candidate_urls))
            _log(f"sub fetch ok via java: {len(jtext)} bytes from {candidate_url}")
            return jtext
        for current_timeout in list(timeouts or [15.0]):
            try:
                req = urllib.request.Request(str(candidate_url or ""), headers=headers)
                ctx = ssl.create_default_context()
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
                with urllib.request.urlopen(req, timeout=float(current_timeout), context=ctx) as resp:
                    raw = resp.read()
                    try:
                        encoding = str(resp.headers.get("Content-Encoding", "") or "")
                    except:
                        encoding = ""
                    text = _decode_subscription_body(raw, encoding=encoding)
                    if text:
                        try:
                            t = _decode_sub_title(resp.headers.get("profile-title", "") or "")
                            if not t:
                                cd = resp.headers.get("Content-Disposition", "") or ""
                                m = re.search(r"filename\*?=(?:UTF-8'')?([^;]+)", str(cd), re.IGNORECASE)
                                if m:
                                    t = _decode_sub_title(urllib.parse.unquote(m.group(1)))
                            if t:
                                _LAST_SUB_TITLE[str(url or "")] = t
                        except Exception:
                            pass
                        _set_vless_fetch_diag(url, stage="fetched", fetched_url=str(candidate_url or ""), timeout=float(current_timeout), tried=len(candidate_urls), errors=" | ".join(list(errors or [])[:4]))
                        return text
            except Exception as e:
                try:
                    host = str(urllib.parse.urlparse(str(candidate_url or "")).netloc or "").strip()
                except:
                    host = ""
                err = "urllib@%s:%s" % (host or "?", str(type(e).__name__))
                if err not in errors:
                    errors.append(err)
            try:
                r = requests.get(str(candidate_url or ""), timeout=float(current_timeout), verify=False, headers=headers)
                if int(getattr(r, "status_code", 0) or 0) == 200:
                    raw = getattr(r, "content", b"") or b""
                    encoding = str(getattr(getattr(r, "headers", {}), "get", lambda *a, **k: "")("Content-Encoding", "") or "")
                    text = _decode_subscription_body(raw, encoding=encoding)
                    if text:
                        _set_vless_fetch_diag(url, stage="fetched", fetched_url=str(candidate_url or ""), timeout=float(current_timeout), tried=len(candidate_urls), errors=" | ".join(list(errors or [])[:4]))
                        return text
            except Exception as e:
                try:
                    host = str(urllib.parse.urlparse(str(candidate_url or "")).netloc or "").strip()
                except:
                    host = ""
                err = "requests@%s:%s" % (host or "?", str(type(e).__name__))
                if err not in errors:
                    errors.append(err)
    _set_vless_fetch_diag(url, stage="fetch_failed", fetched_url="", timeout=float(timeouts[-1] if timeouts else 0.0), tried=len(candidate_urls), errors=" | ".join(list(errors or [])[:4]))
    return ""

def _log(msg): log(f"[exitfy] {msg}")

def _dlog(msg):
    if EXITFY_VERBOSE:
        _log(msg)

class VlessConfigParser:


    @staticmethod
    def _truthy(v):
        return str(v or "").strip().lower() in ("1", "true", "yes", "on")

    @staticmethod
    def _alpn_list(raw):
        try:
            return [p.strip() for p in str(raw or "").split(",") if p.strip()]
        except Exception:
            return []

    @staticmethod
    def _singbox_inbound(local_port, socks_user=None, socks_pass=None):
        inbound = {
            "type": "mixed",
            "tag": "socks-in",
            "listen": VLESS_LOCAL_HOST,
            "listen_port": int(local_port),
        }
        if socks_user and socks_pass:
            inbound["users"] = [{"username": str(socks_user), "password": str(socks_pass)}]
        return inbound

    @staticmethod
    def _singbox_tls(params, default_sni=""):
        security = str(params.get("security", "") or "").strip().lower()
        sni = params.get("sni", "") or params.get("peer", "") or default_sni
        if security not in ("tls", "reality", "xtls"):
            if not security:
                return None
        tls = {
            "enabled": True,
            "server_name": str(sni or ""),
            "insecure": VlessConfigParser._truthy(params.get("insecure", params.get("allowInsecure", "0"))),
        }
        alpn = VlessConfigParser._alpn_list(params.get("alpn", ""))
        if alpn:
            tls["alpn"] = alpn
        fp = str(params.get("fp", "") or "").strip()
        if fp:
            tls["utls"] = {"enabled": True, "fingerprint": fp}
        if security == "reality":
            tls["reality"] = {
                "enabled": True,
                "public_key": str(params.get("pbk", "") or ""),
                "short_id": str(params.get("sid", "") or ""),
            }
            tls.setdefault("utls", {"enabled": True, "fingerprint": fp or "chrome"})
        return tls

    @staticmethod
    def _singbox_transport(params):
        net = str(params.get("type", "tcp") or "tcp").strip().lower()
        host = params.get("host", "") or params.get("sni", "")
        path = params.get("path", "/") or "/"
        if net == "ws":
            tr = {"type": "ws", "path": path}
            if host:
                tr["headers"] = {"Host": str(host)}
            ed = params.get("ed", "")
            if str(ed or "").strip().isdigit():
                tr["max_early_data"] = int(ed)
                tr["early_data_header_name"] = "Sec-WebSocket-Protocol"
            return tr
        if net == "grpc":
            return {"type": "grpc", "service_name": str(params.get("serviceName", params.get("path", "")) or "")}
        if net in ("http", "h2"):
            tr = {"type": "http", "path": path}
            if host:
                tr["host"] = [str(host)]
            return tr
        if net == "httpupgrade":
            tr = {"type": "httpupgrade", "path": path}
            if host:
                tr["host"] = str(host)
            return tr
        return None

    @staticmethod
    def _apply_stream(outbound, params, default_sni=""):
        tls = VlessConfigParser._singbox_tls(params, default_sni=default_sni)
        if tls:
            outbound["tls"] = tls
        transport = VlessConfigParser._singbox_transport(params)
        if transport:
            outbound["transport"] = transport
        return outbound

    @staticmethod
    def _wrap(outbound, local_port, socks_user=None, socks_pass=None):
        if not outbound:
            return None
        outbound["tag"] = "proxy"
        config = {
            "log": {"level": "panic"},
            "dns": SINGBOX_DNS,
            "inbounds": [VlessConfigParser._singbox_inbound(local_port, socks_user, socks_pass)],
            "outbounds": [
                outbound,
                {"type": "direct", "tag": "direct"},
            ],
            "route": {"final": "proxy"},
        }
        return config


    @staticmethod
    def parse_balancer(uris, local_port, socks_user=None, socks_pass=None):
        if not uris:
            return None, []
        outbounds = []
        names = []
        tags = []
        for i, uri in enumerate(uris):
            outb, name = VlessConfigParser._build_outbound(uri)
            if not outb:
                continue
            tag = f"proxy-{i}"
            outb["tag"] = tag
            outbounds.append(outb)
            tags.append(tag)
            names.append(name)
        if not tags:
            return None, []
        outbounds.append({
            "type": "urltest",
            "tag": "auto",
            "outbounds": list(tags),
            "url": "https://www.gstatic.com/generate_204",
            "interval": "10s",
            "tolerance": 50,
        })
        outbounds.append({"type": "direct", "tag": "direct"})
        config = {
            "log": {"level": "panic"},
            "dns": SINGBOX_DNS,
            "inbounds": [VlessConfigParser._singbox_inbound(local_port, socks_user, socks_pass)],
            "outbounds": outbounds,
            "route": {"final": "auto"},
        }
        return json.dumps(config), names

    @staticmethod
    def _parse_std_uri(uri_str):
        name = Z("vless_node_default")
        if "#" in uri_str:
            uri_str, frag = uri_str.split("#", 1)
            name = _clean_vless_name(frag)
            if not name:
                name = Z("vless_node_default")
        scheme_end = uri_str.find("://")
        if scheme_end < 0:
            return None
        body = uri_str[scheme_end + 3:]
        if "@" not in body:
            return None
        user_info, rest = body.split("@", 1)
        if "?" in rest:
            host_port, params_raw = rest.split("?", 1)
        else:
            host_port, params_raw = rest, ""
        host_port = str(host_port).strip().rstrip("/")
        if ":" not in host_port:
            return None
        host, port_str = host_port.split(":", 1)
        try:
            port = int(str(port_str).strip())
        except:
            return None
        params = {}
        if params_raw:
            for pair in params_raw.split("&"):
                if "=" in pair:
                    k, v = pair.split("=", 1)
                    params[k] = urllib.parse.unquote(v)
        return {"user": user_info, "host": host, "port": port, "params": params, "name": name}

    @staticmethod
    def parse(uri_str, local_port, socks_user=None, socks_pass=None):
        try:
            outbound, name = VlessConfigParser._build_outbound(uri_str)
            if not outbound:
                return None, None
            config = VlessConfigParser._wrap(outbound, local_port,
                                             socks_user=socks_user, socks_pass=socks_pass)
            if not config:
                return None, None
            return json.dumps(config), name
        except Exception as e:
            _log(f"config parse error: {e}")
            return None, None

    @staticmethod
    def _build_outbound(uri_str):
        try:
            uri_str = _sanitize_vless_uri(uri_str)
            low = uri_str.lower()
            if low.startswith("vless://"):
                return VlessConfigParser._outbound_vless(uri_str)
            if low.startswith("vmess://"):
                return VlessConfigParser._outbound_vmess(uri_str)
            if low.startswith("trojan://"):
                return VlessConfigParser._outbound_trojan(uri_str)
            if low.startswith("ss://"):
                return VlessConfigParser._outbound_ss(uri_str)
            if low.startswith("hy2://") or low.startswith("hysteria2://"):
                return VlessConfigParser._outbound_hysteria2(uri_str)
            if low.startswith("hysteria://"):
                return VlessConfigParser._outbound_hysteria(uri_str)
            if low.startswith("tuic://"):
                return VlessConfigParser._outbound_tuic(uri_str)
            return None, None
        except Exception as e:
            _log(f"outbound build error: {e}")
            return None, None

    @staticmethod
    def _outbound_vless(uri_str):
        r = VlessConfigParser._parse_std_uri(uri_str)
        if not r:
            return None, None
        params = r["params"]
        outbound = {
            "type": "vless",
            "server": r["host"],
            "server_port": int(r["port"]),
            "uuid": str(r["user"]),
            "packet_encoding": str(params.get("packetEncoding", "xudp") or "xudp"),
        }
        flow = str(params.get("flow", "") or "").strip()
        if flow:
            outbound["flow"] = flow
        VlessConfigParser._apply_stream(outbound, params, default_sni=r["host"])
        return outbound, r["name"]

    @staticmethod
    def _outbound_vmess(uri_str):
        try:
            b64_part = uri_str[8:]
            if "#" in b64_part:
                b64_part = b64_part.split("#", 1)[0]
            b64_part = b64_part.strip().replace("-", "+").replace("_", "/")
            missing = len(b64_part) % 4
            if missing:
                b64_part += "=" * (4 - missing)
            raw = base64.b64decode(b64_part, validate=False)
            obj = json.loads(raw.decode("utf-8", errors="ignore"))
        except Exception:
            return None, None
        name = _clean_vless_name(obj.get("ps", "")) or Z("vless_node_default")
        host = obj.get("add", "")
        try:
            port = int(obj.get("port", 0))
        except Exception:
            return None, None
        if not host or not port:
            return None, None
        outbound = {
            "type": "vmess",
            "server": host,
            "server_port": int(port),
            "uuid": str(obj.get("id", "")),
            "alter_id": _to_int(obj.get("aid", 0), 0),
            "security": str(obj.get("scy", "auto") or "auto"),
        }
        host_val = obj.get("host", "") or ""
        sni = obj.get("sni", "") or host_val
        params = {
            "type": obj.get("net", "tcp") or "tcp",
            "security": "tls" if str(obj.get("tls", "")) == "tls" else "",
            "sni": sni,
            "fp": obj.get("fp", "") or "",
            "alpn": obj.get("alpn", "") or "",
            "path": obj.get("path", "/") or "/",
            "host": host_val or sni,
            "serviceName": obj.get("path", ""),
        }
        VlessConfigParser._apply_stream(outbound, params, default_sni=host)
        return outbound, name

    @staticmethod
    def _outbound_trojan(uri_str):
        r = VlessConfigParser._parse_std_uri(uri_str)
        if not r:
            return None, None
        params = r["params"]
        if not params.get("security"):
            params["security"] = "tls"
        if not params.get("sni"):
            params["sni"] = r["host"]
        outbound = {
            "type": "trojan",
            "server": r["host"],
            "server_port": int(r["port"]),
            "password": urllib.parse.unquote(str(r["user"])),
        }
        VlessConfigParser._apply_stream(outbound, params, default_sni=r["host"])
        return outbound, r["name"]

    @staticmethod
    def _outbound_ss(uri_str):
        try:
            body = uri_str[5:]
            name = Z("vless_node_default")
            if "#" in body:
                body, frag = body.split("#", 1)
                name = _clean_vless_name(frag) or Z("vless_node_default")
            body = body.strip()
            method = password = host = ""
            port = 0
            if "@" in body:
                user_part, server_part = body.split("@", 1)
                server_part = server_part.split("?", 1)[0].strip().rstrip("/")
                try:
                    up = user_part.replace("-", "+").replace("_", "/")
                    miss = len(up) % 4
                    if miss:
                        up += "=" * (4 - miss)
                    decoded = base64.b64decode(up, validate=False).decode("utf-8", errors="ignore")
                    if ":" in decoded:
                        method, password = decoded.split(":", 1)
                    else:
                        method = decoded
                except Exception:
                    if ":" in user_part:
                        method, password = user_part.split(":", 1)
                    else:
                        return None, None
                if ":" not in server_part:
                    return None, None
                host, port_str = server_part.rsplit(":", 1)
                port = int(port_str)
            else:
                try:
                    b64 = body.replace("-", "+").replace("_", "/")
                    miss = len(b64) % 4
                    if miss:
                        b64 += "=" * (4 - miss)
                    decoded = base64.b64decode(b64, validate=False).decode("utf-8", errors="ignore")
                    if "@" not in decoded or ":" not in decoded:
                        return None, None
                    user_part, server_part = decoded.split("@", 1)
                    if ":" in user_part:
                        method, password = user_part.split(":", 1)
                    if ":" in server_part:
                        host, port_str = server_part.rsplit(":", 1)
                        port = int(port_str)
                except Exception:
                    return None, None
            if not method or not password or not host or not port:
                return None, None
            outbound = {
                "type": "shadowsocks",
                "server": host,
                "server_port": int(port),
                "method": method,
                "password": password,
            }
            return outbound, name
        except Exception:
            return None, None

    @staticmethod
    def _hysteria_password(r):
        user = urllib.parse.unquote(str(r.get("user", "") or ""))
        if ":" in user:
            try:
                return user.split(":", 1)[1].strip()
            except Exception:
                return user.strip()
        return user.strip()

    @staticmethod
    def _outbound_hysteria2(uri_str):
        try:
            r = VlessConfigParser._parse_std_uri(uri_str)
            if not r:
                return None, None
            params = r["params"]
            password = VlessConfigParser._hysteria_password(r)
            if not password:
                return None, None
            tls = {
                "enabled": True,
                "server_name": str(params.get("sni", r.get("host", "")) or r.get("host", "")),
                "insecure": VlessConfigParser._truthy(params.get("insecure", "0")),
            }
            alpn = VlessConfigParser._alpn_list(params.get("alpn", ""))
            if alpn:
                tls["alpn"] = alpn
            outbound = {
                "type": "hysteria2",
                "server": r["host"],
                "server_port": int(r["port"]),
                "password": password,
                "tls": tls,
            }
            obfs_pw = str(params.get("obfs-password", "") or "")
            if str(params.get("obfs", "") or "").strip().lower() == "salamander" and obfs_pw:
                outbound["obfs"] = {"type": "salamander", "password": obfs_pw}
            return outbound, r.get("name")
        except Exception:
            return None, None

    @staticmethod
    def _parse_url_uri(uri_str):
        try:
            name = Z("vless_node_default")
            work = uri_str
            if "#" in work:
                work, frag = work.split("#", 1)
                name = _clean_vless_name(frag) or Z("vless_node_default")
            sp = urllib.parse.urlsplit(work)
            host = sp.hostname or ""
            port = sp.port or 0
            if not host or not port:
                return None
            params = {}
            for k, v in urllib.parse.parse_qsl(sp.query, keep_blank_values=True):
                params[k] = v
            user = sp.username or ""
            if sp.password is not None:
                user = f"{user}:{sp.password}"
            return {"user": user, "host": host, "port": int(port), "params": params, "name": name}
        except Exception:
            return None

    @staticmethod
    def _outbound_hysteria(uri_str):
        try:
            r = VlessConfigParser._parse_url_uri(uri_str)
            if not r:
                return None, None
            params = r["params"]
            tls = {
                "enabled": True,
                "server_name": str(params.get("peer", params.get("sni", r.get("host", ""))) or r.get("host", "")),
                "insecure": VlessConfigParser._truthy(params.get("insecure", "0")),
            }
            alpn = VlessConfigParser._alpn_list(params.get("alpn", "")) or ["h3"]
            tls["alpn"] = alpn
            outbound = {
                "type": "hysteria",
                "server": r["host"],
                "server_port": int(r["port"]),
                "tls": tls,
            }
            auth = str(params.get("auth", params.get("auth_str", "")) or "")
            if auth:
                outbound["auth_str"] = auth
            up = str(params.get("upmbps", params.get("up", "")) or "")
            down = str(params.get("downmbps", params.get("down", "")) or "")
            if up:
                outbound["up_mbps"] = _to_int(re.sub(r"[^0-9]", "", up) or 0, 0) or 50
            if down:
                outbound["down_mbps"] = _to_int(re.sub(r"[^0-9]", "", down) or 0, 0) or 100
            obfs = str(params.get("obfs", "") or "")
            if obfs:
                outbound["obfs"] = obfs
            return outbound, r.get("name")
        except Exception:
            return None, None

    @staticmethod
    def _outbound_tuic(uri_str):
        try:
            r = VlessConfigParser._parse_std_uri(uri_str)
            if not r:
                return None, None
            params = r["params"]
            user = urllib.parse.unquote(str(r.get("user", "") or ""))
            if ":" in user:
                uuid_str, password = user.split(":", 1)
            else:
                uuid_str, password = user, ""
            uuid_str = uuid_str.strip()
            if not uuid_str:
                return None, None
            tls = {
                "enabled": True,
                "server_name": str(params.get("sni", r.get("host", "")) or r.get("host", "")),
                "insecure": VlessConfigParser._truthy(params.get("allow_insecure", params.get("insecure", "0"))),
            }
            alpn = VlessConfigParser._alpn_list(params.get("alpn", "")) or ["h3"]
            tls["alpn"] = alpn
            outbound = {
                "type": "tuic",
                "server": r["host"],
                "server_port": int(r["port"]),
                "uuid": uuid_str,
                "password": password,
                "congestion_control": str(params.get("congestion_control", "bbr") or "bbr"),
                "udp_relay_mode": str(params.get("udp_relay_mode", "native") or "native"),
                "tls": tls,
            }
            return outbound, r.get("name")
        except Exception:
            return None, None

class XrayConfigParser:
    @staticmethod
    def _build_stream(params):
        net = params.get("type", "tcp")
        security = params.get("security", "none")
        fp = params.get("fp", "chrome")
        stream = {"network": net, "security": security}
        if security == "reality":
            stream["realitySettings"] = {
                "show": False, "fingerprint": fp,
                "serverName": params.get("sni", ""),
                "publicKey": params.get("pbk", ""),
                "shortId": params.get("sid", ""),
                "spiderX": params.get("spx", ""),
            }
        elif security == "tls":
            tls = {"serverName": params.get("sni", ""), "allowInsecure": False, "fingerprint": fp}
            alpn = params.get("alpn", "")
            if alpn:
                try:
                    tls["alpn"] = str(alpn).split(",")
                except:
                    pass
            stream["tlsSettings"] = tls
        try:
            if "packetEncoding" not in stream:
                stream["packetEncoding"] = str(params.get("packetEncoding", "xudp"))
        except:
            pass
        if net == "ws":
            stream["wsSettings"] = {"path": params.get("path", "/"),
                                     "headers": {"Host": params.get("host", params.get("sni", ""))}}
        elif net == "grpc":
            stream["grpcSettings"] = {"serviceName": params.get("serviceName", ""),
                                       "multiMode": params.get("mode", "multi") == "multi"}
        elif net in ("h2", "http"):
            host = params.get("host", params.get("sni", ""))
            stream["httpSettings"] = {"path": params.get("path", "/"),
                                       "host": [host] if host else []}
        elif net in ("kcp", "mkcp"):
            stream["kcpSettings"] = {"header": {"type": params.get("headerType", "none")},
                                      "seed": params.get("seed", "")}
        elif net in ("xhttp", "splithttp"):
            stream["xhttpSettings"] = {"path": params.get("path", "/"),
                                        "host": params.get("host", params.get("sni", ""))}
        elif net == "httpupgrade":
            stream["httpupgradeSettings"] = {"path": params.get("path", "/"),
                                              "host": params.get("host", params.get("sni", ""))}
        return stream

    @staticmethod
    def _base_config(local_port, socks_user=None, socks_pass=None):
        if socks_user and socks_pass:
            socks_settings = {
                "auth": "password",
                "accounts": [{"user": socks_user, "pass": socks_pass}],
                "udp": True,
                "ip": VLESS_LOCAL_HOST,
            }
        else:
            socks_settings = {"auth": "noauth", "udp": True, "ip": VLESS_LOCAL_HOST}
        return {
            "log": {"loglevel": "none"},
            "inbounds": [{"tag": "socks-in", "port": local_port, "listen": VLESS_LOCAL_HOST,
                          "protocol": "socks",
                          "settings": socks_settings,
                          "sniffing": {"enabled": True, "destOverride": ["http", "tls"], "routeOnly": False}}],
            "outbounds": [{"tag": "proxy"}],
        }

    @staticmethod
    def parse_balancer(uris, local_port, socks_user=None, socks_pass=None):
        if not uris: return None, []
        config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
        names = []
        tags = []
        config["outbounds"] = []
        for i, uri in enumerate(uris):
            cfg_str, name = XrayConfigParser.parse(uri, local_port, socks_user=socks_user, socks_pass=socks_pass)
            if cfg_str:
                try:
                    obj = json.loads(cfg_str)
                    outb = obj["outbounds"][0]
                except Exception:
                    continue
                try:
                    if str(outb.get("protocol", "") or "").strip().lower() == "shadowsocks":
                        servers = ((outb.get("settings") or {}).get("servers") or [])
                        pw = ""
                        try:
                            if servers and isinstance(servers[0], dict):
                                pw = str(servers[0].get("password", "") or "")
                        except Exception:
                            pw = ""
                        if not pw.strip():
                            continue
                except Exception:
                    pass
                tag = f"proxy-{i}"
                outb["tag"] = tag
                config["outbounds"].append(outb)
                tags.append(tag)
                names.append(name)
        if not tags: return None, []
        config["observatory"] = {
            "subjectSelector": tags,
            "probeUrl": "https://www.google.com/generate_204",
            "probeInterval": "15s",
            "enableConcurrent": True
        }
        config["routing"] = {
            "domainStrategy": "AsIs",
            "balancers": [{"tag": "lb", "selector": tags, "strategy": {"type": "leastPing"}}],
            "rules": [{"type": "field", "network": "tcp,udp", "balancerTag": "lb"}]
        }
        return json.dumps(config), names

    @staticmethod
    def _parse_std_uri(uri_str):
        name = Z("vless_node_default")
        if "#" in uri_str:
            uri_str, frag = uri_str.split("#", 1)
            name = _clean_vless_name(frag)
            if not name:
                name = Z("vless_node_default")
        scheme_end = uri_str.find("://")
        if scheme_end < 0:
            return None
        body = uri_str[scheme_end + 3:]
        if "@" not in body:
            return None
        user_info, rest = body.split("@", 1)
        if "?" in rest:
            host_port, params_raw = rest.split("?", 1)
        else:
            host_port, params_raw = rest, ""
        host_port = str(host_port).strip().rstrip("/")
        if ":" not in host_port:
            return None
        host, port_str = host_port.split(":", 1)
        try:
            port = int(str(port_str).strip())
        except:
            return None
        params = {}
        if params_raw:
            for pair in params_raw.split("&"):
                if "=" in pair:
                    k, v = pair.split("=", 1)
                    params[k] = urllib.parse.unquote(v)
        return {"user": user_info, "host": host, "port": port, "params": params, "name": name}

    @staticmethod
    def parse(uri_str, local_port, socks_user=None, socks_pass=None):
        try:
            uri_str = _sanitize_vless_uri(uri_str)
            if uri_str.startswith("vless://"):
                return XrayConfigParser._parse_vless(uri_str, local_port, socks_user=socks_user, socks_pass=socks_pass)
            if uri_str.startswith("vmess://"):
                return XrayConfigParser._parse_vmess(uri_str, local_port, socks_user=socks_user, socks_pass=socks_pass)
            if uri_str.startswith("trojan://"):
                return XrayConfigParser._parse_trojan(uri_str, local_port, socks_user=socks_user, socks_pass=socks_pass)
            if uri_str.startswith("ss://"):
                return XrayConfigParser._parse_ss(uri_str, local_port, socks_user=socks_user, socks_pass=socks_pass)
            if uri_str.startswith("hy2://") or uri_str.startswith("hysteria2://"):
                return XrayConfigParser._parse_hysteria2(uri_str, local_port, socks_user=socks_user, socks_pass=socks_pass)
            return None, None
        except Exception as e:
            _log(f"config parse error: {e}"); return None, None

    @staticmethod
    def _parse_hysteria2(uri_str, local_port, socks_user=None, socks_pass=None):
        try:
            r = XrayConfigParser._parse_std_uri(uri_str)
            if not r:
                return None, None
            params = r["params"]
            user = str(r.get("user", "") or "")
            password = user
            if ":" in user:
                try:
                    password = user.split(":", 1)[1]
                except Exception:
                    password = user
            password = str(password or "").strip()
            if not password:
                return None, None
            tls = {
                "allowInsecure": str(params.get("insecure", "0")) in ("1", "true", "yes"),
                "serverName": params.get("sni", r.get("host", "")),
            }
            try:
                if params.get("alpn"):
                    tls["alpn"] = [p.strip() for p in str(params.get("alpn", "") or "").split(",") if p.strip()]
            except Exception:
                pass
            config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
            config["outbounds"][0].update({
                "protocol": "hysteria2",
                "settings": {"servers": [{"address": r["host"], "port": int(r["port"]), "password": password}]},
                "streamSettings": {"network": "udp", "security": "tls", "tlsSettings": tls},
            })
            return json.dumps(config), r.get("name")
        except Exception:
            return None, None

    @staticmethod
    def _parse_vless(uri_str, local_port, socks_user=None, socks_pass=None):
        r = XrayConfigParser._parse_std_uri(uri_str)
        if not r:
            return None, None
        uuid_str = r["user"]
        params = r["params"]
        flow = params.get("flow", "")
        users = [{"id": uuid_str, "encryption": "none"}]
        if flow:
            users[0]["flow"] = flow
        config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
        config["outbounds"][0].update({
            "protocol": "vless",
            "settings": {"vnext": [{"address": r["host"], "port": r["port"], "users": users}]},
            "streamSettings": XrayConfigParser._build_stream(params),
        })
        return json.dumps(config), r["name"]

    @staticmethod
    def _parse_vmess(uri_str, local_port, socks_user=None, socks_pass=None):
        try:
            b64_part = uri_str[8:]
            if "#" in b64_part:
                b64_part = b64_part.split("#", 1)[0]
            b64_part = b64_part.strip().replace("-", "+").replace("_", "/")
            missing = len(b64_part) % 4
            if missing:
                b64_part += "=" * (4 - missing)
            raw = base64.b64decode(b64_part, validate=False)
            obj = json.loads(raw.decode("utf-8", errors="ignore"))
        except Exception:
            return None, None
        name = _clean_vless_name(obj.get("ps", "")) or Z("vless_node_default")
        host = obj.get("add", "")
        try:
            port = int(obj.get("port", 0))
        except:
            return None, None
        if not host or not port:
            return None, None
        uuid_str = obj.get("id", "")
        aid = _to_int(obj.get("aid", 0), 0)
        scy = obj.get("scy", "auto") or "auto"
        users = [{"id": uuid_str, "alterId": aid, "security": scy}]
        net = obj.get("net", "tcp") or "tcp"
        tls_val = obj.get("tls", "") or ""
        sni = obj.get("sni", "") or ""
        fp_val = obj.get("fp", "chrome") or "chrome"
        alpn_val = obj.get("alpn", "") or ""
        path_val = obj.get("path", "/") or "/"
        host_val = obj.get("host", "") or ""
        header_type = obj.get("type", "none") or "none"
        params = {
            "type": net,
            "security": "tls" if tls_val == "tls" else "none",
            "sni": sni or host_val,
            "fp": fp_val,
            "alpn": alpn_val,
            "path": path_val,
            "host": host_val or sni,
            "headerType": header_type,
            "serviceName": obj.get("path", ""),
            "seed": obj.get("path", ""),
        }
        config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
        config["outbounds"][0].update({
            "protocol": "vmess",
            "settings": {"vnext": [{"address": host, "port": port, "users": users}]},
            "streamSettings": XrayConfigParser._build_stream(params),
        })
        return json.dumps(config), name

    @staticmethod
    def _parse_trojan(uri_str, local_port, socks_user=None, socks_pass=None):
        r = XrayConfigParser._parse_std_uri(uri_str)
        if not r:
            return None, None
        password = urllib.parse.unquote(r["user"])
        params = r["params"]
        if not params.get("security"):
            params["security"] = "tls"
        if not params.get("sni"):
            params["sni"] = r["host"]
        config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
        config["outbounds"][0].update({
            "protocol": "trojan",
            "settings": {"servers": [{"address": r["host"], "port": r["port"], "password": password}]},
            "streamSettings": XrayConfigParser._build_stream(params),
        })
        return json.dumps(config), r["name"]

    @staticmethod
    def _parse_ss(uri_str, local_port, socks_user=None, socks_pass=None):
        try:
            body = uri_str[5:]
            name = Z("vless_node_default")
            if "#" in body:
                body, frag = body.split("#", 1)
                name = _clean_vless_name(frag) or Z("vless_node_default")
            body = body.strip()
            method = ""
            password = ""
            host = ""
            port = 0
            if "@" in body:
                user_part, server_part = body.split("@", 1)
                server_part = server_part.split("?", 1)[0].strip().rstrip("/")
                try:
                    user_part = user_part.replace("-", "+").replace("_", "/")
                    miss = len(user_part) % 4
                    if miss:
                        user_part += "=" * (4 - miss)
                    decoded = base64.b64decode(user_part, validate=False).decode("utf-8", errors="ignore")
                    if ":" in decoded:
                        method, password = decoded.split(":", 1)
                    else:
                        method = decoded
                except:
                    if ":" in user_part:
                        method, password = user_part.split(":", 1)
                    else:
                        return None, None
                if ":" not in server_part:
                    return None, None
                host, port_str = server_part.rsplit(":", 1)
                port = int(port_str)
            else:
                try:
                    b64 = body.replace("-", "+").replace("_", "/")
                    miss = len(b64) % 4
                    if miss:
                        b64 += "=" * (4 - miss)
                    decoded = base64.b64decode(b64, validate=False).decode("utf-8", errors="ignore")
                    if "@" not in decoded or ":" not in decoded:
                        return None, None
                    user_part, server_part = decoded.split("@", 1)
                    if ":" in user_part:
                        method, password = user_part.split(":", 1)
                    if ":" in server_part:
                        host, port_str = server_part.rsplit(":", 1)
                        port = int(port_str)
                except:
                    return None, None
            if not method or not password or not host or not port:
                return None, None
            config = XrayConfigParser._base_config(local_port, socks_user=socks_user, socks_pass=socks_pass)
            config["outbounds"][0].update({
                "protocol": "shadowsocks",
                "settings": {"servers": [{"address": host, "port": port,
                                          "method": method, "password": password}]},
                "streamSettings": {"network": "tcp", "security": "none"},
            })
            return json.dumps(config), name
        except Exception:
            return None, None

class VlessCore:
    def __init__(self, defer=False):
        self.lib = None
        self.mode = None
        self.libc = None
        if not defer:
            self._try_init_standalone()

    @staticmethod
    def core_file_path():
        try:
            ctx = ApplicationLoader.applicationContext
            return os.path.join(str(ctx.getFilesDir()), "exitfy_modules", "libvless.so")
        except Exception:
            return ""

    @staticmethod
    def core_file_exists():
        try:
            p = VlessCore.core_file_path()
            return bool(p) and os.path.exists(p) and os.path.getsize(p) >= 1024
        except Exception:
            return False

    def ensure_loaded(self):
        if self.lib is None:
            self._try_init_standalone()
        return self.is_available()

    def _try_init_standalone(self):
        try:
            ctx = ApplicationLoader.applicationContext
            dir_path = os.path.join(str(ctx.getFilesDir()), "exitfy_modules")
            if not os.path.exists(dir_path):
                os.makedirs(dir_path)
            so_path = os.path.join(dir_path, "libvless.so")
            if (not os.path.exists(so_path)) or (os.path.getsize(so_path) < 1024):
                return
            linker = _NativeLinker()
            lib = linker.load(so_path)
            if not lib:
                return
            lib.StartCore.argtypes = [ctypes.c_char_p]
            lib.StartCore.restype = ctypes.c_void_p
            lib.StopCore.argtypes = []
            lib.StopCore.restype = None
            self.lib = lib
            self.mode = "standalone"
            try:
                self.libc = ctypes.CDLL("libc.so")
                self.libc.free.argtypes = [ctypes.c_void_p]
                self.libc.free.restype = None
            except:
                self.libc = None
        except Exception as e:
            _log(f"libvless standalone init failed: {e}")
            return

    def is_available(self): return self.lib is not None

    def start(self, config_json):
        if not self.is_available(): return "Native library not loaded"
        try:
            res_ptr = self.lib.StartCore(config_json.encode('utf-8'))
            if not res_ptr:
                return ""
            try:
                res_str = ctypes.cast(res_ptr, ctypes.c_char_p).value
                out = res_str.decode('utf-8', errors='ignore') if res_str else ""
            except:
                out = ""
            try:
                if self.libc:
                    self.libc.free(res_ptr)
            except:
                pass
            return out
        except Exception as e: return str(e)

    def stop(self):
        if self.is_available():
            try: self.lib.StopCore()
            except: pass

class _NativeLinker:
    def __init__(self):
        self.libdl = ctypes.CDLL("libdl.so")
        try:
            self.open_ext = self.libdl.android_dlopen_ext
            class Info(ctypes.Structure):
                _fields_ = [
                    ("flags", ctypes.c_uint64),
                    ("reserved_addr", ctypes.c_void_p),
                    ("reserved_size", ctypes.c_size_t),
                    ("relro_fd", ctypes.c_int),
                    ("library_fd", ctypes.c_int),
                    ("library_fd_offset", ctypes.c_uint64),
                    ("library_namespace", ctypes.c_void_p),
                ]
            self.Info = Info
            self.open_ext.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.POINTER(self.Info)]
            self.open_ext.restype = ctypes.c_void_p
        except:
            self.open_ext = None

    def load(self, path: str):
        if not os.path.exists(path):
            return None
        try:
            if int(Build.VERSION.SDK_INT) >= 29 and self.open_ext:
                fd = os.open(path, os.O_RDONLY)
                try:
                    info = self.Info(flags=0x10, library_fd=fd)
                    h = self.open_ext(path.encode(), 2 | 0x100, ctypes.byref(info))
                    if h:
                        return ctypes.CDLL(path, handle=h)
                finally:
                    try: os.close(fd)
                    except: pass
        except:
            pass
        try:
            return ctypes.CDLL(path, mode=2 | 0x100)
        except:
            return None

_ELF_MACHINE_TO_ABI = {
    183: "arm64-v8a",
    40:  "armeabi-v7a",
    62:  "x86_64",
    3:   "x86",
}

def _device_abis():
    abis = []
    try:
        for a in (Build.SUPPORTED_ABIS or []):
            s = str(a or "").strip()
            if s:
                abis.append(s)
    except Exception:
        pass
    if not abis:
        try:
            primary = str(getattr(Build, "CPU_ABI", "") or "").strip()
            if primary:
                abis.append(primary)
        except Exception:
            pass
    return abis or ["arm64-v8a"]

def _validate_core_elf(path):
    try:
        with open(path, "rb") as f:
            head = f.read(20)
    except Exception:
        return False, "addon_pick_file_bad"
    if len(head) < 20 or head[:4] != b"\x7fELF":
        return False, "addon_pick_not_elf"
    try:
        machine = head[18] | (head[19] << 8)
        abi = _ELF_MACHINE_TO_ABI.get(int(machine))
        if abi and abi not in _device_abis():
            return False, "addon_pick_bad_arch"
    except Exception:
        pass
    return True, ""


class NetworkMonitor:
    POLL_INTERVAL_SEC = 2.5
    DEBOUNCE_SEC = 1.5

    def __init__(self, on_change):
        self._on_change = on_change
        self._stop = threading.Event()
        self._thread = None
        self._last_handle = None
        self._cm = None

    def start(self):
        if self._thread is not None:
            return
        self._stop.clear()
        self._thread = threading.Thread(target=self._loop, daemon=True)
        self._thread.start()

    def stop(self):
        self._stop.set()
        self._thread = None

    def _active_handle(self):
        try:
            if self._cm is None:
                ctx = ApplicationLoader.applicationContext
                self._cm = ctx.getSystemService("connectivity")
            if self._cm is None:
                return None
            net = self._cm.getActiveNetwork()
            if net is None:
                return None
            try:
                return int(net.getNetworkHandle())
            except Exception:
                return str(net)
        except Exception:
            return None

    def _loop(self):
        self._last_handle = self._active_handle()
        pending_since = 0.0
        pending_handle = None
        while not self._stop.is_set():
            try:
                cur = self._active_handle()
                if cur is not None and cur != self._last_handle:
                    if pending_handle != cur:
                        pending_handle = cur
                        pending_since = time.time()
                    elif time.time() - pending_since >= self.DEBOUNCE_SEC:
                        self._last_handle = cur
                        pending_handle = None
                        try:
                            self._on_change()
                        except Exception as e:
                            _safe_log(f"network change handler failed: {e}")
                else:
                    pending_handle = None
            except Exception as e:
                _safe_log(f"network monitor loop error: {e}")
            self._stop.wait(self.POLL_INTERVAL_SEC)


def _generate_socks_credentials():
    try:
        username = binascii.hexlify(os.urandom(8)).decode("ascii")
        password = binascii.hexlify(os.urandom(12)).decode("ascii")
        return username, password
    except Exception:
        import uuid as _uuid
        return _uuid.uuid4().hex[:16], _uuid.uuid4().hex[:24]

_PROXY_LABEL_PREFIX = "exitFy"

def _proxy_label_for_uri(uri):
    s = str(uri or "").strip().lower()
    proto = "Proxy"
    if s.startswith("vless://"):
        proto = "VLESS"
    elif s.startswith("vmess://"):
        proto = "VMess"
    elif s.startswith("trojan://"):
        proto = "Trojan"
    elif s.startswith("ss://"):
        proto = "Shadowsocks"
    elif s.startswith("hy2://") or s.startswith("hysteria2://"):
        proto = "Hysteria2"
    elif s.startswith("hysteria://"):
        proto = "Hysteria"
    elif s.startswith("tuic://"):
        proto = "TUIC"
    return f"{_PROXY_LABEL_PREFIX} ¬∑ {proto}"

def _set_proxy_display_name(proxy_obj, name):
    if not proxy_obj:
        return
    try:
        ProxyController = find_class("com.exteragram.messenger.proxy.ProxyController")
        if ProxyController is None:
            return
        ctrl = ProxyController.getInstance()
        if ctrl is None:
            return
        try:
            ctrl.setCurrentProxy(proxy_obj)
        except Exception:
            pass
        if name:
            try:
                ctrl.setName(proxy_obj, str(name))
            except Exception:
                pass
    except Exception as e:
        _safe_log(f"register proxy failed: {e}")

def _vless_apply_tg_proxy(port, enable, socks_user="", socks_pass="", secret="", display_name=""):
    try:
        ProxyInfoClass = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
        try:
            SharedConfig.loadProxyList()
        except:
            pass
        local_proxy = None
        try:
            if hasattr(SharedConfig, "proxyList") and SharedConfig.proxyList:
                duplicates = []
                for i in range(SharedConfig.proxyList.size()):
                    try:
                        p = SharedConfig.proxyList.get(i)
                        if str(p.address) == VLESS_LOCAL_HOST:
                            if local_proxy is None:
                                local_proxy = p
                            else:
                                duplicates.append(p)
                    except:
                        continue
                for p in duplicates:
                    try:
                        SharedConfig.deleteProxy(p)
                    except:
                        pass
        except:
            pass
        ed = MessagesController.getGlobalMainSettings().edit()
        try:
            proxy_list = SharedConfig.proxyList
            if proxy_list:
                to_remove = []
                for i in range(proxy_list.size()):
                    p = proxy_list.get(i)
                    if str(p.address) == VLESS_LOCAL_HOST:
                        to_remove.append(p)
                for p in to_remove:
                    SharedConfig.deleteProxy(p)
        except: pass
        try:
            curr = SharedConfig.currentProxy
            if curr and str(curr.address) == VLESS_LOCAL_HOST:
                SharedConfig.currentProxy = None
        except:
            pass
        if enable:
            _secret = str(secret or "").strip()
            _su = "" if _secret else str(socks_user or "")
            _sp = "" if _secret else str(socks_pass or "")
            if local_proxy is not None:
                try:
                    local_proxy.port = int(port)
                    local_proxy.username = _su
                    local_proxy.password = _sp
                    local_proxy.secret = _secret
                except:
                    pass
                proxy_obj = local_proxy
            else:
                proxy_obj = None
                try:
                    proxy_obj = SharedConfig.addProxy(VLESS_LOCAL_HOST, int(port), _su, _sp, _secret)
                except:
                    proxy_obj = None
                if not proxy_obj:
                    try:
                        proxy_obj = ProxyInfoClass(VLESS_LOCAL_HOST, int(port), _su, _sp, _secret)
                        try:
                            SharedConfig.addProxy(proxy_obj)
                        except:
                            pass
                    except:
                        proxy_obj = None
            try:
                if proxy_obj:
                    SharedConfig.currentProxy = proxy_obj
                    _set_proxy_display_name(proxy_obj, display_name)
            except:
                pass
            try:
                SharedConfig.proxyEnabled = True
            except:
                pass
            ed.putString("proxy_ip", VLESS_LOCAL_HOST); ed.putInt("proxy_port", port)
            try:
                ed.putString("proxy_user", _su); ed.putString("proxy_pass", _sp)
            except:
                pass
            ed.putString("proxy_secret", _secret); ed.putBoolean("proxy_enabled", True)
            calls_enabled = False if _secret else True
            try:
                ed.putBoolean("proxy_enabled_calls", calls_enabled)
            except:
                pass
            try:
                ed.putBoolean("proxy_calls_enabled", calls_enabled)
            except:
                pass
            try:
                ed.putBoolean("calls_use_proxy", calls_enabled)
            except:
                pass
            try:
                for attr in ("proxyEnabledCalls", "proxyCallsEnabled", "callsEnabled", "useProxyForCalls"):
                    try:
                        setattr(SharedConfig, attr, calls_enabled)
                    except:
                        pass
            except:
                pass
            if proxy_obj:
                try:
                    for attr in ("enabledForCalls", "useForCalls"):
                        try:
                            setattr(proxy_obj, attr, calls_enabled)
                        except:
                            pass
                except:
                    pass
            if calls_enabled:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        try:
                            mc = MessagesController.getInstance(ac)
                            if mc:
                                for pname in ("mainconfig", "userconfing"):
                                    try:
                                        prefs = mc.getSharedPreferences(pname, 0)
                                        if prefs:
                                            ed2 = prefs.edit()
                                            ed2.putBoolean("proxy_enabled_calls", True)
                                            ed2.putBoolean("proxy_calls_enabled", True)
                                            ed2.putBoolean("calls_use_proxy", True)
                                            ed2.commit()
                                    except:
                                        pass
                        except:
                            pass
                except:
                    pass
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        try:
                            prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                            if prefs:
                                p2p_prev_key = "exitfy_p2p_backup_" + str(ac)
                                current_p2p = prefs.getInt("calls_p2p", -1)
                                if current_p2p != 2:
                                    prefs.edit().putInt(p2p_prev_key, current_p2p).putInt("calls_p2p", 2).commit()
                        except:
                            pass
                except:
                    pass
        else:
            try:
                curr = SharedConfig.currentProxy
                if curr and str(curr.address) == VLESS_LOCAL_HOST:
                    SharedConfig.currentProxy = None
            except:
                pass
            SharedConfig.proxyEnabled = False
            ed.putBoolean("proxy_enabled", False)
            try:
                for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                    try:
                        prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                        if prefs:
                            p2p_prev_key = "exitfy_p2p_backup_" + str(ac)
                            saved_p2p = prefs.getInt(p2p_prev_key, -1)
                            if saved_p2p >= 0:
                                prefs.edit().putInt("calls_p2p", saved_p2p).remove(p2p_prev_key).commit()
                    except:
                        pass
            except:
                pass
        try:
            ed.commit()
        except:
            ed.apply()
        try:
            SharedConfig.saveProxyList()
        except:
            pass
        SharedConfig.saveConfig()
        _secret2 = str(secret or "").strip()
        _su2 = "" if _secret2 else str(socks_user or "")
        _sp2 = "" if _secret2 else str(socks_pass or "")
        for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
            try:
                cm = ConnectionsManager.getInstance(ac)
                if cm:
                    if enable: cm.setProxySettings(True, VLESS_LOCAL_HOST, port, _su2, _sp2, _secret2)
                    else: cm.setProxySettings(False, "", 0, "", "", "")
            except: pass
        try:
            if enable:
                ConnectionsManager.setProxySettings(True, VLESS_LOCAL_HOST, int(port), _su2, _sp2, _secret2)
            else:
                ConnectionsManager.setProxySettings(False, "", 0, "", "", "")
        except:
            pass
        def _notify():
            try:
                try:
                    from java import jarray
                    from java.lang import Object
                    NotificationCenter.getGlobalInstance().postNotificationName(
                        NotificationCenter.proxySettingsChanged, jarray(Object)(0)
                    )
                except Exception:
                    NotificationCenter.getGlobalInstance().postNotificationName(
                        NotificationCenter.proxySettingsChanged
                    )
            except Exception:
                pass
        try:
            run_on_ui_thread(_notify, 300)
        except Exception:
            pass
    except Exception as e:
        _log(f"vless_apply_tg_proxy error: {e}")

def _check_vless_port(port, timeout=0.2):
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.settimeout(timeout)
            return s.connect_ex((VLESS_LOCAL_HOST, port)) == 0
    except:
        return False

def _check_proxy_internet_real(port, socks_user="", socks_pass=""):
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.settimeout(3.0)
            s.connect((VLESS_LOCAL_HOST, int(port)))
            _su = str(socks_user or "").encode("utf-8")
            _sp = str(socks_pass or "").encode("utf-8")
            if _su and _sp:
                s.sendall(b"\x05\x01\x02")
                resp = s.recv(2)
                if len(resp) < 2 or resp[0] != 0x05:
                    return False
                if resp[1] == 0x02:
                    auth_msg = bytes([0x01, len(_su)]) + _su + bytes([len(_sp)]) + _sp
                    s.sendall(auth_msg)
                    auth_resp = s.recv(2)
                    if len(auth_resp) < 2 or auth_resp[1] != 0x00:
                        return False
                elif resp[1] != 0x00:
                    return False
            else:
                s.sendall(b"\x05\x01\x00")
                if s.recv(2) != b"\x05\x00":
                    return False
            s.sendall(b"\x05\x01\x00\x03\x0a\x67\x6f\x6f\x67\x6c\x65\x2e\x63\x6f\x6d\x00\x50")
            rep = s.recv(10)
            if not rep or len(rep) < 2 or rep[1] != 0x00:
                return False
            s.sendall(b"HEAD / HTTP/1.1\r\nHost: google.com\r\nConnection: close\r\n\r\n")
            resp = s.recv(15)
            return b"HTTP" in resp
    except Exception:
        return False

def _extract_proxy_host_port(raw_uri):
    try:
        u = _sanitize_vless_uri(raw_uri)
        if not u:
            return None, None
        if u.startswith("vless://") or u.startswith("trojan://"):
            m = _RE_URI_HOST_PORT.search(u)
            if m:
                return str(m.group(1) or "").strip("[]"), int(m.group(2))
            r = VlessConfigParser._parse_std_uri(u)
            if r:
                return str(r.get("host") or "").strip("[]"), int(r.get("port") or 0)
            return None, None
        if u.startswith("ss://"):
            body = u[5:].split("#", 1)[0]
            if "@" in body:
                server_part = body.split("@", 1)[1].split("?", 1)[0].strip().rstrip("/")
                if ":" in server_part:
                    host, port = server_part.rsplit(":", 1)
                    return str(host or "").strip("[]"), int(port)
            else:
                try:
                    b64 = body.replace("-", "+").replace("_", "/")
                    miss = len(b64) % 4
                    if miss:
                        b64 += "=" * (4 - miss)
                    decoded = base64.b64decode(b64, validate=False).decode("utf-8", errors="ignore")
                    if "@" in decoded and ":" in decoded:
                        server_part = decoded.split("@", 1)[1]
                        if ":" in server_part:
                            host, port = server_part.rsplit(":", 1)
                            return str(host or "").strip("[]"), int(port)
                except Exception:
                    pass
            return None, None
        if u.startswith("vmess://"):
            try:
                b64_part = u[8:].split("#", 1)[0].strip().replace("-", "+").replace("_", "/")
                miss = len(b64_part) % 4
                if miss:
                    b64_part += "=" * (4 - miss)
                raw = base64.b64decode(b64_part, validate=False)
                obj = json.loads(raw.decode("utf-8", errors="ignore"))
                host = str(obj.get("add", "") or "")
                port = int(obj.get("port", 0) or 0)
                if host and port > 0:
                    return host.strip("[]"), port
            except Exception:
                pass
            return None, None
    except Exception:
        return None, None
    return None, None

def _node_dedup_key(raw_uri):
    try:
        u = _sanitize_vless_uri(raw_uri)
        if not u:
            return ""
        k = _uri_dedup_key(u)
        if k:
            return k
        host, port = _extract_proxy_host_port(u)
        if host and port:
            scheme = str(u.split("://", 1)[0] or "").lower()
            return f"{scheme}://{str(host).lower()}:{int(port)}"
    except Exception:
        pass
    return ""

def _node_soft_dedup_key(raw_uri, raw_name=""):
    try:
        u = _sanitize_vless_uri(raw_uri)
        if not u:
            return ""
        scheme = ""
        try:
            scheme = str(u.split("://", 1)[0] or "").lower()
        except Exception:
            scheme = ""
        host, port = _extract_proxy_host_port(u)
        try:
            nm = str(raw_name or "").strip().lower()
        except Exception:
            nm = ""
        if host and port:
            base = f"{scheme}://{str(host).lower()}:{int(port)}"
            return f"{base}|{nm}" if nm else base
        k = _node_dedup_key(u)
        if k:
            return f"{k}|{nm}" if nm else k
        if nm:
            return f"name:{nm}"
    except Exception:
        pass
    return ""

def _node_hostport_key(raw_uri):
    try:
        u = _sanitize_vless_uri(raw_uri)
        if not u:
            return ""
        scheme = ""
        try:
            scheme = str(u.split("://", 1)[0] or "").lower()
        except Exception:
            scheme = ""
        host, port = _extract_proxy_host_port(u)
        if host and port:
            return f"{scheme}://{str(host).lower()}:{int(port)}"
    except Exception:
        pass
    return ""

def _get_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(('', 0)); return s.getsockname()[1]

def _new_vless_data():
    return {"manual": [], "subs": [], "active_uri": ""}

def _clone_vless_data(data):
    if not isinstance(data, dict):
        return _new_vless_data()
    out = _new_vless_data()
    try:
        manual = data.get("manual", [])
        out["manual"] = list(manual) if isinstance(manual, list) else []
    except Exception:
        out["manual"] = []
    try:
        subs = data.get("subs", [])
        out["subs"] = list(subs) if isinstance(subs, list) else []
    except Exception:
        out["subs"] = []
    try:
        out["active_uri"] = str(data.get("active_uri", "") or "")
    except Exception:
        out["active_uri"] = ""
    return out

_TGWS_TG_RANGES = [
    (struct.unpack("!I", socket.inet_aton("185.76.151.0"))[0], struct.unpack("!I", socket.inet_aton("185.76.151.255"))[0]),
    (struct.unpack("!I", socket.inet_aton("149.154.160.0"))[0], struct.unpack("!I", socket.inet_aton("149.154.175.255"))[0]),
    (struct.unpack("!I", socket.inet_aton("91.105.192.0"))[0], struct.unpack("!I", socket.inet_aton("91.105.193.255"))[0]),
    (struct.unpack("!I", socket.inet_aton("91.108.0.0"))[0], struct.unpack("!I", socket.inet_aton("91.108.255.255"))[0]),
]

