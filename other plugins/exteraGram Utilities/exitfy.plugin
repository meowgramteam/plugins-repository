def _tgws_unique_values(*values):
    out = []
    seen = set()
    for value in values:
        try:
            trimmed = str(value or "").strip()
        except:
            trimmed = ""
        if not trimmed or trimmed in seen:
            continue
        seen.add(trimmed)
        out.append(trimmed)
    return out

def _tgws_xor_mask(data, mask):
    if not mask:
        return data
    buf = bytearray(data)
    for idx in range(len(buf)):
        buf[idx] ^= mask[idx & 3]
    return bytes(buf)

def _tgws_build_frame(opcode, payload, mask=True):
    try:
        body = bytes(payload or b"")
    except:
        body = b""
    out = bytearray()
    out.append(0x80 | (int(opcode) & 0x0F))
    length = len(body)
    mask_bit = 0x80 if mask else 0x00
    if length < 126:
        out.append(mask_bit | length)
    elif length <= 0xFFFF:
        out.append(mask_bit | 126)
        out.extend(struct.pack(">H", length))
    else:
        out.append(mask_bit | 127)
        out.extend(struct.pack(">Q", length))
    if mask:
        mask_key = os.urandom(4)
        out.extend(mask_key)
        body = _tgws_xor_mask(body, mask_key)
    out.extend(body)
    return bytes(out)

def _tgws_read_exact(reader, size):
    buf = b""
    need = int(size or 0)
    while len(buf) < need:
        chunk = reader.read(need - len(buf))
        if not chunk:
            raise EOFError("unexpected eof")
        buf += chunk
    return buf

def _tgws_recv_exact(conn, size):
    data = b""
    need = int(size or 0)
    while len(data) < need:
        chunk = conn.recv(need - len(data))
        if not chunk:
            raise EOFError("unexpected eof")
        data += chunk
    return data

def _tgws_is_telegram_ip(ip):
    try:
        ip_s = str(ip or "")
    except Exception:
        ip_s = ""
    try:
        if ":" in ip_s:
            try:
                socket.inet_pton(socket.AF_INET6, ip_s)
                return True
            except Exception:
                pass
    except Exception:
        pass
    try:
        raw = struct.unpack("!I", socket.inet_aton(ip_s))[0]
        for lo, hi in _TGWS_TG_RANGES:
            if lo <= raw <= hi:
                return True
    except:
        pass
    return False

def _tgws_resolve_ipv4(hostname):
    try:
        hn = str(hostname or "").strip()
        if not hn:
            return None
        try:
            if ":" in hn:
                return None
            socket.inet_aton(hn)
            return hn
        except Exception:
            pass
        for family, _, _, _, sockaddr in socket.getaddrinfo(hn, None, socket.AF_INET, socket.SOCK_STREAM):
            if family == socket.AF_INET:
                return str(sockaddr[0])
    except Exception:
        return None
    return None

def _tgws_default_dc(dc_ip_map):
    try:
        m = dc_ip_map or {}
        if not isinstance(m, dict):
            return None
        for k in ("2", "1", "4", "3", "5"):
            if k in m and str(m.get(k) or "").strip():
                return int(k)
        for k, v in m.items():
            if str(v or "").strip():
                try:
                    return int(k)
                except Exception:
                    continue
    except Exception:
        pass
    return None

def _tgws_is_http_transport(data):
    try:
        raw = bytes(data or b"")
    except:
        raw = b""
    return raw[:5] == b"POST " or raw[:4] == b"GET " or raw[:5] == b"HEAD " or raw[:8] == b"OPTIONS "

def _tgws_keystream_java(key_bytes, iv_bytes, size):
    if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
        raise RuntimeError("Java crypto unavailable")
    cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
    cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key_bytes), "AES"), IvParameterSpec(bytes(iv_bytes)))
    result = cipher.doFinal(b"\x00" * int(size))
    try:
        return bytes(result)
    except:
        return bytes(bytearray(result))

def _tgws_parse_init_meta(data):
    try:
        raw = bytes(data or b"")
        if len(raw) < 64:
            return None, False, None
        key = raw[8:40]
        iv = raw[40:56]
        keystream = _tgws_keystream_java(key, iv, 64)
        plain = bytes(a ^ b for a, b in zip(raw[56:64], keystream[56:64]))
        proto = struct.unpack("<I", plain[0:4])[0]
        dc_raw = struct.unpack("<h", plain[4:6])[0]
        if proto in (0xEFEFEFEF, 0xEEEEEEEE, 0xDDDDDDDD):
            dc = abs(int(dc_raw))
            if 1 <= dc <= 1000:
                return dc, bool(dc_raw < 0), int(proto)
    except:
        pass
    return None, False, None

def _tgws_patch_init_dc(data, dc_value):
    try:
        raw = bytes(data or b"")
    except Exception:
        return data
    if len(raw) < 64:
        return data
    try:
        key = raw[8:40]
        iv = raw[40:56]
        keystream = _tgws_keystream_java(key, iv, 64)
        replacement = struct.pack("<h", int(dc_value))
        patched = bytearray(raw[:64])
        patched[60] = keystream[60] ^ replacement[0]
        patched[61] = keystream[61] ^ replacement[1]
        if len(raw) > 64:
            return bytes(patched) + raw[64:]
        return bytes(patched)
    except Exception:
        return data

class _TgWsMsgSplitter:
    def __init__(self, init_data, proto_int=None):
        raw = bytes(init_data or b"")
        key = raw[8:40]
        iv = raw[40:56]
        if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
            raise RuntimeError("Java crypto unavailable")
        cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
        cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key), "AES"), IvParameterSpec(bytes(iv)))
        try:
            cipher.update(b"\x00" * 64)
        except Exception:
            pass
        self._cipher = cipher
        try:
            self._proto = int(proto_int or 0)
        except Exception:
            self._proto = 0
        self._cipher_buf = bytearray()
        self._plain_buf = bytearray()
        self._disabled = False

    def split(self, chunk):
        if not chunk:
            return []
        if self._disabled:
            return [chunk]

        try:
            self._cipher_buf.extend(bytes(chunk))
            plain = self._cipher.update(bytes(chunk))
            try:
                self._plain_buf.extend(bytes(plain))
            except Exception:
                self._plain_buf.extend(bytes(bytearray(plain)))
        except Exception:
            return [chunk]

        parts = []
        while self._cipher_buf:
            packet_len = self._next_packet_len()
            if packet_len is None:
                break
            if packet_len <= 0:
                parts.append(bytes(self._cipher_buf))
                self._cipher_buf.clear()
                self._plain_buf.clear()
                self._disabled = True
                break
            parts.append(bytes(self._cipher_buf[:packet_len]))
            del self._cipher_buf[:packet_len]
            del self._plain_buf[:packet_len]
        return parts

    def flush(self):
        if not self._cipher_buf:
            return []
        tail = bytes(self._cipher_buf)
        self._cipher_buf.clear()
        self._plain_buf.clear()
        return [tail]

    def _next_packet_len(self):
        try:
            proto = int(self._proto)
        except Exception:
            proto = 0
        if not self._plain_buf:
            return None
        if proto == 0xEFEFEFEF:
            return self._next_abridged_len()
        if proto in (0xEEEEEEEE, 0xDDDDDDDD):
            return self._next_intermediate_len()
        return 0

    def _next_abridged_len(self):
        first = self._plain_buf[0]
        if first in (0x7F, 0xFF):
            if len(self._plain_buf) < 4:
                return None
            payload_len = int.from_bytes(self._plain_buf[1:4], "little") * 4
            header_len = 4
        else:
            payload_len = (first & 0x7F) * 4
            header_len = 1
        if payload_len <= 0:
            return 0
        packet_len = header_len + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len

    def _next_intermediate_len(self):
        if len(self._plain_buf) < 4:
            return None
        payload_len = struct.unpack_from("<I", self._plain_buf, 0)[0] & 0x7FFFFFFF
        if payload_len <= 0:
            return 0
        packet_len = 4 + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len

def _tgws_ws_domains(dc, is_media):
    try:
        dc_num = int(dc or 0)
    except:
        dc_num = 0
    try:
        dc_num = int(TGWS_DC_OVERRIDES.get(int(dc_num), int(dc_num)))
    except Exception:
        pass
    bases = ["web.telegram.org", "telegram.org"]
    out = []
    for base in bases:
        if is_media:
            out.append(f"kws{dc_num}-1.{base}")
            out.append(f"kws{dc_num}.{base}")
        else:
            out.append(f"kws{dc_num}.{base}")
            out.append(f"kws{dc_num}-1.{base}")
    seen = set()
    uniq = []
    for d in out:
        if d not in seen:
            seen.add(d)
            uniq.append(d)
    return uniq

def _tgws_socks_reply(status):
    return bytes((0x05, int(status) & 0xFF, 0x00, 0x01, 0, 0, 0, 0, 0, 0))

def _tgws_read_socks_address(conn, atyp):
    atyp = int(atyp or 0)
    if atyp == 0x01:
        host = socket.inet_ntoa(_tgws_recv_exact(conn, 4))
        port = int.from_bytes(_tgws_recv_exact(conn, 2), "big")
        return host, port
    if atyp == 0x03:
        size = _tgws_recv_exact(conn, 1)[0]
        host = _tgws_recv_exact(conn, size).decode("utf-8", errors="ignore")
        port = int.from_bytes(_tgws_recv_exact(conn, 2), "big")
        return host, port
    if atyp == 0x04:
        host = socket.inet_ntop(socket.AF_INET6, _tgws_recv_exact(conn, 16))
        port = int.from_bytes(_tgws_recv_exact(conn, 2), "big")
        return host, port
    raise ValueError("unsupported atyp")

class _TgWsRawWebSocket:
    def __init__(self, sock, reader):
        self.sock = sock
        self.reader = reader
        self._lock = threading.Lock()
        self._closed = False

    @staticmethod
    def connect(connect_host, sni_host, timeout=TGWS_WS_CONNECT_TIMEOUT_SEC):
        sock = socket.create_connection((str(connect_host), 443), timeout=float(timeout))
        try:
            if TGWS_TCP_NODELAY:
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
        except:
            pass
        try:
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
        except Exception:
            pass
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        wrapped = ctx.wrap_socket(sock, server_hostname=str(sni_host or ""))
        wrapped.settimeout(float(timeout))
        key = base64.b64encode(os.urandom(16)).decode("ascii")
        req = "\r\n".join([
            "GET /apiws HTTP/1.1",
            "Host: " + str(sni_host or ""),
            "Upgrade: websocket",
            "Connection: Upgrade",
            "Sec-WebSocket-Key: " + key,
            "Sec-WebSocket-Version: 13",
            "Sec-WebSocket-Protocol: binary",
            "Origin: https://web.telegram.org",
            "User-Agent: Mozilla/5.0 (Linux; Android 13)",
            "",
            "",
        ])
        wrapped.sendall(req.encode("utf-8"))
        reader = wrapped.makefile("rb")
        status_line = reader.readline().decode("utf-8", errors="ignore").strip()
        headers = {}
        try:
            while True:
                line = reader.readline()
                if not line:
                    break
                if line in (b"\r\n", b"\n"):
                    break
                try:
                    s = line.decode("utf-8", errors="ignore").strip()
                except:
                    continue
                if ":" in s:
                    k, v = s.split(":", 1)
                    headers[str(k).strip().lower()] = str(v).strip()
        except:
            headers = headers or {}
        try:
            _parts = str(status_line or "").split(" ", 2)
            _status_code = int(_parts[1]) if len(_parts) >= 2 else 0
        except Exception:
            _status_code = 0
        if _status_code != 101:
            try:
                reader.close()
            except:
                pass
            try:
                wrapped.close()
            except:
                pass
            code = int(_status_code or 0)
            try:
                loc = str(headers.get("location", "") or "").strip()
            except:
                loc = ""
            if code in (301, 302, 303, 307, 308) and loc:
                raise RuntimeError(f"{status_line} -> {loc}")
            raise RuntimeError(status_line or "bad websocket handshake")
        return _TgWsRawWebSocket(wrapped, reader)

    def send(self, payload):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            self.sock.sendall(_tgws_build_frame(0x2, payload, mask=True))

    def send_batch(self, parts):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            for payload in list(parts or []):
                self.sock.sendall(_tgws_build_frame(0x2, payload, mask=True))

    def _read_frame(self):
        header = _tgws_read_exact(self.reader, 2)
        opcode = header[0] & 0x0F
        masked = bool(header[1] & 0x80)
        length = header[1] & 0x7F
        if length == 126:
            length = struct.unpack(">H", _tgws_read_exact(self.reader, 2))[0]
        elif length == 127:
            length = struct.unpack(">Q", _tgws_read_exact(self.reader, 8))[0]
        mask_key = b""
        if masked:
            mask_key = _tgws_read_exact(self.reader, 4)
        payload = _tgws_read_exact(self.reader, length)
        if masked:
            payload = _tgws_xor_mask(payload, mask_key)
        return opcode, payload

    def recv(self):
        while True:
            opcode, payload = self._read_frame()
            if opcode == 0x8:
                self.close()
                return None
            if opcode == 0x9:
                self._write_control(0xA, payload)
                continue
            if opcode == 0xA:
                continue
            if opcode in (0x1, 0x2):
                return payload

    def _write_control(self, opcode, payload):
        with self._lock:
            if self._closed:
                return
            self.sock.sendall(_tgws_build_frame(opcode, payload, mask=True))

    def close(self):
        with self._lock:
            if self._closed:
                return
            self._closed = True
            try:
                self.sock.sendall(_tgws_build_frame(0x8, b"", mask=True))
            except:
                pass
            try:
                self.reader.close()
            except:
                pass
            try:
                self.sock.close()
            except:
                pass

    def is_closed(self):
        try:
            return bool(self._closed)
        except Exception:
            return True


class _TgWsWsPool:
    def __init__(self, max_age_sec=120.0, max_items_per_key=4):
        self._max_age = float(max_age_sec or 120.0)
        self._max_items = int(max_items_per_key or 4)
        self._lock = threading.Lock()
        self._idle = {}

    def get(self, key):
        now = time.time()
        with self._lock:
            q = self._idle.get(key)
            if not q:
                return None
            while q:
                ws, ts = q.pop(0)
                if ws is None:
                    continue
                try:
                    if ws.is_closed():
                        continue
                except Exception:
                    continue
                if self._max_age and (now - float(ts or 0.0)) > self._max_age:
                    try:
                        ws.close()
                    except Exception:
                        pass
                    continue
                return ws
            return None

    def put(self, key, ws):
        if ws is None:
            return
        try:
            if ws.is_closed():
                return
        except Exception:
            return
        with self._lock:
            q = self._idle.get(key)
            if not q:
                q = []
                self._idle[key] = q
            if len(q) >= self._max_items:
                try:
                    old, _ = q.pop(0)
                    if old is not None:
                        old.close()
                except Exception:
                    pass
            q.append((ws, time.time()))

    def clear(self):
        with self._lock:
            all_items = []
            for q in self._idle.values():
                all_items.extend(list(q))
            self._idle = {}
        for ws, _ in all_items:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass

class TgWsCore:
    def __init__(self):
        self.listener = None
        self.listener_thread = None
        self.stop_event = threading.Event()
        self.lock = threading.Lock()
        self.tracked = set()
        self.fail_until = {}
        self.ws_blacklist = set()
        self.ws_domain_pref = {}
        self._last_ws_event_at = 0.0
        self.port = 0
        self.dc_ip = dict(TGWS_DEFAULT_DC_IP)
        self._auth_user = ""
        self._auth_pass = ""
        self._ws_pool = _TgWsWsPool(max_age_sec=120.0, max_items_per_key=4)
        self._cf_domains = []
        self._cf_pref = {}
        try:
            _tgws_start_cfproxy_domain_refresh(self._set_cf_domains)
        except Exception:
            pass

    def _set_cf_domains(self, domains):
        try:
            d = list(domains or [])
        except Exception:
            d = []
        seen = set()
        out = []
        for x in d:
            try:
                s = str(x or "").strip().lower()
            except Exception:
                continue
            if not s:
                continue
            if s in seen:
                continue
            seen.add(s)
            out.append(s)
        self._cf_domains = out

    def _cf_domains_for_dc(self, dc, is_media=False):
        try:
            dc_num = int(dc or 0)
        except Exception:
            dc_num = 0
        pool = list(getattr(self, "_cf_domains", []) or [])
        if not pool:
            return []
        try:
            pref = str((getattr(self, "_cf_pref", {}) or {}).get(int(dc_num), "") or "").strip().lower()
        except Exception:
            pref = ""
        ordered = []
        if pref and pref in pool:
            ordered.append(pref)
        for base in pool:
            if base != pref:
                ordered.append(base)
        out = []
        seen = set()
        for base in ordered:
            names = [f"kws{dc_num}-1.{base}", f"kws{dc_num}.{base}"] if is_media else [f"kws{dc_num}.{base}", f"kws{dc_num}-1.{base}"]
            for name in names:
                if name not in seen:
                    seen.add(name)
                    out.append(name)
        return out

    def _ws_pool_key(self, dc, is_media):
        try:
            return (int(dc or 0), bool(is_media))
        except Exception:
            return (0, bool(is_media))

    def _ws_pool_get(self, dc, is_media):
        key = self._ws_pool_key(dc, is_media)
        return self._ws_pool.get(key)

    def _ws_pool_put(self, dc, is_media, ws):
        key = self._ws_pool_key(dc, is_media)
        try:
            self._ws_pool.put(key, ws)
        except Exception:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass

    def is_available(self):
        return JavaCipher is not None

    def _track(self, closer):
        with self.lock:
            self.tracked.add(closer)

    def _untrack(self, closer):
        with self.lock:
            self.tracked.discard(closer)

    def _close_all_tracked(self):
        with self.lock:
            closers = list(self.tracked)
            self.tracked.clear()
        for closer in closers:
            try:
                closer.close()
            except:
                pass

    def _parse_config(self, config_json):
        cfg = {"port": int(TGWS_LOCAL_PORT), "dc_ip": dict(TGWS_DEFAULT_DC_IP)}
        raw = str(config_json or "").strip()
        if raw:
            parsed = json.loads(raw)
            if isinstance(parsed, dict):
                if parsed.get("port"):
                    cfg["port"] = int(parsed.get("port") or TGWS_LOCAL_PORT)
                dc_ip = parsed.get("dc_ip")
                if isinstance(dc_ip, dict):
                    for key, value in dc_ip.items():
                        cfg["dc_ip"][str(key)] = str(value)
        if cfg["port"] <= 0 or cfg["port"] > 65535:
            cfg["port"] = int(TGWS_LOCAL_PORT)
        return cfg

    def start(self, config_json, socks_user="", socks_pass=""):
        if not self.is_available():
            return "Java crypto –Ĺ–Ķ–ī–ĺ—Ā—ā—É–Ņ–Ĺ–ĺ"
        try:
            cfg = self._parse_config(config_json)
            self._auth_user = str(socks_user or "")
            self._auth_pass = str(socks_pass or "")
            self.stop()
            listener = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            try:
                if TGWS_TCP_NODELAY:
                    listener.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            except Exception:
                pass
            try:
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
            except Exception:
                pass
            listener.bind((VLESS_LOCAL_HOST, int(cfg["port"])))
            listener.listen(32)
            listener.settimeout(1.0)
            self.listener = listener
            self.port = int(cfg["port"])
            self.dc_ip = dict(cfg.get("dc_ip") or {})
            self.stop_event.clear()
            self.listener_thread = threading.Thread(target=self._accept_loop, daemon=True)
            self.listener_thread.start()
            return ""
        except Exception as exc:
            try:
                if self.listener is not None:
                    self.listener.close()
            except:
                pass
            self.listener = None
            return str(exc)

    def stop(self):
        self.stop_event.set()
        try:
            if self.listener is not None:
                self.listener.close()
        except:
            pass
        self.listener = None
        try:
            self._ws_pool.clear()
        except Exception:
            pass
        self._close_all_tracked()
        thread = self.listener_thread
        self.listener_thread = None
        if thread is not None and thread.is_alive():
            try:
                thread.join(1.5)
            except:
                pass

    def handle_network_change(self):
        try:
            self._ws_pool.clear()
        except Exception:
            pass
        try:
            self._close_all_tracked()
        except Exception:
            pass
        self.fail_until = {}
        self.ws_blacklist = set()
        self._cf_pref = {}
        self._last_ws_event_at = 0.0

    def _accept_loop(self):
        while not self.stop_event.is_set():
            try:
                conn, _ = self.listener.accept()
                try:
                    if TGWS_TCP_NODELAY:
                        conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
                except Exception:
                    pass
                try:
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
                except Exception:
                    pass
            except socket.timeout:
                continue
            except:
                if self.stop_event.is_set():
                    break
                continue
            self._track(conn)
            threading.Thread(target=self._handle_client, args=(conn,), daemon=True).start()

    def _close_write(self, conn):
        try:
            conn.shutdown(socket.SHUT_WR)
        except:
            pass

    def _bridge_tcp(self, left, right):
        done = threading.Event()
        def _forward(src, dst):
            try:
                while not done.is_set():
                    chunk = src.recv(65536)
                    if not chunk:
                        break
                    dst.sendall(chunk)
            except:
                pass
            done.set()
            self._close_write(dst)
        t1 = threading.Thread(target=_forward, args=(left, right), daemon=True)
        t2 = threading.Thread(target=_forward, args=(right, left), daemon=True)
        t1.start()
        t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        try:
            if t1.is_alive():
                t1.join(0.5)
        except Exception:
            pass
        try:
            if t2.is_alive():
                t2.join(0.5)
        except Exception:
            pass
        for item in (left, right):
            try:
                item.close()
            except:
                pass
            self._untrack(item)

    def _bridge_ws(self, client, ws):
        return self._bridge_ws_split(client, ws, None)

    def _bridge_ws_split(self, client, ws, splitter):
        done = threading.Event()
        def _client_to_ws():
            try:
                while not done.is_set():
                    chunk = client.recv(65536)
                    if not chunk:
                        if splitter is not None:
                            try:
                                tail = splitter.flush() if hasattr(splitter, "flush") else []
                            except Exception:
                                tail = []
                            for p in list(tail or []):
                                try:
                                    ws.send(p)
                                except Exception:
                                    break
                        break
                    if splitter is not None:
                        parts = splitter.split(chunk)
                        if len(parts) > 1:
                            try:
                                ws.send_batch(parts)
                            except Exception:
                                for p in parts:
                                    ws.send(p)
                        else:
                            ws.send(parts[0])
                    else:
                        ws.send(chunk)
            except:
                pass
            done.set()
        def _ws_to_client():
            try:
                while not done.is_set():
                    payload = ws.recv()
                    if not payload:
                        break
                    client.sendall(payload)
            except:
                pass
            done.set()
        t1 = threading.Thread(target=_client_to_ws, daemon=True)
        t2 = threading.Thread(target=_ws_to_client, daemon=True)
        t1.start()
        t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        try:
            if t1.is_alive():
                t1.join(0.5)
        except Exception:
            pass
        try:
            if t2.is_alive():
                t2.join(0.5)
        except Exception:
            pass
        try:
            client.close()
        except:
            pass
        self._untrack(client)

    def _bridge_ws_split_with_pool(self, client, ws, splitter, dc=None, is_media=False):
        self._bridge_ws_split(client, ws, splitter)
        try:
            if ws is None:
                return
            if ws.is_closed():
                try:
                    self._untrack(ws)
                except Exception:
                    pass
                return
            self._ws_pool_put(dc, is_media, ws)
        except Exception:
            try:
                ws.close()
            except Exception:
                pass
            try:
                self._untrack(ws)
            except Exception:
                pass

    def _direct_passthrough(self, client, dst, port):
        remote = socket.create_connection((str(dst), int(port)), 10.0)
        self._track(remote)
        client.sendall(_tgws_socks_reply(0x00))
        self._bridge_tcp(client, remote)

    def _tcp_fallback(self, client, dst, port, init_packet):
        remote = socket.create_connection((str(dst), int(port)), 10.0)
        self._track(remote)
        if init_packet:
            remote.sendall(bytes(init_packet))
        self._bridge_tcp(client, remote)

    def _handle_client(self, conn):
        try:
            conn.settimeout(10.0)
            header = _tgws_recv_exact(conn, 2)
            if header[0] != 0x05:
                return
            n_methods = header[1]
            methods = _tgws_recv_exact(conn, n_methods)
            auth_user = str(getattr(self, "_auth_user", "") or "")
            auth_pass = str(getattr(self, "_auth_pass", "") or "")
            if auth_user and auth_pass:
                if 0x02 not in bytes(methods):
                    conn.sendall(b"\x05\xff")
                    return
                conn.sendall(b"\x05\x02")
                sub_ver = _tgws_recv_exact(conn, 1)
                if sub_ver[0] != 0x01:
                    conn.sendall(b"\x01\x01")
                    return
                ulen = _tgws_recv_exact(conn, 1)[0]
                provided_user = _tgws_recv_exact(conn, ulen).decode("utf-8", errors="ignore")
                plen = _tgws_recv_exact(conn, 1)[0]
                provided_pass = _tgws_recv_exact(conn, plen).decode("utf-8", errors="ignore")
                if provided_user != auth_user or provided_pass != auth_pass:
                    conn.sendall(b"\x01\x01")
                    return
                conn.sendall(b"\x01\x00")
            else:
                conn.sendall(b"\x05\x00")
            req = _tgws_recv_exact(conn, 4)
            if req[1] != 0x01:
                conn.sendall(_tgws_socks_reply(0x07))
                return
            atyp = int(req[3])
            dst, port = _tgws_read_socks_address(conn, atyp)
            dst_ip = str(dst)
            if atyp == 0x03:
                try:
                    resolved = _tgws_resolve_ipv4(dst)
                    if resolved:
                        dst_ip = resolved
                except Exception:
                    pass
            if not _tgws_is_telegram_ip(dst_ip):
                try:
                    self._direct_passthrough(conn, dst, port)
                except:
                    try:
                        conn.sendall(_tgws_socks_reply(0x05))
                    except:
                        pass
                return
            conn.sendall(_tgws_socks_reply(0x00))
            conn.settimeout(15.0)
            init_packet = _tgws_recv_exact(conn, 64)
            conn.settimeout(None)
            if _tgws_is_http_transport(init_packet):
                return
            dc, is_media, proto_int = _tgws_parse_init_meta(init_packet)
            try:
                if dc is not None:
                    dc_eff = int(TGWS_DC_OVERRIDES.get(int(dc), int(dc)))
                    if str(dc_eff) in (self.dc_ip or {}):
                        dc = int(dc_eff)
                    elif str(dc) not in (self.dc_ip or {}):
                        dc = None
            except Exception:
                pass
            init_patched = False
            if dc is None:
                try:
                    entry = _TGWS_IP_TO_DC.get(str(dst_ip))
                    if entry is not None:
                        dc = int(entry[0])
                        if not bool(is_media):
                            is_media = bool(entry[1])
                        target_ip0 = str((self.dc_ip or {}).get(str(dc), "") or "").strip()
                        if target_ip0:
                            init_packet = _tgws_patch_init_dc(init_packet, dc if is_media else -dc)
                            init_patched = True
                except Exception:
                    pass
            if dc is None:
                try:
                    if _tgws_is_telegram_ip(dst_ip) and ":" in str(dst_ip):
                        dcd = _tgws_default_dc(self.dc_ip)
                        if dcd is not None:
                            dc = int(dcd)
                            is_media = False
                except Exception:
                    pass
            if dc is None:
                self._tcp_fallback(conn, dst, port, init_packet)
                return
            target_ip = str((self.dc_ip or {}).get(str(dc), "") or "").strip()
            dc_key = (int(dc), bool(is_media))
            try:
                if dc_key in self.ws_blacklist:
                    self._tcp_fallback(conn, dst, port, init_packet)
                    return
            except Exception:
                pass
            fail_until = float(self.fail_until.get(dc_key, 0.0) or 0.0)
            try:
                now0 = time.time()
                ws_timeout = float(TGWS_WS_FAIL_TIMEOUT_SEC) if now0 < fail_until else float(TGWS_WS_CONNECT_TIMEOUT_SEC)
            except Exception:
                ws_timeout = float(TGWS_WS_CONNECT_TIMEOUT_SEC)
            ws = None
            last_ws_exc = None
            ws_failed_redirect = False
            all_redirects = True
            try:
                ws = self._ws_pool_get(dc, is_media)
                if ws is not None:
                    all_redirects = False
            except Exception:
                ws = None
            for candidate_ip in _tgws_unique_values(target_ip, dst_ip):
                if ws is not None:
                    break
                domains = _tgws_ws_domains(dc, is_media)
                try:
                    pref = str(self.ws_domain_pref.get(dc_key) or "").strip()
                except Exception:
                    pref = ""
                if pref:
                    domains = [pref] + [d for d in domains if d != pref]
                for domain in domains:
                    for connect_host in _tgws_unique_values(candidate_ip, _tgws_resolve_ipv4(domain), domain):
                        if ws is not None:
                            break
                        if not str(connect_host or "").strip():
                            continue
                        try:
                            ws = _TgWsRawWebSocket.connect(connect_host, domain, timeout=ws_timeout)
                            try:
                                now = time.time()
                                if now - float(self._last_ws_event_at or 0.0) > 10.0:
                                    self._last_ws_event_at = now
                            except Exception:
                                pass
                            try:
                                self.ws_domain_pref[dc_key] = str(domain)
                            except Exception:
                                pass
                            all_redirects = False
                            break
                        except Exception as e:
                            last_ws_exc = e
                            try:
                                if str(e).startswith("HTTP/") and " 30" in str(e):
                                    ws_failed_redirect = True
                                    continue
                            except Exception:
                                pass
                            all_redirects = False
                            ws = None
                    if ws is not None:
                        break
                if ws is not None:
                    break
            if ws is None:
                try:
                    for domain in self._cf_domains_for_dc(dc, is_media):
                        try:
                            ip4 = _tgws_resolve_ipv4(domain)
                            if ip4:
                                ws = _TgWsRawWebSocket.connect(ip4, domain, timeout=ws_timeout)
                            else:
                                ws = _TgWsRawWebSocket.connect(domain, domain, timeout=ws_timeout)
                            try:
                                base = str(domain).split(".", 1)[1]
                                if base:
                                    self._cf_pref[int(dc)] = base
                            except Exception:
                                pass
                            all_redirects = False
                            break
                        except Exception as e_cf:
                            last_ws_exc = e_cf
                            continue
                except Exception:
                    pass
            if ws is None:
                try:
                    if ws_failed_redirect and all_redirects:
                        self.ws_blacklist.add(dc_key)
                except Exception:
                    pass
                self.fail_until[dc_key] = time.time() + float(TGWS_WS_FAIL_COOLDOWN_SEC)
                self._tcp_fallback(conn, dst, port, init_packet)
                return
            self.fail_until.pop(dc_key, None)
            self._track(ws)
            ws.send(init_packet)
            splitter = None
            try:
                splitter = _TgWsMsgSplitter(init_packet, proto_int)
            except Exception:
                splitter = None
            self._bridge_ws_split_with_pool(conn, ws, splitter, dc=dc, is_media=is_media)
            return
        except:
            pass
        finally:
            try:
                conn.close()
            except:
                pass

def _sub_body_kind(text):
    try:
        s = str(text or "").lstrip()
        if not s:
            return "empty"
        low = s.lower()
        for scheme in _PROXY_SCHEMES:
            if scheme in low:
                return "uri-list:" + scheme.replace("://", "")
        if s[0] in "{[":
            return "json"
        if low.startswith("proxies:") or "\nproxies:" in low:
            return "clash-yaml"
        sample = s[:64]
        if sample and sum(c.isalnum() or c in "+/=_-" for c in sample) >= int(len(sample) * 0.95):
            return "base64?"
        return "unknown"
    except Exception:
        return "?"

def _fetch_vless_nodes(url):
    try:
        url2 = str(url or "")
        text = str(_fetch_text_url(url2, timeout_sec=15.0) or "").strip()
        if not text:
            _log("sub parse: empty body (fetch failed or no content)")
            return []
        _log(f"sub parse: got {len(text)} bytes ({_sub_body_kind(text)})")
        if all(s not in text for s in _PROXY_SCHEMES):
            try:
                b64 = str(text or "").strip()
                b64 = b64.replace("\n", "").replace("\r", "")
                b64 = b64.replace("-", "+").replace("_", "/")
                missing = len(b64) % 4
                if missing:
                    b64 += "=" * (4 - missing)
                raw = base64.b64decode(b64, validate=False)
                text = raw.decode("utf-8", errors="ignore")
                _log(f"sub parse: base64-decoded -> {len(text)} bytes ({_sub_body_kind(text)})")
            except Exception:
                pass
        nodes = []
        links = []
        for line in str(text or "").splitlines():
            line = str(line or "").strip()
            if not line:
                continue
            low_line = line.lower()
            if any(low_line.startswith(scheme) for scheme in _PROXY_SCHEMES):
                links.append(line)
                continue
            try:
                links.extend(PROXY_URI_RE.findall(line))
            except Exception:
                continue
        if not links:
            try:
                raw = str(text or "").lstrip()
                if raw.startswith("{"):
                    obj = json.loads(raw)
                    if isinstance(obj, dict):
                        arr = obj.get("links")
                        if isinstance(arr, list):
                            for it in arr:
                                s = str(it or "").strip()
                                if s:
                                    links.append(s)
                        ssc = obj.get("ssConfLinks")
                        if isinstance(ssc, dict):
                            for v in ssc.values():
                                s = str(v or "").strip()
                                if s:
                                    links.append(s)
                        elif isinstance(ssc, list):
                            for v in ssc:
                                s = str(v or "").strip()
                                if s:
                                    links.append(s)
                        if links:
                            _log(f"sub parse: {len(links)} links from Remnawave JSON")
                        elif obj.get("isFound") is not None:
                            _log("sub parse: Remnawave JSON but links[] empty (check UA / panel config)")
            except Exception:
                pass
        if not links:
            try:
                raw = str(text or "").lstrip()
                if raw.startswith("{") or raw.startswith("["):
                    def _walk(obj, out):
                        if isinstance(obj, dict):
                            t = obj.get("type")
                            p = obj.get("protocol")
                            if str(t).lower() == "vless" or str(p).lower() == "vless":
                                out.append(obj)
                            for v in obj.values():
                                _walk(v, out)
                        elif isinstance(obj, list):
                            for v in obj:
                                _walk(v, out)
                    parsed = json.loads(raw)
                    found = []
                    _walk(parsed, found)
                    for ob in found:
                        try:
                            uuid_str = ob.get("uuid") or ob.get("id") or ob.get("user")
                            server = ob.get("server") or ob.get("address")
                            port = ob.get("server_port") or ob.get("port")
                            if not uuid_str:
                                users = ob.get("users")
                                if isinstance(users, list) and users:
                                    u0 = users[0] if isinstance(users[0], dict) else None
                                    if u0:
                                        uuid_str = u0.get("uuid") or u0.get("id") or u0.get("user")
                            if (not uuid_str or not server or not port) and isinstance(ob.get("settings"), dict):
                                st = ob.get("settings") or {}
                                vnext = st.get("vnext")
                                if isinstance(vnext, list):
                                    for vn in vnext:
                                        try:
                                            if not isinstance(vn, dict):
                                                continue
                                            server2 = vn.get("address") or vn.get("server") or vn.get("address")
                                            port2 = vn.get("port")
                                            users2 = vn.get("users")
                                            uuid2 = None
                                            if isinstance(users2, list) and users2:
                                                u = users2[0] if isinstance(users2[0], dict) else None
                                                if u:
                                                    uuid2 = u.get("id") or u.get("uuid")
                                            if not uuid2 or not server2 or not port2:
                                                continue
                                            link2 = f"vless://{uuid2}@{server2}:{int(port2)}"
                                            tag2 = ob.get("tag") or ob.get("name") or ""
                                            if tag2:
                                                link2 += "#" + urllib.parse.quote(str(tag2))
                                            links.append(link2)
                                        except Exception:
                                            continue
                                continue
                            if not uuid_str or not server or not port:
                                continue
                            tls = ob.get("tls") or {}
                            security = ""
                            sni = ""
                            if isinstance(tls, dict):
                                enabled = tls.get("enabled")
                                if enabled is True or str(enabled).lower() == "true":
                                    security = "tls"
                                sni = tls.get("server_name") or tls.get("sni") or ""
                            transport = ob.get("transport") or {}
                            net = "tcp"
                            path = ""
                            host = ""
                            if isinstance(transport, dict):
                                net = transport.get("type") or transport.get("network") or net
                                net = str(net or "tcp")
                                path = transport.get("path") or ""
                                headers2 = transport.get("headers") or {}
                                if isinstance(headers2, dict):
                                    host = headers2.get("Host") or headers2.get("host") or ""
                            params = {}
                            if security:
                                params["security"] = security
                            if sni:
                                params["sni"] = str(sni)
                            if net:
                                params["type"] = str(net)
                            if path:
                                params["path"] = str(path)
                            if host:
                                params["host"] = str(host)
                            qs = "&".join([f"{urllib.parse.quote(str(k))}={urllib.parse.quote(str(v))}" for k, v in params.items()])
                            tag = ob.get("tag") or ob.get("name") or ""
                            frag = urllib.parse.quote(str(tag)) if tag else ""
                            link = f"vless://{uuid_str}@{server}:{int(port)}"
                            if qs:
                                link += "?" + qs
                            if frag:
                                link += "#" + frag
                            links.append(link)
                        except Exception:
                            continue
            except Exception:
                pass
        if not links:
            for line in str(text or "").splitlines():
                line = str(line or "").strip()
                if line.startswith("vless://"):
                    links.append(line)
        seen_uris = set()
        dedup_off = False
        try:
            dedup_off = bool(getattr(_fetch_vless_nodes, "_dedup_off", False))
        except Exception:
            dedup_off = False
        for link in links:
            try:
                link = _sanitize_vless_uri(str(link or "").strip())
                if not _is_proxy_uri(link):
                    continue
                if not dedup_off:
                    k = _node_named_dedup_key(link)
                    if not k:
                        k = link
                    if k in seen_uris:
                        continue
                    seen_uris.add(k)
                conf, name = VlessConfigParser.parse(link, 1080)
                if conf:
                    name_s = str(name or "").strip()
                    if _is_generic_node_name(name_s):
                        recovered = _name_from_uri(link)
                        if recovered:
                            name_s = recovered
                    if not name_s:
                        name_s = Z("vless_node_default")
                    nodes.append({"name": name_s, "uri": link, "ping": -1})
            except Exception:
                continue
        _log(f"sub parse: {len(links)} links -> {len(nodes)} nodes")
        return nodes
    except Exception as e:
        _log(f"sub parse error: {e}")
        return []

class exitfyPlugin(BasePlugin):
    def _safe_hook_method(self, method_obj, hook_obj):
        try:
            if method_obj is None or hook_obj is None:
                return False
            if not hasattr(self, "_hook_refs"):
                self._hook_refs = []
            if not hasattr(self, "_hooked_sigs"):
                self._hooked_sigs = set()
            try:
                sig = str(method_obj)
            except Exception:
                sig = None
            if sig and sig in self._hooked_sigs:
                return True
            result = self.hook_method(method_obj, hook_obj)
            self._hook_refs.append(hook_obj)
            if result is not None:
                self._hook_refs.append(result)
            if sig:
                self._hooked_sigs.add(sig)
            return True
        except Exception as e:
            return False

    def _normalize_mode(self, raw_mode) -> int:
        try:
            mode = int(raw_mode)
        except Exception:
            mode = 1
        if mode not in (1, 2):
            return 1
        return mode

    def _selector_index_to_mode(self, raw_value) -> int:
        try:
            if isinstance(raw_value, bool):
                return 2 if raw_value else 1
        except Exception:
            pass
        try:
            idx = int(raw_value)
        except Exception:
            idx = None
        if idx is not None:
            return 1 if idx <= 0 else 2
        try:
            s = str(raw_value or "").strip().lower()
            if not s:
                return 1
            if "tg" in s or "ws" in s:
                return 2
            if "server" in s or "—Ā–Ķ—Ä–≤–Ķ—Ä" in s:
                return 1
            if s in ("vless", Z("mode_vless").lower()):
                return 1
            if s in ("tgws", Z("mode_tgws").lower()):
                return 2
        except Exception:
            pass
        return 1

    def _mode_to_selector_index(self, mode_value) -> int:
        mode = self._normalize_mode(mode_value)
        return 0 if mode == 1 else 1

    def _normalize_provider(self, raw_provider) -> int:
        valid_ids = set(PROVIDER_IDS)
        try:
            v = int(raw_provider)
            if v == CUSTOM_PROVIDER_ID:
                return CUSTOM_PROVIDER_ID
            if v in valid_ids:
                return int(v)
            order = self._provider_selector_order()
            if 0 <= v < len(order):
                return int(order[v])
        except Exception:
            pass
        try:
            s = str(raw_provider or "").strip().lower()
            if not s:
                return int(DEFAULT_PROVIDER_ID)
            if "custom" in s or "–ļ–į—Ā—ā–ĺ–ľ" in s or s in ("3", "custom"):
                return CUSTOM_PROVIDER_ID
            for p in VLESS_PROVIDERS:
                pid = int(p.get("id"))
                if s == str(pid):
                    return pid
                if s == str(p.get("name", "")).strip().lower():
                    return pid
                for alias in list(p.get("aliases", []) or []):
                    if s == str(alias or "").strip().lower():
                        return pid
        except Exception:
            pass
        return int(DEFAULT_PROVIDER_ID)

    def _provider_selector_items(self):
        return [PROVIDER_NAMES.get(pid, str(pid)) for pid in PROVIDER_IDS] + [Z("vless_prov_custom")]

    def _provider_selector_order(self):
        return list(PROVIDER_IDS) + [int(CUSTOM_PROVIDER_ID)]

    def _provider_to_selector_index(self, provider_value) -> int:
        p = self._normalize_provider(provider_value)
        order = self._provider_selector_order()
        try:
            return int(order.index(p))
        except Exception:
            pass
        return 0

    def _selector_value_to_provider(self, raw_value) -> int:
        try:
            idx = int(raw_value)
            order = self._provider_selector_order()
            if 0 <= idx < len(order):
                return int(order[idx])
        except Exception:
            pass
        try:
            return self._normalize_provider(raw_value)
        except Exception:
            pass
        try:
            s = str(raw_value or "").strip()
            if not s:
                return int(DEFAULT_PROVIDER_ID)
            s_low = s.lower()
            for p in VLESS_PROVIDERS:
                pid = int(p.get("id"))
                if s_low == str(p.get("name", "")).strip().lower():
                    return pid
                for alias in list(p.get("aliases", []) or []):
                    if s_low == str(alias or "").strip().lower():
                        return pid
            if s_low == Z("vless_prov_custom").lower():
                return int(CUSTOM_PROVIDER_ID)
        except Exception:
            pass
        return int(DEFAULT_PROVIDER_ID)

    def _provider_bucket_key(self, provider) -> str:
        return str(self._normalize_provider(provider))

    def _default_provider_bucket_key(self) -> str:
        return str(int(DEFAULT_PROVIDER_ID))

    def _is_advanced_local_settings_enabled(self) -> bool:
        try:
            return bool(self.get_setting("vless_advanced_enabled", False))
        except Exception:
            return False

    def _normalize_local_host(self, raw_host) -> str:
        try:
            host = str(raw_host or "").strip()
        except Exception:
            host = ""
        if not host:
            return "127.0.0.1"
        if host.lower() == "localhost":
            return "127.0.0.1"
        try:
            socket.inet_aton(host)
            return host
        except Exception:
            pass
        return "127.0.0.1"

    def _local_host(self) -> str:
        if not self._is_advanced_local_settings_enabled():
            return "127.0.0.1"
        return self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1"))

    def _apply_runtime_local_host(self) -> str:
        global VLESS_LOCAL_HOST, vless_local_host
        host = self._normalize_local_host(self._local_host())
        VLESS_LOCAL_HOST = host
        vless_local_host = host
        return host

    def _normalize_local_port(self, raw_port) -> int:
        try:
            port = int(raw_port)
        except Exception:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        if port < 1024 or port > 65535:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        return int(port)

    def _pick_random_local_port(self) -> int:
        self._apply_runtime_local_host()
        for _ in range(48):
            try:
                p = random.randint(20000, 55000)
            except Exception:
                p = 0
            if p > 0 and self._is_local_port_free(p):
                return int(p)
        try:
            p = int(_get_free_port())
            if p >= 1024 and p <= 65535 and self._is_local_port_free(p):
                return int(p)
        except Exception:
            pass
        return int(DEFAULT_LOCAL_PROXY_PORT)

    def _local_port(self) -> int:
        if self._is_advanced_local_settings_enabled():
            return self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT)))
        try:
            runtime_port = self._vless_runtime_port_alive()
            if runtime_port > 0:
                self._runtime_random_local_port = int(runtime_port)
                return int(runtime_port)
        except Exception:
            pass
        try:
            cached = int(getattr(self, "_runtime_random_local_port", 0) or 0)
        except Exception:
            cached = 0
        if cached > 0 and self._is_local_port_free(cached):
            return int(cached)
        try:
            stable = int(self.get_setting("vless_stable_port", 0) or 0)
        except Exception:
            stable = 0
        if 1024 <= stable <= 65535 and self._is_local_port_free(stable):
            self._runtime_random_local_port = int(stable)
            return int(stable)
        p = int(self._pick_random_local_port())
        self._runtime_random_local_port = int(p)
        try:
            self.set_setting("vless_stable_port", int(p), reload_settings=False)
        except Exception:
            pass
        return int(p)

    def _is_local_port_free(self, port: int) -> bool:
        try:
            host = self._apply_runtime_local_host()
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((host, int(port)))
            return True
        except Exception:
            return False

    def _wait_local_port_free(self, port: int, timeout_sec: float = 1.8) -> bool:
        deadline = time.time() + float(max(0.2, timeout_sec))
        while time.time() < deadline:
            if self._is_local_port_free(int(port)):
                return True
            time.sleep(0.08)
        return self._is_local_port_free(int(port))

    def _stable_debounce(self, key, interval_ms=650) -> bool:
        try:
            k = str(key or "default")
            now = int(time.time() * 1000)
            try:
                last_map = getattr(self, "_stable_last_action_ms", None)
                if not isinstance(last_map, dict):
                    last_map = {}
                    self._stable_last_action_ms = last_map
            except Exception:
                last_map = {}
                self._stable_last_action_ms = last_map
            last = int(last_map.get(k, 0) or 0)
            if last > 0 and now - last < int(interval_ms):
                return True
            last_map[k] = now
        except Exception:
            return False
        return False

    def _vless_runtime_port_alive(self) -> int:
        try:
            if not bool(getattr(self, "_vless_running", False)):
                return 0
            port = int(getattr(self, "_vless_runtime_port", 0) or getattr(self, "_vless_port", 0) or 0)
            if port > 0 and _check_vless_port(port, timeout=0.05):
                return int(port)
        except Exception:
            pass
        return 0

    def _reapply_vless_runtime_proxy(self) -> bool:
        port = self._vless_runtime_port_alive()
        if not port:
            return False
        try:
            _su, _sp = self._socks_auth if hasattr(self, "_socks_auth") else ("", "")
            _vless_apply_tg_proxy(int(port), True, socks_user=_su, socks_pass=_sp,
                                  display_name=_proxy_label_for_uri(getattr(self, "_vless_runtime_uri", "") or getattr(self, "_vless_active_uri", "")))
            return True
        except Exception:
            return False

    def _on_network_changed(self):
        try:
            mode = self._normalize_mode(self.get_setting("mode", 1))
        except Exception:
            mode = 1
        if mode == 2 and bool(getattr(self, "_tgws_running", False)):
            _safe_log("network changed -> refreshing TG WS upstream")
            try:
                self._tgws_core.handle_network_change()
            except Exception as e:
                _safe_log(f"tgws network-change failed: {e}")
        elif mode == 1 and bool(getattr(self, "_vless_running", False)):
            if self._vless_runtime_port_alive():
                _safe_log("network changed -> sing-box re-binding, re-applying proxy")
                self._reapply_vless_runtime_proxy()
            elif bool(getattr(self, "_vless_active_uri", "")):
                _safe_log("network changed -> core port dead, reconnecting")
                threading.Thread(target=lambda: self._vless_connect(force=True), daemon=True).start()

    def _restart_active_tunnel_if_running(self, mode_value=None, was_vless=None, was_tgws=None, force=False):
        mode = self._normalize_mode(self.get_setting("mode", 1) if mode_value is None else mode_value)
        if was_vless is None:
            was_vless = bool(getattr(self, "_vless_running", False))
        if was_tgws is None:
            was_tgws = bool(getattr(self, "_tgws_running", False))
        if mode == 1 and was_vless:
            threading.Thread(target=lambda: self._vless_connect(force=bool(force)), daemon=True).start()
        elif mode == 2 and was_tgws:
            threading.Thread(target=self._tgws_connect_bg, daemon=True).start()

    def _start_vless_runtime(self, install_clipboard=False, init_sub=False):
        self._ping_stop.clear()
        self._health_stop.clear()
        threading.Thread(target=self._vless_pinger_loop, daemon=True).start()
        if bool(install_clipboard):
            try:
                self._install_clipboard_hook()
            except Exception:
                pass
        if bool(init_sub):
            try:
                threading.Thread(target=self._init_default_vless_sub, args=(self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID))),), daemon=True).start()
            except Exception:
                pass
        if self.get_setting("vless_enabled", False) and self._vless_active_uri:
            threading.Thread(target=self._vless_connect, daemon=True).start()

    def _start_tgws_runtime(self, auto_start=False, delay_ms=0):
        def _run():
            threading.Thread(target=self._tgws_connect_bg, kwargs={"auto_start": bool(auto_start)}, daemon=True).start()
        try:
            d = int(delay_ms or 0)
        except Exception:
            d = 0
        if d > 0:
            try:
                run_on_ui_thread(_run, d)
                return
            except Exception:
                pass
        _run()

    def _open_spinner_dialog(self, act, title_key="addon_download_title", message_key="addon_downloading"):
        try:
            b = AlertDialogBuilder(act, AlertDialogBuilder.ALERT_TYPE_SPINNER)
            try:
                b.set_title(Z(title_key))
            except:
                pass
            try:
                b.set_message(Z(message_key))
            except:
                pass
            b.show()
            try:
                b.set_cancelable(False)
            except:
                pass
            try:
                b.set_canceled_on_touch_outside(False)
            except:
                pass
            return b
        except Exception as e:
            pass
        return None

    def _close_dialog_safe(self, dialog_obj):
        try:
            if dialog_obj:
                dialog_obj.dismiss()
        except:
            pass

    def _node_display_label(self, node):
        try:
            ping = _to_int(node.get("ping", -1), -1)
        except Exception:
            ping = -1
        ping_str = f"{ping} ms: " if ping > 0 else ""
        try:
            base = str(node.get("name", Z("vless_node_default")) or Z("vless_node_default"))
        except Exception:
            base = Z("vless_node_default")
        if _is_generic_node_name(base):
            recovered = _name_from_uri(node.get("uri", ""))
            if recovered:
                base = recovered
            else:
                base = Z("vless_node_default")
        return ping_str + base

    def on_plugin_load(self):
        self._state = ConnState.DISCONNECTED
        self._state_detail = ""
        self._net_monitor = NetworkMonitor(self._on_network_changed)
        self._vless_core = VlessCore(defer=True)
        self._vless_port = 20808
        self._vless_running = False
        self._ping_event = threading.Event()
        self._ping_stop = threading.Event()
        self._health_stop = threading.Event()
        self._health_fail_count = 0
        self._is_foreground = True
        self._last_clipboard_uri = ""
        self._chat_menu_item_id = "exitfy_settings_chat"
        self._drawer_menu_item_id = "exitfy_settings_drawer"
        self._tgws_core = TgWsCore()
        self._tgws_port = 0
        self._tgws_running = False
        self._tgws_proxy_snapshot = None
        self._tgws_proxy_managed = False
        self._runtime_random_local_port = 0
        self._vless_connect_lock = threading.Lock()
        self._tgws_connect_lock = threading.Lock()
        self._vless_connect_generation = 0
        self._tgws_connect_generation = 0
        self._vless_runtime_uri = ""
        self._vless_runtime_provider = int(DEFAULT_PROVIDER_ID)
        self._vless_runtime_port = 0
        self._vless_selected_provider = int(DEFAULT_PROVIDER_ID)
        self._stable_last_action_ms = {}
        self._vless_data = _new_vless_data()
        self._vless_active_uri = ""
        self._vless_data_custom = _new_vless_data()
        self._vless_data_default = _new_vless_data()
        self._vless_data_default_map = {str(p): _new_vless_data() for p in PROVIDER_IDS}
        try:
            self._vless_data = _clone_vless_data(self.get_setting("vless_data", _new_vless_data()))
            self._vless_active_uri = str(self._vless_data.get("active_uri", "") or "")
            self._vless_data_custom = _clone_vless_data(self.get_setting("vless_data_custom", _new_vless_data()))
            self._vless_data_default = _clone_vless_data(self.get_setting("vless_data_default", _new_vless_data()))
            raw_default_map = self.get_setting("vless_data_default_map", {})
            if not isinstance(raw_default_map, dict):
                raw_default_map = {}
            self._vless_data_default_map = {}
            for p in PROVIDER_IDS:
                k = str(p)
                data_src = raw_default_map.get(k)
                if not isinstance(data_src, dict) and int(p) == int(DEFAULT_PROVIDER_ID):
                    data_src = self._vless_data_default
                self._vless_data_default_map[k] = _clone_vless_data(data_src)
            self._vless_data_default = _clone_vless_data(self._vless_data_default_map.get(self._default_provider_bucket_key(), _new_vless_data()))
        except Exception as e:
            import traceback as _tb
            _log("on_plugin_load data load failed (using defaults): " + repr(e) + " :: " + _tb.format_exc())
            self._vless_data = _new_vless_data()
            self._vless_active_uri = ""
            self._vless_data_custom = _new_vless_data()
            self._vless_data_default = _new_vless_data()
            self._vless_data_default_map = {str(p): _new_vless_data() for p in PROVIDER_IDS}
        try:
            self._last_vless_provider = self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID)))
        except:
            self._last_vless_provider = 0
        try:
            self.set_setting("vless_provider", int(self._last_vless_provider), reload_settings=False)
            self.set_setting("vless_provider_selector", self._provider_to_selector_index(self._last_vless_provider), reload_settings=False)
            self.set_setting("vless_data_default_map", self._vless_data_default_map, reload_settings=False)
        except Exception:
            pass
        try:
            self._vless_selected_provider = int(self._last_vless_provider)
            self._vless_runtime_provider = int(self._last_vless_provider)
        except Exception:
            pass
        try:
            if int(self._last_vless_provider) == int(CUSTOM_PROVIDER_ID):
                self._vless_data = _clone_vless_data(self._vless_data_custom)
            else:
                self._vless_data = _clone_vless_data(self._vless_data_default_map.get(self._provider_bucket_key(self._last_vless_provider), _new_vless_data()))
            self._vless_active_uri = str(self._vless_data.get("active_uri", "") or "")
        except Exception:
            pass
        self._ping_stop = threading.Event()
        self._vless_init_in_progress = False
        self._reload_ui_pending = False
        self._sub_cache = self.get_setting("vless_sub_cache", {})
        if not isinstance(self._sub_cache, dict):
            self._sub_cache = {}
        self._ping_cache = {}
        try:
            self._install_activity_result_hook()
        except:
            pass
        self._add_menu_items()
        try:
            self._install_voip_hook()
        except:
            pass
        try:
            self._install_resume_hook()
        except:
            pass
        mode = self._normalize_mode(self.get_setting("mode", 1))
        try:
            self.set_setting("mode", int(mode), reload_settings=False)
        except Exception:
            pass
        try:
            self.set_setting("mode_selector", self._mode_to_selector_index(mode), reload_settings=False)
        except Exception:
            pass
        try:
            _pset_str("exitfy_hwid_custom", str(self.get_setting("custom_hwid", "") or "").strip())
        except Exception:
            pass
        try:
            self.set_setting("vless_advanced_enabled", bool(self.get_setting("vless_advanced_enabled", False)), reload_settings=False)
        except Exception:
            pass
        try:
            self.set_setting("local_socks_host", self._local_host(), reload_settings=False)
        except Exception:
            pass
        try:
            self._apply_runtime_local_host()
        except Exception:
            pass
        try:
            if self._is_advanced_local_settings_enabled():
                self.set_setting("local_socks_port", self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT))), reload_settings=False)
        except Exception:
            pass
        try:
            legacy_proxy_enabled = bool(self.get_setting("proxy_enabled", False))
            tgws_enabled = bool(self.get_setting("tgws_enabled", False))
            if legacy_proxy_enabled and not tgws_enabled:
                self.set_setting("tgws_enabled", True, reload_settings=False)
            self.set_setting("proxy_enabled", False, reload_settings=False)
        except Exception:
            pass
        try:
            if not bool(self.get_setting("_stable_defaults_v3", False)):
                self.set_setting("vless_auto_switch", False, reload_settings=False)
                self.set_setting("_stable_defaults_v3", True, reload_settings=False)
        except Exception:
            pass
        def _bootstrap():
            try:
                self._net_monitor.start()
            except Exception as e:
                _safe_log(f"network monitor start failed: {e}")
            try:
                if VlessCore.core_file_exists():
                    self._vless_core.ensure_loaded()
            except Exception as e:
                _safe_log(f"core bootstrap failed: {e}")
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except Exception:
                pass
            try:
                if mode == 1:
                    self._start_vless_runtime(install_clipboard=True, init_sub=False)
                elif self.get_setting("tgws_enabled", False):
                    self._start_tgws_runtime(auto_start=True, delay_ms=700)
            except Exception as e:
                _safe_log(f"autostart failed: {e}")
        threading.Thread(target=_bootstrap, daemon=True).start()

    def on_plugin_unload(self):
        self._ping_stop.set()
        self._health_stop.set()
        try:
            if getattr(self, "_net_monitor", None):
                self._net_monitor.stop()
        except Exception:
            pass
        try:
            _was_tgws = bool(getattr(self, "_tgws_running", False) or getattr(self, "_tgws_proxy_managed", False))
        except Exception:
            _was_tgws = False
        try:
            self._tgws_disconnect_with_reason("plugin_unload", silent=True)
        except:
            pass
        if not _was_tgws:
            self._vless_disconnect(silent=True)
        self._remove_menu_items()

    def _tgws_get_static_field(self, cls, name, default=None):
        try:
            f = cls.getDeclaredField(str(name))
            f.setAccessible(True)
            return f.get(None)
        except Exception:
            return default

    def _tgws_set_static_field(self, cls, name, value):
        try:
            f = cls.getDeclaredField(str(name))
            f.setAccessible(True)
            f.set(None, value)
        except Exception:
            pass

    def _tgws_snapshot_current_proxy(self):
        if self._tgws_proxy_snapshot is not None:
            return
        try:
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            current = self._tgws_get_static_field(shared_config_cls, "currentProxyInfo", None)
            enabled = bool(self._tgws_get_static_field(shared_config_cls, "useProxySettings", False))
            snapshot = {
                "enabled": enabled,
                "host": "",
                "port": 0,
                "user": "",
                "password": "",
                "secret": "",
            }
            if current:
                snapshot["host"] = str(get_private_field(current, "address") or "")
                snapshot["port"] = int(get_private_field(current, "port") or 0)
                snapshot["user"] = str(get_private_field(current, "username") or "")
                snapshot["password"] = str(get_private_field(current, "password") or "")
                snapshot["secret"] = str(get_private_field(current, "secret") or "")
            self._tgws_proxy_snapshot = snapshot
        except Exception as exc:
            pass

    def _tgws_restore_previous_proxy(self):
        if not bool(getattr(self, "_tgws_proxy_managed", False)):
            return
        snapshot = getattr(self, "_tgws_proxy_snapshot", None)
        try:
            if snapshot is None:
                return
            enabled = bool(snapshot.get("enabled", False))
            host = str(snapshot.get("host", "") or "")
            port = int(snapshot.get("port", 0) or 0)
            user = str(snapshot.get("user", "") or "")
            password = str(snapshot.get("password", "") or "")
            secret = str(snapshot.get("secret", "") or "")
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            try:
                self._tgws_set_static_field(shared_config_cls, "useProxySettings", bool(enabled))
            except Exception:
                pass
            try:
                if host and port > 0:
                    ProxyInfo = jclass("org.telegram.messenger.SharedConfig$ProxyInfo")
                    pinfo = ProxyInfo(host, int(port), user, password, secret)
                    try:
                        self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", pinfo)
                    except Exception:
                        pass
                    try:
                        SharedConfig.addProxy(pinfo)
                    except Exception:
                        pass
                else:
                    self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", None)
            except Exception:
                pass
            try:
                ConnectionsManager.setProxySettings(bool(enabled), host, int(port), user, password, secret)
            except Exception:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        cm = ConnectionsManager.getInstance(ac)
                        if cm:
                            cm.setProxySettings(bool(enabled), host, int(port), user, password, secret)
                except Exception:
                    pass
        finally:
            try:
                self._tgws_proxy_managed = False
            except Exception:
                pass
            try:
                self._tgws_proxy_snapshot = None
            except Exception:
                pass

    def _install_voip_hook(self):
        plugin_ref = self
        if jclass is None:
            return
        try:
            Class = jclass("java.lang.Class")
        except:
            return
        try:
            instance_cls = Class.forName("org.telegram.messenger.voip.Instance")
            proxy_cls = Class.forName("org.telegram.messenger.voip.Instance$Proxy")
        except:
            instance_cls = None
            proxy_cls = None
        if instance_cls is not None and proxy_cls is not None:
            try:
                ProxyCls = jclass("org.telegram.messenger.voip.Instance$Proxy")
            except:
                ProxyCls = None
            try:
                all_methods = instance_cls.getDeclaredMethods()
            except:
                all_methods = []
            try:
                for m in all_methods:
                    try:
                        mname = m.getName()
                        param_types = m.getParameterTypes()
                        proxy_arg_idx = -1
                        for i, pt in enumerate(param_types):
                            try:
                                pt_name = pt.getName()
                            except:
                                pt_name = ""
                            if "Proxy" in str(pt_name) and "[]" not in str(pt_name):
                                proxy_arg_idx = i
                                break
                        if proxy_arg_idx < 0:
                            continue
                        _idx = int(proxy_arg_idx)
                        _mname = str(mname)
                        class _ProxyInjectHook(MethodHook):
                            _pidx = _idx
                            _mn = _mname
                            def before_hooked_method(self, param):
                                try:
                                    running = bool(getattr(plugin_ref, "_vless_running", False)) or \
                                              bool(getattr(plugin_ref, "_tgws_running", False))
                                    if not running:
                                        return
                                    port = int(getattr(plugin_ref, "_vless_port", 0) or
                                               getattr(plugin_ref, "_tgws_port", 0) or 0)
                                    if port <= 0:
                                        return
                                    if ProxyCls is None:
                                        return
                                    _auth = getattr(plugin_ref, "_socks_auth", ("", ""))
                                    _su = str(_auth[0]) if _auth and len(_auth) > 0 else ""
                                    _sp = str(_auth[1]) if _auth and len(_auth) > 1 else ""
                                    proxy = ProxyCls(VLESS_LOCAL_HOST, int(port), _su, _sp)
                                    param.args[self._pidx] = proxy
                                except:
                                    pass
                        self._safe_hook_method(m, _ProxyInjectHook())
                    except:
                        continue
            except:
                pass
        try:
            voip_cls = None
            for cls_name in ("org.telegram.messenger.voip.VoIPService", "org.telegram.messenger.voip.VoIPBaseService"):
                try:
                    voip_cls = Class.forName(cls_name)
                    break
                except:
                    continue
            if voip_cls is not None:
                class _VoIPStartHook(MethodHook):
                    def before_hooked_method(self, param):
                        try:
                            if not bool(getattr(plugin_ref, "_vless_running", False)):
                                return
                            port = int(getattr(plugin_ref, "_vless_port", 0) or 0)
                            if port <= 0:
                                return
                            try:
                                SharedConfig.proxyEnabled = True
                            except:
                                pass
                            try:
                                ed = MessagesController.getGlobalMainSettings().edit()
                                ed.putBoolean("proxy_enabled_calls", True)
                                ed.putBoolean("proxy_calls_enabled", True)
                                ed.putBoolean("calls_use_proxy", True)
                                ed.commit()
                            except:
                                pass
                        except:
                            pass
                hook_targets = ("startCall", "startRinging", "acceptIncomingCall", "onCallUpdated", "startGroupCall")
                try:
                    for m in voip_cls.getDeclaredMethods():
                        try:
                            if m.getName() in hook_targets:
                                self._safe_hook_method(m, _VoIPStartHook())
                        except:
                            continue
                except:
                    pass
        except:
            pass

    def _core_type(self):
        v = str(self.get_setting("core_type", DEFAULT_CORE_TYPE) or DEFAULT_CORE_TYPE).strip().lower()
        return v if v in (CORE_TYPE_SINGBOX, CORE_TYPE_XRAY) else DEFAULT_CORE_TYPE

    def _active_parser(self):
        return XrayConfigParser if self._core_type() == CORE_TYPE_XRAY else VlessConfigParser

    def _core_download_base(self, core_type=None):
        ct = core_type or self._core_type()
        return CORE_DOWNLOAD_BASES.get(ct, CORE_DOWNLOAD_BASES[DEFAULT_CORE_TYPE])

    def _core_download_candidates(self, url_override=None, core_type=None):
        if str(url_override or "").strip():
            return [str(url_override).strip()]
        base = self._core_download_base(core_type)
        direct = []
        for abi in _device_abis():
            direct.append(f"{base}/libvless-{abi}.so")
        direct.append(f"{base}/libvless.so")
        urls = []
        for d in direct:
            urls.append(d)
            for mirror in GH_MIRRORS:
                urls.append(mirror + d)
        seen = set()
        out = []
        for u in urls:
            if u not in seen:
                seen.add(u)
                out.append(u)
        return out

    def _download_libvless_with_progress(self, on_progress, url_override=None, core_type=None):
        so_path = self._libvless_so_path(create_dir=True)
        if not so_path:
            return False
        dl_core_type = core_type or self._core_type()
        tmp_path = so_path + ".dl"
        for url in self._core_download_candidates(url_override, core_type=dl_core_type):
            try:
                r = requests.get(url, stream=True, timeout=(8, 30))
                if r.status_code != 200:
                    _safe_log(f"core download {url} -> HTTP {r.status_code}")
                    continue
                try:
                    total = int(r.headers.get("content-length") or 0)
                except Exception:
                    total = 0
                done = 0
                if callable(on_progress):
                    try: on_progress(0.0)
                    except Exception: pass
                with open(tmp_path, "wb") as f:
                    for chunk in r.iter_content(8192):
                        if not chunk:
                            continue
                        f.write(chunk)
                        done += len(chunk)
                        if callable(on_progress) and total > 0:
                            try: on_progress(float(done) / float(total))
                            except Exception: pass
                if callable(on_progress):
                    try: on_progress(1.0)
                    except Exception: pass
                if os.path.getsize(tmp_path) < 1024:
                    _safe_log(f"core download {url} too small")
                    continue
                ok, _err = _validate_core_elf(tmp_path)
                if not ok:
                    _safe_log(f"core download {url} failed validation: {_err}")
                    continue
                os.replace(tmp_path, so_path)
                try:
                    self.set_setting("installed_core_type", dl_core_type, reload_settings=False)
                except Exception:
                    pass
                _log(f"core downloaded ok ({dl_core_type}) from {url}")
                return True
            except Exception as e:
                _safe_log(f"core download {url} error: {e}")
                continue
            finally:
                try:
                    if os.path.exists(tmp_path):
                        os.remove(tmp_path)
                except Exception:
                    pass
        return False

    def _download_libvless_and_reload(self):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
        except:
            act = None
        if not act:
            threading.Thread(target=lambda: self._download_libvless_and_reload_bg(None), daemon=True).start()
            return
        dialog_box = {"builder": None}
        run_on_ui_thread(lambda: dialog_box.__setitem__("builder", self._open_spinner_dialog(act)))
        self._set_state(ConnState.LOADING, Z("st_detail_core"))
        def task():
            try:
                ok = self._download_libvless_with_progress(None)
                if ok:
                    self._vless_core = VlessCore()
                run_on_ui_thread(lambda: self._close_dialog_safe(dialog_box.get("builder")))
                if ok:
                    self._set_state(ConnState.DISCONNECTED)
                    _notify_ok(Z("addon_pick_file_ok"))
                else:
                    self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                    error_msg=Z("addon_download_error"))
            except Exception as e:
                run_on_ui_thread(lambda: self._close_dialog_safe(dialog_box.get("builder")))
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=Z("addon_download_error"))
        threading.Thread(target=task, daemon=True).start()

    def _download_libvless_and_reload_bg(self, on_progress, url_override=None):
        try:
            ok = self._download_libvless_with_progress(on_progress, url_override=url_override)
            if ok:
                self._vless_core = VlessCore()
            run_on_ui_thread(self._reload_settings_ui)
        except Exception as e:
            run_on_ui_thread(self._reload_settings_ui)

    def _install_activity_result_hook(self):
        try:
            plugin_ref = self
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            if not LaunchActivity:
                return
            class _ActivityResultHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        req = int(param.args[0])
                        res = int(param.args[1])
                        data = param.args[2]
                    except:
                        return
                    try:
                        if (int(req) & 0xFFFF) != FILE_PICKER_REQUEST_CODE:
                            return
                        _log(f"file picker result: req={req} res={res} hasData={data is not None}")
                        if int(res) != -1:
                            return
                        if not data:
                            return
                        try:
                            uri = data.getData()
                        except:
                            uri = None
                        if uri is None:
                            return
                        threading.Thread(target=plugin_ref._install_libvless_from_uri, args=(uri,), daemon=True).start()
                    except:
                        pass
            for m in LaunchActivity.getDeclaredMethods():
                try:
                    name = str(m.getName() or "")
                    if "onActivityResult" in name and len(m.getParameterTypes()) == 3:
                        self._safe_hook_method(m, _ActivityResultHook())
                        break
                except:
                    continue
        except:
            pass

    def _pick_libvless_file(self):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
        except Exception:
            act = None
        if not act:
            _notify_error(Z("addon_pick_file_error"))
            return
        try:
            from android.content import Intent
        except Exception:
            Intent = None
        if Intent is None:
            _notify_error(Z("addon_pick_file_error"))
            return
        for action in (Intent.ACTION_OPEN_DOCUMENT, Intent.ACTION_GET_CONTENT):
            try:
                intent = Intent(action)
                intent.addCategory(Intent.CATEGORY_OPENABLE)
                intent.setType("*/*")
                try:
                    intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                except Exception:
                    pass
                act.startActivityForResult(intent, FILE_PICKER_REQUEST_CODE)
                _log(f"file picker launched ({action})")
                return
            except Exception as e:
                _safe_log(f"file picker action {action} failed: {e}")
                continue
        _notify_error(Z("addon_pick_file_error"))

    def _install_libvless_from_uri(self, uri):
        dialog_box = {"builder": None}
        _log("core import: started from picked uri")
        self._set_state(ConnState.LOADING, Z("st_detail_core"))
        try:
            try:
                frag = get_last_fragment()
                act = frag.getParentActivity() if frag else None
            except Exception:
                act = None
            if act:
                run_on_ui_thread(lambda a=act: dialog_box.__setitem__("builder", self._open_spinner_dialog(a)))
        except Exception:
            pass

        def _fail(error_key):
            run_on_ui_thread(lambda: self._close_dialog_safe(dialog_box.get("builder")))
            self._set_state(ConnState.ERROR, Z("st_detail_core"), error_msg=Z(error_key))

        tmp_path = None
        try:
            ctx = ApplicationLoader.applicationContext
            cr = ctx.getContentResolver() if ctx else None
            if not cr:
                return _fail("addon_pick_file_error")
            try:
                from android.content import Intent
                take = int(Intent.FLAG_GRANT_READ_URI_PERMISSION) | int(Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION)
                cr.takePersistableUriPermission(uri, take)
            except Exception:
                pass

            inp = None
            try:
                inp = cr.openInputStream(uri)
            except Exception:
                inp = None
            if inp is None:
                return _fail("addon_pick_file_error")

            final_path = self._libvless_so_path(create_dir=True)
            if not final_path:
                try: inp.close()
                except Exception: pass
                return _fail("addon_pick_file_error")
            tmp_path = final_path + ".tmp"

            try:
                with open(tmp_path, "wb") as out:
                    buf = bytearray(8192)
                    while True:
                        try:
                            n = int(inp.read(buf))
                        except Exception:
                            break
                        if n <= 0:
                            break
                        out.write(bytes(buf[:n]))
            finally:
                try: inp.close()
                except Exception: pass

            try:
                if os.path.getsize(tmp_path) < 1024:
                    return _fail("addon_pick_file_bad")
            except Exception:
                return _fail("addon_pick_file_bad")
            ok, err_key = _validate_core_elf(tmp_path)
            if not ok:
                return _fail(err_key)

            try:
                os.replace(tmp_path, final_path)
                tmp_path = None
            except Exception as e:
                _safe_log(f"core atomic replace failed: {e}")
                return _fail("addon_pick_file_error")

            try:
                self._vless_core = VlessCore()
                loaded = bool(self._vless_core and self._vless_core.is_available())
            except Exception as e:
                _safe_log(f"core load after import failed: {e}")
                loaded = False
            run_on_ui_thread(lambda: self._close_dialog_safe(dialog_box.get("builder")))
            if not loaded:
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=Z("addon_core_load_failed"))
                return
            try:
                self.set_setting("installed_core_type", self._core_type(), reload_settings=False)
            except Exception:
                pass
            self._set_state(ConnState.DISCONNECTED)
            _notify_ok(Z("addon_pick_file_ok"))
        except Exception as e:
            _safe_log(f"_install_libvless_from_uri error: {e}")
            return _fail("addon_pick_file_error")
        finally:
            if tmp_path:
                try: os.remove(tmp_path)
                except Exception: pass

    def _exitfy_modules_dir(self, create=False):
        try:
            ctx = ApplicationLoader.applicationContext
            dir_path = os.path.join(str(ctx.getFilesDir()), "exitfy_modules")
            if create and not os.path.exists(dir_path):
                os.makedirs(dir_path)
            return dir_path
        except:
            return None

    def _libvless_so_path(self, create_dir=False):
        try:
            dir_path = self._exitfy_modules_dir(create=bool(create_dir))
            if not dir_path:
                return None
            return os.path.join(dir_path, "libvless.so")
        except:
            return None

    def _has_libvless_addon(self):
        try:
            p = self._libvless_so_path()
            return bool(p) and os.path.exists(p) and os.path.getsize(p) >= 1024
        except:
            return False

    def _delete_libvless_and_reload(self):
        try:
            self._vless_disconnect(silent=True)
        except:
            pass
        def task():
            ok = False
            try:
                p = self._libvless_so_path()
                if p and os.path.exists(p):
                    try:
                        os.remove(p)
                        ok = True
                    except Exception as e:
                        pass
                try:
                    self.set_setting("installed_core_type", "", reload_settings=False)
                except Exception:
                    pass
                self._vless_core = VlessCore()
            except Exception as e:
                pass
            run_on_ui_thread(self._reload_settings_ui)
            if not ok:
                try:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(Z("addon_delete_error")))
                except:
                    pass
        threading.Thread(target=task, daemon=True).start()

    def _migrate_core(self, retry_connect=False, reason="", force=False):
        if bool(getattr(self, "_core_migrating", False)):
            return
        if not force and str(self.get_setting("installed_core_type", "") or "") == self._core_type() \
                and VlessCore.core_file_exists() and self._vless_core.is_available():
            if retry_connect and bool(getattr(self, "_vless_active_uri", "")):
                threading.Thread(target=lambda: self._vless_connect(force=True), daemon=True).start()
            return
        self._core_migrating = True
        if reason:
            _notify_info(reason)
        self._set_state(ConnState.LOADING, Z("st_detail_core"))
        def task():
            loaded = False
            try:
                try:
                    self._vless_disconnect(silent=True)
                except Exception:
                    pass
                try:
                    self._vless_core.stop()
                except Exception:
                    pass
                try:
                    p = self._libvless_so_path()
                    if p and os.path.exists(p):
                        os.remove(p)
                        _log("migrate: removed old core")
                except Exception as e:
                    _safe_log(f"migrate: remove old core failed: {e}")
                try:
                    self.set_setting("installed_core_type", "", reload_settings=False)
                except Exception:
                    pass
                ok = self._download_libvless_with_progress(None)
                if ok:
                    self._vless_core = VlessCore()
                    loaded = self._vless_core.is_available()
                    _log(f"migrate: download ok, core loaded={loaded}")
                else:
                    _log("migrate: download failed")
            except Exception as e:
                _safe_log(f"migrate error: {e}")
            finally:
                self._core_migrating = False
            run_on_ui_thread(self._reload_settings_ui)
            if loaded:
                _notify_ok(Z("core_updated"))
                if retry_connect and bool(getattr(self, "_vless_active_uri", "")):
                    self._vless_connect(force=True)
                else:
                    self._set_state(ConnState.DISCONNECTED)
            else:
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=Z("addon_download_error"))
        threading.Thread(target=task, daemon=True).start()

    def _tgws_connect_bg(self, auto_start=False):
        ok = False
        try:
            ok = bool(self._tgws_connect(auto_start=bool(auto_start)))
        except Exception as e:
            try:
                self._tgws_last_error = str(e)
            except Exception:
                pass
            ok = False
        if not ok:
            msg = Z("tgws_connect_failed")
            try:
                last = str(getattr(self, "_tgws_last_error", "") or "").strip()
                if last:
                    msg = f"{Z('tgws_connect_failed')}: {last}"
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_error(str(msg)))
            except:
                pass
            if not bool(auto_start):
                try:
                    self.set_setting("tgws_enabled", False, reload_settings=True)
                except:
                    pass
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except:
                pass

    def _vless_fetch_nodes_cached(self, url, force=False):
        try:
            url_s = str(url or "").strip()
            if not url_s:
                return []
            dedup_off = bool(self.get_setting("vless_dedup_off", False))
            cache_key = hashlib.sha256((url_s + "|dedup_off=" + ("1" if dedup_off else "0")).encode("utf-8")).hexdigest()
            now_ts = int(time.time())
            if not force:
                entry = self._sub_cache.get(cache_key)
                if isinstance(entry, dict):
                    cached_nodes = entry.get("nodes")
                    cached_ts = _to_int(entry.get("ts", 0), 0)
                    if (isinstance(cached_nodes, list) and cached_nodes and
                            (now_ts - cached_ts) < int(VLESS_SUB_CACHE_TTL_SEC)):
                        return cached_nodes
            try:
                setattr(_fetch_vless_nodes, "_dedup_off", bool(dedup_off))
            except Exception:
                pass
            nodes = _fetch_vless_nodes(url_s)
            if isinstance(nodes, list) and nodes:
                self._sub_cache[cache_key] = {"ts": int(now_ts), "nodes": nodes}
                try:
                    if len(self._sub_cache) > 50:
                        sorted_items = sorted(
                            self._sub_cache.items(),
                            key=lambda kv: _to_int((kv[1] or {}).get("ts", 0), 0),
                            reverse=True
                        )
                        self._sub_cache = dict(sorted_items[:30])
                except Exception:
                    pass
                try:
                    self.set_setting("vless_sub_cache", self._sub_cache, reload_settings=False)
                except Exception:
                    pass
                return nodes
            return []
        except Exception:
            return []

    def _provider_sub_urls(self, provider):
        provider = self._normalize_provider(provider)
        return [
            _normalize_sub_url(u)
            for u in VLESS_PROVIDER_SUBS.get(provider, list(VLESS_PROVIDER_SUBS.get(int(DEFAULT_PROVIDER_ID), [])))
            if _normalize_sub_url(u)
        ]

    def _enforce_provider_subs(self, provider):
        provider = self._normalize_provider(provider)
        if provider == int(CUSTOM_PROVIDER_ID):
            return
        allowed = set(self._provider_sub_urls(provider))
        kept = []
        changed = False
        for sub in (self._vless_data.get("subs", []) or []):
            try:
                url = _normalize_sub_url(sub.get("url", ""))
            except Exception:
                url = ""
            if url in allowed:
                kept.append(sub)
            else:
                changed = True
        if changed:
            self._vless_data["subs"] = kept
            self._vless_save_data()

    def _init_default_vless_sub(self, provider=None):
        self._vless_init_in_progress = True
        if provider is None:
            provider = self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID))
        provider = self._normalize_provider(provider)
        if provider == int(CUSTOM_PROVIDER_ID):
            self._vless_init_in_progress = False
            return
        self._enforce_provider_subs(provider)
        urls = self._provider_sub_urls(provider)
        for url in urls:
            if not url:
                continue
            nodes = self._vless_fetch_nodes_cached(url, force=False)
            if nodes:
                if "subs" not in self._vless_data: self._vless_data["subs"] = []
                existing_urls = [_normalize_sub_url(s.get("url", "")) for s in self._vless_data["subs"]]
                if url not in existing_urls:
                    self._vless_data["subs"].append({
                        "id": url, "url": url,
                        "name": (_sub_title_for_url(url) or urllib.parse.urlparse(url).netloc),
                        "nodes": nodes
                    })
                self._vless_save_data()
                self._ping_event.set()
        self.set_setting("_subs_loaded_for", provider)
        self._vless_init_in_progress = False
        self._reload_settings_ui()

    def create_settings(self):
        try:
            return self._build_settings_impl()
        except Exception as e:
            import traceback as _tb
            _log("create_settings crashed: " + repr(e) + " :: " + _tb.format_exc())
            return [
                Header(text=Z("settings_header")),
                Switch(key="vless_enabled", text=Z("enable_plugin"), default=False,
                       icon="msg_permissions", on_change=self._on_enabled_changed),
                Text(text=Z("settings_error"), icon="msg_error", red=True),
            ]

    def _build_settings_impl(self):
        raw_mode = self.get_setting("mode", None)
        mode = self._normalize_mode(1 if raw_mode is None else raw_mode)
        if raw_mode is None:
            try:
                self.set_setting("mode", int(mode), reload_settings=False)
            except Exception:
                pass
            try:
                self.set_setting("mode_selector", self._mode_to_selector_index(mode), reload_settings=False)
            except Exception:
                pass
        selector_default = self._mode_to_selector_index(mode)
        en_key = "vless_enabled" if mode == 1 else "tgws_enabled"
        en_text = Z("enable_plugin")
        items = [
            Header(text=Z("settings_header")),
            Switch(key=en_key, text=en_text,
                   default=False,
                   icon="msg_permissions", on_change=self._on_enabled_changed),
            Selector(key="mode_selector", text=Z("select_mode"),
                     default=selector_default,
                     items=[Z("mode_vless"), Z("mode_tgws")],
                     icon="msg_switch", on_change=self._on_mode_changed),
        ]
        try:
            if mode == 1:
                items += self._vless_settings_items()
            else:
                items += self._tgws_settings_items()
        except Exception as e:
            import traceback as _tb
            _log("settings build error: " + repr(e) + " :: " + _tb.format_exc())
            items += [Text(text=Z("settings_error"), icon="msg_info")]
        return items

    def _tgws_settings_items(self):
        return [
            self._status_row(),
            Text(text=Z("open_tg_settings"), icon="msg_settings",
                 on_click=lambda v: self._open_tg_proxy_settings()),
            Divider(text=Z("tgws_mode_desc")),
        ]

    def _vless_settings_items(self):
        if not self._vless_core.is_available():
            if VlessCore.core_file_exists():
                return [Divider(text=f"{Z('st_loading')} ({Z('st_detail_core')})")]
            msg = Z("vless_no_core_msg")
            btn = Z("vless_download_addon")
            items = [
                Divider(text=msg),
                Text(text=btn, icon="msg_download", accent=True,
                     on_click=lambda v: self._download_libvless_and_reload()),
            ]
            try:
                url = f"{self._core_download_base()}/libvless-{_device_abis()[0]}.so"
                items.append(Divider(text=Z("addon_manual_hint")))
                items.append(Text(text=Z("addon_download_link"), icon="msg_link", accent=True,
                                  on_click=lambda v, u=url: self._open_tg_link(u)))
            except:
                pass
            try:
                items.append(Text(text=Z("addon_pick_file_btn"), icon="msg_download", accent=True,
                                  on_click=lambda v: self._pick_libvless_file()))
            except:
                pass
            items.append(Divider())
            return items

        active = self._vless_active_uri
        vless_provider = self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID)))
        is_custom = (vless_provider == int(CUSTOM_PROVIDER_ID))
        if not is_custom:
            self._enforce_provider_subs(vless_provider)
        sponsor_idx = vless_provider if not is_custom else -1
        adv_enabled = self._is_advanced_local_settings_enabled()
        if not is_custom and not self._vless_data.get("subs") and not self._vless_init_in_progress \
                and self.get_setting("_subs_loaded_for", -1) != vless_provider:
            self._vless_init_in_progress = True
            threading.Thread(target=self._init_default_vless_sub, args=(vless_provider,), daemon=True).start()
        items = [
            Selector(key="vless_provider_selector", text=Z("vless_provider"),
                     default=self._provider_to_selector_index(vless_provider),
                     items=self._provider_selector_items(),
                     icon="msg_channel", on_change=self._on_vless_provider_changed),
            Text(text=Z("sub_advanced"), icon="msg_settings",
                 create_sub_fragment=self._advanced_subpage),
            Header(text=Z("vless_nodes_header")),
            self._status_row(),
            Text(text=Z("vless_nodes_update"), icon="msg_retry",
                 on_click=lambda v: threading.Thread(target=self._vless_update_all_subs, daemon=True).start()),
            Text(text=Z("sub_manage"), icon="msg_edit",
                 create_sub_fragment=self._manage_servers_subpage),
        ]
        if not self._vless_data.get("manual") and not self._vless_data.get("subs"):
            items.append(Text(text=Z("vless_no_nodes")))
        else:
            visible_nodes = 0
            dedup_off = bool(self.get_setting("vless_dedup_off", False))
            seen = set()
            seen_soft = set()
            seen_name = set()
            seen_hostport = set()
            active_k = ""
            try:
                active_k = _node_named_dedup_key(active)
            except:
                active_k = ""
            def _register_node(node, is_sub=False):
                try:
                    u = _sanitize_vless_uri(node.get("uri", ""))
                    k = _node_dedup_key(u)
                    sk = _node_soft_dedup_key(u, node.get("name", ""))
                    hk = _node_hostport_key(u) if (is_custom and not is_sub) else ""
                    nk = str(_clean_vless_name(node.get("name", "")) or "").strip().lower()
                    if not u or (not k and not sk):
                        return None
                    if dedup_off:
                        return u, k
                    if is_sub:
                        sub_key = _node_named_dedup_key(u, node.get("name", "")) or sk or k
                        if sub_key and sub_key in seen_soft:
                            return None
                        if sub_key:
                            seen_soft.add(sub_key)
                        return u, sub_key
                    if is_custom and not is_sub and hk and hk in seen_hostport:
                        return None
                    if nk and nk in seen_name:
                        return None
                    if (k and k in seen) or (sk and sk in seen_soft):
                        return None
                    if k:
                        seen.add(k)
                    if sk:
                        seen_soft.add(sk)
                    if nk:
                        seen_name.add(nk)
                    if is_custom and not is_sub and hk:
                        seen_hostport.add(hk)
                    return u, k
                except:
                    return None
            if self._vless_data.get("manual"):
                for node in self._vless_data["manual"]:
                    reg = _register_node(node)
                    if not reg:
                        continue
                    _u, k = reg
                    is_act = bool(active_k and k == active_k)
                    items.append(Text(text=self._node_display_label(node), accent=bool(is_act),
                                      on_click=self._make_vless_node_select(node["uri"])))
                    visible_nodes += 1
            for sub in self._vless_data.get("subs", []):
                nodes = sub.get("nodes", [])
                sub_url = _normalize_sub_url(sub.get("url", ""))
                sub_name = str(sub.get("name", "") or "").strip()
                if not sub_name and sub_url:
                    sub_name = urllib.parse.urlparse(sub_url).netloc
                if not nodes:
                    if is_custom and sub_url:
                        items.append(Header(text=f"{sub_name or sub_url} (0)"))
                        items.append(Text(text=Z("custom_sub_delete"), red=True, icon="msg_delete",
                                          on_click=self._make_custom_sub_delete(sub_url)))
                    continue
                unique_nodes = []
                for node in nodes:
                    reg = _register_node(node, is_sub=True)
                    if reg:
                        _u, k = reg
                        unique_nodes.append((node, k))
                if not unique_nodes:
                    continue
                items.append(Header(text=f"{sub_name or sub_url} ({len(unique_nodes)})"))
                for node, k2 in unique_nodes:
                    is_act = bool(active_k and k2 and k2 == active_k)
                    items.append(Text(text=self._node_display_label(node), accent=bool(is_act),
                                      on_click=self._make_vless_node_select(node["uri"])))
                    visible_nodes += 1
                if is_custom and sub_url:
                    items.append(Text(text=Z("custom_sub_delete"), red=True, icon="msg_delete",
                                      on_click=self._make_custom_sub_delete(sub_url)))
            if visible_nodes <= 0:
                items.append(Text(text=Z("vless_no_nodes")))
        if not is_custom and str(REFERRAL.get(sponsor_idx, "") or "").strip():
            items += [
                Text(text=Z("referral_btn"),
                     icon="msg_link",
                     accent=True,
                     on_click=self._make_referral_click(sponsor_idx, "vless")),
            ]
        return items

    def _core_subpage(self):
        items = [
            Header(text=Z("core_select")),
            Selector(key="core_type_selector", text=Z("core_select"),
                     default=(1 if self._core_type() == CORE_TYPE_XRAY else 0),
                     items=[Z("core_singbox"), Z("core_xray")],
                     icon="menu_devices", on_change=self._on_core_type_changed),
            Text(text=Z("core_info_btn"), icon="msg_info", accent=True,
                 on_click=lambda v: self._show_core_info_dialog()),
            Divider(),
        ]
        try:
            if self._vless_core.is_available():
                items.append(Text(text=Z("core_update_btn"), icon="msg_retry", accent=True,
                                  on_click=lambda v: self._migrate_core(retry_connect=False, reason=Z("core_updating"), force=True)))
                items.append(Text(text=Z("addon_delete"), icon="msg_delete", red=True,
                                  on_click=lambda v: self._delete_libvless_and_reload()))
            else:
                items.append(Text(text=Z("vless_download_addon"), icon="msg_download", accent=True,
                                  on_click=lambda v: self._download_libvless_and_reload()))
                items.append(Text(text=Z("addon_pick_file_btn"), icon="msg_download", accent=True,
                                  on_click=lambda v: self._pick_libvless_file()))
        except Exception:
            pass
        return items

    def _manage_servers_subpage(self):
        try:
            is_custom = (self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID))) == int(CUSTOM_PROVIDER_ID))
        except Exception:
            is_custom = False
        items = [Header(text=Z("vless_nodes_manage"))]
        if is_custom:
            items += [
                Text(text=Z("custom_add_sub_btn"), icon="msg_link",
                     on_click=lambda v: self._add_custom_sub_dialog()),
                Text(text=Z("custom_add_key_btn"), icon="msg_link2",
                     on_click=lambda v: self._add_custom_key_dialog()),
                Text(text=Z("custom_info_btn"), icon="msg_info", accent=True,
                     on_click=lambda v: self._show_custom_info_dialog()),
                Divider(),
            ]
        items += [
            Text(text=Z("vless_nodes_clear"), icon="msg_delete", red=True,
                 on_click=lambda v: self._confirm_vless_clear_nodes()),
        ]
        return items

    def _advanced_subpage(self):
        items = [
            Header(text=Z("advanced_settings")),
            Text(text=Z("sub_core"), icon="menu_devices",
                 create_sub_fragment=self._core_subpage),
            Text(text=Z("open_tg_settings"), icon="msg_settings",
                 on_click=lambda v: self._open_tg_proxy_settings()),
            Divider(),
            Switch(key="vless_auto_switch", text=Z("auto_switch"),
                   subtext=Z("auto_switch_desc"), default=False, icon="media_flip"),
            Switch(key="vless_dedup_off", text=Z("dedup_off"),
                   subtext=Z("dedup_off_desc"), default=False, icon="menu_tag_filter"),
            Input(key="custom_hwid", text=Z("hwid_custom"),
                  default=str(self.get_setting("custom_hwid", "")),
                  subtext=Z("hwid_custom_desc"), icon="msg_pin_code",
                  on_change=self._on_custom_hwid_changed),
            Divider(),
            Switch(key="vless_advanced_enabled", text=Z("adv_manual_local"),
                   subtext=Z("adv_manual_local_desc"), default=False,
                   icon="msg_current_location", on_change=self._on_vless_advanced_changed),
            Input(key="local_socks_host", text=Z("local_host"),
                  default=str(self._local_host()),
                  icon="msg_current_location", on_change=self._on_local_host_changed),
            Input(key="local_socks_port", text=Z("local_port"),
                  default=str(self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT)))),
                  icon="menu_hashtag", on_change=self._on_local_port_changed),
        ]
        return items

    def _add_menu_items(self):
        def on_click(ctx):
            self._open_settings()
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id=self._chat_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                item_id=self._drawer_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except:
            pass

    def _remove_menu_items(self):
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except:
            pass

    def _open_settings(self):
        try:
            PC = find_class("com.exteragram.messenger.plugins.PluginsController")
        except:
            PC = None
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
        except:
            PSA = None
        try:
            if PC:
                inst = None
                try:
                    inst = PC.getInstance()
                except:
                    inst = None
                if inst is not None and hasattr(inst, "plugins") and PSA:
                    plugin_obj = None
                    try:
                        plugin_obj = inst.plugins.get(self.id)
                    except:
                        plugin_obj = None
                    if plugin_obj is not None:
                        frag = get_last_fragment()
                        if frag is not None:
                            frag.presentFragment(PSA(plugin_obj))
                            return
                try:
                    PC.openPluginSettings(self.id)
                    return
                except:
                    try:
                        PC.openPluginSettings("exitfy")
                        return
                    except:
                        pass
            frag = get_last_fragment()
            if frag and PC:
                PC.getInstance().openPluginSettings(self.id, frag)
        except:
            pass

    def _on_mode_changed(self, v):
        if self._stable_debounce("mode_changed:%s" % v, 500):
            return
        prev_mode = self._normalize_mode(self.get_setting("mode", 1))
        mode = self._selector_index_to_mode(v)
        try:
            self.set_setting("mode", int(mode), reload_settings=False)
            self.set_setting("mode_selector", self._mode_to_selector_index(mode), reload_settings=False)
        except Exception:
            pass
        def _do():
            self._vless_disconnect(silent=True)
            try:
                self._tgws_disconnect(silent=True)
            except:
                pass
            if int(prev_mode) != 2:
                try:
                    _vless_apply_tg_proxy(0, False)
                except Exception:
                    pass
            if mode == 1:
                self._start_vless_runtime(install_clipboard=False, init_sub=True)
            else:
                try:
                    if not bool(self.get_setting("tgws_enabled", False)):
                        self.set_setting("tgws_enabled", True, reload_settings=True)
                except:
                    pass
                self._start_tgws_runtime(auto_start=False, delay_ms=0)
            run_on_ui_thread(self._reload_settings_ui)
        threading.Thread(target=_do, daemon=True).start()


    def _on_local_port_changed(self, v):
        try:
            if self._stable_debounce("local_port_changed", 500):
                return
            if not self._is_advanced_local_settings_enabled():
                return
            raw = str(v or "").strip()
            if not raw:
                return
            port = self._normalize_local_port(raw)
            if str(port) != raw:
                try:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(Z("local_port_invalid")))
                except Exception:
                    pass
            current = self._local_port()
            if int(port) == int(current):
                return
            was_vless = bool(getattr(self, "_vless_running", False))
            was_tgws = bool(getattr(self, "_tgws_running", False))
            self.set_setting("local_socks_port", int(port), reload_settings=False)
            self._runtime_random_local_port = int(port)
            self._restart_active_tunnel_if_running(was_vless=was_vless, was_tgws=was_tgws, force=True)
            self._reload_settings_ui()
        except Exception:
            pass

    def _on_local_host_changed(self, v):
        try:
            if self._stable_debounce("local_host_changed", 500):
                return
            if not self._is_advanced_local_settings_enabled():
                return
            host = self._normalize_local_host(v)
            prev = self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1"))
            if host == prev:
                return
            was_vless = bool(getattr(self, "_vless_running", False))
            was_tgws = bool(getattr(self, "_tgws_running", False))
            if was_vless:
                self._vless_disconnect(silent=True)
            if was_tgws:
                self._tgws_disconnect(silent=True)
            self.set_setting("local_socks_host", host, reload_settings=False)
            self._apply_runtime_local_host()
            self._restart_active_tunnel_if_running(was_vless=was_vless, was_tgws=was_tgws)
            self._reload_settings_ui()
        except Exception:
            pass

    def _on_vless_advanced_changed(self, v):
        try:
            if self._stable_debounce("vless_advanced_changed:%s" % bool(v), 500):
                return
            enabled = bool(v)
            was_vless = bool(getattr(self, "_vless_running", False))
            was_tgws = bool(getattr(self, "_tgws_running", False))
            if was_vless:
                self._vless_disconnect(silent=True)
            if was_tgws:
                self._tgws_disconnect(silent=True)
            self.set_setting("vless_advanced_enabled", enabled, reload_settings=False)
            if not enabled:
                self.set_setting("local_socks_host", "127.0.0.1", reload_settings=False)
                self._runtime_random_local_port = 0
            else:
                self.set_setting("local_socks_host", self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1")), reload_settings=False)
                self.set_setting("local_socks_port", self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT))), reload_settings=False)
            self._apply_runtime_local_host()
            self._restart_active_tunnel_if_running(was_vless=was_vless, was_tgws=was_tgws)
        except Exception:
            pass
        self._reload_settings_ui()

    def _on_custom_hwid_changed(self, v):
        try:
            value = str(v or "").strip()
            if len(value) > 128:
                value = value[:128]
            self.set_setting("custom_hwid", value, reload_settings=False)
            _pset_str("exitfy_hwid_custom", value)
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_success(Z("hwid_saved")))
            except Exception:
                pass
        except Exception:
            pass

    def _on_enabled_changed(self, v):
        enabled = bool(v)
        mode = self._normalize_mode(self.get_setting("mode", 1))
        if self._stable_debounce("enabled:%s:%s" % (mode, enabled), 500):
            return
        if mode == 1:
            if enabled:
                if not self._vless_active_uri:
                    try:
                        run_on_ui_thread(lambda: BulletinHelper.show_error(Z("vless_select_server_first")))
                    except Exception:
                        pass
                    try:
                        self.set_setting("vless_enabled", False, reload_settings=True)
                    except Exception:
                        pass
                    try:
                        run_on_ui_thread(self._reload_settings_ui)
                    except Exception:
                        pass
                    return
                running_ok = bool(self._vless_runtime_port_alive())
                if running_ok:
                    self._reapply_vless_runtime_proxy()
                    try:
                        run_on_ui_thread(self._reload_settings_ui)
                    except Exception:
                        pass
                else:
                    threading.Thread(target=self._vless_connect, daemon=True).start()
            else:
                threading.Thread(target=lambda: self._vless_disconnect(), daemon=True).start()
        else:
            if enabled:
                threading.Thread(target=self._tgws_connect_bg, daemon=True).start()
            else:
                threading.Thread(target=lambda: self._tgws_disconnect(), daemon=True).start()

    def _on_vless_provider_changed(self, v):
        provider = self._selector_value_to_provider(v)
        if self._stable_debounce("vless_provider_changed:%s" % provider, 500):
            return
        try:
            self._vless_selected_provider = int(provider)
        except Exception:
            pass
        try:
            self.set_setting("vless_provider", int(provider), reload_settings=False)
            self.set_setting("vless_provider_selector", self._provider_to_selector_index(provider), reload_settings=False)
        except Exception:
            pass
        prev_provider = self._normalize_provider(getattr(self, "_last_vless_provider", int(DEFAULT_PROVIDER_ID)))
        try:
            if int(prev_provider) == int(CUSTOM_PROVIDER_ID):
                self._vless_data_custom = _clone_vless_data(self._vless_data)
                self.set_setting("vless_data_custom", self._vless_data_custom, reload_settings=False)
            else:
                prev_key = self._provider_bucket_key(prev_provider)
                self._vless_data_default_map[prev_key] = _clone_vless_data(self._vless_data)
                self._vless_data_default = _clone_vless_data(self._vless_data_default_map.get(self._default_provider_bucket_key(), _new_vless_data()))
                self.set_setting("vless_data_default_map", self._vless_data_default_map, reload_settings=False)
                self.set_setting("vless_data_default", self._vless_data_default, reload_settings=False)
        except Exception:
            pass
        try:
            self._last_vless_provider = int(provider)
        except:
            self._last_vless_provider = provider
        was_vless_running = bool(getattr(self, "_vless_running", False))
        running_uri = str(getattr(self, "_vless_runtime_uri", "") or getattr(self, "_vless_active_uri", "") or "")
        self._vless_active_uri = ""
        if provider == int(CUSTOM_PROVIDER_ID):
            try:
                d = self.get_setting("vless_data_custom", None)
                if isinstance(d, dict):
                    self._vless_data_custom = _clone_vless_data(d)
            except:
                pass
            self._vless_data = _clone_vless_data(self._vless_data_custom)
            self._vless_active_uri = str(self._vless_data.get("active_uri", "") or "")
            self._vless_save_data()
            self._reload_settings_ui()
            return
        key = self._provider_bucket_key(provider)
        try:
            dmap = self.get_setting("vless_data_default_map", {})
            if isinstance(dmap, dict):
                for p in PROVIDER_IDS:
                    self._vless_data_default_map[str(p)] = _clone_vless_data(dmap.get(str(p), self._vless_data_default_map.get(str(p), _new_vless_data())))
        except Exception:
            pass
        self._vless_data = _clone_vless_data(self._vless_data_default_map.get(key, _new_vless_data()))
        self._vless_active_uri = str(self._vless_data.get("active_uri", "") or "")
        self._vless_save_data()
        if not self._vless_data.get("subs") and not self._vless_init_in_progress:
            threading.Thread(target=self._init_default_vless_sub, args=(provider,), daemon=True).start()
        self._reload_settings_ui()

    def _set_state(self, state, detail="", error_msg=None):
        try:
            prev = getattr(self, "_state", None)
            self._state = state
            self._state_detail = str(detail or "")
        except Exception:
            return
        if state == ConnState.ERROR and error_msg:
            _notify_error(error_msg)
        if prev != state:
            try:
                self._reload_settings_ui()
            except Exception:
                pass

    def _status_row(self):
        state = getattr(self, "_state", ConnState.DISCONNECTED)
        detail = getattr(self, "_state_detail", "")
        return Text(text=f"{Z('status_title')}: {_state_label(state, detail)}",
                    icon=_state_icon(state))

    def _reload_settings_ui(self, delay_ms=100):
        try:
            if bool(getattr(self, "_reload_ui_pending", False)):
                return
            self._reload_ui_pending = True
        except Exception:
            pass
        def _do():
            try:
                self._reload_ui_pending = False
            except Exception:
                pass
            try:
                self.set_setting("__reload__", time.time(), reload_settings=True)
            except Exception as e:
                try:
                    err = str(e or "")
                except Exception:
                    err = ""
                if ("RecyclerView is computing a layout or scrolling" in err or
                        "Cannot call this method while RecyclerView is computing a layout" in err):
                    try:
                        run_on_ui_thread(_do, 300)
                    except Exception:
                        pass
                else:
                    try:
                        _log(f"reload_settings_ui error: {e}")
                    except Exception:
                        pass
        run_on_ui_thread(_do, int(delay_ms))

    def _open_tg_proxy_settings(self):
        try:
            frag = get_last_fragment()
            if frag:
                from org.telegram.ui import ProxyListActivity
                frag.presentFragment(ProxyListActivity())
        except: pass

    def _open_tg_link(self, url):
        try:
            url = str(url or "").strip()
            if not url: return
            try:
                frag = get_last_fragment()
                act = frag.getParentActivity() if frag else None
            except:
                act = None
            try:
                from org.telegram.messenger.browser import Browser
            except:
                Browser = None
            ctx = act if act else ApplicationLoader.applicationContext
            if Browser:
                Browser.openUrl(ctx, url)
                return
            from android.content import Intent
            from android.net import Uri
            intent = Intent(Intent.ACTION_VIEW, Uri.parse(url))
            if not act:
                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(intent)
        except:
            pass

    def _show_text_input_dialog(self, title, hint, on_submit):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
            if not act:
                return False
            b = AlertDialogBuilder(act)
            b.set_title(str(title or ""))
            if EditText is None:
                b.set_message(str(hint or ""))
                b.set_negative_button(Z("btn_cancel"), lambda d, w: d.dismiss())
                b.show()
                return False
            et = EditText(act)
            try:
                et.setHint(str(hint or ""))
            except Exception:
                pass
            try:
                et.setSingleLine(True)
            except Exception:
                pass
            try:
                b.set_view(et)
            except Exception:
                try:
                    b.set_message(str(hint or ""))
                except Exception:
                    pass
            def _ok(dlg=None, which=None):
                try:
                    value = str(et.getText() or "").strip()
                except Exception:
                    value = ""
                try:
                    on_submit(value)
                except Exception:
                    pass
                try:
                    if dlg:
                        dlg.dismiss()
                except Exception:
                    pass
            b.set_positive_button(Z("btn_add"), _ok)
            b.set_negative_button(Z("btn_cancel"), lambda d, w: d.dismiss())
            b.show()
            return True
        except Exception:
            return False

    def _show_custom_info_dialog(self):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
            if not act:
                return
            b = AlertDialogBuilder(act)
            b.set_title(Z("custom_info_title"))
            b.set_message(Z("servers_mode_desc"))
            b.set_positive_button("OK", lambda d, w: d.dismiss())
            b.show()
        except Exception:
            pass

    def _show_core_info_dialog(self):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
            if not act:
                return
            b = AlertDialogBuilder(act)
            b.set_title(Z("core_info_title"))
            b.set_message(Z("core_info_text"))
            b.set_positive_button("OK", lambda d, w: d.dismiss())
            b.show()
        except Exception:
            pass

    def _on_core_type_changed(self, v):
        try:
            new_type = CORE_TYPE_XRAY if int(v) == 1 else CORE_TYPE_SINGBOX
        except Exception:
            new_type = DEFAULT_CORE_TYPE
        if new_type == self._core_type():
            return
        try:
            self.set_setting("core_type", new_type, reload_settings=False)
        except Exception:
            pass
        self._migrate_core(retry_connect=False, reason=Z("core_switched"))

    def _confirm_vless_clear_nodes(self):
        try:
            frag = get_last_fragment()
            act = frag.getParentActivity() if frag else None
        except Exception:
            act = None
        if not act:
            self._vless_clear_nodes_keep_subs()
            return
        try:
            b = AlertDialogBuilder(act)
            b.set_title(Z("vless_nodes_clear_title"))
            b.set_message(Z("vless_nodes_clear_msg"))
            b.set_negative_button(Z("btn_cancel"), lambda d, w: d.dismiss())
            b.set_positive_button(
                Z("vless_nodes_clear"),
                lambda d, w: (d.dismiss(), self._vless_clear_nodes_keep_subs())
            )
            try:
                b.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
            except Exception:
                pass
            b.show()
        except Exception:
            self._vless_clear_nodes_keep_subs()

    def _vless_clear_nodes_keep_subs(self):
        if bool(getattr(self, "_vless_running", False)):
            try:
                self.set_setting("vless_enabled", False, reload_settings=False)
            except Exception:
                pass
            self._vless_disconnect(silent=True)

        cleaned_subs = []
        seen_urls = set()
        for sub in (self._vless_data.get("subs", []) or []):
            if not isinstance(sub, dict):
                continue
            url = _normalize_sub_url(sub.get("url", ""))
            if not url or url in seen_urls:
                continue
            seen_urls.add(url)
            name = _sub_title_for_url(url) or str(sub.get("name", "") or "").strip() or urllib.parse.urlparse(url).netloc
            cleaned_subs.append({"id": url, "url": url, "name": name, "nodes": []})

        self._vless_active_uri = ""
        self._vless_data["active_uri"] = ""
        self._vless_data["manual"] = []
        self._vless_data["subs"] = cleaned_subs
        self._sub_cache = {}
        self._vless_save_data()
        try:
            self.set_setting("vless_sub_cache", {}, reload_settings=False)
        except Exception:
            pass
        try:
            self._ping_event.set()
        except Exception:
            pass
        self._reload_settings_ui()
        try:
            run_on_ui_thread(lambda: BulletinHelper.show_success(Z("vless_nodes_cleared")))
        except Exception:
            pass

    def _add_custom_key(self, raw_uri):
        uri = _sanitize_vless_uri(raw_uri)
        if not _is_proxy_uri(uri) or len(uri) < 8:
            run_on_ui_thread(lambda: BulletinHelper.show_error(Z("key_invalid")))
            return
        conf, name = VlessConfigParser.parse(uri, 1080)
        if not conf:
            run_on_ui_thread(lambda: BulletinHelper.show_error(Z("key_parse_error")))
            return
        manual = self._vless_data.get("manual", [])
        dedup_off = bool(self.get_setting("vless_dedup_off", False))
        if not dedup_off:
            k = _node_dedup_key(uri)
            if not k or any(_node_dedup_key(n.get("uri", "")) == k for n in manual):
                return
        manual.append({"name": name or Z("vless_node_default"), "uri": uri, "ping": -1})
        self._vless_data["manual"] = manual
        self._vless_save_data()
        self._ping_event.set()
        self._reload_settings_ui()

    def _add_custom_sub_dialog(self):
        def _submit(value):
            url = _normalize_sub_url(value)
            if not url.startswith("http"):
                run_on_ui_thread(lambda: BulletinHelper.show_error(Z("vless_custom_sub_bad")))
                return
            threading.Thread(target=self._vless_do_add_sub, args=(url, True), daemon=True).start()
        if not self._show_text_input_dialog(Z("custom_sub_add_title"), Z("custom_sub_add_hint"), _submit):
            run_on_ui_thread(lambda: BulletinHelper.show_error(Z("custom_input_empty")))

    def _add_custom_key_dialog(self):
        def _submit(value):
            if not str(value or "").strip():
                run_on_ui_thread(lambda: BulletinHelper.show_error(Z("custom_input_empty")))
                return
            self._add_custom_key(value)
        if not self._show_text_input_dialog(Z("custom_key_add_title"), Z("custom_key_add_hint"), _submit):
            run_on_ui_thread(lambda: BulletinHelper.show_error(Z("custom_input_empty")))

    def _remove_custom_sub(self, url):
        u = _normalize_sub_url(url)
        if not u:
            return
        subs = []
        for s in (self._vless_data.get("subs", []) or []):
            try:
                su = _normalize_sub_url(s.get("url", ""))
                if su == u:
                    continue
                subs.append(s)
            except Exception:
                continue
        self._vless_data["subs"] = subs
        self._vless_save_data()
        self._ping_event.set()
        self._reload_settings_ui()
        try:
            run_on_ui_thread(lambda: BulletinHelper.show_success(Z("custom_sub_deleted")))
        except Exception:
            pass

    def _make_custom_sub_delete(self, url):
        def _handler(v):
            self._remove_custom_sub(url)
        return _handler

    def _make_referral_click(self, provider_idx, source):
        def handler(v):
            try:
                url = REFERRAL.get(provider_idx, "")
                self._open_tg_link(url)
            except Exception as e:
                pass
        return handler

    def _vless_save_data(self):
        self._vless_data["active_uri"] = self._vless_active_uri
        provider_for_save = self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID)))
        dedup_off = bool(self.get_setting("vless_dedup_off", False))
        try:
            if dedup_off:
                try:
                    self.set_setting("vless_data", self._vless_data, reload_settings=False)
                except Exception:
                    pass
                try:
                    provider = provider_for_save
                    if int(provider) == int(CUSTOM_PROVIDER_ID):
                        self._vless_data_custom = _clone_vless_data(self._vless_data)
                        self.set_setting("vless_data_custom", self._vless_data_custom, reload_settings=False)
                    else:
                        key = self._provider_bucket_key(provider)
                        if not isinstance(getattr(self, "_vless_data_default_map", None), dict):
                            self._vless_data_default_map = {}
                        self._vless_data_default_map[key] = _clone_vless_data(self._vless_data)
                        self._vless_data_default = _clone_vless_data(self._vless_data_default_map.get(self._default_provider_bucket_key(), _new_vless_data()))
                        self.set_setting("vless_data_default_map", self._vless_data_default_map, reload_settings=False)
                        self.set_setting("vless_data_default", self._vless_data_default, reload_settings=False)
                except Exception:
                    pass
                return
            global_seen = set()
            global_seen_soft = set()
            global_seen_hostport = set()
            def _dedup_nodes(nodes, seen=None, force_hostport=False, use_named_key=False):
                if seen is None:
                    seen = set()
                local_soft = set()
                local_hostport = set()
                out = []
                for n in (nodes or []):
                    try:
                        u0 = _sanitize_vless_uri(n.get("uri", ""))
                        k = _node_named_dedup_key(u0, n.get("name", "")) if use_named_key else _node_dedup_key(u0)
                        sk = k if use_named_key else _node_soft_dedup_key(u0, n.get("name", ""))
                        hk = _node_hostport_key(u0)
                        if not u0 or (not k and not sk):
                            continue
                        if force_hostport and hk and (hk in local_hostport or hk in global_seen_hostport):
                            continue
                        if (k and (k in seen or k in global_seen)) or (sk and (sk in local_soft or sk in global_seen_soft)):
                            continue
                        if k:
                            seen.add(k)
                            global_seen.add(k)
                        if sk:
                            local_soft.add(sk)
                            global_seen_soft.add(sk)
                        if force_hostport and hk:
                            local_hostport.add(hk)
                            global_seen_hostport.add(hk)
                        nn = dict(n)
                        nn["uri"] = u0
                        out.append(nn)
                    except:
                        continue
                return out
            self._vless_data["manual"] = _dedup_nodes(self._vless_data.get("manual", []), force_hostport=False)
            subs = []
            seen_sub_urls = set()
            for sub in (self._vless_data.get("subs", []) or []):
                try:
                    s2 = dict(sub)
                    url_norm = _normalize_sub_url(s2.get("url", ""))
                    if not url_norm:
                        continue
                    if url_norm in seen_sub_urls:
                        continue
                    seen_sub_urls.add(url_norm)
                    s2["id"] = url_norm
                    s2["url"] = url_norm
                    if not str(s2.get("name", "") or "").strip():
                        s2["name"] = urllib.parse.urlparse(url_norm).netloc
                    s2["nodes"] = _dedup_nodes(sub.get("nodes", []), force_hostport=False, use_named_key=True)
                    subs.append(s2)
                except:
                    continue
            self._vless_data["subs"] = subs
        except:
            pass
        try:
            self.set_setting("vless_data", self._vless_data, reload_settings=False)
        except Exception:
            pass
        try:
            provider = provider_for_save
            if int(provider) == int(CUSTOM_PROVIDER_ID):
                self._vless_data_custom = _clone_vless_data(self._vless_data)
                self.set_setting("vless_data_custom", self._vless_data_custom, reload_settings=False)
            else:
                key = self._provider_bucket_key(provider)
                if not isinstance(getattr(self, "_vless_data_default_map", None), dict):
                    self._vless_data_default_map = {}
                self._vless_data_default_map[key] = _clone_vless_data(self._vless_data)
                self._vless_data_default = _clone_vless_data(self._vless_data_default_map.get(self._default_provider_bucket_key(), _new_vless_data()))
                self.set_setting("vless_data_default_map", self._vless_data_default_map, reload_settings=False)
                self.set_setting("vless_data_default", self._vless_data_default, reload_settings=False)
        except Exception:
            pass

    def _core_start_with_timeout(self, config_json, timeout_sec=None):
        if timeout_sec is None:
            timeout_sec = CORE_START_TIMEOUT_SEC
        result = {"err": None, "done": False}
        def _run():
            try:
                result["err"] = self._vless_core.start(config_json)
            except Exception as e:
                result["err"] = str(e)
            finally:
                result["done"] = True
        t = threading.Thread(target=_run, daemon=True)
        t.start()
        t.join(float(timeout_sec))
        if not result["done"]:
            return "__timeout__"
        return result["err"]

    def _vless_connect(self, force=False):
        active_uri = str(getattr(self, "_vless_active_uri", "") or "")
        if not active_uri:
            return
        try:
            connect_provider = int(getattr(self, "_vless_selected_provider", getattr(self, "_last_vless_provider", int(DEFAULT_PROVIDER_ID))))
        except Exception:
            connect_provider = int(DEFAULT_PROVIDER_ID)
        lock = getattr(self, "_vless_connect_lock", None)
        acquired = False
        try:
            if lock is not None:
                acquired = bool(lock.acquire(False))
                if not acquired:
                    try:
                        _log("vless_connect: skipped, connect already in progress")
                    except Exception:
                        pass
                    return
            try:
                running_ok = bool(getattr(self, "_vless_running", False)) and _check_vless_port(int(getattr(self, "_vless_port", 0) or 0), timeout=0.05)
            except Exception:
                running_ok = False
            if running_ok and not bool(force) and str(getattr(self, "_vless_runtime_uri", "") or active_uri) == active_uri:
                self._reapply_vless_runtime_proxy()
                try:
                    run_on_ui_thread(self._reload_settings_ui)
                except Exception:
                    pass
                return

            try:
                self._vless_connect_generation = int(getattr(self, "_vless_connect_generation", 0) or 0) + 1
                gen = int(self._vless_connect_generation)
            except Exception:
                gen = int(time.time() * 1000)
                self._vless_connect_generation = gen

            self._vless_disconnect(silent=True)
            try:
                self._vless_connect_generation = gen
            except Exception:
                pass
            self._apply_runtime_local_host()
            try:
                _log(f"vless_connect: uri={active_uri!r}")
            except Exception:
                pass
            self._set_state(ConnState.CONNECTING, Z("st_detail_core"))
            if not self._vless_core.is_available():
                self._set_state(ConnState.ERROR, Z("st_no_core"),
                                error_msg=Z("addon_core_load_failed"))
                return
            port = int(self._local_port())
            if not self._wait_local_port_free(port, timeout_sec=1.8):
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=f"{Z('local_port_busy')}: {port}")
                return
            self._vless_port = port
            socks_user, socks_pass = _generate_socks_credentials()
            self._socks_auth = (socks_user, socks_pass)
            use_balancer = self.get_setting("vless_auto_switch", False)
            if use_balancer:
                all_nodes = list(self._vless_data.get("manual", []))
                for sub in self._vless_data.get("subs", []):
                    all_nodes.extend(sub.get("nodes", []))
                valid_nodes = [n for n in all_nodes if 0 < n.get("ping", 9999) < 9999]
                valid_nodes = sorted(valid_nodes, key=lambda x: x["ping"])
                top_nodes = valid_nodes[:10]
                uris = [n["uri"] for n in top_nodes]
                if not uris:
                    uris = [active_uri]
                parser = self._active_parser()
                if len(uris) > 1:
                    config_json, _ = parser.parse_balancer(uris, port, socks_user=socks_user, socks_pass=socks_pass)
                else:
                    config_json, _ = parser.parse(uris[0], port, socks_user=socks_user, socks_pass=socks_pass)
            else:
                config_json, _ = self._active_parser().parse(active_uri, port, socks_user=socks_user, socks_pass=socks_pass)
            if not config_json:
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=Z("key_parse_error"))
                return
            err = self._core_start_with_timeout(config_json)
            if err == "__timeout__":
                _log("StartCore timed out")
                self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                error_msg=Z("addon_core_load_failed"))
                return
            if err and use_balancer:
                try:
                    if "config build error" in str(err).lower():
                        cfg_single, _ = self._active_parser().parse(active_uri, port, socks_user=socks_user, socks_pass=socks_pass)
                        if cfg_single:
                            err2 = self._core_start_with_timeout(cfg_single)
                            if not err2:
                                err = ""
                except Exception:
                    pass
            if err:
                _log(f"core StartCore error: {err}")
                low = str(err).lower()
                core_mismatch = str(self.get_setting("installed_core_type", "") or "") != self._core_type()
                if ("config build error" in low or "config parse error" in low) and core_mismatch:
                    self._migrate_core(retry_connect=True, reason=Z("core_migrating"))
                    return
                msg = str(err)
                self._set_state(ConnState.ERROR, Z("st_detail_core"), error_msg=msg)
                return
            def connection_watchdog():
                _su, _sp = socks_user, socks_pass
                start = time.time()
                deadline = start + VLESS_CONNECT_TIMEOUT_SEC
                while time.time() < deadline:
                    if int(getattr(self, "_vless_connect_generation", 0) or 0) != int(gen):
                        return
                    if _check_vless_port(port, timeout=0.05):
                        _vless_apply_tg_proxy(port, True, socks_user=_su, socks_pass=_sp,
                                              display_name=_proxy_label_for_uri(active_uri))
                        self._vless_running = True
                        self._vless_runtime_uri = active_uri
                        self._vless_runtime_port = int(port)
                        self._vless_runtime_provider = int(connect_provider)
                        self._runtime_random_local_port = int(port)
                        try:
                            self.set_setting("vless_enabled", True, reload_settings=False)
                        except:
                            pass
                        self._set_state(ConnState.CONNECTED, Z("st_detail_core"))
                        return
                    time.sleep(0.1 if (time.time() - start) < 2.0 else 0.25)
                if int(getattr(self, "_vless_connect_generation", 0) or 0) == int(gen):
                    self._set_state(ConnState.ERROR, Z("st_detail_core"),
                                    error_msg=Z("addon_core_load_failed"))
                    run_on_ui_thread(lambda: self._vless_disconnect(silent=True))
            threading.Thread(target=connection_watchdog, daemon=True).start()
        finally:
            try:
                if lock is not None and acquired:
                    lock.release()
            except Exception:
                pass

    def _vless_disconnect(self, silent=False):
        try:
            self._vless_connect_generation = int(getattr(self, "_vless_connect_generation", 0) or 0) + 1
        except Exception:
            pass
        self._vless_core.stop()
        self._vless_running = False
        self._vless_runtime_uri = ""
        self._vless_runtime_port = 0
        _vless_apply_tg_proxy(0, False)
        if not silent:
            self._set_state(ConnState.DISCONNECTED)
            self._reload_settings_ui()

    def _tgws_connect(self, auto_start=False):
        lock = getattr(self, "_tgws_connect_lock", None)
        acquired = False
        try:
            if lock is not None:
                acquired = bool(lock.acquire(False))
                if not acquired:
                    try:
                        _log("tgws_connect: skipped, connect already in progress")
                    except Exception:
                        pass
                    return False
            try:
                running_ok = bool(getattr(self, "_tgws_running", False)) and _check_vless_port(int(getattr(self, "_tgws_port", 0) or 0), timeout=0.05)
            except Exception:
                running_ok = False
            if running_ok:
                try:
                    _su, _sp = self._socks_auth if hasattr(self, "_socks_auth") else ("", "")
                    _vless_apply_tg_proxy(int(getattr(self, "_tgws_port", 0) or 0), True, socks_user=_su, socks_pass=_sp,
                                          display_name=f"{_PROXY_LABEL_PREFIX} ¬∑ TG WS")
                except Exception:
                    pass
                try:
                    run_on_ui_thread(self._reload_settings_ui)
                except Exception:
                    pass
                return True

            self._apply_runtime_local_host()
            try:
                self._vless_disconnect(silent=True)
            except:
                pass
            try:
                self._tgws_connect_generation = int(getattr(self, "_tgws_connect_generation", 0) or 0) + 1
                gen = int(self._tgws_connect_generation)
            except Exception:
                gen = int(time.time() * 1000)
                self._tgws_connect_generation = gen
            self._set_state(ConnState.CONNECTING, Z("st_detail_tgws"))
            port = int(self._local_port())
            if not self._wait_local_port_free(port, timeout_sec=2.0):
                self._tgws_last_error = f"{Z('local_port_busy')}: {port}"
                self._set_state(ConnState.ERROR, Z("st_detail_tgws"),
                                error_msg=self._tgws_last_error)
                return False
            if int(port or 0) <= 0:
                self._tgws_last_error = Z("tgws_no_port")
                self._tgws_running = False
                self._tgws_port = 0
                self._set_state(ConnState.ERROR, Z("st_detail_tgws"),
                                error_msg=self._tgws_last_error)
                return False
            self._tgws_port = int(port)
            socks_user, socks_pass = _generate_socks_credentials()
            self._socks_auth = (socks_user, socks_pass)
            config_json = json.dumps({"port": int(port), "verbose": False})
            err = self._tgws_core.start(config_json, socks_user=socks_user, socks_pass=socks_pass)
            if err:
                self._tgws_last_error = str(err)
                self._tgws_running = False
                self._tgws_port = 0
                self._set_state(ConnState.ERROR, Z("st_detail_tgws"), error_msg=str(err))
                return False
            def _watchdog():
                _su, _sp = socks_user, socks_pass
                deadline = time.time() + float(TGWS_LOCAL_READY_TIMEOUT_SEC)
                while time.time() < deadline:
                    try:
                        if int(getattr(self, "_tgws_connect_generation", 0) or 0) != int(gen):
                            return
                    except Exception:
                        pass
                    if _check_vless_port(int(port), timeout=0.5):
                        try:
                            self._tgws_snapshot_current_proxy()
                        except Exception:
                            pass
                        try:
                            self._tgws_proxy_managed = True
                        except Exception:
                            pass
                        _vless_apply_tg_proxy(int(port), True, socks_user=_su, socks_pass=_sp,
                                              display_name=f"{_PROXY_LABEL_PREFIX} ¬∑ TG WS")
                        self._tgws_running = True
                        try:
                            self.set_setting("tgws_enabled", True, reload_settings=False)
                        except:
                            pass
                        self._set_state(ConnState.CONNECTED, Z("st_detail_tgws"))
                        _notify_ok(Z("tgws_connected"))
                        return
                    time.sleep(0.1)
                self._tgws_running = False
                self._tgws_port = 0
                self._tgws_last_error = "timeout"
                self._set_state(ConnState.ERROR, Z("st_detail_tgws"),
                                error_msg=Z("tgws_timeout"))
                if not bool(auto_start):
                    try:
                        self.set_setting("tgws_enabled", False, reload_settings=True)
                    except:
                        pass
                try:
                    if int(getattr(self, "_tgws_connect_generation", 0) or 0) == int(gen):
                        self._tgws_core.stop()
                except:
                    pass
            threading.Thread(target=_watchdog, daemon=True).start()
            return True
        except:
            self._tgws_running = False
            self._tgws_port = 0
            try:
                self._tgws_last_error = "exception"
            except Exception:
                pass
            try:
                self._tgws_core.stop()
            except:
                pass
            return False
        finally:
            try:
                if lock is not None and acquired:
                    lock.release()
            except Exception:
                pass

    def _tgws_disconnect_with_reason(self, reason, silent=False):
        self._tgws_disconnect(silent=bool(silent))

    def _tgws_disconnect(self, silent=False):
        try:
            self._tgws_connect_generation = int(getattr(self, "_tgws_connect_generation", 0) or 0) + 1
        except Exception:
            pass
        try:
            self._tgws_core.stop()
        except:
            pass
        self._tgws_running = False
        self._tgws_port = 0
        try:
            self._tgws_restore_previous_proxy()
        except Exception:
            _vless_apply_tg_proxy(0, False)
        if not silent:
            self._set_state(ConnState.DISCONNECTED)
            self._reload_settings_ui()

    def _make_vless_node_select(self, uri):
        def handler(v):
            try:
                if self._stable_debounce("vless_node_select", 550):
                    return
                prev = str(getattr(self, "_vless_active_uri", "") or "")
                uri_s = _sanitize_vless_uri(uri)
                if not uri_s or not _is_proxy_uri(uri_s):
                    try:
                        run_on_ui_thread(lambda: BulletinHelper.show_error(Z("key_invalid")))
                    except Exception:
                        pass
                    try:
                        _log(f"vless_node_select: invalid uri: {uri!r} -> {uri_s!r}")
                    except Exception:
                        pass
                    return

                try:
                    self._vless_selected_provider = int(getattr(self, "_last_vless_provider", self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID))))
                except Exception:
                    pass
                self._vless_active_uri = uri_s
                self._vless_save_data()
                running_ok = bool(self._vless_runtime_port_alive())
                runtime_same = str(getattr(self, "_vless_runtime_uri", "") or "") == uri_s
                if running_ok and runtime_same:
                    self._reapply_vless_runtime_proxy()
                else:
                    try:
                        self.set_setting("vless_enabled", True, reload_settings=True)
                    except Exception:
                        pass
                    threading.Thread(target=self._vless_connect, daemon=True).start()
            except Exception as e:
                try:
                    _log(f"vless_node_select error: {e}")
                except Exception:
                    pass
            try:
                self._reload_settings_ui()
            except Exception:
                pass
        return handler

    def _vless_update_all_subs(self):
        urls = []
        seen_urls = set()
        try:
            provider = self._normalize_provider(self.get_setting("vless_provider", int(DEFAULT_PROVIDER_ID)))
        except Exception:
            provider = int(DEFAULT_PROVIDER_ID)
        if provider == int(CUSTOM_PROVIDER_ID):
            for s in self._vless_data.get("subs", []):
                u = _normalize_sub_url(s.get("url", ""))
                if not u or u in seen_urls:
                    continue
                seen_urls.add(u)
                urls.append(u)
        else:
            self._enforce_provider_subs(provider)
            for u in self._provider_sub_urls(provider):
                if not u or u in seen_urls:
                    continue
                seen_urls.add(u)
                urls.append(u)
        if not urls:
            try:
                self._vless_save_data()
            except Exception:
                pass
            try:
                self._ping_event.set()
            except Exception:
                pass
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except Exception:
                pass
            return
        for url in urls:
            self._vless_update_sub(url, force=True)
        try:
            self._ping_event.set()
        except Exception:
            pass

    def _vless_do_add_sub(self, url, force=False):
        url = _normalize_sub_url(url)
        if not url.startswith("http"): return
        nodes = self._vless_fetch_nodes_cached(url, force=bool(force))
        if not nodes:
            def _notify():
                try:
                    t = str(_fetch_text_url(url, timeout_sec=15.0) or "").strip()
                    low = t.lower()
                    if "–Ņ—Ä–ł–Ľ–ĺ–∂–Ķ–Ĺ–ł–Ķ –Ĺ–Ķ –Ņ–ĺ–ī–ī–Ķ—Ä–∂–ł–≤–į–Ķ—ā—Ā—Ź" in low or "not supported" in low:
                        BulletinHelper.show_error(Z("vless_app_not_supported"))
                    else:
                        BulletinHelper.show_error(Z("vless_custom_sub_empty"))
                except:
                    BulletinHelper.show_error(Z("vless_custom_sub_empty"))
            run_on_ui_thread(_notify)
            return
        if nodes:
            if "subs" not in self._vless_data: self._vless_data["subs"] = []
            existing = [_normalize_sub_url(s.get("url", "")) for s in self._vless_data["subs"]]
            if url not in existing:
                self._vless_data["subs"].append({
                    "id": url,
                    "url": url,
                    "name": (_sub_title_for_url(url) or urllib.parse.urlparse(url).netloc),
                    "nodes": nodes
                })
            else:
                for s in self._vless_data.get("subs", []):
                    try:
                        if _normalize_sub_url(s.get("url", "")) == url:
                            s["id"] = url
                            s["url"] = url
                            s["name"] = (_sub_title_for_url(url) or urllib.parse.urlparse(url).netloc)
                            s["nodes"] = nodes
                    except Exception:
                        continue
            self._vless_save_data()
            self._ping_event.set()
            run_on_ui_thread(self._reload_settings_ui)

    def _vless_update_sub(self, url, force=False):
        url = _normalize_sub_url(url)
        nodes = self._vless_fetch_nodes_cached(url, force=bool(force))
        changed = False
        for sub in self._vless_data.get("subs", []):
            if _normalize_sub_url(sub.get("url", "")) == url and nodes:
                sub["id"] = url
                sub["url"] = url
                sub["name"] = (_sub_title_for_url(url) or urllib.parse.urlparse(url).netloc)
                sub["nodes"] = nodes
                changed = True
        if not changed and nodes:
            try:
                if "subs" not in self._vless_data:
                    self._vless_data["subs"] = []
                existing = [_normalize_sub_url(s.get("url", "")) for s in self._vless_data.get("subs", [])]
                if url not in existing:
                    self._vless_data["subs"].append({
                        "id": url,
                        "url": url,
                        "name": (_sub_title_for_url(url) or urllib.parse.urlparse(url).netloc),
                        "nodes": nodes
                    })
                    changed = True
            except:
                pass
        if changed:
            self._vless_save_data()
            self._ping_event.set()
            run_on_ui_thread(self._reload_settings_ui)

    def _vless_pinger_loop(self):
        while not self._ping_stop.is_set():
            self._ping_event.clear()
            try:
                all_nodes = list(self._vless_data.get("manual", []))
                for sub in self._vless_data.get("subs", []):
                    all_nodes.extend(sub.get("nodes", []))
                if not all_nodes:
                    self._ping_event.wait(600)
                    continue
                def _ping_one(node):
                    try:
                        if self._ping_stop.is_set():
                            return False
                        uri = str(node.get("uri", "") or "")
                        cache_key = _node_dedup_key(uri)
                        now_ts = int(time.time())
                        ttl = int(VLESS_PING_CACHE_FG_TTL_SEC if bool(getattr(self, "_is_foreground", True)) else VLESS_PING_CACHE_BG_TTL_SEC)
                        if cache_key:
                            entry = self._ping_cache.get(cache_key)
                            if isinstance(entry, dict):
                                c_ts = _to_int(entry.get("ts", 0), 0)
                                if (now_ts - c_ts) < ttl:
                                    cached_ping = _to_int(entry.get("ping", -1), -1)
                                    if node.get("ping") != cached_ping:
                                        node["ping"] = cached_ping
                                        return True
                                    return False
                        host, port = _extract_proxy_host_port(node.get("uri", ""))
                        if not host or not port:
                            return False
                        st = time.time()
                        with socket.create_connection((str(host), int(port)), timeout=1.5):
                            pass
                        ping_ms = int((time.time() - st) * 1000)
                        if cache_key:
                            self._ping_cache[cache_key] = {"ts": now_ts, "ping": ping_ms}
                        if node.get("ping") != ping_ms:
                            node["ping"] = ping_ms
                            return True
                    except Exception:
                        try:
                            if cache_key:
                                self._ping_cache[cache_key] = {"ts": int(time.time()), "ping": 9999}
                        except Exception:
                            pass
                        if node.get("ping") != 9999:
                            node["ping"] = 9999
                            return True
                    return False
                changed = False
                with ThreadPoolExecutor(max_workers=12) as ex:
                    results = list(ex.map(_ping_one, all_nodes))
                    if any(results):
                        changed = True
                if changed:
                    self._vless_save_data()
                    try:
                        run_on_ui_thread(self._reload_settings_ui)
                    except Exception:
                        pass
                try:
                    if len(self._ping_cache) > 1200:
                        items = sorted(self._ping_cache.items(), key=lambda kv: _to_int((kv[1] or {}).get("ts", 0), 0), reverse=True)
                        self._ping_cache = dict(items[:900])
                except Exception:
                    pass
            except Exception:
                pass
            self._ping_event.wait(600)

    def _proxy_turned_off_externally(self) -> bool:
        try:
            if not MessagesController.getGlobalMainSettings().getBoolean("proxy_enabled", False):
                return True
        except Exception:
            pass
        try:
            cur = SharedConfig.currentProxy
            if cur is not None and str(cur.address) != VLESS_LOCAL_HOST:
                return True
        except Exception:
            pass
        return False

    def _handle_external_proxy_off(self):
        try:
            mode = self._normalize_mode(self.get_setting("mode", 1))
        except Exception:
            mode = 1
        _log("external proxy off detected -> disabling plugin")
        def _do():
            try:
                if mode == 2:
                    self.set_setting("tgws_enabled", False, reload_settings=False)
                    self._tgws_disconnect(silent=True)
                else:
                    self.set_setting("vless_enabled", False, reload_settings=False)
                    self._vless_disconnect(silent=True)
            except Exception:
                pass
        threading.Thread(target=_do, daemon=True).start()
        self._set_state(ConnState.DISCONNECTED)
        try:
            run_on_ui_thread(self._reload_settings_ui)
        except Exception:
            pass

    def _on_resume_reconnect_check(self):
        if self._stable_debounce("resume_reconnect", 2000):
            return
        try:
            mode = self._normalize_mode(self.get_setting("mode", 1))
        except Exception:
            mode = 1
        try:
            if mode == 2:
                if not bool(self.get_setting("tgws_enabled", False)):
                    return
                running = bool(getattr(self, "_tgws_running", False))
                if running and self._proxy_turned_off_externally():
                    self._handle_external_proxy_off()
                    return
                alive = running and _check_vless_port(int(getattr(self, "_tgws_port", 0) or 0), timeout=0.1)
                if not alive:
                    self._start_tgws_runtime(auto_start=False, delay_ms=0)
            else:
                if not (bool(self.get_setting("vless_enabled", False)) and bool(getattr(self, "_vless_active_uri", ""))):
                    return
                if bool(getattr(self, "_vless_running", False)) and self._proxy_turned_off_externally():
                    self._handle_external_proxy_off()
                    return
                if self._vless_runtime_port_alive():
                    self._reapply_vless_runtime_proxy()
                else:
                    threading.Thread(target=lambda: self._vless_connect(force=True), daemon=True).start()
        except Exception as e:
            _safe_log(f"resume reconnect check failed: {e}")

    def _install_resume_hook(self):
        try:
            plugin_ref = self
            class _ResumeHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        plugin_ref._on_resume_reconnect_check()
                    except Exception:
                        pass
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            if LaunchActivity:
                for m in LaunchActivity.getDeclaredMethods():
                    if m.getName() == "onResume" and len(m.getParameterTypes()) == 0:
                        self._safe_hook_method(m, _ResumeHook())
                        break
        except Exception:
            pass

    def _install_clipboard_hook(self):
        try:
            plugin_ref = self
            class _ClipboardHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        uris = plugin_ref._get_clipboard_proxy_uris()
                        if not uris:
                            return
                        if uris[0] == getattr(plugin_ref, "_last_clipboard_uri", ""):
                            return
                        manual = plugin_ref._vless_data.get("manual", [])
                        dedup_off = bool(plugin_ref.get_setting("vless_dedup_off", False))
                        existing = set([_node_dedup_key(str(n.get("uri", ""))) for n in manual]) if not dedup_off else set()
                        new_uris = []
                        for u in uris:
                            if not dedup_off:
                                k = _node_dedup_key(u)
                                if not k or k in existing:
                                    continue
                            new_uris.append(u)
                        plugin_ref._last_clipboard_uri = uris[0]
                        if not new_uris:
                            return
                        plugin_ref._show_clipboard_add_dialog(new_uris)
                    except:
                        pass
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            if LaunchActivity:
                for m in LaunchActivity.getDeclaredMethods():
                    if m.getName() == "onResume" and len(m.getParameterTypes()) == 0:
                        self._safe_hook_method(m, _ClipboardHook())
                        break
        except:
            pass

    def _get_clipboard_proxy_uris(self):
        try:
            ctx = ApplicationLoader.applicationContext
            cm = ctx.getSystemService("clipboard")
            if not cm or not cm.hasPrimaryClip():
                return []
            clip = cm.getPrimaryClip()
            if not clip or clip.getItemCount() == 0:
                return []
            item = clip.getItemAt(0)
            if not item:
                return []
            text = str(item.getText() or "")
            if not text:
                return []
            found = []
            try:
                found.extend(PROXY_URI_RE.findall(text))
            except Exception:
                pass
            try:
                hit_links = re.findall(r"(?:https?://(?:hvpn|hitray)\.io/[^\s\"'<>]+|hitvpn://[^\s\"'<>]+)", text, re.IGNORECASE)
            except Exception:
                hit_links = []
            for hu in hit_links:
                try:
                    found.extend(_decode_hitvpn_link_to_vless_uris(hu))
                except Exception:
                    continue
            out = []
            seen = set()
            for u in found:
                su = _sanitize_vless_uri(u)
                if su and _is_proxy_uri(su) and su not in seen:
                    seen.add(su)
                    out.append(su)
            return out[:10]
        except:
            return []

    def _show_clipboard_add_dialog(self, uris_or_uri):
        if isinstance(uris_or_uri, str):
            uris = [uris_or_uri]
        else:
            uris = list(uris_or_uri or [])
        if not uris:
            return
        def _do():
            try:
                b = AlertDialogBuilder(get_last_fragment())
                if len(uris) == 1:
                    cfg, name = VlessConfigParser.parse(uris[0], 1080)
                    if not name:
                        name = Z("vless_node_default")
                    short = uris[0][:60] + "..." if len(uris[0]) > 60 else uris[0]
                    msg = f"{name}\n\n{short}"
                    title = Z("vless_add_key")
                else:
                    title = Z("vless_add_key")
                    lines = []
                    for u in uris[:10]:
                        _, n = VlessConfigParser.parse(u, 1080)
                        n = n or Z("vless_node_default")
                        lines.append("- " + n)
                    msg = "\n".join(lines)
                b.set_title(str(title))
                b.set_message(str(msg))
                def add_all(d=None, w=None):
                    try:
                        added = 0
                        manual = self._vless_data.get("manual", [])
                        dedup_off = bool(self.get_setting("vless_dedup_off", False))
                        existing = set([_node_dedup_key(str(n.get("uri", ""))) for n in manual]) if not dedup_off else set()
                        for u in uris:
                            if not dedup_off:
                                k = _node_dedup_key(u)
                                if not k or k in existing:
                                    continue
                            cfg, name = VlessConfigParser.parse(u, 1080)
                            if not cfg:
                                continue
                            manual.append({"name": name or Z("vless_node_default"), "uri": u, "ping": -1})
                            existing.add(k)
                            added += 1
                        self._vless_data["manual"] = manual
                        self._vless_save_data()
                        self._ping_event.set()
                        run_on_ui_thread(self._reload_settings_ui)
                        if added > 0:
                            BulletinHelper.show_success(Z("refresh"))
                    except:
                        pass
                    try:
                        if d: d.dismiss()
                    except:
                        pass
                b.set_positive_button(Z("btn_add") if "btn_add" in TRANSLATIONS else "OK", add_all)
                b.set_negative_button(Z("btn_cancel"), lambda d, w: d.dismiss())
                b.show()
            except:
                pass
        run_on_ui_thread(_do)