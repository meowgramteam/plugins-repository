# Структуры для натива
class RetroGameInfo(ctypes.Structure):
    _fields_ = [
        ("path", ctypes.c_char_p),
        ("data", ctypes.c_void_p),
        ("size", ctypes.c_size_t),
        ("meta", ctypes.c_char_p),
    ]

class RetroGameGeometry(ctypes.Structure):
    _fields_ = [
        ("base_width", ctypes.c_uint),
        ("base_height", ctypes.c_uint),
        ("max_width", ctypes.c_uint),
        ("max_height", ctypes.c_uint),
        ("aspect_ratio", ctypes.c_float),
    ]

class RetroSystemTiming(ctypes.Structure):
    _fields_ = [
        ("fps", ctypes.c_double),
        ("sample_rate", ctypes.c_double),
    ]

class RetroSystemAvInfo(ctypes.Structure):
    _fields_ = [
        ("geometry", RetroGameGeometry),
        ("timing", RetroSystemTiming),
    ]

class RetroSystemInfo(ctypes.Structure):
    _fields_ = [
        ("library_name", ctypes.c_char_p),
        ("library_version", ctypes.c_char_p),
        ("valid_extensions", ctypes.c_char_p),
        ("need_fullpath", ctypes.c_bool),
        ("block_extract", ctypes.c_bool),
    ]

class RetroVariable(ctypes.Structure):
    _fields_ = [
        ("key", ctypes.c_char_p),
        ("value", ctypes.c_char_p),
    ]


EnvironmentCallback = ctypes.CFUNCTYPE(ctypes.c_int, ctypes.c_uint, ctypes.c_void_p)
VideoRefreshCallback = ctypes.CFUNCTYPE(None, ctypes.c_void_p, ctypes.c_uint, ctypes.c_uint, ctypes.c_size_t)
AudioSampleCallback = ctypes.CFUNCTYPE(None, ctypes.c_int16, ctypes.c_int16)
AudioSampleBatchCallback = ctypes.CFUNCTYPE(
    ctypes.c_ulong, ctypes.POINTER(ctypes.c_int16), ctypes.c_ulong
)
InputPollCallback = ctypes.CFUNCTYPE(None)
InputStateCallback = ctypes.CFUNCTYPE(ctypes.c_int16, ctypes.c_uint, ctypes.c_uint, ctypes.c_uint, ctypes.c_uint)

_ACTIVE_EMULATOR: "LibretroEmulator | None" = None


@EnvironmentCallback
def _environment_trampoline(cmd: int, data: ctypes.c_void_p) -> int:
    emu = _ACTIVE_EMULATOR
    if emu is None:
        return 0
    return emu._handle_environment(cmd, data)

@VideoRefreshCallback
def _video_refresh_trampoline(data: ctypes.c_void_p, width: int, height: int, pitch: int) -> None:
    emu = _ACTIVE_EMULATOR
    if emu is not None:
        emu._video_refresh(data, width, height, pitch)

@AudioSampleCallback
def _audio_sample_trampoline(left: int, right: int) -> None:
    emu = _ACTIVE_EMULATOR
    if emu is not None:
        emu._audio_sample(left, right)

@AudioSampleBatchCallback
def _audio_batch_trampoline(data: ctypes.POINTER(ctypes.c_int16), frames: int) -> int:
    emu = _ACTIVE_EMULATOR
    if emu is not None:
        return ctypes.c_ulong(emu._audio_batch(data, frames))
    return ctypes.c_ulong(int(frames))

@InputPollCallback
def _input_poll_trampoline() -> None:
    pass

@InputStateCallback
def _input_state_trampoline(port: int, device: int, index: int, button_id: int) -> int:
    emu = _ACTIVE_EMULATOR
    if emu is None:
        return 0
    return emu._input_state(port, device, index, button_id)

# Главная обертка над эмулятором
class LibretroEmulator:
    def __init__(self, lib: ctypes.CDLL, *, system_dir: str) -> None:
        self._lib = lib
        self._system_dir = system_dir
        self._started = False
        self._game_loaded = False

        self._pixel_format = RETRO_PIXEL_FORMAT_0RGB1555
        self._frame_width = 0
        self._frame_height = 0
        self._frame_pitch = 0
        self._width = 256
        self._height = 240
        self._fps = 60.0
        self._sample_rate = 44100.0
        self._audio_player = None

        self._buttons: dict[tuple[int, int], int] = {}
        self._variables: dict[str, str] = {}
        self._rom_path: str | None = None
        self._owned_rom_path: str | None = None
        self._c_buffers: list[ctypes.Array] = []
        self._display_buf: bytearray | None = None
        self._frame_seq = 0

        self._bind_api()

    def bind_display_buffer(self, buf: bytearray | None) -> None:
        self._display_buf = buf
        self._frame_seq = 0

    def _bind_api(self) -> None:
        lib = self._lib
        lib.retro_init.restype = None
        lib.retro_deinit.restype = None
        lib.retro_reset.restype = None
        lib.retro_run.restype = None
        lib.retro_unload_game.restype = None
        lib.retro_api_version.restype = ctypes.c_uint
        lib.retro_get_system_info.argtypes = [ctypes.POINTER(RetroSystemInfo)]
        lib.retro_get_system_av_info.argtypes = [ctypes.POINTER(RetroSystemAvInfo)]
        lib.retro_set_environment.argtypes = [EnvironmentCallback]
        lib.retro_set_video_refresh.argtypes = [VideoRefreshCallback]
        lib.retro_set_audio_sample.argtypes = [AudioSampleCallback]
        lib.retro_set_audio_sample_batch.argtypes = [AudioSampleBatchCallback]
        lib.retro_set_input_poll.argtypes = [InputPollCallback]
        lib.retro_set_input_state.argtypes = [InputStateCallback]
        lib.retro_load_game.argtypes = [ctypes.POINTER(RetroGameInfo)]
        lib.retro_load_game.restype = ctypes.c_uint8

    @staticmethod
    def _parse_variable_default(raw: str) -> str:
        if "; " not in raw:
            return raw
        return raw.split("; ", 1)[1].split("|")[0]

    def _import_variables(self, data: ctypes.c_void_p) -> None:
        self._variables = {}
        if not data:
            log("SET_VARIABLES: empty payload")
            return

        items = ctypes.cast(data, ctypes.POINTER(RetroVariable))
        index = 0
        while items[index].key:
            key = ctypes.string_at(items[index].key).decode("utf-8")
            raw = ""
            if items[index].value:
                raw = ctypes.string_at(items[index].value).decode("utf-8")
            self._variables[key] = self._parse_variable_default(raw)
            index += 1
        log(f"SET_VARIABLES: imported {len(self._variables)} vars")

    def _keep_c_string(self, value: str) -> ctypes.c_char_p:
        buf = ctypes.create_string_buffer(value.encode("utf-8"))
        self._c_buffers.append(buf)
        return ctypes.cast(buf, ctypes.c_char_p)

    def _keep_rom_buffer(self, rom: bytes) -> tuple[ctypes.c_void_p, int]:
        buf = (ctypes.c_char * len(rom)).from_buffer_copy(rom)
        self._c_buffers.append(buf)
        return ctypes.cast(buf, ctypes.c_void_p), len(rom)

    def _write_bool(self, data: ctypes.c_void_p, value: bool) -> None:
        out = ctypes.cast(data, ctypes.POINTER(ctypes.c_uint8))
        out.contents.value = 1 if value else 0

    @property
    def _rom_dir(self) -> str:
        path = os.path.join(self._system_dir, "tmp")
        os.makedirs(path, exist_ok=True)
        return path

    def _handle_environment(self, cmd: int, data: ctypes.c_void_p) -> int:
        if cmd in (ENV_GET_SYSTEM_DIRECTORY, ENV_GET_SAVE_DIRECTORY):
            out = ctypes.cast(data, ctypes.POINTER(ctypes.c_char_p))
            out.contents = self._keep_c_string(self._system_dir)
            return 1

        if cmd == ENV_GET_CAN_DUPE:
            self._write_bool(data, True)
            return 1

        if cmd == ENV_SET_PIXEL_FORMAT:
            out = ctypes.cast(data, ctypes.POINTER(ctypes.c_int))
            self._pixel_format = int(out.contents.value)
            log(f"SET_PIXEL_FORMAT: {self._pixel_format}")
            return 1

        if cmd == ENV_SET_VARIABLES:
            self._import_variables(data)
            return 1

        if cmd == ENV_GET_VARIABLE:
            var = ctypes.cast(data, ctypes.POINTER(RetroVariable)).contents
            if not var.key:
                return 0
            key = ctypes.string_at(var.key).decode("utf-8")
            value = self._variables.get(key)
            if value is None:
                return 0
            var.value = self._keep_c_string(value)
            return 1

        if cmd in (
            ENV_SET_CONTENT_INFO_OVERRIDE,
            ENV_SET_CONTROLLER_INFO,
            ENV_SET_INPUT_DESCRIPTORS,
            ENV_SET_MEMORY_MAPS,
            ENV_SET_CORE_OPTIONS_DISPLAY,
        ):
            return 1

        if cmd == ENV_GET_VARIABLE_UPDATE:
            self._write_bool(data, False)
            return 1

        return 0

    def _video_refresh(self, data: ctypes.c_void_p, width: int, height: int, pitch: int) -> None:
        if int(width) > 0 and int(height) > 0:
            self._frame_width = int(width)
            self._frame_height = int(height)
            self._frame_pitch = int(pitch) if int(pitch) > 0 else int(width) * 2
        if not data:
            return

        frame_w = int(self._frame_width)
        frame_h = int(self._frame_height)
        if frame_w <= 0 or frame_h <= 0:
            return

        row_bytes = frame_w * 2
        pitch = int(self._frame_pitch or row_bytes)
        need = row_bytes * frame_h
        target = self._display_buf

        if target is not None:
            try:
                target_len = len(target)
            except Exception:
                target_len = 0
            if target_len >= need:
                _memmove_to_display_target(
                    target,
                    data,
                    need=need,
                    row_bytes=row_bytes,
                    frame_h=frame_h,
                    pitch=pitch,
                )
                self._frame_seq += 1

    def frame_dims(self) -> tuple[int, int]:
        width = int(self._frame_width or self._width or 0)
        height = int(self._frame_height or self._height or 0)
        return width, height

    def attach_audio(self, player) -> None:
        self._audio_player = player

    def _audio_sample(self, left: int, right: int) -> None:
        player = self._audio_player
        if player is not None:
            player.push_sample(left, right)

    def _audio_batch(self, data: ctypes.POINTER(ctypes.c_int16), frames: int) -> int:
        player = self._audio_player
        if player is not None:
            return player.push_batch(data, frames)
        return int(frames)

    def _input_poll(self) -> None:
        pass

    def _input_state(self, port: int, device: int, index: int, button_id: int) -> int:
        if device == RETRO_DEVICE_JOYPAD:
            return self._buttons.get((int(port), int(button_id)), 0)
        return 0

    def start(self) -> None:
        global _ACTIVE_EMULATOR
        if self._started:
            _ACTIVE_EMULATOR = self
            return
        _ACTIVE_EMULATOR = self
        self._lib.retro_set_environment(_environment_trampoline)
        self._lib.retro_set_video_refresh(_video_refresh_trampoline)
        self._lib.retro_set_audio_sample(_audio_sample_trampoline)
        self._lib.retro_set_audio_sample_batch(_audio_batch_trampoline)
        self._lib.retro_set_input_poll(_input_poll_trampoline)
        self._lib.retro_set_input_state(_input_state_trampoline)
        self._lib.retro_init()
        self._started = True
        log("start: done")

    def shutdown(self) -> None:
        global _ACTIVE_EMULATOR
        self._audio_player = None
        self.bind_display_buffer(None)
        self._c_buffers.clear()
        if self._game_loaded:
            self.unload_rom()
        if self._started:
            self._lib.retro_deinit()
            self._started = False
        if _ACTIVE_EMULATOR is self:
            _ACTIVE_EMULATOR = None

    def system_info(self) -> dict[str, str | bool]:
        info = RetroSystemInfo()
        self._lib.retro_get_system_info(ctypes.byref(info))
        return {
            "name": info.library_name.decode("utf-8", "replace") if info.library_name else "",
            "version": info.library_version.decode("utf-8", "replace") if info.library_version else "",
            "extensions": info.valid_extensions.decode("utf-8", "replace") if info.valid_extensions else "",
            "need_fullpath": bool(info.need_fullpath),
        }

    # Загрузка rom игры
    def _load_rom_data(self, rom: bytes, rom_path: str, *, owned: bool = False) -> None:
        if not self._started:
            raise RuntimeError("Emulator is not started")
        if not rom:
            raise ValueError("ROM is empty")

        rom_path = os.path.realpath(rom_path)
        log(f"load_rom: path={rom_path} bytes={len(rom)} owned={owned}")

        if self._game_loaded:
            log("load_rom: unloading previous game")
            self.unload_rom()

        self._rom_path = rom_path
        self._owned_rom_path = rom_path if owned else None
        self._c_buffers.clear()

        data_ptr, size = self._keep_rom_buffer(rom)
        game_info = RetroGameInfo(
            path=self._keep_c_string(rom_path),
            data=data_ptr,
            size=size,
            meta=None,
        )
        log("load_rom: calling retro_load_game")
        ok = bool(self._lib.retro_load_game(ctypes.byref(game_info)))
        log(f"load_rom: retro_load_game returned {ok}")
        if not ok:
            self._rom_path = None
            self._owned_rom_path = None
            raise RuntimeError(f"retro_load_game failed: {rom_path}")

        av = RetroSystemAvInfo()
        self._lib.retro_get_system_av_info(ctypes.byref(av))
        self._width = int(av.geometry.base_width)
        self._height = int(av.geometry.base_height)
        self._fps = float(av.timing.fps)
        self._sample_rate = float(av.timing.sample_rate or 44100.0)
        self._game_loaded = True
        log(
            f"load_rom: ok {self._width}x{self._height} @ {self._fps:.2f} fps "
            f"audio={self._sample_rate:.0f}Hz"
        )
        if self._pixel_format == RETRO_PIXEL_FORMAT_0RGB1555:
            self._pixel_format = RETRO_PIXEL_FORMAT_RGB565

    def _load_rom_file(self, rom_path: str, *, owned: bool = False) -> None:
        rom_path = os.path.realpath(rom_path)
        if not os.path.isfile(rom_path):
            raise FileNotFoundError(rom_path)
        with open(rom_path, "rb") as file:
            rom = file.read()
        self._load_rom_data(rom, rom_path, owned=owned)

    def load_rom(self, path: str) -> None:
        self._load_rom_file(path, owned=False)

    def load_rom_bytes(self, rom: bytes, filename: str = "game.nes") -> str:
        if not rom:
            raise ValueError("ROM is empty")

        name = os.path.basename(filename) or "game.nes"
        if not name.lower().endswith((".nes", ".fds", ".unf", ".unif")):
            name += ".nes"

        rom_path = os.path.join(self._rom_dir, name)
        log(f"load_rom_bytes: writing {len(rom)} bytes to {rom_path}")
        with open(rom_path, "wb") as file:
            file.write(bytes(rom))

        self._load_rom_data(rom, rom_path, owned=True)
        return rom_path

    def unload_rom(self) -> None:
        if not self._game_loaded:
            return
        self._lib.retro_unload_game()
        self._game_loaded = False
        if self._owned_rom_path:
            try:
                os.remove(self._owned_rom_path)
            except OSError:
                pass
        self._rom_path = None
        self._owned_rom_path = None

    def reset(self) -> None:
        if not self._game_loaded:
            raise RuntimeError("No ROM loaded")
        self._lib.retro_reset()

    def run_frame(self) -> None:
        if not self._game_loaded:
            raise RuntimeError("No ROM loaded")
        self._lib.retro_run()

    def set_button(self, port: int, button_id: int, pressed: bool) -> None:
        self._buttons[(int(port), int(button_id))] = 1 if pressed else 0

    @property
    def width(self) -> int:
        return self._width

    @property
    def height(self) -> int:
        return self._height

    @property
    def fps(self) -> float:
        return self._fps

    @property
    def sample_rate(self) -> float:
        return self._sample_rate

# Классы для работы звука
class _PcmRingBuffer:
    __slots__ = ("_buf", "_cap", "_r", "_size")

    def __init__(self, capacity: int) -> None:
        self._buf = bytearray(capacity)
        self._cap = capacity
        self._r = 0
        self._size = 0

    def clear(self) -> None:
        self._r = 0
        self._size = 0

    def __len__(self) -> int:
        return self._size

    @property
    def _w(self) -> int:
        return (self._r + self._size) % self._cap

    def _drop_oldest(self, nbytes: int) -> None:
        nbytes = min(int(nbytes), self._size)
        if nbytes <= 0:
            return
        self._r = (self._r + nbytes) % self._cap
        self._size -= nbytes

    def write_from_pointer(self, src: ctypes.c_void_p, nbytes: int) -> None:
        nbytes = int(nbytes)
        if nbytes <= 0:
            return
        if nbytes > self._cap:
            skip = nbytes - self._cap
            base = ctypes.cast(src, ctypes.POINTER(ctypes.c_char))
            src = ctypes.cast(ctypes.addressof(base.contents) + skip, ctypes.c_void_p)
            nbytes = self._cap
            self.clear()

        free = self._cap - self._size
        if nbytes > free:
            self._drop_oldest(nbytes - free)

        src_p = ctypes.cast(src, ctypes.POINTER(ctypes.c_char))
        w = self._w
        first = min(nbytes, self._cap - w)
        if first > 0:
            ctypes.memmove(
                (ctypes.c_char * first).from_buffer(self._buf, w),
                src_p,
                first,
            )
        remain = nbytes - first
        if remain > 0:
            ctypes.memmove(
                (ctypes.c_char * remain).from_buffer(self._buf, 0),
                ctypes.cast(ctypes.addressof(src_p.contents) + first, ctypes.POINTER(ctypes.c_char)),
                remain,
            )
        self._size += nbytes

    def contiguous_readable(self) -> int:
        if self._size <= 0:
            return 0
        return min(self._size, self._cap - self._r)

    def read_into(self, dst, offset: int, nbytes: int) -> int:
        nbytes = min(int(nbytes), self._size)
        if nbytes <= 0:
            return 0
        first = min(nbytes, self._cap - self._r)
        if first > 0:
            ctypes.memmove(
                (ctypes.c_char * first).from_buffer(dst, offset),
                (ctypes.c_char * first).from_buffer(self._buf, self._r),
                first,
            )
        remain = nbytes - first
        if remain > 0:
            ctypes.memmove(
                (ctypes.c_char * remain).from_buffer(dst, offset + first),
                (ctypes.c_char * remain).from_buffer(self._buf, 0),
                remain,
            )
        self._r = (self._r + nbytes) % self._cap
        self._size -= nbytes
        return nbytes


class RetroAudioPlayer:
    _RING_BYTES = 44100 * 2
    _WRITE_CHUNK = 4096

    def __init__(self) -> None:
        self._track = None
        self._sample_rate = 44100
        self._started = False
        self._write_error_logged = False
        self._ring = _PcmRingBuffer(self._RING_BYTES)
        self._queue_lock = threading.Lock()
        self._wake = threading.Event()
        self._thread: threading.Thread | None = None
        self._bb_cls = None
        self._bb = None
        self._bb_cap = 0
        self._bb_mem = None
        self._bb_works: bool | None = None
        self._jpcm = None
        self._jpcm_len = 0
        self._sample_scratch = (ctypes.c_int16 * 2)()

    def start(self, sample_rate: float) -> None:
        self.stop()
        self._write_error_logged = False
        self._bb_works = None
        self._sample_rate = max(int(sample_rate or 44100), 8000)
        AudioTrack = find_class("android.media.AudioTrack")
        AudioFormat = find_class("android.media.AudioFormat")
        AudioManager = find_class("android.media.AudioManager")
        channel = AudioFormat.CHANNEL_OUT_STEREO
        encoding = AudioFormat.ENCODING_PCM_16BIT
        min_buf = int(AudioTrack.getMinBufferSize(self._sample_rate, channel, encoding))
        buffer_size = max(min_buf * 6, 16384)
        self._track = AudioTrack(
            AudioManager.STREAM_MUSIC,
            self._sample_rate,
            channel,
            encoding,
            buffer_size,
            AudioTrack.MODE_STREAM,
        )
        self._track.play()
        try:
            self._track.setVolume(1.0)
        except Exception:
            pass
        if self._bb_cls is None:
            self._bb_cls = find_class("java.nio.ByteBuffer")
        self._bb = self._bb_cls.allocateDirect(self._WRITE_CHUNK)
        self._bb_cap = int(self._bb.capacity())
        self._bb_mem = None
        addr = _resolve_direct_byte_buffer_address(self._bb)
        if addr:
            self._bb_mem = (ctypes.c_char * self._bb_cap).from_address(addr)
            log(f"audio: zero-copy direct buffer @ 0x{addr:x}")
        else:
            log("audio: direct buffer address unavailable, using fallback writes")
        self._started = True
        self._wake.set()
        self._thread = threading.Thread(target=self._drain_loop, daemon=True)
        self._thread.start()
        log(f"audio: started {self._sample_rate}Hz buffer={buffer_size}")

    def stop(self) -> None:
        self._started = False
        self._wake.set()
        track = self._track
        self._track = None
        if track is not None:
            try:
                track.pause()
                track.flush()
                track.stop()
                track.release()
            except Exception as error:
                log(f"audio: stop failed: {error}")
        thread = self._thread
        self._thread = None
        if thread is not None and thread is not threading.current_thread():
            try:
                thread.join(0.5)
            except Exception:
                pass
        with self._queue_lock:
            self._ring.clear()
        self._bb = None
        self._bb_mem = None
        self._bb_cap = 0
        self._bb_works = None
        self._jpcm = None
        self._jpcm_len = 0

    def push_sample(self, left: int, right: int) -> None:
        if not self._started:
            return
        scratch = self._sample_scratch
        scratch[0] = max(-32768, min(32767, int(left)))
        scratch[1] = max(-32768, min(32767, int(right)))
        with self._queue_lock:
            self._ring.write_from_pointer(
                ctypes.cast(scratch, ctypes.c_void_p),
                4,
            )
        self._wake.set()

    def push_batch(self, data: ctypes.POINTER(ctypes.c_int16), frames: int) -> int:
        frame_count = int(frames)
        if frame_count <= 0 or not self._started or not data:
            return frame_count
        byte_count = frame_count * 4
        with self._queue_lock:
            self._ring.write_from_pointer(ctypes.cast(data, ctypes.c_void_p), byte_count)
        self._wake.set()
        return frame_count

    def _drain_loop(self) -> None:
        scratch = (ctypes.c_char * self._WRITE_CHUNK)()
        while self._started:
            self._wake.wait(0.008)
            if not self._started:
                break
            while self._started:
                with self._queue_lock:
                    pending = len(self._ring)
                    if pending <= 0:
                        self._wake.clear()
                        break
                    chunk = min(pending, self._WRITE_CHUNK, self._ring.contiguous_readable())
                    if chunk <= 0:
                        break
                    if self._bb_mem is not None:
                        read_n = self._ring.read_into(self._bb_mem, 0, chunk)
                    else:
                        read_n = self._ring.read_into(scratch, 0, chunk)
                if read_n <= 0:
                    break
                if self._bb_mem is not None:
                    self._write_chunk(read_n)
                else:
                    self._write_pcm_bytes(memoryview(scratch)[:read_n])

    def _write_chunk(self, byte_count: int) -> None:
        track = self._track
        bb = self._bb
        if not track or not bb or byte_count <= 0:
            return
        if self._bb_works is not False:
            try:
                bb.position(0)
                bb.limit(byte_count)
                written = int(track.write(bb, byte_count, 0))
                if written > 0:
                    self._bb_works = True
                    return
                self._bb_works = False
            except Exception:
                self._bb_works = False
        self._direct_write_pcm_bytes(byte_count)

    def _write_pcm_bytes(self, pcm) -> None:
        track = self._track
        if not track or not pcm:
            return
        byte_count = len(pcm)
        if byte_count <= 0:
            return
        if self._bb_works is not False and self._bb_mem is not None and byte_count <= self._bb_cap:
            ctypes.memmove(self._bb_mem, (ctypes.c_char * byte_count).from_buffer(pcm), byte_count)
            self._write_chunk(byte_count)
            return
        if self._bb_works is not False and self._write_via_bytebuffer(track, pcm, byte_count):
            return
        self._write_via_bytearray(track, pcm, byte_count)

    def _direct_write_pcm_bytes(self, byte_count: int) -> None:
        track = self._track
        if not track or byte_count <= 0 or self._bb_mem is None:
            return
        try:
            if self._jpcm is None or self._jpcm_len < byte_count:
                self._jpcm = jarray(jbyte)(byte_count)
                self._jpcm_len = byte_count
            jpcm = self._jpcm
            mem = self._bb_mem
            for i in range(byte_count):
                b = mem[i]
                jpcm[i] = b if b < 128 else b - 256
            offset = 0
            while offset < byte_count and self._started:
                written = int(track.write(jpcm, offset, byte_count - offset))
                if written <= 0:
                    break
                offset += written
        except Exception as error:
            if not self._write_error_logged:
                self._write_error_logged = True
                log(f"audio: write failed: {error}")

    def _write_via_bytebuffer(self, track, pcm, byte_count: int) -> bool:
        try:
            if self._bb_cls is None:
                self._bb_cls = find_class("java.nio.ByteBuffer")
            if self._bb is None or self._bb_cap < byte_count:
                self._bb = self._bb_cls.allocateDirect(max(byte_count, self._WRITE_CHUNK))
                self._bb_cap = int(self._bb.capacity())
                self._bb_mem = None
                addr = _resolve_direct_byte_buffer_address(self._bb)
                if addr:
                    self._bb_mem = (ctypes.c_char * self._bb_cap).from_address(addr)
            bb = self._bb
            if self._bb_mem is not None:
                ctypes.memmove(self._bb_mem, (ctypes.c_char * byte_count).from_buffer(pcm), byte_count)
            else:
                bb.clear()
                bb.put(pcm)
            bb.position(0)
            bb.limit(byte_count)
            written = int(track.write(bb, byte_count, 0))
            if written > 0:
                self._bb_works = True
                return True
        except Exception:
            pass
        self._bb_works = False
        return False

    def _write_via_bytearray(self, track, pcm, byte_count: int) -> None:
        try:
            if self._jpcm is None or self._jpcm_len < byte_count:
                self._jpcm = jarray(jbyte)(byte_count)
                self._jpcm_len = byte_count
            jpcm = self._jpcm
            if isinstance(pcm, memoryview):
                raw = pcm.obj
                start = pcm.start or 0
                for i in range(byte_count):
                    b = raw[start + i]
                    jpcm[i] = b if b < 128 else b - 256
            else:
                for i in range(byte_count):
                    b = pcm[i]
                    jpcm[i] = b if b < 128 else b - 256
            offset = 0
            while offset < byte_count and self._started:
                written = int(track.write(jpcm, offset, byte_count - offset))
                if written <= 0:
                    break
                offset += written
        except Exception as error:
            if not self._write_error_logged:
                self._write_error_logged = True
                log(f"audio: write failed: {error}")


# Главный класс плагина
class NesEmuPlugin(BasePlugin):
    def __init__(self) -> None:
        super().__init__()
        self.library = LibretroLibrary(
            filename=LIB_FILENAME,
            expected_sha256=LIB_SHA256,
            cache_dirname=CACHE_DIRNAME,
            data_b64=LIB_B64,
        )
        self.emulator: LibretroEmulator | None = None
        self.dialog = None
        self.activity = None
        self.orig_orient = None
        self.running = False
        self.loop_thread = None
        self.bitmap = None
        self.image = None
        self.width = 256
        self.height = 240
        self._ui_refs: list = []
        self._native_lock = threading.RLock()
        self._byte_buffer_cls = None
        self._display_buffer: bytearray | None = None
        self._display_ctypes = None
        self._display_direct = False
        self._applied_tick = -1
        self._java_buffer = None
        self._java_buffer_need = 0
        self._blit_direct = None
        self._ui_busy = False
        self._bitmap_w = 0
        self._bitmap_h = 0
        self._hooks: list = []
        self._rom_path: str | None = None
        self._pending_file_name: str | None = None
        self._pending_launch_after_download = False
        self._download_delegate = None
        self._observer_account = None
        self.audio_player = RetroAudioPlayer()
        self._touch_active: dict[int, int] = {}
        self._touch_targets: list = []
        self._session_active = False
        self._releasing = False

    def _register_touch_target(self, view, button_id: int) -> None:
        self._touch_targets.append((view, int(button_id)))

    def _hit_touch_button(self, raw_x: float, raw_y: float):
        # Прямой порядок: крестовина (ВЛЕВО перед ВНИЗ), затем центр, затем B перед A
        for view, button_id in self._touch_targets:
            try:
                loc = jarray(jint)([0, 0])
                view.getLocationOnScreen(loc)
                inset = _TOUCH_HIT_INSET_PX.get(int(button_id), (0, 0, 0, 0))
                left = int(loc[0]) + inset[0]
                top = int(loc[1]) + inset[1]
                right = left + int(view.getWidth()) - inset[0] - inset[2]
                bottom = top + int(view.getHeight()) - inset[1] - inset[3]
                if left <= raw_x < right and top <= raw_y < bottom:
                    return button_id
            except Exception:
                pass
        return None

    def _clear_touch_state(self) -> None:
        for button_id in set(self._touch_active.values()):
            self._send_button(button_id, False)
        self._touch_active.clear()

    def _handle_overlay_touch(self, view, event) -> bool:
        MotionEvent = find_class("android.view.MotionEvent")
        try:
            action = event.getActionMasked()
            pointer_index = int(event.getActionIndex())
            pointer_id = int(event.getPointerId(pointer_index))
        except Exception:
            return True

        if action in (MotionEvent.ACTION_DOWN, MotionEvent.ACTION_POINTER_DOWN):
            raw_x = float(event.getRawX(pointer_index))
            raw_y = float(event.getRawY(pointer_index))
            button_id = self._hit_touch_button(raw_x, raw_y)
            if button_id is not None:
                prev = self._touch_active.get(pointer_id)
                if prev is not None and prev != button_id:
                    self._send_button(prev, False)
                self._touch_active[pointer_id] = button_id
                self._send_button(button_id, True)
            return True

        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_POINTER_UP):
            button_id = self._touch_active.pop(pointer_id, None)
            if button_id is not None:
                self._send_button(button_id, False)
            return True

        if action == MotionEvent.ACTION_CANCEL:
            self._clear_touch_state()
            return True

        if action == MotionEvent.ACTION_MOVE:
            count = int(event.getPointerCount())
            for i in range(count):
                pid = int(event.getPointerId(i))
                if pid not in self._touch_active:
                    continue
                raw_x = float(event.getRawX(i))
                raw_y = float(event.getRawY(i))
                current = self._hit_touch_button(raw_x, raw_y)
                held = self._touch_active[pid]
                if current != held:
                    self._send_button(held, False)
                    if current is not None:
                        self._touch_active[pid] = current
                        self._send_button(current, True)
                    else:
                        del self._touch_active[pid]
            return True

        return True

    def on_plugin_load(self):
        log("on_plugin_load")
        _relax_hidden_api()
        self._log_core_info()
        self._hook_android_utilities()

    def _log_core_info(self) -> None:
        try:
            info = self.library.get_system_info()
            name = info.get("name") or "unknown"
            version = info.get("version") or "?"
            extensions = info.get("extensions") or ""
            need_fullpath = bool(info.get("need_fullpath"))
            log(f"core: {name} v{version}")
            if extensions:
                log(f"core extensions: {extensions}")
            log(f"core need_fullpath: {need_fullpath}")
        except Exception as error:
            log(f"core info failed: {error}")

    def on_plugin_unload(self):
        self._release_emulator_resources()
        self._reset_pending_download_state()
        self._detach_download_observer()
        for hook in self._hooks:
            try:
                self.unhook_method(hook)
            except Exception:
                pass
        self._hooks.clear()
        try:
            self.library.release()
        except Exception as error:
            log(f"library release failed: {error}")
        global _ACTIVE_EMULATOR
        _ACTIVE_EMULATOR = None

    def launch_rom(self, rom_path: str) -> None:
        run_on_ui_thread(lambda: self._launch_game_ui(str(rom_path)))

    def _launch_game_ui(self, rom_path: str) -> None:
        try:
            log(f"launch: start {rom_path}")
            rom_path = os.path.realpath(str(rom_path))
            if not os.path.isfile(rom_path):
                raise FileNotFoundError(f"ROM not found: {rom_path}")
            fragment = get_last_fragment()
            activity = fragment.getParentActivity() if fragment else None
            if not activity:
                log("launch: no activity/fragment")
                return
            self.stop_game()
            self._ensure_emulator(rom_path)
            width = int(self.emulator.width)
            height = int(self.emulator.height)
            self._ensure_display_buffer(width, height)
            self.audio_player.start(self.emulator.sample_rate)
            self.emulator.run_frame()
            emu = self.emulator
            self.width, self.height = emu.frame_dims()
            self._build_dialog(activity)
            self._session_active = True
            self.running = True
            self._applied_tick = -1
            self._apply_frame()
            self.loop_thread = threading.Thread(target=self._game_loop, daemon=True)
            self.loop_thread.start()
        except Exception as error:
            log(f"NES launch failed: {error}")
            log(traceback.format_exc())
            self._show_error(str(error))

    def _ensure_emulator(self, rom_path: str) -> None:
        rom_path = os.path.realpath(str(rom_path))
        with open(rom_path, "rb") as rom_file:
            rom_data = rom_file.read()
        if not rom_data:
            raise ValueError(f"ROM file is empty: {rom_path}")
        # QuickNES корректно инициализирует звук только при первой загрузке
        # каждого образа .so в процессе. Поэтому каждую сессию грузим ядро
        # заново (свежая копия .so) с полным retro_init.
        log("ensure_emulator: fresh core load")
        if self.emulator:
            try:
                self.emulator.shutdown()
            except Exception:
                pass
            self.emulator = None
        if self.library.lib is not None:
            try:
                self.library.release()
            except Exception as error:
                log(f"library release before fresh load failed: {error}")
        lib = self.library.load()
        self.emulator = LibretroEmulator(lib, system_dir=self.library.cache_dir)
        self.emulator.attach_audio(self.audio_player)
        self.emulator.start()
        self.emulator.load_rom_bytes(rom_data, os.path.basename(rom_path))
        self._rom_path = rom_path
        log(
            f"emulator ready {self.emulator.width}x{self.emulator.height} "
            f"@ {self.emulator.fps:.2f} fps from {rom_path}"
        )

    def _hook_android_utilities(self) -> None:
        try:
            android_utilities = JClass.forName("org.telegram.messenger.AndroidUtilities")
            for method in android_utilities.getDeclaredMethods():
                method_name = method.getName()
                parameter_types = method.getParameterTypes()
                if method_name == "openDocument" and len(parameter_types) == 3:
                    if "MessageObject" in parameter_types[0].getName():
                        method.setAccessible(True)
                        self._hooks.append(self.hook_method(method, NesRomOpenHook(self)))
                elif method_name == "openForView" and len(parameter_types) == 4:
                    if "MessageObject" in parameter_types[0].getName():
                        method.setAccessible(True)
                        self._hooks.append(self.hook_method(method, NesRomOpenHook(self)))
                elif method_name == "openForView" and len(parameter_types) == 6:
                    first_param = parameter_types[0].getName()
                    second_param = parameter_types[1].getName()
                    if first_param == "java.io.File" and second_param == "java.lang.String":
                        method.setAccessible(True)
                        self._hooks.append(self.hook_method(method, NesRomLocalFileOpenHook(self)))
        except Exception as error:
            log(f"Failed to hook ROM open via AndroidUtilities: {error}")

    def _is_rom_file_name(self, file_name: str) -> bool:
        normalized = str(file_name or "").strip().lower()
        return bool(normalized and normalized.endswith(NES_EXTENSIONS))

    def _is_supported_rom_message(self, message) -> bool:
        return self._is_rom_file_name(self._get_message_file_name(message))

    def _get_message_file_name(self, message) -> str:
        if message is None:
            return ""
        for getter_name in ("getFileName", "getDocumentName"):
            try:
                value = getattr(message, getter_name)()
                if value:
                    return str(value)
            except Exception:
                pass
        try:
            document = message.getDocument()
            if document is not None:
                for attr_name in ("file_name_fixed", "file_name"):
                    value = getattr(document, attr_name, None)
                    if value:
                        return str(value)
        except Exception:
            pass
        return ""

    def _resolve_message_file_path(self, message):
        if message is None:
            return None
        try:
            attach_path = getattr(message.messageOwner, "attachPath", None)
            if attach_path:
                attach_path = str(attach_path)
                if attach_path and os.path.exists(attach_path):
                    return attach_path
        except Exception:
            pass
        try:
            file_loader = jclass("org.telegram.messenger.FileLoader")
            file_obj = file_loader.getInstance(message.currentAccount).getPathToMessage(message.messageOwner)
            if file_obj is not None:
                path = str(file_obj.getAbsolutePath())
                if os.path.exists(path):
                    return path
        except Exception as error:
            log(f"Failed to resolve ROM path from message: {error}")
        return None

    def download_rom_from_message(self, message) -> None:
        try:
            document = message.getDocument()
            if document is None:
                self._show_error("В этом сообщении отсутствует ROM-файл.")
                return
            file_name = self._get_message_file_name(message)
            if not file_name:
                self._show_error("Не удалось определить имя ROM-файла.")
                return
            account = int(message.currentAccount)
            self._attach_download_observer(account)
            self._pending_file_name = file_name
            self._pending_launch_after_download = True
            file_loader = jclass("org.telegram.messenger.FileLoader")
            file_loader.getInstance(account).loadFile(document, message, file_loader.PRIORITY_HIGH, 1)
            log(f"Downloading ROM {file_name}...")
        except Exception as error:
            self._reset_pending_download_state()
            self._detach_download_observer()
            log(f"ROM download start failed: {error}")
            self._show_error(f"Не удалось начать загрузку ROM: {error}")

    def _reset_pending_download_state(self) -> None:
        self._pending_file_name = None
        self._pending_launch_after_download = False

    def _ensure_download_delegate(self) -> None:
        if self._download_delegate is None:
            self._download_delegate = NesDownloadDelegate(self)

    def _attach_download_observer(self, account: int) -> None:
        if self._observer_account == account:
            return
        self._ensure_download_delegate()
        self._detach_download_observer_locked()
        notification_center = NotificationCenter.getInstance(account)
        notification_center.addObserver(self._download_delegate, NotificationCenter.fileLoaded)
        notification_center.addObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
        self._observer_account = account

    def _detach_download_observer(self) -> None:
        self._detach_download_observer_locked()

    def _detach_download_observer_locked(self) -> None:
        if self._observer_account is None:
            return
        try:
            if self._download_delegate is None:
                return
            notification_center = NotificationCenter.getInstance(self._observer_account)
            notification_center.removeObserver(self._download_delegate, NotificationCenter.fileLoaded)
            notification_center.removeObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
        except Exception:
            pass
        finally:
            self._observer_account = None

    def _matches_pending_file(self, location) -> bool:
        if not self._pending_file_name or location is None:
            return False
        return str(location).lower() == str(self._pending_file_name).lower()

    def _on_rom_download_notification(self, notification_id, account, *args) -> None:
        try:
            if self._observer_account is None or int(account) != int(self._observer_account):
                return
            if notification_id == NotificationCenter.fileLoaded:
                location = args[0] if len(args) > 0 else None
                final_file = args[1] if len(args) > 1 else None
                if not self._matches_pending_file(location):
                    return
                path = None
                if final_file is not None and hasattr(final_file, "getAbsolutePath"):
                    path = str(final_file.getAbsolutePath())
                launch_after_download = self._pending_launch_after_download
                self._reset_pending_download_state()
                self._detach_download_observer()
                if path and os.path.exists(path) and launch_after_download:
                    run_on_ui_thread(lambda p=path: self._launch_game_ui(p))
                else:
                    self._show_error("ROM был загружен, но локальный файл не удалось найти.")
            elif notification_id == NotificationCenter.fileLoadFailed:
                location = args[0] if len(args) > 0 else None
                if not self._matches_pending_file(location):
                    return
                failed_name = self._pending_file_name or "ROM"
                self._reset_pending_download_state()
                self._detach_download_observer()
                self._show_error(f"Не удалось загрузить {failed_name}")
        except Exception as error:
            log(f"ROM download notification failed: {error}")

    # UI эмуля
    def _build_dialog(self, activity) -> None:
        Dialog = find_class("android.app.Dialog")
        Window = find_class("android.view.Window")
        WindowManager = find_class("android.view.WindowManager")
        FrameLayout = find_class("android.widget.FrameLayout")
        LinearLayout = find_class("android.widget.LinearLayout")
        ImageView = find_class("android.widget.ImageView")
        TextView = find_class("android.widget.TextView")
        Gravity = find_class("android.view.Gravity")
        Color = find_class("android.graphics.Color")
        GradientDrawable = find_class("android.graphics.drawable.GradientDrawable")
        Bitmap = find_class("android.graphics.Bitmap")
        AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
        MotionEvent = find_class("android.view.MotionEvent")
        OnDismiss = find_class("android.content.DialogInterface$OnDismissListener")

        self.activity = activity
        self.orig_orient = activity.getRequestedOrientation()
        activity.setRequestedOrientation(0)

        class Dismiss(dynamic_proxy(OnDismiss)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin

            def onDismiss(self, dialog):
                self.plugin._on_dialog_dismissed()

        dismiss_listener = Dismiss(self)
        self._ui_refs = [dismiss_listener]

        dialog = Dialog(activity, 16974122)
        dialog.requestWindowFeature(Window.FEATURE_NO_TITLE)
        dialog.setOnDismissListener(dismiss_listener)

        root = FrameLayout(activity)
        root.setBackgroundColor(Color.BLACK)

        self.bitmap = None
        self._bitmap_w = 0
        self._bitmap_h = 0
        self.image = ImageView(activity)
        self.image.setScaleType(ImageView.ScaleType.FIT_CENTER)
        self.image.setBackgroundColor(Color.BLACK)
        root.addView(self.image, FrameLayout.LayoutParams(-1, -1))
        self._ensure_bitmap(self.width, self.height)

        def control_bg(fill: int, stroke: int = 0x44FFFFFF, radius_dp: int = 10):
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            _set_drawable_color(bg, fill)
            _set_drawable_stroke(bg, AndroidUtilities.dp(1), stroke)
            bg.setCornerRadius(AndroidUtilities.dp(radius_dp))
            return bg

        def round_bg(fill: int, stroke: int = 0x44FFFFFF):
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.OVAL)
            _set_drawable_color(bg, fill)
            _set_drawable_stroke(bg, AndroidUtilities.dp(2), stroke)
            return bg

        def add_touchable(view) -> None:
            view.setClickable(False)
            view.setFocusable(False)

        def dpad_button(text: str, parent, button_id: int, width_dp: int = 70, height_dp: int = 70):
            view = TextView(activity)
            view.setText(text)
            view.setTextSize(22)
            _set_text_color(view, 0xEEFFFFFF)
            view.setGravity(Gravity.CENTER)
            view.setIncludeFontPadding(False)
            add_touchable(view)
            view.setBackground(control_bg(0x66404040, 0x44FFFFFF, 8))
            lp = LinearLayout.LayoutParams(AndroidUtilities.dp(width_dp), AndroidUtilities.dp(height_dp))
            lp.setMargins(AndroidUtilities.dp(3), AndroidUtilities.dp(3), AndroidUtilities.dp(3), AndroidUtilities.dp(3))
            parent.addView(view, lp)
            self._register_touch_target(view, button_id)
            return view

        def pill_button(text: str, parent, button_id: int, width_dp: int = 96, height_dp: int = 29):
            view = TextView(activity)
            view.setText(text)
            view.setTextSize(13)
            _set_text_color(view, 0xEEFFFFFF)
            view.setGravity(Gravity.CENTER)
            view.setIncludeFontPadding(False)
            add_touchable(view)
            view.setBackground(control_bg(0x66505050, 0x44FFFFFF, 11))
            lp = LinearLayout.LayoutParams(AndroidUtilities.dp(width_dp), AndroidUtilities.dp(height_dp))
            lp.setMargins(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(4))
            parent.addView(view, lp)
            self._register_touch_target(view, button_id)
            return view

        def action_button(text: str, parent, button_id: int, size_dp: int, fill: int, bottom_margin_dp: int = 0):
            view = TextView(activity)
            view.setText(text)
            view.setTextSize(21 if text == "A" else 18)
            _set_text_color(view, 0xEEFFFFFF)
            view.setGravity(Gravity.CENTER)
            view.setIncludeFontPadding(False)
            add_touchable(view)
            view.setBackground(round_bg(fill))
            lp = LinearLayout.LayoutParams(AndroidUtilities.dp(size_dp), AndroidUtilities.dp(size_dp))
            lp.setMargins(AndroidUtilities.dp(5), AndroidUtilities.dp(3), AndroidUtilities.dp(5), AndroidUtilities.dp(bottom_margin_dp))
            parent.addView(view, lp)
            self._register_touch_target(view, button_id)
            return view

        self._touch_active = {}
        self._touch_targets = []

        dpad_wrap = LinearLayout(activity)
        dpad_wrap.setOrientation(LinearLayout.VERTICAL)
        dpad_wrap.setGravity(Gravity.CENTER)

        dpad_up = LinearLayout(activity)
        dpad_up.setGravity(Gravity.CENTER)
        dpad_wrap.addView(dpad_up, LinearLayout.LayoutParams(-2, -2))

        dpad_mid = LinearLayout(activity)
        dpad_mid.setGravity(Gravity.CENTER)
        dpad_wrap.addView(dpad_mid, LinearLayout.LayoutParams(-2, -2))

        dpad_button("▲", dpad_up, RETRO_DEVICE_ID_JOYPAD_UP, 70, 70)
        dpad_button("◀", dpad_mid, RETRO_DEVICE_ID_JOYPAD_LEFT, 70, 70)
        dpad_button("▼", dpad_mid, RETRO_DEVICE_ID_JOYPAD_DOWN, 70, 70)
        dpad_button("▶", dpad_mid, RETRO_DEVICE_ID_JOYPAD_RIGHT, 70, 70)

        dpad_lp = FrameLayout.LayoutParams(-2, -2)
        dpad_lp.gravity = Gravity.BOTTOM | Gravity.LEFT
        dpad_lp.leftMargin = AndroidUtilities.dp(12)
        dpad_lp.bottomMargin = AndroidUtilities.dp(12)
        root.addView(dpad_wrap, dpad_lp)

        center_wrap = LinearLayout(activity)
        center_wrap.setOrientation(LinearLayout.HORIZONTAL)
        center_wrap.setGravity(Gravity.CENTER)
        pill_button("SELECT", center_wrap, RETRO_DEVICE_ID_JOYPAD_SELECT, 96, 29)
        pill_button("START", center_wrap, RETRO_DEVICE_ID_JOYPAD_START, 96, 29)

        center_lp = FrameLayout.LayoutParams(-2, -2)
        center_lp.gravity = Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL
        center_lp.bottomMargin = AndroidUtilities.dp(16)
        root.addView(center_wrap, center_lp)

        action_outer = FrameLayout(activity)
        action_wrap = LinearLayout(activity)
        action_wrap.setOrientation(LinearLayout.HORIZONTAL)
        action_wrap.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
        action_button("B", action_wrap, RETRO_DEVICE_ID_JOYPAD_B, 68, 0x88C62828, 0)
        action_button("A", action_wrap, RETRO_DEVICE_ID_JOYPAD_A, 68, 0x88E53935, 10)

        action_inner_lp = FrameLayout.LayoutParams(-2, -2)
        action_inner_lp.gravity = Gravity.END | Gravity.CENTER_VERTICAL
        action_outer.addView(action_wrap, action_inner_lp)

        action_lp = FrameLayout.LayoutParams(-2, -2)
        action_lp.gravity = Gravity.BOTTOM | Gravity.RIGHT
        action_lp.rightMargin = AndroidUtilities.dp(44)
        action_lp.bottomMargin = AndroidUtilities.dp(16)
        root.addView(action_outer, action_lp)

        touch_overlay = FrameLayout(activity)
        touch_overlay.setClickable(True)
        touch_overlay.setFocusable(True)
        try:
            touch_overlay.setMotionEventSplittingEnabled(True)
        except Exception:
            pass
        overlay_lp = FrameLayout.LayoutParams(-1, AndroidUtilities.dp(240))
        overlay_lp.gravity = Gravity.BOTTOM
        root.addView(touch_overlay, overlay_lp)
        overlay_listener = TouchListener(self._handle_overlay_touch)
        touch_overlay.setOnTouchListener(overlay_listener)
        self._ui_refs.append(overlay_listener)

        close = TextView(activity)
        close.setText("×")
        _set_text_color(close, 0xFFFFFFFF)
        close.setTextSize(23)
        close.setGravity(Gravity.CENTER)
        close.setBackground(control_bg(0x88000000, 0x44FFFFFF, 12))
        close_listener = ClickListener(lambda: self.stop_game())
        self._ui_refs.append(close_listener)
        close.setOnClickListener(close_listener)
        close_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(62), AndroidUtilities.dp(52))
        close_lp.gravity = Gravity.TOP | Gravity.RIGHT
        close_lp.topMargin = AndroidUtilities.dp(8)
        close_lp.rightMargin = AndroidUtilities.dp(10)
        root.addView(close, close_lp)
        close.bringToFront()

        reset = TextView(activity)
        reset.setText("⟲")
        _set_text_color(reset, 0xFFFFFFFF)
        reset.setTextSize(16)
        reset.setGravity(Gravity.CENTER)
        reset.setBackground(control_bg(0x88000000, 0x44FFFFFF, 12))
        reset_listener = ClickListener(lambda: self._reset_game())
        self._ui_refs.append(reset_listener)
        reset.setOnClickListener(reset_listener)
        reset_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(62), AndroidUtilities.dp(52))
        reset_lp.gravity = Gravity.TOP | Gravity.LEFT
        reset_lp.topMargin = AndroidUtilities.dp(8)
        reset_lp.leftMargin = AndroidUtilities.dp(10)
        root.addView(reset, reset_lp)
        reset.bringToFront()

        def prepare_container(container) -> None:
            container.setClickable(False)
            container.setFocusable(False)
            try:
                container.setMotionEventSplittingEnabled(True)
            except Exception:
                pass

        for container in (dpad_wrap, dpad_up, dpad_mid, center_wrap, action_outer, action_wrap):
            prepare_container(container)

        dialog.setContentView(root)
        dialog.show()
        touch_overlay.bringToFront()
        close.bringToFront()
        reset.bringToFront()
        window = dialog.getWindow()
        if window:
            window.setLayout(-1, -1)
            window.addFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
            decor = window.getDecorView()
            flags = 5894
            decor.setSystemUiVisibility(flags)
        self.dialog = dialog

    def _send_button(self, button_id: int, pressed: bool) -> None:
        try:
            with self._native_lock:
                if self.emulator:
                    self.emulator.set_button(0, button_id, pressed)
        except Exception as error:
            log(f"button failed: {error}")

    def _ensure_display_buffer(self, width: int, height: int) -> None:
        need = int(width) * int(height) * 2
        if need <= 0:
            return
        if self._byte_buffer_cls is None:
            self._byte_buffer_cls = find_class("java.nio.ByteBuffer")

        if self._java_buffer is None or self._java_buffer_need < need:
            self._java_buffer = self._byte_buffer_cls.allocateDirect(need)
            self._java_buffer_need = need
            self._display_direct = False
            self._display_ctypes = None
            self._display_buffer = None
            self._blit_direct = None

        if not self._display_direct:
            addr = _resolve_direct_byte_buffer_address(self._java_buffer)
            if addr:
                self._display_ctypes = (ctypes.c_char * need).from_address(addr)
                self._display_direct = True
                self._display_buffer = None
                log(f"display: zero-copy direct buffer @ 0x{addr:x} ({need} bytes)")
            else:
                if self._display_buffer is None or len(self._display_buffer) < need:
                    self._display_buffer = bytearray(need)
                try:
                    bb_class = str(self._java_buffer.getClass().getName())
                except Exception:
                    bb_class = "?"
                log(
                    f"display: direct address unavailable ({bb_class}), "
                    "using bytearray fallback"
                )

        if self.emulator:
            target = self._display_ctypes if self._display_direct else self._display_buffer
            self.emulator.bind_display_buffer(target)

    def _ensure_bitmap(self, width: int, height: int) -> None:
        if self.bitmap is not None and self._bitmap_w == width and self._bitmap_h == height:
            return
        Bitmap = find_class("android.graphics.Bitmap")
        self.bitmap = Bitmap.createBitmap(width, height, Bitmap.Config.RGB_565)
        self._bitmap_w = width
        self._bitmap_h = height
        if not self._display_direct:
            self._java_buffer = None
            self._java_buffer_need = 0
            self._blit_direct = None
        if self.image is not None:
            self.image.setImageBitmap(self.bitmap)

    def _blit_display_buffer(self, need: int) -> None:
        if need <= 0 or self.bitmap is None:
            return
        if self._display_direct and self._java_buffer is not None:
            bb = self._java_buffer
            bb.position(0)
            bb.limit(need)
            self.bitmap.copyPixelsFromBuffer(bb)
            return

        buf = self._display_buffer
        if not buf:
            return
        if self._byte_buffer_cls is None:
            self._byte_buffer_cls = find_class("java.nio.ByteBuffer")
        if self._java_buffer is None or self._java_buffer_need < need:
            self._java_buffer = self._byte_buffer_cls.allocateDirect(need)
            self._java_buffer_need = need
            self._blit_direct = None
        bb = self._java_buffer
        bb.clear()
        if self._blit_direct is None:
            try:
                bb.put(buf, 0, need)
                self._blit_direct = True
            except Exception:
                bb.clear()
                bb.put(bytes(buf[:need]))
                self._blit_direct = False
        elif self._blit_direct:
            bb.put(buf, 0, need)
        else:
            bb.put(bytes(buf[:need]))
        bb.rewind()
        self.bitmap.copyPixelsFromBuffer(bb)

    def _game_loop(self) -> None:
        try:
            frame_time = 1.0 / 60.0
            next_frame = time.monotonic()

            while self.running:
                with self._native_lock:
                    if not self.emulator:
                        break
                    self.emulator.run_frame()
                    frame_seq = self.emulator._frame_seq
                    fps = float(self.emulator.fps or 60.0)
                    frame_time = 1.0 / max(fps, 1.0)

                if frame_seq != self._applied_tick and not self._ui_busy:
                    self._ui_busy = True
                    run_on_ui_thread(self._apply_frame)

                next_frame += frame_time
                delay = next_frame - time.monotonic()
                if delay > 0:
                    time.sleep(delay)
                elif delay < -frame_time * 2:
                    next_frame = time.monotonic()
        except Exception as error:
            log(f"game loop failed: {error}")
            log(traceback.format_exc())
            self.running = False
            self._show_error(str(error))

    def _apply_frame(self) -> None:
        try:
            if not self.running or not self.image or not self.emulator:
                return
            seq = self.emulator._frame_seq
            if seq == self._applied_tick:
                return
            width, height = self.emulator.frame_dims()
            need = width * height * 2
            if need <= 0:
                return
            if self._display_direct:
                if self._java_buffer is None or self._java_buffer_need < need:
                    return
            elif not self._display_buffer or len(self._display_buffer) < need:
                return
            self._ensure_bitmap(width, height)
            self._blit_display_buffer(need)
            try:
                self.image.postInvalidateOnAnimation()
            except Exception:
                self.image.invalidate()
            self._applied_tick = seq
        except Exception as error:
            log(f"apply frame failed: {error}")
        finally:
            self._ui_busy = False

    def _reset_game(self) -> None:
        try:
            self._clear_touch_state()
            with self._native_lock:
                if self.emulator and self.emulator._game_loaded:
                    self.emulator.reset()
            self._applied_tick = -1
            if self.running and self.emulator:
                self.emulator.run_frame()
                run_on_ui_thread(self._apply_frame)
        except Exception as error:
            log(f"reset failed: {error}")

    def _release_display_resources(self) -> None:
        bitmap = self.bitmap
        self.bitmap = None
        if bitmap is not None:
            try:
                bitmap.recycle()
            except Exception:
                pass
        image = self.image
        self.image = None
        if image is not None:
            try:
                image.setImageBitmap(None)
            except Exception:
                pass
        self._display_buffer = None
        self._display_ctypes = None
        self._display_direct = False
        self._java_buffer = None
        self._java_buffer_need = 0
        self._blit_direct = None
        self._bitmap_w = 0
        self._bitmap_h = 0
        self._applied_tick = -1
        self._ui_busy = False

    def _release_emulator_resources(self) -> None:
        if self._releasing:
            return
        self._releasing = True
        try:
            if not self._session_active and self.emulator is None and not self.running:
                return
            self._session_active = False
            self.running = False
            self.audio_player.stop()
            self._clear_touch_state()
            thread = self.loop_thread
            self.loop_thread = None
            try:
                if thread and thread is not threading.current_thread():
                    thread.join(1.0)
            except Exception:
                pass
            with self._native_lock:
                if self.emulator:
                    try:
                        self.emulator.shutdown()
                    except Exception as error:
                        log(f"emulator shutdown failed: {error}")
                    self.emulator = None
            global _ACTIVE_EMULATOR
            _ACTIVE_EMULATOR = None
            try:
                self.library.release()
            except Exception as error:
                log(f"library release failed: {error}")
            self._release_display_resources()
            self._touch_targets.clear()
            self._touch_active.clear()
            self._rom_path = None
            log("session released")
        finally:
            self._releasing = False

    def _on_dialog_dismissed(self) -> None:
        self._release_emulator_resources()
        try:
            if self.activity and self.orig_orient is not None:
                self.activity.setRequestedOrientation(self.orig_orient)
        except Exception:
            pass
        self.dialog = None
        self.activity = None
        self.orig_orient = None
        self._ui_refs = []

    def stop_game(self) -> None:
        dialog = self.dialog
        self.dialog = None
        self._release_emulator_resources()
        if dialog:
            try:
                dialog.dismiss()
            except Exception:
                pass
        else:
            try:
                if self.activity and self.orig_orient is not None:
                    self.activity.setRequestedOrientation(self.orig_orient)
            except Exception:
                pass
            self.activity = None
            self.orig_orient = None
            self._ui_refs = []

    def _show_error(self, message: str) -> None:
        def run() -> None:
            fragment = get_last_fragment()
            activity = fragment.getParentActivity() if fragment else None
            if activity:
                self._show_dialog(activity, "NES Emu", message)

        run_on_ui_thread(run)

    def _show_dialog(self, activity, title: str, message: str) -> None:
        try:
            Builder = find_class("android.app.AlertDialog$Builder")
            builder = Builder(activity)
            builder.setTitle(title)
            builder.setMessage(message)
            builder.setPositiveButton("OK", None)
            builder.show()
        except Exception as error:
            log(f"dialog failed: {error}; message={message}")

    def load_rom_path(self, path: str) -> None:
        if not self.emulator:
            raise RuntimeError("Emulator is not initialized")
        self.emulator.load_rom(path)
        log(
            f"NES Emu: ROM loaded from {path} "
            f"({self.emulator.width}x{self.emulator.height} @ {self.emulator.fps:.2f} fps)"
        )
