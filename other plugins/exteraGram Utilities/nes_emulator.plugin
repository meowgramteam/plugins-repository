# Константы для натива
RTLD_NOW = 2
RTLD_GLOBAL = 0x100
RTLD_MODE = RTLD_NOW | RTLD_GLOBAL

def log(*args, sep: str = " ") -> None:
    _log("[NesEMU] " + sep.join(map(str, args)))

# Спасибо за фиксы цвета @itskotovski / @mishabotov
def _as_color_int(color) -> int:
    try:
        value = int(color) & 0xFFFFFFFF
        if value >= 0x80000000:
            value -= 0x100000000
        return int(value)
    except Exception:
        return -1


def _set_text_color(text_view, color) -> None:
    safe_color = _as_color_int(color)
    try:
        method = text_view.getClass().getMethod("setTextColor", Integer.TYPE)
        method.invoke(text_view, Integer(safe_color))
    except Exception as error:
        log(f"setTextColor(int) skipped: {error}")


def _set_drawable_color(drawable, color) -> None:
    safe_color = _as_color_int(color)
    try:
        method = drawable.getClass().getMethod("setColor", Integer.TYPE)
        method.invoke(drawable, Integer(safe_color))
        return
    except Exception as error:
        log(f"GradientDrawable.setColor(int) failed: {error}")
    try:
        ColorStateList = find_class("android.content.res.ColorStateList")
        drawable.setColor(ColorStateList.valueOf(Integer(safe_color)))
    except Exception:
        pass


def _set_drawable_stroke(drawable, width, color) -> None:
    safe_color = _as_color_int(color)
    try:
        method = drawable.getClass().getMethod("setStroke", Integer.TYPE, Integer.TYPE)
        method.invoke(drawable, Integer(int(width)), Integer(safe_color))
    except Exception as error:
        log(f"GradientDrawable.setStroke(int,int) skipped: {error}")

_hidden_api_relaxed = False

# Что бы напрямую можно было писать в буфер экрана и эмулятор не безбожно лагал мне пришлось юзать hidden api и unsafe, извините
def _relax_hidden_api() -> None:
    global _hidden_api_relaxed
    if _hidden_api_relaxed:
        return
    _hidden_api_relaxed = True
    try:
        runtime = jclass("dalvik.system.VMRuntime").getRuntime()
        for pattern in ("L", "Lsun/nio/ch/;Ljava/nio/;Ljdk/internal/misc/;Lsun/misc/"):
            try:
                runtime.setHiddenApiExemptions(pattern)
                return
            except Exception:
                continue
    except Exception:
        pass

def _get_unsafe():
    for unsafe_name in ("jdk.internal.misc.Unsafe", "sun.misc.Unsafe"):
        try:
            unsafe_cls = jclass(unsafe_name)
            field = unsafe_cls.getDeclaredField("theUnsafe")
            field.setAccessible(True)
            return field.get(None)
        except Exception:
            continue
    return None

def _resolve_direct_byte_buffer_address(bb) -> int | None:
    if bb is None:
        return None
    try:
        if not bool(bb.isDirect()):
            return None
    except Exception:
        return None

    _relax_hidden_api()

    try:
        addr = int(bb.address())
        if addr > 0:
            return addr
    except Exception:
        pass

    try:
        direct_buffer = jclass("sun.nio.ch.DirectBuffer")
        if bool(direct_buffer.isInstance(bb)):
            method = direct_buffer.getMethod("address")
            addr = int(method.invoke(bb))
            if addr > 0:
                return addr
    except Exception:
        pass

    try:
        direct_buffer = jclass("sun.nio.ch.DirectBuffer")
        if bool(direct_buffer.isInstance(bb)):
            addr = int(direct_buffer.cast(bb).address())
            if addr > 0:
                return addr
    except Exception:
        pass

    obj = bb
    for method_name in ("address",):
        try:
            method = obj.getClass().getMethod(method_name)
            addr = int(method.invoke(obj))
            if addr > 0:
                return addr
        except Exception:
            pass
        try:
            method = obj.getClass().getDeclaredMethod(method_name)
            method.setAccessible(True)
            addr = int(method.invoke(obj))
            if addr > 0:
                return addr
        except Exception:
            pass

    for field_name in ("address",):
        try:
            field = obj.getClass().getDeclaredField(field_name)
            field.setAccessible(True)
            addr = int(field.getLong(obj))
            if addr > 0:
                return addr
        except Exception:
            pass

    unsafe = _get_unsafe()
    if unsafe is not None:
        for field_name in ("address",):
            try:
                field = obj.getClass().getDeclaredField(field_name)
                field.setAccessible(True)
                offset = int(unsafe.objectFieldOffset(field))
                addr = int(unsafe.getLong(obj, offset))
                if addr > 0:
                    return addr
            except Exception:
                pass

    byte_buffer_cls = jclass("java.nio.ByteBuffer")
    for bits_name in ("java.nio.Bits", "jdk.internal.misc.VM"):
        try:
            bits_cls = jclass(bits_name)
            method = bits_cls.getDeclaredMethod("getDirectBufferAddress", byte_buffer_cls)
            method.setAccessible(True)
            addr = int(method.invoke(None, bb))
            if addr > 0:
                return addr
        except Exception:
            pass

    try:
        secrets = jclass("jdk.internal.access.SharedSecrets")
        method = secrets.getDeclaredMethod("getJavaNioAccess")
        method.setAccessible(True)
        nio_access = method.invoke(None)
        if nio_access is not None:
            access_method = nio_access.getClass().getDeclaredMethod(
                "getDirectBufferAddress",
                byte_buffer_cls,
            )
            access_method.setAccessible(True)
            addr = int(access_method.invoke(nio_access, bb))
            if addr > 0:
                return addr
    except Exception:
        pass

    return None

def _memmove_to_display_target(target, data: ctypes.c_void_p, *, need: int, row_bytes: int, frame_h: int, pitch: int) -> None:
    if isinstance(target, bytearray):
        if pitch == row_bytes:
            ctypes.memmove((ctypes.c_char * need).from_buffer(target), data, need)
            return
        src = ctypes.cast(data, ctypes.POINTER(ctypes.c_char))
        for y in range(frame_h):
            ctypes.memmove(
                (ctypes.c_char * row_bytes).from_buffer(target, y * row_bytes),
                ctypes.cast(
                    ctypes.addressof(src.contents) + y * pitch,
                    ctypes.POINTER(ctypes.c_char * row_bytes),
                ),
                row_bytes,
            )
        return

    if pitch == row_bytes:
        ctypes.memmove(target, data, need)
        return

    base = ctypes.addressof(target)
    src = ctypes.cast(data, ctypes.POINTER(ctypes.c_char))
    for y in range(frame_h):
        ctypes.memmove(
            ctypes.cast(base + y * row_bytes, ctypes.POINTER(ctypes.c_char * row_bytes)),
            ctypes.cast(
                ctypes.addressof(src.contents) + y * pitch,
                ctypes.POINTER(ctypes.c_char * row_bytes),
            ),
            row_bytes,
        )


# Кнопочки
class ClickListener(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
    def __init__(self, fn) -> None:
        super().__init__()
        self.fn = fn

    def onClick(self, view) -> None:
        self.fn()

class TouchListener(dynamic_proxy(find_class("android.view.View$OnTouchListener"))):
    def __init__(self, fn) -> None:
        super().__init__()
        self.fn = fn

    def onTouch(self, view, event) -> bool:
        return self.fn(view, event)


NES_EXTENSIONS = (".nes", ".fds", ".unf", ".unif")

# Спасибки за логику хуков @itskotovski / @mishabotov
class NesDownloadDelegate(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def didReceivedNotification(self, notification_id, account, *args):
        plugin = self._plugin_ref()
        if plugin is not None:
            plugin._on_rom_download_notification(notification_id, account, *args)

class NesRomOpenHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def before_hooked_method(self, param):
        plugin = self._plugin_ref()
        if plugin is None:
            return
        try:
            if not param.args:
                return
            message = param.args[0]
            if not plugin._is_supported_rom_message(message):
                return
            if "openForView" in param.method.getName():
                param.setResult(True)
            else:
                param.setResult(None)
            rom_path = plugin._resolve_message_file_path(message)
            if rom_path and os.path.exists(rom_path):
                run_on_ui_thread(lambda p=rom_path: plugin.launch_rom(p))
            else:
                run_on_ui_thread(lambda m=message: plugin.download_rom_from_message(m))
        except Exception as error:
            log(f"ROM open hook failed: {error}")

class NesRomLocalFileOpenHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def before_hooked_method(self, param):
        plugin = self._plugin_ref()
        if plugin is None:
            return
        try:
            if not param.args or len(param.args) < 2:
                return
            file_obj = param.args[0]
            file_name = str(param.args[1] or "")
            if not plugin._is_rom_file_name(file_name):
                return
            rom_path = None
            try:
                if file_obj is not None and hasattr(file_obj, "getAbsolutePath"):
                    rom_path = str(file_obj.getAbsolutePath())
            except Exception:
                rom_path = None
            if not rom_path or not os.path.exists(rom_path):
                return
            param.setResult(True)
            run_on_ui_thread(lambda p=rom_path: plugin.launch_rom(p))
        except Exception as error:
            log(f"ROM local open hook failed: {error}")

# Класс для работы с нативом
class NativeLinker:
    def __init__(self) -> None:
        self.open_ext = None
        self.Info = None
        try:
            self.libc = ctypes.CDLL("libc.so", mode=RTLD_MODE)
        except Exception:
            self.libc = None
        try:
            self.libdl = ctypes.CDLL("libdl.so")
            self.open_ext = self.libdl.android_dlopen_ext

            class Info(ctypes.Structure):
                _fields_ = [
                    ("flags", ctypes.c_uint64),
                    ("reserved_addr", ctypes.c_void_p),
                    ("reserved_size", ctypes.c_size_t),
                    ("relro_fd", ctypes.c_int),
                    ("library_fd", ctypes.c_int),
                    ("library_fd_offset", ctypes.c_uint64),
                    ("library_namespace", ctypes.c_void_p),
                ]

            self.Info = Info
            self.open_ext.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.POINTER(self.Info)]
            self.open_ext.restype = ctypes.c_void_p
            self.libdl.dlopen.argtypes = [ctypes.c_char_p, ctypes.c_int]
            self.libdl.dlopen.restype = ctypes.c_void_p
            self.libdl.dlclose.argtypes = [ctypes.c_void_p]
            self.libdl.dlclose.restype = ctypes.c_int
        except Exception:
            self.open_ext = None
            self.Info = None

    def load(self, path: str) -> tuple[ctypes.CDLL | None, ctypes.c_void_p | None]:
        if not path or not os.path.exists(path) or os.path.getsize(path) < 1024:
            return None, None
        encoded = path.encode("utf-8")
        try:
            Build = find_class("android.os.Build")
            if int(Build.VERSION.SDK_INT) >= 29 and self.open_ext and self.Info:
                fd = os.open(path, os.O_RDONLY)
                try:
                    info = self.Info(flags=0x10, library_fd=fd)
                    handle = self.open_ext(encoded, RTLD_MODE, ctypes.byref(info))
                    if handle:
                        return ctypes.CDLL(path, handle=handle), handle
                finally:
                    try:
                        os.close(fd)
                    except Exception:
                        pass
        except Exception as error:
            log(f"android_dlopen_ext failed: {error}")
        try:
            if self.libdl:
                handle = self.libdl.dlopen(encoded, RTLD_MODE)
                if handle:
                    return ctypes.CDLL(path, handle=handle), handle
        except Exception as error:
            log(f"dlopen failed: {error}")
        try:
            return ctypes.CDLL(path, mode=RTLD_MODE), None
        except Exception as error:
            log(f"ctypes load failed: {error}")
            return None, None

    def unload(self, handle: ctypes.c_void_p | None) -> None:
        if not handle or not self.libdl:
            return
        try:
            self.libdl.dlclose(handle)
        except Exception as error:
            log(f"dlclose failed: {error}")

# Лоадер для нативной библиотеки
class LibretroLibrary:
    def __init__(self, *, filename: str, expected_sha256: str, cache_dirname: str, data_b64: str) -> None:
        self.filename = filename
        self.expected_sha256 = expected_sha256
        self.cache_dirname = cache_dirname
        self.data_b64 = data_b64
        self.lib: ctypes.CDLL | None = None
        self._handle: ctypes.c_void_p | None = None
        self.lib_path: str | None = None
        self._session_path: str | None = None
        self._load_counter = 0
        self._linker = NativeLinker()

    @property
    def cache_dir(self) -> str:
        files_dir = str(ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath())
        path = os.path.join(files_dir, self.cache_dirname)
        os.makedirs(path, exist_ok=True)
        return path

    def _write_lib_file(self, target: str, data_b64: str, expected_sha: str, *, executable: bool = False) -> None:
        if os.path.exists(target):
            try:
                with open(target, "rb") as handle:
                    if hashlib.sha256(handle.read()).hexdigest() == expected_sha:
                        if executable:
                            os.chmod(target, 0o755)
                        return
            except OSError:
                pass
        tmp = target + ".tmp"
        data = lzma.decompress(base64.b64decode(data_b64.encode("ascii")))
        if hashlib.sha256(data).hexdigest() != expected_sha:
            raise RuntimeError("embedded core checksum mismatch")
        with open(tmp, "wb") as handle:
            handle.write(data)
        os.replace(tmp, target)
        if executable:
            os.chmod(target, 0o755)

    def ensure(self) -> str:
        lib_dir = os.path.join(self.cache_dir, "lib")
        os.makedirs(lib_dir, exist_ok=True)
        lib_path = os.path.join(lib_dir, self.filename)
        self._write_lib_file(lib_path, self.data_b64, self.expected_sha256, executable=True)
        self.lib_path = lib_path
        return lib_path

    def _cleanup_session_copies(self, lib_dir: str, *, keep: str | None = None) -> None:
        # QuickNES держит звук в статике .so, поэтому каждую сессию мы грузим
        # отдельную копию. Тут чистим осиротевшие копии от прошлых запусков.
        try:
            names = os.listdir(lib_dir)
        except OSError:
            return
        for name in names:
            if name == self.filename or not name.endswith(self.filename):
                continue
            full = os.path.join(lib_dir, name)
            if keep and os.path.abspath(full) == os.path.abspath(keep):
                continue
            try:
                os.remove(full)
            except OSError:
                pass

    def _make_session_copy(self) -> str:
        canonical = self.ensure()
        lib_dir = os.path.join(self.cache_dir, "lib")
        self._cleanup_session_copies(lib_dir, keep=self._session_path)
        self._load_counter += 1
        session_name = f"s{os.getpid()}_{self._load_counter}_{self.filename}"
        session_path = os.path.join(lib_dir, session_name)
        shutil.copyfile(canonical, session_path)
        os.chmod(session_path, 0o755)
        return session_path

    def load(self) -> ctypes.CDLL:
        if self.lib is not None:
            return self.lib

        try:
            Build = find_class("android.os.Build")
            abis = [str(x) for x in Build.SUPPORTED_ABIS]
            if "arm64-v8a" not in abis:
                raise RuntimeError(f"embedded core is arm64-v8a only, device ABI: {', '.join(abis)}")
        except RuntimeError:
            raise
        except Exception:
            pass

        # Свежая копия на сессию = свежее статическое состояние ядра (нужно для звука).
        session_path = self._make_session_copy()
        log(f"loading core from {session_path}")
        lib, handle = self._linker.load(session_path)
        if not lib:
            try:
                os.remove(session_path)
            except OSError:
                pass
            raise RuntimeError(f"Failed to load library: {session_path}")
        self.lib = lib
        self._handle = handle
        self._session_path = session_path
        self.lib.retro_api_version.restype = ctypes.c_uint
        self.lib.retro_get_system_info.argtypes = [ctypes.POINTER(RetroSystemInfo)]
        log(f"core loaded, api={int(self.lib.retro_api_version())}")
        return self.lib

    def get_system_info(self) -> dict[str, str | bool]:
        keep_loaded = self.lib is not None
        lib = self.load()
        info = RetroSystemInfo()
        lib.retro_get_system_info(ctypes.byref(info))
        result = {
            "name": info.library_name.decode("utf-8", "replace") if info.library_name else "",
            "version": info.library_version.decode("utf-8", "replace") if info.library_version else "",
            "extensions": info.valid_extensions.decode("utf-8", "replace") if info.valid_extensions else "",
            "need_fullpath": bool(info.need_fullpath),
        }
        if not keep_loaded:
            self.release()
        return result

    def release(self) -> None:
        self._linker.unload(self._handle)
        self.lib = None
        self._handle = None
        session_path = self._session_path
        self._session_path = None
        if session_path:
            try:
                os.remove(session_path)
            except OSError:
                pass


