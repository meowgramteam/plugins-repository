            f = get_last_fragment()
            act = f.getParentActivity() if f else None
            if not act:
                run_on_ui_thread(self._show_mature_notice_dialog, 1500)
                return

            from android.widget import TextView, LinearLayout
            from android.graphics import Color
            from android.view import Gravity

            buy_url = "https://t.me/tribute/app?startapp=sXPd"

            full_text = ('В настройках плагина есть вкладка «Доп. контент (18+)» — '
                        'платный доступ к расширенному каталогу моделей с регулярными '
                        'качественными обновлениями. Оформить можно по кнопке «Купить» ниже.')

            tv = TextView(act)
            tv.setText(full_text)
            tv.setTextSize(0, AndroidUtilities.dp(16.0))
            try:
                tv.setTextColor(Color.parseColor("#FFFFFF"))
                tv.setLineSpacing(AndroidUtilities.dp(5.0), 1.05)
                tv.setGravity(Gravity.CENTER_HORIZONTAL)
            except Exception: pass
            pad_h = AndroidUtilities.dp(28.0)
            pad_v = AndroidUtilities.dp(20.0)
            tv.setPadding(pad_h, pad_v, pad_h, pad_v)

            wrapper = LinearLayout(act)
            wrapper.setOrientation(LinearLayout.VERTICAL)
            wrapper.addView(tv)

            builder = AlertDialogBuilder(act)
            builder.set_title("Дополнительный контент 18+")
            builder.set_view(wrapper)
            builder.set_cancelable(True)

            def _on_buy(b, w):
                b.dismiss()
                self.ss("mature_notice_shown", True)
                self._open_url(buy_url)

            builder.set_positive_button("Понятно", lambda b, w: b.dismiss())
            builder.set_neutral_button("Купить", _on_buy)
            builder.set_on_dismiss_listener(lambda b: self.ss("mature_notice_shown", True))
            builder.show()
        except Exception as e:
            self._log("mature_notice_dialog: " + str(e) + "\n" + traceback.format_exc())
            self.ss("mature_notice_shown", True)

    def on_plugin_unload(self):
        self._log("=== unloading ===")
        if self._comp: self._comp.hide()
        if self._sherpa: self._sherpa.stop()
        if self._sounds: self._sounds.stop()
        if self._quotes: self._quotes.stop()
        if self._battery: self._battery.stop()
        if self._sched: self._sched.stop()
        if self._cam: self._cam.stop_cinematic()
        for h in self._hooks:
            try: self.unhook_method(h)
            except Exception: pass
        self._hooks.clear()

    def on_app_event(self,event_type:AppEvent):
        try:
            if event_type==AppEvent.RESUME:
                comp=self._comp
                if comp and not comp._alive and not comp._hidden and self.is_on():
                    comp._showing=False
                    run_on_ui_thread(comp._open)
        except Exception: pass

    def _stella_start(self):
        self._log('Stella OK')
        try: BulletinHelper.show_success(self.t('s_ready'))
        except Exception: pass

    def _on_stella_exit(self):
        if self._comp and self._comp._alive:
            self._comp._hidden=True; self._comp.hide()

    def _on_enable_change(self,v):
        enabled=bool(v); self.ss("enable",enabled)
        if not self._comp: return
        if enabled:
            if not self._comp._alive:
                self._comp._showing=False; self._comp._hidden=False; self._comp.show()
        else:
            if self._comp._alive: self._comp._hidden=True; self._comp.hide()

    def _on_borders(self,v):
        self.ss("show_borders",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            run_on_ui_thread(lambda: self._comp._js("if(window.showBorder)showBorder("+val+");"))

    def _on_pan(self,v):
        self.ss("pan_mode",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            rot="true" if bool(self.gs("rotate_mode")) else "false"
            run_on_ui_thread(lambda: self._comp._js(
                "if(window.showPanIndicator)showPanIndicator("+val+");"
                "if(window.setInteractionMode)setInteractionMode("+rot+","+val+");"))

    def _on_rotate_mode(self,v):
        self.ss("rotate_mode",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            pan="true" if bool(self.gs("pan_mode")) else "false"
            run_on_ui_thread(lambda: self._comp._js(
                "if(window.setInteractionMode)setInteractionMode("+val+","+pan+");"))

    def _on_stella_enable(self,v):
        enabled=bool(v); self.ss("stella_enable",enabled)
        if enabled:
            run_on_queue(self._stella_start)
            if self._sounds: self._sounds.play('greet')
        else:
            self._stella_stop()

    def _stella_stop(self):
        """Остановить звуковые реакции Стеллы (вызывается при выключении тумблера)."""
        try:
            if self._sounds: self._sounds.stop()
            self._log("Stella sounds stopped")
        except Exception as e:
            self._log("stella_stop: "+str(e))

    def _on_win_size(self,w,h):
        try:
            if w is not None: self.ss("width_dp", max(64,min(600,int(float(str(w))))))
            if h is not None: self.ss("height_dp",max(100,min(900,int(float(str(h))))))
            if self._comp and self._comp._alive:
                wd=int(self.gs("width_dp") or 128)
                hd=int(self.gs("height_dp") or 310)
                self._comp.resize(wd,hd)
        except Exception as e: self._log("win_size: "+str(e))

    def _on_win_shape(self,i):
        self.ss("win_shape",int(i))
        if self._comp and self._comp._alive: run_on_ui_thread(self._comp._apply_win_shape)


    def _remember_model(self,url,label=None):
        try:
            lst=json.loads(self.gs("model_list") or "[]")
        except Exception: lst=[]
        lst=[e for e in lst if e.get("url")!=url]
        if not label:
            label=url.split("/")[-1].rsplit(".",1)[0] or "Модель"
        lst.insert(0,{"url":url,"label":label})
        lst=lst[:10]
        self.ss("model_list", json.dumps(lst))

    def _rename_model(self,url,new_label):
        try:
            lst=json.loads(self.gs("model_list") or "[]")
        except Exception: lst=[]
        for e in lst:
            if e.get("url")==url: e["label"]=str(new_label).strip()[:40] or e.get("label")
        self.ss("model_list", json.dumps(lst))

    def _switch_model(self,url):
        self.ss("vrm_url", url)
        if self._comp and self._comp._alive:
            self._comp._js("if(window.loadVRM)loadVRM("+json.dumps(url)+");")
        elif self._comp:
            self._comp._showing=False; self._comp._hidden=False; self._comp.show()

    def _forget_model(self,url):
        try:
            lst=json.loads(self.gs("model_list") or "[]")
        except Exception: lst=[]
        lst=[e for e in lst if e.get("url")!=url]
        self.ss("model_list", json.dumps(lst))

    def _pick_file(self,view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                I=find_class("android.content.Intent")
                i=I(I.ACTION_OPEN_DOCUMENT)
                i.addCategory(I.CATEGORY_OPENABLE); i.setType("*/*")
                act.startActivityForResult(i,PICK_REQUEST)
            except Exception as e: self._log("pick: "+str(e))
        run_on_ui_thread(_do)

    def _copy_vrm(self,uri):
        try:
            f=get_last_fragment(); act=f.getParentActivity() if f else None
            if not act: return
            from java import jarray, jbyte
            cr=act.getContentResolver(); inp=cr.openInputStream(uri)
            if not inp: return
            orig_name=None
            try:
                OC=find_class("android.provider.OpenableColumns")
                c=cr.query(uri,None,None,None,None)
                if c and c.moveToFirst():
                    idx=c.getColumnIndex(OC.DISPLAY_NAME)
                    if idx>=0: orig_name=c.getString(idx)
                if c: c.close()
            except Exception: orig_name=None
            buf=jarray(jbyte)(65536); chunks=[]
            while True:
                n=inp.read(buf,0,65536)
                if n==-1: break
                chunks.append(bytes(b if b>=0 else b+256 for b in buf[:n]))
            inp.close(); data=b"".join(chunks); self._log("VRM: "+str(len(data))+"b")
            cache=act.getCacheDir().getAbsolutePath()
            base=(orig_name or "model").rsplit(".",1)[0]
            safe="".join(ch if (ch.isalnum() or ch in "-_ ") else "_" for ch in base)[:40].strip() or "model"
            fname=safe+"_"+str(int(time.time()*1000))+".vrm"
            dst=os.path.join(cache,fname)
            with open(dst,"wb") as out: out.write(data)
            new_url="file://"+dst
            self.ss("vrm_url",new_url)
            self._remember_model(new_url, label=safe)
            def _after():
                try: BulletinHelper.show_success(self.t("copy_ok"))
                except Exception: pass
                if self._comp:
                    if self._comp._alive: self._comp.load_vrm()
                    else: self._comp._showing=False; self._comp._hidden=False; self._comp.show()
            run_on_ui_thread(_after)
        except Exception as e:
            self._log("copy_vrm: "+str(e))
            try: BulletinHelper.show_error(self.t("copy_err"))
            except Exception: pass

    def _show_motions_menu(self, v=None, category=None):
        """Показать список .vrma анимаций из /sdcard/Stella/Motions/"""
        p=self
        try:
            files=[]; base=MOTIONS_DIR
            pool=None
            if category=="dance": pool=[os.path.join(base,n) for n in ANIM_DANCE]
            if pool:
                files=[(os.path.splitext(os.path.basename(p))[0],p) for p in pool if os.path.exists(p)]
            else:
                for root,dirs,fns in os.walk(base):
                    for fn in sorted(fns):
                        if fn.lower().endswith(".vrma"):
                            files.append((os.path.splitext(fn)[0], os.path.join(root,fn)))
                    dirs.sort()
            if not files:
                try: BulletinHelper.show_info(" "+MOTIONS_DIR+" — нет .vrma файлов")
                except Exception: pass
                return
        except Exception as e:
            p._log("motions scan: "+str(e)); return

        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                items=["▶ "+nm for nm,_ in files]+["⏹ Стоп"]
                bld=AlertDialogBuilder(act)
                bld.set_title(" Анимации")
                def oc(b,i):
                    b.dismiss()
                    if i>=len(files):
                        if p._comp and p._comp._alive:
                            p._comp._js("if(window.stopVrma)stopVrma();")
                        return
                    nm,path=files[i]
                    if p._comp and p._comp._alive:
                        loop=str(1 if "loop" in path.lower() else 0)
                        url="file://"+path
                        def _do_play(u=url,l=loop,n=nm):
                            import json as _j
                            p._comp._inject_vrma_lib()
                            p._comp._js("if(window.playVrma)playVrma("+_j.dumps(u)+","+l+");")
                            p._log("vrma: "+n)
                            try: BulletinHelper.show_info("▶ "+n)
                            except Exception: pass
                        run_on_queue(_do_play)
                        try: BulletinHelper.show_info("▶ "+nm)
                        except Exception: pass
                bld.set_items(items,oc)
                bld.set_negative_button("Закрыть",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: p._log("motions menu: "+str(e))
        run_on_ui_thread(_do)

    def _flip_model(self, view=None):
        if self._comp and self._comp._alive:
            self._comp._js("if(window.rotateModel)rotateModel(Math.PI);")
            try: BulletinHelper.show_info("Модель перевёрнута на 180°")
            except Exception: pass

