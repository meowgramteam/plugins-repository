def _detect_package_name():
    """
    Определяет реальное имя пакета текущего Telegram-клиента (AyuGram,
    exteraGram, официальный Telegram, Telegram Web и т.д.), чтобы пути
    сохранения файлов Стеллы не ломались при смене клиента/пересборке.
    """
    try:
        ctx = find_class("org.telegram.messenger.ApplicationLoader").applicationContext
        pkg = str(ctx.getPackageName())
        if pkg:
            return pkg
    except Exception:
        pass
    for candidate in ("com.radolyn.ayugram", "com.exteragram.messenger",
                      "org.telegram.messenger", "org.telegram.messenger.web"):
        return candidate
    return "org.telegram.messenger"

