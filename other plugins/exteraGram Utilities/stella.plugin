class StellaMood:
    """Система настроения."""
    def __init__(self):
        self._score = 0
        self._mood = 'neutral'
        self._last_interact = time.time()

    @property
    def current(self): return self._mood

    def on_tap(self):
        self._score = min(100, self._score + 8)
        self._last_interact = time.time()
        self._recalc()

    def on_dance(self):
        self._score = min(100, self._score + 20)
        self._last_interact = time.time()
        self._recalc()

    def on_idle_long(self):
        self._score = max(-50, self._score - 4)
        self._recalc()

    def tick(self):
        now = time.time()
        if now - self._last_interact > 600:
            self._score = max(-30, self._score - 2)
        elif self._score > 0:
            self._score = max(0, self._score - 1)
        elif self._score < 0:
            self._score = min(0, self._score + 1)
        self._recalc()

    def _recalc(self):
        h = datetime.datetime.now().hour
        if h >= 23 or h < 5:
            self._mood = 'sleepy'
        elif self._score >= 70:
            self._mood = 'excited'
        elif self._score >= 30:
            self._mood = 'happy'
        elif self._score >= 5:
            self._mood = 'neutral'
        elif self._score <= -30:
            self._mood = 'bored'
        else:
            self._mood = 'neutral'

    def get_anim_pool(self):
        return MOODS.get(self._mood, MOODS['neutral'])['anim']

    def describe(self):
        icons = {'happy':'','neutral':'','sleepy':'',
                 'energetic':'','bored':'','excited':''}
        return icons.get(self._mood, '') + ' ' + self._mood.capitalize()


class StellaStats:
    """Статистика и достижения."""
    def __init__(self, plugin):
        self._p = plugin
        self._start = time.time()
        if not self._p.gs(STAT_FIRST):
            self._p.ss(STAT_FIRST, datetime.datetime.now().strftime('%d.%m.%Y'))
        self._p.ss(STAT_SESS, int(self._p.gs(STAT_SESS) or 0) + 1)

    def tap(self):
        v = int(self._p.gs(STAT_TAPS) or 0) + 1
        self._p.ss(STAT_TAPS, v)
        self._check()

    def dance(self):
        v = int(self._p.gs(STAT_DANCES) or 0) + 1
        self._p.ss(STAT_DANCES, v)
        self._check()

    def save_uptime(self):
        elapsed = int(time.time() - self._start)
        total = int(self._p.gs(STAT_UPTIME) or 0) + elapsed
        self._p.ss(STAT_UPTIME, total)

    def summary(self):
        taps = int(self._p.gs(STAT_TAPS) or 0)
        dance = int(self._p.gs(STAT_DANCES) or 0)
        sess = int(self._p.gs(STAT_SESS) or 0)
        up = int(self._p.gs(STAT_UPTIME) or 0)
        first = self._p.gs(STAT_FIRST) or '?'
        h, m = up // 3600, (up % 3600) // 60
        unlocked = json.loads(self._p.gs('achievements') or '[]')
        achs = '\n'.join(
            f" {a['icon']} {a['name']}"
            for a in ACHIEVEMENTS if a['id'] in unlocked
        ) or ' нет пока'
        return (
            f" Касаний: {taps}\n"
            f" Танцев: {dance}\n"
            f" Сессий: {sess}\n"
            f"⏱ Онлайн: {h}ч {m}м\n"
            f" С нами с: {first}\n\n"
            f" Достижения:\n{achs}"
        )

    def _check(self):
        s = {STAT_TAPS: int(self._p.gs(STAT_TAPS) or 0),
             STAT_DANCES: int(self._p.gs(STAT_DANCES) or 0),
             STAT_SESS: int(self._p.gs(STAT_SESS) or 0),
             STAT_UPTIME: int(self._p.gs(STAT_UPTIME) or 0)}
        unlocked = json.loads(self._p.gs('achievements') or '[]')
        for a in ACHIEVEMENTS:
            if a['id'] not in unlocked:
                try:
                    if a['req'](s):
                        unlocked.append(a['id'])
                        self._p.ss('achievements', json.dumps(unlocked))
                        try: BulletinHelper.show_success(f" {a['icon']} {a['name']}")
                        except Exception: pass
                except Exception: pass


class StellaScheduler:
    """Планировщик событий по времени суток."""
    def __init__(self, plugin, companion_ref):
        self._p = plugin
        self._cref = companion_ref
        self._last_h = -1
        self._running = False

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            while self._running:
                try:
                    h = datetime.datetime.now().hour
                    if h != self._last_h:
                        self._last_h = h
                        self._on_hour(h)
                except Exception: pass
                time.sleep(60)
        threading.Thread(target=_loop, daemon=True, name='sched').start()

    def stop(self): self._running = False

    def _on_hour(self, h):
        comp = self._cref()
        if not comp or not comp._alive: return
        if h == 7:
            run_on_queue(lambda: comp._play_random_anim(TIME_GREET['morning'][2], False))
            if self._p._sounds: self._p._sounds.play('greet')
        elif h == 19:
            run_on_queue(lambda: comp._play_random_anim(TIME_GREET['evening'][2], False))
        elif h == 23:
            if self._p._sounds: self._p._sounds.play('sleep')
        elif 10 <= h <= 20 and random.random() < 0.25:
            run_on_queue(lambda: comp._play_random_anim(ANIM_RANDOM, False))


class StellaCamera:
    """Управление камерой — пресеты и кино-режим."""
    def __init__(self, companion):
        self._c = companion
        self._preset = 'portrait'
        self._cin = False

    def apply(self, name):
        p = CAMERA_PRESETS.get(name)
        if not p or not self._c or not self._c._alive: return
        self._preset = name
        self._c._js(
            f"if(cam){{"
            f"cam.fov={p['fov']};cam.updateProjectionMatrix();"
            f"cam.position.set(0,{p['y']},{p['z']});"
            f"cam.lookAt(0,{p['y']},0);}}"
        )

    def start_cinematic(self):
        if self._cin: return
        self._cin = True
        presets = list(CAMERA_PRESETS.keys())
        idx = [0]
        def _loop():
            while self._cin and self._c and self._c._alive:
                time.sleep(9)
                if not self._cin: break
                idx[0] = (idx[0] + 1) % len(presets)
                run_on_ui_thread(lambda: self.apply(presets[idx[0]]))
        threading.Thread(target=_loop, daemon=True, name='cinematic').start()

    def stop_cinematic(self): self._cin = False


class StellaIdleQuotes:
    """Периодически показывает фразы от Стеллы."""
    def __init__(self, plugin):
        self._p = plugin
        self._running = False
        self._interval = 300

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            time.sleep(120)
            while self._running:
                try:
                    if self._p.gs('idle_quotes'):
                        lang = 'en' if int(self._p.gs('language') or 0) == 1 else 'ru'
                        pool = IDLE_QUOTES_EN if lang == 'en' else IDLE_QUOTES_RU
                        try: BulletinHelper.show_info(random.choice(pool))
                        except Exception: pass
                except Exception: pass
                time.sleep(self._interval + random.randint(-60, 60))
        threading.Thread(target=_loop, daemon=True, name='quotes').start()

    def stop(self): self._running = False


class StellaBatteryMonitor:
    """Реакция на уровень батареи."""
    def __init__(self, plugin, companion_ref):
        self._p = plugin
        self._cref = companion_ref
        self._last = -1
        self._running = False

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            while self._running:
                try:
                    lv = self._level()
                    if 0 <= lv != self._last:
                        self._react(lv)
                        self._last = lv
                except Exception: pass
                time.sleep(120)
        threading.Thread(target=_loop, daemon=True, name='battery').start()

    def stop(self): self._running = False

    def _level(self):
        try:
            ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
            IM = find_class('android.content.Intent')
            IF = find_class('android.content.IntentFilter')
            b = ctx.registerReceiver(None, IF(IM.ACTION_BATTERY_CHANGED))
            return b.getIntExtra('level', -1)
        except Exception: return -1

    def _react(self, lv):
        comp = self._cref()
        if not comp or not comp._alive: return
        if lv <= 15 and self._last > 15:
            try: BulletinHelper.show_info(f" {lv}% — Стелла устаёт...")
            except Exception: pass
            run_on_queue(lambda: comp._play_random_anim(
                ['Loop/SadIdleMain.vrma'], True))
        elif lv >= 95 and (self._last < 90 or self._last < 0):
            try: BulletinHelper.show_success(f" {lv}% — Стелла заряжена!")
            except Exception: pass
            run_on_queue(lambda: comp._play_random_anim(
                ['Loop/Offensive Idle.vrma'], True))


def read_vrm_meta(path):
    """Читает метаданные VRM файла (имя, автор, лицензия)."""
    import struct
    try:
        with open(path, 'rb') as f:
            if f.read(4) != b'glTF': return {}
            f.read(8)
            clen = struct.unpack('<I', f.read(4))[0]
            if f.read(4) != b'JSON': return {}
            gltf = json.loads(f.read(clen).decode('utf-8', errors='ignore'))
        ext = gltf.get('extensions', {})
        meta = (ext.get('VRM',{}).get('meta',{}) or
                ext.get('VRMC_vrm',{}).get('meta',{}))
        return {
            'name': meta.get('title','') or meta.get('name','') or os.path.basename(path),
            'author': meta.get('author',''),
            'version': meta.get('version',''),
            'license': meta.get('licenseName','') or meta.get('license',''),
        }
    except Exception: return {}


def haptic(strength='light'):
    """Тактильная вибрация."""
    try:
        ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
        vib = ctx.getSystemService('vibrator')
        ms = {'light':15,'medium':30,'heavy':60}.get(strength,15)
        vib.vibrate(ms)
    except Exception: pass


def get_screen_dp():
    """Размер экрана в dp."""
    try:
        ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
        dm = ctx.getResources().getDisplayMetrics()
        d = dm.density or 1
        return int(dm.widthPixels / d), int(dm.heightPixels / d)
    except Exception: return 392, 850


class StellaScreensaver:
    """Хранитель экрана — автоматическая смена анимаций."""
    def __init__(self, companion):
        self._c = companion
        self._active = False

    def start(self):
        if self._active: return
        self._active = True
        pools = [ANIM_IDLE, ANIM_RANDOM, ANIM_GREET, ANIM_DANCE]
        idx = [0]
        def _loop():
            while self._active and self._c and self._c._alive:
                pool = pools[idx[0] % len(pools)]; idx[0] += 1
                self._c._play_random_anim(pool, False)
                time.sleep(30 + random.random() * 20)
        threading.Thread(target=_loop, daemon=True, name='screensaver').start()

    def stop(self): self._active = False


class StellaVRMPicker:
    """Помощник выбора VRM файлов с предпросмотром метаданных."""
    def __init__(self, plugin): self._p = plugin

    def pick_and_load(self):
        self._p._pick_file()

    def show_meta(self, path):
        meta = read_vrm_meta(path)
        if not meta: return
        def _do():
            try:
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act: return
                msg = (
                    f" {meta.get('name','?')}\n"
                    f" {meta.get('author','?')}\n"
                    f" {meta.get('license','?')}"
                )
                bld = AlertDialogBuilder(act)
                bld.set_title("VRM Info")
                bld.set_message(msg)
                bld.set_positive_button("OK", lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("vrm meta: "+str(e))
        run_on_ui_thread(_do)


class StellaQuickMenu:
    """Меню быстрых действий."""
    def __init__(self, plugin, companion):
        self._p = plugin
        self._c = companion

    def show(self):
        def _do():
            try:
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act: return
                lang = 'en' if int(self._p.gs('language') or 0) == 1 else 'ru'
                actions = QUICK_ACTIONS_EN if lang == 'en' else QUICK_ACTIONS_RU
                labels = [a[0] for a in actions]
                bld = AlertDialogBuilder(act)
                bld.set_title(" " + ("Quick Actions" if lang == 'en' else "Быстрые действия"))
                def oc(b, i):
                    b.dismiss()
                    self._exec(actions[i][1])
                bld.set_items(labels, oc)
                bld.set_negative_button("", lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("quick: "+str(e))
        run_on_ui_thread(_do)

    def _exec(self, cmd):
        c = self._c; p = self._p
        if not c or not c._alive: return
        try:
            if cmd == 'wave':
                c._js('(function(){var t=0,dur=2.5;function w(){t+=0.016;var v=Math.sin(t*7)*0.5*(1-t/dur);if(vrm){var b=vrm.humanoid.getNormalizedBoneNode("rightUpperArm");if(b)b.rotation.z=-1.15+v;}if(t<dur)requestAnimationFrame(w);}w();})();')
            elif cmd == 'dance':
                run_on_queue(lambda: c._play_random_anim(ANIM_DANCE, False))
                if p._stats: p._stats.dance()
            elif cmd == 'sleep':
                run_on_ui_thread(c._go_sleep)
            elif cmd == 'greet':
                run_on_queue(lambda: c._play_random_anim(ANIM_GREET, False))
            elif cmd == 'cinematic':
                if p._cam:
                    if p._cam._cin: p._cam.stop_cinematic()
                    else: p._cam.start_cinematic()
            elif cmd == 'close_up':
                if p._cam: p._cam.apply('close_up')
            elif cmd == 'standard':
                if p._cam: p._cam.apply('portrait')
            elif cmd == 'reset':
                c._js("if(window.resetPan)resetPan();")
                if p._cam: p._cam.apply('portrait')
            elif cmd == 'flip180':
                c._js("if(window.rotateModel)rotateModel(Math.PI);")
                try:
                    BulletinHelper.show_info("Модель развёрнута на 180°")
                except Exception: pass
            elif cmd == 'rotate_toggle':
                new_v = not bool(p.gs('rotate_mode'))
                p._on_rotate_mode(new_v)
                try:
                    BulletinHelper.show_info(
                        "Режим поворота одним пальцем: " + ("включён" if new_v else "выключен"))
                except Exception: pass
        except Exception as e:
            p._log("quick_exec: "+str(e))


class StellaThemeManager:
    """Управление темами оформления."""
    def __init__(self, companion): self._c = companion

    def apply(self, theme_name):
        t = THEMES.get(theme_name, THEMES['dark'])
        if not self._c or not self._c._alive: return
        self._c._js("document.body.style.background='"+t['body']+"';")

    @staticmethod
    def names(): return list(THEMES.keys())


class StellaDebugger:
    """Отладчик — показывает состояние VRM и анимаций."""
    def __init__(self, plugin, companion):
        self._p = plugin
        self._c = companion
        self._on = False

    def toggle(self):
        self._on = not self._on
        if self._c and self._c._alive:
            disp = "block" if self._on else "none"
            self._c._js(f"document.getElementById('s').style.display='{disp}';")

    def dump(self):
        if not self._c or not self._c._alive: return "no model"
        self._c._js(
            "st('EXPR:'+_expressions.length+'|BONES:'+Object.keys(_bones).length+"
            "'|VRMA:'+(_vrmaPlaying?'PLAY':'idle')+'|BASE:'+(_baseAction?'OK':'NO')"
            "+'|CACHE:'+Object.keys(_clipCache).length);"
        )

    def info(self):
        p = self._p
        taps = int(p.gs(STAT_TAPS) or 0)
        dances = int(p.gs(STAT_DANCES) or 0)
        sess = int(p.gs(STAT_SESS) or 0)
        mood = p._mood.describe() if hasattr(p, '_mood') else '?'
        w, h = get_screen_dp()
        return (
            f" Debug Info\n"
            f"Screen: {w}×{h}dp\n"
            f"Mood: {mood}\n"
            f"Taps: {taps} | Dances: {dances}\n"
            f"Sessions: {sess}\n"
            f"VRM: {p.gs('vrm_url') or 'default'}\n"
            f"Motions: {MOTIONS_DIR}\n"
            f"Sounds: {SOUNDS_BASE}"
        )


class StellaAutoDownloader:
    """Автоматическая загрузка ресурсов."""
    def __init__(self, plugin): self._p = plugin

    def check_and_download(self):
        """Скачать все недостающие анимации и звуки в фоне."""
        import urllib.request as _ur, urllib.parse as _up
        missing = [f for f in MOTION_FILES
                   if not os.path.exists(os.path.join(MOTIONS_DIR, f))]
        if not missing: return
        self._p._log(f"auto-dl: {len(missing)} анимаций...")
        try: BulletinHelper.show_info(f" Загружаю {len(missing)} анимаций...")
        except Exception: pass
        ok = 0
        for fn in missing:
            dst = os.path.join(MOTIONS_DIR, fn)
            url = MOTIONS_REPO + "/" + _up.quote(fn)
            try:
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                _ur.urlretrieve(url, dst)
                ok += 1
            except Exception as e:
                self._p._log(f"dl fail: {fn}: {e}")
        if ok:
            try: BulletinHelper.show_success(f" Загружено {ok} анимаций")
            except Exception: pass
        self._p._log(f"auto-dl done: {ok}/{len(missing)}")

    def check_vrm(self):
        if not os.path.exists(STELLA_VRM):
            import urllib.request as _ur
            try:
                os.makedirs(os.path.dirname(STELLA_VRM), exist_ok=True)
                _ur.urlretrieve(DEFAULT_VRM, STELLA_VRM)
                self._p.ss('vrm_url', 'file://' + STELLA_VRM)
                try: BulletinHelper.show_success(" Stella.vrm загружен!")
                except Exception: pass
            except Exception as e:
                self._p._log("vrm dl fail: " + str(e))



class WaifuPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._logs=[]; self._comp=None; self._hooks=[]
        self._sounds=None; self._sherpa=None
        self._mood = StellaMood()
        self._stats = StellaStats(self)
        self._dl = StellaAutoDownloader(self)
        self._quotes = StellaIdleQuotes(self)
        self._battery = None
        self._sched = None
        self._cam = None
        self._acc = None
        self._quick = None
        self._dbg = None
        self._vrm_picker = None

    def gs(self,k): return self.get_setting(k,DEFAULTS.get(k))
    def ss(self,k,v,r=False): self.set_setting(k,v,reload_settings=r)
    def is_on(self): return bool(self.gs("enable"))
    def stella_on(self): return bool(self.gs("stella_enable"))

    def _auto_setup(self):
        """Автоматическая загрузка VRM и звуков при первом запуске."""
        import urllib.request as _ur
        def _dl(url,path):
            try:
                os.makedirs(os.path.dirname(path),exist_ok=True)
                _ur.urlretrieve(url,path)
                return True
            except Exception as e: self._log("dl err "+os.path.basename(path)+": "+str(e)); return False
        if not os.path.exists(STELLA_VRM):
            self._log("auto: downloading Stella.vrm...")
            try: BulletinHelper.show_info(" Скачиваю Stella.vrm...")
            except Exception: pass
            if _dl(DEFAULT_VRM, STELLA_VRM):
                self._log("auto: VRM OK")
                self.ss("vrm_url","file://"+STELLA_VRM)
                try: BulletinHelper.show_success(" Stella.vrm загружен!")
                except Exception: pass
            else:
                try: BulletinHelper.show_error(" Ошибка загрузки VRM")
                except Exception: pass
        import urllib.request as _ur2, urllib.parse as _up3, json as _js2
        for cat in SOUND_CATS:
            cat_dir=os.path.join(SOUNDS_BASE,cat)
            try: os.makedirs(cat_dir,exist_ok=True)
            except Exception: pass
            try: existing=[f for f in os.listdir(cat_dir) if os.path.splitext(f)[1].lower() in SOUND_EXTS]
            except Exception: existing=[]
            if existing: continue
            try:
                api="https://api.github.com/repos/exterabase/lelouch/contents/sounds/"+_up3.quote(cat)
                req=_ur2.Request(api,headers={"User-Agent":"Mozilla/5.0"})
                with _ur2.urlopen(req,timeout=10) as resp: items=_js2.loads(resp.read().decode())
                for item in items:
                    if item.get("type")=="file" and os.path.splitext(item["name"])[1].lower() in SOUND_EXTS:
                        dst=os.path.join(cat_dir,item["name"])
                        raw_url=item.get("download_url","")
                        try:
                            req2=_ur2.Request(raw_url,headers={"User-Agent":"Mozilla/5.0"})
                            with _ur2.urlopen(req2,timeout=15) as r2:
                                with open(dst,"wb") as out: out.write(r2.read())
                            self._log("sound ok: "+cat+"/"+item["name"])
                        except Exception as e: self._log("sound fail: "+cat+"/"+item["name"]+": "+str(e))
            except Exception as e: self._log("sound api ["+cat+"]: "+str(e))
        missing_m=[f for f in MOTION_FILES
                   if not os.path.exists(os.path.join(MOTIONS_DIR,f))]
        if missing_m:
            self._log("auto: downloading "+str(len(missing_m))+" motions...")
            import urllib.parse as _up2
            for fn in missing_m:
                dst=os.path.join(MOTIONS_DIR,fn)
                url=MOTIONS_REPO+"/"+_up2.quote(fn)
                _dl(url,dst)
        if self._sounds: self._sounds.invalidate()
        self._log("auto: setup done")
    def _lang(self):
        try: return "en" if int(self.gs("language") or 0)==1 else "ru"
        except: return "ru"
    def t(self,k): return S.get(self._lang(),S["ru"]).get(k,k)

    def _log(self,msg):
        ts=datetime.datetime.now().strftime("%H:%M:%S")
        self._logs.append("["+ts+"] "+str(msg))
        if len(self._logs)>800: self._logs=self._logs[-800:]
        alog("[Stella] "+str(msg))

    def on_plugin_load(self):
        self._log("=== Stella v2.0.1 ===")
        self._comp = _Companion(self)
        self._sounds = _SoundPlayer(self)
        self._sherpa = _SherpaEngine(self)
        self._cam = StellaCamera(self._comp)
        self._battery = StellaBatteryMonitor(self, lambda: self._comp)
        self._sched = StellaScheduler(self, lambda: self._comp)
        self.add_on_send_message_hook()
        try:
            cls=find_class("org.telegram.ui.LaunchActivity")
            if cls:
                r=self.hook_all_methods(cls,"onActivityResult",_ResultHook(self))
                if r: self._hooks.extend(r); self._log("hook ok: "+str(len(r)))
        except Exception as e: self._log("hook: "+str(e))
        run_on_queue(self._auto_setup)
        if self.is_on(): self._comp.show()
        if self.stella_on(): run_on_queue(self._stella_start)
        if bool(self.gs("idle_quotes")): self._quotes.start()
        if bool(self.gs("battery_react")): self._battery.start()
        if bool(self.gs("sched_react")): self._sched.start()
        if not bool(self.gs("welcome_shown")):
            run_on_ui_thread(self._show_welcome_dialog, 800)

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        """Перехватывает исходящее сообщение: если текст совпадает с
        кастомной командой смены модели (вкладка «Смена модели»), сообщение
        НЕ уходит в чат — вместо этого открывается выбор файла модели."""
        try:
            msg = getattr(params, "message", None)
            if not isinstance(msg, str): return HookResult()
            cmd = str(self.gs("custom_model_cmd") or "").strip()
            if cmd and msg.strip().lower() == cmd.lower():
                run_on_ui_thread(self._pick_file)
                try: BulletinHelper.show_info(" Открываю выбор модели...")
                except Exception: pass
                return HookResult(strategy=HookStrategy.CANCEL)
        except Exception as e:
            self._log("model_cmd_hook: "+str(e))
        return HookResult()

    def _show_welcome_dialog(self):
        """
        Показывается один раз после установки плагина.
        Ссылка и кнопка «Подписаться» кликабельны, но переход по ним —
        исключительно по решению пользователя. Никакой автоматической
        подписки на канал здесь нет.
        """
        try:
            f = get_last_fragment()
            act = f.getParentActivity() if f else None
            if not act:
                run_on_ui_thread(self._show_welcome_dialog, 1500)
                return

            from android.widget import TextView, LinearLayout
            from android.graphics import Color
            from android.view import Gravity

            channel_url = "https://t.me/knice_tech"

            full_text = ('Разработано при поддержке проекта "Голосовой помощник для ПК — Stella". '
                         'Ссылка на канал доступна по кнопке "Подписаться" ниже.')

            tv = TextView(act)
            tv.setText(full_text)
            tv.setTextSize(0, AndroidUtilities.dp(17.0))
            try:
                tv.setTextColor(Color.parseColor("#FFFFFF"))
                tv.setLineSpacing(AndroidUtilities.dp(5.0), 1.05)
                tv.setGravity(Gravity.CENTER_HORIZONTAL)
            except Exception: pass
            pad_h = AndroidUtilities.dp(28.0)
            pad_v = AndroidUtilities.dp(20.0)
            tv.setPadding(pad_h, pad_v, pad_h, pad_v)

            wrapper = LinearLayout(act)
            wrapper.setOrientation(LinearLayout.VERTICAL)
            wrapper.addView(tv)

            builder = AlertDialogBuilder(act)
            builder.set_title("Добро пожаловать в Stella ")
            builder.set_view(wrapper)
            builder.set_cancelable(True)

            def _on_subscribe(b, w):
                b.dismiss()
                self.ss("welcome_shown", True)
                self._open_url(channel_url)

            builder.set_positive_button("Понятно", lambda b, w: b.dismiss())
            builder.set_neutral_button("Подписаться", _on_subscribe)
            builder.set_on_dismiss_listener(lambda b: (
                self.ss("welcome_shown", True),
                run_on_ui_thread(self._show_age_gate_dialog, 400),
            ))
            builder.show()
        except Exception as e:
            self._log("welcome_dialog: " + str(e) + "\n" + traceback.format_exc())
            self.ss("welcome_shown", True)
            run_on_ui_thread(self._show_age_gate_dialog, 400)

    def _show_age_gate_dialog(self):
        """
        Возрастное подтверждение + согласие с условиями использования.
        Показывается один раз (флаг age_gate_shown), сразу после
        приветственного окна. Относится к отдельному платному 18+ продукту
        (не к бесплатной модели из этого плагина).
        """
        if bool(self.gs("age_gate_shown")):
            return
        try:
            f = get_last_fragment()
            act = f.getParentActivity() if f else None
            if not act:
                run_on_ui_thread(self._show_age_gate_dialog, 1500)
                return

            from android.widget import TextView, LinearLayout
            from android.graphics import Color
            from android.view import Gravity

            terms_url = "https://t.me/knice_tech"

            full_text = ('Отдельный платный 18+ продукт проекта Stella предназначен только '
                        'для совершеннолетних пользователей. Продолжая, вы подтверждаете, '
                        'что вам исполнилось 18 лет, и соглашаетесь с условиями использования '
                        '(кнопка "Условия" ниже).')

            tv = TextView(act)
            tv.setText(full_text)
            tv.setTextSize(0, AndroidUtilities.dp(16.0))
            try:
                tv.setTextColor(Color.parseColor("#FFFFFF"))
                tv.setLineSpacing(AndroidUtilities.dp(5.0), 1.05)
                tv.setGravity(Gravity.CENTER_HORIZONTAL)
            except Exception: pass
            pad_h = AndroidUtilities.dp(28.0)
            pad_v = AndroidUtilities.dp(20.0)
            tv.setPadding(pad_h, pad_v, pad_h, pad_v)

            wrapper = LinearLayout(act)
            wrapper.setOrientation(LinearLayout.VERTICAL)
            wrapper.addView(tv)

            builder = AlertDialogBuilder(act)
            builder.set_title("Возрастное подтверждение 18+")
            builder.set_view(wrapper)
            builder.set_cancelable(False)

            def _confirm(b, w):
                b.dismiss()
                self.ss("age_gate_shown", True)
                self.ss("age_confirmed", True)
                self._log("age_gate: confirmed 18+")
                run_on_ui_thread(self._show_mature_notice_dialog, 400)

            def _decline(b, w):
                b.dismiss()
                self.ss("age_gate_shown", True)
                self.ss("age_confirmed", False)
                self._log("age_gate: declined (under 18)")
                try:
                    BulletinHelper.show_info("18+ функции будут недоступны")
                except Exception: pass

            def _terms(b, w):
                self._open_url(terms_url)

            builder.set_positive_button("Мне есть 18, продолжить", _confirm)
            builder.set_negative_button("Мне нет 18", _decline)
            builder.set_neutral_button("Условия", _terms)
            builder.show()
        except Exception as e:
            self._log("age_gate: " + str(e) + "\n" + traceback.format_exc())
            self.ss("age_gate_shown", True)

    def _show_mature_notice_dialog(self):
        """
        Показывается один раз (флаг mature_notice_shown), сразу после
        возрастного подтверждения. Информирует про вкладку «Доп. контент
        (18+)» в настройках плагина + кнопка покупки платного доступа.
        """
        if bool(self.gs("mature_notice_shown")):
            return
