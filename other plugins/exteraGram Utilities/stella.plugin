    def _show_health(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                lines=[]
                vurl=self.gs('vrm_url') or ''
                if vurl.startswith('file://') and os.path.exists(vurl[7:]):
                    try: lines.append(" VRM: "+str(os.path.getsize(vurl[7:])//1024)+"KB")
                    except: lines.append(" VRM: OK")
                else: lines.append(" VRM: URL")
                loaded=sum(1 for f in MOTION_FILES if os.path.exists(os.path.join(MOTIONS_DIR,f)))
                lines.append(" Анимаций: "+str(loaded)+"/"+str(len(MOTION_FILES)))
                bld=AlertDialogBuilder(act)
                bld.set_title(" Диагностика")
                bld.set_message(chr(10).join(lines))
                bld.set_positive_button("OK",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("health: "+str(e))
        run_on_ui_thread(_do)
    def _show_help_dialog(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                text=(
                    'Разработано при поддержке проекта "Голосовой помощник для ПК — Stella".\n\n'

                    ' ЖЕСТЫ (управление моделью)\n'
                    'Один тап — Стелла показывает случайную эмоцию.\n'
                    'Тройной тап подряд — запускает случайный танец.\n'
                    'Долгое нажатие — открывает быстрое меню действий (помахать, '
                    'потанцевать, приветствие, кино-режим, крупный план, сброс позиции, '
                    'разворот на 180° и т.д.).\n'
                    'Перетаскивание одним пальцем — двигает окно Стеллы по экрану. '
                    'Если во вкладке «Камера и свет» включён «Поворот одним пальцем» — '
                    'вместо этого поворачивает и наклоняет саму модель.\n'
                    'Два пальца — работают всегда одинаково, в любом режиме: сведение/'
                    'разведение приближает и отдаляет камеру (зум), вращение пальцами '
                    'поворачивает модель.\n\n'

                    ' ВКЛАДКА «ОСНОВНОЕ»\n'
                    'Показать Стеллу — включает или полностью скрывает 3D-компаньона.\n'
                    'Загрузить / Перезагрузить модель — выбор своего .vrm файла с телефона '
                    'и повторная загрузка текущей модели.\n'
                    'Перевернуть модель на 180° — если после загрузки модель стоит спиной '
                    'к камере.\n'
                    'Скачать всё — одной кнопкой скачивает базовую модель, анимации и звуки.\n'
                    'Звуковые реакции — Стелла озвучивает касания и события короткими '
                    'звуками.\n\n'

                    ' ВКЛАДКА «ОКНО»\n'
                    'Пресет размера / Ширина / Высота — готовые размеры окна или свои '
                    'значения в dp.\n'
                    'Прозрачность и границы окна — насколько окно прозрачное и нужна ли '
                    'рамка для удобного захвата.\n'
                    'Прилипать к краям / Заблокировать — окно само прижимается к краю '
                    'экрана после отпускания, либо вообще запрещено двигать.\n\n'

                    ' ВКЛАДКА «ПОВЕДЕНИЕ»\n'
                    'Реакции на касание / Фразы Стеллы — случайные эмоции при тапе и '
                    'периодические фразы-подсказки.\n'
                    'Реакция на батарею / на время суток — Стелла комментирует уровень '
                    'заряда телефона и здоровается утром/вечером/ночью.\n'
                    'Скорость анимации — насколько быстро проигрывается idle-анимация.\n'
                    'Физика при переносе окна / Сила ветра — волосы и элементы одежды '
                    'покачиваются при перетаскивании окна и от «ветра» — лёгкой постоянной '
                    'анимации.\n\n'

                    ' ВКЛАДКА «КАМЕРА И СВЕТ»\n'
                    'Поворот модели — ручные значения поворота/наклона и зума камеры, а '
                    'также включение режима «поворот одним пальцем» (см. жесты выше).\n'
                    'Освещение — яркость и цвет основного света сцены.\n'
                    'Кожа / Одежда / Волосы — яркость и HEX-цвет для перекраски материалов '
                    'модели.\n'
                    'Ограничение FPS — 60 максимальная плавность, 30/24 экономия батареи '
                    'на слабых телефонах.\n\n'

                    ' ВКЛАДКА «МОДЕЛИ»\n'
                    'Загрузить новую модель / Список моделей — все ранее загруженные .vrm '
                    'сохраняются здесь, нажми на модель в списке, чтобы переключиться на '
                    'неё без повторной загрузки.\n'
                    'Команда смены модели — своя текстовая фраза, при отправке которой '
                    'откроется выбор файла.\n\n'

                    ' ВКЛАДКА «18+»\n'
                    'Каталог моделей — внешняя ссылка на дополнительный каталог моделей '
                    '18+, доступна только совершеннолетним.\n\n'

                    ' СТАТИСТИКА\n'
                    'Показывает количество касаний, танцев, сессий и открытые '
                    'достижения.\n\n'

                    ' РАЗРАБОТЧИКИ И ПОДДЕРЖКА\n'
                    '@lyzos, @rei_plugins, канал поддержки — ссылки доступны на этой же '
                    'вкладке ниже.'
                )
                bld=AlertDialogBuilder(act)
                bld.set_title("Справка по Stella")
                bld.set_message(text)
                bld.set_positive_button("Понятно",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("help_dialog: "+str(e))
        run_on_ui_thread(_do)

