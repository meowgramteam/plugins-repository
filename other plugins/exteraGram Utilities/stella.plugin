    def _open_url(self,url):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                from android.content import Intent
                from android.net import Uri
                intent=Intent(Intent.ACTION_VIEW, Uri.parse(url))
                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                act.startActivity(intent)
            except Exception as e:
                self._log("open_url: "+str(e))
        run_on_ui_thread(_do)

    def _open_tg(self,u):
        def _do():
            url="https://t.me/"+u
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                from android.content import Intent
                from android.net import Uri
                intent=Intent(Intent.ACTION_VIEW, Uri.parse(url))
                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                act.startActivity(intent)
            except Exception as e:
                self._log("tg open: "+str(e))
                try:
                    from android.content import Intent
                    from android.net import Uri
                    ctx=find_class("org.telegram.messenger.ApplicationLoader").applicationContext
                    intent=Intent(Intent.ACTION_VIEW, Uri.parse(url))
                    intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                    ctx.startActivity(intent)
                except Exception as e2:
                    self._log("tg open fallback: "+str(e2))
        run_on_ui_thread(_do)

