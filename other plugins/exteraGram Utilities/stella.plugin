def _vrma_path(name):
    return os.path.join(MOTIONS_DIR, name)

def _base_anim_url():
    """URL базовой (всегда играющей) анимации: локальный файл в приоритете,
    иначе — GitHub-репозиторий с анимациями."""
    local = _vrma_path(ANIM_BASE)
    if os.path.exists(local):
        return "file://" + local
    import urllib.parse as _up
    return MOTIONS_REPO + "/" + _up.quote(ANIM_BASE)

