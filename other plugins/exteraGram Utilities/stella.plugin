        run_on_ui_thread(_do)

    def _reset(self,view=None):
        for k,v in DEFAULTS.items(): self.ss(k,v)
        self.ss("enable",True,r=True); self._log("reset")
        try: BulletinHelper.show_success(self.t("reset_ok"))
        except Exception: pass

    def _ci(self,key):
        def cb(v):
            try:
                val=int(float(str(v).strip())); self.ss(key,val)
                if self._comp and self._comp._alive:
                    if key in ("width_dp","height_dp"):
                        self._comp.resize(int(self.gs("width_dp")),int(self.gs("height_dp")))
                    elif key=="idle_speed":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setSpd)setSpd("+str(val/50.0)+");"))
                    elif key=="cam_z":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setCamZ)setCamZ("+str(val/10.0)+");"))
                    elif key=="alpha":
                        run_on_ui_thread(lambda: self._comp._root and
                            self._comp._root.setAlpha(val/100.0))
                    elif key=="rotate_y":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setRotationY)setRotationY("+str(val)+");"))
                    elif key=="rotate_x":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setRotationX)setRotationX("+str(val)+");"))
                    elif key=="light_brightness":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setLightBrightness)setLightBrightness("+str(val)+");"))
                    elif key=="skin_brightness":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setSkinBrightness)setSkinBrightness("+str(val)+");"))
                    elif key=="clothes_brightness":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setClothesBrightness)setClothesBrightness("+str(val)+");"))
                    elif key=="hair_brightness":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setHairBrightness)setHairBrightness("+str(val)+");"))
                    elif key=="target_fps":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setTargetFPS)setTargetFPS("+str(val)+");"))
            except Exception as e: self._log("ci("+key+"): "+str(e))
        return cb

    def _cb(self,k): return lambda v: self.ss(k,bool(v))
    def _cl(self,i): self.ss("language",i,r=True)

    def _ci_str(self,key):
        """Простой сеттер для текстовых (не числовых) настроек-строк."""
        def cb(v): self.ss(key,str(v))
        return cb

    def _on_wind_strength(self,v):
        try: iv=max(0,min(100,int(v)))
        except Exception: iv=0
        self.ss("wind_strength",iv)
        if self._comp: self._comp._js("if(window.setWindStrength)setWindStrength("+str(iv)+");")

    def _open_mature_catalog(self,view=None):
        if not bool(self.gs("age_confirmed")):
            try: BulletinHelper.show_info("Нужно подтвердить возраст 18+, чтобы открыть каталог")
            except Exception: pass
            run_on_ui_thread(self._show_age_gate_dialog, 300)
            return
        if not MATURE_CATALOG_URL:
            try: BulletinHelper.show_info("Ссылка на каталог ещё не настроена")
            except Exception: pass
            return
        self._open_url(MATURE_CATALOG_URL)

    LIGHT_COLORS = ["#FFFFFF","#FFE4C4","#CFE8FF","#FFD1E8","#D6FFCF"]
    def _on_light_color(self, i):
        try:
            hexc = self.LIGHT_COLORS[int(i)]
            self.ss("light_color", hexc)
            if self._comp and self._comp._alive:
                run_on_ui_thread(lambda: self._comp._js(
                    "if(window.setLightColor)setLightColor("+json.dumps(hexc)+");"))
        except Exception as e: self._log("light_color: "+str(e))

    def _on_skin_color_hex(self, v):
        try:
            hexc = str(v).strip()
            if not hexc.startswith("#") or len(hexc) not in (4,7): return
            self.ss("skin_color", hexc)
            if self._comp and self._comp._alive:
                run_on_ui_thread(lambda: self._comp._js(
                    "if(window.setSkinColor)setSkinColor("+json.dumps(hexc)+");"))
        except Exception as e: self._log("skin_color: "+str(e))

    def _on_hair_color_hex(self, v):
        try:
            hexc = str(v).strip()
            if not hexc.startswith("#") or len(hexc) not in (4,7): return
            self.ss("hair_color", hexc)
            if self._comp and self._comp._alive:
                run_on_ui_thread(lambda: self._comp._js(
                    "if(window.setHairColor)setHairColor("+json.dumps(hexc)+");"))
        except Exception as e: self._log("hair_color: "+str(e))

    def _on_clothes_color_hex(self, v):
        try:
            hexc = str(v).strip()
            if not hexc.startswith("#") or len(hexc) not in (4,7): return
            self.ss("clothes_color", hexc)
            if self._comp and self._comp._alive:
                run_on_ui_thread(lambda: self._comp._js(
                    "if(window.setClothesColor)setClothesColor("+json.dumps(hexc)+");"))
        except Exception as e: self._log("clothes_color: "+str(e))

    def _show_download_progress(self, view=None):
        """Скачать всё: VRM + анимации + звуки — BottomSheet с прогресс-баром."""
        import urllib.request as _ur, urllib.parse as _up, json as _js
        p = self

        def _run():
            tasks = []
            if not os.path.exists(STELLA_VRM):
                tasks.append(("Stella.vrm", DEFAULT_VRM, STELLA_VRM))
            for fn in MOTION_FILES:
                dst = os.path.join(MOTIONS_DIR, fn)
                if not os.path.exists(dst):
                    tasks.append((fn, MOTIONS_REPO + "/" + _up.quote(fn), dst))
            for cat in SOUND_CATS:
                cat_dir = os.path.join(SOUNDS_BASE, cat)
                try: existing=[f for f in os.listdir(cat_dir) if os.path.splitext(f)[1].lower() in SOUND_EXTS]
                except Exception: existing=[]
                if existing: continue
                try:
                    api="https://api.github.com/repos/exterabase/lelouch/contents/sounds/"+_up.quote(cat)
                    req=_ur.Request(api,headers={"User-Agent":"Mozilla/5.0"})
                    with _ur.urlopen(req,timeout=10) as resp: items=_js.loads(resp.read().decode())
                    for item in items:
                        if item.get("type")=="file" and os.path.splitext(item["name"])[1].lower() in SOUND_EXTS:
                            dst=os.path.join(cat_dir,item["name"])
                            tasks.append((cat+"/"+item["name"],item.get("download_url",""),dst))
                except Exception as e: p._log("sound api ["+cat+"]: "+str(e))

            total=len(tasks)
            if total==0:
                run_on_ui_thread(lambda: BulletinHelper.show_success("Всё уже загружено!")); return

            pb_ref=[None]; tv_ref=[None]; tv2_ref=[None]; sheet_ref=[None]

            def _make_sheet():
                try:
                    f=get_last_fragment(); act=f.getParentActivity() if f else None
                    if not act: return
                    AU =find_class("org.telegram.messenger.AndroidUtilities")
                    LL =find_class("android.widget.LinearLayout")
                    LLP =find_class("android.widget.LinearLayout$LayoutParams")
                    PB =find_class("android.widget.ProgressBar")
                    TV =find_class("android.widget.TextView")
                    GR =find_class("android.graphics.Color")
                    TF =find_class("android.graphics.Typeface")
                    BS =find_class("org.telegram.ui.ActionBar.BottomSheet")

                    pad=AU.dp(20.0)
                    root=LL(act); root.setOrientation(1)
                    root.setPadding(pad,AU.dp(16.0),pad,AU.dp(24.0))

                    tv_title=TV(act)
                    tv_title.setText("Загрузка ресурсов")
                    tv_title.setTextSize(0,AU.dp(8.0))
                    try:
                        tv_title.setTypeface(TF.DEFAULT_BOLD)
                        tv_title.setTextColor(GR.parseColor("#FFFFFF"))
                    except Exception: pass
                    lp_t=LLP(-2,-2); lp_t.bottomMargin=AU.dp(10.0)
                    root.addView(tv_title,lp_t)

                    pb=PB(act,None,16842872)
                    pb.setMax(total); pb.setProgress(0)
                    lp_pb=LLP(-1,AU.dp(6.0))
                    root.addView(pb,lp_pb)

                    tv=TV(act); tv.setText("0 / "+str(total))
                    tv.setTextSize(0,AU.dp(5.5))
                    try: tv.setTextColor(GR.parseColor("#AAAAAA"))
                    except Exception: pass
                    lp_tv=LLP(-2,-2); lp_tv.topMargin=AU.dp(8.0)
                    root.addView(tv,lp_tv)

                    tv2=TV(act); tv2.setText("Подготовка...")
                    tv2.setTextSize(0,AU.dp(5.0))
                    try: tv2.setTextColor(GR.parseColor("#777777"))
                    except Exception: pass
                    lp_tv2=LLP(-1,-2); lp_tv2.topMargin=AU.dp(4.0)
                    root.addView(tv2,lp_tv2)

                    builder=BS.Builder(act)
                    builder.setCustomView(root)
                    sheet=builder.create()
                    sheet.setCancelable(False)
                    sheet.show()
                    sheet_ref[0]=sheet; pb_ref[0]=pb; tv_ref[0]=tv; tv2_ref[0]=tv2
                except Exception as e: p._log("dl_sheet: "+str(e))
            run_on_ui_thread(_make_sheet)
            import time as _t; _t.sleep(0.6)

            ok=0; fail=0
            for idx,(name,url,dst) in enumerate(tasks,1):
                try:
                    os.makedirs(os.path.dirname(dst),exist_ok=True)
                    req=_ur.Request(url,headers={"User-Agent":"Mozilla/5.0"})
                    with _ur.urlopen(req,timeout=20) as r:
                        with open(dst,"wb") as out: out.write(r.read())
                    ok+=1
                except Exception as e: p._log("dl fail: "+name+": "+str(e)); fail+=1
                c=idx
                def _upd(c=c,n=name):
                    try:
                        if pb_ref[0]: pb_ref[0].setProgress(c)
                        if tv_ref[0]: tv_ref[0].setText(str(c)+" / "+str(total))
                        if tv2_ref[0]: tv2_ref[0].setText(n[-40:] if len(n)>40 else n)
                    except Exception: pass
                run_on_ui_thread(_upd)

            def _done():
                try:
                    if sheet_ref[0]:
                        try: sheet_ref[0].dismiss()
                        except Exception: pass
                    if ok>0:
                        BulletinHelper.show_success("Загружено "+str(ok)+" файлов"+(", ошибок: "+str(fail) if fail else ""))
                        if p._sounds: p._sounds.invalidate()
                    else:
                        BulletinHelper.show_error("Ошибка загрузки. Проверь интернет.")
                except Exception: pass
            run_on_ui_thread(_done)

        threading.Thread(target=_run,daemon=True,name="stella_dl").start()

    def create_settings(self) -> List[Any]:
        t=self.t
        tab=int(self.gs("settings_tab") or 0)
        top=[
            Selector(key="settings_tab",text="Вкладка",default=0,
                     items=["Основное","Окно","Поведение","Камера и свет",
                            "Модели","18+","Справка"],
                     icon="msg_settings",
                     on_change=lambda i: self.ss("settings_tab",i,r=True)),
        ]
        bot=[
            Divider(text=t("footer")),
            Text(text="Сбросить настройки",icon="chats_delete",red=True,on_click=self._reset),
        ]
        if tab==0:
            mid=[
                Header(text="Модель"),
                Switch(key="enable",text="Показать Стеллу",subtext="Включить 3D компаньона",
                       default=True,icon="msg_settings",on_change=self._on_enable_change),
                Text(text="Загрузить модель (.vrm)",icon="msg_link",accent=True,on_click=self._pick_file),
                Text(text="Перезагрузить модель",icon="msg_reset",accent=True,on_click=self._do_reload),
                Text(text=" Перевернуть модель на 180°",icon="msg_reset",
                     subtext="Если модель стоит спиной — нажми здесь",
                     on_click=self._flip_model),
                Text(text="Скачать всё",subtext="Модель + анимации + звуки",icon="msg_download",accent=True,on_click=self._show_download_progress),
                Divider(),
                Header(text="Звуки"),
                Switch(key="stella_enable",text="Звуковые реакции",subtext="Стелла реагирует на касания",
                       default=True,icon="msg_voice",on_change=self._on_stella_enable),
                Divider(),
                Header(text="Язык"),
                Selector(key="language",text="Язык",default=0,
                         items=["RU","EN"],icon="msg_language",on_change=self._cl),
                Text(text="Справка по всем функциям",icon="msg_info",accent=True,
                     on_click=self._show_help_dialog),
            ]
        elif tab==1:
            mid=[
                Header(text="Размер"),
                Text(text="Пресет размера",icon="msg_photo",on_click=self._show_size_menu),
                Input(key="width_dp", text="Ширина (dp)",default="128",
                      icon="msg_settings",on_change=lambda v: self._on_win_size(v,None)),
                Input(key="height_dp",text="Высота (dp)",default="310",
                      icon="msg_settings",on_change=lambda v: self._on_win_size(None,v)),
                Divider(),
                Header(text="Внешний вид"),
                Input(key="alpha",text="Прозрачность (%)",default=str(DEFAULTS["alpha"]),
                      icon="msg_settings",on_change=self._ci("alpha")),
                Switch(key="show_borders",text="Границы окна",subtext="Показать рамку окна",
                       default=False,icon="msg_photo",on_change=self._on_borders),
                Divider(),
                Header(text="Позиция"),
                Switch(key="snap",text="Прилипать к краям",subtext="Окно прилипает к краю экрана",
                       default=True,icon="msg_settings",on_change=self._cb("snap")),
                Switch(key="locked",text="Заблокировать",subtext="Запретить двигать окно",
                       default=False,icon="chats_lock",on_change=self._cb("locked")),
            ]
        elif tab==2:
            mid=[
                Header(text="Поведение"),
                Switch(key="auto_react",text="Реакции на касание",subtext="Случайная эмоция при тапе",
                       default=True,icon="msg_smile",on_change=self._cb("auto_react")),
                Switch(key="idle_quotes",text="Фразы Стеллы",
                       subtext="Показывать фразы каждые 5 мин",
                       default=True,icon="msg_input",on_change=self._on_idle_quotes),
                Switch(key="battery_react",text="Реакция на батарею",
                       subtext="Реагировать на уровень заряда",
                       default=True,icon="msg_battery",on_change=self._on_battery_react),
                Switch(key="sched_react",text="Реакция на время суток",
                       subtext="Приветствия утром и вечером",
                       default=True,icon="msg_schedule",on_change=self._on_sched_react),
                Input(key="idle_speed",text="Скорость анимации (%)",default=str(DEFAULTS["idle_speed"]),
                      icon="msg_settings",on_change=self._ci("idle_speed")),
                Divider(),
                Header(text="Физика"),
                Switch(key="win_physics",text="Физика при переносе окна",
                       subtext="Волосы/грудь реагируют на перетаскивание окна",
                       default=True,icon="msg_settings",on_change=self._cb("win_physics")),
                Input(key="wind_strength",text="Сила ветра (%)",default=str(DEFAULTS["wind_strength"]),
                      subtext="0 — ветра нет",
                      icon="msg_settings",on_change=self._on_wind_strength),
            ]
        elif tab==3:
            mid=[
                Header(text="Поворот модели"),
                Switch(key="rotate_mode",text="Поворот одним пальцем",
                       subtext="Выкл — окно двигается пальцем, как раньше",
                       default=False,icon="msg_settings",on_change=self._on_rotate_mode),
                Text(text="Двумя пальцами — крутить в любом режиме"),
                Input(key="rotate_y",text="Поворот по горизонтали (°)",default="0",
                      icon="msg_settings",on_change=self._ci("rotate_y")),
                Input(key="rotate_x",text="Наклон по вертикали (°)",default="0",
                      icon="msg_settings",on_change=self._ci("rotate_x")),
                Input(key="cam_z",text="Зум (меньше = ближе)",default=str(DEFAULTS["cam_z"]),
                      icon="msg_settings",on_change=self._ci("cam_z")),
                Divider(),
                Header(text="Освещение"),
                Input(key="light_brightness",text="Яркость света (%)",default=str(DEFAULTS["light_brightness"]),
                      icon="msg_settings",on_change=self._ci("light_brightness")),
                Selector(key="light_color_i",text="Цвет света",default=0,
                         items=["Белый","Тёплый","Холодный","Розовый","Мятный"],
                         icon="msg_photo",on_change=self._on_light_color),
                Input(key="skin_brightness",text="Яркость кожи (%)",default=str(DEFAULTS.get("skin_brightness",100)),
                      icon="msg_settings",on_change=self._ci("skin_brightness")),
                Input(key="clothes_brightness",text="Яркость одежды (%)",default=str(DEFAULTS.get("clothes_brightness",100)),
                      icon="msg_settings",on_change=self._ci("clothes_brightness")),
                Input(key="clothes_color",text="Цвет одежды (#RRGGBB)",default=str(DEFAULTS.get("clothes_color","#FFFFFF")),
                      subtext="Любой HEX-цвет, например #3A6EA5",
                      icon="msg_photo",on_change=self._on_clothes_color_hex),
                Input(key="skin_color",text="Цвет кожи (#RRGGBB)",default=str(DEFAULTS.get("skin_color","#FFFFFF")),
                      subtext="Любой HEX-цвет, например #FFDCC2",
                      icon="msg_photo",on_change=self._on_skin_color_hex),
                Divider(),
                Header(text="Волосы"),
                Input(key="hair_brightness",text="Яркость волос (%)",default=str(DEFAULTS.get("hair_brightness",100)),
                      icon="msg_settings",on_change=self._ci("hair_brightness")),
                Input(key="hair_color",text="Цвет волос (#RRGGBB)",default=str(DEFAULTS.get("hair_color","#FFFFFF")),
                      subtext="Любой HEX-цвет, например #7A4FBF",
                      icon="msg_photo",on_change=self._on_hair_color_hex),
                Divider(),
                Header(text="Производительность"),
                Selector(key="target_fps_i",text="Ограничение FPS",default=0,
                         items=["60 (макс. плавность)","30 (баланс)","24 (экономия батареи)"],
                         icon="msg_settings",
                         on_change=lambda i: self._ci("target_fps")([60,30,24][int(i)])),
            ]
        elif tab==4:
            try: _mlist=json.loads(self.gs("model_list") or "[]")
            except Exception: _mlist=[]
            mid=[
                Header(text="Смена модели"),
                Text(text="Загрузить новую модель (.vrm)",icon="msg_link",accent=True,on_click=self._pick_file),
                Text(text="Перезагрузить текущую модель",icon="msg_reset",accent=True,on_click=self._do_reload),
                Divider(),
            ]
            if _mlist:
                mid.append(Header(text="Загруженные модели (нажми, чтобы переключить)"))
                cur=str(self.gs("vrm_url") or "")
                for e in _mlist:
                    u=e.get("url",""); lbl=e.get("label") or (u.split("/")[-1] or u)
                    if len(lbl)>34: lbl=lbl[:31]+"..."
                    mid.append(Text(text=(("Текущая: " if u==cur else "")+lbl),
                                     subtext=u, icon="msg_photo_settings",
                                     on_click=(lambda uu: (lambda v=None: self._switch_model(uu)))(u)))
                mid.append(Divider())
            mid += [
                Header(text="Текстовая команда"),
                Input(key="custom_model_cmd",text="Команда смены модели",
                      default=str(DEFAULTS.get("custom_model_cmd","")),
                      subtext="Отправка этой фразы откроет выбор файла",
                      icon="msg_edit",on_change=self._ci_str("custom_model_cmd")),
            ]
        elif tab==5:
            mid=[
                Header(text="Доп. контент (18+)"),
                Text(text=" Только 18+",
                     subtext="Только для совершеннолетних",
                     icon="msg_info",red=True),
                Text(text="Каталог моделей",icon="msg_link",accent=True,
                     on_click=self._open_mature_catalog),
            ]
        else:
            mid=[
                Header(text="Добро пожаловать"),
                Text(text="Открыть справку",icon="msg_info",accent=True,
                     on_click=self._show_help_dialog,
                     subtext="Разработано при поддержке проекта «Голосовой помощник "
                             "для ПК — Stella». Жесты, все вкладки и функции — полностью "
                             "внутри, без обрезки текста"),
                Divider(),

                Header(text="Статистика"),
                Text(text="Открыть статистику",icon="msg_stats",accent=True,
                     on_click=self._show_stats,
                     subtext="Количество касаний, танцев, сессий и открытые достижения"),
                Divider(),

                Header(text="Разработчики и поддержка"),
                Text(text="@lyzos",icon="msg_openprofile",accent=True,
                     on_click=lambda v: self._open_tg("lyzos")),
                Text(text="@rei_plugins",icon="msg_openprofile",accent=True,
                     on_click=lambda v: self._open_tg("rei_plugins")),
                Text(text="Канал поддержки",icon="msg_channel",accent=True,
                     on_click=lambda v: self._open_url("https://t.me/knice_tech")),
            ]
        return top+mid+bot
