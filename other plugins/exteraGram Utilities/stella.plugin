_HTML = r"""<!DOCTYPE html><html><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:transparent}
#s{display:none;position:fixed;bottom:4px;left:4px;right:4px;text-align:center;
   font:10px monospace;color:#fff;background:rgba(0,0,0,.45);border-radius:4px;
   padding:2px 4px;pointer-events:none;z-index:9999}
#bord{display:none;position:fixed;top:0;left:0;right:0;bottom:0;
   border:2px dashed rgba(255,80,80,.85);border-radius:4px;pointer-events:none;z-index:9998}
#pan-ind{display:none;position:fixed;top:4px;left:50%;transform:translateX(-50%);
   font:11px monospace;color:#fff;background:rgba(0,120,255,.65);border-radius:8px;
   padding:2px 10px;pointer-events:none;z-index:9999}
</style></head><body>
<div id="s">Booting...</div><div id="bord"></div><div id="pan-ind">PAN</div>
<script>
var $s=document.getElementById("s");
function st(t){$s.textContent=t;}
window.onerror=function(m){st("ERR:"+m.substring(0,60));return true;};
window.showBorder=function(v){document.getElementById("bord").style.display=v?"block":"none";};
window.showPanIndicator=function(v){document.getElementById("pan-ind").style.display=v?"block":"none";};
var _pc=0;
function _waitLibs(){
  _pc++;if(_pc>200){st("TIMEOUT");return;}
  if(typeof THREE==="undefined"||typeof THREE_VRM==="undefined"){
    st("wait libs("+_pc+")...");setTimeout(_waitLibs,300);return;}
  if(typeof THREE.GLTFLoader==="undefined"){
    st("wait gltf("+_pc+")...");setTimeout(_waitLibs,300);return;}
  _init();
}
setTimeout(_waitLibs,200);
var renderer,scene,cam,vrm=null,clk,idleT=0,_spd=1.0,loader;
var dl,amb,hemi,dlFill,dlRim;
var _pitchX=0;
var _targetFPS=60,_frameInterval=1000/60,_lastFrameT=0;
var lkTX=0,lkTY=0,lkCX=0,lkCY=0,lkCT=0;
var brT=0,_camZ=3.5,_rest={},_bones={},_expressions=[];
var ALL_BONES=["hips","spine","chest","upperChest","neck","head",
  "leftShoulder","leftUpperArm","leftLowerArm","leftHand",
  "leftThumbProximal","leftThumbIntermediate","leftThumbDistal",
  "leftIndexProximal","leftIndexIntermediate","leftIndexDistal",
  "leftMiddleProximal","leftMiddleIntermediate","leftMiddleDistal",
  "leftRingProximal","leftRingIntermediate","leftRingDistal",
  "leftLittleProximal","leftLittleIntermediate","leftLittleDistal",
  "rightShoulder","rightUpperArm","rightLowerArm","rightHand",
  "rightThumbProximal","rightThumbIntermediate","rightThumbDistal",
  "rightIndexProximal","rightIndexIntermediate","rightIndexDistal",
  "rightMiddleProximal","rightMiddleIntermediate","rightMiddleDistal",
  "rightRingProximal","rightRingIntermediate","rightRingDistal",
  "rightLittleProximal","rightLittleIntermediate","rightLittleDistal",
  "leftUpperLeg","leftLowerLeg","leftFoot","rightUpperLeg","rightLowerLeg","rightFoot"];
var SKIP_A=["blink","blinkLeft","blinkRight","lookUp","lookDown","lookLeft","lookRight"];
var REST_L=["hips","spine","chest","upperChest","neck","head",
  "leftShoulder","leftUpperArm","leftLowerArm","leftHand",
  "rightShoulder","rightUpperArm","rightLowerArm","rightHand",
  "leftUpperLeg","rightUpperLeg","leftLowerLeg","rightLowerLeg","leftFoot","rightFoot"];
function _init(){
  var W=window.innerWidth,H=window.innerHeight,dpr=window.devicePixelRatio||1;
  renderer=new THREE.WebGLRenderer({antialias:true,alpha:true,powerPreference:"high-performance"});
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setSize(W,H);renderer.setClearColor(0,0);
  renderer.shadowMap.enabled=true;
  renderer.shadowMap.type=THREE.PCFSoftShadowMap;
  try{
    renderer.outputEncoding=THREE.sRGBEncoding;
    renderer.toneMapping=THREE.LinearToneMapping;
    renderer.toneMappingExposure=1.0; // LinearToneMapping быстрее ACES
  }catch(e){}
  document.body.appendChild(renderer.domElement);
  scene=new THREE.Scene();
  cam=new THREE.PerspectiveCamera(28,W/H,0.01,100);
  cam.position.set(0,0.78,_camZ);cam.lookAt(0,0.78,0);
  dl=new THREE.DirectionalLight(0xfff4e6,0.95);dl.position.set(1,2.2,1.6);
  dl.castShadow=true; dl.shadow.mapSize.set(1024,1024);
  dl.shadow.camera.near=0.1; dl.shadow.camera.far=6;
  dl.shadow.camera.left=-1;dl.shadow.camera.right=1;dl.shadow.camera.top=1;dl.shadow.camera.bottom=-1;
  scene.add(dl);
  dlFill=new THREE.DirectionalLight(0xcfe8ff,0.12);dlFill.position.set(-1.4,0.6,0.8);scene.add(dlFill);
  dlRim=new THREE.DirectionalLight(0xffffff,0.15);dlRim.position.set(-0.3,1.4,-1.8);scene.add(dlRim);
  amb=new THREE.AmbientLight(0xffffff,0.12);scene.add(amb);
  hemi=new THREE.HemisphereLight(0xb1e4ff,0xffe0b2,0.35);scene.add(hemi);
  clk=new THREE.Clock();
  loader=new THREE.GLTFLoader();
  loader.register(function(p){return new THREE_VRM.VRMLoaderPlugin(p);});
  _buildEnvMap();
  st("Ready");_anim();
}
// ── Простая процедурная environment-карта через PMREMGenerator, без
// внешних зависимостей (RoomEnvironment из examples/jsm недоступен в r128 UMD).
function _buildEnvMap(){
  try{
    var pmrem=new THREE.PMREMGenerator(renderer);
    pmrem.compileEquirectangularShader();
    var envScene=new THREE.Scene();
    var top=new THREE.PointLight(0xffffff,6,10);top.position.set(0,3,1);envScene.add(top);
    var side=new THREE.PointLight(0xbcd8ff,3,10);side.position.set(-2,1,2);envScene.add(side);
    var geo=new THREE.SphereGeometry(1,16,16);
    var mat=new THREE.MeshStandardMaterial({color:0x888899,side:THREE.BackSide});
    envScene.add(new THREE.Mesh(geo,mat));
    scene.environment=pmrem.fromScene(envScene,0.02).texture;
    pmrem.dispose();
  }catch(e){}
}
function _nb(n){
  try{var b=vrm.humanoid.getNormalizedBoneNode(n);if(b)return b;}catch(e){}
  try{return vrm.humanoid.getRawBoneNode(n);}catch(e){}return null;
}
function _disc(v){
  _expressions=[];_bones={};
  try{
    var em=v.expressionManager,seen={};
    if(em&&em.expressionMap)Object.keys(em.expressionMap).forEach(function(k){
      if(!seen[k]){seen[k]=1;_expressions.push(k);}
    });
  }catch(e){}
  ALL_BONES.forEach(function(b){
    try{var nd=v.humanoid.getNormalizedBoneNode(b);if(!nd)nd=v.humanoid.getRawBoneNode(b);if(nd)_bones[b]=true;}catch(e){}
  });
}
function _stR(v){
  _rest={};
  REST_L.forEach(function(n){
    try{var b=v.humanoid.getNormalizedBoneNode(n);if(!b)b=v.humanoid.getRawBoneNode(n);
      if(b)_rest[n]={x:b.rotation.x,y:b.rotation.y,z:b.rotation.z};}catch(e){}
  });
  [["leftUpperArm", 0.08,0, 1.15],["rightUpperArm", 0.08,0,-1.15],
   ["leftLowerArm", 0.12,0,-0.06],["rightLowerArm", 0.12,0, 0.06],
   ["leftHand", -0.06,0, 0.04],["rightHand", -0.06,0,-0.04]].forEach(function(f){
    try{var b=v.humanoid.getNormalizedBoneNode(f[0]);if(!b)b=v.humanoid.getRawBoneNode(f[0]);
      if(b){b.rotation.x=f[1];b.rotation.y=f[2];b.rotation.z=f[3];_rest[f[0]]={x:f[1],y:f[2],z:f[3]};}}catch(e){}
  });
}
function _ab(n,dx,dy,dz){
  if(!_bones[n])return;var r=_rest[n];if(!r)return;var b=_nb(n);if(!b)return;
  b.rotation.x=r.x+(dx||0);b.rotation.y=r.y+(dy||0);b.rotation.z=r.z+(dz||0);
}
var _vrmCache={}; var _vrmCacheOrder=[]; var _VRM_CACHE_MAX=10;
function _cacheTouch(url){
  var i=_vrmCacheOrder.indexOf(url);
  if(i>-1)_vrmCacheOrder.splice(i,1);
  _vrmCacheOrder.push(url);
  while(_vrmCacheOrder.length>_VRM_CACHE_MAX){
    var old=_vrmCacheOrder.shift();
    if(old!==url&&_vrmCache[old]){
      try{ if(_vrmCache[old].scene.parent) scene.remove(_vrmCache[old].scene); THREE_VRM.VRMUtils.deepDispose(_vrmCache[old].scene);}catch(e){}
      delete _vrmCache[old];
    }
  }
}
window.getCachedModels=function(){return JSON.stringify(Object.keys(_vrmCache));};
window.loadVRM=function(url){
  if(!loader){st("not init");return;}
  if(vrm&&vrm.scene&&vrm.scene.parent) scene.remove(vrm.scene);
  try{if(_mixer)_mixer.stopAllAction();}catch(e){}
  _mixer=null;_baseAction=null;_vrmaAction=null;_vrmaPlaying=false;_baseLoading=false;
  if(_vrmCache[url]){
    vrm=_vrmCache[url];_cacheTouch(url);
    scene.add(vrm.scene);_rest={};_bones={};_expressions=[];
    _disc(vrm);_stR(vrm);idleT=0;lkCT=0;_classifyMaterials(vrm);
    if(_baseUrl) window.loadBaseAnim(_baseUrl);
    st("VRM OK(cache)|expr:"+_expressions.filter(function(e){return SKIP_A.indexOf(e)<0;}).length+"|bones:"+Object.keys(_bones).length);
    return;
  }
  st("Loading...");
  loader.load(url,
    function(g){
      var nv=g.userData.vrm;try{THREE_VRM.VRMUtils.rotateVRM0(nv);}catch(e){}
      nv.scene.traverse(function(o){o.frustumCulled=false;if(o.isMesh){o.castShadow=true;o.receiveShadow=true;}});
      var _isV0=true;
      try{ var mv=nv.meta&&(nv.meta.metaVersion||nv.meta.specVersion); if(mv&&String(mv).indexOf("1")===0) _isV0=false; }catch(e){}
      nv.scene.rotation.y=_isV0?Math.PI:0;
      _vrmCache[url]=nv;_cacheTouch(url);
      if(!_vrmCache[url])return;
      vrm=nv;_rest={};_bones={};_expressions=[];
      scene.add(vrm.scene);
      _disc(vrm);_stR(vrm);idleT=0;lkCT=0;_classifyMaterials(vrm);
      if(_baseUrl) window.loadBaseAnim(_baseUrl);
st("VRM OK|expr:"+_expressions.filter(function(e){return SKIP_A.indexOf(e)<0;}).length+"|bones:"+Object.keys(_bones).length);
    },
    function(x){if(x.total>0)st(Math.round(x.loaded/x.total*100)+"%");},
    function(e){st("ERR:"+((e&&e.message)||String(e)));}
  );
};
var _skinMats=[],_clothMats=[],_hairMats=[],_matBase={};
var SKIN_KEYWORDS=["skin","body","face","hand","finger","foot","leg","arm","ear","head","neck"];
var HAIR_KEYWORDS=["hair","fringe","bangs","ahoge","ponytail"];
var EXCLUDE_KEYWORDS=["eye","brow","lash","iris","pupil","sclera","cornea","tooth","tongue","nail"];
var _matSettings={skinB:100,clothB:100,hairB:100,skinC:null,clothC:null,hairC:null};
function _isOutlineMat(m,name){
  if(name.indexOf("outline")>-1)return true;
  if(m.side===THREE.BackSide)return true;
  return false;
}
function _classifyMaterials(v){
  _skinMats=[];_clothMats=[];_hairMats=[];_matBase={};
  if(!v||!v.scene)return;
  var seen={};
  var maxAniso=1;
  try{maxAniso=renderer.capabilities.getMaxAnisotropy()||1;}catch(e){}
  v.scene.traverse(function(o){
    if(!o.material)return;
    var mats=Array.isArray(o.material)?o.material:[o.material];
    mats.forEach(function(m){
      if(!m||seen[m.uuid])return; seen[m.uuid]=true;
      // Анизотропная фильтрация — текстуры волос/одежды остаются чёткими
      // на скользящих углах обзора вместо размытия.
      try{
        ["map","normalMap","roughnessMap","metalnessMap","emissiveMap"].forEach(function(tk){
          if(m[tk]&&m[tk].isTexture) m[tk].anisotropy=maxAniso;
        });
      }catch(e){}
      var name=((m.name||"")+" "+(o.name||"")).toLowerCase();
      if(_isOutlineMat(m,name))return;
      if(EXCLUDE_KEYWORDS.some(function(k){return name.indexOf(k)>-1;}))return;
      var isHair=HAIR_KEYWORDS.some(function(k){return name.indexOf(k)>-1;});
      var isSkin=!isHair&&SKIN_KEYWORDS.some(function(k){return name.indexOf(k)>-1;});
      var base=m.color?{r:m.color.r,g:m.color.g,b:m.color.b}:{r:1,g:1,b:1};
      _matBase[m.uuid]=base;
      if(isHair)_hairMats.push(m); else if(isSkin)_skinMats.push(m); else _clothMats.push(m);
    });
  });
  _applyMatSettings();
}
function _applyMatSettings(){
  window.setSkinBrightness(_matSettings.skinB);
  window.setClothesBrightness(_matSettings.clothB);
  window.setHairBrightness(_matSettings.hairB);
  if(_matSettings.skinC) window.setSkinColor(_matSettings.skinC);
  if(_matSettings.clothC) window.setClothesColor(_matSettings.clothC);
  if(_matSettings.hairC) window.setHairColor(_matSettings.hairC);
}
window.setClothesBrightness=function(v){
  _matSettings.clothB=v;
  var f=Math.max(0,Math.min(1.6,(v||100)/100));
  _clothMats.forEach(function(m){
    var b=_matBase[m.uuid]; if(!b||!m.color)return;
    m.color.setRGB(b.r*f,b.g*f,b.b*f);
  });
};
window.setClothesColor=function(hex){
  _matSettings.clothC=hex;
  try{
    var c=new THREE.Color(hex);
    _clothMats.forEach(function(m){ if(m.color) m.color.copy(c); });
  }catch(e){}
};
window.setSkinBrightness=function(v){
  _matSettings.skinB=v;
  var f=Math.max(0,Math.min(1.6,(v||100)/100));
  _skinMats.forEach(function(m){
    var b=_matBase[m.uuid]; if(!b||!m.color)return;
    m.color.setRGB(b.r*f,b.g*f,b.b*f);
  });
};
window.setSkinColor=function(hex){
  _matSettings.skinC=hex;
  try{
    var c=new THREE.Color(hex);
    _skinMats.forEach(function(m){ if(m.color) m.color.copy(c); });
  }catch(e){}
};
window.setHairBrightness=function(v){
  _matSettings.hairB=v;
  var f=Math.max(0,Math.min(1.6,(v||100)/100));
  _hairMats.forEach(function(m){
    var b=_matBase[m.uuid]; if(!b||!m.color)return;
    m.color.setRGB(b.r*f,b.g*f,b.b*f);
  });
};
window.setHairColor=function(hex){
  _matSettings.hairC=hex;
  try{
    var c=new THREE.Color(hex);
    _hairMats.forEach(function(m){ if(m.color) m.color.copy(c); });
  }catch(e){}
};
window.getExpressions=function(){return JSON.stringify(_expressions);};
window.zoomCam=function(f){_camZ=Math.max(1,Math.min(8,_camZ*f));if(cam)cam.position.z=_camZ;};
window.setCamZ=function(z){_camZ=Math.max(1,Math.min(8,z));if(cam)cam.position.z=_camZ;};
window.rotateModel=function(r){if(vrm)vrm.scene.rotation.y+=r;};
window.rotateModelX=function(r){
  if(!vrm)return;
  _pitchX=Math.max(-0.9,Math.min(0.9,_pitchX+r));
  vrm.scene.rotation.x=_pitchX;
};
window.setRotationY=function(deg){if(vrm)vrm.scene.rotation.y=deg*Math.PI/180;};
window.setRotationX=function(deg){
  if(!vrm)return;
  _pitchX=Math.max(-0.9,Math.min(0.9,deg*Math.PI/180));
  vrm.scene.rotation.x=_pitchX;
};
window.getRotation=function(){
  if(!vrm)return JSON.stringify({y:0,x:0});
  return JSON.stringify({y:vrm.scene.rotation.y*180/Math.PI,x:_pitchX*180/Math.PI});
};

// ── Режим взаимодействия синхронизируется из Python при старте и смене настроек
var _rotateModeOn=false,_panModeOn=false;
window.setInteractionMode=function(rot,pan){_rotateModeOn=!!rot;_panModeOn=!!pan;};

// ── Нативные тач-жесты: вращение, пинч-зум и pan теперь полностью в JS,
// без ежекадрового evaluateJavascript из Python (устранение лагов).
var _tp1=null,_tPinchDist=1,_tPinchAngle=0,_tAvgY=0,_tGestureActive=false;
function _distAngle(t0,t1){
  var dx=t1.clientX-t0.clientX,dy=t1.clientY-t0.clientY;
  return {d:Math.max(Math.sqrt(dx*dx+dy*dy),1.0),a:Math.atan2(dy,dx),ay:(t0.clientY+t1.clientY)/2};
}
document.addEventListener("touchstart",function(e){
  if(e.touches.length>=2){
    var da=_distAngle(e.touches[0],e.touches[1]);
    _tPinchDist=da.d;_tPinchAngle=da.a;_tAvgY=da.ay;_tGestureActive=true;
    e.preventDefault();
  }else if(e.touches.length===1&&(_rotateModeOn||_panModeOn)){
    _tp1={x:e.touches[0].clientX,y:e.touches[0].clientY};_tGestureActive=true;
  }
},{passive:false});
document.addEventListener("touchmove",function(e){
  if(!_tGestureActive)return;
  if(e.touches.length>=2){
    var da=_distAngle(e.touches[0],e.touches[1]);
    var f=da.d/_tPinchDist;
    if(Math.abs(f-1.0)>0.006){zoomCam(1.0/Math.max(f,0.01));_tPinchDist=da.d;}
    var ddeg=da.a-_tPinchAngle;
    while(ddeg>Math.PI)ddeg-=2*Math.PI; while(ddeg<-Math.PI)ddeg+=2*Math.PI;
    if(Math.abs(ddeg)>0.015){rotateModel(ddeg*0.55);_tPinchAngle=da.a;}
    var dy=da.ay-_tAvgY;
    if(Math.abs(dy)>2)rotateModelX(-dy*0.0022);
    _tAvgY=da.ay; e.preventDefault();
  }else if(e.touches.length===1&&_tp1){
    var t=e.touches[0],dx=t.clientX-_tp1.x,dy=t.clientY-_tp1.y;
    if(_rotateModeOn){rotateModel(dx*0.006);rotateModelX(-dy*0.004);}
    else if(_panModeOn){panModel(dx,dy);}
    _tp1={x:t.clientX,y:t.clientY}; e.preventDefault();
  }
},{passive:false});
document.addEventListener("touchend",function(e){
  if(e.touches.length===0){_tp1=null;_tGestureActive=false;}
  else if(e.touches.length<2)_tGestureActive=false;
},{passive:false});
document.addEventListener("touchcancel",function(){_tp1=null;_tGestureActive=false;},{passive:false});
window.setLightBrightness=function(v){
  var f=Math.max(0.05,Math.min(2.5,(v||100)/100));
  if(dl)dl.intensity=1.1*f;
  if(amb)amb.intensity=0.12*Math.min(1,f);
  if(hemi)hemi.intensity=0.35*Math.min(1,f);
  if(dlFill)dlFill.intensity=0.12*Math.min(1,f);
  if(dlRim)dlRim.intensity=0.15*Math.min(1,f);
};
window.setLightColor=function(hex){
  try{ if(dl)dl.color.set(hex); }catch(e){}
};
window.setTargetFPS=function(f){
  _targetFPS=Math.max(10,Math.min(60,f||30)); _frameInterval=1000/_targetFPS;
};
var _panX=0,_panY=0;
window.panModel=function(dx,dy){
  if(!vrm||!cam)return;
  var ww=2*Math.tan(14*Math.PI/180)*_camZ,wh=ww*(window.innerHeight/window.innerWidth);
  _panX+=dx/window.innerWidth*ww*0.18;_panY-=dy/window.innerHeight*wh*0.18;
};
window.hitTest=function(x,y){
  try{
    var px=new Uint8Array(4);
    var ctx2=renderer.getContext();
    renderer.render(scene,cam);
    ctx2.readPixels(x,renderer.domElement.height-y,1,1,ctx2.RGBA,ctx2.UNSIGNED_BYTE,px);
    return px[3]>10;
  }catch(e){return true;}
};
window.resetPan=function(){_panX=0;_panY=0;};
window.setSpd=function(s){_spd=Math.max(0.01,s);};

// ── Физика окна: когда пользователь тащит само окно (не модель), содержимое
// сцены раньше вообще не получало никакого сигнала об этом движении, из-за
// чего волосы/грудь (VRM spring-bone chains) оставались неподвижными.
// Каждый шаг перетаскивания окна теперь толкает модель маленьким импульсом,
// который сам сцену не смещает навсегда, а пружинно гасится — этого
// достаточно, чтобы встроенная физика VRM (springBoneManager) увидела
// движение суставов и отреагировала покачиванием.
var _winKick={x:0,y:0,vx:0,vy:0};
window.applyWindowKick=function(dx,dy){
  if(!vrm)return;
  _winKick.vx+=(dx||0)*0.0038;
  _winKick.vy+=(-(dy||0))*0.0038;
  var mx=0.55; _winKick.vx=Math.max(-mx,Math.min(mx,_winKick.vx));
  _winKick.vy=Math.max(-mx,Math.min(mx,_winKick.vy));
};
function _updateWinKick(dt){
  if(!vrm)return;
  var k=55,d=6;
  _winKick.vx+=(-k*_winKick.x)*dt; _winKick.vx*=(1-Math.min(1,d*dt));
  _winKick.x+=_winKick.vx*dt;
  _winKick.vy+=(-k*_winKick.y)*dt; _winKick.vy*=(1-Math.min(1,d*dt));
  _winKick.y+=_winKick.vy*dt;
}

// ── Ветер: непрерывное лёгкое покачивание, сила регулируется в настройках.
// Работает через тот же механизм — плавно сдвигает корень модели шумом,
// от чего волосы/грудь через встроенную физику VRM тоже колышутся.
var _windStrength=0,_windT=0;
window.setWindStrength=function(v){_windStrength=Math.max(0,Math.min(100,v||0))/100.0;};
function _updateWind(dt){
  if(_windStrength<=0||!vrm)return;
  _windT+=dt;
  var s=_windStrength;
  _winKick.vx+=_ns(_windT,0.7)*s*0.9*dt;
  _winKick.vy+=_ns(_windT*1.3,0.55)*s*0.5*dt*0.5;
  try{
    var b=vrm.humanoid&&vrm.humanoid.getNormalizedBoneNode("chest");
    if(b) b.rotation.z=(b.rotation.z||0)*0.9+_ns(_windT,0.6)*s*0.05*0.1;
  }catch(e){}
}

function _ns(t,f){return Math.sin(t*f)*0.55+Math.sin(t*f*2.17+1.3)*0.3+Math.sin(t*f*5.37+2.9)*0.15;}
function _nsL(t,f,l){return _ns(t,f)*l;}

var _lk={tx:0,ty:0,cx:0,cy:0,ct:0};
var _sw={v:0,tv:0,ct:0};
var _brPhase=0;
var _WMP=0.628, _WMS=1.25;

function _anim(){
  requestAnimationFrame(_anim);if(!renderer)return;
  var _now=(window.performance&&performance.now)?performance.now():Date.now();
  if(_now-_lastFrameT<_frameInterval)return;
  _lastFrameT=_now;
  var dt=clk?Math.min(clk.getDelta(),0.025):0.016; // clamp: стабильный spring bone
  if(!vrm||Object.keys(_rest).length===0){renderer.render(scene,cam);return;}
  if(_mixer) _mixer.update(dt);
  _updateWind(dt);
  _updateWinKick(dt);
  if(!_shake.active){
    vrm.scene.position.x=_panX+_winKick.x;
    vrm.scene.position.y=_panY+_winKick.y;
  }
  if(_mixer&&(_baseAction||_vrmaPlaying)){
    vrm.update(dt);renderer.render(scene,cam);return;
  }
  var t=idleT; idleT+=dt*_spd; _brPhase+=dt*_spd;
  var bp=_brPhase;

  var br=Math.sin(bp*1.1)*0.014*_WMS;
  var br2=Math.sin(bp*1.1+0.35)*0.008*_WMS;
  var br3=Math.sin(bp*1.1+0.65)*0.005*_WMS;

  _sw.ct-=dt;
  if(_sw.ct<=0){_sw.tv=(_ns(t,0.07)-0.5)*0.022*_WMS;_sw.ct=3+Math.random()*4;}
  _sw.v+=(_sw.tv-_sw.v)*dt*0.9;
  var sw=_sw.v;

  _lk.ct-=dt;
  if(_lk.ct<=0){
    var mag=Math.random()<0.7?0.12:0.25;
    _lk.tx=(Math.random()-0.5)*mag;
    _lk.ty=(Math.random()-0.5)*mag*0.6+(Math.random()<0.1?0.06:0);
    _lk.ct=2+Math.random()*4;
  }
  _lk.cx+=(_lk.tx-_lk.cx)*Math.min(1,dt*1.8);
  _lk.cy+=(_lk.ty-_lk.cy)*Math.min(1,dt*1.8);

  var hipR=_ns(t,_WMP*0.18)*0.007*_WMS;
  _ab("hips", br*0.4, sw*0.35+hipR, sw*0.55+_ns(t,_WMP*0.22)*0.007*_WMS);
  _ab("spine", br*0.85+_ns(t,_WMP*0.19)*0.006*_WMS, -sw*0.28, sw*0.32);
  _ab("chest", br2+_ns(t,_WMP*0.21)*0.005*_WMS, -sw*0.14, sw*0.18);
  _ab("upperChest", br3, -sw*0.07, sw*0.1);

  _ab("neck", _lk.cy*0.38+br*0.28+_ns(t,_WMP*0.27)*0.006, _lk.cx*0.38, _ns(t,_WMP*0.25)*0.007);
  _ab("head", _lk.cy*0.62+_ns(t,_WMP*0.33)*0.009, _lk.cx*0.62, _ns(t,_WMP*0.38)*0.006);

  _ab("leftShoulder", br2*0.5+_ns(t,_WMP*0.31)*0.01, -sw*0.25, _ns(t,_WMP*0.28)*0.012*_WMS);
  _ab("rightShoulder", br2*0.5+_ns(t,_WMP*0.31)*0.01, sw*0.25, _ns(t,_WMP*0.28)*0.012*_WMS);

  var laFw=_ns(t+0.0, _WMP*0.29)*0.065*_WMS;
  var laSw=_ns(t+0.0, _WMP*0.37)*0.045*_WMS;
  var laTw=_ns(t+0.0, _WMP*0.43)*0.035*_WMS;
  _ab("leftUpperArm", laFw+br2*0.55, laTw, laSw*0.4);
  _ab("leftLowerArm", _ns(t+0.0,_WMP*0.52)*0.055+0.06, _ns(t+0.0,_WMP*0.41)*0.025, _ns(t+0.0,_WMP*0.35)*0.04);
  _ab("leftHand", _ns(t+0.0,_WMP*0.71)*0.04, _ns(t+0.0,_WMP*0.58)*0.035, _ns(t+0.0,_WMP*0.67)*0.025);

  var raFw=_ns(t+1.57,_WMP*0.29)*0.065*_WMS;
  var raSw=_ns(t+1.57,_WMP*0.37)*0.045*_WMS;
  var raTw=_ns(t+1.57,_WMP*0.43)*0.035*_WMS;
  _ab("rightUpperArm", raFw+br2*0.55, -raTw, raSw*0.4);
  _ab("rightLowerArm", _ns(t+1.57,_WMP*0.52)*0.055+0.06,-_ns(t+1.57,_WMP*0.41)*0.025, _ns(t+1.57,_WMP*0.35)*0.04);
  _ab("rightHand", _ns(t+1.57,_WMP*0.71)*0.04,-_ns(t+1.57,_WMP*0.58)*0.035, _ns(t+1.57,_WMP*0.67)*0.025);

  var fb=0.16;
  ["left","right"].forEach(function(s,si){
    var ph=si*1.57;
    _ab(s+"ThumbProximal", _ns(t+ph,_WMP*0.6)*0.035, _ns(t+ph,_WMP*0.5)*0.04, fb*0.35+_ns(t+ph,_WMP*0.75)*0.025);
    _ab(s+"ThumbIntermediate", _ns(t+ph,_WMP*0.7)*0.025, 0, fb*0.25+_ns(t+ph,_WMP*0.85)*0.018);
    _ab(s+"ThumbDistal", _ns(t+ph,_WMP*0.8)*0.018, 0, fb*0.18);
    [["Index",0.0],["Middle",0.35],["Ring",0.7],["Little",1.05]].forEach(function(fp){
      var fn=fp[0],fo=fp[1];
      _ab(s+fn+"Proximal", _ns(t+ph+fo,_WMP*0.55)*0.022, 0, fb+_ns(t+ph+fo,_WMP*0.72)*0.022);
      _ab(s+fn+"Intermediate", _ns(t+ph+fo,_WMP*0.62)*0.018, 0, fb*1.15+_ns(t+ph+fo,_WMP*0.78)*0.016);
      _ab(s+fn+"Distal", _ns(t+ph+fo,_WMP*0.68)*0.012, 0, fb*0.95+_ns(t+ph+fo,_WMP*0.82)*0.012);
    });
  });

  var legW=Math.sin(t*_WMP*0.17)*0.014*_WMS;
  _ab("leftUpperLeg", legW*0.5+br*0.18, sw*0.12, legW);
  _ab("rightUpperLeg",-legW*0.5+br*0.18, -sw*0.12, -legW);
  _ab("leftLowerLeg", Math.max(0,legW)*0.07, 0, 0);
  _ab("rightLowerLeg", Math.max(0,-legW)*0.07, 0, 0);
  _ab("leftFoot", _ns(t,_WMP*0.23)*0.009, 0, 0);
  _ab("rightFoot", _ns(t+1.0,_WMP*0.23)*0.009, 0, 0);


  _animExtras(dt, br||0);
  vrm.update(Math.min(dt,0.016));renderer.render(scene,cam);
}
var _danceT=0;
window.startDance=function(dur){_danceT=dur||30;if(vrm)vrm.scene.position.y=0;};
window.stopDance=function(){_danceT=0;if(vrm)vrm.scene.position.y=0;};

var _mixer=null,_vrmaAction=null,_baseAction=null,_vrmaLoader=null;
var _vrmaPlaying=false,_vrmaLoop=false;
var _clipCache={};
var _FADE=0.5;
var _baseUrl=null;
var _baseLoading=false;
var _baseRetryT=null;

window.loadBaseAnim=function(url){
  _baseUrl=url;_baseLoading=true;
  _initVrmaLoader();
  if(!_vrmaLoader){_baseLoading=false;_scheduleBaseRetry();return;}
  if(_clipCache[url]){
    if(!vrm){_baseLoading=false;return;}
    if(!_mixer) _mixer=new THREE.AnimationMixer(vrm.scene);
    _baseAction=_mixer.clipAction(_clipCache[url]);
    _baseAction.setLoop(THREE.LoopRepeat,Infinity);
    _baseAction.play();
    _baseLoading=false;
    st("BASE_OK");
    return;
  }
  _vrmaLoader.load(url,function(g){
    try{
      if(!vrm){_baseLoading=false;return;}
      var VRMA=window.THREE_VRM_ANIMATION||window.THREE_VRM_A;
      var clip=VRMA.createVRMAnimationClip(g.userData.vrmAnimations[0],vrm);
      _clipCache[url]=clip;
      if(!_mixer) _mixer=new THREE.AnimationMixer(vrm.scene);
      _baseAction=_mixer.clipAction(clip);
      _baseAction.setLoop(THREE.LoopRepeat,Infinity);
      _baseAction.play();
      _baseLoading=false;
      st("BASE_OK");
    }catch(e){_baseLoading=false;st("base err:"+e.message);_scheduleBaseRetry();}
  },null,function(e){_baseLoading=false;st("base load err:"+String(e));_scheduleBaseRetry();});
};
function _scheduleBaseRetry(){
  if(_baseRetryT)clearTimeout(_baseRetryT);
  if(!_baseUrl)return;
  _baseRetryT=setTimeout(function(){if(!_baseAction&&_baseUrl)window.loadBaseAnim(_baseUrl);},4000);
}

function _initVrmaLoader(){
  if(_vrmaLoader)return;
  try{
    var VRMA=window.THREE_VRM_ANIMATION||window.THREE_VRM_A||null;
    if(!VRMA){st("vrma lib not loaded");return;}
    _vrmaLoader=new THREE.GLTFLoader();
    _vrmaLoader.register(function(p){return new THREE_VRM.VRMLoaderPlugin(p);});
    if(VRMA.VRMAnimationLoaderPlugin){
      _vrmaLoader.register(function(p){return new VRMA.VRMAnimationLoaderPlugin(p);});
    }
  }catch(e){st("vrma loader err: "+e.message);}
}

function _playClip(clip, loop){
  if(!vrm||!clip)return;
  if(!_mixer) _mixer=new THREE.AnimationMixer(vrm.scene);
  var newAction=_mixer.clipAction(clip);
  if(newAction===_vrmaAction && _vrmaPlaying) return;
  newAction.setLoop(loop?THREE.LoopRepeat:THREE.LoopOnce,Infinity);
  newAction.clampWhenFinished=!loop;
  newAction.reset(); newAction.play();
  if(_vrmaAction && _vrmaAction!==newAction && _vrmaAction!==_baseAction){
    _vrmaAction.crossFadeTo(newAction,_FADE,true);
  } else if(_baseAction && _baseAction!==newAction){
    _baseAction.crossFadeTo(newAction,_FADE,true);
  }
  _vrmaAction=newAction; _vrmaLoop=!!loop; _vrmaPlaying=true;
  _mixer.removeEventListener("finished",_mixer._stellaCb||function(){});
  _mixer._stellaCb=function(e){
    if(e.action===_vrmaAction){
      _vrmaPlaying=false;
      if(_baseAction){
        _baseAction.reset(); _baseAction.play();
        newAction.crossFadeTo(_baseAction,_FADE,true);
      }else{
        newAction.setLoop(THREE.LoopRepeat,Infinity);
        newAction.clampWhenFinished=false;
        newAction.reset(); newAction.play();
        _vrmaPlaying=true;
        if(_baseUrl&&!_baseLoading) window.loadBaseAnim(_baseUrl);
      }
      st("VRMA_END");
    }
  };
  _mixer.addEventListener("finished",_mixer._stellaCb);
  st("VRMA_OK|dur:"+clip.duration.toFixed(1)+(loop?"|loop":""));
}

window.playVrma=function(url, loop){
  if(!vrm){st("no vrm");return;}
  _initVrmaLoader();
  if(!_vrmaLoader){st("no vrma loader");return;}
  if(_clipCache[url]){ _playClip(_clipCache[url],loop); return; }
  st("Loading anim...");
  _vrmaLoader.load(url,
    function(g){
      try{
        var VRMA=window.THREE_VRM_ANIMATION||window.THREE_VRM_A;
        var clip=VRMA.createVRMAnimationClip(g.userData.vrmAnimations[0],vrm);
        _clipCache[url]=clip;
        _playClip(clip,loop);
      }catch(e){st("vrma play err: "+e.message);}
    },
    null,
    function(e){st("vrma load err: "+(e.message||String(e)));}
  );
};

window.stopVrma=function(){
  if(!_vrmaPlaying)return;
  _vrmaPlaying=false;
  if(_baseAction && _vrmaAction && _vrmaAction!==_baseAction){
    _baseAction.reset(); _baseAction.play();
    _vrmaAction.crossFadeTo(_baseAction,_FADE,true);
    _vrmaAction=_baseAction;
  } else if(_baseAction){
    _baseAction.reset(); _baseAction.play();
    _vrmaAction=_baseAction;
  } else if(_mixer){
    _mixer.stopAllAction();
    _vrmaAction=null;
    if(_baseUrl&&!_baseLoading) window.loadBaseAnim(_baseUrl);
  }
};

var _outlineEnabled = false;
var _bloomEnabled = false;

window.setOutline = function(enabled, color, width) {
  _outlineEnabled = !!enabled;
  if(!vrm) return;
  try {
    vrm.scene.traverse(function(obj) {
      if(obj.material) {
        if(Array.isArray(obj.material)) {
          obj.material.forEach(function(m) {
            if(m.outlineColorFactor !== undefined) {
              m.outlineWidthMode = enabled ? 'worldCoordinates' : 'none';
            }
          });
        } else if(obj.material.outlineColorFactor !== undefined) {
          obj.material.outlineWidthMode = enabled ? 'worldCoordinates' : 'none';
        }
      }
    });
  } catch(e) {}
};

var _lookAtTarget = null;
window.setLookAtTarget = function(x, y) {
  _lookAtTarget = {x: x, y: y};
};
window.clearLookAt = function() {
  _lookAtTarget = null;
};

var _targetFov = 26;
window.zoomCam = function(factor) {
  _targetFov = Math.max(10, Math.min(60, cam.fov * factor));
};
function _updateFov(dt) {
  if(!cam) return;
  var diff = _targetFov - cam.fov;
  if(Math.abs(diff) > 0.05) {
    cam.fov += diff * Math.min(1, dt * 6);
    cam.updateProjectionMatrix();
  }
}

var _shake = {active: false, t: 0, strength: 0};
window.shake = function(strength, duration) {
  _shake.active = true;
  _shake.t = duration || 0.3;
  _shake.strength = strength || 0.015;
};
function _applyShake(dt) {
  if(!_shake.active || !vrm) return;
  _shake.t -= dt;
  if(_shake.t <= 0) {
    _shake.active = false;
    vrm.scene.position.x = _panX+_winKick.x;
    vrm.scene.position.z = 0;
    return;
  }
  vrm.scene.position.x = (Math.random()-0.5) * _shake.strength;
  vrm.scene.position.z = (Math.random()-0.5) * _shake.strength * 0.5;
}

var _breathScale = true;
window.setBreathScale = function(v) { _breathScale = !!v; };
function _applyBreathScale(br) {
  if(!_breathScale || !vrm) return;
  var s = 1 + br * 0.003;
  vrm.scene.scale.set(s, s, s);
}

var _autoRotate = false;
var _rotateSpeed = 0.2;
window.setAutoRotate = function(v, speed) {
  _autoRotate = !!v;
  if(speed) _rotateSpeed = speed;
};

var _shadowMesh = null;
window.showShadow = function(visible) {
  if(visible && !_shadowMesh) {
    try {
      var sg = new THREE.PlaneGeometry(2, 2);
      var sm = new THREE.ShadowMaterial({ opacity: 0.28 });
      _shadowMesh = new THREE.Mesh(sg, sm);
      _shadowMesh.rotation.x = -Math.PI/2;
      _shadowMesh.position.y = -0.01;
      _shadowMesh.receiveShadow = true;
      scene.add(_shadowMesh);
    } catch(e) {}
  }
  if(_shadowMesh) _shadowMesh.visible = !!visible;
};

// ── Полная очистка WebGL-контекста перед закрытием WebView, чтобы не
// оставлять висящий GPU-контекст/геометрию/текстуры в памяти устройства.
window.disposeVRM=function(){
  try{
    if(vrm){ try{THREE_VRM.VRMUtils.deepDispose(vrm.scene);}catch(e){} vrm=null; }
    Object.keys(_vrmCache||{}).forEach(function(k){
      try{THREE_VRM.VRMUtils.deepDispose(_vrmCache[k].scene);}catch(e){}
    });
    _vrmCache={};_vrmCacheOrder=[];
    if(scene){
      scene.traverse(function(o){
        if(o.geometry)try{o.geometry.dispose();}catch(e){}
        if(o.material){
          (Array.isArray(o.material)?o.material:[o.material]).forEach(function(m){
            try{
              Object.keys(m).forEach(function(k){var t=m[k];if(t&&t.isTexture)t.dispose();});
              m.dispose();
            }catch(e){}
          });
        }
      });
      while(scene.children.length)scene.remove(scene.children[0]);
    }
    _shadowMesh=null;
    if(renderer){
      try{renderer.dispose();}catch(e){}
      try{renderer.forceContextLoss();}catch(e){}
      if(renderer.domElement&&renderer.domElement.parentNode)
        renderer.domElement.parentNode.removeChild(renderer.domElement);
    }
    renderer=null;scene=null;cam=null;
  }catch(e){}
};

var _particles = null;
var _particleT = 0;
window.showParticles = function(enabled) {
  if(!enabled) { if(_particles) { scene.remove(_particles); _particles = null; } return; }
  if(_particles) return;
  try {
    var count = 40;
    var geom = new THREE.BufferGeometry();
    var pos = new Float32Array(count * 3);
    for(var i = 0; i < count; i++) {
      pos[i*3 ] = (Math.random()-0.5)*0.6;
      pos[i*3+1] = Math.random()*1.8;
      pos[i*3+2] = (Math.random()-0.5)*0.6;
    }
    geom.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    var mat = new THREE.PointsMaterial({
      color: 0xcc88ff, size: 0.025, transparent: true,
      opacity: 0.7, depthWrite: false
    });
    _particles = new THREE.Points(geom, mat);
    scene.add(_particles);
  } catch(e) {}
};
function _updateParticles(dt) {
  if(!_particles) return;
  _particleT += dt;
  var pos = _particles.geometry.attributes.position.array;
  for(var i = 0; i < pos.length/3; i++) {
    pos[i*3+1] += dt * (0.05 + Math.sin(_particleT*0.5+i)*0.02);
    if(pos[i*3+1] > 1.9) pos[i*3+1] = 0;
  }
  _particles.geometry.attributes.position.needsUpdate = true;
  _particles.rotation.y += dt * 0.1;
}

window.setTint = function(hexColor, alpha) {
  try {
    var el = document.getElementById('_tint');
    if(!el) {
      el = document.createElement('div');
      el.id = '_tint';
      el.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:1;transition:background 1s';
      document.body.appendChild(el);
    }
    el.style.background = hexColor
      ? 'rgba('+ parseInt(hexColor.slice(1,3),16) + ','
          + parseInt(hexColor.slice(3,5),16) + ','
          + parseInt(hexColor.slice(5,7),16) + ',' + (alpha||0.08) +')'
      : 'none';
  } catch(e) {}
};

function _animExtras(dt, br) {
  _updateFov(dt);
  _applyShake(dt);
  _applyBreathScale(br);
  _updateParticles(dt);
  if(_autoRotate && vrm) vrm.scene.rotation.y += dt * _rotateSpeed;
}

var _fpsFrames=0, _fpsT=0, _fps=0;
function _countFps(dt) {
  _fpsFrames++; _fpsT += dt;
  if(_fpsT >= 1.0) { _fps=_fpsFrames; _fpsFrames=0; _fpsT=0; }
  return _fps;
}
window.getFps = function() { return _fps; };

var _boneHelpers = [];
window.showBoneHelpers = function(v) {
  _boneHelpers.forEach(function(h) { scene.remove(h); });
  _boneHelpers = [];
  if(!v || !vrm) return;
  try {
    var hmat = new THREE.MeshBasicMaterial({color:0x00ff88,wireframe:true});
    var hgeom = new THREE.SphereGeometry(0.02,8,8);
    Object.keys(_bones).forEach(function(name) {
      var bn = _nb(name);
      if(!bn) return;
      var h = new THREE.Mesh(hgeom, hmat);
      bn.add(h);
      _boneHelpers.push(h);
    });
  } catch(e) {}
};

window.getScreenshot = function() {
  try {
    renderer.render(scene, cam);
    return renderer.domElement.toDataURL('image/png');
  } catch(e) { return null; }
};

var _timeline = null;
window.playTimeline = function(keyframes, onDone) {
  _timeline = {frames: keyframes, idx: 0, cb: onDone || null};
  _timelineNext();
};
function _timelineNext() {
  if(!_timeline || _timeline.idx >= _timeline.frames.length) {
    if(_timeline && _timeline.cb) _timeline.cb();
    _timeline = null; return;
  }
  var fr = _timeline.frames[_timeline.idx++];
  window.playVrma(fr.anim, fr.loop || false);
  if(!fr.loop) {
    setTimeout(_timelineNext, (fr.dur || 4) * 1000);
  }
}

window.showInfo = function(text, durationMs) {
  try {
    var el = document.getElementById('_info');
    if(!el) {
      el = document.createElement('div');
      el.id = '_info';
      el.style.cssText = (
        'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);' +
        'background:rgba(0,0,0,0.65);color:#fff;padding:6px 16px;' +
        'border-radius:20px;font:13px sans-serif;pointer-events:none;' +
        'z-index:9999;opacity:0;transition:opacity 0.35s'
      );
      document.body.appendChild(el);
    }
    el.textContent = text;
    el.style.opacity = '1';
    clearTimeout(el._t);
    el._t = setTimeout(function() { el.style.opacity='0'; }, durationMs||2500);
  } catch(e) {}
};

var _moodColor = null;
window.setMoodColor = function(hex) {
  _moodColor = hex;
  var el = document.getElementById('_mood_bg');
  if(!el) {
    el = document.createElement('div');
    el.id = '_mood_bg';
    el.style.cssText = (
      'position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;' +
      'z-index:0;transition:background 2s'
    );
    document.body.insertBefore(el, document.body.firstChild);
  }
  if(hex) {
    var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    el.style.background = 'radial-gradient(ellipse at 50% 100%, rgba('+r+','+g+','+b+',0.12) 0%, transparent 70%)';
  } else {
    el.style.background = 'none';
  }
};


window.forceResize=function(){
  try{
    if(!renderer||!cam)return;
    var W=window.innerWidth,H=window.innerHeight;
    if(!W||!H)return;
    renderer.setSize(W,H);
    cam.aspect=W/H;
    cam.updateProjectionMatrix();
  }catch(e){}
};
window.addEventListener("resize",function(){window.forceResize();});
var _lastRW=0,_lastRH=0;
setInterval(function(){
  try{
    if(window.innerWidth!==_lastRW||window.innerHeight!==_lastRH){
      _lastRW=window.innerWidth;_lastRH=window.innerHeight;
      window.forceResize();
    }
  }catch(e){}
},400);


</script></body></html>"""

class _ResultHook(MethodHook):
    def __init__(self,p): self._p=p
    def after_hooked_method(self,param):
        try:
            if int(param.args[0])==PICK_REQUEST and int(param.args[1])==-1 and param.args[2]:
                uri=param.args[2].getData()
                if uri:
                    try: BulletinHelper.show_info("⏳ Загрузка модели...")
                    except Exception: pass
                    run_on_queue(lambda: self._p._copy_vrm(uri))
        except Exception as e: self._p._log("hook: "+str(e))

class _SoundPlayer:
    def __init__(self,p):
        self._p=p; self._mp=None; self._lock=threading.Lock(); self._cache={}
        self._playing=False; self._last_play=0.0

    def _scan(self,cat):
        if cat in self._cache: return self._cache[cat]
        base=str(self._p.gs("stella_sounds") or SOUNDS_BASE)
        files=[]
        try:
            for fn in os.listdir(os.path.join(base,cat)):
                if os.path.splitext(fn)[1].lower() in SOUND_EXTS:
                    files.append(os.path.join(base,cat,fn))
        except OSError: pass
        except Exception as e: self._p._log("scan["+cat+"]: "+str(e))
        self._cache[cat]=files; return files

    def invalidate(self): self._cache.clear()

    def play(self,cat):
        now=time.time()
        if self._playing and (now-self._last_play)<3.0: return
        files=self._scan(cat)
        if not files: return
        path=random.choice(files)
        self._last_play=now
        run_on_ui_thread(lambda: self._do_play(path))

    def _do_play(self,path):
        try:
            with self._lock:
                if self._mp:
                    try:
                        self._mp.stop(); self._mp.release()
                    except Exception: pass
                    self._mp=None
                self._playing=False
                MP=find_class("android.media.MediaPlayer"); mp=MP()
                mp.setDataSource(path)
                mp.prepare()
                vol=int(self._p.gs("stella_volume") or 80)/100.0
                mp.setVolume(vol,vol)
                OCL=find_class("android.media.MediaPlayer$OnCompletionListener")
                sp_ref=self
                class _CL(dynamic_proxy(OCL)):
                    def __init__(self): super().__init__()
                    def onCompletion(self_c,m):
                        try:
                            with sp_ref._lock:
                                sp_ref._playing=False
                                try: m.release()
                                except Exception: pass
                                if sp_ref._mp is m: sp_ref._mp=None
                        except Exception: pass
                mp.setOnCompletionListener(_CL())
                OEL=find_class("android.media.MediaPlayer$OnErrorListener")
                class _EL(dynamic_proxy(OEL)):
                    def __init__(self): super().__init__()
                    def onError(self_e,m,what,extra):
                        try:
                            with sp_ref._lock:
                                sp_ref._playing=False
                                try: m.reset(); m.release()
                                except Exception: pass
                                if sp_ref._mp is m: sp_ref._mp=None
                        except Exception: pass
                        return True
                mp.setOnErrorListener(_EL())
                mp.start()
                self._mp=mp; self._playing=True
        except Exception as e: self._p._log("play: "+str(e)); self._playing=False

    def stop(self):
        with self._lock:
            self._playing=False
            if self._mp:
                try: self._mp.stop(); self._mp.release()
                except Exception: pass
                self._mp=None

class _SherpaEngine:
    def __init__(self,p): pass
    def is_ready(self): return True
    def is_installed(self): return True
    def stop(self): pass

class _Companion:
    IDLE_SLEEP=20.0; IDLE_CHECK=4.0; IDLE_SWITCH=9.0
    def __init__(self,p):
        self._p=p; self._wm=None; self._root=None; self._wv=None; self._lp=None
        self._alive=False; self._hidden=False; self._showing=False
        self._itx=self._ity=0.0; self._ivx=self._ivy=0; self._expressions=[]
        self._last_touch=time.time(); self._sleeping=False
        self._idle_t=None; self._tap_count=0; self._tap_ts=0.0
        self._vrm_loaded=False

    def show(self):
        if self._alive: run_on_ui_thread(self.load_vrm,200); return
        if self._showing: return
        self._showing=True; run_on_queue(self._ensure_libs)

    def hide(self): run_on_ui_thread(self._close)

    def load_vrm(self):
        url=str(self._p.gs("vrm_url") or DEFAULT_VRM).strip()
        if url==DEFAULT_VRM and os.path.exists(STELLA_VRM):
            url="file://"+STELLA_VRM
        self._p._remember_model(url)
        run_on_ui_thread(lambda: self._js("if(window.loadVRM)loadVRM("+json.dumps(url)+");"),200)
        run_on_ui_thread(self._poll_status,3500)

    def _cache(self):
        try:
            return find_class("org.telegram.messenger.ApplicationLoader")\
                .applicationContext.getCacheDir().getAbsolutePath()
        except Exception: return "/data/user/0/com.radolyn.ayugram/cache"

    def _ensure_libs(self):
        cache=self._cache(); os.makedirs(cache,exist_ok=True)
        missing=[n for n in LIB_URLS
                 if not os.path.exists(os.path.join(cache,n))
                 or os.path.getsize(os.path.join(cache,n))<1000]
        if missing:
            for name in missing:
                try:
                    urllib.request.urlretrieve(LIB_URLS[name],os.path.join(cache,name))
                    self._p._log("DL OK: "+name)
                except Exception as e:
                    self._p._log("DL FAIL "+name+": "+str(e)); self._showing=False; return
        run_on_ui_thread(self._open,800)

    def _inject_vrma_lib(self):
        """Лениво загружает и инжектит three-vrm-animation.js.
        Скачивание файла безопасно делать в фоне, но evaluateJavascript
        обязан выполняться на UI-потоке — иначе WebView кидает исключение."""
        if not self._wv or not self._alive: return False
        cache=self._cache()
        path=os.path.join(cache,"three-vrm-animation.js")
        if not os.path.exists(path) or os.path.getsize(path)<1000:
            try:
                import urllib.request
                urllib.request.urlretrieve(
                    "https://cdn.jsdelivr.net/npm/@pixiv/three-vrm-animation@2/lib/three-vrm-animation.js", path)
                self._p._log("DL OK: three-vrm-animation.js")
            except Exception as e:
                self._p._log("DL FAIL vrma: "+str(e)); return False
        try:
            with open(path,"r",encoding="utf-8") as f: js=f.read()
        except Exception as e:
            self._p._log("inject vrma FAIL: "+str(e)); return False
        wv=self._wv; alive=self._alive
        def _inj():
            try:
                if wv and alive:
                    wv.evaluateJavascript(js,None)
                    self._vrma_injected=True
            except Exception as e:
                self._p._log("inject vrma FAIL: "+str(e))
        run_on_ui_thread(_inj)
        return True

    def _inject_libs(self):
        if not self._wv or not self._alive: return
        cache=self._cache()
        libs=["three.min.js","GLTFLoader.js","three-vrm.js","three-vrm-animation.js"]
        wv=self._wv; alive=self._alive; debug=bool(self._p.gs("debug_logs"))
        for name in libs:
            path=os.path.join(cache,name)
            if not os.path.exists(path): self._p._log("skip missing: "+name); continue
            try:
                with open(path,"r",encoding="utf-8") as f: js=f.read()
            except Exception as e:
                self._p._log("inject FAIL "+name+": "+str(e)); continue
            def _inj(js=js,name=name):
                try:
                    if wv and alive: wv.evaluateJavascript(js,None)
                    if debug: self._p._log("inject "+name+" ("+str(len(js)//1024)+"KB)")
                except Exception as e: self._p._log("inject FAIL "+name+": "+str(e))
            run_on_ui_thread(_inj)

    def _js(self,code):
        wv=self._wv; alive=self._alive
        def _run():
            try:
                if wv and alive: wv.evaluateJavascript(code,None)
            except Exception: pass
        run_on_ui_thread(_run)

    def _fetch_expressions(self):
        if not self._alive or not self._wv: return
        try:
            VC=find_class("android.webkit.ValueCallback"); comp=self
            class _CBExpr(dynamic_proxy(VC)):
                def __init__(self): super().__init__()
                def onReceiveValue(self_c,val):
                    try:
                        raw=str(val) if val else "[]"
                        try: names=json.loads(json.loads(raw))
                        except Exception: names=json.loads(raw)
                        if not isinstance(names,list): names=[]
                        comp._expressions=names
                        comp._p._log("exprs: "+str(names))
                    except Exception as e: comp._p._log("expr parse: "+str(e))
            self._wv.evaluateJavascript("window.getExpressions?getExpressions():'[]'",_CBExpr())
        except Exception as e: self._p._log("fetch_expr: "+str(e))

    def _poll_status(self):
        if not self._alive or not self._wv: return
        try:
            VC=find_class("android.webkit.ValueCallback"); comp=self
            class _CBPoll(dynamic_proxy(VC)):
                def __init__(self): super().__init__()
                def onReceiveValue(self_c,val):
                    try:
                        v=str(val).replace('"','').replace("'",'').strip() if val else "?"
                        _log_en = bool(comp._p.gs("debug_logs"))
                        if _log_en and v not in ("?","Ready","Loading anim..."):
                            comp._p._log("JS: "+v)
                        if "VRMA_END" in v or "DANCE_END" in v:
                            p2=comp._p
                            if p2._sounds: p2._sounds.play("ready")
                            comp._last_touch=time.time()
                            if not comp._sleeping:
                                run_on_queue(comp._play_idle)
                        if "VRM OK" in v:
                            comp._p._log("VRM OK")
                            comp._vrm_loaded=True
                            try: BulletinHelper.show_success(comp._p.t("load_ok"))
                            except Exception: pass
                            run_on_ui_thread(comp._fetch_expressions,600)
                            def _vrm_ready():
                                p2=comp._p
                                if p2._sounds: p2._sounds.play("ready")
                                def _greet():
                                    if p2._sounds: p2._sounds.play("greet")
                                    comp._last_touch=time.time()
                                    comp._play_random_anim(ANIM_GREET, loop=False)
                                    comp._start_idle_watcher()
                                run_on_queue(_greet)
                            run_on_queue(_vrm_ready)
                        if "ERR" in v and "TIMEOUT" not in v:
                            comp._p._log("JS ERR: "+v)
                        if not comp._vrm_loaded:
                            run_on_ui_thread(comp._poll_status,1500)
                    except Exception as e:
                        comp._p._log("poll_cb: "+str(e))
                        try:
                            if not comp._vrm_loaded:
                                run_on_ui_thread(comp._poll_status,1500)
                        except Exception: pass
            self._wv.evaluateJavascript(
                "document.getElementById('s')&&document.getElementById('s').textContent||'?'",_CBPoll())
        except Exception as e: self._p._log("poll: "+str(e))

    def resize(self,w,h): run_on_ui_thread(lambda: self._do_resize(w,h))
    def _do_resize(self,w,h):
        try:
            if not self._alive or bool(self._p.gs("lock_win_size")): return
            self._lp.width=AndroidUtilities.dp(float(w))
            self._lp.height=AndroidUtilities.dp(float(h))
            self._wm.updateViewLayout(self._root,self._lp)
            run_on_ui_thread(lambda: self._js("if(window.forceResize)forceResize();"),80)
        except Exception as e: self._p._log("resize: "+str(e))

    def _snap(self):
        try:
            if not self._alive: return
            sw=find_class("org.telegram.messenger.ApplicationLoader")\
                .applicationContext.getResources().getDisplayMetrics().widthPixels
            tx=4 if self._lp.x<sw//2 else sw-self._lp.width-4
            self._lp.x=tx; self._wm.updateViewLayout(self._root,self._lp); self._p.ss("pos_x",tx)
        except Exception as e: self._p._log("snap: "+str(e))

    def _apply_win_shape(self):
        try:
            if not self._alive: return
            shape=int(self._p.gs("win_shape") or WIN_RECT)
            if shape==WIN_BODY: w=AndroidUtilities.dp(160.0); h=AndroidUtilities.dp(460.0)
            else:
                w=AndroidUtilities.dp(float(self._p.gs("width_dp")))
                h=AndroidUtilities.dp(float(self._p.gs("height_dp")))
            self._lp.width=w; self._lp.height=h
            self._wm.updateViewLayout(self._root,self._lp)
            run_on_ui_thread(lambda: self._js("if(window.forceResize)forceResize();"),80)
        except Exception as e: self._p._log("win_shape: "+str(e))

    def _trigger_random_expr(self):
        cands=[e for e in self._expressions if e in EXPR_POS]
        if not cands:
            cands=[e for e in self._expressions
                   if e not in EXPR_SKIP and e not in ('sad','angry','sorrow')]
        if cands:
            self._js("if(window.triggerExpr)triggerExpr("+json.dumps(random.choice(cands))+",1.8);")

    def _show_expr_menu(self,act):
        t=self._p.t; comp=self
        exprs=[e for e in self._expressions if e not in EXPR_SKIP]
        if exprs:
            items=[EXPR_EMOJI.get(n,'')+" "+n for n in exprs]+[t("m_expr_back")]
        else:
            items=[t("m_no_expr"),t("m_expr_back")]
        bld=AlertDialogBuilder(act); bld.set_title(t("m_expr"))
        def oc(b,i):
            b.dismiss()
            if exprs and i<len(exprs):
                comp._js("if(window.triggerExpr)triggerExpr("+json.dumps(exprs[i])+",2.2);")
            else: run_on_ui_thread(comp._menu,120)
        bld.set_items(items,oc)
        bld.set_negative_button(t("m_close"),lambda b,w: b.dismiss())
        bld.show()

    def _menu(self):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                t=self._p.t; locked=bool(self._p.gs("locked"))
                pan_on=bool(self._p.gs("pan_mode")); enabled=bool(self._p.gs("enable"))
                items=[
                    t("m_off") if enabled else t("m_on"),
                    t("m_pan_off") if pan_on else t("m_pan_on"),
                    t("m_reset_pan"),t("m_zoom_in"),t("m_zoom_out"),
                    t("m_unlock") if locked else t("m_lock"),
                    t("m_reload"),t("m_pick"),t("m_hide"),
                ]
                bld=AlertDialogBuilder(act); bld.set_title(t("m_title"))
                comp=self; p=self._p
                def oc(b,i):
                    b.dismiss()
                    if i==0: p._on_enable_change(not enabled)
                    elif i==1:
                        nv=not pan_on; p.ss("pan_mode",nv)
                        comp._js("if(window.showPanIndicator)showPanIndicator("+("true" if nv else "false")+");")
                    elif i==2: comp._js("if(window.resetPan)resetPan();")
                    elif i==3: comp._js("if(window.zoomCam)zoomCam(0.85);")
                    elif i==4: comp._js("if(window.zoomCam)zoomCam(1.18);")
                    elif i==5: p.ss("locked",not locked)
                    elif i==6: comp.load_vrm()
                    elif i==7: p._pick_file()
                    elif i==8:
                        comp._hidden=True; run_on_ui_thread(comp._close)
                        try: BulletinHelper.show_info(t("hidden"))
                        except Exception: pass
                bld.set_items(items,oc)
                bld.set_negative_button(t("m_close"),lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("menu: "+str(e))
        run_on_ui_thread(_do)

    def _open(self):
        if self._alive: self._showing=False; return
        if self._wv and self._vrm_loaded:
            try:
                fc=find_class
                LP=fc("android.view.WindowManager$LayoutParams"); G=fc("android.view.Gravity")
                PF=fc("android.graphics.PixelFormat"); B=fc("android.os.Build")
                ctx=fc("org.telegram.messenger.ApplicationLoader").applicationContext
                wm=ctx.getSystemService("window")
                if not wm: return
                wpx=int(AndroidUtilities.dp(float(self._p.gs("width_dp") or 128)))
                hpx=int(AndroidUtilities.dp(float(self._p.gs("height_dp") or 310)))
                lp_type=2038 if int(str(B.VERSION.SDK_INT))>=26 else 2002
                wm_flags=(LP.FLAG_NOT_FOCUSABLE|LP.FLAG_LAYOUT_IN_SCREEN|
                          LP.FLAG_LAYOUT_NO_LIMITS|LP.FLAG_HARDWARE_ACCELERATED)
                _px=int(self._p.gs("pos_x") or 20); _py=int(self._p.gs("pos_y") or 60)
                lp=LP(wpx,hpx,_px,_py,lp_type,wm_flags,PF.TRANSLUCENT)
                lp.gravity=G.TOP|G.LEFT
                wm.addView(self._root,lp)
                self._wm=wm; self._lp=lp
                self._alive=True; self._showing=False
                self._p._log("addView restore OK")
                self._start_idle_watcher()
                return
            except Exception as e:
                self._p._log("restore fail: "+str(e))
                self._wv=None; self._vrm_loaded=False
        try:
            fc=find_class
            LP=fc("android.view.WindowManager$LayoutParams"); G=fc("android.view.Gravity")
            FL=fc("android.widget.FrameLayout"); FLP=fc("android.widget.FrameLayout$LayoutParams")
            View=fc("android.view.View"); ME=fc("android.view.MotionEvent")
            PF=fc("android.graphics.PixelFormat"); B=fc("android.os.Build")
            SC=fc("android.provider.Settings"); IC=fc("android.content.Intent")
            UC=fc("android.net.Uri"); AL=fc("org.telegram.messenger.ApplicationLoader")
            H=fc("android.os.Handler"); LO=fc("android.os.Looper")
            RC=fc("java.lang.Runnable"); OTL=fc("android.view.View$OnTouchListener")
            WV=fc("android.webkit.WebView")
            ctx=AL.applicationContext
            if not ctx: run_on_ui_thread(self._open,2000); return
            if B.VERSION.SDK_INT>=23 and not SC.canDrawOverlays(ctx):
                try: BulletinHelper.show_error(self._p.t("perm"))
                except Exception: pass
                i=IC(SC.ACTION_MANAGE_OVERLAY_PERMISSION)
                i.setData(UC.parse("package:"+ctx.getPackageName()))
                i.addFlags(IC.FLAG_ACTIVITY_NEW_TASK); ctx.startActivity(i)
                self._showing=False; return
            wm=ctx.getSystemService("window")
            if not wm: self._showing=False; return
            act_ctx=ctx
            try:
                f=get_last_fragment()
                if f: act_ctx=f.getParentActivity()
            except Exception: pass
            wv=WV(act_ctx); ws=wv.getSettings()
            ws.setJavaScriptEnabled(True); ws.setDomStorageEnabled(True)
            ws.setAllowFileAccess(True); ws.setAllowContentAccess(True)
            for setter in ("setAllowFileAccessFromFileURLs","setAllowUniversalAccessFromFileURLs"):
                try: getattr(ws,setter)(True)
                except Exception: pass
            try: ws.setMixedContentMode(0)
            except Exception: pass
            try: ws.setSafeBrowsingEnabled(False)
            except Exception: pass
            ws.setUserAgentString("Mozilla/5.0 (Linux; Android 13) AppleWebKit/537.36 Chrome/112 Mobile")
            wv.setBackgroundColor(0x00000000); wv.setLayerType(View.LAYER_TYPE_HARDWARE,None)
            root=FL(act_ctx); root.addView(wv,FLP(-1,-1))
            root.setAlpha(int(self._p.gs("alpha"))/100.0)
            lp_type=LP.TYPE_APPLICATION_OVERLAY if B.VERSION.SDK_INT>=26 else LP.TYPE_PHONE
            wm_flags=(LP.FLAG_NOT_FOCUSABLE|LP.FLAG_NOT_TOUCH_MODAL|
                      LP.FLAG_LAYOUT_NO_LIMITS|LP.FLAG_HARDWARE_ACCELERATED)
            shape=int(self._p.gs("win_shape") or WIN_RECT)
            if shape==WIN_BODY: wpx=AndroidUtilities.dp(160.0); hpx=AndroidUtilities.dp(460.0)
            else:
                wpx=AndroidUtilities.dp(float(self._p.gs("width_dp") or 128))
                hpx=AndroidUtilities.dp(float(self._p.gs("height_dp") or 310))
            _px=int(self._p.gs("pos_x") or -1)
            _py=int(self._p.gs("pos_y") or -1)
            if _px<0 or _py<0:
                try:
                    dm=ctx.getResources().getDisplayMetrics()
                    _px=max(0,(dm.widthPixels-wpx)//2)
                    _py=int(dm.heightPixels*0.05)
                    self._p.ss("pos_x",_px); self._p.ss("pos_y",_py)
                except Exception: _px=20; _py=60
            lp=LP(wpx,hpx,_px,_py,lp_type,wm_flags,PF.TRANSLUCENT)
            lp.gravity=G.TOP|G.LEFT
            try: lp.flags|=LP.FLAG_NOT_TOUCH_MODAL|LP.FLAG_WATCH_OUTSIDE_TOUCH
            except Exception: pass
            wm.addView(root,lp)
            self._root=root; self._wv=wv; self._lp=lp; self._wm=wm
            self._alive=True; self._showing=False; self._p._log("addView OK")
            p=self._p; wvr=wv; comp=self
            def _s2():
                try: wvr.loadDataWithBaseURL("file:///android_asset/",_HTML,"text/html","UTF-8",None)
                except Exception as e: p._log("s2: "+str(e))
            def _s1():
                try: comp._inject_libs()
                except Exception as e: p._log("s1: "+str(e))

            def _s3():
                try:
                    url=str(p.gs("vrm_url") or DEFAULT_VRM).strip()
                    spd=int(p.gs("idle_speed"))/50.0; cz=int(p.gs("cam_z") or 35)/10.0
                    sb="true" if bool(p.gs("show_borders")) else "false"
                    pm="true" if bool(p.gs("pan_mode")) else "false"
                    rm="true" if bool(p.gs("rotate_mode")) else "false"
                    rot_y=int(p.gs("rotate_y") or 0); rot_x=int(p.gs("rotate_x") or 0)
                    light_b=int(p.gs("light_brightness") or 100)
                    light_c=str(p.gs("light_color") or "#FFFFFF")
                    fps=int(p.gs("target_fps") or 60)
                    wind=int(p.gs("wind_strength") or 0)
                    skin_b=int(p.gs("skin_brightness") or 100)
                    cloth_b=int(p.gs("clothes_brightness") or 100)
                    hair_b=int(p.gs("hair_brightness") or 100)
                    skin_c=str(p.gs("skin_color") or "#FFFFFF")
                    cloth_c=str(p.gs("clothes_color") or "#FFFFFF")
                    hair_c=str(p.gs("hair_color") or "#FFFFFF")
                    wvr.evaluateJavascript("if(window.setSpd)setSpd("+str(spd)+");",None)
                    wvr.evaluateJavascript("if(window.setCamZ)setCamZ("+str(cz)+");",None)
                    wvr.evaluateJavascript("if(window.showBorder)showBorder("+sb+");",None)
                    wvr.evaluateJavascript("if(window.showPanIndicator)showPanIndicator("+pm+");",None)
                    wvr.evaluateJavascript("if(window.setInteractionMode)setInteractionMode("+rm+","+pm+");",None)
                    wvr.evaluateJavascript("if(window.setTargetFPS)setTargetFPS("+str(fps)+");",None)
                    if p._sounds: p._sounds.play("load")
                    wvr.evaluateJavascript("if(window.loadVRM)loadVRM("+json.dumps(url)+");",None)
                    p._log("VRM sent"); run_on_ui_thread(comp._poll_status,3500)
                    def _apply_saved_view():
                        wvr.evaluateJavascript("if(window.setRotationY)setRotationY("+str(rot_y)+");",None)
                        wvr.evaluateJavascript("if(window.setRotationX)setRotationX("+str(rot_x)+");",None)
                        wvr.evaluateJavascript("if(window.setLightBrightness)setLightBrightness("+str(light_b)+");",None)
                        wvr.evaluateJavascript("if(window.setLightColor)setLightColor("+json.dumps(light_c)+");",None)
                        wvr.evaluateJavascript("if(window.setWindStrength)setWindStrength("+str(wind)+");",None)
                        wvr.evaluateJavascript("if(window.setSkinBrightness)setSkinBrightness("+str(skin_b)+");",None)
                        wvr.evaluateJavascript("if(window.setClothesBrightness)setClothesBrightness("+str(cloth_b)+");",None)
                        wvr.evaluateJavascript("if(window.setHairBrightness)setHairBrightness("+str(hair_b)+");",None)
                        if skin_c!="#FFFFFF": wvr.evaluateJavascript("if(window.setSkinColor)setSkinColor("+json.dumps(skin_c)+");",None)
                        if cloth_c!="#FFFFFF": wvr.evaluateJavascript("if(window.setClothesColor)setClothesColor("+json.dumps(cloth_c)+");",None)
                        if hair_c!="#FFFFFF": wvr.evaluateJavascript("if(window.setHairColor)setHairColor("+json.dumps(hair_c)+");",None)
                    run_on_ui_thread(_apply_saved_view, 1200)
                    run_on_ui_thread(_apply_saved_view, 2500)
                    def _load_base():
                        try:
                            comp._inject_vrma_lib()
                            comp._js("if(window.loadBaseAnim)loadBaseAnim("+json.dumps(_base_anim_url())+");")
                        except Exception as e: p._log("base_anim: "+str(e))
                    run_on_queue(_load_base)
                except Exception as e: p._log("s3: "+str(e))
            class _S2(dynamic_proxy(RC)):
                def __init__(self): super().__init__()
                def run(self_r): _s2()
            class _S1(dynamic_proxy(RC)):
                def __init__(self): super().__init__()
                def run(self_r): _s1()
            class _S3(dynamic_proxy(RC)):
                def __init__(self): super().__init__()
                def run(self_r): _s3()
            h=H(LO.getMainLooper())
            h.postDelayed(_S2(),500); h.postDelayed(_S1(),2000); h.postDelayed(_S3(),5000)
            self._attach_touch(OTL,ME)
        except Exception as e:
            self._p._log("_open: "+str(e)+"\n"+traceback.format_exc())
            self._showing=False

    def _attach_touch(self,OTL_c,MotionEvent):
        # Вращение модели, пинч-зум и pan_mode теперь обрабатываются нативно
        # в JS (touchstart/touchmove/touchend внутри _HTML) — без ежекадрового
        # evaluateJavascript. Здесь остаётся ТОЛЬКО то, что требует Android API:
        # перемещение самого плавающего окна (LayoutParams.x/.y), тапы (эмоции/
        # меню/танец) и передача импульса физики окна (applyWindowKick).
        # onTouch всегда возвращает False, чтобы событие доходило и до WebView.
        try:
            comp=self; pr=self._p; lr=self._lp; wr=self._wm; wvr=self._wv
            class TL(dynamic_proxy(OTL_c)):
                def __init__(self):
                    super().__init__(); self.moved=False; self.pinching=False
                    self.ms=0; self.lp_pend=False; self.dist=0.0
                    self._lwx=0.0; self._lwy=0.0
                def onTouch(self_t,v,ev):
                    try:
                        a=ev.getActionMasked()
                        if a==MotionEvent.ACTION_DOWN:
                            comp._last_touch=time.time()
                            if comp._sleeping: run_on_ui_thread(comp._wake_up)
                            comp._itx=ev.getRawX(); comp._ity=ev.getRawY()
                            comp._ivx=lr.x; comp._ivy=lr.y
                            self_t._lwx=comp._itx; self_t._lwy=comp._ity
                            self_t.moved=False; self_t.pinching=False
                            self_t.dist=0.0; self_t.ms=int(time.time()*1000); self_t.lp_pend=True
                            ref=self_t
                            def _lng():
                                if ref.lp_pend and not ref.moved: ref.lp_pend=False; comp._menu()
                            run_on_ui_thread(_lng,800)
                        elif a==MotionEvent.ACTION_POINTER_DOWN:
                            # Мультитач полностью обрабатывается JS-слушателями (пинч-зум/
                            # поворот); здесь только помечаем, что это не одиночный тап.
                            self_t.pinching=True; self_t.lp_pend=False
                        elif a==MotionEvent.ACTION_MOVE:
                            comp._last_touch=time.time()
                            if bool(pr.gs("locked")) or self_t.pinching: return False
                            if bool(pr.gs("rotate_mode")) or bool(pr.gs("pan_mode")):
                                # Вращение/pan одним пальцем — это делает JS-слушатель
                                # touchmove внутри WebView, Python окно двигать не должен.
                                return False
                            dx=ev.getRawX()-comp._itx; dy=ev.getRawY()-comp._ity
                            self_t.dist=math.sqrt(dx*dx+dy*dy)
                            if self_t.dist>12: self_t.moved=True; self_t.lp_pend=False
                            if self_t.moved:
                                if bool(pr.gs("win_physics")):
                                    sx=ev.getRawX(); sy=ev.getRawY()
                                    stx=sx-self_t._lwx; sty=sy-self_t._lwy
                                    self_t._lwx=sx; self_t._lwy=sy
                                    if abs(stx)>0.5 or abs(sty)>0.5:
                                        comp._js("if(window.applyWindowKick)applyWindowKick("+str(round(stx,2))+","+str(round(sty,2))+");")
                                lr.x=int(comp._ivx+dx); lr.y=int(comp._ivy+dy)
                                try: wr.updateViewLayout(comp._root,lr)
                                except Exception: pass
                        elif a==MotionEvent.ACTION_POINTER_UP:
                            try:
                                AU2=find_class("org.telegram.messenger.AndroidUtilities")
                                dpf=AU2.dp(1.0)
                                if dpf>0: pr.ss("width_dp",lr.width//dpf); pr.ss("height_dp",lr.height//dpf)
                            except Exception: pass
                        elif a==MotionEvent.ACTION_UP:
                            self_t.lp_pend=False
                            if self_t.moved:
                                if not bool(pr.gs("rotate_mode")) and not bool(pr.gs("pan_mode")):
                                    pr.ss("pos_x",lr.x); pr.ss("pos_y",lr.y)
                                    if bool(pr.gs("snap")): run_on_ui_thread(comp._snap,120)
                            elif (not self_t.pinching and self_t.dist<8 and
                                  (int(time.time()*1000)-self_t.ms)<500):
                                _now=time.time()
                                if _now-comp._tap_ts<1.5: comp._tap_count+=1
                                else: comp._tap_count=1
                                comp._tap_ts=_now
                                if pr._stats: pr._stats.tap()
                                if pr._mood: pr._mood.on_tap()
                                if comp._tap_count>=3:
                                    comp._tap_count=0
                                    if pr._stats: pr._stats.dance()
                                    if pr._mood: pr._mood.on_dance()
                                    run_on_ui_thread(comp._start_dance)
                                elif bool(pr.gs("auto_react")):
                                    run_on_ui_thread(comp._trigger_random_expr)
                                    if pr._sounds: pr._sounds.play("ok")
                            self_t.pinching=False
                    except Exception as te: pr._log("touch: "+str(te))
                    return False
            wvr.setOnTouchListener(TL()); self._p._log("touch OK")
            self._start_idle_watcher()
        except Exception as e: self._p._log("attach_touch: "+str(e))

    def _start_dance(self):
        if not self._alive: return
        if self._sleeping: self._wake_up()
        self._play_random_anim(ANIM_DANCE, loop=False)

    def _start_idle_watcher(self):
        if self._idle_t and self._idle_t.is_alive(): return
        comp=self
        import random as _r
        _next_switch=[0.0]
        def _loop():
            while comp._alive:
                time.sleep(comp.IDLE_CHECK)
                if not comp._alive: break
                now=time.time()
                if not comp._sleeping and now-comp._last_touch>=comp.IDLE_SLEEP:
                    run_on_ui_thread(comp._go_sleep)
                    _next_switch[0]=now+comp.IDLE_SWITCH; continue
                if comp._sleeping: continue
                if now>=_next_switch[0]:
                    _next_switch[0]=now+comp.IDLE_SWITCH+_r.random()*10
                    run_on_queue(comp._play_idle)
        self._idle_t=threading.Thread(target=_loop,daemon=True,name="idle")
        self._idle_t.start()

    def _go_sleep(self):
        if self._sleeping or not self._alive: return
        self._sleeping=True; self._p._log("idle: sleeping")
        if self._p._sounds: self._p._sounds.play("sleep")
        p=_vrma_path("Loop/SadIdleMain.vrma")
        if os.path.exists(p):
            self._inject_and_play(p, loop=True)


    def _wake_up(self):
        if not self._sleeping: return
        self._sleeping=False; self._p._log("idle: wake up")
        self._js("if(window.stopVrma)stopVrma();")
        if self._p._sounds: self._p._sounds.play("greet")
        self._play_random_anim(ANIM_GREET, loop=False)
        import threading as _th2
        def _back_idle(): run_on_queue(self._play_idle)
        _th2.Timer(4.0, _back_idle).start()

    def _inject_and_play(self, path, loop=False):
        """Воспроизвести vrma анимацию. Инжектит lib только один раз."""
        import json as _j
        url="file://"+path
        l_str="true" if loop else "false"
        js_play="if(window.playVrma)playVrma("+_j.dumps(url)+","+l_str+");"
        def _do_on_ui():
            if not getattr(self,"_vrma_injected",False):
                self._inject_vrma_lib()
            self._js(js_play)
        run_on_ui_thread(_do_on_ui, 100)

    def _play_random_anim(self, pool, loop=False):
        """Сыграть случайную анимацию из пула если файл существует."""
        import random as _r
        candidates=[p for p in pool if os.path.exists(_vrma_path(p))]
        if candidates:
            self._inject_and_play(_vrma_path(_r.choice(candidates)), loop=loop)

    def _play_idle(self):
        """Играть случайный idle loop=False — по VRMA_END придёт следующий."""
        if self._sleeping: return
        import random as _r
        pool = [p for p in (ANIM_IDLE+ANIM_RANDOM)
                if os.path.exists(_vrma_path(p))]
        if not pool: return
        prev = getattr(self, "_last_idle", None)
        cands = [p for p in pool if p != prev] or pool
        name = _r.choice(cands); self._last_idle = name
        self._inject_and_play(_vrma_path(name), loop=False)

    def _close(self):
        try:
            if self._alive and self._wm and self._root:
                if self._wv:
                    try: self._wv.evaluateJavascript("if(window.disposeVRM)disposeVRM();",None)
                    except Exception: pass
                    self._wv.loadUrl("about:blank")
                self._wm.removeView(self._root); self._alive=False
                self._vrm_loaded=False
        except Exception as e: self._p._log("_close: "+str(e))



