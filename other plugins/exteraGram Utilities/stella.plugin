                get_text=lambda: ("\n".join(self._logs[-200:]) if self._logs else self.t("log_e"))
                bld=AlertDialogBuilder(act); bld.set_title(self.t("log_t"))
                bld.set_message(get_text())
                def _refresh(b,w):
