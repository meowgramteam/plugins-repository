            try:
                current_ui_fragment = get_last_fragment()
                if not current_ui_fragment or not current_ui_fragment.getParentActivity():
                    return

                dialog = AlertDialogBuilder(current_ui_fragment.getParentActivity())
                dialog.set_title("Кастомные эмодзи")
                dialog.set_message(
                    "1) Найди кастомный эмодзи в Telegram.\n"
                    "2) Отправь его в @AdsMarkdownBot.\n"
                    "3) Скопируй document_id и вставь в поле.\n"
                    "Пустое значение оставит стандартный эмодзи."
                )
                dialog.set_positive_button("Понял", None)
                dialog.set_top_animation(
                    R.raw.boosts, 72, False,
                    Theme.getColor(Theme.key_dialogTopBackground)
                )
                dialog.show()
            except Exception as ui_error:
                log(f"{LOG_PREFIX} ошибка показа инструкции эмодзи: {ui_error}")

        run_on_ui_thread(display)

