class PendingTask:
    """
    Задача, которая ждёт ответа от приватного бота.

    Когда пользователь отправляет команду типа BotCommand (.nsfw, .sfw и т.д.),
    команда отправляется боту, и мы сохраняем информацию о ней в очередь.
    Когда бот ответит, MessageListener найдёт соответствующую задачу и отправит
    ответ в правильный чат.

    Атрибуты:
        destination: ID чата, куда отправить ответ
        reply_to: ID сообщения, на которое ответить (или None)
        request_msg_id: ID сообщения с командой (для отслеживания)
        command: Какая команда была отправлена
    """
    __slots__ = ('destination', 'reply_to', 'request_msg_id', 'command')

    def __init__(
        self, destination: int, reply_to: Optional[int],
        request_msg_id: Optional[int], command: BotCommand,
    ):
        self.destination = destination
        self.reply_to = reply_to
        self.request_msg_id = request_msg_id
        self.command = command


# ════════════════════════════════════════════════════════════════════════════
# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ════════════════════════════════════════════════════════════════════════════

def to_signed_32(unsigned_value: int) -> int:
    """
    Преобразовать беззнаковое 32-битное число в подписанное.

    Это нужно для совместимости с Telegram API, которая использует
    подписанные 32-битные integer для ID чатов.

    Примеры:
        to_signed_32(0xFFFFFFFF) → -1
        to_signed_32(0x80000000) → -2147483648
    """
    masked = unsigned_value & 0xFFFFFFFF
    return masked if masked < 0x80000000 else masked - 0x100000000

@lru_cache(maxsize=1024)
def _utf16_length(text: str | None) -> int:
    if not text:
        return 0

    return len(text.encode("utf-16-le")) // 2


# ════════════════════════════════════════════════════════════════════════════
# СЛУШАТЕЛЬ УВЕДОМЛЕНИЙ
# ════════════════════════════════════════════════════════════════════════════

class MessageListener(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    """
    Слушает уведомления Telegram о новых сообщениях.

    Как это работает:

    1. Пользователь отправляет ".nsfw" → мы отправляем "/rc" боту
    2. Бот обрабатывает и отправляет нам результат
    3. Telegram уведомляет: "новое сообщение пришло"
    4. MessageListener ловит это уведомление
    5. Проверяет: это от нашего бота?
    6. Если да → берёт результат и отправляет в правильный чат

    Использует weak reference на плагин, чтобы избежать утечек памяти.
    """

    def __init__(self, plugin: "NyashnostiPlugin"):
        super().__init__()
        self.plugin_ref = weakref.ref(plugin)
        self._chaquopy_dict = None
        self._chaquopy_type = None

    def didReceivedNotification(self, notification_id, account, notification_args):
        """Вызывается каждый раз, когда приходит какое-либо уведомление."""
        plugin = self.plugin_ref()
        if not plugin:
            return

        # Нас интересуют только уведомления о новых сообщениях
        if notification_id != NotificationCenter.didReceiveNewMessages:
            return

        messages_list = notification_args[1]
        if not messages_list:
            return

        # Проверяем каждое сообщение в пакете
        for message_index in range(messages_list.size()):
            try:
                message_object = messages_list.get(message_index)
                if message_object and plugin._is_from_bot(message_object):
                    plugin._handle_bot_message(message_object)
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка обработки сообщения: {error}")

    def _chaquopyGetDict(self):
        return self._chaquopy_dict

    def _chaquopySetDict(self, pyObject: PyObject):
        self._chaquopy_dict = pyObject

    def _chaquopyGetType(self):
        return getattr(self, "_chaquopy_type", None)


