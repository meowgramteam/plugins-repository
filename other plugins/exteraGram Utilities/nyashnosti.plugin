class ApiKeySource:
    """
    Конфигурация провайдера API ключей для booru источников.

    Атрибуты:
        setting_key: Ключ в настройках (где хранится пользовательский ключ)
        command: Команда booru, для которой это нужно
        provider_name: Красивое имя провайдера (для UI)
        text: Текст в настройке
        subtext: Подтекст в настройке
        default: API ключ по умолчанию (публичный)
        link_text: Текст ссылки "как получить ключ"
        link_url: URL ссылки
    """
    __slots__ = (
        'setting_key', 'command', 'provider_name', 'text',
        'subtext', 'default', 'link_text', 'link_url',
    )

    def __init__(
        self, setting_key: str, command: str, provider_name: str,
        text: str, subtext: str, default: str, link_text: str, link_url: str,
    ):
        self.setting_key = setting_key
        self.command = command
        self.provider_name = provider_name
        self.text = text
        self.subtext = subtext
        self.default = default
        self.link_text = link_text
        self.link_url = link_url

class CustomBooruSource:
    __slots__ = ('command', 'url', 'login', 'key')

    def __init__(self, command: str, url: str, login: Optional[str], key: Optional[str]):
        self.command = command
        self.url = url
        self.login = login
        self.key = key


