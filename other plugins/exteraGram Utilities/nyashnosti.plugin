    def _normalize_custom_booru_value(self, value: Any) -> str:
        if value is None:
            return ""
        if isinstance(value, str):
            return value.strip()
        try:
            return str(value).strip()
        except Exception:
            return ""

    def _normalize_custom_booru_command(self, value: Any) -> str:
        command = self._normalize_custom_booru_value(value)
        if not command:
            return ""
        command = command.split()[0]
        while command and command[0] in (".", "/"):
            command = command[1:]
        return command.lower()

    def _build_ai_filter_sources(self) -> list[tuple[str, str]]:
        sources: list[tuple[str, str]] = [
            ("gelb", "Gelbooru"),
            ("danb", "Danbooru"),
            ("r34", "Rule34"),
            ("yd", "Yandere"),
        ]
        for source in self._get_custom_booru_sources():
            sources.append((source.command, source.command))
        return sources

    def _ai_filter_setting_key(self, command: str) -> str:
        return f"{AI_FILTER_KEY_PREFIX}{self._normalize_custom_booru_command(command)}"

    def _open_ai_filter_selector(self) -> None:
        try:
            from ui.quanta import MultiSelector
        except Exception:
            log(f"{LOG_PREFIX} MultiSelector не доступен")
            return

        sources = self._build_ai_filter_sources()
        if not sources:
            return

        items = [label for _, label in sources]
        setting_keys = [self._ai_filter_setting_key(command) for command, _ in sources]
        default_keys = [
            self._ai_filter_setting_key("gelb"),
            self._ai_filter_setting_key("r34"),
        ]

        def show_selector():
            MultiSelector(
                items=items,
                title="Фильтр ИИ-контента",
                subtitle="Выберите источники, где добавлять -ai_generated",
                setting_keys=setting_keys,
                plugin_instance=self,
                default=default_keys,
                action_text="Готово",
                show_count=True,
                show_select_all=True,
            )

        run_on_ui_thread(show_selector)

    def _append_exclusion_tag(self, tags: str, tag: str) -> str:
        normalized = self._normalize_custom_booru_value(tags)
        if not normalized:
            return tag
        tokens = {t.strip() for t in normalized.split() if t.strip()}
        if tag in tokens:
            return normalized
        return f"{normalized} {tag}"

    def _apply_ai_filter(self, command: str, tags: str) -> str:
        command_key = self._normalize_custom_booru_command(command)
        setting_key = self._ai_filter_setting_key(command_key)
        setting_value = self.get_setting(setting_key, None)
        if setting_value is None:
            if command_key in ("gelb", "r34"):
                return self._append_exclusion_tag(tags, AI_FILTER_TAG)
            return tags
        if setting_value:
            return self._append_exclusion_tag(tags, AI_FILTER_TAG)
        return tags

    def _normalize_custom_booru_url(self, value: Any) -> str:
        url = self._normalize_custom_booru_value(value)
        if not url:
            return ""
        if not url.startswith(("http://", "https://")):
            url = f"https://{url}"
        parsed = urlparse(url)
        if parsed.scheme not in ("http", "https") or not parsed.netloc or not parsed.hostname:
            return ""
        if not self._is_valid_custom_booru_hostname(parsed.hostname):
            return ""
        normalized = parsed.geturl().rstrip("/")
        return normalized

    def _is_valid_custom_booru_hostname(self, hostname: str) -> bool:
        if not hostname or "." not in hostname:
            return False
        if hostname.startswith(".") or hostname.endswith("."):
            return False
        parts = [p for p in hostname.split(".") if p]
        if len(parts) < 2:
            return False
        for part in parts:
            if not part or part.startswith("-") or part.endswith("-"):
                return False
        return True

    def _is_valid_custom_booru_url(self, value: Any) -> bool:
        url = self._normalize_custom_booru_url(value)
        if not url:
            return False
        parsed = urlparse(url)
        return (
            parsed.scheme in ("http", "https")
            and bool(parsed.netloc)
            and bool(parsed.hostname)
            and self._is_valid_custom_booru_hostname(parsed.hostname)
        )

    def _serialize_custom_booru(self, source: CustomBooruSource) -> dict[str, str]:
        return {
            "command": self._normalize_custom_booru_command(source.command),
            "url": self._normalize_custom_booru_url(source.url),
            "login": self._normalize_custom_booru_value(source.login),
            "key": self._normalize_custom_booru_value(source.key),
        }

    def _deserialize_custom_booru(self, raw: Any) -> CustomBooruSource | None:
        if isinstance(raw, CustomBooruSource):
            command = self._normalize_custom_booru_command(raw.command)
            url = self._normalize_custom_booru_url(raw.url)
            login = self._normalize_custom_booru_value(raw.login)
            key = self._normalize_custom_booru_value(raw.key)
        elif isinstance(raw, dict):
            command = self._normalize_custom_booru_command(raw.get("command"))
            url = self._normalize_custom_booru_url(raw.get("url"))
            login = self._normalize_custom_booru_value(raw.get("login"))
            key = self._normalize_custom_booru_value(raw.get("key"))
        else:
            return None

        if not command or not url:
            return None

        return CustomBooruSource(command, url, login or None, key or None)

    def _get_custom_booru_sources(self) -> list[CustomBooruSource]:
        raw_sources = self.get_setting("custom_booru_sources", [])
        if not isinstance(raw_sources, list):
            log(f"{LOG_PREFIX} custom_booru_sources имеет неверный формат; сбрасываем поле")
            self.set_setting("custom_booru_sources", [], reload_settings=False)
            return []

        parsed_sources: list[CustomBooruSource] = []
        normalized_payload: list[dict[str, str]] = []
        needs_reset = False

        for raw_source in raw_sources:
            parsed = self._deserialize_custom_booru(raw_source)
            if not parsed:
                needs_reset = True
                continue

            serialized = self._serialize_custom_booru(parsed)
            normalized_payload.append(serialized)
            parsed_sources.append(
                CustomBooruSource(
                    serialized["command"],
                    serialized["url"],
                    serialized["login"] or None,
                    serialized["key"] or None,
                )
            )

            if not isinstance(raw_source, dict):
                needs_reset = True
                continue

            raw_normalized = {
                "command": self._normalize_custom_booru_command(raw_source.get("command")),
                "url": self._normalize_custom_booru_url(raw_source.get("url")),
                "login": self._normalize_custom_booru_value(raw_source.get("login")),
                "key": self._normalize_custom_booru_value(raw_source.get("key")),
            }
            if raw_normalized != serialized:
                needs_reset = True

        if needs_reset:
            self.set_setting("custom_booru_sources", normalized_payload, reload_settings=False)

        return parsed_sources

    def _set_custom_booru_sources(self, sources: list[CustomBooruSource], reload_settings: bool = True) -> None:
        payload: list[dict[str, str]] = []
        for source in sources:
            serialized = self._serialize_custom_booru(source)
            if not serialized["command"] or not serialized["url"]:
                continue
            payload.append(serialized)
        self.set_setting("custom_booru_sources", payload, reload_settings=reload_settings)

    def _add_booru_entry(self, _view: Optional[View] = None) -> None:
        log(f"{LOG_PREFIX} попытка добавления боруса")
        command = self._normalize_custom_booru_command(self.get_setting("custom_command", ""))
        url = self._normalize_custom_booru_url(self.get_setting("custom_url", ""))
        login = self._normalize_custom_booru_value(self.get_setting("custom_login", "")) or None
        key = self._normalize_custom_booru_value(self.get_setting("custom_key", "")) or None

        if not command or not url:
            log(f"{LOG_PREFIX} не получилось сохранить борус: без аргумента (command: {command}, url: {url})")
            self._show_error("Заполни команду и URL")
            return
        if not self._is_valid_custom_booru_url(url):
            log(f"{LOG_PREFIX} не получилось сохранить борус: некорректный URL ({url})")
            self._show_error("Некорректный URL")
            return
        if command in BOORU_COMMANDS or command in BotCommand.__members__:
            log(f"{LOG_PREFIX} не получилось сохранить борус: команда конфликтует с дефолтной")
            self._show_error("Команда уже занята")
            return

        configs = self._get_custom_booru_sources()
        for cfg in configs:
            if cfg.command.lower() == command:
                log(f"{LOG_PREFIX} не получилось сохранить борус: уже существует")
                self._show_info("Такой источник уже есть")
                return

        configs.append(CustomBooruSource(command, url, login, key))
        self._set_custom_booru_sources(configs, reload_settings=True)
        log(f"{LOG_PREFIX} сохранили новый борус: {command}")
        self._show_success("Источник добавлен")

    def _confirm_delete_custom_booru(self, command: str, url: str) -> None:
        """Показать подтверждение удаления кастомного booru."""
        def display():
            try:
                current_fragment = get_last_fragment()
                if not current_fragment or not current_fragment.getParentActivity():
                    return

                dialog = AlertDialogBuilder(current_fragment.getParentActivity())
                dialog.set_title("Удалить источник?")
                dialog.set_message(f"{command} — {url}")
                dialog.set_positive_button(
                    "Удалить",
                    lambda _dialog, _which, cmd=command: self._delete_custom_booru(cmd),
                )
                dialog.set_negative_button("Отмена", None)
                dialog.show()
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка показа подтверждения удаления: {error}")

        run_on_ui_thread(display)

    def _show_custom_booru_info(self, config: "CustomBooruSource") -> None:
        """Показать подробную информацию о кастомном booru."""
        def display():
            try:
                current_fragment = get_last_fragment()
                if not current_fragment or not current_fragment.getParentActivity():
                    return

                login_value = config.login or "—"
                key_value = "есть" if config.key else "—"

                dialog = AlertDialogBuilder(current_fragment.getParentActivity())
                dialog.set_title("Информация об источнике")
                dialog.set_message(
                    f"Команда:\n{config.command}\n\n"
                    f"URL:\n{config.url}\n\n"
                    f"Логин:\n{login_value}\n\n"
                    f"API ключ:\n{key_value}"
                )
                dialog.set_positive_button("Ок", None)
                dialog.show()
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка показа информации о источнике: {error}")

        run_on_ui_thread(display)

    def _delete_custom_booru(self, command: str) -> None:
        """Удалить кастомный booru по команде."""
        command_key = self._normalize_custom_booru_command(command)
        if not command_key:
            return

        configs = self._get_custom_booru_sources()
        filtered = [cfg for cfg in configs if cfg.command.lower() != command_key]
        if len(filtered) == len(configs):
            log(f"{LOG_PREFIX} не нашли борус для удаления: {command_key}")
            self._show_info("Источник не найден")
            return

        self._set_custom_booru_sources(filtered, reload_settings=True)
        log(f"{LOG_PREFIX} удалили борус: {command_key}")
        self._show_success("Источник удалён")

    def _show_booru_command_guide(self) -> None:
        """Показать окно с пошаговой инструкцией по добавлению своего booru."""
        def display():
            try:
                current_fragment = get_last_fragment()
                if not current_fragment or not current_fragment.getParentActivity():
                    return

                dialog = AlertDialogBuilder(current_fragment.getParentActivity())
                dialog.set_title("Гайд по команде Booru")
                dialog.set_message(
                    "1) Придумай команду без точки (пример: booru1).\n"
                    "2) Вставь рабочий URL (https://...)\n"
                    "3) Если нужно — укажи логин и ключ\n"
                    "4) Нажми «Сохранить источник»"
                )
                dialog.set_positive_button("Понял", None)
                dialog.set_top_animation(
                    R.raw.boosts, 72, False,
                    Theme.getColor(Theme.key_dialogTopBackground)
                )
                dialog.show()
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка показа гайда по команде Booru: {error}")

        run_on_ui_thread(display)

    def on_plugin_load(self):
        """Вызывается при загрузке плагина."""
        log(f"{LOG_PREFIX} загружается плагин v{__version__}")
        self.add_on_send_message_hook()
        self._register_observer()
        self._show_usage_dialog_once()

    def on_plugin_unload(self):
        """Вызывается при выгрузке плагина."""
        log(f"{LOG_PREFIX} плагин выгружается")
        self._unregister_observer()

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                  ОСНОВНАЯ ЛОГИКА ОБРАБОТКИ КОМАНД                     ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def on_send_message_hook(self, account, params):
        """
        Перехватываем отправку сообщения и обрабатываем команды.

        Процесс:
        1. Извлекаем текст и место отправки
        2. Парсим команду (ищем .команда в начале)
        3. Для BotCommand → отправляем боту в фоне
        4. Для booru команды → запрашиваем API напрямую в фоне
        5. Отменяем оригинальное сообщение (возвращаем CANCEL)
        """
        try:
            message_text: str = getattr(params, "message", "")
            if not message_text or not message_text.startswith("."):
                return HookResult(strategy=HookStrategy.DEFAULT)

            destination_chat_id = self._get_id(params.peer)
            message_tokens = message_text.split()
            parsed_command = self._parse_command(message_tokens)
            if not parsed_command:
                return HookResult(strategy=HookStrategy.DEFAULT)

            log(f"{LOG_PREFIX} перехвачено сообщение: '{message_text}' → команда: {parsed_command}")

            if isinstance(parsed_command, BotCommand):
                run_on_queue(lambda cmd=parsed_command: self._run_bot_command(params, cmd))
                return HookResult(strategy=HookStrategy.CANCEL)
            else:
                search_query = " ".join(message_tokens[1:]).strip()
                run_on_queue(lambda cmd=parsed_command, q=search_query:
                    self._handle_booru_command(destination_chat_id, q, cmd))
                return HookResult(strategy=HookStrategy.CANCEL)

            return HookResult(strategy=HookStrategy.DEFAULT)

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка в перехватчике: {error}")
            return HookResult(strategy=HookStrategy.DEFAULT)

    def _run_bot_command(self, params, command: BotCommand):
        """
        Выполнить команду типа BotCommand (отправить боту).

        Процесс:
        1. Очищаем старые задачи (gc) если их много
        2. Подписываемся на канал и проверяем бота
        3. Отправляем команду боту
        4. Сохраняем задачу в очередь (ждём ответа)
        """
        log(f"{LOG_PREFIX} выполнение команды бота: {command}")
        try:
            self._garbage_collect()
            self._subscribe()

            destination_chat = self._get_id(params.peer)
            reply_to_message_id = getattr(params, "replyToMsgId", None)
            command_message_id = getattr(params, "request_msg_id", None)

            # Отправляем команду боту (.nsfw → /rc)
            bot_command_text = f"/{command.value}"
            send_text(BOT_ID, bot_command_text)

            # Сохраняем в очередь для последующей обработки ответа
            task = PendingTask(
                destination=destination_chat,
                reply_to=reply_to_message_id,
                request_msg_id=command_message_id,
                command=command,
            )
            self._enqueue_task(task)
        except Exception as error:
            log(f"{LOG_PREFIX} ошибка команды бота: {error}")
            self._show_error("Ошибка при выполнении команды")

    def _handle_booru_command(self, destination: int, tags: str, command: str):
        """
        Обработать команду Booru (прямой API запрос).

        Процесс:
        1. Запрашиваем посты по тегам
        2. Выбираем случайный пост
        3. Форматируем красивое сообщение
        4. Скачиваем изображение если нужно
        5. Отправляем результат
        """
        display_tags = tags
        log(f"{LOG_PREFIX} выполнение booru команды: {command} с тегами: '{display_tags}'")
        try:
            self._show_info(BOORU_STATUS_SEARCHING)

            if command == "randb":
                resolved_command, source_info, posts = self._fetch_random_posts(display_tags)
            else:
                fetch_tags = self._apply_ai_filter(command, display_tags)
                posts, source_info = self._fetch_booru_posts(command, fetch_tags)
                resolved_command = command

            if posts is None:
                self._show_error(BOORU_STATUS_FAILED)
                return

            if not posts:
                self._show_error(BOORU_STATUS_EMPTY)
                return

            chosen_post = choice(posts)
            formatted_message, message_entities = self._format_booru_message(
                resolved_command, display_tags, chosen_post, source_info=source_info
            )

            if source_info:
                source_hint = source_info.get("type")
            elif command in BOORU_COMMANDS:
                source_hint = BOORU_COMMANDS[command]
            else:
                source_hint = command
            file_url = self._select_file_url(chosen_post, source_hint)

            if not file_url:
                self._show_error("Не удалось получить файл поста")
                return

            downloaded_file_path: Optional[str] = None
            send_parameters: dict[str, Any] = {
                "peer": destination,
                "entities": message_entities,
            }

            sender_function = send_text
            downloaded_file_path = self._download_file(file_url)
            if not downloaded_file_path:
                self._show_error("Не удалось скачать файл")
                return
            sender_function = send_photo if not self._is_video(file_url) else send_video

            # Подготавливаем параметры отправки
            if sender_function == send_photo:
                send_parameters["caption"] = formatted_message
                send_parameters["file_path"] = downloaded_file_path
                send_parameters["high_quality"] = True
            elif sender_function == send_video:
                send_parameters["caption"] = formatted_message
                send_parameters["file_path"] = downloaded_file_path
            else:
                send_parameters["text"] = formatted_message

            sender_function(**send_parameters)


        except Exception as error:
            log(f"{LOG_PREFIX} ошибка booru команды: {error}\n{traceback.format_exc()}")
            self._show_error(BOORU_STATUS_FAILED)

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                   ЗАПРОСЫ К API BOORU ИСТОЧНИКОВ                      ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _build_source_info(
        self,
        source_type: str,
        base_url: Optional[str] = None,
        label: Optional[str] = None,
        suffix: Optional[str] = None,
    ) -> dict[str, Any]:
        info: dict[str, Any] = {
            "type": source_type,
            "label": label or BOORU_DISPLAY_NAMES.get(source_type, source_type.capitalize()),
        }
        if base_url:
            info["base_url"] = base_url.rstrip("/")
        if suffix:
            info["suffix"] = suffix
        return info

    def _base_url_for_type(self, source_type: str) -> Optional[str]:
        return {
            "gelbooru": "https://gelbooru.com",
            "danbooru": "https://danbooru.donmai.us",
            "rule34": "https://rule34.xxx",
            "yandere": "https://yande.re",
        }.get(source_type)

    def _source_type_from_suffix(self, suffix: str) -> str:
        if suffix == DAPI_SUFFIX:
            return "gelbooru"
        if suffix == ALTERNATE_SUFFIX:
            return "danbooru"
        if suffix == ALTERNATE2_SUFFIX:
            return "yandere"
        return "custom"

    def _fetch_booru_posts(
        self, cmd: str, search_tags: str
    ) -> tuple[list[dict[str, Any]] | None, dict[str, Any] | None]:
        """Главный метод для получения постов с правильного источника."""
        try:
            command_text = str(cmd).lower()
            if command_text in BOORU_COMMANDS:
                log(f"{LOG_PREFIX} {command_text} это дефолт бору")
                if command_text == "gelb":
                    return (
                        self._fetch_gelbooru_posts(search_tags),
                        self._build_source_info("gelbooru", self._base_url_for_type("gelbooru")),
                    )
                if command_text == "danb":
                    return (
                        self._fetch_danbooru_posts(search_tags),
                        self._build_source_info("danbooru", self._base_url_for_type("danbooru")),
                    )
                if command_text == "r34":
                    return (
                        self._fetch_rule34_posts(search_tags),
                        self._build_source_info("rule34", self._base_url_for_type("rule34")),
                    )
                if command_text == "yd":
                    return (
                        self._fetch_yandere_posts(search_tags),
                        self._build_source_info("yandere", self._base_url_for_type("yandere")),
                    )
                if command_text == "randb":
                    return [], None
                return [], None

            custom = next(
                (booru for booru in self._get_custom_booru_sources()
                 if booru.command.lower() == command_text),
                None
            )
            if custom:
                log(f"{LOG_PREFIX} {cmd} это кастом бору")
                return self._fetch_custom_booru(custom, search_tags)

            log(f"{LOG_PREFIX} {cmd} это непонятночто (custom: {custom})")
            return [], None

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка получения постов: {error}")
            return [], None

    def _fetch_gelbooru_posts(self, search_tags: str) -> list[dict[str, Any]] | None:
        """Получить посты с Gelbooru."""
        api_endpoint = "https://gelbooru.com" + DAPI_SUFFIX
        request_params = BOORU_PARAMS | {"limit": 100, "tags": search_tags}
        request_params.update(self._resolve_api_options("gelbooru_api", GELBOORU_PUBLIC_KEY))
        return self._request_booru_posts(api_endpoint, request_params)

    def _fetch_danbooru_posts(self, search_tags: str) -> list[dict[str, Any]] | None:
        """Получить посты с Danbooru."""
        api_endpoint = "https://danbooru.donmai.us" + ALTERNATE_SUFFIX
        request_params = {"limit": 100, "tags": search_tags}
        request_params.update(self._resolve_api_options("danbooru_api", DANBOORU_PUBLIC_KEY))
        return self._request_booru_posts(api_endpoint, request_params)

    def _fetch_rule34_posts(self, search_tags: str) -> list[dict[str, Any]] | None:
        """Получить посты с Rule34."""
        api_endpoint = "https://rule34.xxx" + DAPI_SUFFIX
        request_params = BOORU_PARAMS | {"limit": 100, "tags": search_tags}
        request_params.update(self._resolve_api_options("rule34_api", RULE34_PUBLIC_KEY))
        return self._request_booru_posts(api_endpoint, request_params)

    def _fetch_yandere_posts(self, search_tags: str) -> list[dict[str, Any]] | None:
        """Получить посты с Yandere."""
        api_endpoint = "https://yande.re" + ALTERNATE_SUFFIX
        request_params = {"limit": 100, "tags": search_tags}
        request_params.update(self._resolve_api_options("yandere_api", YANDERE_PUBLIC_KEY))
        return self._request_booru_posts(api_endpoint, request_params)

    def _fetch_custom_booru(
        self, booru: CustomBooruSource, search_tags: Optional[str]
    ) -> tuple[list[dict[str, Any]] | None, dict[str, Any] | None]:
        suffix = self._detect_booru_type(booru)
        if not suffix:
            return None, None

        params: dict[str, str | int] = {}

        if booru.login and booru.key:
            params["login"] = booru.login
            params["api_key"] = booru.key

        if search_tags:
            params["tags"] = search_tags

        params["limit"] = 100
        params |= BOORU_PARAMS

        query = urlencode(params)
        request_url = f"{booru.url}{suffix}?{query}"

        posts = self._request_booru_posts(request_url, None)
        if posts is None:
            log(f"{LOG_PREFIX} не удалось получить посты с бору {booru.command}")
            return None, None

        source_type = self._source_type_from_suffix(suffix)
        source_info = self._build_source_info(
            source_type,
            base_url=booru.url,
            label=booru.command,
            suffix=suffix,
        )
        return posts, source_info



    def _detect_booru_type(self, booru: CustomBooruSource) -> Optional[str]:
        params: dict[str, str | int] = {}

        if booru.login and booru.key:
            params["login"] = booru.login
            params["api_key"] = booru.key

        params["limit"] = 1

        params |= BOORU_PARAMS

        query = urlencode(params)

        for suffix in (DAPI_SUFFIX, ALTERNATE_SUFFIX, ALTERNATE2_SUFFIX):
            request_url = f"{booru.url}{suffix}?{query}"

            try:
                if get(
                    request_url,
                    timeout=5,
                    headers=BOORU_REQUEST_HEADERS,
                ).ok:
                    return suffix
            except RequestException:
                pass

        return None

    def _fetch_random_posts(
        self, search_tags: str
    ) -> tuple[str, dict[str, Any] | None, list[dict[str, Any]] | None]:
        """Получить посты случайного источника (randb)."""
        sources = [
            ("gelb", "gelbooru", self._fetch_gelbooru_posts),
            ("danb", "danbooru", self._fetch_danbooru_posts),
            ("r34", "rule34", self._fetch_rule34_posts),
            ("yd", "yandere", self._fetch_yandere_posts),
        ]

        command_key, source_type, fetcher = choice(sources)
        filtered_tags = self._apply_ai_filter(command_key, search_tags)
        posts = fetcher(filtered_tags)
        label = f"{BOORU_DISPLAY_NAMES.get(source_type, source_type.capitalize())} (randb)"
        source_info = self._build_source_info(
            source_type,
            base_url=self._base_url_for_type(source_type),
            label=label,
        )
        return command_key, source_info, posts

    def _request_booru_posts(
        self, url: str, params: dict[str, Any] | None
    ) -> list[dict[str, Any]] | None:
        """Выполнить HTTP запрос к booru API и вернуть список постов."""
        try:
            http_response: Response = get(
                url,
                params=params,
                headers=BOORU_REQUEST_HEADERS,
                timeout=BOORU_REQUEST_TIMEOUT,
            )
            if not http_response.ok:
                log(
                    f"{LOG_PREFIX} API ответил ошибкой: "
                    f"{http_response.status_code} {http_response.reason}"
                )
                return None

            return self._parse_booru_response(http_response)
        except RequestException as error:
            log(f"{LOG_PREFIX} ошибка запроса API: {error}")
            return None

    def _parse_booru_response(self, response: Response) -> list[dict[str, Any]] | None:
        """Извлечь посты из JSON/XML ответа booru."""
        try:
            payload = response.json()
            if isinstance(payload, dict):
                if "post" in payload:
                    return payload.get("post") or []
                if "posts" in payload:
                    return payload.get("posts") or []
            if isinstance(payload, list):
                return payload
        except ValueError:
            raw_text = (response.text or "").strip()
            if raw_text and raw_text.startswith("<"):
                try:
                    root = ET.fromstring(raw_text)
                    return [node.attrib for node in root.findall(".//post")]
                except ET.ParseError as xml_error:
                    log(f"{LOG_PREFIX} XML parse error: {xml_error}")
                    return None
            if raw_text:
                log(f"{LOG_PREFIX} ответ не похож на JSON/XML: {raw_text[:200]}")
            return None

        return None

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                 УПРАВЛЕНИЕ API КЛЮЧАМИ И НАСТРОЙКАМИ                  ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _parse_api_options(self, raw_api_string: str) -> dict[str, str]:
        """Распарсить строку API параметров в словарь."""
        if not raw_api_string:
            return {}

        parsed_options = {}
        for api_segment in raw_api_string.split("&"):
            if not api_segment or "=" not in api_segment:
                continue
            parameter_key, parameter_value = api_segment.split("=", 1)
            parsed_options[parameter_key.strip()] = parameter_value.strip()

        return parsed_options

    def _resolve_api_options(self, setting_key: str, default_api_string: str) -> dict[str, str]:
        """Получить API параметры из настроек или использовать default."""
        user_api_value = self.get_setting(setting_key, default_api_string)
        return self._parse_api_options(user_api_value)

    def _on_api_key_setting_changed(self, source: ApiKeySource, user_input: str) -> None:
        """Вызывается когда пользователь изменил API ключ."""
        try:
            normalized_input = (user_input or "").strip()

            if not normalized_input:
                run_on_ui_thread(
                    lambda: BulletinHelper.show_info(f"{source.provider_name}: публичный ключ")
                )
                return

            parsed_api_options = self._build_api_options_from_value(normalized_input)
            self._validate_api_key_options(source, parsed_api_options)

            run_on_ui_thread(
                lambda: BulletinHelper.show_success(f"{source.provider_name}: OK")
            )

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка API ключа: {error}")
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(f"{source.provider_name}: {error}")
            )

    def _build_api_options_from_value(self, input_value: str) -> dict[str, str]:
        """Сконвертировать пользовательский ввод в параметры API."""
        parsed_options = self._parse_api_options(input_value)
        if not parsed_options and "=" not in input_value:
            parsed_options = {"api_key": input_value}
        return parsed_options

    def _validate_api_key_options(self, source: ApiKeySource, options: dict[str, str]) -> None:
        """Проверить что API параметры валидны."""
        if not options.get("api_key"):
            raise ValueError("API key not found in options")

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                         ДИАЛОГИ И UI                                  ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _show_api_key_guide(self):
        """Показать диалог с инструкцией по получению API ключей."""
        def display_guide():
            try:
                current_ui_fragment = get_last_fragment()
                if not current_ui_fragment or not current_ui_fragment.getParentActivity():
                    return

                dialog = AlertDialogBuilder(current_ui_fragment.getParentActivity())
                dialog.set_title("Получение API-ключей для booru")
                dialog.set_message(
                    "Пошаговая инструкция:\n\n"
                    "1) Авторизуйся на сайте booru\n"
                    "2) Перейди в My Account\n"
                    "3) Найди секцию API Keys\n"
                    "4) Создай новый ключ\n"
                    "5) Скопируй ключ целиком\n"
                    "6) Вставь его в поле настроек\n"
                )
                dialog.set_positive_button("OK", None)
                dialog.set_top_animation(
                    R.raw.boosts, 72, False,
                    Theme.getColor(Theme.key_dialogTopBackground)
                )
                dialog.show()
            except Exception as ui_error:
                log(f"{LOG_PREFIX} ошибка показа диалога: {ui_error}")

        run_on_ui_thread(display_guide)

    def _open_webview_url(self, url: str) -> None:
        """Открыть URL в системном браузере."""
        try:
            run_on_ui_thread(
                lambda: Browser.openUrl(ApplicationLoader.applicationContext, url, True)
            )
        except Exception as error:
            log(f"{LOG_PREFIX} ошибка открытия URL: {error}")

    def _webview_link(self, display_text: str, target_url: str) -> Text:
        """Создать кликабельный текст-ссылку в настройках."""
        return Text(
            text=display_text,
            accent=True,
            on_click=lambda _: self._open_webview_url(target_url),
        )

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                    ФОРМАТИРОВАНИЕ СООБЩЕНИЙ                           ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _get_text_setting(self, setting_key: str, fallback_value: str) -> str:
        """Получить текстовую настройку безопасно."""
        retrieved_value = self.get_setting(setting_key, fallback_value)
        return fallback_value if retrieved_value is None else str(retrieved_value)

    def _normalize_emoji_id(self, value: Any, fallback_value: int) -> int:
        if value is None:
            return fallback_value
        if isinstance(value, int):
            return value
        if isinstance(value, str):
            trimmed = value.strip()
            if not trimmed:
                return fallback_value
            if trimmed.isdigit():
                try:
                    return int(trimmed)
                except Exception:
                    return fallback_value
        try:
            return int(value)
        except Exception:
            return fallback_value

    def _get_custom_emoji_id(self, setting_key: str, fallback_value: int) -> int:
        return self._normalize_emoji_id(self.get_setting(setting_key, fallback_value), fallback_value)

    def _normalize_rating_value(self, value: Any) -> str:
        normalized = self._normalize_custom_booru_value(value).lower()
        if not normalized:
            return ""
        if ":" in normalized:
            normalized = normalized.split(":", 1)[1]
        normalized = normalized.split()[0]
        rating_map = {
            "g": "generic",
            "gen": "generic",
            "general": "generic",
            "generic": "generic",
            "s": "safe",
            "safe": "safe",
            "sfw": "safe",
            "sens": "sensitive",
            "sensitive": "sensitive",
            "q": "questionable",
            "questionable": "questionable",
            "e": "explicit",
            "explicit": "explicit",
            "nsfw": "explicit",
        }
        return rating_map.get(normalized, "generic")

    def _build_template_line(self, template_string: str, value_to_insert: str) -> tuple[str, int]:
        """Построить строку из шаблона подставляя значение."""
        template_string = "" if template_string is None else str(template_string)
        value_to_insert = "" if value_to_insert is None else str(value_to_insert)

        if "{}" in template_string:
            before_placeholder, after_placeholder = template_string.split("{}", 1)
            final_string = f"{before_placeholder}{value_to_insert}{after_placeholder}"
            offset = _utf16_length(before_placeholder)
            return final_string, offset

        final_string = f"{template_string}{value_to_insert}"
        offset = _utf16_length(template_string)
        return final_string, offset

    def _extract_template_length(self, template_string: str) -> int:
        """Вспомогательная функция для извлечения длины до значения в шаблоне."""
        if "{}" in template_string:
            before_placeholder = template_string.split("{}", 1)[0]
            return _utf16_length(before_placeholder)
        return _utf16_length(template_string)

    def _build_custom_emoji_entity(self, offset: int, document_id: int, alt: str) -> dict[str, Any]:
        if not document_id:
            return {}
        alt = alt or "✨"
        return {
            "cls": TLRPC.TL_messageEntityCustomEmoji,
            "offset": offset,
            "length": _utf16_length(alt),
            "attrs": {"document_id": int(document_id)},
        }

    def _prefix_with_custom_emoji(
        self, text: str, document_id: int, alt: str
    ) -> tuple[str, int, list[dict[str, Any]]]:
        if not document_id:
            return text, 0, []
        alt = alt or "✨"
        prefix = f"{alt} "
        entity = self._build_custom_emoji_entity(0, document_id, alt)
        return f"{prefix}{text}", _utf16_length(prefix), [entity] if entity else []

    def _format_booru_message(
        self,
        booru_source: str,
        search_query: str,
        post_data: dict[str, Any],
        source_info: dict[str, Any] | None = None,
    ) -> tuple[str, list]:
        """Отформатировать красивое сообщение о посте booru."""
        try:
            source_hint = source_info.get("type") if source_info else None
            file_url = self._select_file_url(post_data, source_hint)
            post_url = self._get_post_url(booru_source, post_data, source_info)
            post_tags = self._extract_post_tags(post_data)
            post_rating = self._normalize_rating_value(post_data.get("rating", ""))

            lines: list[dict[str, Any]] = []
            newline_length = _utf16_length("\n")

            def append_line(
                text: str,
                entities_meta: list[dict[str, Any]] | None = None,
            ) -> None:
                lines.append({
                    "text": text,
                    "entities": entities_meta.copy() if entities_meta else [],
                })

            # Заголовок
            if self.get_setting("format_header", True):
                source_label = None
                if source_info:
                    source_label = source_info.get("label") or source_info.get("type")
                if not source_label:
                    if booru_source in BOORU_COMMANDS:
                        source_key = BOORU_COMMANDS[booru_source]
                    else:
                        source_key = str(booru_source)
                    source_label = BOORU_DISPLAY_NAMES.get(
                        source_key,
                        source_key.capitalize(),
                    )
                header_text, _ = self._build_template_line(
                    self._get_text_setting("format_header_label", DEFAULT_HEADER_LABEL),
                    f" • {source_label} • {choice(KAOMOJI)}",
                )
                header_emoji_id = self._get_custom_emoji_id(
                    "emoji_header_id", DEFAULT_HEADER_EMOJI_ID
                )
                header_text, _, header_emoji_entities = self._prefix_with_custom_emoji(
                    header_text, header_emoji_id, DEFAULT_EMOJI_ALTS["header"]
                )
                append_line(
                    header_text,
                    header_emoji_entities + [
                        {
                            "cls": TLRPC.TL_messageEntityTextUrl,
                            "offset": 0,
                            "length": _utf16_length(header_text),
                            "attrs": {"url": f"https://t.me/{CHANNEL_USERNAME}"},
                        }
                    ],
                )

            # Поиск
            if self.get_setting("format_query", True) and search_query:
                query_text, query_value_offset = self._build_template_line(
                    self._get_text_setting("format_query_label", DEFAULT_QUERY_LABEL),
                    search_query,
                )
                query_emoji_id = self._get_custom_emoji_id(
                    "emoji_query_id", DEFAULT_QUERY_EMOJI_ID
                )
                query_text, query_prefix_len, query_emoji_entities = self._prefix_with_custom_emoji(
                    query_text, query_emoji_id, DEFAULT_EMOJI_ALTS["query"]
                )
                append_line(
                    query_text,
                    query_emoji_entities + [
                        {
                            "cls": TLRPC.TL_messageEntityCode,
                            "offset": query_value_offset + query_prefix_len,
                            "length": _utf16_length(search_query),
                        }
                    ],
                )

            # Ссылки
            link_defs: list[dict[str, Any]] = []
            delimiter = " • "
            delimiter_length = _utf16_length(delimiter)
            if file_url and self.get_setting("format_image_file", True):
                label_text = self._get_text_setting(
                    "format_image_file_label", DEFAULT_IMAGE_FILE_LABEL
                )
                link_defs.append({
                    "label": label_text,
                    "url": file_url,
                })
            if post_url and post_url != file_url and self.get_setting("format_image_post", True):
                label_text = self._get_text_setting(
                    "format_image_post_label", DEFAULT_IMAGE_POST_LABEL
                )
                link_defs.append({
                    "label": label_text,
                    "url": post_url,
                })
            if link_defs:
                line_text = delimiter.join(definition["label"] for definition in link_defs)
                links_emoji_id = self._get_custom_emoji_id(
                    "emoji_links_id", DEFAULT_LINKS_EMOJI_ID
                )
                line_text, line_prefix_len, line_emoji_entities = self._prefix_with_custom_emoji(
                    line_text, links_emoji_id, DEFAULT_EMOJI_ALTS["links"]
                )
                link_entities: list[dict[str, Any]] = []
                running_offset = 0
                for index, definition in enumerate(link_defs):
                    label_length = _utf16_length(definition["label"])
                    link_entities.append({
                        "cls": TLRPC.TL_messageEntityTextUrl,
                        "offset": line_prefix_len + running_offset,
                        "length": label_length,
                        "attrs": {"url": definition["url"]},
                    })
                    running_offset += label_length
                    if index < len(link_defs) - 1:
                        running_offset += delimiter_length
                if line_emoji_entities:
                    link_entities = line_emoji_entities + link_entities
                append_line(line_text, link_entities)

            # Теги
            if self.get_setting("format_tags", True) and post_tags:
                tags_text, tags_value_offset = self._build_template_line(
                    self._get_text_setting("format_tags_label", DEFAULT_TAGS_LABEL),
                    post_tags,
                )
                tags_emoji_id = self._get_custom_emoji_id(
                    "emoji_tags_id", DEFAULT_TAGS_EMOJI_ID
                )
                tags_text, tags_prefix_len, tags_emoji_entities = self._prefix_with_custom_emoji(
                    tags_text, tags_emoji_id, DEFAULT_EMOJI_ALTS["tags"]
                )
                append_line(
                    tags_text,
                    tags_emoji_entities + [
                        {
                            "cls": TLRPC.TL_messageEntityBlockquote,
                            "offset": tags_value_offset + tags_prefix_len,
                            "length": _utf16_length(post_tags),
                            "attrs": {"collapsed": True},
                        }
                    ],
                )

            # Рейтинг
            if self.get_setting("format_rating", True) and post_rating:
                rating_key = post_rating
                rating_emoji_id = self._get_custom_emoji_id(
                    f"emoji_rating_{rating_key}_id",
                    DEFAULT_RATING_EMOJI_IDS.get(rating_key, DEFAULT_RATING_EMOJI_IDS["generic"]),
                )
                rating_text, rating_value_offset = self._build_template_line(
                    self._get_text_setting("format_rating_label", DEFAULT_RATING_LABEL),
                    post_rating,
                )
                rating_text, rating_prefix_len, rating_emoji_entities = self._prefix_with_custom_emoji(
                    rating_text, rating_emoji_id, DEFAULT_EMOJI_ALTS.get(rating_key, DEFAULT_EMOJI_ALTS["generic"])
                )
                append_line(
                    rating_text,
                    rating_emoji_entities + [
                        {
                            "cls": TLRPC.TL_messageEntityCode,
                            "offset": rating_value_offset + rating_prefix_len,
                            "length": _utf16_length(post_rating),
                        }
                    ],
                )

            final_message = "\n".join(line["text"] for line in lines)
            message_entities: list = []
            current_offset = 0
            for index, line in enumerate(lines):
                for entity_meta in line["entities"]:
                    entity = entity_meta["cls"]()
                    entity.offset = current_offset + entity_meta["offset"]
                    entity.length = entity_meta["length"]
                    for attr_name, attr_value in entity_meta.get("attrs", {}).items():
                        setattr(entity, attr_name, attr_value)
                    message_entities.append(entity)

                current_offset += _utf16_length(line["text"])
                if index < len(lines) - 1:
                    current_offset += newline_length

            return final_message, message_entities

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка форматирования: {error}")
            return f"{search_query} • {choice(KAOMOJI)}", []

    def _get_post_url(
        self,
        booru_source: str,
        post_data: dict[str, Any],
        source_info: dict[str, Any] | None = None,
    ) -> str:
        """Получить URL поста на booru по данным поста."""
        post_id = post_data.get("id") or post_data.get("post_id")
        if not post_id:
            return ""

        source_type = None
        base_url = None
        suffix = None
        if source_info:
            source_type = source_info.get("type")
            base_url = source_info.get("base_url")
            suffix = source_info.get("suffix")

        if not source_type:
            if booru_source in BOORU_COMMANDS:
                source_type = BOORU_COMMANDS[booru_source]
            else:
                source_type = str(booru_source)

        if not base_url:
            base_url = self._base_url_for_type(source_type)

        if not base_url:
            return ""

        base_url = base_url.rstrip("/")

        if suffix == DAPI_SUFFIX or source_type in ("gelbooru", "rule34"):
            return f"{base_url}/index.php?page=post&s=view&id={post_id}"
        if suffix == ALTERNATE_SUFFIX or source_type == "danbooru":
            return f"{base_url}/posts/{post_id}"
        if suffix == ALTERNATE2_SUFFIX or source_type == "yandere":
            return f"{base_url}/post/show/{post_id}"

        return ""

    def _select_file_url(self, post_data: dict[str, Any], source_hint: str | None = None) -> str:
        """Выбрать лучший URL файла из поста, подстраиваясь под тип booru."""
        url_fields_by_priority = BOORU_FILE_FIELD_PRIORITY
        for field_name in url_fields_by_priority:
            field_value = post_data.get(field_name)
            if field_value:
                return field_value
        return ""

    def _extract_post_tags(self, post_data: dict[str, Any]) -> str:
        """Извлечь теги из поста."""
        possible_tag_fields = ["tags", "tag_string", "tag_string_general"]
        for field_name in possible_tag_fields:
            tag_value = post_data.get(field_name)
            if isinstance(tag_value, str) and tag_value.strip():
                return tag_value.strip()
        return ""

    def _is_video(self, file_url: str) -> bool:
        """Проверить, является ли файл видео по расширению."""
        file_extension = self._infer_extension(file_url)
        return file_extension in VIDEO_EXTENSIONS

    def _download_file(self, file_url: str) -> Optional[str]:
        """Скачать файл и сохранить в временную папку."""
        log(f"{LOG_PREFIX} скачивание файла: {file_url}")
        try:
            headers = self._build_image_download_headers(file_url)
            with get(file_url, stream=True, timeout=FILE_DOWNLOAD_TIMEOUT, headers=headers) as http_response:
                if not http_response.ok:
                    log(f"{LOG_PREFIX} не удалось скачать файл, статус: {http_response.status_code}")
                    return None

                file_extension = self._infer_extension(file_url)
                temp_file = NamedTemporaryFile(delete=False, suffix=file_extension)

                for data_chunk in http_response.iter_content(CHUNK_SIZE):
                    if data_chunk:
                        temp_file.write(data_chunk)

                temp_file.flush()
                temp_file.close()
                return temp_file.name

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка скачивания: {error}")
            return None

    def _build_image_download_headers(self, file_url: str) -> dict[str, str]:
        """Собрать заголовки для скачивания медиа по ссылке booru."""
        headers = BOORU_IMAGE_HEADERS.copy()
        parsed_url = urlparse(file_url)
        if parsed_url.netloc:
            scheme = parsed_url.scheme or "https"
            headers["Referer"] = f"{scheme}://{parsed_url.netloc}"
        return headers

    def _infer_extension(self, file_url: str) -> str:
        """Получить расширение файла из URL."""
        try:
            url_path = urlparse(file_url).path
            _, file_extension = os.path.splitext(url_path)
            return file_extension if file_extension else ".jpg"
        except Exception:
            return ".jpg"

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║              УПРАВЛЕНИЕ ОЧЕРЕДЬЮ ЗАДАЧ                                ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _enqueue_task(self, task: PendingTask):
        """Добавить задачу в очередь ожидания ответа от бота."""
        with self.task_lock:
            if len(self.pending_tasks) >= self.MAX_PENDING_TASKS:
                self.pending_tasks.popleft()
            self.pending_tasks.append(task)

    def _garbage_collect(self):
        """Очистить старые задачи из очереди если размер превышен."""
        with self.task_lock:
            while len(self.pending_tasks) > self.MAX_PENDING_TASKS:
                self.pending_tasks.popleft()

    def _handle_bot_message(self, message_object: MessageObject):
        """Обработать сообщение, пришедшее от бота."""
        try:
            with self.task_lock:
                if not self.pending_tasks:
                    return
                current_task = self.pending_tasks.popleft()

            message_owner = getattr(message_object, "messageOwner", None)
            if not message_owner:
                return
            self._mark_bot_message_as_read(message_owner)

            original_text = getattr(message_owner, "message", "")

            credits_format = CREDITS.text.format(choice(KAOMOJI))
            final_text = f"{credits_format}\n\n{original_text}" if original_text else credits_format

            entities_list = []
            if hasattr(CREDITS, 'entities') and CREDITS.entities:
                for entity in CREDITS.entities:
                    entities_list.append(entity)

            if hasattr(message_owner, 'entities') and message_owner.entities:
                offset_shift = _utf16_length(credits_format) + _utf16_length("\n\n")
                entities = [message_owner.entities.get(i) for i in range(message_owner.entities.size())]
                for entity in entities:
                    entity_copy = entity.__class__()
                    for attr in dir(entity):
                        if not attr.startswith('_'):
                            try:
                                val = getattr(entity, attr)
                                if not callable(val):
                                    if attr == 'offset':
                                        setattr(entity_copy, attr, val + offset_shift)
                                    else:
                                        setattr(entity_copy, attr, val)
                            except:
                                pass
                    entities_list.append(entity_copy)

            media = getattr(message_owner, "media", None)
            media_params = {}

            if media:
                photo = getattr(media, "photo", None)
                document = getattr(media, "document", None)
                video = getattr(media, "video", None)
                video_note = getattr(media, "video_note", None)

                if photo:
                    media_params["photo"] = photo
                    media_params["caption"] = final_text
                elif video:
                    media_params["video"] = video
                    media_params["caption"] = final_text
                elif video_note:
                    media_params["video_note"] = video_note
                elif document:
                    media_params["document"] = document
                    media_params["caption"] = final_text

            reply_msg = None
            if current_task.reply_to:
                try:
                    messages_controller: MessagesController = get_messages_controller()
                    reply_msg = messages_controller.getMessageObject(
                        current_task.destination,
                        current_task.reply_to,
                        False, 0, False
                    )
                except Exception:
                    pass

            params: dict[str, Any] = {
                "peer": current_task.destination,
            }

            if reply_msg:
                params["replyToMsg"] = reply_msg

            if entities_list:
                params["entities"] = [e.to_tlrpc_object() if hasattr(e, 'to_tlrpc_object') else e
                                     for e in entities_list]

            params.update(media_params)

            if not media_params:
                params["message"] = final_text

            send_message(params)

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка обработки сообщения от бота: {error}")

    def _mark_bot_message_as_read(self, message_owner) -> None:
        """Отметить сообщение от бота как прочитанное в Telegram."""
        try:
            message_id = getattr(message_owner, "id", 0)
            if not message_id:
                return

            bot_peer = self.messagesController.getInputPeer(BOT_ID)
            if not bot_peer:
                return

            read_request = TLRPC.TL_messages_readHistory()
            read_request.peer = bot_peer
            read_request.max_id = message_id

            def on_read_complete(response, error):
                if error:
                    error_text = getattr(error, 'text', str(error))
                    log(f"{LOG_PREFIX} ошибка отмечания прочитанным: {error_text}")

            run_on_queue(
                lambda: send_request(read_request, RequestCallback(on_read_complete))
            )

        except Exception as error:
            log(f"{LOG_PREFIX} ошибка отмечания прочитанным: {error}")

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                 ПРОВЕРКА И ИДЕНТИФИКАЦИЯ СООБЩЕНИЙ                    ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _is_from_bot(self, message_object: MessageObject) -> bool:
        """Проверить, пришло ли сообщение от нашего бота."""
        try:
            message_owner: Optional[TLRPC.Message] = getattr(message_object, "messageOwner", None)
            if not message_owner:
                return False

            # Способ 1: from_id содержит user_id
            sender_info = getattr(message_owner, "from_id", None)
            if sender_info and getattr(sender_info, "user_id", 0) == BOT_ID:
                return True

            # Способ 2: Переложенное сообщение (fwd_from)
            forwarded_info = getattr(message_owner, "fwd_from", None)
            if forwarded_info:
                original_sender = getattr(forwarded_info, "from_id", None)
                if original_sender and getattr(original_sender, "user_id", 0) == BOT_ID:
                    return True

            return False
        except Exception:
            return False

    def _register_observer(self):
        """Зарегистрировать MessageListener для получения уведомлений."""
        if not self.listener:
            try:
                self.listener = MessageListener(self)

                def register_in_ui():
                    account_instance: Optional[AccountInstance] = get_account_instance()
                    if not account_instance:
                        log(f"{LOG_PREFIX} не удалось получить AccountInstance для регистрации слушателя")
                        return
                    notification_center = account_instance.getNotificationCenter()
                    notification_center.addObserver(
                        self.listener,
                        NotificationCenter.didReceiveNewMessages,
                    )

                run_on_ui_thread(register_in_ui)
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка регистрации слушателя: {error}")

    def _unregister_observer(self):
        """Отменить регистрацию MessageListener при выгрузке плагина."""
        if self.listener:
            try:
                def unregister_from_ui():
                    account_instance: Optional[AccountInstance] = get_account_instance()
                    if not account_instance:
                        log(f"{LOG_PREFIX} не удалось получить AccountInstance для отмены регистрации слушателя")
                        return
                    notification_center = account_instance.getNotificationCenter()
                    notification_center.removeObserver(
                        self.listener,
                        NotificationCenter.didReceiveNewMessages,
                    )

                run_on_ui_thread(unregister_from_ui)
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка отмены регистрации: {error}")
            finally:
                self.listener = None

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║         РАБОТА С TELEGRAM PEERS (CHAT IDS, USER IDS, ETC)             ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _get_id(self, peer_object) -> int:
        """Преобразовать объект peer в числовой ID диалога."""
        try:
            if isinstance(peer_object, int):
                return peer_object

            if isinstance(peer_object, TLRPC.TL_inputPeerChannel):
                return to_signed_32(-1000000000000 - peer_object.channel_id)
            elif isinstance(peer_object, TLRPC.TL_inputPeerUser):
                return peer_object.user_id
            elif isinstance(peer_object, TLRPC.TL_inputPeerChat):
                return -peer_object.chat_id
            elif isinstance(peer_object, TLRPC.TL_inputPeerSelf):
                return get_user_config().getClientUserId()
            else:
                return 0
        except Exception:
            return 0

    def _parse_command(self, message_tokens: list[str]) -> BotCommand | str | None:
        """Распарсить первое слово сообщения как команду."""
        try:
            if not message_tokens:
                return None

            first_token = message_tokens[0]
            if not first_token.startswith('.'):
                return None

            command_text = first_token[1:].lower()

            if command_text in BotCommand.__members__:
                return BotCommand[command_text]

            if command_text in BOORU_COMMANDS:
                return command_text

            for source in self._get_custom_booru_sources():
                if source.command.lower() == command_text:
                    return source.command

            return None
        except Exception:
            return None

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║               ПОДПИСКА НА КАНАЛ И ИНИЦИАЛИЗАЦИЯ БОТА                  ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _subscribe(self):
        """Подписать на канал и инициализировать приватного бота если нужно."""
        def perform_subscribe():
            try:
                resolve_request = TLRPC.TL_contacts_resolveUsername()
                resolve_request.username = CHANNEL_USERNAME

                def on_channel_resolved(response, error):
                    try:
                        if error or not response:
                            return

                        chats = getattr(response, "chats", None)
                        if not chats or chats.size() == 0:
                            return

                        channel = chats.get(0)

                        if hasattr(channel, 'left') and not channel.left:
                            self._verifyBot()
                            return

                        join_request = TLRPC.TL_channels_joinChannel()
                        input_channel = TLRPC.TL_inputChannel()
                        input_channel.channel_id = channel.id
                        input_channel.access_hash = channel.access_hash
                        join_request.channel = input_channel

                        def on_joined(response, error):
                            try:
                                if not error:
                                    self._verifyBot()
                            except Exception:
                                pass

                        send_request(join_request, RequestCallback(on_joined))
                    except Exception:
                        pass

                send_request(resolve_request, RequestCallback(on_channel_resolved))
            except Exception:
                pass

        run_on_queue(perform_subscribe)

    def _verifyBot(self) -> None:
        """Проверить наличие бота и инициализировать его если нужно."""
        try:
            existing_dialog = self.messagesController.getDialog(BOT_ID)
            if existing_dialog:
                return

            bot_user = self.messagesController.getUser(BOT_ID)
            if bot_user:
                self.messagesController.sendBotStart(bot_user, "start")
                return

            self.messagesController.resolveUsername(BOT_USERNAME, None)
        except Exception:
            pass

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                         ВЫВОД ОШИБОК                                  ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def _show_error(self, error_message: str) -> None:
        """Показать ошибку пользователю через toast."""
        try:
            run_on_ui_thread(lambda: BulletinHelper.show_error(error_message))
        except Exception as ui_error:
            log(f"{LOG_PREFIX} ошибка показа ошибки: {ui_error}")

    def _show_info(self, message: str) -> None:
        """Показать информационное сообщение пользователю."""
        try:
            run_on_ui_thread(lambda: BulletinHelper.show_info(message))
        except Exception as ui_error:
            log(f"{LOG_PREFIX} ошибка показа уведомления: {ui_error}")

    def _show_success(self, message: str) -> None:
        """Показать успех пользователю."""
        try:
            run_on_ui_thread(lambda: BulletinHelper.show_success(message))
        except Exception as ui_error:
            log(f"{LOG_PREFIX} ошибка показа успеха: {ui_error}")
