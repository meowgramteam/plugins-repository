    def _create_sources_subpage(self) -> list[Any]:
        """Подстраница с источниками и ключами."""
        section: list[Any] = [
            Header("Источники"),
            Text(
                text="Справка по источникам",
                icon="msg_info",
                accent=True,
                on_click=lambda _: self._show_sources_help(),
            ),
            Text(
                text="Как получить API‑ключи",
                icon="msg_settings",
                accent=True,
                on_click=lambda _: self._show_api_key_guide(),
            ),
            Divider(text="Ключи Booru (необязательно)"),
        ]

        for api_source in API_KEY_SOURCES:
            section.append(
                Input(
                    key=api_source.setting_key,
                    text=api_source.text,
                    subtext=api_source.subtext,
                    default=api_source.default,
                    on_change=lambda value, src=api_source:
                        self._on_api_key_setting_changed(src, value),
                )
            )
            section.append(self._webview_link(api_source.link_text, api_source.link_url))

        section.append(Divider(text="Свои источники"))
        section.append(Text(
            text="Гайд по добавлению",
            accent=True,
            icon="msg_info",
            on_click=lambda _: self._show_booru_command_guide(),
        ))
        section.append(Input(
            key="custom_command",
            text="Команда",
            subtext="Пример: booru1",
        ))
        section.append(Input(
            key="custom_url",
            text="URL",
            subtext="Пример: danbooru.donmai.us",
        ))
        section.append(Input(
            key="custom_login",
            text="Логин",
            subtext="Если требуется",
        ))
        section.append(Input(
            key="custom_key",
            text="API ключ",
            subtext="Если требуется",
        ))
        section.append(Text(
            text="Сохранить источник",
            accent=True,
            icon="msg_add",
            on_click=self._add_booru_entry,
        ))

        configs = self._get_custom_booru_sources()
        section.append(Divider(text="Добавленные источники"))
        if configs:
            section.append(Text(
                text="Тап — детали, удерж — удалить",
                accent=False,
            ))
            for config in configs:
                section.append(Text(
                    text=f"{config.command} — {config.url}",
                    accent=False,
                    icon="msg_delete",
                    on_click=lambda _view=None, cfg=config: self._show_custom_booru_info(cfg),
                    on_long_click=lambda _view=None, cmd=config.command, url=config.url:
                        self._confirm_delete_custom_booru(cmd, url)
                ))
        else:
            section.append(Text(
                text="Список пуст",
                accent=False,
            ))

        return section

