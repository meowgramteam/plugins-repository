class NyashnostiPlugin(BasePlugin):
    """
    Основной класс плагина.

    Управляет всеми аспектами работы:
    • Перехват команд из сообщений
    • Отправка команд боту и ожидание ответов
    • Прямые запросы к booru API
    • Форматирование и отправка результатов
    """

    MAX_PENDING_TASKS = MAX_PENDING_TASKS_LIMIT

    def __init__(self):
        super().__init__()
        self.listener: Optional[MessageListener] = None
        self.task_lock = Lock()
        self.pending_tasks: Deque[PendingTask] = deque()
        self.messagesController: MessagesController = get_messages_controller()

    # ╔═══════════════════════════════════════════════════════════════════════╗
    # ║                 ИНТЕГРАЦИЯ С ФРЕЙМВОРКОМ                              ║
    # ╚═══════════════════════════════════════════════════════════════════════╝

    def create_settings(self) -> list[Any]:
        """Создать UI элементы для настроек плагина."""
        settings: list[Any] = []
        settings.extend(self._build_master_section())
        settings.append(Divider())
        settings.append(Header("Расширенные настройки"))
        settings.append(Text(
            text="Источники",
            accent=False,
            icon="photo_star",
            create_sub_fragment=self._create_sources_subpage,
            link_alias="sources_section",
        ))
        settings.append(Text(
            text="Оформление карточки",
            accent=False,
            icon="msg_mention",
            create_sub_fragment=self._create_card_content_subpage,
            link_alias="card_style_section",
        ))
        settings.append(Text(
            text="Фильтр контента",
            accent=False,
            icon="msg_settings",
            create_sub_fragment=self._create_ai_filter_subpage,
            link_alias="content_filter_section",
        ))
        return settings

    def _build_master_section(self) -> list[Any]:
        """Мастер-экран: быстрый старт и подсказки."""
        return [
            Header("Мастер"),
            Text(
                text="3 шага: команды, источн., вид",
                accent=False,
            ),
            Text(
                text="Открыть краткий гайд",
                accent=True,
                icon="msg_settings",
                on_click=lambda _: self._show_usage_dialog(),
            ),
            Text(
                text="Список команд",
                accent=True,
                icon="msg_info",
                on_click=lambda _: self._show_commands_dialog(),
            ),
        ]

    def _show_usage_dialog(self):
        """Показать окно с пошаговой инструкцией по использованию."""
        def display():
            try:
                current_ui_fragment = get_last_fragment()
                if not current_ui_fragment or not current_ui_fragment.getParentActivity():
                    return

                dialog = AlertDialogBuilder(current_ui_fragment.getParentActivity())
                dialog.set_title("Быстрый старт Nyashnosti")
                dialog.set_message(
                    "1) Напиши команду и теги в чате.\n"
                    "   Пример: .danb hatsune_miku rating:s\n"
                    "2) Booru-команды: .gelb .danb .r34 .yd .randb\n"
                    "3) Теги — через пробел. Для исключения: -tag\n"
                    "4) .randb выбирает случайный источник.\n"
                    "5) Свои источники добавляются в «Источники».\n"
                    "6) Бот-команды: .nsfw .sfw .femboy .loli .lolisfw .tead\n"
                    "   Их обрабатывает @ferganteusbot.\n"
                    "7) Если ответа нет — проверь бота в настройках."
                )
                dialog.set_positive_button("Понял", None)
                dialog.set_top_animation(
                    R.raw.boosts, 72, False,
                    Theme.getColor(Theme.key_dialogTopBackground)
                )
                dialog.show()
            except Exception as ui_error:
                log(f"{LOG_PREFIX} ошибка показа инструкции: {ui_error}")

        run_on_ui_thread(display)

    def _show_commands_dialog(self) -> None:
        """Показать список команд с короткими пояснениями."""
        def display():
            try:
                current_ui_fragment = get_last_fragment()
                if not current_ui_fragment or not current_ui_fragment.getParentActivity():
                    return

                bot_lines = [
                    f".{cmd.name} — {BOT_COMMAND_DESCRIPTIONS.get(cmd.name, 'команда бота')}"
                    for cmd in BotCommand
                ]
                booru_lines = [
                    f".{cmd} — {BOORU_COMMAND_DESCRIPTIONS.get(cmd, 'booru поиск')}"
                    for cmd in BOORU_COMMANDS.keys()
                ]

                dialog = AlertDialogBuilder(current_ui_fragment.getParentActivity())
                dialog.set_title("Команды Nyashnosti")
                dialog.set_message(
                    "Бот-команды:\n"
                    + "\n".join(bot_lines)
                    + "\n\nBooru-команды:\n"
                    + "\n".join(booru_lines)
                    + "\n\nПример:\n.danb hatsune_miku rating:s"
                )
                dialog.set_positive_button("Ок", None)
                dialog.show()
            except Exception as error:
                log(f"{LOG_PREFIX} ошибка показа списка команд: {error}")

        run_on_ui_thread(display)

    def _show_usage_dialog_once(self) -> None:
        """Показать инструкцию при первом использовании."""
        try:
            if self.get_setting(FIRST_USE_GUIDE_KEY, False):
                return
            self.set_setting(FIRST_USE_GUIDE_KEY, True, reload_settings=False)
            self._show_usage_dialog()
        except Exception as error:
            log(f"{LOG_PREFIX} ошибка показа инструкции при первом запуске: {error}")

    def _show_custom_emoji_guide(self) -> None:
        """Показать инструкцию по кастомным эмодзи."""
