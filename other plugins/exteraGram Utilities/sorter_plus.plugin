                if holder[0] is not None:
                    holder[0].dismiss()
            except Exception:
                pass
            try:
                action()
            except Exception:
                pass

        move_btn = self._create_md3_button(
            context,
            "Переместить",
            icon_name="msg_retry",
            filled=True,
            danger=False,
            align_left=False,
        )
        move_btn.setOnClickListener(
            OnClickListener(lambda _v: _close_then(lambda: self._enter_move_mode()))
        )
        move_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        move_lp.setMargins(
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(6)),
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
        )
        card.addView(move_btn, move_lp)

        builder.setView(root)
        holder[0] = builder.create()
        self._bind_sheet_swipe_tree(root, touch_state, root, holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, holder, consume_down=True)
        self._show_md3_dialog(holder[0])

    def _on_folder_action(self, folder_id, index):
        if index == 0:
            self._start_edit_folder_flow(folder_id)
        elif index == 1:
            self._open_folder_plugins_editor(folder_id)
        elif index == 2:
            self._confirm_delete_folder(folder_id)

    def _open_add_menu(self):
        self._show_md3_choice_sheet(
            "Создание",
            ["Создать папку", "Создать авто-папку"],
            lambda which: self._start_create_folder_flow() if int(which) == 0 else self._start_create_auto_folder_flow(),
            selected_index=-1,
            danger_index=-1,
            cancel_text="Закрыть",
        )

    def _start_create_folder_flow(self):
        self._ask_folder_name(
            title="Новая папка",
            default_name="Новая папка",
            callback=lambda name: self._pick_folder_icon(lambda icon: self._create_folder(name, icon)),
        )

    def _start_create_auto_folder_flow(self):
        options = []
        kinds = []
        for auto_kind in ("new", "enabled", "disabled"):
            if self._auto_folder_exists(auto_kind):
                continue
            spec = AUTO_FOLDER_RULES.get(auto_kind, {})
            kinds.append(auto_kind)
            options.append(str(spec.get("title", auto_kind)))
        if not options:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Все автопапки уже созданы"))
            return
        self._show_md3_choice_sheet(
            "Автопапка",
            options,
            lambda which: self._create_auto_folder(kinds[int(which)]),
            selected_index=-1,
            danger_index=-1,
            cancel_text="Закрыть",
        )

    def _create_auto_folder(self, auto_kind):
        auto_kind = str(auto_kind or "").strip().lower()
        if auto_kind not in AUTO_FOLDER_RULES:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Неизвестный тип автопапки"))
            return
        if self._auto_folder_exists(auto_kind):
            run_on_ui_thread(lambda: BulletinHelper.show_error("Такая автопапка уже есть"))
            return
        keep_add_end = self._is_add_at_end_slot(len(self._folders))
        folder_id = f"folder_{int(time.time() * 1000)}_{self._folder_counter}"
        self._folder_counter += 1
        spec = AUTO_FOLDER_RULES.get(auto_kind, {})
        self._folders.append(
            {
                "id": folder_id,
                "name": str(spec.get("title", "Автопапка")),
                "icon": str(spec.get("icon", "msg_folder")),
                "color": "",
                "plugins": [],
                "type": "auto",
                "auto_kind": auto_kind,
            }
        )
        if keep_add_end:
            self._add_pill_index = len(self._folders) + 1
        self._selected_folder_id = folder_id
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Автопапка создана"))

    def _start_edit_folder_flow(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return

        self._ask_folder_name(
            title="Редактировать папку",
            default_name=folder.get("name", "Папка"),
            callback=lambda name: self._pick_folder_icon(
                lambda icon: self._update_folder(folder_id, name, icon),
                initial=folder.get("icon", "msg_folder"),
            ),
        )

    def _ask_folder_name(self, title, default_name, callback):
        context = self._dialog_context()
        if context is None:
            return
        self._dbg(f"ask_folder_name: title={title}")

        edit = EditText(context)
        edit.setText(default_name or "")
        edit.setHint("Название папки")
        edit.setSingleLine(True)
        edit.setSelectAllOnFocus(True)
        self._style_input_edittext(edit)
        try:
            edit.setPadding(
                int(AndroidUtilities.dp(14)),
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(14)),
                int(AndroidUtilities.dp(12)),
            )
        except Exception:
            pass

        builder = AlertDialog.Builder(context)
        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.TRANSPARENT)
        root.setPadding(
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(10)),
        )

        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setBackgroundColor(Color.TRANSPARENT)
        root.addView(
            card,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        handle = View(context)
        hbg = GradientDrawable()
        hbg.setCornerRadius(float(AndroidUtilities.dp(3)))
        hbg.setColor(self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x80))
        handle.setBackground(hbg)
        h_lp = LinearLayout.LayoutParams(int(AndroidUtilities.dp(34)), int(AndroidUtilities.dp(5)))
        h_lp.gravity = Gravity.CENTER_HORIZONTAL
        h_lp.setMargins(0, int(AndroidUtilities.dp(10)), 0, int(AndroidUtilities.dp(12)))
        card.addView(handle, h_lp)

        title_tv = TextView(context)
        title_tv.setText(str(title or "Новая папка"))
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setPadding(
            int(AndroidUtilities.dp(18)),
            0,
            int(AndroidUtilities.dp(18)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(
            title_tv,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        input_wrap = FrameLayout(context)
        input_bg = GradientDrawable()
        input_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
        try:
            input_fill = Theme.getColor(getattr(Theme, "key_windowBackgroundWhiteInputField", Theme.key_windowBackgroundWhite))
        except Exception:
            input_fill = self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x22)
        input_bg.setColor(self._with_alpha(int(input_fill), 0xE8))
        try:
            input_stroke = Theme.getColor(getattr(Theme, "key_windowBackgroundWhiteInputFieldActivated", Theme.key_divider))
        except Exception:
            input_stroke = Theme.getColor(Theme.key_divider)
        input_bg.setStroke(int(AndroidUtilities.dp(1)), int(input_stroke))
        input_wrap.setBackground(input_bg)
        iw_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        iw_lp.setMargins(int(AndroidUtilities.dp(16)), 0, int(AndroidUtilities.dp(16)), int(AndroidUtilities.dp(14)))
        card.addView(input_wrap, iw_lp)
        input_wrap.addView(
            edit,
            FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                FrameLayout.LayoutParams.WRAP_CONTENT,
                Gravity.CENTER_VERTICAL,
            ),
        )

        btns = LinearLayout(context)
        btns.setOrientation(LinearLayout.HORIZONTAL)
        btns.setPadding(int(AndroidUtilities.dp(12)), 0, int(AndroidUtilities.dp(12)), int(AndroidUtilities.dp(12)))
        card.addView(
            btns,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        holder = [None]
        touch_state = {"active": False, "drag": False, "y0": 0.0}

        def _done():
            try:
                if holder[0] is not None:
                    holder[0].dismiss()
            except Exception:
                pass
            callback((str(edit.getText()) or "").strip() or "Папка")

        def _cancel():
            try:
                if holder[0] is not None:
                    holder[0].dismiss()
            except Exception:
                pass

        cancel = self._create_md3_button(
            context,
            "Отмена",
            icon_name="msg_cancel",
            filled=False,
            danger=False,
            align_left=False,
        )
        cancel.setOnClickListener(OnClickListener(lambda _v: _cancel()))
        btns.addView(
            cancel,
            LinearLayout.LayoutParams(
                0,
                LinearLayout.LayoutParams.WRAP_CONTENT,
                1.0,
            ),
        )

        spacer = View(context)
        btns.addView(
            spacer,
            LinearLayout.LayoutParams(
                int(AndroidUtilities.dp(8)),
                1,
            ),
        )

        submit = self._create_md3_button(
            context,
            "Далее",
            icon_name="msg_arrowright",
            filled=True,
            danger=False,
            align_left=False,
        )
        submit.setOnClickListener(OnClickListener(lambda _v: _done()))
        btns.addView(
            submit,
            LinearLayout.LayoutParams(
                0,
                LinearLayout.LayoutParams.WRAP_CONTENT,
                1.0,
            ),
        )

        builder.setView(root)
        holder[0] = builder.create()
        self._dbg("ask_folder_name: dialog created")
        self._bind_sheet_swipe_tree(root, touch_state, root, holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, holder, consume_down=True)
        self._show_md3_dialog(holder[0])

    def _pick_folder_icon(self, callback, initial=None):
        context = self._dialog_context()
        if context is None:
            return
        self._dbg(f"pick_folder_icon: initial={initial}")

        icon_choices = self._available_icon_presets()
        builder = AlertDialog.Builder(context)
        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.TRANSPARENT)
        root.setPadding(
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(8)),
        )

        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setBackgroundColor(Color.TRANSPARENT)
        root.addView(
            card,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        handle = View(context)
        hbg = GradientDrawable()
        hbg.setCornerRadius(float(AndroidUtilities.dp(3)))
        hbg.setColor(self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x80))
        handle.setBackground(hbg)
        h_lp = LinearLayout.LayoutParams(int(AndroidUtilities.dp(34)), int(AndroidUtilities.dp(5)))
        h_lp.gravity = Gravity.CENTER_HORIZONTAL
        h_lp.setMargins(0, int(AndroidUtilities.dp(10)), 0, int(AndroidUtilities.dp(12)))
        card.addView(handle, h_lp)

        title_tv = TextView(context)
        title_tv.setText("Иконка папки")
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setPadding(
            int(AndroidUtilities.dp(18)),
            0,
            int(AndroidUtilities.dp(18)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(
            title_tv,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        grid_scroll = ScrollView(context)
        grid_root = LinearLayout(context)
        grid_root.setOrientation(LinearLayout.VERTICAL)
        grid_root.setPadding(
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(6)),
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(6)),
        )
        grid_scroll.addView(
            grid_root,
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.WRAP_CONTENT,
            ),
        )
        gs_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        gs_lp.setMargins(
            int(AndroidUtilities.dp(8)),
            0,
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(grid_scroll, gs_lp)

        selected_bg = Theme.getColor(Theme.key_actionBarTabLine)
        normal_bg = self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhite), 0xEE)
        normal_stroke = Theme.getColor(Theme.key_divider)
        icon_tint = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
        per_row = 6
        row = None
        dialog_holder = [None]
        touch_state = {"active": False, "drag": False, "y0": 0.0}

        for idx, (icon_name, _label) in enumerate(icon_choices):
            if idx % per_row == 0:
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setLayoutParams(
                    LinearLayout.LayoutParams(
                        LinearLayout.LayoutParams.MATCH_PARENT,
                        LinearLayout.LayoutParams.WRAP_CONTENT,
                    )
                )
                row.setPadding(0, 0, 0, int(AndroidUtilities.dp(6)))
                grid_root.addView(row)

            cell = LinearLayout(context)
            cell.setGravity(Gravity.CENTER)
            cell.setLayoutParams(
                LinearLayout.LayoutParams(
                    0,
                    int(AndroidUtilities.dp(42)),
                    1.0,
                )
            )
            cell_lp = cell.getLayoutParams()
            cell_lp.setMargins(int(AndroidUtilities.dp(2)), 0, int(AndroidUtilities.dp(2)), 0)
            cell.setLayoutParams(cell_lp)

            cell_bg = GradientDrawable()
            cell_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
            if icon_name == initial:
                cell_bg.setColor(self._with_alpha(selected_bg, 0x52))
                cell_bg.setStroke(int(AndroidUtilities.dp(1)), self._with_alpha(selected_bg, 0xA8))
            else:
                cell_bg.setColor(normal_bg)
                cell_bg.setStroke(int(AndroidUtilities.dp(1)), self._with_alpha(normal_stroke, 0xD0))
            cell.setBackground(cell_bg)

            icon_res = getattr(R_tg.drawable, icon_name, 0)
            if icon_res:
                iv = ImageView(context)
                iv.setImageResource(icon_res)
                iv.setColorFilter(icon_tint)
                cell.addView(
                    iv,
                    LinearLayout.LayoutParams(
                        int(AndroidUtilities.dp(20)),
                        int(AndroidUtilities.dp(20)),
                    ),
                )
            cell.setOnClickListener(
                OnClickListener(
                    lambda _v, icon_name=icon_name: self._on_icon_pick(
                        icon_name, callback, dialog_holder
                    )
                )
            )
            row.addView(cell)

        close_btn = self._create_md3_button(
            context,
            "Закрыть",
            icon_name="msg_cancel",
            filled=False,
            danger=False,
            align_left=False,
        )
        close_btn.setOnClickListener(
            OnClickListener(lambda _v: dialog_holder[0].dismiss() if dialog_holder[0] is not None else None)
        )
        close_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        close_lp.setMargins(
            int(AndroidUtilities.dp(12)),
            0,
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
        )
        card.addView(close_btn, close_lp)

        builder.setView(root)
        dialog_holder[0] = builder.create()
        self._dbg("pick_folder_icon: dialog created")
        self._bind_sheet_swipe_tree(root, touch_state, root, dialog_holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, dialog_holder, consume_down=True)
        self._show_md3_dialog(dialog_holder[0])

    def _on_icon_pick(self, icon_name, callback, dialog_holder):
        callback(icon_name)
        try:
            if dialog_holder and dialog_holder[0]:
                dialog_holder[0].dismiss()
        except Exception:
            pass

    def _style_input_edittext(self, edit):
        try:
            edit.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        except Exception:
            pass
        try:
            edit.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
        except Exception:
            pass

    def _create_folder(self, name, icon):
        keep_add_end = self._is_add_at_end_slot(len(self._folders))
        folder_id = f"folder_{int(time.time() * 1000)}_{self._folder_counter}"
        self._folder_counter += 1
        self._folders.append(
            {
                "id": folder_id,
                "name": name,
                "icon": icon,
                "color": "",
                "plugins": [],
                "type": "manual",
                "auto_kind": "",
            }
        )
        if keep_add_end:
            self._add_pill_index = len(self._folders) + 1
        self._selected_folder_id = folder_id
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка создана"))

    def _update_folder(self, folder_id, name, icon):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        folder["name"] = name
        folder["icon"] = icon
        folder["type"] = "manual"
        folder["auto_kind"] = ""
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка обновлена"))

    def _confirm_delete_folder(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        self._show_md3_choice_sheet(
            "Удалить папку?",
            [f"Удалить «{folder.get('name', 'Папка')}»", "Отмена"],
            lambda which: self._delete_folder(folder_id) if int(which) == 0 else None,
            danger_index=0,
            cancel_text="Закрыть",
        )

    def _delete_folder(self, folder_id):
        keep_add_end = self._is_add_at_end_slot(len(self._folders))
        self._folders = [f for f in self._folders if f.get("id") != folder_id]
        self._move_order = [fid for fid in (self._move_order or []) if fid != folder_id]
        if self._selected_folder_id == folder_id:
            self._selected_folder_id = "all"
        if keep_add_end:
            self._add_pill_index = len(self._folders) + 1
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка удалена"))

    def _open_folder_plugins_editor(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        if self._is_auto_folder(folder):
            run_on_ui_thread(lambda: BulletinHelper.show_error("Для автопапки выбор плагинов не нужен"))
            return
        self._dbg(f"open_folder_plugins_editor: folder_id={folder_id}")

        all_plugins = self._list_plugins()
        if not all_plugins:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Плагины не найдены"))
            return
        self._dbg(f"open_folder_plugins_editor: plugins={len(all_plugins)}")

        selected = set(folder.get("plugins", []))
        context = self._dialog_context()
        if context is None:
            return

        builder = AlertDialog.Builder(context)
        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.TRANSPARENT)
        root.setPadding(
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(8)),
        )

        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setBackgroundColor(Color.TRANSPARENT)
        root.addView(
            card,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        handle = View(context)
        hbg = GradientDrawable()
        hbg.setCornerRadius(float(AndroidUtilities.dp(3)))
        hbg.setColor(self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x80))
        handle.setBackground(hbg)
        h_lp = LinearLayout.LayoutParams(int(AndroidUtilities.dp(34)), int(AndroidUtilities.dp(5)))
        h_lp.gravity = Gravity.CENTER_HORIZONTAL
        h_lp.setMargins(0, int(AndroidUtilities.dp(10)), 0, int(AndroidUtilities.dp(12)))
        card.addView(handle, h_lp)

        title_tv = TextView(context)
        title_tv.setText(f"{folder.get('name', 'Папка')} • плагины")
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setPadding(
            int(AndroidUtilities.dp(18)),
            0,
            int(AndroidUtilities.dp(18)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(
            title_tv,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        list_scroll = ScrollView(context)
        list_root = LinearLayout(context)
        list_root.setOrientation(LinearLayout.VERTICAL)
        list_root.setPadding(
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(4)),
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(6)),
        )
        list_scroll.addView(
            list_root,
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.WRAP_CONTENT,
            ),
        )
        ls_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            int(AndroidUtilities.dp(340)),
        )
        ls_lp.setMargins(
            int(AndroidUtilities.dp(8)),
            0,
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(list_scroll, ls_lp)

        holder = [None]
        touch_state = {"active": False, "drag": False, "y0": 0.0}
        state = {"dirty": False, "closed": False}

        default_text = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
        secondary_text = Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2)

        def _apply_row_state(bg, title_view, mark_view, is_selected):
            fill, stroke, text_color = self._sheet_button_palette(filled=bool(is_selected), danger=False)
            bg.setColor(int(fill))
            bg.setStroke(int(AndroidUtilities.dp(1)), int(stroke))
            title_view.setTextColor(int(text_color if is_selected else default_text))
            mark_view.setText("✓" if is_selected else "○")
            mark_view.setTextColor(int(text_color if is_selected else secondary_text))

        loading_tv = TextView(context)
        loading_tv.setText("Загрузка плагинов…")
        loading_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        loading_tv.setTextColor(secondary_text)
        loading_tv.setPadding(
            int(AndroidUtilities.dp(20)),
            int(AndroidUtilities.dp(18)),
            int(AndroidUtilities.dp(20)),
            int(AndroidUtilities.dp(18)),
        )
        list_root.addView(
            loading_tv,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        def _commit_changes():
            if state.get("closed"):
                return
            folder["plugins"] = sorted(selected)
            if not state.get("dirty"):
                return
            state["dirty"] = False
            self._save_state()
            self._refresh_plugins_list()

        def _build_row(pid, name):
            row = LinearLayout(context)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(
                int(AndroidUtilities.dp(16)),
                int(AndroidUtilities.dp(11)),
                int(AndroidUtilities.dp(16)),
                int(AndroidUtilities.dp(11)),
            )
            row_bg = GradientDrawable()
            row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            row.setBackground(row_bg)

            title = TextView(context)
            title.setText(str(name or pid))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            row.addView(
                title,
                LinearLayout.LayoutParams(
                    0,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    1.0,
                ),
            )

            mark = TextView(context)
            mark.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            row.addView(
                mark,
                LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                ),
            )

            _apply_row_state(row_bg, title, mark, pid in selected)

            def _toggle(_v, pid=pid, row_bg=row_bg, title=title, mark=mark):
                if pid in selected:
                    selected.remove(pid)
                else:
                    selected.add(pid)
                state["dirty"] = True
                _apply_row_state(row_bg, title, mark, pid in selected)

            row.setOnClickListener(OnClickListener(_toggle))
            row_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            row_lp.setMargins(
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(4)),
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(4)),
            )
            list_root.addView(row, row_lp)

        def _populate_rows(start_index=0):
            if state.get("closed"):
                return
            if int(start_index) == 0:
                try:
                    list_root.removeAllViews()
                except Exception:
                    pass
            chunk = all_plugins[int(start_index): int(start_index) + 28]
            for pid, name in chunk:
                _build_row(pid, name)
            next_index = int(start_index) + len(chunk)
            if next_index < len(all_plugins):
                run_on_ui_thread(lambda: _populate_rows(next_index), 12)

        close_btn = self._create_md3_button(
            context,
            "Готово",
            icon_name="msg_check",
            filled=True,
            danger=False,
            align_left=False,
        )
        close_btn.setOnClickListener(
            OnClickListener(
                lambda _v: (
                    _commit_changes(),
                    holder[0].dismiss() if holder[0] is not None else None,
                )
            )
        )
        close_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        close_lp.setMargins(
            int(AndroidUtilities.dp(12)),
            0,
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
        )
        card.addView(close_btn, close_lp)

        builder.setView(root)
        holder[0] = builder.create()
        dismiss_listener = self._make_dismiss_listener(
            lambda _dialog: (
                _commit_changes(),
                state.__setitem__("closed", True),
                holder.__setitem__(0, None),
            )
        )
        if dismiss_listener is not None:
            try:
                holder[0].setOnDismissListener(dismiss_listener)
            except Exception:
                pass
        self._dbg("open_folder_plugins_editor: dialog created")
        self._bind_sheet_swipe_tree(root, touch_state, root, holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, holder, consume_down=True)
        self._show_md3_dialog(holder[0])
        run_on_ui_thread(lambda: _populate_rows(0), 16)

    def _list_plugins(self, force=False):
        result = []
        now = time.time()
        if (not force) and self._plugins_cache and (now - float(self._plugins_cache_ts or 0.0) <= 8.0):
            return list(self._plugins_cache)
        try:
            controller = PluginsController.getInstance()
            plugins_map = controller.plugins
            keys = plugins_map.keySet().toArray()
            for key in keys:
                plugin = plugins_map.get(key)
                if plugin is None:
                    continue
                pid = str(plugin.getId())
                name = str(plugin.getName() or pid)
                result.append((pid, name))
        except Exception as e:
            self._dbg(f"_list_plugins error: {e}")
        result.sort(key=lambda x: x[1].lower())
        self._plugins_cache = list(result)
        self._plugins_cache_ts = now
        return list(result)

    def _refresh_plugins_list(self):
        activity = self._stored_activity
        if activity is None:
            return

        def _run():
            try:
                list_view = get_private_field(activity, "listView")
                if list_view and list_view.adapter:
                    list_view.adapter.update(True)
            except Exception as e:
                self._dbg(f"refresh error: {e}")

        run_on_ui_thread(_run)

    def _find_folder(self, folder_id):
        for folder in self._folders:
            if folder.get("id") == folder_id:
                return folder
        return None

    def _available_icon_presets(self):
        out = []
        for icon_name, label in ICON_PRESETS:
            try:
                if getattr(R_tg.drawable, icon_name, 0):
                    out.append((icon_name, label))
            except Exception:
                pass
        if len(out) % 2 != 0:
            used = {name for name, _ in out}
            for icon_name, label in [
                ("msg_contacts", "Контакты"),
                ("msg_saved", "Избранное"),
                ("msg_link", "Ссылка"),
                ("msg_info", "Инфо"),
            ]:
                try:
                    if icon_name in used:
                        continue
                    if getattr(R_tg.drawable, icon_name, 0):
                        out.append((icon_name, label))
                        break
                except Exception:
                    pass
        if not out:
            out = [("msg_folder", "Папка")]
        return out

    def _dialog_context(self):
        if self._stored_context is not None:
            return self._stored_context
        fragment = get_last_fragment()
        if fragment:
            try:
                return fragment.getParentActivity()
            except Exception:
                return None
        return None

    def _state_backup_path(self):
        try:
            if self._stored_context is not None:
                files_dir = self._stored_context.getFilesDir()
                if files_dir is not None:
                    path = os.path.join(str(files_dir.getAbsolutePath()), f"{__id__}_state.json")
                    if path:
                        return path
        except Exception:
            pass
        try:
            home = os.path.expanduser("~")
            if home:
                return os.path.join(home, f".{__id__}_state.json")
        except Exception:
            pass
        return f"{__id__}_state.json"

    def _read_state_backup(self):
        path = self._state_backup_path()
        if not path:
            return {}
        try:
            if not os.path.exists(path):
                return {}
        except Exception:
            return {}
        try:
            with open(path, "r", encoding="utf-8") as fh:
                data = json.load(fh)
            return data if isinstance(data, dict) else {}
        except Exception as e:
            self._dbg(f"read_state_backup error: {e}")
            return {}

    def _write_state_backup(self):
        path = self._state_backup_path()
        if not path:
            return
        try:
            parent = os.path.dirname(path)
            if parent:
                os.makedirs(parent, exist_ok=True)
        except Exception:
            pass
        try:
            with open(path, "w", encoding="utf-8") as fh:
                json.dump(
                    {
                        "folders": self._folders,
                        "selected_folder_id": self._selected_folder_id,
                        "sort_mode": self._sort_mode,
                        "folder_counter": int(self._folder_counter),
                        "all_pill_index": int(self._all_pill_index),
                        "add_pill_index": int(self._add_pill_index),
                    },
                    fh,
                    ensure_ascii=False,
                )
        except Exception as e:
            self._dbg(f"write_state_backup error: {e}")

    def _normalize_folder(self, folder):
        if not isinstance(folder, dict):
            return None
        fid = str(folder.get("id", "") or "").strip()
        if not fid:
            return None
        folder_type = str(folder.get("type", "manual") or "manual").strip().lower()
        if folder_type not in ("manual", "auto"):
            folder_type = "manual"
        auto_kind = str(folder.get("auto_kind", "") or "").strip().lower()
        if folder_type == "auto":
            if auto_kind not in AUTO_FOLDER_RULES:
                return None
            default_title = AUTO_FOLDER_RULES.get(auto_kind, {}).get("title", "Автопапка")
            default_icon = AUTO_FOLDER_RULES.get(auto_kind, {}).get("icon", "msg_folder")
            plugins = []
        else:
            default_title = "Папка"
            default_icon = "msg_folder"
            plugins = list(folder.get("plugins", []) or [])
        return {
            "id": fid,
            "name": str(folder.get("name", default_title) or default_title),
            "icon": str(folder.get("icon", default_icon) or default_icon),
            "color": str(folder.get("color", "#4F8CFF") or "#4F8CFF"),
            "plugins": plugins,
            "type": folder_type,
            "auto_kind": auto_kind,
        }

    def _folder_type(self, folder):
        try:
            return str(folder.get("type", "manual") or "manual")
        except Exception:
            return "manual"

    def _folder_auto_kind(self, folder):
        try:
            return str(folder.get("auto_kind", "") or "")
        except Exception:
            return ""

    def _is_auto_folder(self, folder):
        return self._folder_type(folder) == "auto"

    def _auto_folder_exists(self, auto_kind):
        for folder in self._folders:
            if self._is_auto_folder(folder) and self._folder_auto_kind(folder) == auto_kind:
                return True
        return False

    def _load_state(self):
        self._folders = []
        self._selected_folder_id = str(self.get_setting("selected_folder_id", "all") or "all")
        self._sort_mode = str(self.get_setting("sort_mode", "default") or "default")
        self._folder_counter = int(self.get_setting("folder_counter", 0) or 0)
        try:
            self._all_pill_index = int(self.get_setting("all_pill_index", 0) or 0)
        except Exception:
            self._all_pill_index = 0
        raw_add_index = self.get_setting("add_pill_index", "__missing__")
        try:
            self._add_pill_index = int(1 if raw_add_index == "__missing__" else (raw_add_index or 1))
        except Exception:
            self._add_pill_index = 1
        add_migrated = bool(self.get_setting("add_pill_migrated", False))

        raw = self.get_setting("folders_json", "")
        backup = self._read_state_backup()
        if not raw and backup:
            raw = json.dumps(backup.get("folders", []) or [], ensure_ascii=False)
            self._selected_folder_id = str(backup.get("selected_folder_id", self._selected_folder_id) or "all")
            self._sort_mode = str(backup.get("sort_mode", self._sort_mode) or "default")
            try:
                self._folder_counter = int(backup.get("folder_counter", self._folder_counter) or 0)
            except Exception:
                pass
            try:
                self._all_pill_index = int(backup.get("all_pill_index", self._all_pill_index) or 0)
            except Exception:
                pass
            try:
                self._add_pill_index = int(backup.get("add_pill_index", self._add_pill_index) or 1)
            except Exception:
                pass
        if not raw:
            return
        try:
            data = json.loads(raw)
            if isinstance(data, list):
                cleaned = []
                for folder in data:
                    normalized = self._normalize_folder(folder)
                    if normalized is not None:
                        cleaned.append(normalized)
                self._folders = cleaned
        except Exception as e:
            self._dbg(f"load_state error: {e}")
            self._folders = []
            if backup:
                try:
                    self._folders = [
                        normalized
                        for normalized in (self._normalize_folder(folder) for folder in backup.get("folders", []) or [])
                        if normalized is not None
                    ]
                except Exception:
                    self._folders = []
        if self._selected_folder_id == AUTO_NEW_FOLDER_ID:
            new_auto = None
            for folder in self._folders:
                if self._is_auto_folder(folder) and self._folder_auto_kind(folder) == "new":
                    new_auto = str(folder.get("id", "") or "")
                    break
            self._selected_folder_id = new_auto or "all"
        max_slot = max(0, len(self._folders) + 1)
        self._all_pill_index = max(0, min(int(self._all_pill_index), max_slot))
        if raw_add_index == "__missing__":
            self._add_pill_index = max_slot
        self._add_pill_index = max(0, min(int(self._add_pill_index), max_slot))
        if (not add_migrated) and self._folders and int(self._add_pill_index) <= 1:
            self._add_pill_index = max_slot
            self.set_setting("add_pill_migrated", True)

    def _save_state(self):
        self.set_setting("folders_json", json.dumps(self._folders, ensure_ascii=False))
        self.set_setting("selected_folder_id", self._selected_folder_id)
        self.set_setting("sort_mode", self._sort_mode)
        self.set_setting("folder_counter", int(self._folder_counter))
        self.set_setting("all_pill_index", int(self._all_pill_index))
        self.set_setting("add_pill_index", int(self._add_pill_index))
        self.set_setting("add_pill_migrated", True)
        self._write_state_backup()
