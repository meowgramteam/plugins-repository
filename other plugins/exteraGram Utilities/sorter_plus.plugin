        root.addView(scroll)
        root.addView(move_apply_wrap)
        root.addView(sort_row)
        outer.addView(root)
        try:
            outer.setClipChildren(False)
            root.setClipChildren(False)
            root.setClipToPadding(False)
        except Exception:
            pass

        self._pills_container = outer
        self._pills_layout = layout
        self._pills_scroll = scroll
        self._sort_plate = sort_plate
        self._move_apply_wrap = move_apply_wrap
        self._move_apply_btn = move_apply_btn
        self._pill_meta = []

    def _ordered_folders(self):
        folders = list(self._folders or [])
        if not self._move_mode or not self._move_order:
            return folders
        by_id = {str(folder.get("id", "")): folder for folder in folders}
        ordered = []
        used = set()
        for folder_id in self._move_order:
            folder = by_id.get(str(folder_id))
            if folder is None:
                continue
            ordered.append(folder)
            used.add(str(folder_id))
        for folder in folders:
            folder_id = str(folder.get("id", ""))
            if folder_id not in used:
                ordered.append(folder)
        return ordered

    def _ordered_pill_tokens(self):
        folder_ids = [str(folder.get("id", "")) for folder in self._ordered_folders() if str(folder.get("id", ""))]
        if self._move_mode and self._move_order:
            ordered = []
            seen = set()
            for token in self._move_order:
                token = str(token or "")
                if token == "all":
                    ordered.append("all")
                    seen.add("all")
                elif token == "add":
                    ordered.append("add")
                    seen.add("add")
                elif token in folder_ids and token not in seen:
                    ordered.append(token)
                    seen.add(token)
            for folder_id in folder_ids:
                if folder_id not in seen:
                    ordered.append(folder_id)
            markers = []
            if "all" not in seen:
                markers.append(("all", int(self._all_pill_index), 0))
            if "add" not in seen:
                markers.append(("add", int(self._add_pill_index), 1))
            for token, idx, order in sorted(markers, key=lambda item: (int(item[1]), int(item[2]))):
                ordered.insert(max(0, min(len(ordered), int(idx))), token)
            return ordered
        ordered = list(folder_ids)
        markers = [
            ("all", int(self._all_pill_index), 0),
            ("add", int(self._add_pill_index), 1),
        ]
        for token, idx, order in sorted(markers, key=lambda item: (int(item[1]), int(item[2]))):
            ordered.insert(max(0, min(len(ordered), int(idx))), token)
        return ordered

    def _is_add_at_end_slot(self, folder_count_before):
        try:
            return int(self._add_pill_index) >= int(folder_count_before) + 1
        except Exception:
            return False

    def _can_reorder_folder_id(self, folder_id):
        if not folder_id:
            return False
        if str(folder_id) in ("all", "add"):
            return True
        return self._find_folder(folder_id) is not None

    def _reorderable_pill_meta(self):
        out = []
        for meta in self._pill_meta:
            try:
                if meta.get("kind") not in ("all", "folder", "add"):
                    continue
                folder_id = meta.get("value")
                if not self._can_reorder_folder_id(folder_id):
                    continue
                out.append(meta)
            except Exception:
                pass
        return out

    def _update_move_apply_ui(self):
        try:
            if self._move_apply_wrap is not None:
                self._move_apply_wrap.setVisibility(View.VISIBLE if self._move_mode else View.GONE)
        except Exception:
            pass
        try:
            if self._sort_plate is not None:
                self._sort_plate.setAlpha(0.55 if self._move_mode else 1.0)
        except Exception:
            pass

    def _start_move_shake(self):
        self._move_anim_token += 1
        token = int(self._move_anim_token)

        def _tick(phase=0):
            if token != int(self._move_anim_token):
                return
            if not self._move_mode:
                for meta in self._reorderable_pill_meta():
                    try:
                        meta["view"].animate().rotation(0.0).setDuration(110).start()
                    except Exception:
                        pass
                return
            active_drag = bool(self._move_drag_state.get("drag", False))
            hold_active = bool(self._move_drag_state.get("hold", False))
            if active_drag or hold_active:
                for meta in self._reorderable_pill_meta():
                    try:
                        meta["view"].animate().cancel()
                    except Exception:
                        pass
                    try:
                        meta["view"].setRotation(0.0)
                    except Exception:
                        pass
                run_on_ui_thread(lambda: _tick(phase + 1), 150)
                return
            angle = -0.7 if (int(phase) % 2 == 0) else 0.7
            active_view = self._move_drag_state.get("view")
            for meta in self._reorderable_pill_meta():
                view = meta.get("view")
                if view is None:
                    continue
                if active_drag and view == active_view:
                    continue
                try:
                    view.animate().rotation(float(angle)).setDuration(170).start()
                except Exception:
                    pass
            run_on_ui_thread(lambda: _tick(phase + 1), 185)

        _tick(0)

    def _enter_move_mode(self):
        self._move_mode = True
        self._move_order = self._ordered_pill_tokens()
        self._move_drag_state = {}
        self._rebuild_pills()
        self._apply_pill_layout_order(immediate=True)
        self._update_move_apply_ui()
        self._start_move_shake()

    def _cancel_move_mode(self, refresh=True):
        self._move_mode = False
        self._move_order = []
        self._move_drag_state = {}
        self._move_anim_token += 1
        if refresh:
            self._rebuild_pills()
            self._refresh_plugins_list()
        else:
            self._update_move_apply_ui()

    def _apply_move_mode(self):
        if not self._move_mode:
            return
        applied_tokens = self._ordered_pill_tokens()
        self._all_pill_index = 0
        self._add_pill_index = max(0, len(applied_tokens) - 1)
        for idx, token in enumerate(applied_tokens):
            if token == "all":
                self._all_pill_index = idx
            elif token == "add":
                self._add_pill_index = idx
        by_id = {str(folder.get("id", "")): folder for folder in self._folders}
        new_folders = []
        used = set()
        for token in applied_tokens:
            if token in ("all", "add"):
                continue
            folder = by_id.get(str(token))
            if folder is None:
                continue
            new_folders.append(folder)
            used.add(str(token))
        for folder in self._folders:
            folder_id = str(folder.get("id", ""))
            if folder_id not in used:
                new_folders.append(folder)
        self._folders = new_folders
        self._move_mode = False
        self._move_order = []
        self._move_drag_state = {}
        self._move_anim_token += 1
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Порядок папок сохранён"))

    def _pill_visual_span(self, view):
        try:
            width = float(view.getWidth() or 0.0)
        except Exception:
            width = 0.0
        if width <= 0.0:
            try:
                width = float(view.getMeasuredWidth() or 0.0)
            except Exception:
                width = 0.0
        left_margin = 0.0
        right_margin = 0.0
        try:
            lp = view.getLayoutParams()
        except Exception:
            lp = None
        if lp is not None:
            try:
                left_margin = float(getattr(lp, "leftMargin", 0) or 0.0)
            except Exception:
                left_margin = 0.0
            try:
                right_margin = float(getattr(lp, "rightMargin", 0) or 0.0)
            except Exception:
                right_margin = 0.0
        return {
            "width": width,
            "left_margin": left_margin,
            "right_margin": right_margin,
            "span": max(0.0, left_margin + width + right_margin),
        }

    def _pill_target_translations(self):
        reorderable = self._reorderable_pill_meta()
        if not reorderable:
            return {}
        meta_by_token = {}
        base_left = None
        for meta in reorderable:
            view = meta.get("view")
            token = str(meta.get("value", "") or "")
            if view is None or not token:
                continue
            try:
                left = float(view.getLeft() or 0.0)
            except Exception:
                left = 0.0
            meta_by_token[token] = {"left": left, "view": view, "span": self._pill_visual_span(view)}
            if base_left is None or left < base_left:
                base_left = left
        if not meta_by_token:
            return {}
        if base_left is None:
            base_left = 0.0
        ordered_tokens = [str(token) for token in (self._move_order or []) if str(token) in meta_by_token]
        for token in meta_by_token:
            if token not in ordered_tokens:
                ordered_tokens.append(token)
        targets = {}
        cursor = float(base_left)
        for idx, token in enumerate(ordered_tokens):
            info = meta_by_token.get(token)
            if info is None:
                continue
            span = info.get("span") or {}
            left_margin = float(span.get("left_margin", 0.0))
            right_margin = float(span.get("right_margin", 0.0))
            width = float(span.get("width", 0.0))
            current_left = float(info.get("left", cursor))
            target_left = float(cursor + left_margin)
            targets[token] = float(target_left - current_left)
            cursor += float(left_margin + width + right_margin)
        return targets

    def _capture_drag_snapshot_centers(self):
        snapshot = {}
        for meta in self._reorderable_pill_meta():
            view = meta.get("view")
            token = str(meta.get("value", "") or "")
            if view is None or not token:
                continue
            try:
                width = float(view.getWidth() or 0.0)
            except Exception:
                width = 0.0
            if width <= 0.0:
                try:
                    width = float(view.getMeasuredWidth() or 0.0)
                except Exception:
                    width = 0.0
            try:
                location = jarray(jclass("int"))(2)
                view.getLocationOnScreen(location)
                center = float(location[0] or 0.0) + (width / 2.0)
            except Exception:
                center = 0.0
            snapshot[token] = float(center)
        return snapshot

    def _apply_pill_layout_order(self, active_view=None, immediate=False):
        reorderable = self._reorderable_pill_meta()
        if not reorderable:
            return
        targets = self._pill_target_translations()
        active_drag = bool(self._move_drag_state.get("drag", False))
        live_reorder = bool(self._move_mode and active_drag and bool(self._move_drag_state.get("reordering", False)))
        for meta in reorderable:
            view = meta.get("view")
            token = str(meta.get("value", "") or "")
            if view is None or not token:
                continue
            if active_drag and view == active_view:
                continue
            target_tx = float(targets.get(token, 0.0))
            if immediate or live_reorder:
                try:
                    view.setTranslationX(float(target_tx))
                except Exception:
                    pass
                continue
            try:
                view.animate().cancel()
            except Exception:
                pass
            try:
                view.animate().translationX(float(target_tx)).setDuration(80).start()
            except Exception:
                try:
                    view.setTranslationX(float(target_tx))
                except Exception:
                    pass

    def _drag_global_center_x(self, drag_view, raw_x, state):
        try:
            finger_raw = float(raw_x if raw_x is not None else 0.0)
        except Exception:
            finger_raw = 0.0
        try:
            offset = float(state.get("finger_offset", 0.0))
        except Exception:
            offset = 0.0
        try:
            width = float(drag_view.getWidth() or 0.0)
        except Exception:
            width = 0.0
        if width <= 0.0:
            try:
                width = float(drag_view.getMeasuredWidth() or 0.0)
            except Exception:
                width = 0.0
        if width <= 0.0:
            width = float(AndroidUtilities.dp(PILL_WIDTH_DP))
        return float(finger_raw - offset + (width * 0.5))

    def _drag_translation_for_raw_x(self, drag_view, raw_x, state):
        try:
            finger_raw = float(raw_x if raw_x is not None else 0.0)
        except Exception:
            finger_raw = 0.0
        try:
            offset = float(state.get("finger_offset", 0.0))
        except Exception:
            offset = 0.0
        try:
            location = jarray(jclass("int"))(2)
            parent = drag_view.getParent()
            if parent is not None:
                parent.getLocationOnScreen(location)
                parent_x = float(location[0] or 0.0)
            else:
                parent_x = 0.0
        except Exception:
            parent_x = 0.0
        try:
            base_left = float(drag_view.getLeft() or 0.0)
        except Exception:
            base_left = 0.0
        desired_left = float(finger_raw - offset - parent_x)
        return float(desired_left - base_left)

    def _maybe_reorder_dragged_pill(self, drag_view, folder_id, raw_x=None, state=None):
        if not self._move_mode:
            return False
        reorderable = self._reorderable_pill_meta()
        if not reorderable:
            return False
        drag_state = state or {}
        reordering_started = bool(drag_state.get("reordering", False))
        target_tx_map = self._pill_target_translations() if reordering_started else {}
        snapshot_centers = drag_state.get("snapshot_centers") or {}
        centers = []
        try:
            drag_width = float(drag_view.getWidth() or 0.0)
        except Exception:
            drag_width = 0.0
        if drag_width <= 0.0:
            try:
                drag_width = float(drag_view.getMeasuredWidth() or 0.0)
            except Exception:
                drag_width = 0.0
        drag_center = self._drag_global_center_x(drag_view, raw_x, drag_state)
        parent_screen_x = 0.0
        if reordering_started:
            try:
                location = jarray(jclass("int"))(2)
                parent = drag_view.getParent()
                if parent is not None:
                    parent.getLocationOnScreen(location)
                    parent_screen_x = float(location[0] or 0.0)
            except Exception:
                parent_screen_x = 0.0
        for meta in reorderable:
            view = meta.get("view")
            value = meta.get("value")
            if view is None or not value:
                continue
            if value == folder_id:
                continue
            try:
                width = float(view.getWidth() or 0.0)
            except Exception:
                width = 0.0
            if width <= 0.0:
                try:
                    width = float(view.getMeasuredWidth() or 0.0)
                except Exception:
                    width = 0.0
            if reordering_started:
                try:
                    center = float(parent_screen_x) + float(view.getLeft()) + float(target_tx_map.get(str(value), 0.0)) + (width / 2.0)
                except Exception:
                    center = 0.0
            else:
                try:
                    center = float(snapshot_centers.get(str(value), float(view.getLeft()) + (width / 2.0)))
                except Exception:
                    center = 0.0
            centers.append((value, center))
        desired_index = 0
        for _value, center in centers:
            if drag_center > center:
                desired_index += 1
        current = [str(fid) for fid in (self._move_order or []) if self._can_reorder_folder_id(fid)]
        if folder_id not in current:
            return False
        current_no_drag = [fid for fid in current if fid != folder_id]
        desired_index = max(0, min(len(current_no_drag), int(desired_index)))
        candidate = list(current_no_drag)
        candidate.insert(desired_index, folder_id)
        if candidate == current:
            return False
        self._move_order = candidate
        if state is not None:
            state["dirty_reorder"] = True
            state["reordering"] = True
        self._apply_pill_layout_order(active_view=drag_view, immediate=True)
        return True

    def _bind_move_pill_touch(self, view, folder_id):
        iface = find_class("android.view.View$OnTouchListener")
        if iface is None or view is None:
            return
        Proxy = dynamic_proxy(iface)

        class _Drag(Proxy):
            def onTouch(_self, v, event):
                try:
                    action = int(event.getActionMasked())
                    raw_x = float(event.getRawX())
                    state = self._move_drag_state
                    if action == MotionEvent.ACTION_DOWN:
                        state.clear()
                        self._apply_pill_layout_order(immediate=True)
                        state["view"] = view
                        state["folder_id"] = folder_id
                        state["x0"] = raw_x
                        state["hold"] = True
                        try:
                            state["base_tx"] = float(view.getTranslationX())
                        except Exception:
                            state["base_tx"] = 0.0
                        try:
                            location = jarray(jclass("int"))(2)
                            view.getLocationOnScreen(location)
                            state["finger_offset"] = float(raw_x - float(location[0]))
                        except Exception:
                            try:
                                state["finger_offset"] = float(view.getWidth() or 0.0) * 0.5
                            except Exception:
                                state["finger_offset"] = 0.0
                        state["drag"] = False
                        state["reordering"] = False
                        state["dirty_reorder"] = False
                        state["snapshot_centers"] = self._capture_drag_snapshot_centers()
                        for meta in self._reorderable_pill_meta():
                            mv = meta.get("view")
                            if mv is None:
                                continue
                            try:
                                mv.animate().cancel()
                            except Exception:
                                pass
                            try:
                                mv.setRotation(0.0)
                            except Exception:
                                pass
                            try:
                                mv.setScaleX(1.0)
                                mv.setScaleY(1.0)
                                mv.setAlpha(1.0)
                            except Exception:
                                pass
                        try:
                            view.animate().cancel()
                        except Exception:
                            pass
                        try:
                            if self._pills_scroll is not None:
                                self._pills_scroll.requestDisallowInterceptTouchEvent(True)
                        except Exception:
                            pass
                        return True
                    if state.get("view") != view or state.get("folder_id") != folder_id:
                        return False
                    if action == MotionEvent.ACTION_MOVE:
                        dx = self._drag_translation_for_raw_x(view, raw_x, state)
                        if not bool(state.get("drag", False)) and abs(dx) >= float(AndroidUtilities.dp(6)):
                            state["drag"] = True
                            state["hold"] = False
                            try:
                                view.performHapticFeedback(HapticFeedbackConstants.LONG_PRESS)
                            except Exception:
                                pass
                            try:
                                view.bringToFront()
                            except Exception:
                                pass
                        if bool(state.get("drag", False)):
                            try:
                                if self._pills_scroll is not None:
                                    self._pills_scroll.requestDisallowInterceptTouchEvent(True)
                            except Exception:
                                pass
                            view.setRotation(0.0)
                            view.setTranslationX(float(dx))
                            view.setScaleX(1.03)
                            view.setScaleY(1.03)
                            view.setAlpha(1.0)
                            self._maybe_reorder_dragged_pill(view, folder_id, raw_x=raw_x, state=state)
                        return True
                    if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                        had_reorder = bool(state.get("dirty_reorder", False))
                        target_tx = 0.0
                        try:
                            target_tx = float(self._pill_target_translations().get(str(folder_id), 0.0))
                        except Exception:
                            target_tx = 0.0
                        state.clear()
                        try:
                            if self._pills_scroll is not None:
                                self._pills_scroll.requestDisallowInterceptTouchEvent(False)
                        except Exception:
                            pass
                        if had_reorder:
                            self._apply_pill_layout_order(immediate=True, active_view=view)
                        self._apply_pill_layout_order()
                        try:
                            view.animate().translationX(float(target_tx)).scaleX(1.0).scaleY(1.0).alpha(1.0).setDuration(100).start()
                        except Exception:
                            try:
                                view.setTranslationX(float(target_tx))
                                view.setScaleX(1.0)
                                view.setScaleY(1.0)
                                view.setAlpha(1.0)
                            except Exception:
                                pass
                        if self._move_mode:
                            run_on_ui_thread(lambda: self._start_move_shake(), 110)
                        return True
                except Exception:
                    return False
                return False

        view.setOnTouchListener(_Drag())

    def _rebuild_pills(self):
        if self._pills_layout is None:
            return

        self._pills_layout.removeAllViews()
        self._pill_meta = []
        self._update_move_apply_ui()
        pill_views = {}
        all_pill = self._create_pill("Все", "msg_folders")
        self._bind_pill(all_pill, "all", "all", "msg_folders")
        pill_views["all"] = all_pill

        for folder in self._ordered_folders():
            folder_id = str(folder.get("id", "") or "")
            if not folder_id:
                continue
            pill = self._create_pill(folder.get("name", "Папка"), folder.get("icon", "msg_folder"))
            self._bind_pill(
                pill,
                "folder",
                folder_id,
                folder.get("icon", "msg_folder"),
            )
            pill_views[folder_id] = pill

        add_pill = self._create_add_pill()
        self._bind_pill(add_pill, "add", "add", "")
        pill_views["add"] = add_pill

        for token in self._ordered_pill_tokens():
            view = pill_views.get(str(token))
            if view is not None:
                self._pills_layout.addView(view)

        tail_spacer = View(self._stored_context)
        tail_spacer.setLayoutParams(
            LinearLayout.LayoutParams(
                0,
                1,
                1.0,
            )
        )
        self._pills_layout.addView(tail_spacer)

        self._update_pills_visual_state()
        self._update_sort_plate()

    def _pill_display_text(self, text):
        value = re.sub(r"\s+", " ", str(text or "")).strip()
        if not value:
            value = "Папка"
        if len(value) > 25:
            value = value[:24] + "…"
        return value

    def _create_pill(self, text, icon_name):
        context = self._stored_context
        pill = TextView(context)
        pill.setText(self._pill_display_text(text))
        pill.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
        pill.setGravity(Gravity.CENTER)
        pill.setSingleLine(True)
        pill.setMaxLines(1)
        pill.setEllipsize(TextUtils.TruncateAt.END)
        pill.setPadding(
            int(AndroidUtilities.dp(13)),
            0,
            int(AndroidUtilities.dp(13)),
            0,
        )
        lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
        )
        lp.setMargins(int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)), int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)))
        pill.setLayoutParams(lp)
        try:
            pill.setMinWidth(int(AndroidUtilities.dp(52)))
        except Exception:
            pass
        try:
            pill.setMaxWidth(int(AndroidUtilities.dp(236)))
        except Exception:
            pass

        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(PILL_HEIGHT_DP / 2.0)))
        pill.setBackground(bg)
        self._set_pill_icon(pill, icon_name, Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        return pill

    def _set_pill_icon(self, view, icon_name, tint_color):
        try:
            if not icon_name:
                view.setCompoundDrawables(None, None, None, None)
                view.setCompoundDrawablePadding(0)
                return
            icon_res = getattr(R_tg.drawable, icon_name, 0)
            if not icon_res:
                return
            drawable = self._stored_context.getResources().getDrawable(icon_res)
            if drawable is None:
                return
            size = int(AndroidUtilities.dp(14))
            drawable.setBounds(0, 0, size, size)
            try:
                drawable.setTint(tint_color)
            except Exception:
                pass
            view.setCompoundDrawables(drawable, None, None, None)
            view.setCompoundDrawablePadding(int(AndroidUtilities.dp(6)))
        except Exception:
            pass

    def _create_add_pill(self):
        context = self._stored_context
        pill = TextView(context)
        pill.setText("+")
        pill.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        pill.setGravity(Gravity.CENTER)
        pill.setIncludeFontPadding(False)
        pill.setPadding(0, 0, 0, 0)
        try:
            pill.setTranslationY(float(AndroidUtilities.dp(2)))
        except Exception:
            pass
        pill.setSingleLine(True)
        lp = LinearLayout.LayoutParams(
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
        )
        lp.setMargins(int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)), int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)))
        pill.setLayoutParams(lp)
        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        pill.setBackground(bg)
        return pill

    def _bind_pill(self, view, kind, value, icon_name):
        self._pill_meta.append(
            {
                "view": view,
                "kind": kind,
                "value": value,
                "icon": icon_name,
            }
        )
        view.setOnClickListener(OnClickListener(lambda _: self._on_pill_click(kind, value, view)))
        view.setOnLongClickListener(
            OnLongClickListener(lambda _: self._on_pill_long_click(kind, value, view))
        )
        if self._move_mode and kind in ("all", "folder", "add") and self._can_reorder_folder_id(value):
            self._bind_move_pill_touch(view, value)

    def _on_pill_click(self, kind, value, view):
        if self._move_mode:
            return
        self._animate_pill_tap(view)
        if kind == "add":
            self._open_add_menu()
            return
        if kind in ("all", "folder"):
            self._selected_folder_id = value
            self._save_state()
            self._update_pills_visual_state()
            self._refresh_plugins_list()

    def _on_pill_long_click(self, kind, value, view):
        if self._move_mode:
            return True
        try:
            view.performHapticFeedback(HapticFeedbackConstants.LONG_PRESS)
        except Exception:
            pass

        if kind == "folder":
            if value == AUTO_NEW_FOLDER_ID:
                return True
            self._show_folder_actions(value)
            return True
        if kind == "all":
            self._show_all_actions()
            return True
        if kind == "add":
            self._open_add_menu()
            return True
        return False

    def _animate_pill_tap(self, view):
        try:
            view.animate().cancel()
            view.setScaleX(0.96)
            view.setScaleY(0.96)
            view.animate().scaleX(1.0).scaleY(1.0).setDuration(150).start()
        except Exception:
            pass

    def _update_pills_visual_state(self):
        for meta in self._pill_meta:
            view = meta["view"]
            kind = meta["kind"]
            value = meta["value"]
            icon_name = meta["icon"]

            selected = kind in ("all", "folder") and self._selected_folder_id == value
            normal_bg = Theme.getColor(Theme.key_windowBackgroundWhite)
            selected_base = Theme.getColor(Theme.key_actionBarTabLine)
            stroke = Theme.getColor(Theme.key_divider)
            bg = view.getBackground()
            fill_color = normal_bg
            if isinstance(bg, GradientDrawable):
                if selected:
                    fill_color = self._with_alpha(selected_base, 0x52)
                    bg.setStroke(
                        int(AndroidUtilities.dp(1)),
                        self._with_alpha(selected_base, 0xAA),
                    )
                else:
                    bg.setStroke(int(AndroidUtilities.dp(1)), stroke)
                bg.setColor(fill_color)

            selected_text = Theme.getColor(
                getattr(Theme, "key_actionBarTabActiveText", Theme.key_windowBackgroundWhiteBlackText)
            )
            normal_text = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
            text_color = selected_text if selected else normal_text
            view.setTextColor(text_color)
            self._set_pill_icon(view, icon_name, text_color)
            view.setAlpha(1.0 if selected else 0.97)
            view.setScaleY(1.0)
            if self._move_mode and kind in ("all", "folder", "add") and self._can_reorder_folder_id(value):
                try:
                    view.setScaleX(1.0)
                except Exception:
                    pass
        self._update_sort_plate()

    def _with_alpha(self, color, alpha):
        color = self._safe_color_int(color, Color.BLACK)
        return Color.argb(
            int(alpha) & 0xFF,
            Color.red(int(color)),
            Color.green(int(color)),
            Color.blue(int(color)),
        )

    def _safe_color_int(self, value, fallback=0):
        try:
            if isinstance(value, float) and not math.isfinite(value):
                return int(fallback)
        except Exception:
            pass
        try:
            return int(value)
        except Exception:
            try:
                return int(fallback)
            except Exception:
                return 0

    def _blend_colors(self, start_color, end_color, ratio):
        start_color = self._safe_color_int(start_color, Color.BLACK)
        end_color = self._safe_color_int(end_color, start_color)
        try:
            amount = float(ratio)
            if not math.isfinite(amount):
                amount = 0.0
            amount = max(0.0, min(1.0, amount))
        except Exception:
            amount = 0.0
        inv = 1.0 - amount
        def _mix_channel(a, b):
            try:
                value = (float(a) * inv) + (float(b) * amount)
                if not math.isfinite(value):
                    value = float(a)
            except Exception:
                value = float(a)
            try:
                value = max(0.0, min(255.0, value))
            except Exception:
                value = 0.0
            return int(value)
        return Color.argb(
            _mix_channel(Color.alpha(int(start_color)), Color.alpha(int(end_color))),
            _mix_channel(Color.red(int(start_color)), Color.red(int(end_color))),
            _mix_channel(Color.green(int(start_color)), Color.green(int(end_color))),
            _mix_channel(Color.blue(int(start_color)), Color.blue(int(end_color))),
        )

    def _ideal_text_color(self, color):
        color = self._safe_color_int(color, Color.WHITE)
        r = Color.red(int(color))
        g = Color.green(int(color))
        b = Color.blue(int(color))
        yiq = (299 * r + 587 * g + 114 * b) / 1000.0
        return Color.BLACK if yiq >= 160 else Color.WHITE

    def _sheet_surface_color(self):
        try:
            return self._safe_color_int(Theme.getColor(Theme.key_windowBackgroundWhite), Color.WHITE)
        except Exception:
            return Color.WHITE

    def _sheet_accent_color(self):
        try:
            key = getattr(
                Theme,
                "key_windowBackgroundWhiteBlueText",
                getattr(Theme, "key_windowBackgroundWhiteBlueText4", Theme.key_actionBarTabLine),
            )
            return self._safe_color_int(Theme.getColor(key), Theme.getColor(Theme.key_actionBarTabLine))
        except Exception:
            return self._safe_color_int(Theme.getColor(Theme.key_actionBarTabLine), Color.BLACK)

    def _sheet_button_palette(self, filled=False, danger=False):
        surface = self._sheet_surface_color()
        divider = self._safe_color_int(Theme.getColor(Theme.key_divider), surface)
        default_text = self._safe_color_int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText), Color.BLACK)
        accent = self._sheet_accent_color()
        red = self._safe_color_int(
            Theme.getColor(getattr(Theme, "key_text_RedRegular", Theme.key_windowBackgroundWhiteBlackText)),
            accent,
        )
        main = red if danger else accent
        dark_surface = self._ideal_text_color(surface) == Color.WHITE
        if dark_surface:
            neutral_fill = self._with_alpha(Color.WHITE, 0x18)
            neutral_stroke = self._with_alpha(Color.WHITE, 0x2C)
            tinted_fill = self._with_alpha(main, 0x36 if danger else 0x2A)
            tinted_stroke = self._with_alpha(main, 0xD2 if danger else 0xB6)
        else:
            neutral_fill = self._with_alpha(divider, 0x34)
            neutral_stroke = self._with_alpha(divider, 0x92)
            tinted_fill = self._with_alpha(main, 0x24 if danger else 0x1C)
            tinted_stroke = self._with_alpha(main, 0x92 if danger else 0x78)

        if filled:
            fill = tinted_fill
            stroke = tinted_stroke
            text = main
        else:
            fill = neutral_fill
            stroke = tinted_stroke if danger else neutral_stroke
            text = red if danger else default_text
        return int(fill), int(stroke), int(text)

    def _sheet_card_background(self, radius_dp=26):
        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(radius_dp)))
        surface = self._sheet_surface_color()
        divider = self._safe_color_int(Theme.getColor(Theme.key_divider), surface)
        dark_surface = self._ideal_text_color(surface) == Color.WHITE
        bg.setColor(int(surface))
        bg.setStroke(
            int(AndroidUtilities.dp(1)),
            int(self._with_alpha(divider, 0xB0 if dark_surface else 0x78)),
        )
        return bg

    def _sort_mode_title(self):
        for key, title in SORT_MODES:
            if key == self._sort_mode:
                return title
        return SORT_MODES[0][1]

    def _update_sort_plate(self):
        plate = self._sort_plate
        if plate is None:
            return
        fill, stroke, text_color = self._sheet_button_palette(filled=False, danger=False)
        bg = plate.getBackground()
        if isinstance(bg, GradientDrawable):
            bg.setColor(int(fill))
            bg.setStroke(
                int(AndroidUtilities.dp(1)),
                int(stroke),
            )
        plate.setTextColor(int(text_color))
        plate.setText(f"Сортировка: {self._sort_mode_title()}  ▾")
        plate.setVisibility(View.VISIBLE)

    def _to_charseq_array(self, values):
        StringCls = jclass("java.lang.String")
        return jarray(StringCls)([str(v) for v in values])

    def _make_item_click_listener(self, fn):
        iface = find_class("android.content.DialogInterface$OnClickListener")
        if not iface:
            return None
        Proxy = dynamic_proxy(iface)

        class _Listener(Proxy):
            def onClick(self, dialog, which):
                fn(dialog, int(which))

        return _Listener()

    def _make_button_click_listener(self, fn):
        iface = find_class("org.telegram.ui.ActionBar.AlertDialog$OnButtonClickListener")
        if not iface:
            return None
        Proxy = dynamic_proxy(iface)

        class _Listener(Proxy):
            def onClick(self, dialog, which):
                fn(dialog, int(which))

        return _Listener()

    def _make_dismiss_listener(self, fn):
        iface = find_class("android.content.DialogInterface$OnDismissListener")
        if not iface:
            return None
        Proxy = dynamic_proxy(iface)

        class _Listener(Proxy):
            def onDismiss(self, dialog):
                fn(dialog)

        return _Listener()

    def _parse_color(self, hex_color, fallback):
        try:
            return Color.parseColor(str(hex_color))
        except Exception:
            return fallback

    def _show_md3_dialog(self, dialog):
        if dialog is None:
            self._dbg("show_md3_dialog: dialog is None")
            return None
        try:
            dialog.show()
            self._dbg("show_md3_dialog: dialog.show ok")
        except Exception:
            self._dbg("show_md3_dialog: dialog.show failed")
            return dialog
        try:
            window = dialog.getWindow()
            if window is None:
                self._dbg("show_md3_dialog: window is None")
                return dialog
            try:
                lp = window.getAttributes()
                if lp is not None:
                    if hasattr(lp, "gravity"):
                        lp.gravity = int(Gravity.BOTTOM)
                    lp.width = int(getattr(ViewGroup.LayoutParams, "MATCH_PARENT", -1))
                    lp.height = int(getattr(ViewGroup.LayoutParams, "WRAP_CONTENT", -2))
                    window.setAttributes(lp)
            except Exception:
                pass
            try:
                ColorDrawable = jclass("android.graphics.drawable.ColorDrawable")
                window.setBackgroundDrawable(ColorDrawable(Color.TRANSPARENT))
            except Exception:
                pass
            try:
                decor = window.getDecorView()
                if decor is not None:
                    try:
                        decor.setBackgroundColor(Color.TRANSPARENT)
                    except Exception:
                        pass
                    decor.setAlpha(0.0)
                    decor.setTranslationY(float(AndroidUtilities.dp(22.0)))
                    decor.animate().alpha(1.0).translationY(0.0).setDuration(190).start()
                    self._dbg("show_md3_dialog: decor animation started")
                else:
                    self._dbg("show_md3_dialog: decor is None")
            except Exception:
                self._dbg("show_md3_dialog: decor animation failed")
                pass
        except Exception:
            self._dbg("show_md3_dialog: outer failure")
            pass
        return dialog

    def _resolve_sheet_motion_view(self, holder, fallback):
        return fallback

    def _resolve_sheet_decor(self, holder):
        try:
            dialog = holder[0] if holder else None
            if dialog is not None:
                window = dialog.getWindow()
                if window is not None:
                    decor = window.getDecorView()
                    if decor is not None:
                        return decor
        except Exception:
            pass
        return None

    def _bind_sheet_swipe_close(self, target, touch_state, sheet, holder, consume_down=False):
        try:
            if target is None or sheet is None:
                return
            is_sheet = False
            try:
                is_sheet = bool(target == sheet)
            except Exception:
                is_sheet = bool(target is sheet)
            iface = find_class("android.view.View$OnTouchListener")
            if iface is None:
                return
            Proxy = dynamic_proxy(iface)

            class _Swipe(Proxy):
                def onTouch(self, _v, event):
                    try:
                        action = int(event.getActionMasked())
                        if action == MotionEvent.ACTION_DOWN:
                            touch_state["active"] = True
                            touch_state["drag"] = False
                            touch_state["y0"] = float(event.getRawY())
                            touch_state["target"] = _v
                            try:
                                motion_view = self._resolve_sheet_motion_view(holder, sheet)
                                touch_state["base_ty"] = float(motion_view.getTranslationY())
                            except Exception:
                                touch_state["base_ty"] = 0.0
                            try:
                                touch_state["base_alpha"] = float(motion_view.getAlpha())
                            except Exception:
                                touch_state["base_alpha"] = 1.0
                            return True
                        if action == MotionEvent.ACTION_MOVE and touch_state.get("active"):
                            dy = float(event.getRawY()) - float(touch_state.get("y0", 0.0))
                            if dy > float(AndroidUtilities.dp(6.0)) or bool(touch_state.get("drag", False)):
                                touch_state["drag"] = True
                                motion_view = self._resolve_sheet_motion_view(holder, sheet)
                                base_ty = float(touch_state.get("base_ty", 0.0))
                                motion_view.setTranslationY(
                                    min(float(AndroidUtilities.dp(260.0)), max(0.0, base_ty + dy))
                                )
                                try:
                                    fade = max(0.72, float(touch_state.get("base_alpha", 1.0)) - (max(0.0, dy) / float(AndroidUtilities.dp(520.0))))
                                    motion_view.setAlpha(float(fade))
                                except Exception:
                                    pass
                                try:
                                    decor = self._resolve_sheet_decor(holder)
                                    if decor is not None:
                                        decor.setAlpha(max(0.80, 1.0 - (max(0.0, dy) / float(AndroidUtilities.dp(900.0)))))
                                except Exception:
                                    pass
                                return True
                            return True
                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            dy = float(event.getRawY()) - float(touch_state.get("y0", 0.0))
                            drag = bool(touch_state.get("drag", False))
                            touch_state["active"] = False
                            touch_state["drag"] = False
                            if drag:
                                if dy >= float(AndroidUtilities.dp(34.0)):
                                    try:
                                        motion_view = self._resolve_sheet_motion_view(holder, sheet)
                                        current_ty = max(0.0, float(motion_view.getTranslationY()))
                                        try:
                                            motion_height = float(motion_view.getHeight())
                                        except Exception:
                                            motion_height = 0.0
                                        target_y = max(
                                            float(AndroidUtilities.dp(180.0)),
                                            current_ty + max(float(AndroidUtilities.dp(120.0)), motion_height * 0.75),
                                        )
                                        motion_view.animate().translationY(target_y).alpha(0.0).setDuration(210).start()
                                        try:
                                            decor = self._resolve_sheet_decor(holder)
                                            if decor is not None and decor != motion_view:
                                                decor.animate().alpha(0.0).setDuration(210).start()
                                        except Exception:
                                            pass
                                        if holder[0] is not None:
                                            run_on_ui_thread(lambda: holder[0].dismiss(), 215)
                                    except Exception:
                                        try:
                                            if holder[0] is not None:
                                                holder[0].dismiss()
                                        except Exception:
                                            pass
                                else:
                                    try:
                                        motion_view = self._resolve_sheet_motion_view(holder, sheet)
                                        motion_view.animate().translationY(0.0).alpha(1.0).setDuration(190).start()
                                        try:
                                            decor = self._resolve_sheet_decor(holder)
                                            if decor is not None and decor != motion_view:
                                                decor.animate().alpha(1.0).setDuration(190).start()
                                        except Exception:
                                            pass
                                    except Exception:
                                        try:
                                            motion_view = self._resolve_sheet_motion_view(holder, sheet)
                                            motion_view.setTranslationY(0.0)
                                            motion_view.setAlpha(1.0)
                                        except Exception:
                                            pass
                                return True
                            if action == MotionEvent.ACTION_UP:
                                try:
                                    node = _v
                                    safety = 0
                                    while node is not None and safety < 8:
                                        try:
                                            if bool(node.performClick()):
                                                break
                                        except Exception:
                                            pass
                                        try:
                                            parent = node.getParent()
                                            if parent is None:
                                                break
                                            node = parent
                                        except Exception:
                                            break
                                        safety += 1
                                except Exception:
                                    pass
                            return True
                    except Exception:
                        return False
                    return False

            target.setOnTouchListener(_Swipe())
        except Exception:
            pass

    def _bind_sheet_swipe_tree(self, node, touch_state, sheet, holder):
        try:
            if node is None:
                return
            cls_name = ""
            try:
                cls_name = str(node.getClass().getName() or "")
            except Exception:
                cls_name = ""
            if (
                "EditText" not in cls_name
                and "ScrollView" not in cls_name
                and "HorizontalScrollView" not in cls_name
            ):
                self._bind_sheet_swipe_close(node, touch_state, sheet, holder, consume_down=False)
            child_count = 0
            try:
                child_count = int(node.getChildCount() or 0)
            except Exception:
                child_count = 0
            for i in range(child_count):
                try:
                    self._bind_sheet_swipe_tree(node.getChildAt(i), touch_state, sheet, holder)
                except Exception:
                    pass
        except Exception:
            pass

    def _create_md3_button(self, context, text, icon_name=None, filled=False, danger=False, align_left=False):
        btn = TextView(context)
        btn.setText(str(text or ""))
        btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        btn.setSingleLine(True)
        try:
            btn.setEllipsize(TextUtils.TruncateAt.END)
        except Exception:
            pass
        btn.setIncludeFontPadding(False)
        btn.setGravity(int(Gravity.CENTER_VERTICAL | (Gravity.LEFT if align_left else Gravity.CENTER_HORIZONTAL)))
        btn.setPadding(
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
        )
        try:
            btn.setMinHeight(int(AndroidUtilities.dp(38)))
        except Exception:
            pass
        fill, stroke, text_color = self._sheet_button_palette(filled=filled, danger=danger)

        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(18)))
        bg.setColor(int(fill))
        bg.setStroke(int(AndroidUtilities.dp(1)), int(stroke))
        btn.setBackground(bg)
        btn.setTextColor(int(text_color))
        if icon_name:
            self._set_pill_icon(btn, icon_name, int(text_color))
        return btn

    def _show_md3_choice_sheet(
        self,
        title,
        options,
        on_select,
        selected_index=-1,
        danger_index=-1,
        cancel_text="Отмена",
    ):
        context = self._dialog_context()
        if context is None:
            self._dbg(f"show_md3_choice_sheet: no context title={title}")
            return None
        self._dbg(
            f"show_md3_choice_sheet: title={title} options={len(options or [])} selected={selected_index} danger={danger_index}"
        )
        builder = AlertDialog.Builder(context)

        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.TRANSPARENT)
        root.setPadding(
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(8)),
        )
        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setBackgroundColor(Color.TRANSPARENT)
        root.addView(
            card,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        handle = View(context)
        handle_bg = GradientDrawable()
        handle_bg.setCornerRadius(float(AndroidUtilities.dp(3)))
        handle_bg.setColor(self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x80))
        handle.setBackground(handle_bg)
        h_lp = LinearLayout.LayoutParams(int(AndroidUtilities.dp(34)), int(AndroidUtilities.dp(5)))
        h_lp.gravity = Gravity.CENTER_HORIZONTAL
        h_lp.setMargins(0, int(AndroidUtilities.dp(10)), 0, int(AndroidUtilities.dp(12)))
        card.addView(handle, h_lp)

        holder = [None]
        touch_state = {"active": False, "drag": False, "y0": 0.0}

        if title:
            title_tv = TextView(context)
            title_tv.setText(str(title))
            title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
            title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            title_tv.setPadding(
                int(AndroidUtilities.dp(18)),
                0,
                int(AndroidUtilities.dp(18)),
                int(AndroidUtilities.dp(8)),
            )
            card.addView(
                title_tv,
                LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                ),
            )

        def _pick(index):
            try:
                if holder[0] is not None:
                    holder[0].dismiss()
            except Exception:
                pass
            try:
                on_select(int(index))
            except Exception:
                pass

        for idx, label in enumerate(options or []):
            row = LinearLayout(context)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(
                int(AndroidUtilities.dp(14)),
                int(AndroidUtilities.dp(9)),
                int(AndroidUtilities.dp(14)),
                int(AndroidUtilities.dp(9)),
            )
            row_bg = GradientDrawable()
            row_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
            fill, stroke, row_text = self._sheet_button_palette(
                filled=bool(idx == int(selected_index)),
                danger=bool(idx == int(danger_index)),
            )
            row_bg.setColor(int(fill))
            row_bg.setStroke(int(AndroidUtilities.dp(1)), int(stroke))
            row.setBackground(row_bg)

            tv = TextView(context)
            tv.setText(str(label or ""))
            tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            tv.setTextColor(int(row_text))
            row.addView(
                tv,
                LinearLayout.LayoutParams(
                    0,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    1.0,
                ),
            )

            if idx == int(selected_index):
                check = TextView(context)
                check.setText("✓")
                check.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
                check.setTextColor(int(row_text))
                row.addView(
                    check,
                    LinearLayout.LayoutParams(
                        LinearLayout.LayoutParams.WRAP_CONTENT,
                        LinearLayout.LayoutParams.WRAP_CONTENT,
                    ),
                )
            row.setOnClickListener(OnClickListener(lambda _v, i=idx: _pick(i)))
            row_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            row_lp.setMargins(
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(2)),
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(2)),
            )
            card.addView(row, row_lp)

        if cancel_text:
            sep = View(context)
            sep.setBackgroundColor(self._with_alpha(Theme.getColor(Theme.key_divider), 0x88))
            card.addView(
                sep,
                LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    int(AndroidUtilities.dp(1)),
                ),
            )
            cancel = self._create_md3_button(
                context,
                str(cancel_text),
                icon_name="msg_cancel",
                filled=False,
                danger=False,
                align_left=False,
            )
            cancel.setOnClickListener(
                OnClickListener(lambda _v: holder[0].dismiss() if holder[0] is not None else None)
            )
            cancel_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            cancel_lp.setMargins(
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(10)),
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(8)),
            )
            card.addView(cancel, cancel_lp)

        builder.setView(root)
        holder[0] = builder.create()
        self._dbg("show_md3_choice_sheet: dialog created")
        self._bind_sheet_swipe_tree(root, touch_state, root, holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, holder, consume_down=True)
        self._show_md3_dialog(holder[0])
        return holder[0]

    def _open_sort_dialog(self):
        if self._move_mode:
            return
        self._dbg(f"open_sort_dialog: mode={self._sort_mode}")
        options = [title for _key, title in SORT_MODES]
        selected_index = 0
        for idx, (key, _title) in enumerate(SORT_MODES):
            if key == self._sort_mode:
                selected_index = idx
                break
        run_on_ui_thread(
            lambda: self._show_md3_choice_sheet(
                "Сортировка",
                options,
                lambda which: self._set_sort_mode(SORT_MODES[int(which)][0]),
                selected_index=selected_index,
            ),
            16,
        )

    def _set_sort_mode(self, mode):
        self._sort_mode = mode
        self._save_state()
        self._update_pills_visual_state()
        self._refresh_plugins_list()

    def _show_folder_actions(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        self._dbg(f"show_folder_actions: folder_id={folder_id}")
        context = self._dialog_context()
        if context is None:
            return

        builder = AlertDialog.Builder(context)
        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(Color.TRANSPARENT)
        root.setPadding(
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(8)),
        )
        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setBackgroundColor(Color.TRANSPARENT)
        root.addView(
            card,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        handle = View(context)
        hbg = GradientDrawable()
        hbg.setCornerRadius(float(AndroidUtilities.dp(3)))
        hbg.setColor(self._with_alpha(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2), 0x80))
        handle.setBackground(hbg)
        h_lp = LinearLayout.LayoutParams(int(AndroidUtilities.dp(34)), int(AndroidUtilities.dp(5)))
        h_lp.gravity = Gravity.CENTER_HORIZONTAL
        h_lp.setMargins(0, int(AndroidUtilities.dp(10)), 0, int(AndroidUtilities.dp(12)))
        card.addView(handle, h_lp)

        title_tv = TextView(context)
        title_tv.setText(str(folder.get("name", "Папка")))
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setPadding(
            int(AndroidUtilities.dp(18)),
            0,
            int(AndroidUtilities.dp(18)),
            int(AndroidUtilities.dp(10)),
        )
        card.addView(
            title_tv,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        holder = [None]
        touch_state = {"active": False, "drag": False, "y0": 0.0}

        def _close_then(action):
            try:
                if holder[0] is not None:
                    holder[0].dismiss()
            except Exception:
                pass
            try:
                action()
            except Exception:
                pass

        is_auto = self._is_auto_folder(folder)
        if not is_auto:
            add_btn = self._create_md3_button(
                context,
                "Добавить плагины",
                icon_name="msg_add",
                filled=True,
                danger=False,
                align_left=True,
            )
            add_btn.setOnClickListener(
                OnClickListener(lambda _v: _close_then(lambda: self._open_folder_plugins_editor(folder_id)))
            )
            add_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            add_lp.setMargins(
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(6)),
                int(AndroidUtilities.dp(12)),
                int(AndroidUtilities.dp(8)),
            )
            card.addView(add_btn, add_lp)

        row = LinearLayout(context)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        row_lp.setMargins(
            int(AndroidUtilities.dp(12)),
            0,
            int(AndroidUtilities.dp(12)),
            int(AndroidUtilities.dp(8)),
        )
        card.addView(row, row_lp)

        if not is_auto:
            edit_btn = self._create_md3_button(
                context,
                "Редактировать",
                icon_name="msg_edit",
                filled=False,
                danger=False,
                align_left=False,
            )
            edit_btn.setOnClickListener(
                OnClickListener(lambda _v: _close_then(lambda: self._start_edit_folder_flow(folder_id)))
            )
            row.addView(
                edit_btn,
                LinearLayout.LayoutParams(
                    0,
                    LinearLayout.LayoutParams.WRAP_CONTENT,
                    1.0,
                ),
            )

            spacer = View(context)
            row.addView(
                spacer,
                LinearLayout.LayoutParams(
                    int(AndroidUtilities.dp(8)),
                    1,
                ),
            )

        move_btn = self._create_md3_button(
            context,
            "Переместить",
            icon_name="msg_retry",
            filled=False,
            danger=False,
            align_left=False,
        )
        move_btn.setOnClickListener(
            OnClickListener(lambda _v: _close_then(lambda: self._enter_move_mode()))
        )
        row.addView(
            move_btn,
            LinearLayout.LayoutParams(
                0,
                LinearLayout.LayoutParams.WRAP_CONTENT,
                1.0,
            ),
        )

        spacer = View(context)
        row.addView(
            spacer,
            LinearLayout.LayoutParams(
                int(AndroidUtilities.dp(8)),
                1,
            ),
        )

        del_btn = self._create_md3_button(
            context,
            "Удалить",
            icon_name="msg_delete",
            filled=True,
            danger=True,
            align_left=False,
        )
        del_btn.setOnClickListener(
            OnClickListener(lambda _v: _close_then(lambda: self._confirm_delete_folder(folder_id)))
        )
        row.addView(
            del_btn,
            LinearLayout.LayoutParams(
                0,
                LinearLayout.LayoutParams.WRAP_CONTENT,
                1.0,
            ),
        )

        builder.setView(root)
        holder[0] = builder.create()
        self._dbg("show_folder_actions: dialog created")
        self._bind_sheet_swipe_tree(root, touch_state, root, holder)
        self._bind_sheet_swipe_close(handle, touch_state, root, holder, consume_down=True)
        self._show_md3_dialog(holder[0])

