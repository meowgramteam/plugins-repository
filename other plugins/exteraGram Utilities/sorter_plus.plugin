class PluginsFoldersPlus(BasePlugin):
    def __init__(self):
        super().__init__()
        self._hooks = []
        self._folders = []
        self._selected_folder_id = "all"
        self._sort_mode = "default"
        self._stored_context = None
        self._stored_activity = None
        self._pills_container = None
        self._pills_layout = None
        self._pills_scroll = None
        self._sort_plate = None
        self._move_apply_wrap = None
        self._move_apply_btn = None
        self._pill_meta = []
        self._folder_counter = 0
        self._all_pill_index = 0
        self._add_pill_index = 1
        self._self_avatar_bitmap = None
        self._pending_self_install_until = 0.0
        self._modern_spacing_fix_target = None
        self._move_mode = False
        self._move_order = []
        self._move_anim_token = 0
        self._move_drag_state = {}
        self._plugins_cache = []
        self._plugins_cache_ts = 0.0

    def _dbg(self, text):
        try:
            log(f"[Sorter+] {text}")
        except Exception:
            pass

    def on_plugin_load(self):
        self._load_state()
        self._install_hooks()

    def on_plugin_unload(self):
        self._move_mode = False
        self._move_order = []
        self._move_anim_token += 1
        self._move_drag_state = {}
        for hook in list(self._hooks):
            try:
                self.unhook_method(hook)
            except Exception:
                pass
        self._hooks = []
        self._pills_container = None
        self._pills_layout = None
        self._pills_scroll = None
        self._sort_plate = None
        self._move_apply_wrap = None
        self._move_apply_btn = None
        self._pill_meta = []
        self._all_pill_index = 0
        self._add_pill_index = 1
        self._self_avatar_bitmap = None
        self._pending_self_install_until = 0.0
        self._modern_spacing_fix_target = None
        self._plugins_cache = []
        self._plugins_cache_ts = 0.0

    def _reset_all(self):
        self._folders = []
        self._selected_folder_id = "all"
        self._sort_mode = "default"
        self._all_pill_index = 0
        self._add_pill_index = 1
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Сброшено"))

    def _install_hooks(self):
        try:
            PluginsActivity = find_class("com.exteragram.messenger.plugins.ui.PluginsActivity")
            if not PluginsActivity:
                self._dbg("PluginsActivity not found")
                return

            ContextClass = find_class("android.content.Context")
            ArrayListClass = find_class("java.util.ArrayList")
            UniversalAdapterClass = find_class("org.telegram.ui.Components.UniversalAdapter")
            if not (ContextClass and ArrayListClass and UniversalAdapterClass):
                self._dbg("Failed to resolve hook parameter classes")
                return

            create_view = PluginsActivity.getClass().getDeclaredMethod("createView", ContextClass)
            create_view.setAccessible(True)
            fill_items = PluginsActivity.getClass().getDeclaredMethod(
                "fillItems", ArrayListClass, UniversalAdapterClass
            )
            fill_items.setAccessible(True)

            self._hooks.append(self.hook_method(create_view, self._CreateViewHook(self)))
            self._hooks.append(self.hook_method(fill_items, self._FillItemsHook(self)))
            self._install_plugin_cell_hook()
            self._dbg("Hooks installed")
        except Exception as e:
            self._dbg(f"Hook install error: {e}")

    def _install_plugin_cell_hook(self):
        try:
            PluginCell = find_class("com.exteragram.messenger.plugins.ui.components.PluginCell")
            if not PluginCell:
                self._dbg("PluginCell class not found")
                return
            target = None
            methods = PluginCell.getClass().getDeclaredMethods()
            for method in methods:
                if method.getName() != "set":
                    continue
                params = method.getParameterTypes()
                if len(params) == 2:
                    target = method
                    break
            if not target:
                self._dbg("PluginCell.set method not found")
                return
            target.setAccessible(True)
            self._hooks.append(self.hook_method(target, self._PluginCellHook(self)))
        except Exception as e:
            self._dbg(f"PluginCell hook error: {e}")

    def _install_extra_plugin_view_hooks(self):
        for class_name in EXTRA_PLUGIN_VIEW_CLASSES:
            try:
                cls = find_class(class_name)
                if not cls:
                    continue
                hooked = 0
                for method in cls.getClass().getDeclaredMethods():
                    method_name = str(method.getName() or "")
                    if method_name not in ("set", "bind", "setData", "update"):
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    has_plugin_arg = False
                    for param_type in params:
                        try:
                            if "com.exteragram.messenger.plugins.Plugin" in str(param_type.getName() or ""):
                                has_plugin_arg = True
                                break
                        except Exception:
                            pass
                    if not has_plugin_arg:
                        continue
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._GenericPluginViewHook(self)))
                    hooked += 1
                if hooked:
                    self._dbg(f"{class_name}: hooked {hooked} methods")
            except Exception as e:
                self._dbg(f"extra hook error {class_name}: {e}")

    def _install_install_surface_hooks(self):
        for class_name in INSTALL_SURFACE_CLASSES:
            try:
                cls = jclass(class_name)
            except Exception:
                cls = None
            if cls is None:
                continue

            try:
                hooked = 0
                constructors = cls.getDeclaredConstructors()
                for ctor in constructors:
                    params = ctor.getParameterTypes()
                    if len(params) < 2:
                        continue
                    has_install_params = False
                    for p in params:
                        try:
                            if "PluginInstallParams" in str(p.getName() or ""):
                                has_install_params = True
                                break
                        except Exception:
                            pass
                    if not has_install_params:
                        continue
                    ctor.setAccessible(True)
                    self._hooks.append(self.hook_method(ctor, self._InstallSurfaceHook(self)))
                    hooked += 1
                if hooked:
                    self._dbg(f"{class_name}: hooked {hooked} constructors")
            except Exception as e:
                self._dbg(f"install surface hook error {class_name}: {e}")

    def _install_install_context_hooks(self):
        try:
            AndroidUtils = find_class("org.telegram.messenger.AndroidUtilities")
            if AndroidUtils:
                JavaFile = find_class("java.io.File")
                methods = AndroidUtils.getClass().getDeclaredMethods()
                for method in methods:
                    if method.getName() != "openForView":
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    try:
                        if JavaFile is not None and str(params[0].getName() or "") != str(JavaFile.getName() or ""):
                            continue
                    except Exception:
                        pass
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._OpenForViewHook(self)))
        except Exception as e:
            self._dbg(f"openForView hook error: {e}")

        try:
            Engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if Engine:
                methods = Engine.getClass().getDeclaredMethods()
                for method in methods:
                    method_name = str(method.getName() or "")
                    if method_name not in ("validatePluginFromFile", "loadPluginFromFile"):
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    first_param_name = ""
                    try:
                        first_param_name = str(params[0].getName() or "")
                    except Exception:
                        first_param_name = ""
                    if first_param_name != "java.lang.String":
                        continue
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._EnginePathHook(self)))
        except Exception as e:
            self._dbg(f"engine path hook error: {e}")

    def _install_success_bulletin_hook(self):
        try:
            Sheet = None
            try:
                Sheet = jclass("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
            except Exception:
                Sheet = None
            if not Sheet:
                return
            hooked = 0
            for method in Sheet.getClass().getDeclaredMethods():
                if method.getName() != "showSuccessBulletin":
                    continue
                params = method.getParameterTypes()
                if len(params) != 3:
                    continue
                try:
                    p0 = str(params[0].getName() or "")
                    p1 = str(params[1].getName() or "")
                    p2 = str(params[2].getName() or "")
                except Exception:
                    continue
                if "org.telegram.ui.ActionBar.BaseFragment" not in p0:
                    continue
                if "com.exteragram.messenger.plugins.Plugin" not in p1:
                    continue
                if p2 != "boolean":
                    continue
                method.setAccessible(True)
                self._hooks.append(self.hook_method(method, self._InstallSuccessBulletinHook(self)))
                hooked += 1
            if hooked:
                self._dbg(f"Install success bulletin hook: {hooked}")
        except Exception as e:
            self._dbg(f"success bulletin hook error: {e}")

    class _CreateViewHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                if self.plugin._stored_context is not None and self.plugin._stored_context != param.args[0]:
                    self.plugin._cancel_move_mode(refresh=False)
                    self.plugin._pills_container = None
                    self.plugin._pills_layout = None
                    self.plugin._pills_scroll = None
                    self.plugin._sort_plate = None
                    self.plugin._move_apply_wrap = None
                    self.plugin._move_apply_btn = None
                    self.plugin._pill_meta = []
                self.plugin._stored_activity = param.thisObject
                self.plugin._stored_context = param.args[0]
                self.plugin._ensure_pills_container()
                self.plugin._rebuild_pills()
                self.plugin._refresh_plugins_list()
            except Exception as e:
                self.plugin._dbg(f"createView hook error: {e}")

    class _FillItemsHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                items = param.args[0]
                self.plugin._process_fill_items(items)
            except Exception as e:
                self.plugin._dbg(f"fillItems hook error: {e}")

    class _PluginCellHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                try:
                    plugin_obj = param.args[0]
                except Exception:
                    plugin_obj = None
                plugin_id = self.plugin._plugin_id(plugin_obj)
                if not plugin_id:
                    return
                mtime = self.plugin._plugin_mtime(plugin_id)
                if not mtime:
                    return
                stamp = time.strftime("%d.%m.%Y %H:%M", time.localtime(int(mtime) / 1000.0))
                subtitle = get_private_field(param.thisObject, "subtitleView")
                if subtitle is None:
                    return

                desc_view = get_private_field(param.thisObject, "descriptionView")
                if desc_view is None:
                    return
                current_desc_cs = None
                try:
                    current_desc_cs = desc_view.getText()
                except Exception:
                    current_desc_cs = None
                current_desc = str(current_desc_cs or "")
                update_line = f"обновлён {stamp}"
                desc_view.setVisibility(View.VISIBLE)
                try:
                    lm = LinkMovementMethod.getInstance()
                    subtitle.setMovementMethod(lm)
                    desc_view.setMovementMethod(lm)
                    subtitle.setLinksClickable(True)
                    desc_view.setLinksClickable(True)
                except Exception:
                    pass
                try:
                    subtitle_cs = subtitle.getText()
                except Exception:
                    subtitle_cs = None
                subtitle_text = str(subtitle_cs or "")
                is_new = bool(self.plugin._is_recent_mtime(mtime))
                try:
                    if is_new and ("new" not in subtitle_text.lower()):
                        sb_title = SpannableStringBuilder()
                        if subtitle_cs:
                            sb_title.append(subtitle_cs)
                        if subtitle_text.strip():
                            sb_title.append("  ")
                        badge_start = len(sb_title)
                        sb_title.append("NEW")
                        accent_key = getattr(Theme, "key_actionBarTabLine", Theme.key_windowBackgroundWhiteBlackText)
                        sb_title.setSpan(
                            ForegroundColorSpan(Theme.getColor(accent_key)),
                            badge_start,
                            badge_start + 3,
                            Spanned.SPAN_EXCLUSIVE_EXCLUSIVE,
                        )
                        subtitle.setText(sb_title)
                    elif is_new and (not subtitle_text.strip()):
                        subtitle.setText("NEW")
                except Exception:
                    pass
                if is_new:
                    update_line = f"NEW · {update_line}"
                if re.match(
                    r"^(?:NEW\s+·\s+)?обновл[её]н\s+\d{2}\.\d{2}\.\d{4}\s+\d{2}:\d{2}\b",
                    current_desc,
                    flags=re.IGNORECASE,
                ):
                    return
                try:
                    sb = SpannableStringBuilder()
                    sb.append(update_line)
                    sb.append("\n\n")
                    gray_key = getattr(Theme, "key_windowBackgroundWhiteGrayText2", None)
                    if gray_key is None:
                        gray_key = getattr(
                            Theme,
                            "key_windowBackgroundWhiteGrayText",
                            Theme.key_windowBackgroundWhiteBlackText,
                        )
                    gray_color = Theme.getColor(gray_key)
                    sb.setSpan(
                        ForegroundColorSpan(gray_color),
                        0,
                        len(update_line),
                        Spanned.SPAN_EXCLUSIVE_EXCLUSIVE,
                    )
                    if current_desc_cs:
                        sb.append(current_desc_cs)
                    desc_view.setText(sb)
                except Exception:
                    final_desc = f"{update_line}\n\n{current_desc}".strip()
                    desc_view.setText(final_desc)
            except Exception:
                pass

    class _GenericPluginViewHook(MethodHook):
        def __init__(self, plugin):
