# -----------------------------------------------------------------------------
# Small safe helpers
# -----------------------------------------------------------------------------

def _now():
    return time.time()


def _clamp(v, a, b):
    return a if v < a else b if v > b else v


def _jint32(v):
    v = int(v) & 0xFFFFFFFF
    if v >= 0x80000000:
        v -= 0x100000000
    return int(v)


def _safe(obj, method, *args):
    try:
        if obj is None:
            return False
        fn = getattr(obj, method, None)
        if not fn:
            return False
        fn(*args)
        return True
    except Exception:
        return False


def _safe_log(msg):
    try:
        log(msg)
    except Exception:
        pass


