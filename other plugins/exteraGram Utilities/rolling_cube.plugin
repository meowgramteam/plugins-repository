    def _slider_meta(self, key):
        return SLIDER_SETTINGS.get(key, {})

    def _slider_steps(self, meta):
        try:
            return max(1, int(round((float(meta["max"]) - float(meta["min"])) / float(meta["step"]))))
        except Exception:
            return 100

    def _slider_value_from_progress(self, meta, progress):
        try:
            val = float(meta["min"]) + float(progress) * float(meta["step"])
            return _clamp(val, float(meta["min"]), float(meta["max"]))
        except Exception:
            return 0.0

    def _slider_progress_from_value(self, meta, value):
        try:
            return int(round((float(value) - float(meta["min"])) / float(meta["step"])))
        except Exception:
            return 0

    def _slider_raw_value(self, key, default=None):
        try:
            if default is None:
                default = DEFAULT_SETTINGS.get(key, "0")
            return _as_float(self._s(key), default, None, None)
        except Exception:
            return _as_float(DEFAULT_SETTINGS.get(key, "0"), "0", None, None)

    def _slider_format(self, key, value=None):
        meta = self._slider_meta(key)
        if value is None:
            value = self._slider_raw_value(key)
        try:
            step = float(meta.get("step", 0.01))
            suffix = meta.get("suffix", "")
            if step >= 1.0:
                text = str(int(round(float(value))))
            elif step >= 0.1:
                text = ("%.1f" % float(value)).rstrip("0").rstrip(".")
            elif step >= 0.01:
                text = ("%.2f" % float(value)).rstrip("0").rstrip(".")
            else:
                text = ("%.3f" % float(value)).rstrip("0").rstrip(".")
            return text + suffix
        except Exception:
            return str(value)

    def _slider_row_label(self, key):
        meta = self._slider_meta(key)
        return "%s: %s" % (meta.get("row_title", meta.get("title", key)), self._slider_format(key))

    def _slider_store_value(self, key, value):
        meta = self._slider_meta(key)
        try:
            step = float(meta.get("step", 0.01))
            if step >= 1.0:
                stored = str(int(round(float(value))))
            elif step >= 0.1:
                stored = ("%.1f" % float(value)).rstrip("0").rstrip(".")
            elif step >= 0.01:
                stored = ("%.2f" % float(value)).rstrip("0").rstrip(".")
            else:
                stored = ("%.3f" % float(value)).rstrip("0").rstrip(".")
        except Exception:
            stored = str(value)
        self._set_plugin_setting(key, stored)
        self._update_slider_row_text(key)
        return stored

    def _remember_slider_row_view(self, key, view):
        try:
            if view:
                self._slider_row_views[key] = view
                self._update_slider_row_text(key, view)
        except Exception:
            pass

    def _try_update_text_tree(self, root, label, title, depth=0):
        if root is None or depth > 6:
            return False
        changed = False
        try:
            txt = str(root.getText())
            # Update only the setting label, not random explanatory text.
            if txt == title or txt.startswith(title + ":") or txt.startswith(title + " ") or title in txt:
                root.setText(label)
                changed = True
        except Exception:
            pass
        try:
            count = int(root.getChildCount())
            for i in range(count):
                try:
                    if self._try_update_text_tree(root.getChildAt(i), label, title, depth + 1):
                        changed = True
                except Exception:
                    pass
        except Exception:
            pass
        return changed

    def _update_slider_row_text(self, key, view=None):
        meta = self._slider_meta(key)
        if not meta:
            return
        label = self._slider_row_label(key)
        title = meta.get("row_title", meta.get("title", key))
        targets = []
        if view is not None:
            targets.append(view)
            try:
                p = view.getParent()
                for _ in range(3):
                    if p:
                        targets.append(p)
                        p = p.getParent()
            except Exception:
                pass
        try:
            saved = self._slider_row_views.get(key)
            if saved:
                targets.append(saved)
        except Exception:
            pass
        try:
            item = self._slider_setting_items.get(key)
            if item is not None:
                try:
                    item.text = label
                except Exception:
                    pass
                try:
                    item.setText(label)
                except Exception:
                    pass
        except Exception:
            pass
        for t in targets:
            try:
                if self._try_update_text_tree(t, label, title):
                    try:
                        t.invalidate()
                    except Exception:
                        pass
                    return
            except Exception:
                pass

    def _slider_item(self, key, link_alias=None):
        meta = self._slider_meta(key)
        icon = meta.get("icon", "msg_settings")
        item = Text(
            text=self._slider_row_label(key),
            icon=icon,
            on_click=lambda v, _key=key: self._open_slider_sheet(_key, v),
            link_alias=link_alias or key,
        )
        try:
            self._slider_setting_items[key] = item
        except Exception:
            pass
        return item

    def _dp_ui(self, ctx, value):
        try:
            AU = find_class("org.telegram.messenger.AndroidUtilities")
            if AU:
                return int(AU.dp(float(value)))
        except Exception:
            pass
        try:
            return int(float(value) * float(ctx.getResources().getDisplayMetrics().density))
        except Exception:
            return int(value)

    def _get_launch_activity(self):
        try:
            LA = find_class("org.telegram.ui.LaunchActivity")
        except Exception:
            return None
        for fn in ("instance", "INSTANCE", "lastInstance", "currentActivity"):
            try:
                act = getattr(LA, fn, None)
                if act:
                    return act
            except Exception:
                pass
        for mn in ("getInstance", "getLastInstance", "getCurrentActivity"):
            try:
                m = getattr(LA, mn, None)
                if m:
                    act = m()
                    if act:
                        return act
            except Exception:
                pass
        return None

    def _make_text_view(self, ctx, text, size, color, bold=False):
        TextViewClass = find_class("android.widget.TextView")
        TypedValue = find_class("android.util.TypedValue")
        tv = TextViewClass(ctx)
        try:
            tv.setText(str(text))
        except Exception:
            pass
        try:
            tv.setTextColor(int(color))
        except Exception:
            pass
        try:
            if TypedValue:
                tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, float(size))
            else:
                tv.setTextSize(float(size))
        except Exception:
            pass
        if bold:
            try:
                AU = find_class("org.telegram.messenger.AndroidUtilities")
                if AU:
                    tv.setTypeface(AU.bold())
            except Exception:
                pass
        return tv

    def _clean_number_input(self, text, meta):
        try:
            s = str(text).strip().replace(",", ".")
            suffix = str(meta.get("suffix", ""))
            if suffix and s.endswith(suffix):
                s = s[: -len(suffix)].strip()
            s = s.replace(" ", "")
            return float(s)
        except Exception:
            return None

    def _open_manual_value_dialog(self, act, key, meta, value_view, seek, steps, changed):
        try:
            BottomSheet = find_class("org.telegram.ui.ActionBar.BottomSheet")
            Theme = find_class("org.telegram.ui.ActionBar.Theme")
            LinearLayout = find_class("android.widget.LinearLayout")
            EditText = find_class("android.widget.EditText")
            Gravity = find_class("android.view.Gravity")
            LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
            OnClickListener = find_class("android.view.View$OnClickListener")
            GradientDrawable = find_class("android.graphics.drawable.GradientDrawable")
            if not BottomSheet or not LinearLayout or not EditText or not OnClickListener:
                return

            try:
                sheet = BottomSheet(act, False, act.getResourceProvider())
            except Exception:
                try:
                    sheet = BottomSheet(act, False, None)
                except Exception:
                    sheet = BottomSheet(act, False)

            try:
                sheet.setApplyBottomPadding(False)
                sheet.setApplyTopPadding(False)
            except Exception:
                pass

            try:
                bg = Theme.getColor(Theme.key_windowBackgroundWhite)
                text_color = Theme.getColor(Theme.key_dialogTextBlack)
                gray = Theme.getColor(Theme.key_dialogTextGray3)
                accent = Theme.getColor(Theme.key_featuredStickers_addButton)
            except Exception:
                bg, text_color, gray, accent = _jint32(0xFF202124), _jint32(0xFFEDEDED), _jint32(0xFF9AA0A6), _jint32(0xFF6B7BFF)

            try:
                sheet.fixNavigationBar(bg)
            except Exception:
                pass

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(self._dp_ui(act, 22), self._dp_ui(act, 20), self._dp_ui(act, 22), self._dp_ui(act, 18))
            try:
                root.setBackgroundColor(bg)
            except Exception:
                pass

            title = self._make_text_view(act, "Введите число", 20, text_color, True)
            label = self._make_text_view(act, meta.get("title", key), 14, gray, False)
            hint = self._make_text_view(act, "Можно ввести любое значение. Если число слишком большое или маленькое, плагин ограничит его безопасным пределом.", 13, gray, False)

            edit = EditText(act)
            try:
                edit.setSingleLine(True)
                edit.setSelectAllOnFocus(True)
                edit.setText(str(self._slider_format(key)).replace(str(meta.get("suffix", "")), ""))
                edit.setTextColor(int(text_color))
                edit.setHintTextColor(int(gray))
                edit.setTextSize(22.0)
                edit.setPadding(self._dp_ui(act, 14), self._dp_ui(act, 12), self._dp_ui(act, 14), self._dp_ui(act, 12))
                edit.setInputType(12290)
                edit.setHint("Например: 1.25")
            except Exception:
                pass

            try:
                if GradientDrawable:
                    box = GradientDrawable()
                    box.setShape(GradientDrawable.RECTANGLE)
                    box.setCornerRadius(float(self._dp_ui(act, 12)))
                    box.setColor(_jint32(0x1A6B7BFF))
                    box.setStroke(int(self._dp_ui(act, 1)), int(accent))
                    edit.setBackground(box)
            except Exception:
                pass

            try:
                if LayoutHelper and Gravity:
                    root.addView(title, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 0, 0, 8))
                    root.addView(label, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 0, 0, 10))
                    root.addView(edit, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 10))
                    root.addView(hint, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 0, 0, 12))
                else:
                    root.addView(title); root.addView(label); root.addView(edit); root.addView(hint)
            except Exception:
                root.addView(title); root.addView(label); root.addView(edit); root.addView(hint)

            # Built-in numeric pad fallback. Some Telegram BottomSheet builds
            # focus EditText but refuse to open the system IME. This keypad
            # keeps exact numeric input usable even when Android hides the
            # keyboard. It is not a replacement for IME; tapping the field still
            # tries to open it.
            try:
                keypad_hint = self._make_text_view(act, "Клавиатура не открылась? Используйте кнопки ниже.", 12, gray, False)
                root.addView(keypad_hint, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 0, 0, 8)) if LayoutHelper and Gravity else root.addView(keypad_hint)
            except Exception:
                pass

            def _edit_insert_token(token):
                try:
                    s = str(edit.getText())
                    a = int(edit.getSelectionStart())
                    b = int(edit.getSelectionEnd())
                    if a < 0: a = len(s)
                    if b < 0: b = a
                    lo, hi = (a, b) if a <= b else (b, a)
                    if token == "BACK":
                        if lo != hi:
                            ns = s[:lo] + s[hi:]
                            pos = lo
                        elif lo > 0:
                            ns = s[:lo-1] + s[hi:]
                            pos = lo - 1
                        else:
                            ns = s
                            pos = 0
                    elif token == "CLEAR":
                        ns = ""
                        pos = 0
                    else:
                        ns = s[:lo] + str(token) + s[hi:]
                        pos = lo + len(str(token))
                    edit.setText(ns)
                    try: edit.setSelection(int(pos))
                    except Exception: pass
                    try: edit.requestFocus()
                    except Exception: pass
                except Exception:
                    pass

            try:
                keypad = LinearLayout(act)
                keypad.setOrientation(LinearLayout.VERTICAL)
                key_rows = [["7", "8", "9", "⌫"], ["4", "5", "6", "−"], ["1", "2", "3", "."], ["0", "00", ",", "C"]]
                for row_items in key_rows:
                    row = LinearLayout(act)
                    row.setOrientation(LinearLayout.HORIZONTAL)
                    for item in row_items:
                        btn = self._make_text_view(act, item, 18, text_color, True)
                        try:
                            btn.setGravity(Gravity.CENTER if Gravity else 17)
                            btn.setPadding(0, self._dp_ui(act, 11), 0, self._dp_ui(act, 11))
                            bbg = GradientDrawable() if GradientDrawable else None
                            if bbg:
                                bbg.setShape(GradientDrawable.RECTANGLE)
                                bbg.setCornerRadius(float(self._dp_ui(act, 10)))
                                bbg.setColor(_jint32(0x126B7BFF))
                                btn.setBackground(bbg)
                        except Exception:
                            pass
                        token = "BACK" if item == "⌫" else "CLEAR" if item == "C" else "-" if item == "−" else "." if item == "," else item
                        class KeyClick(dynamic_proxy(OnClickListener)):
                            def __init__(self, t):
                                super().__init__()
                                self.t = t
                            def onClick(self, v):
                                try: _edit_insert_token(self.t)
                                except Exception: pass
                        try: btn.setOnClickListener(KeyClick(token))
                        except Exception: pass
                        try: row.addView(btn, LinearLayout.LayoutParams(0, -2, 1.0))
                        except Exception: row.addView(btn)
                    try: keypad.addView(row, LinearLayout.LayoutParams(-1, -2))
                    except Exception: keypad.addView(row)
                root.addView(keypad, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 14)) if LayoutHelper and Gravity else root.addView(keypad)
            except Exception:
                pass

            buttons = LinearLayout(act)
            buttons.setOrientation(LinearLayout.HORIZONTAL)
            cancel = self._make_text_view(act, "Отмена", 16, gray, True)
            save = self._make_text_view(act, "Сохранить", 16, accent, True)
            try:
                pad_v = self._dp_ui(act, 13)
                cancel.setGravity(Gravity.CENTER if Gravity else 1)
                save.setGravity(Gravity.CENTER if Gravity else 1)
                cancel.setPadding(0, pad_v, 0, pad_v)
                save.setPadding(0, pad_v, 0, pad_v)
            except Exception:
                pass

            plugin = self
            sheet_ref = {"sheet": sheet}

            def _save_value():
                try:
                    val = plugin._clean_number_input(edit.getText(), meta)
                    if val is None:
                        return False
                    changed["value"] = val
                    changed["committed"] = True
                    value_view.setText(plugin._slider_format(key, val))
                    plugin._slider_store_value(key, val)
                    try:
                        changed["ignore_programmatic"] = True
                        prog = _clamp(plugin._slider_progress_from_value(meta, val), 0, steps)
                        seek.setProgress(int(prog))
                    except Exception:
                        pass
                    finally:
                        changed["ignore_programmatic"] = False
                    plugin._setting_changed()
                    return True
                except Exception:
                    return False

            class SaveClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try:
                        if _save_value():
                            sheet_ref["sheet"].dismiss()
                    except Exception:
                        pass

            class CancelClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try:
                        sheet_ref["sheet"].dismiss()
                    except Exception:
                        pass

            try:
                cancel.setOnClickListener(CancelClick())
                save.setOnClickListener(SaveClick())
            except Exception:
                pass

            try:
                buttons.addView(cancel, LinearLayout.LayoutParams(0, -2, 1.0))
                buttons.addView(save, LinearLayout.LayoutParams(0, -2, 1.0))
                root.addView(buttons, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 0)) if LayoutHelper and Gravity else root.addView(buttons)
            except Exception:
                root.addView(buttons)

            def _focus_keyboard_once():
                try:
                    edit.setFocusable(True)
                    edit.setFocusableInTouchMode(True)
                    edit.setEnabled(True)
                    edit.setCursorVisible(True)
                except Exception:
                    pass
                try:
                    edit.requestFocusFromTouch()
                except Exception:
                    pass
                try:
                    edit.requestFocus()
                except Exception:
                    pass
                try:
                    edit.post(lambda: edit.requestFocus())
                except Exception:
                    pass
                try:
                    WindowManager = find_class("android.view.WindowManager$LayoutParams")
                    mode = 0
                    if WindowManager:
                        for n in ("SOFT_INPUT_ADJUST_RESIZE", "SOFT_INPUT_STATE_ALWAYS_VISIBLE"):
                            try: mode |= int(getattr(WindowManager, n))
                            except Exception: pass
                    try:
                        w = sheet_ref["sheet"].getWindow()
                        if w and mode:
                            w.setSoftInputMode(mode)
                    except Exception:
                        pass
                    try:
                        act.getWindow().setSoftInputMode(mode)
                    except Exception:
                        pass
                except Exception:
                    pass
                try:
                    Context = find_class("android.content.Context")
                    imm = None
                    try:
                        if Context and hasattr(Context, "INPUT_METHOD_SERVICE"):
                            imm = act.getSystemService(Context.INPUT_METHOD_SERVICE)
                    except Exception:
                        pass
                    if not imm:
                        try: imm = act.getSystemService("input_method")
                        except Exception: imm = None
                    if imm:
                        IMM = find_class("android.view.inputmethod.InputMethodManager")
                        show_forced = 2
                        show_implicit = 1
                        try:
                            show_forced = int(getattr(IMM, "SHOW_FORCED"))
                            show_implicit = int(getattr(IMM, "SHOW_IMPLICIT"))
                        except Exception:
                            pass
                        try: imm.restartInput(edit)
                        except Exception: pass
                        try: imm.showSoftInput(edit, show_forced)
                        except Exception: pass
                        try: imm.showSoftInput(edit, show_implicit)
                        except Exception: pass
                        try: imm.toggleSoftInput(show_forced, 0)
                        except Exception: pass
                except Exception:
                    pass

            class EditFocusClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try: _focus_keyboard_once()
                    except Exception: pass

            try:
                edit.setOnClickListener(EditFocusClick())
            except Exception:
                pass

            try:
                sheet.setCustomView(root)
                try:
                    # Ask Android to open the keyboard for this BottomSheet
                    # instead of treating it like a passive overlay.
                    WindowManager = find_class("android.view.WindowManager$LayoutParams")
                    if WindowManager and hasattr(WindowManager, "SOFT_INPUT_STATE_ALWAYS_VISIBLE"):
                        try:
                            mode = int(WindowManager.SOFT_INPUT_STATE_ALWAYS_VISIBLE)
                            try: mode |= int(WindowManager.SOFT_INPUT_ADJUST_RESIZE)
                            except Exception: pass
                            sheet.setSoftInputMode(mode)
                        except Exception:
                            pass
                except Exception:
                    pass
                sheet.show()
                _focus_keyboard_once()
                try:
                    # BottomSheet steals focus during its opening animation on
                    # some Telegram/Android builds, so repeat after layout.
                    run_on_ui_thread(_focus_keyboard_once, 120)
                    run_on_ui_thread(_focus_keyboard_once, 300)
                except Exception:
                    pass
            except Exception:
                pass
        except Exception as e:
            _safe_log("[%s] manual value sheet error: %s" % (__id__, e))

    def _open_slider_sheet(self, key, source_view=None):
        try:
            self._remember_slider_row_view(key, source_view)
            meta = self._slider_meta(key)
            if not meta:
                return
            act = self._get_launch_activity() or self._get_app_context()
            if not act:
                return

            BottomSheet = find_class("org.telegram.ui.ActionBar.BottomSheet")
            Theme = find_class("org.telegram.ui.ActionBar.Theme")
            LinearLayout = find_class("android.widget.LinearLayout")
            SeekBar = find_class("android.widget.SeekBar")
            Gravity = find_class("android.view.Gravity")
            LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
            View = find_class("android.view.View")
            OnClickListener = find_class("android.view.View$OnClickListener")
            SeekListener = find_class("android.widget.SeekBar$OnSeekBarChangeListener")

            if not BottomSheet or not LinearLayout or not SeekBar:
                return

            try:
                sheet = BottomSheet(act, False, act.getResourceProvider())
            except Exception:
                try:
                    sheet = BottomSheet(act, False, None)
                except Exception:
                    sheet = BottomSheet(act, False)

            try:
                sheet.setApplyBottomPadding(False)
                sheet.setApplyTopPadding(False)
            except Exception:
                pass

            try:
                bg = Theme.getColor(Theme.key_windowBackgroundWhite)
                text_color = Theme.getColor(Theme.key_dialogTextBlack)
                gray = Theme.getColor(Theme.key_dialogTextGray3)
                accent = Theme.getColor(Theme.key_featuredStickers_addButton)
            except Exception:
                bg, text_color, gray, accent = _jint32(0xFFFFFFFF), _jint32(0xFF111111), _jint32(0xFF777777), _jint32(0xFF6B7BFF)

            try:
                sheet.fixNavigationBar(bg)
            except Exception:
                pass

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(self._dp_ui(act, 22), self._dp_ui(act, 18), self._dp_ui(act, 22), self._dp_ui(act, 18))
            try:
                root.setBackgroundColor(bg)
            except Exception:
                pass

            title = self._make_text_view(act, meta.get("title", key), 20, text_color, True)
            desc = self._make_text_view(act, meta.get("description", ""), 13, gray, False)
            value = self._make_text_view(act, self._slider_format(key), 28, accent, True)
            value_hint = self._make_text_view(act, "Можно ввести своё значение, нажав на число", 12, gray, False)

            try:
                value.setGravity(Gravity.CENTER if Gravity else 1)
                value_hint.setGravity(Gravity.CENTER if Gravity else 1)
                value.setPadding(self._dp_ui(act, 16), self._dp_ui(act, 10), self._dp_ui(act, 16), self._dp_ui(act, 8))
                value.setMinHeight(self._dp_ui(act, 52))
                value_hint.setPadding(0, 0, 0, self._dp_ui(act, 10))
            except Exception:
                pass

            try:
                if LayoutHelper and Gravity:
                    root.addView(title, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 2, 0, 4))
                    root.addView(desc, LayoutHelper.createLinear(-1, -2, Gravity.LEFT, 0, 0, 0, 12))
                    root.addView(value, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 2, 0, 0))
                    root.addView(value_hint, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 10))
                else:
                    root.addView(title); root.addView(desc); root.addView(value); root.addView(value_hint)
            except Exception:
                root.addView(title); root.addView(desc); root.addView(value); root.addView(value_hint)

            seek = SeekBar(act)
            try:
                seek.setPadding(0, self._dp_ui(act, 18), 0, self._dp_ui(act, 18))
                seek.setMinimumHeight(self._dp_ui(act, 64))
            except Exception:
                pass
            steps = self._slider_steps(meta)
            try:
                seek.setMax(int(steps))
            except Exception:
                pass
            cur = self._slider_raw_value(key)
            progress = _clamp(self._slider_progress_from_value(meta, cur), 0, steps)
            try:
                seek.setProgress(int(progress))
            except Exception:
                pass

            plugin = self
            changed = {"value": cur, "committed": False, "ignore_programmatic": False}

            class ManualValueClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try:
                        plugin._open_manual_value_dialog(act, key, meta, value, seek, steps, changed)
                    except Exception:
                        pass

            try:
                value.setOnClickListener(ManualValueClick())
                value.setClickable(True)
            except Exception:
                pass

            class BarListener(dynamic_proxy(SeekListener)):
                def __init__(self):
                    super().__init__()
                def onProgressChanged(self, bar, prog, fromUser):
                    try:
                        if changed.get("ignore_programmatic") and not fromUser:
                            return
                        val = plugin._slider_value_from_progress(meta, int(prog))
                        changed["value"] = val
                        value.setText(plugin._slider_format(key, val))
                        if fromUser:
                            plugin._slider_store_value(key, val)
                    except Exception:
                        pass
                def onStartTrackingTouch(self, bar):
                    pass
                def onStopTrackingTouch(self, bar):
                    try:
                        plugin._slider_store_value(key, changed["value"])
                        changed["committed"] = True
                        plugin._setting_changed()
                    except Exception:
                        pass

            try:
                seek.setOnSeekBarChangeListener(BarListener())
            except Exception:
                pass

            try:
                root.addView(seek, LayoutHelper.createLinear(-1, 64, Gravity.CENTER_HORIZONTAL, 0, 2, 0, 2)) if LayoutHelper and Gravity else root.addView(seek)
            except Exception:
                root.addView(seek)

            minmax = LinearLayout(act)
            minmax.setOrientation(LinearLayout.HORIZONTAL)
            min_tv = self._make_text_view(act, "Слайдер от " + self._slider_format(key, meta.get("min", 0)), 12, gray, False)
            max_tv = self._make_text_view(act, "до " + self._slider_format(key, meta.get("max", 1)), 12, gray, False)
            try:
                lp1 = LinearLayout.LayoutParams(0, -2, 1.0)
                lp2 = LinearLayout.LayoutParams(0, -2, 1.0)
                minmax.addView(min_tv, lp1)
                max_tv.setGravity(Gravity.RIGHT if Gravity else 5)
                minmax.addView(max_tv, lp2)
            except Exception:
                minmax.addView(min_tv); minmax.addView(max_tv)
            try:
                root.addView(minmax, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 18)) if LayoutHelper and Gravity else root.addView(minmax)
            except Exception:
                root.addView(minmax)

            buttons = LinearLayout(act)
            buttons.setOrientation(LinearLayout.HORIZONTAL)
            reset = self._make_text_view(act, "Сброс", 16, gray, True)
            done = self._make_text_view(act, "Готово", 16, accent, True)
            try:
                reset.setGravity(Gravity.CENTER)
                done.setGravity(Gravity.CENTER)
                pad_v = self._dp_ui(act, 12)
                reset.setPadding(0, pad_v, 0, pad_v)
                done.setPadding(0, pad_v, 0, pad_v)
            except Exception:
                pass

            class ResetClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try:
                        d = _as_float(DEFAULT_SETTINGS.get(key, "0"), "0", None, None)
                        changed["value"] = d
                        value.setText(plugin._slider_format(key, d))
                        changed["ignore_programmatic"] = True
                        try:
                            prog = _clamp(plugin._slider_progress_from_value(meta, d), 0, steps)
                            seek.setProgress(int(prog))
                        except Exception:
                            pass
                        finally:
                            changed["ignore_programmatic"] = False
                        plugin._slider_store_value(key, d)
                        changed["committed"] = True
                        plugin._setting_changed()
                    except Exception:
                        pass

            class DoneClick(dynamic_proxy(OnClickListener)):
                def __init__(self):
                    super().__init__()
                def onClick(self, v):
                    try:
                        plugin._slider_store_value(key, changed["value"])
                        if not changed.get("committed"):
                            plugin._setting_changed()
                        sheet.dismiss()
                    except Exception:
                        pass

            try:
                reset.setOnClickListener(ResetClick())
                done.setOnClickListener(DoneClick())
            except Exception:
                pass
            try:
                buttons.addView(reset, LinearLayout.LayoutParams(0, -2, 1.0))
                buttons.addView(done, LinearLayout.LayoutParams(0, -2, 1.0))
                root.addView(buttons, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 2, 0, 0)) if LayoutHelper and Gravity else root.addView(buttons)
            except Exception:
                root.addView(buttons)

            try:
                sheet.setCustomView(root)
                sheet.show()
            except Exception:
                pass
        except Exception as e:
            _safe_log("[%s] slider sheet error: %s" % (__id__, e))

    def _create_physics_settings(self):
        return [
            Header(text="Пресеты физики"),
            Selector(key="physics_preset", text="Настройки физики", items=["Мягкий", "Баланс", "Тяжёлый", "Хаос", "Лёд", "Резина", "Камень", "Желе", "Пинбол", "Игрушка", "Мыло", "Пружина", "Металл", "Песок", "Невесомость", "Аркада", "Стекло", "Магнит", "Бильярд", "Сонный"], default=1, icon="msg_settings", on_change=self._physics_preset, link_alias="physics_preset"),
            Divider(text="Вы можете выбрать готовый пресет настроек физики."),

            Header(text="Управление пальцем"),
            self._slider_item("finger_spring"),
            self._slider_item("roll_sensitivity"),
            self._slider_item("linear_friction"),
            self._slider_item("slow_friction"),
            self._slider_item("slow_speed"),
            self._slider_item("stop_speed"),
            self._slider_item("wall_bounce"),

            Header(text="Физика граней"),
            self._slider_item("edge_fall_power"),
            self._slider_item("wobble_power"),
            self._slider_item("settle_damping"),
            self._slider_item("surface_roll"),
            self._slider_item("settle_speed"),
        ]

    def _create_size_settings(self):
        return [
            Header(text="Размер и касание"),
            self._slider_item("cube_size_dp"),
            self._slider_item("mini_cube_scale"),
            self._slider_item("touch_box_mult"),
            self._slider_item("visual_box_mult"),
            self._slider_item("start_x_percent"),
            self._slider_item("start_y_percent"),
        ]

    def _create_split_settings(self):
        return [
            Header(text="Разделение и соединение"),
            Switch(key="enable_split_merge", text="Деление при ударе", default=DEFAULT_SETTINGS["enable_split_merge"], subtext="Куб делится от сильного удара о стену и собирается обратно при сильном ударе друг о друга", icon="msg_folders", on_change=self._setting_changed, link_alias="enable_split_merge"),
            Switch(key="infinite_split", text="Бесконечное деление", default=DEFAULT_SETTINGS["infinite_split"], subtext="Каждый кубик может снова делиться, пока не достигнут лимит размера или количества", icon="msg_folders", on_change=self._setting_changed, link_alias="infinite_split"),
            self._slider_item("split_force_dp"),
            self._slider_item("split_child_scale"),
            self._slider_item("min_split_size_dp"),
            self._slider_item("max_cube_count"),
            self._slider_item("split_tiny_force_mult"),
            self._slider_item("merge_spin_force"),
            self._slider_item("merge_distance_mult"),
            self._slider_item("split_cooldown"),
            self._slider_item("merge_cooldown"),
            Switch(key="merge_pair_only", text="Соединять только пару", default=DEFAULT_SETTINGS["merge_pair_only"], subtext="В бесконечном режиме соединяются только столкнувшиеся кубики, а не всё сразу", icon="msg_link", on_change=self._setting_changed, link_alias="merge_pair_only"),
        ]

    def _create_visual_settings(self):
        return [
            Header(text="Внешний вид"),
            Selector(key="visual_preset", text="Стиль куба", items=["Не менять", "Неон", "Матовый", "Стекло", "Лава", "Конфета", "Минимал", "Кибер", "Игрушка", "Тень", "Плазма", "Аквариум", "Золото", "Изумруд", "Космос", "Снег", "Сакура", "Янтарь", "Терминал", "Молния", "Рубин", "Север"], default=DEFAULT_SETTINGS["visual_preset"], icon="msg_palette", on_change=self._visual_preset, link_alias="visual_preset"),
            Selector(key="color_theme", text="Цвет куба", items=[x[0] for x in COLOR_THEMES], default=DEFAULT_SETTINGS["color_theme"], icon="msg_palette", on_change=self._setting_changed, link_alias="color_theme"),
            self._slider_item("cube_hue"),
            self._slider_item("saturation"),
            self._slider_item("brightness"),
            self._slider_item("face_alpha"),
            self._slider_item("corner_radius_dp"),
            self._slider_item("stroke_dp"),
            self._slider_item("perspective_depth"),
            self._slider_item("edge_bump"),
            self._slider_item("pulse_strength"),
        ]

    def _create_feedback_settings(self):
        return [
            Header(text="Тактильная отдача"),
            Switch(key="haptics", text="Тактильная отдача", default=DEFAULT_SETTINGS["haptics"], subtext="Тики на ребрах, удар и соединение", icon="msg_vibration", on_change=self._setting_changed, link_alias="haptics"),
            self._slider_item("haptic_power"),
            Switch(key="debug_logs", text="Логи ошибок", default=DEFAULT_SETTINGS["debug_logs"], icon="menu_intro_solar", on_change=self._setting_changed, link_alias="debug_logs"),
        ]

    def create_settings(self):
        if not Header:
            return []
        return [
            Header(text="Настройки куба"),
            Text(text="Настройки физики", icon="msg_speed", create_sub_fragment=self._create_physics_settings, link_alias="physics"),
            Text(text="Размер и касание", icon="msg_customize", create_sub_fragment=self._create_size_settings, link_alias="size"),
            Text(text="Разделение и соединение", icon="msg_folders", create_sub_fragment=self._create_split_settings, link_alias="split_merge"),
            Text(text="Внешний вид", icon="msg_palette", create_sub_fragment=self._create_visual_settings, link_alias="visual"),
            Text(text="Отклик и отладка", icon="msg_vibration", create_sub_fragment=self._create_feedback_settings, link_alias="feedback"),
            Divider(text="Нажмите на любой параметр, чтобы открыть слайдер."),
            Text(text="Сбросить настройки", red=True, icon="msg_delete", on_click=self._reset_settings, link_alias="reset_settings"),
        ]

    def _get_app_context(self):
        try:
            AL = find_class("org.telegram.messenger.ApplicationLoader")
            ctx = getattr(AL, "applicationContext", None)
            if ctx:
                return ctx
        except Exception:
            pass
        try:
            AT = find_class("android.app.ActivityThread")
            app = AT.currentApplication()
            if app:
                return app
        except Exception:
            pass
        return None

    def on_plugin_load(self):
        run_on_ui_thread(self._start)

    def on_plugin_unload(self):
        run_on_ui_thread(self._stop)

    def _start(self):
        try:
            ctx = self._get_app_context()
            if not ctx:
                _safe_log("[%s] no app context" % __id__)
                return
            self.engine = _CubeEngine(ctx, self)
            self.engine.start()
        except Exception as e:
            _safe_log("[%s] _start error: %s" % (__id__, e))
            self.engine = None

    def _stop(self):
        try:
            if self.engine:
                self.engine.stop()
        finally:
            self.engine = None
