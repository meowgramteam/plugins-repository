SEARCH_LOG_FILE_NAME = "lyrics_search.log"
SEARCH_LOG_MAX_BYTES = 1 * 1024 * 1024
DEFAULT_SEARCH_LOG_ENABLED = False
_search_log_lock = threading.Lock()


def _search_log_path() -> str:
    return os.path.join(Plugin.dir_path(), SEARCH_LOG_FILE_NAME)


def _search_log_enabled() -> bool:
    try:
        plugin = Plugin.get_instance()
        return setting_bool(plugin, "search_log_enabled", DEFAULT_SEARCH_LOG_ENABLED)
    except Exception:
        return DEFAULT_SEARCH_LOG_ENABLED


def search_log(line: str) -> None:
    if not _search_log_enabled():
        return
    try:
        path = _search_log_path()
        with _search_log_lock:
            try:
                if os.path.exists(path) and os.path.getsize(path) > SEARCH_LOG_MAX_BYTES:
                    os.remove(path)
            except Exception:
                pass
            with open(path, "a", encoding="utf-8") as f:
                f.write("[{}] {}\n".format(time.strftime("%Y-%m-%d %H:%M:%S"), line))
    except Exception:
        pass


def export_search_log_to_downloads() -> str:
    path = _search_log_path()
    try:
        with open(path, "rb") as f:
            data = f.read()
    except Exception:
        data = b""
    if not data:
        raise RuntimeError("лог поиска пуст или ещё не создан — найдите текст хотя бы раз")

    file_name = "lyrics_search_log_{}.txt".format(time.strftime("%Y%m%d_%H%M%S"))
    context = ApplicationLoader.applicationContext

    if Build.VERSION.SDK_INT >= 29:
        resolver = context.getContentResolver()
        values = ContentValues()
        values.put(JString(MediaStore.Downloads.DISPLAY_NAME), JString(file_name))
        values.put(JString(MediaStore.Downloads.MIME_TYPE), JString("text/plain"))
        values.put(JString(MediaStore.Downloads.IS_PENDING), Integer(1))
        uri = resolver.insert(MediaStore.Downloads.EXTERNAL_CONTENT_URI, values)
        if uri is None:
            raise RuntimeError("система не дала создать файл в Downloads")
        out = resolver.openOutputStream(uri)
        try:
            out.write(data)
            out.flush()
        finally:
            out.close()
        done_values = ContentValues()
        done_values.put(JString(MediaStore.Downloads.IS_PENDING), Integer(0))
        resolver.update(uri, done_values, None, None)
    else:
        downloads_dir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS)
        dest = File(downloads_dir, file_name)
        with open(dest.getAbsolutePath(), "wb") as out_f:
            out_f.write(data)

    return file_name


def clear_search_log() -> None:
    path = _search_log_path()
    try:
        if os.path.exists(path):
            os.remove(path)
    except Exception:
        pass


PLOG_FILE_NAME = "lyrics_plugin.log"
PLOG_MAX_BYTES = 3 * 1024 * 1024
DEFAULT_PLOG_ENABLED = False
_plog_lock = threading.Lock()
_plog_session_id = "{:.0f}".format(time.time())


def _plog_path() -> str:
    try:
        return os.path.join(Plugin.dir_path(), PLOG_FILE_NAME)
    except Exception:
        return "/tmp/" + PLOG_FILE_NAME


def _plog_enabled() -> bool:
    try:
        plugin = Plugin.get_instance()
        return setting_bool(plugin, "plog_enabled", DEFAULT_PLOG_ENABLED)
    except Exception:
        return DEFAULT_PLOG_ENABLED


def plog(tag: str, msg: str, level: str = "I") -> None:
    if not _plog_enabled():
        return
    try:
        path = _plog_path()
        ts = time.strftime("%Y-%m-%d %H:%M:%S")
        line = "[{}][{}][{}][{}] {}\n".format(ts, _plog_session_id, level, tag, msg)
        with _plog_lock:
            try:
                if os.path.exists(path) and os.path.getsize(path) > PLOG_MAX_BYTES:
                    with open(path, "r", encoding="utf-8", errors="replace") as f:
                        content = f.read()
                    half = len(content) // 2
                    cut = content.find("\n", half)
                    if cut < 0:
                        cut = half
                    with open(path, "w", encoding="utf-8") as f:
                        f.write("...лог обрезан...\n")
                        f.write(content[cut + 1:])
            except Exception:
                pass
            with open(path, "a", encoding="utf-8") as f:
                f.write(line)
    except Exception:
        pass


def plog_exc(tag: str, msg: str, exc: BaseException) -> None:
    try:
        tb = traceback.format_exc()
    except Exception:
        tb = str(exc)
    plog(tag, "{}: {}\n{}".format(msg, str(exc), tb), level="E")


def plog_crash(tag: str, msg: str, exc: BaseException) -> None:
    try:
        tb = traceback.format_exc()
    except Exception:
        tb = str(exc)
    plog(tag, "CRASH: {}: {}\n{}".format(msg, str(exc), tb), level="C")


