def safe_str(value: Any, default: str = "") -> str:
    if value is None:
        return default
    try:
        text = str(value)
    except Exception:
        return default
    text = text.strip()
    return text if text else default


def normalize_key(*parts: str) -> str:
    text = " ".join([safe_str(p) for p in parts if safe_str(p)])
    text = text.lower()
    text = re.sub(r"\([^)]*\)|\[[^]]*\]", " ", text)
    text = re.sub(r"feat\.?|ft\.?", " ", text, flags=re.I)
    text = re.sub(r"[^\wа-яё]+", " ", text, flags=re.IGNORECASE)
    return re.sub(r"\s+", " ", text).strip()


def _trigram_similarity(a: str, b: str) -> float:
    if not a and not b:
        return 1.0
    if not a or not b:
        return 0.0
    if a == b:
        return 1.0

    def get_trigrams(s: str):
        s = s.replace(" ", "")
        if len(s) < 3:
            return {s} if s else set()
        return {s[i:i + 3] for i in range(len(s) - 2)}

    set_a = get_trigrams(a)
    set_b = get_trigrams(b)
    if not set_a and not set_b:
        return 1.0
    if not set_a or not set_b:
        return 0.0
    intersection = len(set_a & set_b)
    denom = max(len(set_a), len(set_b))
    if denom == 0:
        return 0.0
    return intersection / denom


def levenshtein_ratio(a: str, b: str) -> float:
    a = a.replace(" ", "")
    b = b.replace(" ", "")
    if not a and not b:
        return 1.0
    if not a or not b:
        return 0.0
    if a == b:
        return 1.0

    len_a, len_b = len(a), len(b)
    prev_row = list(range(len_b + 1))
    for i in range(1, len_a + 1):
        curr_row = [i] + [0] * len_b
        char_a = a[i - 1]
        for j in range(1, len_b + 1):
            cost_sub = prev_row[j - 1] + (0 if char_a == b[j - 1] else 1)
            cost_del = prev_row[j] + 1
            cost_ins = curr_row[j - 1] + 1
            curr_row[j] = min(cost_sub, cost_del, cost_ins)
        prev_row = curr_row

    distance = prev_row[len_b]
    shorter = min(len_a, len_b)
    if shorter == 0:
        return 0.0
    return max(0.0, 1.0 - (distance / shorter))


def _digit_mismatch_factor(a: str, b: str) -> float:
    digits_a = re.findall(r"\d+", a)
    digits_b = re.findall(r"\d+", b)
    if not digits_a or not digits_b:
        return 1.0
    if set(digits_a) & set(digits_b):
        return 1.0
    return 0.5


def ngram_similarity(a: str, b: str, n: int = 3) -> float:
    trigram_sim = _trigram_similarity(a, b)
    if trigram_sim >= 0.9:
        base = trigram_sim
    else:
        base = max(trigram_sim, levenshtein_ratio(a, b))
    return base * _digit_mismatch_factor(a, b)


def dp(context: Any, value: int) -> int:
    try:
        density = context.getResources().getDisplayMetrics().density
        return int(value * density + 0.5)
    except Exception:
        return value


def _decode_bitmap_bounded(path: str, max_dimension: int) -> Optional["Bitmap"]:
    try:
        bounds = BitmapFactory.Options()
        bounds.inJustDecodeBounds = True
        BitmapFactory.decodeFile(path, bounds)
        src_w = int(bounds.outWidth)
        src_h = int(bounds.outHeight)
        if src_w <= 0 or src_h <= 0:
            return None

        sample = 1
        largest_side = max(src_w, src_h)
        while largest_side // (sample * 2) >= max_dimension:
            sample *= 2

        options = BitmapFactory.Options()
        options.inPreferredConfig = Bitmap.Config.ARGB_8888
        options.inSampleSize = sample
        return BitmapFactory.decodeFile(path, options)
    except BaseException as e:
        _log_safe("_decode_bitmap_bounded", e)
        return None


def _safe_pil_source(src_path: str, max_dimension: int) -> Optional[str]:
    try:
        if not src_path or not os.path.exists(src_path):
            return None
        cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
        os.makedirs(cache_dir, exist_ok=True)
        suffix = hashlib.md5(
            "{}|{}".format(src_path, max_dimension).encode("utf-8", "ignore")
        ).hexdigest()[:16]
        out_path = os.path.join(cache_dir, "pil_safe_{}.jpg".format(suffix))

        try:
            if os.path.exists(out_path) and os.path.getmtime(out_path) >= os.path.getmtime(src_path):
                return out_path
        except Exception:
            pass

        bmp = _decode_bitmap_bounded(src_path, max_dimension)
        if bmp is None:
            return None
        fos = FileOutputStream(out_path)
        try:
            bmp.compress(Bitmap.CompressFormat.JPEG, 90, fos)
            fos.flush()
        finally:
            fos.close()
        return out_path
    except BaseException as e:
        _log_safe("_safe_pil_source", e)
        return None


def _draw_play_icon(canvas: "Canvas", size: int, color: int) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    paint.setStyle(Paint.Style.FILL)
    path = Path()
    pad_x = size * 0.30
    pad_y = size * 0.18
    path.moveTo(pad_x, pad_y)
    path.lineTo(size - pad_x * 0.85, size * 0.5)
    path.lineTo(pad_x, size - pad_y)
    path.close()
    canvas.drawPath(path, paint)


def _draw_pause_icon(canvas: "Canvas", size: int, color: int) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    paint.setStyle(Paint.Style.FILL)
    bar_w = size * 0.16
    gap = size * 0.14
    top = size * 0.2
    bottom = size * 0.8
    cx = size / 2.0
    left_x = cx - gap / 2.0 - bar_w
    right_x = cx + gap / 2.0
    r = size * 0.03
    canvas.drawRoundRect(RectF(left_x, top, left_x + bar_w, bottom), r, r, paint)
    canvas.drawRoundRect(RectF(right_x, top, right_x + bar_w, bottom), r, r, paint)


def _draw_heart_icon(canvas: "Canvas", size: int, color: int, filled: bool) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    if filled:
        paint.setStyle(Paint.Style.FILL)
    else:
        paint.setStyle(Paint.Style.STROKE)
        paint.setStrokeWidth(size * 0.085)
        paint.setStrokeJoin(Paint.Join.ROUND)
        paint.setStrokeCap(Paint.Cap.ROUND)
    w = float(size)
    h = float(size)
    path = Path()
    path.moveTo(w * 0.5, h * 0.82)
    path.cubicTo(w * 0.05, h * 0.55, w * 0.08, h * 0.16, w * 0.32, h * 0.16)
    path.cubicTo(w * 0.46, h * 0.16, w * 0.5, h * 0.30, w * 0.5, h * 0.30)
    path.cubicTo(w * 0.5, h * 0.30, w * 0.54, h * 0.16, w * 0.68, h * 0.16)
    path.cubicTo(w * 0.92, h * 0.16, w * 0.95, h * 0.55, w * 0.5, h * 0.82)
    path.close()
    canvas.drawPath(path, paint)


def make_icon_drawable(context: Any, size_dp: int, color: int, draw_fn) -> Optional["BitmapDrawable"]:
    size_px = max(1, dp(context, size_dp))
    for cfg in [Bitmap.Config.ARGB_8888, Bitmap.Config.ARGB_4444, Bitmap.Config.RGB_565]:
        try:
            bmp = Bitmap.createBitmap(size_px, size_px, cfg)
            cv = Canvas(bmp)
            draw_fn(cv, size_px, color)
            d = BitmapDrawable(context.getResources(), bmp)
            d.setBounds(0, 0, size_px, size_px)
            return d
        except BaseException as e:
            _log_safe("make_icon_drawable cfg=" + str(cfg), e)
    return None


