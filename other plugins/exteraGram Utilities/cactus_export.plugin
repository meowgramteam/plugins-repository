    def __init__(self):
        super().__init__()
        self.dex_class = None
        self.plugin_metadata = {}
        self.metadata_loading = False
        self.file_hook = None
        self.span_hook = None
        self.span_draw_hook = None
        self.radius_hook = None
        self.coords_hook = None

    def on_plugin_load(self):
        self.add_on_send_message_hook()
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id="dumper_open_menu",
                icon="msg_filled_data_sent",
                text="📤 Экспорт Плагинов",
                on_click=lambda _: self._manual_dump(None)
            )
        )
        
        JavaClass = find_class("java.lang.Class")
        
        try:
            method = AndroidUtilities.getClass().getDeclaredMethod(
                "openForView", 
                [FileClass, JavaClass.forName("java.lang.String"), JavaClass.forName("java.lang.String"), Activity, JavaClass.forName("org.telegram.ui.ActionBar.Theme$ResourcesProvider"), Boolean.TYPE]
            )
            self.file_hook = self.hook_method(method, OpenFileHook(self))
        except:
            try:
                for m in AndroidUtilities.getClass().getDeclaredMethods():
                    if m.getName() == "openForView":
                        self.file_hook = self.hook_method(m, OpenFileHook(self))
                        break
            except: pass

        try:
            TPIRS_class = JavaClass.forName("org.telegram.ui.Components.TextPaintImageReceiverSpan")
            for ctor in TPIRS_class.getDeclaredConstructors():
                if len(ctor.getParameterTypes()) >= 5:
                    self.span_hook = self.hook_method(ctor, SpanConstructorHook())
                    break
            for m in TPIRS_class.getDeclaredMethods():
                if m.getName() == "draw":
                    self.span_draw_hook = self.hook_method(m, SpanDrawHook())
                    break
        except: pass
        
        try:
            ImageReceiver_class = JavaClass.forName("org.telegram.messenger.ImageReceiver")
            for m in ImageReceiver_class.getDeclaredMethods():
                if m.getName() == "setRoundRadius" and len(m.getParameterTypes()) == 1:
                    self.radius_hook = self.hook_method(m, ImageReceiverRadiusHook())
                    break
            for m in ImageReceiver_class.getDeclaredMethods():
                if m.getName() == "setImageCoords" and len(m.getParameterTypes()) == 4:
                    self.coords_hook = self.hook_method(m, ImageReceiverCoordsHook())
                    break
        except: pass

        threading.Thread(target=self._ensure_dex_and_metadata_loaded).start()

    def on_plugin_unload(self):
        self.remove_menu_item("dumper_open_menu")
        if self.file_hook: self.unhook_method(self.file_hook)
        if self.span_hook: self.unhook_method(self.span_hook)
        if self.span_draw_hook: self.unhook_method(self.span_draw_hook)
        if self.radius_hook: self.unhook_method(self.radius_hook)
        if self.coords_hook: self.unhook_method(self.coords_hook)

    def has_settings(self):
        return True

    def create_settings(self):
        settings = [
            Header(self._get_string_by_key("cat_control")),
            Input(key="trigger_command", text=self._get_string_by_key("cmd_menu"), default=".sexport"),
            Divider(),
            Header(self._get_string_by_key("cat_state"))
        ]

        restore_mode = self.get_setting("restore_state_mode", True)
        
        settings.append(Switch(
            key="restore_state_mode",
            text=self._get_string_by_key("restore_state"),
            subtext=self._get_string_by_key("restore_state_sub"),
            default=True,
            icon="avd_theme",
            on_change=lambda v: self._refresh_ui()
        ))

        if not restore_mode:
            force_enable = self.get_setting("force_enable_mode", False)
            subtext_key = "force_enable_sub_on" if force_enable else "force_enable_sub_off"
            
            settings.append(Switch(
                key="force_enable_mode",
                text=self._get_string_by_key("force_enable"),
                subtext=self._get_string_by_key(subtext_key),
                default=False,
                icon="ic_unlock",
                on_change=lambda v: self._refresh_ui() 
            ))
            
        return settings

    def _refresh_ui(self):
        run_on_ui_thread(lambda: self._refresh_ui_safe())

    def _refresh_ui_safe(self):
        try:
            fragment = get_last_fragment()
            if not fragment: return
            adapter = get_private_field(fragment, "adapter") 
            if adapter: adapter.update(True)
        except: pass

    def _get_string_by_key(self, key):
        lang = Locale.getDefault().getLanguage()
        if lang not in self.STRINGS: lang = "en"
        return self.STRINGS[lang].get(key, key)
        
    def _get_java_strings_map(self):
        lang = Locale.getDefault().getLanguage()
        if lang not in self.STRINGS: lang = "en"
        string_dict = self.STRINGS[lang]
        java_map = HashMap()
        for k, v in string_dict.items(): java_map.put(k, v)
        return java_map

    def on_send_message_hook(self, account, params) -> HookResult:
        if not isinstance(params.message, str): return HookResult()
        msg = params.message.strip()
        
        if msg == self.get_setting("trigger_command", ".sexport"):
            if self.metadata_loading:
                run_on_ui_thread(lambda: BulletinHelper.show_info("Загрузка данных плагинов..."))
                return HookResult(strategy=HookStrategy.CANCEL)
            
            run_on_queue(lambda: self._prepare_dump(params.peer))
            return HookResult(strategy=HookStrategy.CANCEL)
            
        return HookResult()
    
    def _load_dex(self):
        if self.dex_class: return True
        if hasattr(sys, "_cactus_dex_class") and sys._cactus_dex_class is not None:
            self.dex_class = sys._cactus_dex_class
            return True
            
        try:
            url = URL(DEX_URL)
            stream = url.openStream()
            bytes_out = find_class("java.io.ByteArrayOutputStream")()
            buffer = jarray(jbyte)(4096)
            while True:
                read = stream.read(buffer)
                if read == -1: break
                bytes_out.write(buffer, 0, read)
            
            dex_bytes = bytes_out.toByteArray()
            stream.close()
            
            loader = InMemoryDexClassLoader(
                ByteBuffer.wrap(dex_bytes),
                ApplicationLoader.applicationContext.getClassLoader()
            )
            self.dex_class = loader.loadClass("org.den4iksop.cactuslib.ImportExportBottomSheet")
            sys._cactus_dex_class = self.dex_class
            return True
        except: return False

    def _ensure_dex_and_metadata_loaded(self):
        if self.dex_class is None:
            self._load_dex()
        if self.dex_class:
            self._load_all_metadata_in_background()

    def _load_all_metadata_in_background(self):
        if self.metadata_loading: return
        self.metadata_loading = True
        
        plugins_dir = get_plugins_dir()
        files_to_check = [f for f in os.listdir(plugins_dir) if f.endswith(('.py', '.plugin'))]
        
        new_metadata = {}
        for fname in files_to_check:
            fpath = os.path.join(plugins_dir, fname)
            new_metadata[fname] = self._read_plugin_metadata(fpath)
            
        self.plugin_metadata = new_metadata
        self.metadata_loading = False

    def _read_plugin_metadata(self, filepath):
        metadata = {}
        try:
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read(1024 * 5)
            try:
                tree = ast.parse(content)
                for node in ast.walk(tree):
                    if isinstance(node, ast.Assign):
                        for target in node.targets:
                            if isinstance(target, ast.Name) and target.id in ['__id__', '__name__', '__version__', '__icon__']:
                                if isinstance(node.value, (ast.Constant, ast.Str)):
                                    metadata[target.id] = node.value.value if isinstance(node.value, ast.Constant) else node.value.s
            except: pass
            
            if not metadata:
                patterns = {
                    '__id__': r'^__id__\s*=\s*[\'"]([^\'"]+)[\'"]',
                    '__name__': r'^__name__\s*=\s*[\'"]([^\'"]+)[\'"]',
                    '__version__': r'^__version__\s*=\s*[\'"]([^\'"]+)[\'"]',
                    '__icon__': r'^__icon__\s*=\s*[\'"]([^\'"]+)[\'"]'
                }
                for key, pattern in patterns.items():
                    if m := re.search(pattern, content, re.MULTILINE):
                        metadata[key] = m.group(1)
            
            try:
                pid = metadata.get('__id__')
                if pid:
                    controller = PluginsController.getInstance()
                    metadata['enabled'] = controller.isPluginEnabled(pid)
            except: pass

            return metadata
        except:
            return metadata

    def _manual_dump(self, v):
        frag = get_last_fragment()
        if frag:
            try: 
                pid = frag.getDialogId()
                if pid: run_on_queue(lambda: self._prepare_dump(pid))
            except: pass

    def _prepare_dump(self, peer_id):
        if not self.dex_class:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка загрузки DEX!"))
            return

        plugins_dir = get_plugins_dir()
        if not os.path.exists(plugins_dir): return
        
        all_files = sorted([f for f in os.listdir(plugins_dir) if f.endswith(('.py', '.plugin'))])
        all_files = [f for f in all_files if not f.startswith(".temp")]
        run_on_ui_thread(lambda: self._show_cactus_ui(peer_id, all_files, True))

    def open_import_ui(self, filepath):
        try:
            with open(filepath, "rb") as f: content = f.read()
            data = json.loads(self.decode_and_decompress(content))
            
            plugins_map = {}
            if "file_content" in data:
                meta = data.get("plugin_meta", {})
                pid = meta.get("id", "unknown")
                plugins_map[pid] = data
            else:
                plugins_map = data

            run_on_ui_thread(lambda: self._show_cactus_ui(None, plugins_map, False, plugins_map))
        except Exception as e: 
            run_on_ui_thread(lambda: BulletinHelper.show_error(f"Error: {e}"))

    def _prepare_icon(self, icon_str):
        if not icon_str or not isinstance(icon_str, str): 
            return None
            
        if "/" in icon_str and re.match(r"^[a-zA-Z][a-zA-Z0-9_]*/\d+$", icon_str):
            try:
                parts = icon_str.split("/")
                arr = ArrayList(2)
                arr.add(parts[0])
                arr.add(Integer(int(parts[1])))
                return arr
            except: return None
        else:
            try:
                ctx = ApplicationLoader.applicationContext
                res_id = ctx.getResources().getIdentifier(icon_str, "drawable", ctx.getPackageName())
                if res_id != 0:
                    from androidx.core.content import ContextCompat
                    import android.graphics.PorterDuff as PorterDuff
                    import android.graphics.PorterDuffColorFilter as PorterDuffColorFilter
                    from org.telegram.ui.ActionBar import Theme
                    
                    drawable = ContextCompat.getDrawable(ctx, res_id)
                    if drawable:
                        drawable = drawable.mutate()
                        size = AndroidUtilities.dp(20)
                        y_offset = AndroidUtilities.dp(4)
                        drawable.setBounds(0, y_offset, size, size + y_offset)
                        
                        color = Theme.getColor(Theme.key_dialogTextBlack)
                        drawable.setColorFilter(PorterDuffColorFilter(color, PorterDuff.Mode.SRC_IN))
                        return drawable
            except: pass
        return None

    def _show_cactus_ui(self, peer_id, files_data, is_export_mode, parsed_import_data=None):
        frag = get_last_fragment()
        if not frag: return
        if not self.dex_class: return

        j_strings = self._get_java_strings_map()
        j_plugins = ArrayList()
        j_names = HashMap()
        j_versions = HashMap()
        j_icons = HashMap()
        
        pc = PluginsController.getInstance()
        
        if is_export_mode:
            for f in files_data:
                j_plugins.add(f)
                plugin_id = os.path.splitext(f)[0]
                
                live_plugin = pc.plugins.get(plugin_id)
                meta = self.plugin_metadata.get(f, {})
                
                p_name = getattr(live_plugin, "name", meta.get('__name__', plugin_id)) if live_plugin else meta.get('__name__', plugin_id)
                p_version = getattr(live_plugin, "version", meta.get('__version__', "1.0")) if live_plugin else meta.get('__version__', "1.0")
                
                p_icon = meta.get('__icon__', "")
                if live_plugin:
                    try:
                        pack = live_plugin.getPack()
                        idx = live_plugin.getIndex()
                        if pack and idx >= 0:
                            p_icon = f"{pack}/{idx}"
                    except: pass
                
                j_names.put(f, p_name)
                j_versions.put(f, p_version)
                
                icon_obj = self._prepare_icon(p_icon)
                if icon_obj:
                    j_icons.put(f, icon_obj)
        else:
            for pid, pdata in files_data.items():
                if not pdata: continue
                j_plugins.add(pid)
                meta = pdata.get("plugin_meta", {})
                j_names.put(pid, meta.get("name", pid))
                j_versions.put(pid, meta.get("version", "1.0"))
                icon_obj = self._prepare_icon(meta.get("icon", ""))
                if icon_obj:
                    j_icons.put(pid, icon_obj)

        animator = DefaultItemAnimator()
        animator.setSupportsChangeAnimations(False)
        animator.setDelayAnimations(False)
        animator.setInterpolator(CubicBezierInterpolator.EASE_OUT_QUINT)
        animator.setDurations(350)

        try:
            ctor = self.dex_class.getConstructors()[0]
            sheet = ctor.newInstance(
                frag, is_export_mode, j_strings, j_plugins, animator, j_names, j_versions, j_icons
            )
            
            def on_done_python(sheet_view, selected_list, on_err, on_succ, with_data):
                sel_files = list(selected_list.toArray())
                if not sel_files: return
                include_data = bool(with_data)
                
                if is_export_mode:
                    run_on_queue(lambda: self._process_export_cactus(peer_id, sel_files, include_data))
                else:
                    run_on_queue(lambda: self._process_import_selected(parsed_import_data, sel_files, include_data))
                
                run_on_ui_thread(lambda: sheet_view.dismiss())

            sheet.setOnDone(Callback5(on_done_python))
            sheet.show()
            
        except Exception as e:
            err_str = str(e)
            if "proxy" in err_str or "ImportExportBottomSheet" in err_str:
                 run_on_ui_thread(lambda: BulletinHelper.show_error(self._get_string_by_key("restart_needed")))

    def _get_settings_native(self, pid):
        if not engine_settings: return {}
        try: return engine_settings.get_all_settings(pid) or {}
        except: return {}

    def _set_setting_native(self, pid, key, value):
        if not engine_settings: return
        try: engine_settings.set_setting(pid, key, value)
        except: pass

    def _clear_settings_native(self, pid):
        if not engine_settings: return
        try:
            if hasattr(engine_settings, "clear_settings"):
                engine_settings.clear_settings(pid)
        except: pass

    def _invoke_native_load(self, engine, path, existing_plugin):
        if not engine: return
        try:
            for m in engine.getClass().getDeclaredMethods():
                if m.getName() == "loadPluginFromFile" and len(m.getParameterTypes()) == 4:
                    m.setAccessible(True)
                    m.invoke(engine, path, existing_plugin, None, None)
                    return
        except: pass

    def _set_plugin_enabled(self, pid, state):
        try:
            pc = PluginsController.getInstance()
            for m in pc.getClass().getDeclaredMethods():
                if m.getName() == "setPluginEnabled":
                    m.setAccessible(True)
                    m.invoke(pc, pid, Boolean(state), None)
                    return
        except: pass
        try:
            ctx = ApplicationLoader.applicationContext
            prefs = ctx.getSharedPreferences("plugins", 0)
            editor = prefs.edit()
            editor.putBoolean(pid, state)
            editor.apply()
        except: pass

    def _is_plugin_enabled(self, pid):
        try:
            ctx = ApplicationLoader.applicationContext
            prefs = ctx.getSharedPreferences("plugins", 0)
            if prefs.contains(pid):
                return prefs.getBoolean(pid, True)
        except: pass
        return True

    def _process_export_cactus(self, peer_id, files, include_settings):
        plugins_dir = get_plugins_dir()
        msg = self._get_string_by_key("export_progress").format(len(files))
        run_on_ui_thread(lambda: BulletinHelper.show_info(msg))
        
        master_data = {}
        for fname in files:
            fpath = os.path.join(plugins_dir, fname)
            try:
                meta = self.plugin_metadata.get(fname, self._read_plugin_metadata(fpath))
                dump = self._dump_single_plugin(fpath, include_settings, meta)
                if dump:
                    master_data[os.path.splitext(fname)[0]] = dump
            except: pass
        
        if not master_data:
            run_on_ui_thread(lambda: BulletinHelper.show_error(self._get_string_by_key("error_empty")))
            return
        
        try:
            json_str = json.dumps(master_data)
            final_blob = base64.b64encode(zlib.compress(json_str.encode('utf-8'), level=9)).decode('utf-8')
            export_name = "plugins-export.cactusexport"
            export_path = os.path.join(plugins_dir, export_name)
            with open(export_path, "wb") as f:
                f.write(final_blob.encode('utf-8'))
            send_document(peer_id, export_path, caption=self._get_string_by_key("export_done"))
            time.sleep(1)
            os.remove(export_path)
        except Exception as e:
            run_on_ui_thread(lambda: BulletinHelper.show_error(self._get_string_by_key("export_error").format(e)))

    def _process_import_selected(self, all_data, selected_ids, with_settings):
        count = 0
        plugins_dir = get_plugins_dir()
        
        restore_state = self.get_setting("restore_state_mode", True)
        force_enable = self.get_setting("force_enable_mode", False)
        
        try:
            files_dir = ApplicationLoader.getFilesDirFixed().getAbsolutePath()
            datastores_dir = os.path.join(files_dir, "datastores")
            if not os.path.exists(datastores_dir):
                os.makedirs(datastores_dir)
        except:
            datastores_dir = None

        try:
            for pid in selected_ids:
                if pid in all_data:
                    pdata = all_data[pid]
                    if not pdata: continue

                    try:
                        enc_content = pdata.get("file_content")
                        if enc_content:
                            code = self.decode_and_decompress(enc_content)
                            
                            target_path = os.path.join(plugins_dir, f"{pid}.py")
                            with open(target_path, "wb") as f:
                                f.write(code)
                                
                            meta = pdata.get("plugin_meta", {})
                            
                            target_state = True
                            if restore_state:
                                target_state = meta.get("enabled", True)
                            else:
                                target_state = force_enable
                            
                            if with_settings and engine_settings:
                                self._clear_settings_native(pid)
                                settings = pdata.get("settings", {})
                                for k, v in settings.items():
                                    self._set_setting_native(pid, k, v)
                                
                                if datastores_dir and "data" in pdata and pdata["data"]:
                                    try:
                                        db_path = os.path.join(datastores_dir, f"{pid}_db.json")
                                        with open(db_path, "w", encoding="utf-8") as f:
                                            json.dump(pdata["data"], f, ensure_ascii=False)
                                    except: pass
                            
                            pc = PluginsController.getInstance()
                            engine = pc.engines.get("python") if pc and hasattr(pc, 'engines') else None
                            existing = pc.plugins.get(pid) if pc else None
                            
                            self._invoke_native_load(engine, target_path, existing)
                            self._set_plugin_enabled(pid, target_state)
                            
                            count += 1
                    except: pass

            if count > 0:
                run_on_ui_thread(lambda: NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.pluginsUpdated))
                msg = self._get_string_by_key("import_done").format(count)
                run_on_ui_thread(lambda: BulletinHelper.show_success(msg))
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error(self._get_string_by_key("not_imported")))
            
        except Exception as e:
            run_on_ui_thread(lambda: BulletinHelper.show_error(self._get_string_by_key("import_error").format(e)))

    def _dump_single_plugin(self, filepath, include_settings, meta):
        try:
            with open(filepath, "rb") as f: raw_content = f.read()
            file_content_enc = base64.b64encode(zlib.compress(raw_content, level=9)).decode('utf-8')
            plugin_id = meta.get('__id__', os.path.splitext(os.path.basename(filepath))[0])
            enabled_state = self._is_plugin_enabled(plugin_id)
            
            settings = None
            data_content = None
            
            if include_settings:
                settings = self._get_settings_native(plugin_id)
                try:
                    files_dir = ApplicationLoader.getFilesDirFixed().getAbsolutePath()
                    db_path = os.path.join(files_dir, "datastores", f"{plugin_id}_db.json")
                    if os.path.exists(db_path):
                        with open(db_path, "r", encoding="utf-8") as f:
                            data_content = json.load(f)
                except: pass

            return {
                "file_content": file_content_enc,
                "settings": settings,
                "data": data_content,
                "plugin_meta": {
                    "id": plugin_id,
                    "name": meta.get('__name__', plugin_id),
                    "version": meta.get('__version__', '1.0'),
                    "icon": meta.get('__icon__', ''),
                    "enabled": enabled_state
                }
            }
        except: return None
    
    def compress_and_encode(self, data):
        if not data: return ""
        if isinstance(data, str): data = data.encode('utf-8')
        return base64.b64encode(zlib.compress(data, level=9)).decode('utf-8')

    def decode_and_decompress(self, data):
        if not data: return b""
        return zlib.decompress(base64.b64decode(data))
