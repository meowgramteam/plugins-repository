def get_private_field(obj, field_name):
    try:
        field = obj.getClass().getDeclaredField(field_name)
        field.setAccessible(True)
        return field.get(obj)
    except:
        try:
            field = obj.getClass().getSuperclass().getDeclaredField(field_name)
            field.setAccessible(True)
            return field.get(obj)
        except:
            return None

def set_private_field(obj, field_name, value):
    try:
        field = obj.getClass().getDeclaredField(field_name)
        field.setAccessible(True)
        field.set(obj, value)
    except:
        try:
            field = obj.getClass().getSuperclass().getDeclaredField(field_name)
            field.setAccessible(True)
            field.set(obj, value)
        except:
            pass

if hasattr(sys, "_cactus_Callback5"):
    Callback5 = sys._cactus_Callback5
else:
    class Callback5(dynamic_proxy(Utilities.Callback5)):
        def __init__(self, fun):
            super().__init__()
            self.fun = fun
        def run(self, t1, t2, t3, t4, t5):
            self.fun(t1, t2, t3, t4, t5)
    sys._cactus_Callback5 = Callback5

class OpenFileHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        
    def before_hooked_method(self, param):
        try:
            file_obj = param.args[0]
            if not file_obj: return
            path = file_obj.getAbsolutePath()
            if path.endswith(".cactusexport"):
                param.setResult(True) 
                self.plugin.open_import_ui(path)
        except: pass

class SpanConstructorHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            args = param.args
            cell = args[0]
            if cell and "CheckBoxCell" in str(cell.getClass().getSimpleName()):
                anim_tv = get_private_field(cell, "animatedTextView")
                if anim_tv:
                    param.args[0] = anim_tv 
            
            target_size_dp = int(AndroidUtilities.dp(24))
            for i in range(len(args)):
                if args[i] == 46:
                    param.args[i] = Integer(target_size_dp)
                    
            if len(args) >= 7 and (str(type(args[6])) == "java.lang.Boolean" or isinstance(args[6], bool)):
                param.args[6] = Boolean(False) 
        except: pass

    def after_hooked_method(self, param):
        try:
            span = param.thisObject
            target_size_dp = int(AndroidUtilities.dp(24))
            set_private_field(span, "width", Integer(target_size_dp))
            set_private_field(span, "height", Integer(target_size_dp))
            try: set_private_field(span, "recolorDrawable", Boolean(False))
            except: pass
        except: pass

class SpanDrawHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            span = param.thisObject
            ir = get_private_field(span, "imageReceiver")
            if ir:
                try: ir.setAllowDecodeSingleFrame(False)
                except: pass
                try: ir.setAllowStartAnimation(True)
                except: pass
                try: ir.setAllowStartLottieAnimation(True)
                except: pass
                
                ir.onAttachedToWindow()
                
                try:
                    lottie = ir.getLottieAnimation()
                    if lottie and not lottie.isRunning(): lottie.start()
                except: pass
                try:
                    anim = ir.getAnimation()
                    if anim and not anim.isRunning(): anim.start()
                except: pass
        except: pass

class ImageReceiverRadiusHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            if not param.args: return
            val = param.args[0]
            target_val = int(AndroidUtilities.dp(8.0))
            if val == target_val:
                Thread = find_class("java.lang.Thread")
                stack = Thread.currentThread().getStackTrace()
                stack_str = "".join([str(x.getClassName()) for x in stack[:8]])
                if "cactuslib" in stack_str.lower() or "ImportExport" in stack_str:
                    param.args[0] = Integer(int(AndroidUtilities.dp(3.0)))
        except: pass

class ImageReceiverCoordsHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            args = param.args
            if len(args) >= 4:
                Thread = find_class("java.lang.Thread")
                stack = Thread.currentThread().getStackTrace()
                stack_str = "".join([str(x.getClassName()) for x in stack[:6]])
                if "TextPaintImageReceiverSpan" in stack_str or "ImportExport" in stack_str:
                    y = args[1]
                    offset = int(AndroidUtilities.dp(2.0)) 
                    param.args[1] = Integer(y + offset)
        except: pass

