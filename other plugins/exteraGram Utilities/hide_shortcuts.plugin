__id__ = "hide_shortcuts"
__name__ = "HideShortcuts"
__description__ = "Скрывает контакты/чаты из быстрых ярлыков приложения, оставляя только Новую беседу и Безопасный режим."
__author__ = "@RnPlugins"
__version__ = "1.0.0"
__icon__ = "RnDev/9"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader

DEX_B64 = """"""

class Plugin(BasePlugin):
    def on_plugin_load(self):
        try:
            self.log("Loading HideShortcuts module...")
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.HideShortcuts")
            self.dex_instance = self.dex_class.newInstance()
            
            # Вызываем метод start()
            start_method = self.dex_class.getMethod("start")
            start_method.invoke(self.dex_instance)
            self.log("HideShortcuts module loaded and started successfully.")
        except Exception as e:
            self.log(f"Failed to load HideShortcuts module: {e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading HideShortcuts module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(self.dex_instance)
                self.log("HideShortcuts module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
            self.dex_instance = None
        except Exception as e:
            self.log(f"Failed to unload HideShortcuts module: {e}")
