    def _force_reapply(self):
        self._last_apply_time.clear()
        self._apply_pending.clear()
        self._apply_requested.clear()
        self._extra_apply_gen.clear()
        self._drawable_cache.clear()
        for st in list(self._applied.values()):
            self._restore_chat_store(st)
        self._applied.clear()
        for st in list(self._extras_applied.values()):
            self._restore_extras_store(st)
        self._extras_applied.clear()
        if not self.get_setting("enabled", True) or not self._is_supported():
            try:
                BulletinHelper.show_info("Оформление снято (эффект выкл. или недоступен)")
            except Exception:
                pass
            return
        try:
            BulletinHelper.show_info("Настройки переприменены")
        except Exception:
            pass
        chats = [
            ca for ca in list(self._active_chats)
            if self._is_fragment_active(ca) and self._is_fragment_resumed(ca)
        ]
        for i, ca in enumerate(chats):
            try:
                self.apply_to_chat(ca, i * 75, urgent=True)
            except Exception:
                pass
        extras = [
            ex for ex in list(self._active_extras)
            if self._is_fragment_active(ex) and self._is_fragment_resumed(ex)
        ]
        for i, ex in enumerate(extras):
            try:
                self.apply_to_extra_fragment(ex, i * 85, urgent=True)
            except Exception:
                pass

    def _get_attr(self, obj, name):
        if obj is None: return None
        try: return getattr(obj, name)
        except Exception:
            try: return get_private_field(obj, name)
            except Exception: return None

    def _set_attr(self, obj, name, value):
        if obj is None:
            return False
        try:
            setattr(obj, name, value)
            return True
        except Exception:
            try:
                return bool(set_private_field(obj, name, value))
            except Exception:
                return False

    def _is_fragment_active(self, fragment):
        if not fragment:
            return False
        try:
            if _truthy_fragment_flag(self._get_attr(fragment, "isFinished")):
                return False
            if _truthy_fragment_flag(self._get_attr(fragment, "finishing")):
                return False
        except Exception:
            pass
        return True

    def _is_fragment_resumed(self, fragment):
        if not fragment:
            return False
        try:
            return bool(fragment.isResumed())
        except Exception:
            pass
        try:
            p = self._get_attr(fragment, "paused")
            if p is not None:
                return not _truthy_fragment_flag(p)
        except Exception:
            pass
        return True

    def _clamp_dp_setting(self, value, default, lo, hi):
        try:
            v = float(str(value).replace(",", ".").strip())
            return max(lo, min(hi, v))
        except Exception:
            return default

    def _panel_has_real_height(self, panel, min_dp=8):
        if panel is None or panel.getVisibility() != View.VISIBLE:
            return False
        try:
            h = int(panel.getHeight())
            if h <= 0:
                h = int(panel.getMeasuredHeight())
            return h >= AndroidUtilities.dp(min_dp)
        except Exception:
            return False

    def _detach_settings_glass_alpha_sync(self, store):
        if not store:
            return
        try:
            store.pop("_lg_hdr_alpha_i", None)
        except Exception:
            pass
        t = store.pop("_settings_ab_predraw", None)
        if not t:
            return
        try:
            bg, listener = t
            obs = bg.getViewTreeObserver()
            if obs.isAlive():
                obs.removeOnPreDrawListener(listener)
        except Exception:
            pass

    def _sync_settings_header_glass_alpha(self, fragment, store):
        try:
            if not fragment or not store:
                return
            if not self._is_fragment_active(fragment):
                self._detach_settings_glass_alpha_sync(store)
                return
            try:
                name = fragment.getClass().getName()
            except Exception:
                return
            if not name.startswith("org.telegram.ui.SettingsActivity"):
                return
            scrim = _get_first_available_field(fragment, "actionBarBackground")
            entry = store.get("action_bar")
            if not scrim or not entry:
                return
            dr = entry.get("applied")
            if dr is None:
                return
            a = max(0, min(255, int(float(scrim.getAlpha()) * 255.0 + 0.5)))
            try:
                if store.get("_lg_hdr_alpha_i") == a:
                    return
            except Exception:
                pass
            store["_lg_hdr_alpha_i"] = a
            dr.setAlpha(a)
        except Exception:
            pass

    def _attach_settings_glass_alpha_sync(self, fragment, store):
        if not fragment or not store:
            return
        self._detach_settings_glass_alpha_sync(store)
        try:
            name = fragment.getClass().getName()
        except Exception:
            return
        if not name.startswith("org.telegram.ui.SettingsActivity"):
            return
        bg = _get_first_available_field(fragment, "actionBarBackground")
        if not bg:
            return
        Lcls = safe_find_class("android.view.ViewTreeObserver$OnPreDrawListener")
        if not Lcls:
            return
        plug = self
        frag = fragment
        st = store

        class _SettingsHeaderPreDraw(dynamic_proxy(Lcls)):
            def onPreDraw(self):
                plug._sync_settings_header_glass_alpha(frag, st)
                return True

        listener = _SettingsHeaderPreDraw()
        try:
            bg.getViewTreeObserver().addOnPreDrawListener(listener)
            store["_settings_ab_predraw"] = (bg, listener)
        except Exception:
            pass

    def _resolve_action_bar(self, chat_activity):
        if not chat_activity:
            return None
        ab = getattr(chat_activity, "actionBar", None)
        if ab is None:
            try:
                ab = get_private_field(chat_activity, "actionBar")
            except Exception:
                ab = None
        if ab is None:
            try:
                getter = getattr(chat_activity, "getActionBar", None)
                if callable(getter):
                    ab = getter()
            except Exception:
                ab = None
        return ab

    def _persist_settings_bulk(self, mapping, reload_settings=False):
        try:
            self.import_settings(dict(mapping), reload_settings=reload_settings)
            return
        except Exception:
            pass
        items = list(mapping.items())
        for i, (k, v) in enumerate(items):
            last = i == len(items) - 1
            try:
                self.set_setting(k, v, reload_settings=reload_settings and last)
            except TypeError:
                self.set_setting(k, v)

    def _is_likely_dark_theme(self, theme_delegate):
        try:
            m = getattr(Theme, "isCurrentThemeDark", None)
            if callable(m):
                try:
                    return bool(m(theme_delegate))
                except TypeError:
                    return bool(m())
        except Exception:
            pass
        try:
            if theme_delegate is not None:
                fn = getattr(theme_delegate, "isDark", None)
                if callable(fn):
                    try:
                        return bool(fn())
                    except Exception:
                        pass
                v = self._get_attr(theme_delegate, "isDark")
                if v is not None:
                    return bool(v)
        except Exception:
            pass
        return None

    def _action_bar_luminance_0_1(self, theme_delegate):
        try:
            if theme_delegate is not None:
                c = int(Theme.getColor(Theme.key_actionBarDefault, theme_delegate))
            else:
                c = int(Theme.getColor(Theme.key_actionBarDefault))
            r = (c >> 16) & 0xFF
            g = (c >> 8) & 0xFF
            b = c & 0xFF
            return (0.299 * r + 0.587 * g + 0.114 * b) / 255.0
        except Exception:
            return None

    def _theme_is_light(self, theme_delegate):
        dark = self._is_likely_dark_theme(theme_delegate)
        if dark is True:
            return False
        if dark is False:
            return True
        lum = self._action_bar_luminance_0_1(theme_delegate)
        if lum is not None:
            return lum >= 0.48
        return False

    def _adapt_glass_to_theme(self, theme_delegate, action_alpha, panel_alpha, action_intensity, panel_intensity, strong_glass=False):
        lum = self._action_bar_luminance_0_1(theme_delegate)
        dark = self._is_likely_dark_theme(theme_delegate)
        aa = float(action_alpha)
        pa = float(panel_alpha)
        ai = float(action_intensity)
        pi = float(panel_intensity)
        if lum is not None:
            if lum >= 0.6:
                ai = min(0.74, ai * 0.94)
                pi = min(0.72, pi * 0.93)
                aa = min(0.91, aa * 1.025)
                pa = min(0.89, pa * 1.02)
            elif lum <= 0.2:
                ai = min(0.82, ai * 0.98)
                pi = min(0.78, pi * 0.97)
        if strong_glass:
            if lum is not None and lum >= 0.48:
                ai = min(0.7, ai * 0.89)
                pi = min(0.68, pi * 0.88)
                aa = min(0.93, aa * 1.035)
                pa = min(0.91, pa * 1.03)
            if dark is True or (lum is not None and lum < 0.34):
                ai = min(0.78, ai * 0.95)
                pi = min(0.74, pi * 0.94)
        return aa, pa, ai, pi

    def _strong_glass_tune_action_bar(self, alpha, thickness_dp, intensity):
        a = float(alpha)
        a = max(0.73, min(0.93, a * 0.92))
        th = min(max(float(thickness_dp) * 1.34, 15.0), 22.0)
        inten = min(0.86, max(float(intensity) * 1.42, 0.62))
        return a, th, inten

    def _strong_glass_tune_panels(self, alpha, thickness_dp, intensity):
        a = float(alpha)
        a = max(0.68, min(0.92, a * 0.90))
        th = min(max(float(thickness_dp) * 1.32, 12.0), 24.0)
        inten = min(0.90, max(float(intensity) * 1.38, 0.58))
        return a, th, inten

    def _compute_glass_params(self, theme_delegate, strong_glass=None):
        if strong_glass is None:
            strong_glass = bool(self.get_setting("strong_glass", False))
        action_alpha = self._parse_float_safe(self.get_setting("action_bar_alpha", "0.82"), clamp_0_1=True)
        panel_alpha = self._parse_float_safe(self.get_setting("panel_alpha", "0.80"), clamp_0_1=True)
        action_thickness_dp = self._clamp_dp_setting(self.get_setting("action_bar_thickness", "14"), 14, 6, 32)
        panel_thickness_dp = self._clamp_dp_setting(self.get_setting("panel_thickness", "12"), 12, 6, 32)
        action_intensity = self._parse_float_safe(self.get_setting("action_bar_intensity", "0.42"), clamp_0_1=True)
        panel_intensity = self._parse_float_safe(self.get_setting("panel_intensity", "0.38"), clamp_0_1=True)
        panel_radius_dp = self._clamp_dp_setting(self.get_setting("panel_radius", "0"), 0, 0, 24)
        if strong_glass:
            action_alpha, action_thickness_dp, action_intensity = self._strong_glass_tune_action_bar(
                action_alpha, action_thickness_dp, action_intensity
            )
            panel_alpha, panel_thickness_dp, panel_intensity = self._strong_glass_tune_panels(
                panel_alpha, panel_thickness_dp, panel_intensity
            )
        action_alpha, panel_alpha, action_intensity, panel_intensity = self._adapt_glass_to_theme(
            theme_delegate, action_alpha, panel_alpha, action_intensity, panel_intensity, strong_glass
        )
        return {
            "strong_glass": bool(strong_glass),
            "liquid_ok": bool(strong_glass),
            "action_alpha": action_alpha,
            "panel_alpha": panel_alpha,
            "action_thickness": AndroidUtilities.dp(action_thickness_dp),
            "panel_thickness": AndroidUtilities.dp(panel_thickness_dp),
            "action_intensity": action_intensity,
            "panel_intensity": panel_intensity,
            "panel_radius": AndroidUtilities.dp(panel_radius_dp),
        }

    def _apply_action_bar_bottom_corners(self, drawable, bottom_radius_px):
        if not drawable or bottom_radius_px is None:
            return
        r = max(0, int(bottom_radius_px))
        if r == 0:
            return
        attempts = (
            lambda: drawable.setRadius(0, 0, r, r, False),
            lambda: drawable.setRadius(0, 0, r, r, True),
            lambda: drawable.setRadius(0, 0, r, r),
        )
        for fn in attempts:
            try:
                fn()
                return
            except Exception:
                pass

    def _configure_action_bar_drawable(self, drawable, bottom_radius_px, thickness, intensity, allow_liquid_glass=True):
        if not drawable:
            return
        try:
            if thickness is not None:
                drawable.setThickness(thickness)
            if intensity is not None:
                drawable.setIntensity(float(intensity))
        except Exception:
            pass
        self._apply_action_bar_bottom_corners(drawable, bottom_radius_px)

    def _clip_action_bar_outline(self, action_bar, bottom_radius_px):
        if not action_bar or Build.VERSION.SDK_INT < 21:
            return
        try:
            try:
                action_bar.setOutlineProvider(None)
            except Exception:
                pass
            action_bar.setClipToOutline(False)
            fn = getattr(action_bar, "invalidateOutline", None)
            if callable(fn):
                fn()
            self._clear_outline_ancestors(action_bar, 7)
            action_bar.invalidate()
        except Exception:
            pass

    def _clear_view_outline_clip(self, view):
        if not view or Build.VERSION.SDK_INT < 21:
            return
        try:
            view.setClipToOutline(False)
            view.setOutlineProvider(None)
            fn = getattr(view, "invalidateOutline", None)
            if callable(fn):
                fn()
            view.invalidate()
        except Exception:
            pass

    def _clear_outline_ancestors(self, view, max_depth=6):
        if not view or Build.VERSION.SDK_INT < 21:
            return
        parent = view
        for _ in range(max(0, int(max_depth))):
            try:
                parent = parent.getParent()
            except Exception:
                break
            if parent is None:
                break
            self._clear_view_outline_clip(parent)

    def _view_needs_reapply_background(self, store, key, view):
        if view is None:
            return False
        entry = store.get(key)
        if not entry or entry.get("view") is not view:
            return True
        applied = entry.get("applied")
        if applied is None:
            return True
        try:
            if view.getBackground() != applied:
                return True
        except Exception:
            return True
        return False

    def _action_bar_tune_signature(self, action_thickness, action_intensity, allow_liquid_glass, action_alpha):
        th = 0
        try:
            th = int(action_thickness) if action_thickness is not None else 0
        except Exception:
            th = 0
        try:
            intensity = round(float(action_intensity), 4)
        except Exception:
            intensity = 0.0
        try:
            alpha = round(float(action_alpha), 4)
        except Exception:
            alpha = 0.0
        return (th, intensity, bool(allow_liquid_glass), alpha)

    def _action_bar_needs_reapply(self, store, action_bar, tune_sig=None):
        entry = store.get("action_bar")
        if action_bar is None:
            return False
        if not entry or entry.get("view") is not action_bar:
            return True
        if entry.get("mode") != "drawable":
            return True
        if tune_sig is not None and entry.get("_lg_ab_sig") != tune_sig:
            return True
        if entry.get("_lg_ab_sig") is not None:
            try:
                if self._get_attr(action_bar, "actionBarColor") not in (None, 0, Color.TRANSPARENT):
                    return True
            except Exception:
                pass
            return False
        return self._view_needs_reapply_background(store, "action_bar", action_bar)

    def _clear_actionbar_solid_scrim(self, store, action_bar):
        if not action_bar:
            return
        try:
            if "action_bar_color" not in store or store["action_bar_color"].get("view") is not action_bar:
                store["action_bar_color"] = {
                    "view": action_bar,
                    "actionBarColor": self._get_attr(action_bar, "actionBarColor"),
                    "actionModeColor": self._get_attr(action_bar, "actionModeColor"),
                }
            self._set_attr(action_bar, "actionBarColor", Color.TRANSPARENT)
            self._set_attr(action_bar, "actionModeColor", Color.TRANSPARENT)
        except Exception:
            store.pop("action_bar_color", None)

    def _build_action_bar_provider(self, resources_provider, action_alpha, use_monet=False):
        if use_monet:
            provider = self._invoke_native_blur_provider("topPanel", resources_provider)
            if provider is not None:
                sig = self._color_provider_cache_sig(
                    resources_provider, Theme.key_actionBarDefault, action_alpha, False, True, True
                )
                return _ColorProviderProxy(provider, False, True, True), sig
        return self._build_color_provider(
            resources_provider,
            Theme.key_actionBarDefault,
            action_alpha,
            disable_top_stroke=False,
            disable_shadow=True,
            disable_bottom_stroke=True,
        )

    def _get_action_bar_applied_drawable(self, store):
        if not store:
            return None
        entry = store.get("action_bar")
        if not entry or entry.get("mode") != "drawable":
            return None
        return entry.get("applied")

    def _find_action_bar_store(self, action_bar):
        if not action_bar:
            return None
        store = self._action_bar_store_index.get(id(action_bar))
        if store:
            entry = store.get("action_bar")
            if entry and entry.get("view") is action_bar:
                return store
            self._unindex_action_bar_store(action_bar)
        for candidate in list(self._applied.values()) + list(self._extras_applied.values()):
            entry = candidate.get("action_bar")
            if entry and entry.get("view") is action_bar:
                self._index_action_bar_store(action_bar, candidate)
                return candidate
        return None

    def _action_bar_in_action_mode(self, action_bar):
        if not action_bar:
            return False
        try:
            fn = getattr(action_bar, "isActionModeShowed", None)
            if callable(fn):
                return bool(fn())
        except Exception:
            pass
        try:
            return bool(self._get_attr(action_bar, "actionModeVisible"))
        except Exception:
            return False

    def _action_bar_glass_suspended(self, store):
        return bool(store and store.get("action_bar_action_mode_suspended"))

    def _resolve_chat_from_action_bar(self, action_bar):
        if not action_bar:
            return None
        try:
            fragment = self._get_attr(action_bar, "parentFragment")
        except Exception:
            fragment = None
        if fragment is None:
            return None
        try:
            if _fragment_class_name(fragment) == CLASS_CHAT_ACTIVITY:
                return fragment
        except Exception:
            pass
        return None

    def _resolve_theme_delegate_from_action_bar(self, action_bar):
        chat = self._resolve_chat_from_action_bar(action_bar)
        if chat is not None:
            return self._resolve_resources_provider(chat)
        try:
            fragment = self._get_attr(action_bar, "parentFragment")
        except Exception:
            fragment = None
        if fragment is not None:
            return self._resolve_resources_provider(fragment)
        return None

    def _actionbar_theme_color(self, color_key, theme_delegate=None):
        try:
            if theme_delegate is not None:
                return int(Theme.getColor(color_key, theme_delegate))
            return int(Theme.getColor(color_key))
        except Exception:
            try:
                return int(Theme.getColor(color_key))
            except Exception:
                return 0

    def _strip_actionbar_glass_drawable(self, store, action_bar):
        if not action_bar or not store:
            return False
        entry = store.get("action_bar")
        if not entry or entry.get("view") is not action_bar:
            return False
        theme_delegate = self._resolve_theme_delegate_from_action_bar(action_bar)
        action_mode_color = self._actionbar_theme_color(
            Theme.key_actionBarActionModeDefault, theme_delegate
        )
        action_bar_color = self._actionbar_theme_color(
            Theme.key_actionBarDefault, theme_delegate
        )
        try:
            ours = entry.get("applied")
            current_bg = action_bar.getBackground()
            orig_bg = entry.get("background")
            if current_bg is ours:
                if orig_bg is not None and orig_bg is not ours:
                    action_bar.setBackground(orig_bg)
                else:
                    action_bar.setBackground(None)
            try:
                eb = store.get("action_bar_blurred")
                if eb and eb.get("view") is action_bar and eb.get("blurredBackground") is not None:
                    self._set_attr(action_bar, "blurredBackground", eb.get("blurredBackground"))
                else:
                    self._set_attr(action_bar, "blurredBackground", False)
            except Exception:
                self._set_attr(action_bar, "blurredBackground", False)
            if action_bar_color:
                action_bar.setBackgroundColor(action_bar_color)
            if action_mode_color:
                self._set_attr(action_bar, "actionModeColor", action_mode_color)
                setter = getattr(action_bar, "setActionModeOverrideColor", None)
                if callable(setter):
                    setter(action_mode_color)
            action_bar.invalidate()
            return True
        except Exception as exc:
            self._debug_log_exc("action_bar strip glass", exc)
            return False

    def _reapply_actionbar_glass_drawable(self, store, action_bar):
        if not action_bar or not store:
            return False
        entry = store.get("action_bar")
        if not entry or entry.get("view") is not action_bar or entry.get("mode") != "drawable":
            return False
        ours = entry.get("applied")
        if ours is None:
            return False
        try:
            action_bar.setBackground(ours)
            self._set_attr(action_bar, "backgroundColor", Color.TRANSPARENT)
            self._shield_actionbar_glass_drawable(store, action_bar, bump_diag=False)
            action_bar.invalidate()
            return True
        except Exception as exc:
            self._debug_log_exc("action_bar reapply glass", exc)
            return False

    def _hide_chat_actionbar_chrome_for_action_mode(self, store, chat_activity):
        if not chat_activity or store.get("action_mode_chrome"):
            return
        saved = {}
        for field in (
            "avatarContainer",
            "headerItem",
            "attachItem",
            "searchItem",
            "searchIconItem",
            "audioCallIconItem",
            "editTextItem",
        ):
            view = _get_first_available_field(chat_activity, field)
            if view is None:
                continue
            try:
                saved[field] = {
                    "view": view,
                    "visibility": int(view.getVisibility()),
                    "alpha": float(view.getAlpha()),
                }
                view.setVisibility(View.GONE)
            except Exception:
                pass
        action_bar = self._resolve_action_bar(chat_activity)
        if action_bar is not None:
            try:
                titles = getattr(action_bar, "getTitlesContainer", None)
                titles = titles() if callable(titles) else None
            except Exception:
                titles = None
            if titles is not None:
                try:
                    saved["_titles_container"] = {
                        "view": titles,
                        "visibility": int(titles.getVisibility()),
                        "alpha": float(titles.getAlpha()),
                    }
                    titles.setVisibility(View.GONE)
                except Exception:
                    pass
        if saved:
            store["action_mode_chrome"] = saved

    def _restore_chat_actionbar_chrome_after_action_mode(self, store):
        saved = store.pop("action_mode_chrome", None)
        if not saved:
            return
        for key, entry in saved.items():
            view = entry.get("view") if entry else None
            if view is None:
                continue
            try:
                vis = entry.get("visibility")
                if vis is not None:
                    view.setVisibility(int(vis))
                alpha = entry.get("alpha")
                if alpha is not None:
                    view.setAlpha(float(alpha))
                view.invalidate()
            except Exception:
                pass

    def _hide_top_panel_for_action_mode(self, store, chat_activity):
        if not chat_activity or store.get("action_mode_top_panel"):
            return
        layout = self._resolve_top_panel_layout(chat_activity)
        if layout is None:
            return
        try:
            store["action_mode_top_panel"] = {
                "view": layout,
                "visibility": int(layout.getVisibility()),
                "alpha": float(layout.getAlpha()),
            }
            layout.setVisibility(View.GONE)
            layout.invalidate()
        except Exception:
            store.pop("action_mode_top_panel", None)

    def _restore_top_panel_after_action_mode(self, store):
        entry = store.pop("action_mode_top_panel", None)
        if not entry:
            return
        layout = entry.get("view")
        if layout is None:
            return
        try:
            vis = entry.get("visibility")
            if vis is not None:
                layout.setVisibility(int(vis))
            alpha = entry.get("alpha")
            if alpha is not None:
                layout.setAlpha(float(alpha))
            layout.invalidate()
        except Exception:
            pass

    def _enter_actionbar_action_mode(self, store, action_bar):
        if not action_bar or not store:
            return
        if store.get("action_bar_action_mode_suspended"):
            return
        store["action_bar_action_mode_suspended"] = True
        self._strip_actionbar_glass_drawable(store, action_bar)
        chat = self._resolve_chat_from_action_bar(action_bar)
        if chat is not None:
            self._hide_chat_actionbar_chrome_for_action_mode(store, chat)
            if self.get_setting("apply_top_panels", True):
                self._hide_top_panel_for_action_mode(store, chat)

    def _resume_actionbar_glass_after_action_mode(self, store, action_bar):
        if not action_bar or not store:
            return
        if self._action_bar_in_action_mode(action_bar):
            return
        if not store.pop("action_bar_action_mode_suspended", None):
            return
        self._restore_chat_actionbar_chrome_after_action_mode(store)
        self._restore_top_panel_after_action_mode(store)
        try:
            entry = store.get("action_bar")
            if entry and entry.get("mode") == "drawable" and entry.get("applied") is not None:
                self._reapply_actionbar_glass_drawable(store, action_bar)
            else:
                self._shield_actionbar_glass_drawable(store, action_bar)
            action_bar.invalidate()
        except Exception as exc:
            self._debug_log_exc("action_bar resume after action mode", exc)

    def _shield_actionbar_glass_drawable(self, store, action_bar, bump_diag=True):
        if not action_bar:
            return
        if self._action_bar_in_action_mode(action_bar) or self._action_bar_glass_suspended(store):
            return
        try:
            if "action_bar_blurred" not in store or store["action_bar_blurred"].get("view") is not action_bar:
                store["action_bar_blurred"] = {
                    "view": action_bar,
                    "blurredBackground": self._get_attr(action_bar, "blurredBackground"),
                }
            self._set_attr(action_bar, "blurredBackground", True)
        except Exception:
            pass
        self._clear_actionbar_solid_scrim(store, action_bar)
        if bump_diag:
            self._bump_diag("action_bar_shield_calls")

    def _on_action_bar_background_changed(self, action_bar, new_bg):
        if not action_bar or not self.get_setting("enabled", True):
            return
        store = self._find_action_bar_store(action_bar)
        if self._action_bar_in_action_mode(action_bar) or self._action_bar_glass_suspended(store):
            return
        if not store:
            return
        ours = self._get_action_bar_applied_drawable(store)
        if ours is None:
            return
        if new_bg is ours:
            return
        key = id(action_bar)
        now_ms = time.time() * 1000.0
        if now_ms - float(self._action_bar_color_shield_last.get(key, 0.0)) < self._ACTION_BAR_COLOR_SHIELD_MS:
            return
        self._action_bar_color_shield_last[key] = now_ms
        try:
            action_bar.setBackground(ours)
            self._shield_actionbar_glass_drawable(store, action_bar)
            self._bump_diag("action_bar_bg_restore_calls")
            action_bar.invalidate()
        except Exception as exc:
            self._debug_log_exc("action_bar bg restore", exc)

    def _on_action_bar_color_changed(self, action_bar, before=False):
        if not action_bar or not self.get_setting("enabled", True):
            return
        store = self._find_action_bar_store(action_bar)
        if self._action_bar_in_action_mode(action_bar) or self._action_bar_glass_suspended(store):
            return
        if not store:
            return
        if before:
            self._shield_actionbar_glass_drawable(store, action_bar)
            return
        key = id(action_bar)
        now_ms = time.time() * 1000.0
        if now_ms - float(self._action_bar_color_shield_last.get(key, 0.0)) < self._ACTION_BAR_COLOR_SHIELD_MS:
            return
        self._action_bar_color_shield_last[key] = now_ms
        try:
            self._shield_actionbar_glass_drawable(store, action_bar)
            action_bar.invalidate()
        except Exception as exc:
            self._debug_log_exc("action_bar color shield", exc)

    def _on_action_bar_show_action_mode_before(self, action_bar):
        if not action_bar or not self.get_setting("enabled", True):
            return
        if not self.get_setting("apply_action_bar", True):
            return
        store = self._find_action_bar_store(action_bar)
        if not store:
            return
        self._enter_actionbar_action_mode(store, action_bar)

    def _on_action_bar_mode_changed(self, action_bar):
        if not action_bar or not self.get_setting("enabled", True):
            return
        store = self._find_action_bar_store(action_bar)
        if not store:
            return
        if self._action_bar_in_action_mode(action_bar):
            self._enter_actionbar_action_mode(store, action_bar)
            return
        run_on_ui_thread(
            lambda ab=action_bar, st=store: self._resume_actionbar_glass_after_action_mode(st, ab),
            self._ACTION_BAR_MODE_RESUME_MS,
        )

    def _detach_action_bar_native_blur(self, host_fragment, action_bar):
        if not action_bar:
            return
        content_view = _get_first_available_field(host_fragment, "contentView", "fragmentView")
        if content_view is not None:
            try:
                blur_behind = getattr(content_view, "blurBehindViews", None)
                if blur_behind is not None:
                    blur_behind.remove(action_bar)
            except Exception:
                pass

    def _factory_create_drawable(self, factory, target, provider, allow_liquid_glass=True, track_fail=False, cache_sig=None):
        if not factory or not target:
            if track_fail:
                self._bump_diag("drawable_create_fail")
            return None
        prov_part = cache_sig if cache_sig is not None else (id(provider) if provider is not None else 0)
        cache_key = (id(factory), id(target), prov_part, bool(allow_liquid_glass))
        cached = self._drawable_cache_get(cache_key)
        if cached is not None:
            self._bump_diag("drawable_cache_hits")
            return cached
        prev_liquid = self._factory_get_liquid_allowed(factory)
        drawable = None
        try:
            self._factory_set_liquid_allowed(factory, bool(allow_liquid_glass))
            arg_sets = ()
            if provider is not None:
                arg_sets = (
                    (target, provider, bool(allow_liquid_glass)),
                    (target, provider, True),
                    (target, provider),
                )
            else:
                arg_sets = ((target,),)
            for args in arg_sets:
                try:
                    drawable = factory.create(*args)
                    if drawable is not None:
                        break
                except TypeError:
                    continue
                except Exception:
                    continue
            if drawable is not None:
                self._drawable_cache_put(cache_key, drawable)
                return drawable
            if track_fail:
                self._bump_diag("drawable_create_fail")
            return None
        except Exception as exc:
            if track_fail:
                self._bump_diag("drawable_create_fail")
            self._debug_log_exc("factory_create_drawable", exc)
            return None
        finally:
            if prev_liquid is not None:
                self._factory_set_liquid_allowed(factory, prev_liquid)

    def _apply_action_bar_glass(
        self, store, host_fragment, action_bar, factory, frosted_factory, theme_delegate,
        action_alpha, action_thickness, action_intensity, panel_radius,
        allow_liquid_glass, performance_mode=False, settings_header_sync=False,
    ):
        if not action_bar or not factory:
            return False
        tune_sig = self._action_bar_tune_signature(
            action_thickness, action_intensity, allow_liquid_glass, action_alpha
        )
        entry = store.get("action_bar")
        if (
            entry
            and entry.get("view") is action_bar
            and entry.get("mode") == "drawable"
            and entry.get("_lg_ab_sig") == tune_sig
        ):
            if self._action_bar_in_action_mode(action_bar):
                self._enter_actionbar_action_mode(store, action_bar)
            else:
                self._shield_actionbar_glass_drawable(store, action_bar)
            return True
        prev_ab = store.get("action_bar")
        if prev_ab and prev_ab.get("view") is not None and prev_ab.get("view") is not action_bar:
            self._restore_action_bar_parts(store)
        self._detach_action_bar_native_blur(host_fragment, action_bar)
        if allow_liquid_glass:
            self._factory_set_liquid_allowed(factory, True)
            self._factory_set_liquid_allowed(frosted_factory, True)
        provider, _psig = self._build_action_bar_provider(theme_delegate, action_alpha, use_monet=allow_liquid_glass)
        if provider is None:
            return False
        bg = None
        fac_order = self._action_bar_drawable_factories_order(factory, frosted_factory)
        if not allow_liquid_glass and frosted_factory is not None:
            fac_order = [f for f in (frosted_factory, factory) if f is not None]
        for fac in fac_order:
            bg = self._factory_create_drawable(fac, action_bar, provider, allow_liquid_glass, track_fail=True)
            if bg:
                break
        if not bg:
            return False
        self._configure_action_bar_drawable(
            bg, panel_radius, action_thickness, action_intensity,
            allow_liquid_glass=allow_liquid_glass,
        )
        self._disable_actionbar_shadows(store, action_bar)
        self._apply_background(store, "action_bar", action_bar, bg)
        if self._action_bar_in_action_mode(action_bar):
            self._enter_actionbar_action_mode(store, action_bar)
        else:
            self._shield_actionbar_glass_drawable(store, action_bar)
        store["action_bar"]["mode"] = "drawable"
        store["action_bar"]["_lg_ab_sig"] = tune_sig
        self._clip_action_bar_outline(action_bar, panel_radius)
        content_view = _get_first_available_field(host_fragment, "contentView")
        try:
            action_bar.invalidate()
            if content_view:
                content_view.invalidate()
        except Exception:
            pass
        if settings_header_sync:
            self._attach_settings_glass_alpha_sync(host_fragment, store)
            self._sync_settings_header_glass_alpha(host_fragment, store)
        pr = panel_radius
        clip_delay = 280 if performance_mode else 180
        run_on_ui_thread(lambda ab=action_bar, p=pr: self._clip_action_bar_outline(ab, p), clip_delay)
        return True

    def _is_settings_activity(self, fragment):
        try:
            return _fragment_class_name(fragment).startswith(CLASS_SETTINGS_ACTIVITY)
        except Exception:
            return False

    def _extra_fragment_scope(self, fragment):
        cname = _fragment_class_name(fragment)
        sk = _EXTRA_FRAGMENT_SETTING_BY_CLASS.get(cname)
        if sk and self.get_setting(sk, False):
            return True, sk, False
        if not self.get_setting("apply_action_bar", True):
            return False, sk, False
        if cname in _EXTRA_ACTION_BAR_ONLY_CLASSES:
            return True, sk, True
        return False, sk, False

    def _top_panel_tune_signature(self, panel_thickness, panel_intensity, allow_liquid_glass):
        th = 0
        try:
            th = int(panel_thickness) if panel_thickness is not None else 0
        except Exception:
            th = 0
        try:
            intensity = round(float(panel_intensity), 4)
        except Exception:
            intensity = 0.0
        return (th, intensity, bool(allow_liquid_glass))

    def _panel_needs_reapply(self, store, key, view, tune_sig=None):
        entry = store.get(key)
        if entry and entry.get("mode") == "topics_tabs":
            if view is None:
                return False
            if entry.get("view") is not view:
                return True
            return False
        if entry and entry.get("mode") in ("top_panel_layout", "top_panel_tune"):
            if view is None:
                return False
            if entry.get("view") is not view:
                return True
            if self._top_panel_layout_waiting_native(store, view):
                return True
            if tune_sig is not None and entry.get("_lg_tune_sig") != tune_sig:
                return True
            if entry.get("_lg_tune_sig") is not None:
                return False
            cur = self._get_top_panel_layout_drawable(view)
            return cur is None and not entry.get("_lg_top_panel_gave_up")
        return self._view_needs_reapply_background(store, key, view)

    def _store_needs_cleanup(self, store):
        if not store:
            return False
        apply_action_bar = self.get_setting("apply_action_bar", True)
        apply_top_panels = self.get_setting("apply_top_panels", True)
        apply_search_bar = self.get_setting("apply_search_bar", True)
        apply_story_bar = self.get_setting("apply_story_bar", True)
        ab_keys = ("action_bar", "action_bar_blurred", "action_bar_cast_shadows", "action_bar_color")
        if not apply_action_bar and any(store.get(k) for k in ab_keys):
            return True
        if not apply_top_panels and any(store.get(k) for k in ("top_panel_layout", "top_panel")):
            return True
        if not apply_search_bar and store.get("search_container"):
            return True
        if not apply_search_bar and (store.get("search_bar") or store.get("search_results")):
            return True
        if not apply_story_bar and store.get("story_bar"):
            return True
        return False

    def _restore_panel_if_view_replaced(self, store, key, new_view):
        prev = store.get(key)
        if prev and new_view is not None and prev.get("view") is not None and prev.get("view") is not new_view:
            self._restore_panel_entry(store, key)

    def _parse_float_safe(self, value, default=0.8, clamp_0_1=False):
        try:
            v = float(str(value).replace(",", ".").strip())
            if clamp_0_1:
                return max(0.0, min(1.0, v))
            return v
        except (TypeError, ValueError, AttributeError):
            return default

    def _is_supported(self):
        sdk = int(getattr(Build.VERSION, "SDK_INT", 0))
        if sdk < 29:
            self._warn_once("Blur3 не поддерживается на этом устройстве.")
            return False
        try:
            blur_on = SharedConfig.chatBlurEnabled()
        except Exception:
            blur_on = True
        if not blur_on:
            self._warn_once("Размытие чата отключено. Включите в настройках Telegram.")
            return False
        if sdk < 33:
            self._warn_once("Liquid-режим недоступен — используется Frosted.")
        return True

    def _warn_once(self, text):
        if self._warned:
            return
        try:
            BulletinHelper.show_info(text)
            self._warned = True
        except Exception as exc:
            self._debug_log_exc("warn_once bulletin", exc)

    def apply_to_chat(self, chat_activity, delay_ms=120, urgent=False):
        if not chat_activity or not self._is_fragment_active(chat_activity):
            return
        self._prune_runtime_state()
        if not self.get_setting("enabled", True):
            key = id(chat_activity)
            st = self._applied.get(key)
            if st:
                self._restore_chat_store(st)
                self._applied.pop(key, None)
                self._last_apply_time.pop(key, None)
            self._apply_pending.discard(key)
            self._apply_requested.discard(key)
            try:
                self._active_chats.discard(chat_activity)
            except Exception:
                pass
            return
        if not self._is_supported():
            key = id(chat_activity)
            st = self._applied.get(key)
            if st:
                self._restore_chat_store(st)
                self._applied.pop(key, None)
                self._last_apply_time.pop(key, None)
            self._apply_pending.discard(key)
            self._apply_requested.discard(key)
            try:
                self._active_chats.discard(chat_activity)
            except Exception:
                pass
            return

        try:
            self._active_chats.add(chat_activity)
        except Exception:
            pass

        key = id(chat_activity)
        store = self._applied.get(key, {})
        debounce_ms_hint = 0
        if not urgent and store:
            try:
                prev_sig = store.get("_lg_apply_sig")
                current_sig = self._chat_apply_signature(chat_activity)
                if prev_sig is None and self._store_needs_sig_recovery(store):
                    urgent = True
                elif self._is_real_theme_burst(prev_sig, current_sig):
                    delay_ms = max(delay_ms, 180)
                    debounce_ms_hint = self._THEME_BURST_DEBOUNCE_MS
                    self._bump_diag("theme_burst_chat")
                    self._maybe_theme_burst_hint()
                elif prev_sig is not None and prev_sig != current_sig:
                    delay_ms = max(delay_ms, 90)
            except Exception:
                pass
        if len(self._last_apply_time) > 128:
            valid_keys = set(self._applied.keys())
            self._last_apply_time = {k: v for k, v in self._last_apply_time.items() if k in valid_keys}
        current_time = time.time() * 1000
        last_time = self._last_apply_time.get(key, 0)
        debounce_ms = self._PERFORMANCE_DEBOUNCE_MS if self.get_setting("performance_mode", False) else self._APPLY_DEBOUNCE_MS
        if debounce_ms_hint:
            debounce_ms = max(debounce_ms, debounce_ms_hint)
        if not urgent and self._in_startup_grace():
            debounce_ms = max(debounce_ms, self._STARTUP_DEBOUNCE_MIN_MS)
            delay_ms = max(delay_ms, self._STARTUP_EXTRA_DELAY_MIN_MS)

        if current_time - last_time < debounce_ms:
            self._apply_requested.add(key)
            return
        if key in self._apply_pending:
            self._apply_requested.add(key)
            return
        if not self._needs_apply(chat_activity):
            return

        self._apply_pending.add(key)
        self._last_apply_time[key] = current_time

        run_on_ui_thread(lambda: self._apply_chat_impl(chat_activity), delay_ms)

    def _needs_apply(self, chat_activity):
        store = self._applied.get(id(chat_activity), {})
        apply_action_bar = self.get_setting("apply_action_bar", True)
        apply_top_panels = self.get_setting("apply_top_panels", True)
        apply_search_bar = self.get_setting("apply_search_bar", True)
        apply_story_bar = self.get_setting("apply_story_bar", True)
        if not (apply_action_bar or apply_top_panels or apply_search_bar or apply_story_bar):
            return bool(store)
        if self._store_needs_cleanup(store):
            return True
        try:
            if store.get("_lg_apply_sig") != self._chat_apply_signature(chat_activity):
                return True
        except Exception:
            pass
        if not store:
            return True
        if apply_action_bar:
            ab = self._resolve_action_bar(chat_activity)
            if ab:
                strong_glass = self.get_setting("strong_glass", False)
                action_thickness = AndroidUtilities.dp(
                    self._clamp_dp_setting(self.get_setting("action_bar_thickness", "14"), 14, 6, 32)
                )
                action_intensity = self._parse_float_safe(self.get_setting("action_bar_intensity", "0.42"), clamp_0_1=True)
                action_alpha = self._parse_float_safe(self.get_setting("action_bar_alpha", "0.82"), clamp_0_1=True)
                ab_sig = self._action_bar_tune_signature(
                    action_thickness, action_intensity, bool(strong_glass), action_alpha
                )
                if self._action_bar_needs_reapply(store, ab, tune_sig=ab_sig):
                    return True
        if apply_top_panels:
            tpl = self._resolve_top_panel_layout(chat_activity)
            if tpl is not None:
                if self._top_panel_layout_waiting_native(store, tpl):
                    return True
                tune_sig = self._top_panel_tune_signature(
                    AndroidUtilities.dp(self._clamp_dp_setting(self.get_setting("panel_thickness", "12"), 12, 6, 32)),
                    self._parse_float_safe(self.get_setting("panel_intensity", "0.38"), clamp_0_1=True),
                    bool(self.get_setting("strong_glass", False)),
                )
                if self._panel_needs_reapply(store, "top_panel_layout", tpl, tune_sig=tune_sig):
                    return True
            elif "top_panel_layout" in store:
                return True
            p = _get_first_available_field(chat_activity, "topChatPanelView")
            if p is not None and self._panel_has_real_height(p, self._MIN_TOP_PANEL_DP):
                if self._panel_needs_reapply(store, "top_panel", p):
                    return True
            elif "top_panel" in store or "top_panel2" in store:
                return True
        if apply_search_bar:
            sc = _get_first_available_field(chat_activity, "searchContainer")
            if sc is not None and sc.getVisibility() == View.VISIBLE:
                if self._panel_needs_reapply(store, "search_container", sc):
                    return True
            elif "search_container" in store:
                return True
            sp = self._resolve_search_primary_view(chat_activity)
            if sp is not None and self._chat_search_ui_visible(sp):
                if self._panel_needs_reapply(store, "search_bar", sp):
                    return True
            elif "search_bar" in store:
                return True
            msc = _get_first_available_field(chat_activity, "messagesSearchListContainer")
            if msc is not None and msc.getVisibility() == View.VISIBLE:
                if self._panel_needs_reapply(store, "search_results", msc):
                    return True
            elif "search_results" in store:
                return True
        elif "search_bar" in store or "search_results" in store:
            return True
        if apply_story_bar:
            sv = self._resolve_story_bar_view(chat_activity)
            if sv is not None and sv.getVisibility() == View.VISIBLE:
                if self._panel_needs_reapply(store, "story_bar", sv):
                    return True
            elif "story_bar" in store:
                return True
        elif "story_bar" in store:
            return True
        return False

    def _apply_chat_impl(self, chat_activity):
        try:
            if not self._is_fragment_active(chat_activity):
                return
            if not self._is_fragment_resumed(chat_activity):
                return
            if not self.get_setting("enabled", True):
                ek = id(chat_activity)
                st_off = self._applied.pop(ek, None)
                if st_off:
                    self._restore_chat_store(st_off)
                self._apply_pending.discard(ek)
                self._apply_requested.discard(ek)
                self._last_apply_time.pop(ek, None)
                try:
                    self._active_chats.discard(chat_activity)
                except Exception:
                    pass
                return
            if not self._is_supported():
                key_cleanup = id(chat_activity)
                st_cleanup = self._applied.pop(key_cleanup, None)
                if st_cleanup:
                    self._restore_chat_store(st_cleanup)
                self._apply_pending.discard(key_cleanup)
                self._apply_requested.discard(key_cleanup)
                self._last_apply_time.pop(key_cleanup, None)
                try:
                    self._active_chats.discard(chat_activity)
                except Exception:
                    pass
                return

            self._ensure_native_glass_setup(chat_activity)

            key = id(chat_activity)
            store = self._applied.setdefault(key, {})
            apply_action_bar = self.get_setting("apply_action_bar", True)
            apply_top_panels = self.get_setting("apply_top_panels", True)
            apply_search_bar = self.get_setting("apply_search_bar", True)
            apply_story_bar = self.get_setting("apply_story_bar", True)
            performance_mode = self.get_setting("performance_mode", False)
            self._sync_disabled_regions(store, chat_activity)
            if not (apply_action_bar or apply_top_panels or apply_search_bar or apply_story_bar):
                store.pop("_lg_apply_sig", None)
                self._factory_cooldown_chat.pop(key, None)
                return
            theme_delegate = self._resolve_resources_provider(chat_activity)
            if apply_action_bar:
                if self._blur_needs_preserved_background_clip(chat_activity):
                    if store.get("background_clip"):
                        self._restore_background_clip_for_chat(chat_activity)
                else:
                    self._unclip_chat_background(chat_activity)

            factory, frosted_factory = self._resolve_blur_factory_pair(chat_activity, store)
            if not factory and frosted_factory:
                factory, frosted_factory = frosted_factory, None
            if not factory:
                now_ms = time.time() * 1000
                next_retry = float(self._factory_cooldown_chat.get(key, 0))
                if now_ms < next_retry:
                    self._bump_diag("factory_cooldown_skip_chat")
                    return
                retry_ms = 700.0 if self._in_startup_grace() else float(self._FACTORY_RETRY_COOLDOWN_MS)
                self._factory_cooldown_chat[key] = now_ms + retry_ms
                self._bump_diag("factory_miss_chat")
                store.pop("_lg_apply_sig", None)
                return
            self._factory_cooldown_chat.pop(key, None)

            glass = self._compute_glass_params(theme_delegate)
            strong_glass = glass["strong_glass"]
            liquid_ok = glass["liquid_ok"]
            action_alpha = glass["action_alpha"]
            panel_alpha = glass["panel_alpha"]
            action_thickness = glass["action_thickness"]
            panel_thickness = glass["panel_thickness"]
            action_intensity = glass["action_intensity"]
            panel_intensity = glass["panel_intensity"]
            panel_radius = glass["panel_radius"]
            self._ensure_factory_source_root(chat_activity, factory, frosted_factory)
            self._reset_factories_liquid_glass(factory, frosted_factory, allow_liquid=strong_glass)

            action_bar = self._resolve_action_bar(chat_activity)

            if action_bar and apply_action_bar:
                perf = self.get_setting("performance_mode", False)
                if not self._apply_action_bar_glass(
                    store, chat_activity, action_bar, factory, frosted_factory, theme_delegate,
                    action_alpha, action_thickness, action_intensity, panel_radius,
                    liquid_ok, performance_mode=perf,
                ):
                    store["_lg_sig_dirty"] = True

            if apply_top_panels:
                top_layout = self._resolve_top_panel_layout(chat_activity)
                if top_layout is not None:
                    if "top_panel" in store:
                        self._restore_panel_entry(store, "top_panel")
                    if "top_panel2" in store:
                        self._restore_panel_entry(store, "top_panel2")
                    self._apply_top_panel_layout_glass(
                        store, "top_panel_layout", top_layout, factory, frosted_factory, theme_delegate,
                        panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        allow_liquid_glass=liquid_ok, provider_kind="chat", owner=chat_activity,
                    )
                else:
                    if "top_panel_layout" in store:
                        self._restore_panel_entry(store, "top_panel_layout")
                    top1 = _get_first_available_field(chat_activity, "topChatPanelView")
                    self._apply_or_restore_top_row(
                        store, "top_panel", top1, factory, theme_delegate,
                        panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        allow_liquid_glass=liquid_ok, chat_activity=chat_activity,
                    )
                    if "top_panel2" in store:
                        self._restore_panel_entry(store, "top_panel2")

            if apply_search_bar:
                search_container = _get_first_available_field(chat_activity, "searchContainer")
                if search_container and search_container.getVisibility() == View.VISIBLE:
                    self._restore_panel_if_view_replaced(store, "search_container", search_container)
                    self._apply_search_bar(
                        store, search_container, factory, theme_delegate, panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        store_key="search_container", strong_glass=strong_glass, allow_liquid_glass=liquid_ok,
                    )
                elif "search_container" in store:
                    self._restore_panel_entry(store, "search_container")
                search_panel = self._resolve_search_primary_view(chat_activity)
                if search_panel and self._chat_search_ui_visible(search_panel):
                    self._restore_panel_if_view_replaced(store, "search_bar", search_panel)
                    self._apply_search_bar(
                        store, search_panel, factory, theme_delegate, panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        strong_glass=strong_glass, allow_liquid_glass=liquid_ok,
                    )
                elif "search_bar" in store:
                    self._restore_panel_entry(store, "search_bar")
                msc = _get_first_available_field(chat_activity, "messagesSearchListContainer")
                if msc and msc.getVisibility() == View.VISIBLE:
                    self._restore_panel_if_view_replaced(store, "search_results", msc)
                    self._apply_search_bar(
                        store, msc, factory, theme_delegate, panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        store_key="search_results", strong_glass=strong_glass, allow_liquid_glass=liquid_ok,
                    )
                elif "search_results" in store:
                    self._restore_panel_entry(store, "search_results")

            if apply_story_bar:
                story_bar = self._resolve_story_bar_view(chat_activity)
                if story_bar and self._view_inside_any_top_panel_layout(story_bar):
                    if "story_bar" in store:
                        self._restore_panel_entry(store, "story_bar")
                    story_bar = None
                if story_bar and story_bar.getVisibility() == View.VISIBLE:
                    self._restore_panel_if_view_replaced(store, "story_bar", story_bar)
                    if self._topics_tabs_has_native_api(story_bar):
                        if not self._apply_topics_tabs_glass(
                            store, "story_bar", story_bar, factory, frosted_factory, theme_delegate,
                            panel_alpha, panel_radius, panel_thickness, panel_intensity, liquid_ok,
                        ):
                            store["_lg_sig_dirty"] = True
                    else:
                        provider, _psig = self._build_color_provider(theme_delegate, self._theme_key_glass_top_panel(), panel_alpha, True, True)
                        bg = None
                        if provider is not None:
                            bg = self._factory_create_drawable(factory, story_bar, provider, liquid_ok)
                        if provider is not None and bg:
                            if strong_glass:
                                st_th = max(AndroidUtilities.dp(8), int(panel_thickness * 0.92))
                                st_in = max(0.12, min(1.0, float(panel_intensity) * 0.96))
                            else:
                                st_th, st_in = panel_thickness, panel_intensity
                            self._configure_drawable(bg, panel_radius, st_th, st_in, allow_liquid_glass=liquid_ok)
                            self._apply_panel_background(store, "story_bar", story_bar, bg)
                        else:
                            store["_lg_sig_dirty"] = True
                elif "story_bar" in store:
                    self._restore_panel_entry(store, "story_bar")

            if store.pop("_lg_sig_dirty", None):
                store.pop("_lg_apply_sig", None)
            else:
                store["_lg_apply_sig"] = self._chat_apply_signature(chat_activity)

        except Exception:
            try:
                k = id(chat_activity)
                d = self._applied.get(k)
                if d:
                    d.pop("_lg_apply_sig", None)
            except Exception:
                pass
        finally:
            try:
                key = id(chat_activity)
                self._apply_pending.discard(key)
                if key in self._apply_requested:
                    self._apply_requested.discard(key)
                    if (
                        self.get_setting("enabled", True)
                        and self._is_supported()
                        and self._is_fragment_active(chat_activity)
                        and self._is_fragment_resumed(chat_activity)
                        and self._needs_apply(chat_activity)
                    ):
                        follow = 120 if self.get_setting("performance_mode", False) else 80
                        self.apply_to_chat(chat_activity, follow, urgent=False)
            except Exception:
                pass

    def _apply_search_bar(self, store, search_panel, factory, theme_delegate, alpha, radius, thickness, intensity, store_key="search_bar", strong_glass=False, allow_liquid_glass=True):
        if not search_panel:
            return
        if self._view_inside_any_top_panel_layout(search_panel):
            if store_key in store:
                self._restore_panel_entry(store, store_key)
            return
        try:
            if store_key == "search_bar" and not self._chat_search_ui_visible(search_panel):
                return
            if store_key == "search_results" and search_panel.getVisibility() != View.VISIBLE:
                return
            provider, _psig = self._build_top_panel_layout_provider(
                theme_delegate, alpha, provider_kind=self._search_provider_kind(store_key)
            )
            if provider is None:
                provider, _psig = self._build_color_provider(
                    theme_delegate, self._theme_key_glass_top_panel(), alpha, True, True, True
                )
            if provider is None:
                store["_lg_sig_dirty"] = True
                return
            bg = self._factory_create_drawable(factory, search_panel, provider, allow_liquid_glass)
            if bg:
                search_radius = max(AndroidUtilities.dp(8), radius - AndroidUtilities.dp(1))
                if strong_glass:
                    search_thickness = max(AndroidUtilities.dp(8), int(thickness * 0.91))
                    search_intensity = max(0.12, min(1.0, float(intensity) * 0.95))
                else:
                    search_thickness = max(AndroidUtilities.dp(7), int(thickness * 0.78))
                    search_intensity = max(0.1, min(1.0, float(intensity) * 0.88))
                self._configure_drawable(bg, search_radius, search_thickness, search_intensity, allow_liquid_glass=allow_liquid_glass)
                self._apply_panel_background(store, store_key, search_panel, bg)
            else:
                store["_lg_sig_dirty"] = True
        except Exception as exc:
            self._debug_log_exc("apply_search_bar", exc)

    def _sync_disabled_regions(self, store, chat_activity):
        apply_action_bar = self.get_setting("apply_action_bar", True)
        apply_top_panels = self.get_setting("apply_top_panels", True)
        apply_search_bar = self.get_setting("apply_search_bar", True)
        apply_story_bar = self.get_setting("apply_story_bar", True)
        if not apply_action_bar:
            if any(store.get(k) for k in ("action_bar", "action_bar_blurred", "action_bar_cast_shadows", "action_bar_color")):
                self._restore_action_bar_parts(store)
        if not apply_top_panels:
            for k in ("top_panel_layout", "top_panel", "top_panel2"):
                if k in store:
                    self._restore_panel_entry(store, k)
        if not apply_search_bar:
            if "search_bar" in store:
                self._restore_panel_entry(store, "search_bar")
            if "search_container" in store:
                self._restore_panel_entry(store, "search_container")
            if "search_results" in store:
                self._restore_panel_entry(store, "search_results")
        if not apply_story_bar:
            if "story_bar" in store:
                self._restore_panel_entry(store, "story_bar")

    def _restore_action_bar_parts(self, store):
        self._detach_settings_glass_alpha_sync(store)
        e = store.get("action_bar")
        if e and e.get("view"):
            try:
                v = e["view"]
                v.setBackground(e.get("background"))
                if e.get("backgroundColor") is not None:
                    self._set_attr(v, "backgroundColor", e.get("backgroundColor"))
                if e.get("layer_type") is not None:
                    try:
                        v.setLayerType(int(e["layer_type"]), None)
                    except Exception:
                        pass
                if Build.VERSION.SDK_INT >= 21:
                    try:
                        if "saved_clip_to_outline" in e:
                            v.setOutlineProvider(e.get("saved_outline_provider"))
                            v.setClipToOutline(bool(e.get("saved_clip_to_outline")))
                        else:
                            v.setOutlineProvider(None)
                            v.setClipToOutline(False)
                    except Exception:
                        pass
                v.invalidate()
            except Exception:
                pass
        eb = store.get("action_bar_blurred")
        if eb and eb.get("view") is not None:
            try:
                self._set_attr(eb["view"], "blurredBackground", eb.get("blurredBackground"))
                eb["view"].invalidate()
            except Exception:
                pass
        es = store.get("action_bar_cast_shadows")
        if es and es.get("view") is not None:
            try:
                if es.get("castShadows") is not None:
                    try:
                        es["view"].setCastShadows(es.get("castShadows"))
                    except Exception:
                        self._set_attr(es["view"], "castShadows", es.get("castShadows"))
                es["view"].invalidate()
            except Exception:
                pass
        ec = store.get("action_bar_color")
        if ec and ec.get("view") is not None:
            try:
                if ec.get("actionBarColor") is not None:
                    self._set_attr(ec["view"], "actionBarColor", ec.get("actionBarColor"))
                if ec.get("actionModeColor") is not None:
                    self._set_attr(ec["view"], "actionModeColor", ec.get("actionModeColor"))
                ec["view"].invalidate()
            except Exception:
                pass
        ab_view = e.get("view") if e else None
        if ab_view is not None:
            self._unindex_action_bar_store(ab_view)
        for k in ("action_bar", "action_bar_blurred", "action_bar_cast_shadows", "action_bar_color"):
            store.pop(k, None)
        store.pop("action_bar_action_mode_suspended", None)
        store.pop("action_mode_chrome", None)
        store.pop("action_mode_top_panel", None)

    def _restore_chat_store(self, store):
        if not store:
            return
        self._restore_action_bar_parts(store)
        for key in ("top_panel_layout", "top_panel", "top_panel2", "search_bar", "search_container", "search_results", "story_bar"):
            self._restore_panel_entry(store, key)
        e = store.get("background_clip")
        if e and e.get("view"):
            try:
                e["view"].setClipBounds(e.get("clip"))
                e["view"].invalidate()
            except Exception:
                pass
        store.pop("background_clip", None)
        store.pop("_lg_apply_sig", None)
        store.pop("_lg_sig_dirty", None)
        store.pop("_lg_top_panel_wait_ms", None)
        store.pop("_lg_top_panel_gave_up", None)

    def _restore_panel_entry(self, store, key):
        entry = store.get(key)
        if not entry:
            return
        view = entry.get("view")
        if entry.get("mode") == "topics_tabs" and view:
            try:
                for setter_name, key in (
                    ("setTopMenuBackgroundDrawable", "top_menu_bg"),
                    ("setSideMenuBackgroundDrawable", "side_menu_bg"),
                ):
                    setter = getattr(view, setter_name, None)
                    if callable(setter):
                        setter(entry.get(key))
                view.invalidate()
            except Exception:
                pass
            store.pop(key, None)
            return
        if entry.get("mode") in ("top_panel_layout", "top_panel_tune") and view:
            try:
                setter = getattr(view, "setBlurredBackground", None)
                if callable(setter):
                    setter(entry.get("blurred_background"))
                updater = getattr(view, "updateColors", None)
                if callable(updater):
                    updater()
                view.invalidate()
            except Exception:
                pass
            store.pop(key, None)
            return
        try:
            if view:
                view.setBackground(entry.get("background"))
                if entry.get("drawBlur") is not None:
                    self._set_attr(view, "drawBlur", entry.get("drawBlur"))
                if entry.get("backgroundColor") is not None:
                    self._set_attr(view, "backgroundColor", entry.get("backgroundColor"))
                if entry.get("layer_type") is not None:
                    try:
                        view.setLayerType(int(entry["layer_type"]), None)
                    except Exception:
                        pass
                if Build.VERSION.SDK_INT >= 21:
                    try:
                        if "saved_clip_to_outline" in entry:
                            view.setOutlineProvider(entry.get("saved_outline_provider"))
                            view.setClipToOutline(bool(entry.get("saved_clip_to_outline")))
                        else:
                            self._clear_view_outline_clip(view)
                    except Exception:
                        pass
                view.invalidate()
        except Exception:
            if view:
                try:
                    view.invalidate()
                except Exception:
                    pass
        store.pop(key, None)

    def _theme_color_fingerprint(self, resources_provider):
        try:
            if resources_provider is not None:
                return int(Theme.getColor(Theme.key_actionBarDefault, resources_provider))
            return int(Theme.getColor(Theme.key_actionBarDefault))
        except Exception:
            try:
                return int(Theme.getColor(Theme.key_actionBarDefault))
            except Exception:
                return 0

    def _glass_state_signature(self, resources_provider):
        try:
            tup = tuple(self.get_setting(k, DEFAULT_SETTINGS[k]) for k in DEFAULT_SETTINGS)
        except Exception:
            tup = ()
        return (tup, self._theme_color_fingerprint(resources_provider))

    def _chat_apply_signature(self, chat_activity):
        td = None
        try:
            td = get_private_field(chat_activity, "themeDelegate")
        except Exception:
            pass
        return self._glass_state_signature(td)

    def _fragment_apply_signature(self, fragment):
        return self._glass_state_signature(self._resolve_resources_provider(fragment))

    def _color_provider_cache_sig(self, resources_provider, color_key, alpha, disable_top_stroke=False, disable_shadow=False, disable_bottom_stroke=False):
        rid = 0
        try:
            if resources_provider is not None:
                rid = id(resources_provider)
        except Exception:
            rid = 0
        ck = 0
        if color_key is not None:
            try:
                ck = int(color_key)
            except Exception:
                try:
                    ck = hash(str(color_key))
                except Exception:
                    ck = 0
        return (
            ck,
            round(float(alpha), 5),
            bool(disable_top_stroke),
            bool(disable_shadow),
            bool(disable_bottom_stroke),
            rid,
            self._theme_color_fingerprint(resources_provider),
        )

    def _build_color_provider(self, resources_provider, color_key, alpha, disable_top_stroke=False, disable_shadow=False, disable_bottom_stroke=False):
        sig = self._color_provider_cache_sig(
            resources_provider, color_key, alpha, disable_top_stroke, disable_shadow, disable_bottom_stroke
        )
        try:
            provider = BlurredBackgroundColorProviderThemed(resources_provider, color_key, float(alpha))
            if disable_top_stroke or disable_shadow or disable_bottom_stroke:
                return _ColorProviderProxy(provider, disable_top_stroke, disable_shadow, disable_bottom_stroke), sig
            return provider, sig
        except Exception:
            native, nsig = self._build_native_top_panel_provider(
                resources_provider, alpha, disable_top_stroke, disable_shadow, disable_bottom_stroke
            )
            if native is not None:
                return native, nsig
            return None, sig

    def _ensure_factory_source_root(self, chat_activity, factory, frosted_factory=None):
        content_view = _get_first_available_field(chat_activity, "contentView", "fragmentView")
        watcher = _get_first_available_field(chat_activity, "viewPositionWatcher")
        if not content_view:
            return False
        ok = False
        for fac in (factory, frosted_factory):
            if not fac:
                continue
            try:
                setter = getattr(fac, "setSourceRootView", None)
                if not callable(setter):
                    continue
                if watcher is not None:
                    setter(watcher, content_view)
                    ok = True
                else:
                    setter(content_view)
                    ok = True
            except TypeError:
                try:
                    if watcher is not None:
                        setter(watcher, content_view)
                        ok = True
                except Exception:
                    pass
            except Exception:
                pass
        return ok

    def _resolve_top_panel_layout(self, chat_activity):
        return _get_first_available_field(chat_activity, "topPanelLayout")

    def _theme_key_glass_top_panel(self):
        return getattr(Theme, "key_glass_targetMainTopPanel", None) or Theme.key_chat_topPanelBackground

    def _get_top_panel_layout_drawable(self, layout):
        if not layout:
            return None
        return _get_first_available_field(layout, "backgroundDrawable", "blurredBackground")

    def _invoke_native_blur_provider(self, method_name, resources_provider):
        if resources_provider is None:
            return None
        impl_cls = safe_find_class(
            "org.telegram.ui.Components.blur3.drawable.color.impl.BlurredBackgroundProviderImpl"
        )
        if not impl_cls:
            return None
        try:
            fn = getattr(impl_cls, method_name, None)
            if callable(fn):
                return fn(resources_provider)
        except Exception:
            pass
        try:
            m = impl_cls.getDeclaredMethod(
                method_name,
                resources_provider.getClass(),
            )
            m.setAccessible(True)
            return m.invoke(None, resources_provider)
        except Exception:
            pass
        try:
            m = impl_cls.getClass().getDeclaredMethod(
                method_name,
                resources_provider.getClass(),
            )
            m.setAccessible(True)
            return m.invoke(None, resources_provider)
        except Exception:
            return None

    def _build_top_panel_layout_provider(self, resources_provider, panel_alpha, provider_kind="chat"):
        method = self._TOP_PANEL_PROVIDER_METHODS.get(provider_kind, "topPanelChatActivity")
        provider = self._invoke_native_blur_provider(method, resources_provider)
        fallbacks = []
        if provider_kind == "search_tags":
            fallbacks = ("topPanelChatActivity", "topPanel")
        elif provider_kind == "search_list":
            fallbacks = ("topPanelChatActivity", "topPanel")
        elif provider_kind == "top_panel":
            fallbacks = ("topPanelChatActivity",)
        elif provider_kind == "chat":
            fallbacks = ("topPanel",)
        for fb in fallbacks:
            if provider is not None:
                break
            provider = self._invoke_native_blur_provider(fb, resources_provider)
        if provider is not None:
            sig = self._color_provider_cache_sig(
                resources_provider, self._theme_key_glass_top_panel(), panel_alpha, True, True, False
            )
            return provider, sig
        return self._build_color_provider(
            resources_provider, self._theme_key_glass_top_panel(), panel_alpha, True, True, False
        )

    def _build_native_top_panel_provider(
        self, resources_provider, alpha, disable_top_stroke=False, disable_shadow=False, disable_bottom_stroke=False
    ):
        provider, sig = self._build_top_panel_layout_provider(
            resources_provider, alpha, provider_kind="chat"
        )
        if provider is None:
            sig = self._color_provider_cache_sig(
                resources_provider, Theme.key_chat_topPanelBackground, alpha,
                disable_top_stroke, disable_shadow, disable_bottom_stroke,
            )
            return None, sig
        if disable_top_stroke or disable_shadow or disable_bottom_stroke:
            return _ColorProviderProxy(provider, disable_top_stroke, disable_shadow, disable_bottom_stroke), sig
        return provider, sig

    def _save_top_panel_layout_tune_entry(self, store, store_key, layout, native_drawable):
        entry = store.get(store_key)
        if entry and entry.get("view") is layout and entry.get("mode") == "top_panel_tune":
            if entry.get("blurred_background") is None and native_drawable is not None:
                entry["blurred_background"] = native_drawable
            return entry
        saved_native = native_drawable
        if entry and entry.get("blurred_background") is not None:
            saved_native = entry.get("blurred_background")
        store[store_key] = {
            "view": layout,
            "blurred_background": saved_native,
            "mode": "top_panel_tune",
        }
        return store[store_key]

    def _apply_top_panel_layout_glass(
        self, store, store_key, layout, factory, frosted_factory, theme_delegate,
        panel_alpha, panel_radius, panel_thickness, panel_intensity,
        allow_liquid_glass=True, provider_kind="chat", owner=None,
    ):
        if not layout:
            if store_key in store:
                self._restore_panel_entry(store, store_key)
            return
        self._restore_panel_if_view_replaced(store, store_key, layout)

        tune_sig = self._top_panel_tune_signature(panel_thickness, panel_intensity, allow_liquid_glass)
        entry = store.get(store_key)
        if entry and entry.get("view") is layout and entry.get("_lg_tune_sig") == tune_sig:
            return

        existing = self._get_top_panel_layout_drawable(layout)
        if existing is not None:
            store.pop("_lg_top_panel_wait_ms", None)
            entry = self._save_top_panel_layout_tune_entry(store, store_key, layout, existing)
            self._tune_top_panel_layout_drawable(
                existing, panel_thickness, panel_intensity, allow_liquid_glass
            )
            entry["applied"] = existing
            entry["_lg_tune_sig"] = tune_sig
            entry.pop("_lg_top_panel_gave_up", None)
            try:
                layout.invalidate()
            except Exception:
                pass
            return

        if store.get("_lg_top_panel_gave_up"):
            return

        now_ms = time.time() * 1000.0
        if store.get("_lg_top_panel_wait_ms") is None:
            store["_lg_top_panel_wait_ms"] = now_ms

        if not self._top_panel_native_grace_expired(store):
            store["_lg_sig_dirty"] = True
            self._schedule_top_panel_native_retries(owner, 0)
            return

        if not factory:
            store["_lg_top_panel_gave_up"] = True
            return

        provider, _psig = self._build_top_panel_layout_provider(theme_delegate, panel_alpha, provider_kind)
        if provider is None:
            store["_lg_top_panel_gave_up"] = True
            return

        bg = None
        for fac in self._action_bar_drawable_factories_order(factory, frosted_factory):
            bg = self._factory_create_drawable(fac, layout, provider, allow_liquid_glass)
            if bg:
                break
        if not bg:
            store["_lg_top_panel_gave_up"] = True
            return

        self._tune_top_panel_layout_drawable(bg, panel_thickness, panel_intensity, allow_liquid_glass)
        if store_key not in store or store[store_key].get("view") is not layout:
            store[store_key] = {
                "view": layout,
                "blurred_background": None,
                "mode": "top_panel_layout",
            }
        store[store_key]["applied"] = bg
        store[store_key]["_lg_tune_sig"] = tune_sig
        store[store_key]["_lg_top_panel_created"] = True
        try:
            layout.setBlurredBackground(bg)
            layout.invalidate()
        except Exception:
            store["_lg_sig_dirty"] = True
            return
        store.pop("_lg_top_panel_wait_ms", None)

    def _factory_get_liquid_allowed(self, factory):
        if not factory or Build.VERSION.SDK_INT < 33:
            return None
        for name in ("isLiquidGlassEffectAllowed", "getLiquidGlassEffectAllowed"):
            fn = getattr(factory, name, None)
            if callable(fn):
                try:
                    return bool(fn())
                except Exception:
                    pass
        return None

    def _factory_set_liquid_allowed(self, factory, allowed):
        if not factory or Build.VERSION.SDK_INT < 33:
            return
        fn = getattr(factory, "setLiquidGlassEffectAllowed", None)
        if not callable(fn):
            return
        try:
            fn(bool(allowed))
        except TypeError:
            if allowed:
                try:
                    fn()
                except Exception:
                    pass
        except Exception:
            pass

    def _reset_factories_liquid_glass(self, factory, frosted_factory, allow_liquid=False):
        for f in (factory, frosted_factory):
            if f:
                self._factory_set_liquid_allowed(f, bool(allow_liquid))

    def _view_inside_top_panel_layout(self, chat_activity, view):
        if not chat_activity or not view:
            return False
        layout = self._resolve_top_panel_layout(chat_activity)
        if layout is None:
            return False
        try:
            parent = view.getParent()
            while parent is not None:
                if parent is layout:
                    return True
                parent = parent.getParent()
        except Exception:
            return False
        return False

    def _topics_tabs_has_native_api(self, view):
        return callable(getattr(view, "setTopMenuBackgroundDrawable", None))

    def _apply_topics_tabs_glass(
        self, store, store_key, topics_tabs, factory, frosted_factory, theme_delegate,
        panel_alpha, panel_radius, panel_thickness, panel_intensity, allow_liquid_glass,
    ):
        if not topics_tabs or not factory:
            return False
        provider, _psig = self._build_top_panel_layout_provider(theme_delegate, panel_alpha, "chat")
        if provider is None:
            store["_lg_sig_dirty"] = True
            return False
        bg = None
        for fac in self._action_bar_drawable_factories_order(factory, frosted_factory):
            bg = self._factory_create_drawable(fac, topics_tabs, provider, allow_liquid_glass)
            if bg:
                break
        if not bg:
            store["_lg_sig_dirty"] = True
            return False
        self._configure_drawable(bg, panel_radius, panel_thickness, panel_intensity, allow_liquid_glass=allow_liquid_glass)
        entry = store.get(store_key)
        if not entry or entry.get("view") is not topics_tabs:
            saved = {"view": topics_tabs, "mode": "topics_tabs"}
            for getter_name, key in (
                ("getTopMenuBackgroundDrawable", "top_menu_bg"),
                ("getSideMenuBackgroundDrawable", "side_menu_bg"),
            ):
                fn = getattr(topics_tabs, getter_name, None)
                if callable(fn):
                    try:
                        saved[key] = fn()
                    except Exception:
                        saved[key] = None
            store[store_key] = saved
            entry = saved
        try:
            setter = getattr(topics_tabs, "setTopMenuBackgroundDrawable", None)
            if callable(setter):
                setter(bg)
            side = getattr(topics_tabs, "setSideMenuBackgroundDrawable", None)
            if callable(side):
                side(bg)
            topics_tabs.invalidate()
            return True
        except Exception:
            store["_lg_sig_dirty"] = True
            return False

    def _apply_or_restore_top_row(
        self, store, store_key, row_view, factory, theme_delegate,
        panel_alpha, panel_radius, panel_thickness, panel_intensity,
        allow_liquid_glass=True, chat_activity=None,
    ):
        if chat_activity and row_view and self._view_inside_top_panel_layout(chat_activity, row_view):
            if store_key in store:
                self._restore_panel_entry(store, store_key)
            return
        if row_view and self._panel_has_real_height(row_view, self._MIN_TOP_PANEL_DP):
            self._restore_panel_if_view_replaced(store, store_key, row_view)
            provider, _psig = self._build_color_provider(
                theme_delegate, self._theme_key_glass_top_panel(), panel_alpha, True, True
            )
            if provider is None:
                store["_lg_sig_dirty"] = True
                return
            bg = self._factory_create_drawable(factory, row_view, provider, allow_liquid_glass)
            if bg:
                self._configure_drawable(bg, panel_radius, panel_thickness, panel_intensity, allow_liquid_glass=allow_liquid_glass)
                self._apply_panel_background(store, store_key, row_view, bg)
            else:
                store["_lg_sig_dirty"] = True
        elif store_key in store:
            self._restore_panel_entry(store, store_key)

    def _configure_drawable(self, drawable, radius, thickness, intensity, allow_liquid_glass=True):
        if not drawable:
            return
        try:
            if radius is not None:
                drawable.setRadius(radius)
            if thickness is not None:
                drawable.setThickness(thickness)
            if intensity is not None:
                drawable.setIntensity(float(intensity))
        except Exception:
            pass
        self._drawable_set_liquid_glass_allowed(drawable, allow_liquid_glass)

    def _drawable_set_liquid_glass_allowed(self, drawable, allowed):
        if not drawable:
            return
        for name in ("setLiquidGlassEffectAllowed", "setLiquidGlassAllowed"):
            fn = getattr(drawable, name, None)
            if callable(fn):
                try:
                    fn(bool(allowed))
                    return
                except TypeError:
                    if allowed:
                        try:
                            fn()
                        except Exception:
                            pass
                    return
                except Exception:
                    pass

    def _top_panel_layout_waiting_native(self, store, layout):
        if not layout or not store:
            return False
        wait_since = store.get("_lg_top_panel_wait_ms")
        if wait_since is None:
            return False
        if self._get_top_panel_layout_drawable(layout) is not None:
            store.pop("_lg_top_panel_wait_ms", None)
            return False
        return (time.time() * 1000.0) - float(wait_since) < float(self._TOP_PANEL_NATIVE_GRACE_MS)

    def _top_panel_native_grace_expired(self, store):
        wait_since = store.get("_lg_top_panel_wait_ms")
        if wait_since is None:
            return False
        return (time.time() * 1000.0) - float(wait_since) >= float(self._TOP_PANEL_NATIVE_GRACE_MS)

    def _schedule_top_panel_native_retries(self, owner, base_delay_ms=0):
        if owner is None:
            return
        plug = self
        perf = self.get_setting("performance_mode", False)
        delays = self._TOP_PANEL_TUNE_RETRY_MS_PERF if perf else self._TOP_PANEL_TUNE_RETRY_MS

        def _run():
            try:
                if not plug._is_fragment_active(owner) or not plug._is_fragment_resumed(owner):
                    return
                try:
                    if owner in plug._active_chats:
                        plug.apply_to_chat(owner, 0)
                        return
                except Exception:
                    pass
                plug.apply_to_extra_fragment(owner, 0)
            except Exception:
                pass

        for delay in delays:
            run_on_ui_thread(_run, max(0, int(delay) + int(base_delay_ms)))

    def _tune_top_panel_layout_drawable(self, drawable, panel_thickness, panel_intensity, allow_liquid_glass):
        if not drawable:
            return
        try:
            if panel_thickness is not None:
                drawable.setThickness(panel_thickness)
        except Exception:
            pass
        try:
            if panel_intensity is not None:
                drawable.setIntensity(float(panel_intensity))
        except Exception:
            pass
        self._drawable_set_liquid_glass_allowed(drawable, allow_liquid_glass)

    def _apply_background(self, store, key, view, drawable):
        if not view or not drawable: return
        if key not in store or store[key].get("view") is not view:
            ne = {"view": view, "background": view.getBackground()}
            try:
                ne["backgroundColor"] = self._get_attr(view, "backgroundColor")
            except Exception:
                pass
            if Build.VERSION.SDK_INT >= 21:
                try:
                    ne["saved_clip_to_outline"] = bool(view.getClipToOutline())
                    ne["saved_outline_provider"] = view.getOutlineProvider()
                except Exception:
                    pass
            try:
                ne["layer_type"] = int(view.getLayerType())
            except Exception:
                ne["layer_type"] = None
            store[key] = ne
        store[key]["applied"] = drawable
        if key == "action_bar":
            self._index_action_bar_store(view, store)
        try:
            view.setBackground(drawable)
            self._set_attr(view, "backgroundColor", Color.TRANSPARENT)
            view.invalidate()
        except Exception:
            store["_lg_sig_dirty"] = True

    def _view_inside_any_top_panel_layout(self, view):
        if not view:
            return False
        try:
            parent = view.getParent()
            while parent is not None:
                pname = str(parent.getClass().getName())
                if "TopPanelLayout" in pname:
                    return True
                parent = parent.getParent()
        except Exception:
            return False
        return False

    def _apply_panel_background(self, store, key, panel, drawable, clear_solid_underlay=True):
        if not panel or not drawable:
            return
        if self._view_inside_any_top_panel_layout(panel):
            return
        if key not in store or store[key].get("view") is not panel:
            clip_sv = None
            prov_sv = None
            if Build.VERSION.SDK_INT >= 21:
                try:
                    clip_sv = bool(panel.getClipToOutline())
                    prov_sv = panel.getOutlineProvider()
                except Exception:
                    pass
            try:
                lt = int(panel.getLayerType())
            except Exception:
                lt = None
            store[key] = {
                "view": panel,
                "background": panel.getBackground(),
                "drawBlur": self._get_attr(panel, "drawBlur"),
                "backgroundColor": self._get_attr(panel, "backgroundColor"),
                "saved_clip_to_outline": clip_sv,
                "saved_outline_provider": prov_sv,
                "layer_type": lt,
            }
        store[key]["applied"] = drawable
        try:
            if Build.VERSION.SDK_INT >= 21:
                self._clear_view_outline_clip(panel)
            panel.setBackground(drawable)
            self._set_attr(panel, "drawBlur", False)
            if clear_solid_underlay:
                self._set_attr(panel, "backgroundColor", Color.TRANSPARENT)
            self._clear_outline_ancestors(panel, 6)
            panel.invalidate()
        except Exception:
            store["_lg_sig_dirty"] = True

    def _disable_actionbar_shadows(self, store, action_bar):
        try:
            prev = self._get_attr(action_bar, "castShadows")
            if "action_bar_cast_shadows" not in store or store["action_bar_cast_shadows"].get("view") is not action_bar:
                store["action_bar_cast_shadows"] = {"view": action_bar, "castShadows": prev}
            try:
                action_bar.setCastShadows(False)
            except Exception:
                self._set_attr(action_bar, "castShadows", False)
        except Exception:
            store.pop("action_bar_cast_shadows", None)

    def _blur_needs_preserved_background_clip(self, chat_activity):
        if not chat_activity:
            return False
        for attr in ("topicId", "openedTopicId", "forumTopicId", "selectedTopicId"):
            try:
                v = _get_first_available_field(chat_activity, attr)
                if v is None:
                    continue
                if int(v) != 0:
                    return True
            except Exception:
                pass
        return False

    def _unclip_chat_background(self, chat_activity):
        try:
            content_view = get_private_field(chat_activity, "contentView") or getattr(chat_activity, "contentView", None)
            if not content_view: return
            bg_view = getattr(content_view, "backgroundView", None) or get_private_field(content_view, "backgroundView")
            if not bg_view: return
            store = self._applied.setdefault(id(chat_activity), {})
            if "background_clip" not in store or store["background_clip"].get("view") is not bg_view:
                prev = None
                try:
                    current = bg_view.getClipBounds()
                    if current: prev = Rect(current.left, current.top, current.right, current.bottom)
                except Exception:
                    prev = None
                store["background_clip"] = {"view": bg_view, "clip": prev}
            bg_view.setClipBounds(None)
            bg_view.invalidate()
        except Exception:
            st = self._applied.get(id(chat_activity))
            if st:
                st.pop("background_clip", None)

    def _restore_background_clip_for_chat(self, chat_activity):
        try:
            store = self._applied.get(id(chat_activity))
            if not store:
                return
            e = store.get("background_clip")
            if e and e.get("view"):
                try:
                    e["view"].setClipBounds(e.get("clip"))
                    e["view"].invalidate()
                except Exception:
                    pass
                store.pop("background_clip", None)
        except Exception:
            pass

    def _resolve_story_bar_view(self, chat_activity):
        return _get_first_available_field(chat_activity, "topicsTabs")

    def _find_chat_for_search_view(self, view):
        if not view:
            return None
        for ca in list(self._active_chats):
            try:
                if not self._is_fragment_active(ca):
                    continue
                for field in ("hashtagSearchTabs", "fragmentSearchField", "searchTabs", "searchContainer"):
                    if _get_first_available_field(ca, field) is view:
                        return ca
            except Exception:
                pass
        return None

    def _cleanup_chat(self, chat_activity):
        if not chat_activity: return
        key = id(chat_activity)
        ab = self._resolve_action_bar(chat_activity)
        if ab is not None:
            self._action_bar_color_shield_last.pop(id(ab), None)
        st = self._applied.pop(key, None)
        if st:
            self._evict_drawable_cache_for_view_ids(self._collect_drawable_cache_view_ids(st))
            self._restore_chat_store(st)
        self._apply_pending.discard(key)
        self._apply_requested.discard(key)
        self._last_apply_time.pop(key, None)
        self._factory_cooldown_chat.pop(key, None)
        try:
            self._active_chats.discard(chat_activity)
        except Exception:
            pass

    def _restore_all(self, reapply_after=True):
        for st in list(self._applied.values()):
            self._restore_chat_store(st)
        self._applied.clear()
        self._action_bar_store_index.clear()
        self._last_apply_time.clear()
        self._apply_pending.clear()
        self._apply_requested.clear()
        self._extra_apply_gen.clear()
        self._factory_cooldown_chat.clear()
        self._factory_cooldown_extra.clear()
        self._drawable_cache.clear()
        self._restore_all_extras(reapply_after=False)
        if reapply_after and self.get_setting("enabled", True) and self._is_supported():
            chats = [
                ca for ca in list(self._active_chats)
                if self._is_fragment_active(ca) and self._is_fragment_resumed(ca)
            ]
            for i, ca in enumerate(chats):
                try:
                    self.apply_to_chat(ca, 30 + i * 90, urgent=True)
                except Exception:
                    pass
            extras = [
                ex for ex in list(self._active_extras)
                if self._is_fragment_active(ex) and self._is_fragment_resumed(ex)
            ]
            for i, ex in enumerate(extras):
                try:
                    self.apply_to_extra_fragment(ex, 40 + i * 100, urgent=True)
                except Exception:
                    pass

    def _resolve_resources_provider(self, fragment):
        return _get_first_available_field(fragment, "themeDelegate", "resourceProvider")

    def _resolve_blur_factory_pair(self, fragment, store=None):
        main = _get_first_available_field(
            fragment, "glassBackgroundDrawableFactory", "iBlur3FactoryLiquidGlass"
        )
        frost = _get_first_available_field(
            fragment, "glassBackgroundDrawableFactoryFrosted", "iBlur3FactoryFrostedLiquidGlass", "iBlur3FactoryFrosted"
        )
        if main or frost:
            return main, frost
        if store is not None:
            cached = store.get("_lg_synth_factory_pair")
            if cached:
                return cached
        src_main = _get_first_available_field(fragment, "iBlur3SourceGlass")
        src_frost = _get_first_available_field(fragment, "iBlur3SourceGlassFrosted")
        if not src_main:
            gs = getattr(fragment, "getGlassSource", None)
            if callable(gs):
                try:
                    src_main = gs()
                except Exception:
                    pass
        fac_cls = safe_find_class("org.telegram.ui.Components.blur3.BlurredBackgroundDrawableViewFactory")
        if not fac_cls or not src_main:
            return None, None
        try:
            main = fac_cls(src_main)
        except Exception:
            main = None
        frost = None
        if src_frost is not None and src_frost is not src_main:
            try:
                frost = fac_cls(src_frost)
            except Exception:
                frost = None
        pair = (main, frost)
        if store is not None and (main or frost):
            store["_lg_synth_factory_pair"] = pair
        return pair

    def _action_bar_drawable_factories_order(self, factory, frosted):
        order = []
        if factory is not None:
            order.append(factory)
        if frosted is not None:
            fid = id(frosted)
            if not any(id(f) == fid for f in order if f is not None):
                order.append(frosted)
        seen = set()
        out = []
        for fac in order:
            if fac is None:
                continue
            k = id(fac)
            if k in seen:
                continue
            seen.add(k)
            out.append(fac)
        return out

    def _extra_fragment_needs_apply(self, fragment, store, sk, action_bar_only=False):
        if store.get("_lg_apply_sig") != self._fragment_apply_signature(fragment):
            return True
        action_bar = self._resolve_action_bar(fragment)
        if action_bar and self.get_setting("apply_action_bar", True):
            strong_glass = self.get_setting("strong_glass", False)
            action_thickness = AndroidUtilities.dp(
                self._clamp_dp_setting(self.get_setting("action_bar_thickness", "14"), 14, 6, 32)
            )
            action_intensity = self._parse_float_safe(self.get_setting("action_bar_intensity", "0.42"), clamp_0_1=True)
            action_alpha = self._parse_float_safe(self.get_setting("action_bar_alpha", "0.82"), clamp_0_1=True)
            ab_sig = self._action_bar_tune_signature(
                action_thickness, action_intensity, bool(strong_glass), action_alpha
            )
            if self._action_bar_needs_reapply(store, action_bar, tune_sig=ab_sig):
                return True
        if action_bar_only:
            return False
        if sk in ("apply_dialogs_list", "apply_topics_header"):
            tpl = _get_first_available_field(fragment, "topPanelLayout")
            if tpl is not None:
                if self._top_panel_layout_waiting_native(store, tpl):
                    return True
                if self._panel_needs_reapply(store, "top_panel_layout", tpl):
                    return True
            elif "top_panel_layout" in store:
                return True
        return False

    def _restore_extras_store(self, store):
        if not store:
            return
        self._restore_action_bar_parts(store)
        self._restore_panel_entry(store, "top_panel_layout")
        store.pop("_lg_top_panel_wait_ms", None)

    def _restore_all_extras(self, reapply_after=True):
        for st in list(self._extras_applied.values()):
            self._restore_extras_store(st)
        self._extras_applied.clear()
        if reapply_after and self.get_setting("enabled", True) and self._is_supported():
            extras = [
                ex for ex in list(self._active_extras)
                if self._is_fragment_active(ex) and self._is_fragment_resumed(ex)
            ]
            for i, ex in enumerate(extras):
                try:
                    self.apply_to_extra_fragment(ex, 40 + i * 100, urgent=True)
                except Exception:
                    pass

    def apply_to_extra_fragment(self, fragment, delay_ms=100, urgent=False):
        if not fragment or not self._is_fragment_active(fragment):
            return
        self._prune_runtime_state()
        should_run, sk, action_bar_only = self._extra_fragment_scope(fragment)
        if not should_run:
            key = id(fragment)
            self._extra_apply_gen.pop(key, None)
            st = self._extras_applied.pop(key, None)
            if st:
                self._restore_extras_store(st)
            try:
                self._active_extras.discard(fragment)
            except Exception:
                pass
            return
        if not self.get_setting("enabled", True):
            key = id(fragment)
            self._extra_apply_gen.pop(key, None)
            st = self._extras_applied.pop(key, None)
            if st:
                self._restore_extras_store(st)
            try:
                self._active_extras.discard(fragment)
            except Exception:
                pass
            return
        if not self._is_supported():
            key = id(fragment)
            self._extra_apply_gen.pop(key, None)
            st = self._extras_applied.pop(key, None)
            if st:
                self._restore_extras_store(st)
            try:
                self._active_extras.discard(fragment)
            except Exception:
                pass
            return
        try:
            self._active_extras.add(fragment)
        except Exception:
            pass
        if not urgent and self._in_startup_grace():
            delay_ms = max(delay_ms, self._STARTUP_EXTRA_DELAY_MIN_MS + 80)
        key = id(fragment)
        if not urgent:
            store = self._extras_applied.get(key, {})
            if store:
                try:
                    prev_sig = store.get("_lg_apply_sig")
                    current_sig = self._fragment_apply_signature(fragment)
                    if prev_sig is None and self._store_needs_sig_recovery(store):
                        urgent = True
                    elif self._is_real_theme_burst(prev_sig, current_sig):
                        delay_ms = max(delay_ms, 220)
                        self._bump_diag("theme_burst_extra")
                        self._maybe_theme_burst_hint()
                    elif prev_sig is not None and prev_sig != current_sig:
                        delay_ms = max(delay_ms, 100)
                except Exception:
                    pass
        if len(self._extra_apply_gen) > 96:
            alive = set(self._extras_applied.keys())
            try:
                alive.update(id(x) for x in list(self._active_extras))
            except Exception:
                pass
            self._extra_apply_gen = {k: v for k, v in self._extra_apply_gen.items() if k in alive}
        self._extra_apply_gen[key] = int(self._extra_apply_gen.get(key, 0)) + 1
        gen = int(self._extra_apply_gen[key])
        plug, fr = self, fragment

        def _run():
            if int(plug._extra_apply_gen.get(key, 0)) != gen:
                return
            plug._apply_extra_fragment_impl(fr, sk, action_bar_only)

        run_on_ui_thread(_run, delay_ms)

    def _apply_extra_fragment_impl(self, fragment, sk=None, action_bar_only=False):
        try:
            if not self._is_fragment_active(fragment):
                return
            if not self.get_setting("enabled", True) or not self._is_supported():
                self._cleanup_extra(fragment)
                return
            should_run, scope_sk, ab_only = self._extra_fragment_scope(fragment)
            if not should_run:
                self._cleanup_extra(fragment)
                return
            self._ensure_native_glass_setup(fragment)
            if sk is None:
                sk = scope_sk
            action_bar_only = action_bar_only or ab_only
            store = self._extras_applied.setdefault(id(fragment), {})
            if (
                store.get("_lg_apply_sig") == self._fragment_apply_signature(fragment)
                and not self._extra_fragment_needs_apply(fragment, store, sk, action_bar_only)
            ):
                return
            rp = self._resolve_resources_provider(fragment)
            factory, frosted = self._resolve_blur_factory_pair(fragment, store)
            if not factory and frosted:
                factory, frosted = frosted, None
            if not factory:
                key = id(fragment)
                now_ms = time.time() * 1000
                next_retry = float(self._factory_cooldown_extra.get(key, 0))
                if now_ms < next_retry:
                    self._bump_diag("factory_cooldown_skip_extra")
                    return
                self._factory_cooldown_extra[key] = now_ms + float(self._FACTORY_RETRY_COOLDOWN_MS)
                self._bump_diag("factory_miss_extra")
                store.pop("_lg_apply_sig", None)
                return
            self._factory_cooldown_extra.pop(id(fragment), None)
            glass = self._compute_glass_params(rp)
            strong_glass = glass["strong_glass"]
            liquid_ok = glass["liquid_ok"]
            action_alpha = glass["action_alpha"]
            panel_alpha = glass["panel_alpha"]
            action_thickness = glass["action_thickness"]
            panel_thickness = glass["panel_thickness"]
            action_intensity = glass["action_intensity"]
            panel_intensity = glass["panel_intensity"]
            panel_radius = glass["panel_radius"]
            self._reset_factories_liquid_glass(factory, frosted, allow_liquid=liquid_ok)
            self._ensure_factory_source_root(fragment, factory, frosted)
            sig_dirty = False

            action_bar = self._resolve_action_bar(fragment)
            if action_bar and self.get_setting("apply_action_bar", True):
                perf = self.get_setting("performance_mode", False)
                if not self._apply_action_bar_glass(
                    store, fragment, action_bar, factory, frosted, rp,
                    action_alpha, action_thickness, action_intensity, panel_radius,
                    liquid_ok, performance_mode=perf,
                    settings_header_sync=self._is_settings_activity(fragment),
                ):
                    sig_dirty = True

            if not action_bar_only and sk in ("apply_dialogs_list", "apply_topics_header"):
                top_layout = _get_first_available_field(fragment, "topPanelLayout")
                if top_layout is not None:
                    self._apply_top_panel_layout_glass(
                        store, "top_panel_layout", top_layout, factory, frosted, rp,
                        panel_alpha, panel_radius, panel_thickness, panel_intensity,
                        allow_liquid_glass=liquid_ok, provider_kind="top_panel",
                        owner=fragment,
                    )
                elif "top_panel_layout" in store:
                    self._restore_panel_entry(store, "top_panel_layout")

            if sig_dirty or store.pop("_lg_sig_dirty", None):
                store.pop("_lg_apply_sig", None)
            else:
                store["_lg_apply_sig"] = self._fragment_apply_signature(fragment)
        except Exception:
            try:
                k = id(fragment)
                st = self._extras_applied.get(k)
                if st:
                    st.pop("_lg_apply_sig", None)
            except Exception:
                pass

    def _cleanup_extra(self, fragment):
        if not fragment:
            return
        key = id(fragment)
        ab = self._resolve_action_bar(fragment)
        if ab is not None:
            self._action_bar_color_shield_last.pop(id(ab), None)
        self._extra_apply_gen.pop(key, None)
        self._factory_cooldown_extra.pop(key, None)
        st = self._extras_applied.pop(key, None)
        if st:
            self._evict_drawable_cache_for_view_ids(self._collect_drawable_cache_view_ids(st))
            self._restore_extras_store(st)
        try:
            self._active_extras.discard(fragment)
        except Exception:
            pass

    def _chat_search_ui_visible(self, view):
        if not view:
            return False
        try:
            if view.getVisibility() == View.VISIBLE:
                return True
        except Exception:
            pass
        shown = getattr(view, "shown", None)
        if callable(shown):
            try:
                return bool(shown())
            except Exception:
                return False
        return False

    def _resolve_search_primary_view(self, chat_activity):
        for field in ("hashtagSearchTabs", "fragmentSearchField", "searchTabs"):
            view = _get_first_available_field(chat_activity, field)
            if view is not None:
                return view
        return _get_first_available_field(chat_activity, "searchContainer")

    def _reset_to_defaults(self):
        def _do_reset():
            self._persist_settings_bulk(DEFAULT_SETTINGS)
            self._last_apply_time.clear()
            self._extra_apply_gen.clear()
            self._apply_pending.clear()
            self._apply_requested.clear()
            self._drawable_cache.clear()
            run_on_ui_thread(self._restore_all)
            try:
                BulletinHelper.show_info("Настройки сброшены к значениям по умолчанию")
            except Exception:
                pass

        self._show_confirm_dialog(
            "Сброс настроек",
            "Все параметры будут возвращены к значениям по умолчанию. Продолжить?",
            _do_reset,
            positive="Сбросить",
        )

    def _hook_action_bar(self):
        ActionBarClass = safe_find_class("org.telegram.ui.ActionBar.ActionBar")
        if not ActionBarClass:
            return
        added = 0
        Integer = safe_find_class("java.lang.Integer")
        Drawable = safe_find_class("android.graphics.drawable.Drawable")
        if Integer:
            try:
                m = self._class_declared_method(ActionBarClass, "setBackgroundColor", Integer.TYPE)
                if m:
                    m.setAccessible(True)
                    self._register_hook(self.hook_method(m, _ActionBarColorBeforeHook(self)))
                    self._register_hook(self.hook_method(m, _ActionBarColorAfterHook(self)))
                    added += 2
            except Exception as e:
                self._debug_log("action_bar.setBackgroundColor hook failed: %s" % e)
        if Drawable:
            try:
                m = self._class_declared_method(ActionBarClass, "setBackground", Drawable)
                if m:
                    m.setAccessible(True)
                    self._register_hook(self.hook_method(m, _ActionBarBackgroundHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("action_bar.setBackground hook failed: %s" % e)
        for mname in ("showActionMode", "hideActionMode"):
            try:
                seen = set()
                for m in self._class_declared_methods(ActionBarClass):
                    if m.getName() != mname:
                        continue
                    sig = str(m.toString())
                    if sig in seen:
                        continue
                    seen.add(sig)
                    m.setAccessible(True)
                    self._register_hook(self.hook_method(m, _ActionBarModeHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("action_bar.%s hook failed: %s" % (mname, e))
        self._log_hook_status("action_bar", added)

    def _hook_chat_activity(self):
        ChatActivityClass = safe_find_class("org.telegram.ui.ChatActivity")
        if not ChatActivityClass:
            return
        ctx_cls = safe_find_class("android.content.Context")
        added = 0

        try:
            if ctx_cls:
                create_view = self._class_declared_method(ChatActivityClass, "createView", ctx_cls)
                if create_view:
                    create_view.setAccessible(True)
                    self._register_hook(self.hook_method(create_view, _ChatCreateViewHook(self)))
                    added += 1
        except Exception as e:
            self._debug_log("chat_activity.createView hook failed: %s" % e)

        try:
            on_resume = self._class_declared_method(ChatActivityClass, "onResume")
            if on_resume:
                on_resume.setAccessible(True)
                self._register_hook(self.hook_method(on_resume, _ChatResumeHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("chat_activity.onResume hook failed: %s" % e)

        try:
            seen = set()
            for m in self._class_declared_methods(ChatActivityClass):
                if m.getName() != "updateColors":
                    continue
                sig = str(m.toString())
                if sig in seen:
                    continue
                seen.add(sig)
                m.setAccessible(True)
                self._register_hook(self.hook_method(m, _ChatResumeHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("chat_activity.updateColors hook failed: %s" % e)

        try:
            BoolT = safe_find_class("java.lang.Boolean")
            if BoolT:
                update_top = self._class_declared_method(ChatActivityClass, "updateTopPanel", BoolT.TYPE)
                if update_top:
                    update_top.setAccessible(True)
                    self._register_hook(self.hook_method(update_top, _ChatResumeHook(self)))
                    added += 1
        except Exception as e:
            self._debug_log("chat_activity.updateTopPanel hook failed: %s" % e)

        try:
            invalidate_clip = self._class_declared_method(ChatActivityClass, "invalidateClipRectForBackgroundAndChatList")
            if invalidate_clip:
                invalidate_clip.setAccessible(True)
                self._register_hook(self.hook_method(invalidate_clip, _ChatClipHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("chat_activity.invalidateClipRect hook failed: %s" % e)

        try:
            on_destroy = self._class_declared_method(ChatActivityClass, "onFragmentDestroy")
            if on_destroy:
                on_destroy.setAccessible(True)
                self._register_hook(self.hook_method(on_destroy, _ChatDestroyHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("chat_activity.onFragmentDestroy hook failed: %s" % e)
        self._log_hook_status("chat_activity", added)

    def _hook_chat_search_tabs(self):
        cls = safe_find_class("org.telegram.ui.Components.ChatSearchTabs")
        if not cls:
            return
        added = 0
        try:
            seen = set()
            for m in self._class_declared_methods(cls):
                if m.getName() not in ("show", "setVisibility", "setShown"):
                    continue
                sig = str(m.toString())
                if sig in seen:
                    continue
                seen.add(sig)
                m.setAccessible(True)
                self._register_hook(self.hook_method(m, _ChatSearchRepaintHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("ChatSearchTabs search-tabs hook failed: %s" % e)
        self._log_hook_status("chat_search_tabs", added)

    def _hook_dialog_cell_extras(self):
        Cls = safe_find_class("org.telegram.ui.Cells.DialogCell")
        if not Cls:
            return
        added = 0
        try:
            seen = set()
            for m in self._class_declared_methods(Cls):
                if m.getName() != "setDialog":
                    continue
                sig = str(m.toString())
                if sig in seen:
                    continue
                seen.add(sig)
                m.setAccessible(True)
                self._register_hook(self.hook_method(m, _DialogCellSetDialogHook(self)))
                added += 1
        except Exception as e:
            self._debug_log("dialog_cell_extras.setDialog hook failed: %s" % e)
        self._log_hook_status("dialog_cell_extras", added)

    def _maybe_apply_dialogs_extra_from_cell(self, dialogs_activity):
        if not dialogs_activity:
            return
        if not self.get_setting("enabled", True) or not self.get_setting("apply_dialogs_list", False):
            return
        if not self._is_fragment_active(dialogs_activity):
            return
        try:
            if _fragment_class_name(dialogs_activity) != CLASS_DIALOGS_ACTIVITY:
                return
        except Exception:
            return
        key = id(dialogs_activity)
        if len(self._last_dialogs_extra_from_cell) > 96:
            self._last_dialogs_extra_from_cell.clear()
        now = time.time() * 1000
        last = self._last_dialogs_extra_from_cell.get(key, 0)
        if now - last < self._DIALOGS_EXTRA_FROM_CELL_MS:
            return
        self._last_dialogs_extra_from_cell[key] = now
        self.apply_to_extra_fragment(dialogs_activity, 40)

    def _hook_extra_fragments(self):
        ctx_cls = safe_find_class("android.content.Context")
        added = 0
        for cname in (
            CLASS_DIALOGS_ACTIVITY,
            CLASS_SETTINGS_ACTIVITY,
            CLASS_TOPICS_FRAGMENT,
        ):
            Cls = safe_find_class(cname)
            if not Cls or not ctx_cls:
                continue
            try:
                cv = self._class_declared_method(Cls, "createView", ctx_cls)
                if cv:
                    cv.setAccessible(True)
                    self._register_hook(self.hook_method(cv, _ExtraFragmentResumeHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("%s createView hook failed: %s" % (cname, e))
            try:
                ore = self._class_declared_method(Cls, "onResume")
                if ore:
                    ore.setAccessible(True)
                    self._register_hook(self.hook_method(ore, _ExtraFragmentResumeHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("%s onResume hook failed: %s" % (cname, e))
            try:
                seen = set()
                for m in self._class_declared_methods(Cls):
                    if m.getName() != "updateColors":
                        continue
                    sig = str(m.toString())
                    if sig in seen:
                        continue
                    seen.add(sig)
                    m.setAccessible(True)
                    self._register_hook(self.hook_method(m, _ExtraFragmentResumeHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("%s updateColors hook failed: %s" % (cname, e))
            try:
                dest = self._class_declared_method(Cls, "onFragmentDestroy")
                if dest:
                    dest.setAccessible(True)
                    self._register_hook(self.hook_method(dest, _ExtraFragmentDestroyHook(self)))
                    added += 1
            except Exception as e:
                self._debug_log("%s onFragmentDestroy hook failed: %s" % (cname, e))
        self._log_hook_status("extra_fragments", added)


class _ActionBarColorBeforeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            self.plugin._on_action_bar_color_changed(param.thisObject, before=True)
        except Exception:
            pass


class _ActionBarColorAfterHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            self.plugin._on_action_bar_color_changed(param.thisObject, before=False)
        except Exception:
            ab = getattr(param, "thisObject", None)
            if ab is not None:
                try:
                    self.plugin._on_action_bar_color_changed(ab, before=False)
                except Exception:
                    pass


class _ActionBarBackgroundHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            args = getattr(param, "args", None)
            new_bg = args[0] if args and len(args) > 0 else None
            self.plugin._on_action_bar_background_changed(param.thisObject, new_bg)
        except Exception:
            pass


class _ActionBarModeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if param.method.getName() != "showActionMode":
                return
            self.plugin._on_action_bar_show_action_mode_before(param.thisObject)
        except Exception:
            ab = getattr(param, "thisObject", None)
            if ab is not None:
                try:
                    self.plugin._on_action_bar_show_action_mode_before(ab)
                except Exception:
                    pass

    def after_hooked_method(self, param):
        try:
            self.plugin._on_action_bar_mode_changed(param.thisObject)
        except Exception:
            ab = getattr(param, "thisObject", None)
            if ab is not None:
                try:
                    self.plugin._on_action_bar_mode_changed(ab)
                except Exception:
                    pass


class _ChatCreateViewHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            ca = param.thisObject
            plug = self.plugin
            perf = plug.get_setting("performance_mode", False)
            if plug._in_startup_grace():
                delays = (480, 1100) if perf else (480, 1100, 1800)
                for delay in delays:
                    run_on_ui_thread(lambda c=ca, p=plug: p.apply_to_chat(c, 0), delay)
            else:
                plug.apply_to_chat(ca, 120)
                if not perf:
                    run_on_ui_thread(lambda c=ca, p=plug: p.apply_to_chat(c, 0), 420)
        except Exception as exc:
            ca = getattr(param, "thisObject", None)
            if ca:
                try:
                    self.plugin.apply_to_chat(ca, 120)
                except Exception:
                    self.plugin._debug_log_exc("chat createView fallback", exc)

class _ChatResumeHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            ca = param.thisObject
            plug = self.plugin
            method = getattr(param, "method", None)
            is_top_panel = False
            try:
                is_top_panel = method is not None and method.getName() == "updateTopPanel"
            except Exception:
                is_top_panel = False
            if is_top_panel:
                plug.apply_to_chat(ca, 90)
                if not plug.get_setting("performance_mode", False):
                    run_on_ui_thread(lambda c=ca, p=plug: p.apply_to_chat(c, 0), 320)
            elif plug._in_startup_grace():
                plug.apply_to_chat(ca, 200)
            else:
                plug.apply_to_chat(ca, 70)
        except Exception as exc:
            ca = getattr(param, "thisObject", None)
            if ca:
                try:
                    self.plugin.apply_to_chat(ca, 100)
                except Exception:
                    self.plugin._debug_log_exc("chat resume fallback", exc)

class _ChatDestroyHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            self.plugin._cleanup_chat(param.thisObject)
        except Exception:
            obj = getattr(param, "thisObject", None)
            if obj is not None:
                try:
                    self.plugin._cleanup_chat(obj)
                except Exception:
                    pass

class _ChatSearchRepaintHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            plug = self.plugin
            view = param.thisObject
            chat = plug._find_chat_for_search_view(view)
            if chat is None:
                return
            if plug._in_startup_grace():
                base, step = 95, 100
            elif plug.get_setting("performance_mode", False):
                base, step = 70, 65
            else:
                base, step = 45, 55
            plug.apply_to_chat(chat, base)
        except Exception as exc:
            self.plugin._debug_log_exc("chat search repaint", exc)


class _DialogCellSetDialogHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            cell = param.thisObject
            da = get_private_field(cell, "parentFragment")
            plug = self.plugin
            run_on_ui_thread(lambda p=plug, d=da: p._maybe_apply_dialogs_extra_from_cell(d), 0)
        except Exception:
            pass


class _ExtraFragmentResumeHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            fr = param.thisObject
            plug = self.plugin
            perf = plug.get_setting("performance_mode", False)
            if plug._in_startup_grace():
                run_on_ui_thread(lambda: plug.apply_to_extra_fragment(fr, 0), 460)
                if not perf:
                    run_on_ui_thread(lambda: plug.apply_to_extra_fragment(fr, 0), 960)
            else:
                plug.apply_to_extra_fragment(fr, 90)
                retry = 380 if perf else 780
                run_on_ui_thread(lambda: plug.apply_to_extra_fragment(fr, 0), retry)
        except Exception as exc:
            self.plugin._debug_log_exc("extra fragment resume", exc)

class _ExtraFragmentDestroyHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            self.plugin._cleanup_extra(param.thisObject)
        except Exception:
            pass

class _ChatClipHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("enabled", True) or not self.plugin.get_setting("apply_action_bar", True):
                return
            ca = param.thisObject
            if not self.plugin._is_fragment_resumed(ca):
                return
            try:
                td = get_private_field(ca, "themeDelegate")
            except Exception:
                td = None
            if self.plugin._theme_is_light(td):
                self.plugin._restore_background_clip_for_chat(ca)
            elif self.plugin._blur_needs_preserved_background_clip(ca):
                return
            else:
                self.plugin._unclip_chat_background(ca)
        except Exception:
            pass
