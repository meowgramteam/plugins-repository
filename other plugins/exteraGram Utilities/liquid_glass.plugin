def _setting_icon(key, fallback="msg_info"):
    return SETTING_ICONS.get(key, fallback)


class _ColorProviderProxy(dynamic_proxy(BlurredBackgroundColorProvider)):
    def __init__(self, base, disable_top_stroke=False, disable_shadow=False, disable_bottom_stroke=False):
        super().__init__()
        self._base = base
        self._disable_top_stroke = disable_top_stroke
        self._disable_shadow = disable_shadow
        self._disable_bottom_stroke = disable_bottom_stroke

    def getShadowColor(self):
        if self._disable_shadow:
            return 0
        try:
            return self._base.getShadowColor()
        except Exception:
            return 0

    def getBackgroundColor(self):
        try:
            return self._base.getBackgroundColor()
        except Exception:
            return 0

    def getStrokeColorTop(self):
        if self._disable_top_stroke:
            return 0
        try:
            return self._base.getStrokeColorTop()
        except Exception:
            return 0

    def getStrokeColorBottom(self):
        if self._disable_bottom_stroke:
            return 0
        try:
            return self._base.getStrokeColorBottom()
        except Exception:
            return 0


def safe_find_class(class_name):
    if class_name in _class_cache:
        return _class_cache[class_name]
    try:
        cls = find_class(class_name)
        _class_cache[class_name] = cls
        return cls
    except Exception:
        _class_cache[class_name] = None
        return None


def _fragment_class_name(fragment):
    if not fragment:
        return None
    try:
        return fragment.getClass().getName()
    except Exception:
        return None


def _get_first_available_field(obj, *names):
    if not obj or not names:
        return None
    for name in names:
        try:
            v = getattr(obj, name, None)
        except Exception:
            v = None
        if v is not None:
            return v
        try:
            v = get_private_field(obj, name)
        except Exception:
            v = None
        if v is not None:
            return v
    return None


def _truthy_fragment_flag(raw):
    if raw is None:
        return False
    try:
        if callable(raw):
            raw = raw()
    except Exception:
        return False
    try:
        return bool(raw)
    except Exception:
        return False


class LiquidGlassPlugin(BasePlugin):
    _TOP_PANEL_PROVIDER_METHODS = {
        "chat": "topPanelChatActivity",
        "top_panel": "topPanel",
        "search_tags": "topPanelChatActivityTags",
        "search_list": "topPanelChatActivitySearchListBg",
    }
    _APPLY_DEBOUNCE_MS = 130
    _PERFORMANCE_DEBOUNCE_MS = 240
    _MIN_TOP_PANEL_DP = 8
    _DIALOGS_EXTRA_FROM_CELL_MS = 520
    _DRAWABLE_CACHE_MAX = 96
    _STARTUP_GRACE_MS = 2400
    _STARTUP_DEBOUNCE_MIN_MS = 420
    _STARTUP_EXTRA_DELAY_MIN_MS = 260
    _STATE_STORE_MAX = 128
    _FACTORY_RETRY_COOLDOWN_MS = 2500
    _THEME_BURST_DEBOUNCE_MS = 320
    _TOP_PANEL_NATIVE_GRACE_MS = 900
    _TOP_PANEL_TUNE_RETRY_MS = (550,)
    _TOP_PANEL_TUNE_RETRY_MS_PERF = (900,)
    _ACTION_BAR_COLOR_SHIELD_MS = 90
    _ACTION_BAR_MODE_RESUME_MS = 220

    def __init__(self):
        super().__init__()
        self._loaded = False
        self._hooks = []
        self._applied = {}
        self._warned = False
        self._apply_pending = set()
        self._apply_requested = set()
        self._drawable_cache = OrderedDict()
        self._last_apply_time = {}
        self._active_chats = WeakSet()
        self._extras_applied = {}
        self._active_extras = WeakSet()
        self._last_dialogs_extra_from_cell = {}
        self._startup_grace_until_ms = 0.0
        self._extra_apply_gen = {}
        self._settings_apply_gen = 0
        self._factory_cooldown_chat = {}
        self._factory_cooldown_extra = {}
        self._action_bar_color_shield_last = {}
        self._action_bar_store_index = {}
        self._theme_burst_hint_shown = False
        self._load_requirements_hint_shown = False
        self._menu_chat_reapply_id = None
        self._menu_chat_settings_id = None
        self._menu_action_debounce_ts = {}
        self._diag = {
            "factory_miss_chat": 0,
            "factory_miss_extra": 0,
            "factory_cooldown_skip_chat": 0,
            "factory_cooldown_skip_extra": 0,
            "theme_burst_chat": 0,
            "theme_burst_extra": 0,
            "state_prunes": 0,
            "action_bar_shield_calls": 0,
            "action_bar_bg_restore_calls": 0,
            "drawable_create_fail": 0,
            "drawable_cache_hits": 0,
            "dialog_shown": 0,
            "import_confirmed": 0,
            "import_cancelled": 0,
        }

    def _arm_startup_grace(self):
        self._startup_grace_until_ms = (time.time() * 1000.0) + float(self._STARTUP_GRACE_MS)

    def _in_startup_grace(self):
        return (time.time() * 1000.0) < self._startup_grace_until_ms

    def _index_action_bar_store(self, action_bar, store):
        if action_bar is not None and store is not None:
            self._action_bar_store_index[id(action_bar)] = store

    def _unindex_action_bar_store(self, action_bar):
        if action_bar is not None:
            self._action_bar_store_index.pop(id(action_bar), None)

    def _rebuild_action_bar_store_index(self):
        self._action_bar_store_index.clear()
        for store in list(self._applied.values()) + list(self._extras_applied.values()):
            entry = store.get("action_bar")
            view = entry.get("view") if entry else None
            if view is not None:
                self._action_bar_store_index[id(view)] = store

    def _schedule_settings_reapply(self, delay_ms=120):
        self._settings_apply_gen += 1
        gen = int(self._settings_apply_gen)

        def _run():
            if int(self._settings_apply_gen) != gen:
                return
            self._restore_all()

        run_on_ui_thread(_run, delay_ms)

    def on_app_event(self, event_type: AppEvent):
        if event_type == AppEvent.START:
            self._arm_startup_grace()

    def on_plugin_load(self):
        if self._loaded:
            self.on_plugin_unload()
        self._warned = False
        self._loaded = True
        self._theme_burst_hint_shown = False
        self._arm_startup_grace()
        self._verify_client_requirements()
        self._hook_chat_activity()
        self._hook_action_bar()
        self._hook_dialog_cell_extras()
        self._hook_chat_search_tabs()
        self._hook_extra_fragments()
        self._register_menu_items()

    def on_plugin_unload(self):
        self._loaded = False
        self._unregister_menu_items()
        for ref in self._hooks:
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._hooks.clear()
        try:
            self._last_dialogs_extra_from_cell.clear()
        except Exception:
            self._last_dialogs_extra_from_cell = {}
        self._startup_grace_until_ms = 0.0
        self._extra_apply_gen.clear()
        self._apply_pending.clear()
        self._apply_requested.clear()
        self._factory_cooldown_chat.clear()
        self._factory_cooldown_extra.clear()
        self._action_bar_color_shield_last.clear()
        self._action_bar_store_index.clear()
        self._drawable_cache.clear()
        _class_cache.clear()
        run_on_ui_thread(lambda: self._restore_all(reapply_after=False))

    def _register_hook(self, ref):
        if ref and ref not in self._hooks:
            self._hooks.append(ref)

    def _log_hook_status(self, block_name, added):
        try:
            self.log("[LiquidGlass] hooks %s: %d" % (block_name, int(added)))
        except Exception:
            pass

    def _debug_enabled(self):
        try:
            return bool(self.get_setting("debug_logs", False))
        except Exception:
            return False

    def _debug_log(self, text):
        if not self._debug_enabled():
            return
        try:
            self.log("[LiquidGlass][debug] %s" % str(text))
        except Exception:
            pass

    def _debug_log_exc(self, text, exc):
        if not self._debug_enabled():
            return
        try:
            self.log("[LiquidGlass][debug] %s: %s" % (str(text), str(exc)))
        except Exception:
            pass

    def _class_declared_method(self, cls, name, *arg_types):
        if not cls:
            return None
        try:
            return cls.getDeclaredMethod(name, *arg_types)
        except Exception:
            pass
        try:
            return cls.getClass().getDeclaredMethod(name, *arg_types)
        except Exception:
            return None

    def _class_declared_methods(self, cls):
        if not cls:
            return []
        try:
            return cls.getDeclaredMethods()
        except Exception:
            pass
        try:
            return cls.getClass().getDeclaredMethods()
        except Exception:
            return []

    def _bump_diag(self, key, inc=1):
        try:
            self._diag[key] = int(self._diag.get(key, 0)) + int(inc)
        except Exception:
            pass

    def _dialog_activity(self):
        try:
            fragment = get_last_fragment()
            if fragment is None:
                return None
            return fragment.getParentActivity()
        except Exception:
            return None

    def _show_confirm_dialog(self, title, message, on_confirm, positive="OK", negative="Отмена", on_cancel=None):
        activity = self._dialog_activity()
        if activity is None:
            try:
                if on_confirm:
                    on_confirm()
            except Exception:
                pass
            return

        def _ok(bld, which):
            self._bump_diag("dialog_shown")
            try:
                if on_confirm:
                    on_confirm()
            except Exception as exc:
                self._debug_log_exc("confirm_dialog_ok", exc)
            try:
                bld.dismiss()
            except Exception:
                pass

        def _cancel(bld, which):
            try:
                if on_cancel:
                    on_cancel()
            except Exception as exc:
                self._debug_log_exc("confirm_dialog_cancel", exc)
            try:
                bld.dismiss()
            except Exception:
                pass

        try:
            builder = AlertDialogBuilder(activity)
            builder.set_title(str(title))
            builder.set_message(str(message))
            builder.set_positive_button(str(positive), _ok)
            builder.set_negative_button(str(negative), _cancel)
            builder.set_cancelable(True)
            builder.show()
        except Exception as exc:
            self._debug_log_exc("confirm_dialog", exc)
            try:
                if on_confirm:
                    on_confirm()
            except Exception:
                pass

    def _count_enabled_areas(self):
        keys = (
            "apply_action_bar",
            "apply_top_panels",
            "apply_search_bar",
            "apply_story_bar",
            "apply_dialogs_list",
            "apply_topics_header",
        )
        n = 0
        for k in keys:
            try:
                if bool(self.get_setting(k, DEFAULT_SETTINGS[k])):
                    n += 1
            except Exception:
                pass
        return n

    def _settings_effect_mode_label(self):
        try:
            if not self.get_setting("enabled", True):
                return "Выкл."
            if not self._is_supported():
                return "Недоступен"
            sdk = int(getattr(Build.VERSION, "SDK_INT", 0))
            if bool(self.get_setting("strong_glass", False)) and sdk >= 33:
                return "Liquid Glass"
            return "Frosted"
        except Exception:
            return "—"

    def _settings_status_line(self):
        mode = self._settings_effect_mode_label()
        n = self._count_enabled_areas()
        perf = " · Экономия" if self.get_setting("performance_mode", False) else ""
        return "Режим: %s · зон: %d%s" % (mode, n, perf)

    def _health_check_line_short(self):
        if not self._is_supported():
            return "Эффект недоступен"
        fails = int(self._diag.get("drawable_create_fail", 0))
        if fails:
            return "Ошибки отрисовки: %d" % fails
        return "Готов к работе"

    def _health_check_line(self):
        parts = []
        if self._is_supported():
            parts.append("Эффект доступен")
        else:
            parts.append("Эффект недоступен")
        miss = int(self._diag.get("factory_miss_chat", 0)) + int(self._diag.get("factory_miss_extra", 0))
        if miss:
            parts.append("Пропуски blur: %d" % miss)
        fails = int(self._diag.get("drawable_create_fail", 0))
        if fails:
            parts.append("Ошибки drawable: %d" % fails)
        parts.append("Хуки: %d" % int(len(self._hooks)))
        parts.append("Кэш: %d" % int(len(self._drawable_cache)))
        return " · ".join(parts)

    def _on_settings_tab_change(self, index):
        try:
            self.set_setting("settings_tab", int(index), reload_settings=True)
        except TypeError:
            self.set_setting("settings_tab", int(index))

    def _areas_summary_line(self):
        active = []
        for key, label in _AREA_LABELS.items():
            try:
                if bool(self.get_setting(key, DEFAULT_SETTINGS[key])):
                    active.append(label)
            except Exception:
                pass
        if not active:
            return "Ничего не выбрано"
        if len(active) == len(_AREA_LABELS):
            return "Все зоны"
        if len(active) <= 3:
            return ", ".join(active)
        return "%d зоны" % len(active)

    def _settings_status_widgets(self):
        supported = bool(self._is_supported())
        enabled = bool(self.get_setting("enabled", True))
        rows = []
        rows.extend(self._requirements_hint_widgets())
        status_kw = {}
        if not supported:
            status_kw = {"icon": "msg_warning", "red": True}
        elif enabled:
            status_kw = {"icon": "msg_theme", "accent": True}
        else:
            status_kw = {"icon": "msg_info"}
        rows.append(
            Text(
                text=self._settings_status_line(),
                subtext=self._health_check_line_short(),
                **status_kw,
            )
        )
        if rows:
            rows.append(Divider())
        return rows

    def _build_settings_tab_overview(self, on_change):
        n = self._count_enabled_areas()
        return [
            Header(text="Обзор"),
            Switch(
                key="enabled",
                text="Включить эффект",
                subtext="Во всём приложении",
                icon=_setting_icon("enabled"),
                default=True,
                link_alias="enabled",
                on_change=on_change,
            ),
            Text(
                text="Переприменить стекло",
                subtext="Без перезапуска",
                icon="msg_retry",
                accent=True,
                on_click=lambda v: run_on_ui_thread(self._force_reapply),
            ),
            Divider(),
            Header(text="Сводка"),
            Text(
                text="Активные зоны: %d из %d" % (n, len(_AREA_LABELS)),
                subtext=self._areas_summary_line(),
                icon="msg_folders",
            ),
            Text(
                text="Режим: %s" % self._settings_effect_mode_label(),
                subtext="Liquid Glass — С Strong Glass",
                icon="msg_photo_settings",
            ),
        ]

    def _verify_client_requirements(self):
        if self._load_requirements_hint_shown:
            return
        self._load_requirements_hint_shown = True
        missing = []
        if not safe_find_class("org.telegram.ui.ActionBar.ActionBar"):
            missing.append("ActionBar")
        if not safe_find_class("org.telegram.ui.ChatActivity"):
            missing.append("ChatActivity")
        if not safe_find_class("org.telegram.ui.Components.blur3.BlurredBackgroundDrawableViewFactory"):
            missing.append("blur3")
        if missing:
            try:
                BulletinHelper.show_info(
                    "Нужен exteraGram %s (не найдено: %s)" % (__app_version__, ", ".join(missing))
                )
            except Exception:
                pass

    def _ensure_native_glass_setup(self, fragment):
        if not fragment:
            return
        setup = getattr(fragment, "setupGlass", None)
        if not callable(setup):
            return
        try:
            setup()
        except Exception:
            pass

    def _search_provider_kind(self, store_key):
        if store_key == "search_results":
            return "search_list"
        if store_key == "search_bar":
            return "search_tags"
        return "chat"

    def _signature_theme_fingerprint(self, sig):
        try:
            if sig and len(sig) >= 2:
                return sig[1]
        except Exception:
            pass
        return None

    def _is_real_theme_burst(self, prev_sig, current_sig):
        if prev_sig is None or current_sig is None or prev_sig == current_sig:
            return False
        prev_theme = self._signature_theme_fingerprint(prev_sig)
        curr_theme = self._signature_theme_fingerprint(current_sig)
        if prev_theme is None or curr_theme is None:
            return False
        return prev_theme != curr_theme

    def _store_needs_sig_recovery(self, store):
        if not store or store.get("_lg_apply_sig") is not None:
            return False
        for key in (
            "action_bar", "top_panel", "top_panel_layout", "top_panel2",
            "search_bar", "search_container", "search_results", "story_bar",
        ):
            if key in store:
                return True
        return False

    def _maybe_theme_burst_hint(self):
        if self._theme_burst_hint_shown:
            return
        self._theme_burst_hint_shown = True
        try:
            BulletinHelper.show_info("Тема сменилась — эффект обновится через мгновение")
        except Exception:
            pass

    def _drawable_cache_get(self, cache_key):
        d = self._drawable_cache
        if cache_key not in d:
            return None
        drawable = d.pop(cache_key)
        d[cache_key] = drawable
        return drawable

    def _drawable_cache_put(self, cache_key, drawable):
        d = self._drawable_cache
        if cache_key in d:
            d.pop(cache_key)
        d[cache_key] = drawable
        while len(d) > self._DRAWABLE_CACHE_MAX:
            d.popitem(last=False)

    def _collect_drawable_cache_view_ids(self, store):
        ids = set()
        if not store:
            return ids
        for key in (
            "action_bar",
            "action_bar_blurred",
            "action_bar_cast_shadows",
            "top_panel_layout",
            "top_panel",
            "top_panel2",
            "search_bar",
            "search_container",
            "search_results",
            "story_bar",
        ):
            entry = store.get(key)
            view = entry.get("view") if entry else None
            if view is not None:
                try:
                    ids.add(id(view))
                except Exception:
                    pass
        clip = store.get("background_clip")
        if clip and clip.get("view"):
            try:
                ids.add(id(clip["view"]))
            except Exception:
                pass
        return ids

    def _evict_drawable_cache_for_view_ids(self, view_ids):
        if not view_ids or not self._drawable_cache:
            return
        drop = [k for k in self._drawable_cache if k and len(k) > 1 and k[1] in view_ids]
        for k in drop:
            self._drawable_cache.pop(k, None)

    def _prune_runtime_state(self):
        if (
            len(self._applied) < self._STATE_STORE_MAX
            and len(self._extras_applied) < self._STATE_STORE_MAX
            and len(self._last_apply_time) < (self._STATE_STORE_MAX * 2)
            and len(self._factory_cooldown_chat) < (self._STATE_STORE_MAX * 2)
            and len(self._factory_cooldown_extra) < (self._STATE_STORE_MAX * 2)
            and len(self._action_bar_color_shield_last) < (self._STATE_STORE_MAX * 2)
        ):
            return
        keep_chat_ids = set()
        keep_extra_ids = set()
        keep_action_bar_ids = set()
        try:
            keep_chat_ids.update(id(x) for x in list(self._active_chats))
        except Exception:
            pass
        try:
            keep_extra_ids.update(id(x) for x in list(self._active_extras))
        except Exception:
            pass
        for store in list(self._applied.values()) + list(self._extras_applied.values()):
            entry = store.get("action_bar")
            view = entry.get("view") if entry else None
            if view is not None:
                try:
                    keep_action_bar_ids.add(id(view))
                except Exception:
                    pass
        self._applied = {k: v for k, v in self._applied.items() if k in keep_chat_ids}
        self._extras_applied = {k: v for k, v in self._extras_applied.items() if k in keep_extra_ids}
        self._last_apply_time = {k: v for k, v in self._last_apply_time.items() if k in keep_chat_ids}
        self._factory_cooldown_chat = {k: v for k, v in self._factory_cooldown_chat.items() if k in keep_chat_ids}
        self._factory_cooldown_extra = {k: v for k, v in self._factory_cooldown_extra.items() if k in keep_extra_ids}
        self._action_bar_color_shield_last = {
            k: v for k, v in self._action_bar_color_shield_last.items() if k in keep_action_bar_ids
        }
        self._rebuild_action_bar_store_index()
        keep_view_ids = set()
        keep_view_ids.update(keep_action_bar_ids)
        for store in list(self._applied.values()) + list(self._extras_applied.values()):
            keep_view_ids.update(self._collect_drawable_cache_view_ids(store))
        if self._drawable_cache:
            drop = [k for k in self._drawable_cache if not k or len(k) < 2 or k[1] not in keep_view_ids]
            for k in drop:
                self._drawable_cache.pop(k, None)
        self._bump_diag("state_prunes")

    def _profile_setting_keys(self):
        return [k for k in DEFAULT_SETTINGS if k not in _PROFILE_UI_KEYS]

    def _menu_action_debounce_ok(self, key, min_interval_ms=500):
        try:
            now = int(time.time() * 1000)
            k = str(key or "").strip()
            if not k:
                return True
            prev = int(self._menu_action_debounce_ts.get(k, 0) or 0)
            if prev and (now - prev) < int(min_interval_ms):
                return False
            self._menu_action_debounce_ts[k] = now
            if len(self._menu_action_debounce_ts) > 32:
                cutoff = now - 30000
                self._menu_action_debounce_ts = {
                    kk: vv for kk, vv in self._menu_action_debounce_ts.items() if int(vv or 0) >= cutoff
                }
            return True
        except Exception:
            return True

    def _open_tg(self, username):
        u = str(username or "").strip().lstrip("@")
        if not u or not u.replace("_", "").isalnum():
            return
        try:
            AppLoader = safe_find_class("org.telegram.messenger.ApplicationLoader")
            if AppLoader is None:
                AppLoader = safe_find_class("com.exteragram.messenger.ApplicationLoader")
            Intent_cls = safe_find_class("android.content.Intent")
            Uri_cls = safe_find_class("android.net.Uri")
            if AppLoader is None or Intent_cls is None or Uri_cls is None:
                return
            ctx = AppLoader.applicationContext
            if ctx is None:
                return
            it = Intent_cls(Intent_cls.ACTION_VIEW, Uri_cls.parse("tg://resolve?domain=%s" % u))
            it.addFlags(Intent_cls.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(it)
        except Exception:
            pass

    def _open_plugin_settings(self):
        try:
            from com.exteragram.messenger.plugins import PluginsController
            from com.exteragram.messenger.plugins.ui import PluginSettingsActivity

            fragment = get_last_fragment()
            if fragment is None:
                raise RuntimeError("fragment missing")

            controller = PluginsController.getInstance()
            plugin = controller.plugins.get(__id__)
            if plugin is None:
                raise RuntimeError("plugin missing")

            fragment.presentFragment(PluginSettingsActivity(plugin))
            return
        except Exception:
            pass
        try:
            from com.exteragram.messenger.plugins import PluginsController

            fragment = get_last_fragment()
            controller = PluginsController.getInstance()
            if fragment is not None:
                engine = controller.getPluginsEngine()
                if engine is not None:
                    try:
                        engine.openPluginSettings(__id__, fragment)
                        return
                    except TypeError:
                        engine.openPluginSetting(__id__, fragment)
                        return
            try:
                controller.openPluginSettings(__id__)
                return
            except TypeError:
                controller.openPluginSettings(__id__, "")
                return
        except Exception as exc:
            self._debug_log_exc("open_plugin_settings", exc)
            try:
                BulletinHelper.show_error("Не удалось открыть настройки")
            except Exception:
                pass

    def _register_menu_items(self):
        self._unregister_menu_items()
        try:
            self._menu_chat_settings_id = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Настройки плагина",
                    subtext="Liquid Glass",
                    icon="msg_settings",
                    on_click=self._menu_open_settings,
                    priority=14,
                )
            )
            self._menu_chat_reapply_id = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Переприменить стекло",
                    subtext="Liquid Glass",
                    icon="msg_retry",
                    on_click=self._menu_reapply_glass,
                    priority=12,
                )
            )
        except Exception as exc:
            self._debug_log_exc("register_menu_items", exc)

    def _unregister_menu_items(self):
        for attr in ("_menu_chat_settings_id", "_menu_chat_reapply_id"):
            item_id = getattr(self, attr, None)
            if item_id:
                try:
                    self.remove_menu_item(item_id)
                except Exception:
                    pass
            setattr(self, attr, None)

    def _menu_reapply_glass(self, context):
        if not self._menu_action_debounce_ok("chat_reapply", 500):
            return
        run_on_ui_thread(self._force_reapply)

    def _menu_open_settings(self, context):
        if not self._menu_action_debounce_ok("chat_settings", 500):
            return
        run_on_ui_thread(self._open_plugin_settings)

    def _client_blur_restricted(self):
        try:
            from org.telegram.messenger import UserConfig, MessagesController
            account = int(UserConfig.selectedAccount)
            mc = MessagesController.getInstance(account)
            cfg = mc.config
            if Theme.isCurrentThemeDark() and bool(cfg.disableBlurInDarkTheme.get()):
                return "dark"
            if not Theme.isCurrentThemeDark() and bool(cfg.disableBlurInLightTheme.get()):
                return "light"
        except Exception:
            pass
        return None

    def _requirements_hint_widgets(self):
        rows = []
        try:
            blur_on = SharedConfig.chatBlurEnabled()
        except Exception:
            blur_on = True
        if not blur_on:
            rows.append(
                Text(
                    text="Нужно размытие чата",
                    subtext="Telegram → Чат → Размытие",
                    icon="msg_warning",
                    red=True,
                )
            )
        if not self.get_setting("strong_glass", False):
            rows.append(
                Text(
                    text="Сейчас: Frosted",
                    subtext="Strong Glass — вкладка «Вид»",
                    icon="msg_info",
                )
            )
        restricted = self._client_blur_restricted()
        if restricted == "dark":
            rows.append(
                Text(
                    text="Blur выкл. в тёмной теме",
                    subtext="Ограничение сервера",
                    icon="msg_warning",
                )
            )
        elif restricted == "light":
            rows.append(
                Text(
                    text="Blur выкл. в светлой теме",
                    subtext="Ограничение сервера",
                    icon="msg_warning",
                )
            )
        return rows

    def _get_application_context(self):
        for pkg in (
            "org.telegram.messenger.ApplicationLoader",
            "com.exteragram.messenger.ApplicationLoader",
        ):
            AL = safe_find_class(pkg)
            if not AL:
                continue
            try:
                ctx = AL.applicationContext
                if ctx is not None:
                    return ctx
            except Exception:
                pass
        return None

    def _clipboard_copy_text(self, text):
        ctx = self._get_application_context()
        if not ctx or not text:
            return False
        try:
            Context = safe_find_class("android.content.Context")
            ClipData = safe_find_class("android.content.ClipData")
            if not Context or not ClipData:
                return False
            cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if not cm:
                return False
            clip = ClipData.newPlainText(__id__, str(text))
            cm.setPrimaryClip(clip)
            return True
        except Exception:
            return False

    def _notify_copied(self, message):
        try:
            BulletinHelper.show_copied_to_clipboard(message)
        except Exception:
            try:
                BulletinHelper.show_info(message)
            except Exception:
                pass

    def _clipboard_get_text(self):
        ctx = self._get_application_context()
        if not ctx:
            return None
        try:
            Context = safe_find_class("android.content.Context")
            if not Context:
                return None
            cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if not cm:
                return None
            clip = cm.getPrimaryClip()
            if not clip or clip.getItemCount() < 1:
                return None
            t = clip.getItemAt(0).getText()
            if t is None:
                return None
            return str(t)
        except Exception:
            return None

    def _coerce_import_value(self, key, raw):
        if key not in DEFAULT_SETTINGS:
            return None
        default = DEFAULT_SETTINGS[key]
        if isinstance(default, bool):
            if isinstance(raw, bool):
                return raw
            if isinstance(raw, (int, float)):
                return raw != 0
            s = str(raw).strip().lower()
            return s in ("1", "true", "yes", "on", "да")
        if key in NUMERIC_SETTING_LIMITS:
            lo, hi = NUMERIC_SETTING_LIMITS[key]
            try:
                v = float(str(raw).replace(",", ".").strip())
            except Exception:
                return str(default)
            v = max(float(lo), min(float(hi), v))
            if float(v).is_integer():
                return str(int(v))
            return ("%.3f" % v).rstrip("0").rstrip(".")
        return str(raw)

    def _migrate_import_profile(self, obj):
        if not isinstance(obj, dict):
            return obj
        migrated = dict(obj)
        try:
            schema_version = int(migrated.get("schema_version", 1))
        except Exception:
            schema_version = 1
        if schema_version >= PROFILE_SCHEMA_VERSION:
            inner = migrated.get("settings")
            if isinstance(inner, dict):
                for k in _OBSOLETE_SETTING_KEYS:
                    inner.pop(k, None)
                for k in _PROFILE_UI_KEYS:
                    inner.pop(k, None)
            return migrated
        inner = migrated.get("settings")
        if not isinstance(inner, dict):
            inner = {}
            for k in DEFAULT_SETTINGS:
                if k in migrated:
                    inner[k] = migrated[k]
        merged_settings = {k: DEFAULT_SETTINGS[k] for k in DEFAULT_SETTINGS}
        if isinstance(inner, dict):
            for k, v in inner.items():
                if k in DEFAULT_SETTINGS and k not in _OBSOLETE_SETTING_KEYS and k not in _PROFILE_UI_KEYS:
                    merged_settings[k] = v
        return {
            "format": "liquid_glass",
            "schema_version": PROFILE_SCHEMA_VERSION,
            "version": migrated.get("version", __version__),
            "settings": merged_settings,
        }

    def _export_profile_json(self):
        payload = {
            "format": "liquid_glass",
            "schema_version": PROFILE_SCHEMA_VERSION,
            "version": __version__,
            "settings": {k: self.get_setting(k, DEFAULT_SETTINGS[k]) for k in self._profile_setting_keys()},
        }
        try:
            text = json.dumps(payload, ensure_ascii=False, indent=2)
        except Exception:
            try:
                BulletinHelper.show_info("Ошибка экспорта")
            except Exception:
                pass
            return
        if self._clipboard_copy_text(text):
            self._notify_copied("Профиль скопирован в буфер")
        else:
            try:
                BulletinHelper.show_error("Не удалось записать буфер обмена")
            except Exception:
                pass

    def _parse_import_profile(self, raw):
        if not raw or not str(raw).strip():
            return {"error": "Буфер пуст"}
        try:
            obj = json.loads(str(raw).strip())
        except Exception:
            return {"error": "Неверный JSON в буфере"}
        obj = self._migrate_import_profile(obj)
        if not isinstance(obj, dict):
            return {"error": "Ожидался объект JSON"}
        fmt = obj.get("format")
        if fmt is not None and fmt != "liquid_glass":
            return {"error": "Это не профиль Liquid Glass"}
        schema_version = obj.get("schema_version", 1)
        try:
            schema_version = int(schema_version)
        except Exception:
            schema_version = 1
        if schema_version > PROFILE_SCHEMA_VERSION:
            return {"error": "Профиль из более новой версии плагина"}
        inner = obj.get("settings", obj)
        if not isinstance(inner, dict):
            return {"error": "Нет блока settings"}
        current = {k: self.get_setting(k, DEFAULT_SETTINGS[k]) for k in DEFAULT_SETTINGS}
        merged = dict(current)
        changes = []
        n = 0
        for k, v in inner.items():
            if k not in DEFAULT_SETTINGS or k in _PROFILE_UI_KEYS:
                continue
            c = self._coerce_import_value(k, v)
            if c is None:
                continue
            old = current.get(k)
            if old != c:
                changes.append((k, old, c))
            merged[k] = c
            n += 1
        if n == 0:
            return {"error": "Нет распознанных полей"}
        return {"merged": merged, "n": n, "changes": changes}

    def _import_profile_from_clipboard(self):
        parsed = self._parse_import_profile(self._clipboard_get_text())
        if parsed.get("error"):
            try:
                BulletinHelper.show_info(str(parsed["error"]))
            except Exception:
                pass
            return
        merged = parsed["merged"]
        n = int(parsed["n"])
        changes = parsed.get("changes") or []
        if not changes:
            try:
                BulletinHelper.show_info("Профиль совпадает с текущими настройками")
            except Exception:
                pass
            return
        lines = []
        for k, old, new in changes[:14]:
            lines.append("%s: %s → %s" % (k, old, new))
        if len(changes) > 14:
            lines.append("… и ещё %d" % (len(changes) - 14))
        message = "Будет обновлено полей: %d\n\n%s" % (len(changes), "\n".join(lines))

        def _apply():
            self._commit_import_profile(merged, n)

        def _cancel():
            self._bump_diag("import_cancelled")

        self._show_confirm_dialog(
            "Импорт профиля",
            message,
            _apply,
            positive="Применить",
            on_cancel=_cancel,
        )

    def _commit_import_profile(self, merged, n):
        self._bump_diag("import_confirmed")
        self._persist_settings_bulk(merged)
        self._last_apply_time.clear()
        self._extra_apply_gen.clear()
        self._apply_pending.clear()
        self._apply_requested.clear()
        self._drawable_cache.clear()
        run_on_ui_thread(self._restore_all)
        try:
            BulletinHelper.show_info("Импорт: %d полей" % int(n))
        except Exception:
            pass

    def _export_debug_report(self):
        try:
            blur_on = bool(SharedConfig.chatBlurEnabled())
        except Exception:
            blur_on = True
        is_supported_now = bool(int(getattr(Build.VERSION, "SDK_INT", 0)) >= 29 and blur_on)
        try:
            settings = {k: self.get_setting(k, DEFAULT_SETTINGS[k]) for k in DEFAULT_SETTINGS}
        except Exception:
            settings = {}
        try:
            diag = dict(self._diag)
        except Exception:
            diag = {}
        try:
            report = {
                "format": "liquid_glass_debug_report",
                "schema_version": 1,
                "plugin_id": __id__,
                "plugin_name": __name__,
                "plugin_version": __version__,
                "app_version_req": __app_version__,
                "sdk_version_req": __sdk_version__,
                "app_min_version_legacy": __min_version__,
                "android_sdk": int(getattr(Build.VERSION, "SDK_INT", 0)),
                "is_supported_now": is_supported_now,
                "chat_blur_enabled": bool(blur_on),
                "runtime": {
                    "hooks_registered": int(len(self._hooks)),
                    "active_chats": int(len(list(self._active_chats))),
                    "active_extras": int(len(list(self._active_extras))),
                    "applied_chat_stores": int(len(self._applied)),
                    "applied_extra_stores": int(len(self._extras_applied)),
                    "apply_pending": int(len(self._apply_pending)),
                    "apply_requested": int(len(self._apply_requested)),
                    "factory_cooldown_chat": int(len(self._factory_cooldown_chat)),
                    "factory_cooldown_extra": int(len(self._factory_cooldown_extra)),
                    "drawable_cache_size": int(len(self._drawable_cache)),
                },
                "diagnostics": diag,
                "settings": settings,
            }
            text = json.dumps(report, ensure_ascii=False, indent=2)
        except Exception:
            try:
                BulletinHelper.show_error("Ошибка сборки debug-отчёта")
            except Exception:
                pass
            return

        if self._clipboard_copy_text(text):
            self._notify_copied("Debug-отчёт скопирован в буфер")
        else:
            try:
                BulletinHelper.show_error("Не удалось записать debug-отчёт в буфер")
            except Exception:
                pass

    def _export_debug_summary(self):
        try:
            blur_on = bool(SharedConfig.chatBlurEnabled())
        except Exception:
            blur_on = True
        sdk = int(getattr(Build.VERSION, "SDK_INT", 0))
        supported = bool(sdk >= 29 and blur_on)
        try:
            summary = (
                "Liquid Glass Debug Summary\n"
                "version: %s\n"
                "android_sdk: %d\n"
                "supported_now: %s\n"
                "chat_blur_enabled: %s\n"
                "hooks_registered: %d\n"
                "active_chats: %d\n"
                "active_extras: %d\n"
                "factory_miss_chat: %d\n"
                "factory_miss_extra: %d\n"
                "theme_burst_chat: %d\n"
                "theme_burst_extra: %d\n"
                "state_prunes: %d\n"
                "action_bar_shield_calls: %d\n"
                "action_bar_bg_restore_calls: %d\n"
                "drawable_create_fail: %d\n"
                "drawable_cache_hits: %d\n"
                "drawable_cache_size: %d"
            ) % (
                __version__,
                sdk,
                "yes" if supported else "no",
                "yes" if blur_on else "no",
                int(len(self._hooks)),
                int(len(list(self._active_chats))),
                int(len(list(self._active_extras))),
                int(self._diag.get("factory_miss_chat", 0)),
                int(self._diag.get("factory_miss_extra", 0)),
                int(self._diag.get("theme_burst_chat", 0)),
                int(self._diag.get("theme_burst_extra", 0)),
                int(self._diag.get("state_prunes", 0)),
                int(self._diag.get("action_bar_shield_calls", 0)),
                int(self._diag.get("action_bar_bg_restore_calls", 0)),
                int(self._diag.get("drawable_create_fail", 0)),
                int(self._diag.get("drawable_cache_hits", 0)),
                int(len(self._drawable_cache)),
            )
        except Exception:
            try:
                BulletinHelper.show_info("Ошибка сборки краткого отчёта")
            except Exception:
                pass
            return

        if self._clipboard_copy_text(summary):
            self._notify_copied("Краткий отчёт скопирован в буфер")
        else:
            try:
                BulletinHelper.show_error("Не удалось записать краткий отчёт в буфер")
            except Exception:
                pass

    def create_settings(self) -> List[Any]:
        def on_change(_):
            self._schedule_settings_reapply(90)

        tab = int(self.get_setting("settings_tab", 0) or 0)
        if tab < 0 or tab >= len(_SETTINGS_TAB_ITEMS):
            tab = 0

        rows = [
            Header(text="Liquid Glass"),
            Selector(
                key="settings_tab",
                text="Раздел",
                items=_SETTINGS_TAB_ITEMS,
                default=tab,
                icon="msg_settings",
                on_change=self._on_settings_tab_change,
            ),
            Divider(),
        ]

        if tab == 0:
            rows.extend(self._settings_status_widgets())
            rows.extend(self._build_settings_tab_overview(on_change))
        elif tab == 1:
            rows.extend(self._create_areas_settings())
        elif tab == 2:
            rows.extend(self._create_appearance_settings())
            rows.append(Divider())
            rows.extend(self._create_position_settings())
        elif tab == 3:
            rows.extend(self._create_tools_settings())
        else:
            rows.extend(self._create_help_settings())

        rows.append(Divider())
        rows.extend([
            Header(text="О плагине"),
            Text(
                text="@PluginProject",
                subtext="Обновления",
                icon="msg_channel",
                accent=True,
                on_click=lambda v: self._open_tg("PluginProject"),
            ),
            Text(
                text="@w3b_0s1nt",
                subtext="Автор форка",
                icon="msg_contact",
                accent=True,
                on_click=lambda v: self._open_tg("w3b_0s1nt"),
            ),
            Divider(text="%s · v%s" % (__name__, __version__)),
        ])
        return rows

    def _create_areas_settings(self):
        def on_change(_):
            self._schedule_settings_reapply(90)

        n = self._count_enabled_areas()
        return [
            Header(text="Области применения"),
            Text(
                text="Включено зон: %d из %d" % (n, len(_AREA_LABELS)),
                subtext=self._areas_summary_line(),
                icon="msg_info",
            ),
            Divider(),
            Header(text="В чате"),
            Switch(
                key="apply_action_bar",
                text="Шапка чата",
                subtext="Чат, диалоги, настройки",
                icon=_setting_icon("apply_action_bar"),
                default=True,
                on_change=on_change,
            ),
            Switch(
                key="apply_top_panels",
                text="Верхние панели",
                subtext="Плашки над чатом",
                icon=_setting_icon("apply_top_panels"),
                default=True,
                on_change=on_change,
            ),
            Switch(
                key="apply_search_bar",
                text="Поиск в чате",
                subtext="Строка и панель поиска",
                icon=_setting_icon("apply_search_bar"),
                default=True,
                on_change=on_change,
            ),
            Switch(
                key="apply_story_bar",
                text="Сторис и табы",
                subtext="Полоса над чатом",
                icon=_setting_icon("apply_story_bar"),
                default=True,
                on_change=on_change,
            ),
            Divider(),
            Header(text="Вне чата"),
            Switch(
                key="apply_dialogs_list",
                text="Список диалогов",
                subtext="Панель экрана чатов",
                icon=_setting_icon("apply_dialogs_list"),
                default=False,
                on_change=on_change,
            ),
            Switch(
                key="apply_topics_header",
                text="Список тем форума",
                subtext="Панель экрана тем",
                icon=_setting_icon("apply_topics_header"),
                default=False,
                on_change=on_change,
            ),
        ]

    def _create_appearance_settings(self):
        def on_change(_):
            self._schedule_settings_reapply(110)

        return [
            Header(text="Внешний вид"),
            Header(text="Прозрачность"),
            Input(
                key="action_bar_alpha",
                text="Прозрачность шапки",
                subtext="0.3 — 1.0",
