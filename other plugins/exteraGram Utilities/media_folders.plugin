JClass = jclass("java.lang.Class")
BAR_HEIGHT_DP = 44
PREFS_NAME = "media_folders_data"
GIF_FOLDERS_KEY = "gif_folders_json"
STICKER_FOLDERS_KEY = "sticker_folders_json"
EMOJI_FOLDERS_KEY = "emoji_folders_json"
GIF_TAB_ORDER_KEY = "gif_tab_order_json"
STICKER_TAB_ORDER_KEY = "sticker_tab_order_json"
EMOJI_TAB_ORDER_KEY = "emoji_tab_order_json"

_GIF_ACTIVE_FOLDER_CACHE = None
_STICKER_ACTIVE_FOLDER_CACHE = None
_EMOJI_ACTIVE_FOLDER_CACHE = None
_HIDE_TRENDING_CACHE = None
_GLASS_ENABLED_CACHE = None
_GLASS_ALPHA_CACHE = None
_GLASS_TABS_CACHE = None


def _parse_color(value):
    try:
        s = str(value).strip()
        if not s:
            return None
        if not s.startswith("#"):
            s = "#" + s
        if len(s) == 4:
            s = "#" + s[1] + s[1] + s[2] + s[2] + s[3] + s[3]
        return Color.parseColor(s)
    except Exception:
        return None


def _get_color_setting(key):
    prefs = _get_prefs()
    return str(prefs.getString(key, ""))


def _set_color_setting(key, value):
    prefs = _get_prefs()
    prefs.edit().putString(key, str(value).strip()).apply()


def _get_tab_bg_color():
    return _parse_color(_get_color_setting("tab_bg_color"))


def _get_tab_text_color():
    return _parse_color(_get_color_setting("tab_text_color"))


def _get_subtab_bg_color():
    return _parse_color(_get_color_setting("subtab_bg_color"))


def _get_subtab_text_color():
    return _parse_color(_get_color_setting("subtab_text_color"))


def _get_prefs():
    return ApplicationLoader.applicationContext.getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE)


def _load_folders(media_type):
    prefs = _get_prefs()
    if media_type == "gif":
        key = GIF_FOLDERS_KEY
    elif media_type == "sticker":
        key = STICKER_FOLDERS_KEY
    else:
        key = EMOJI_FOLDERS_KEY
    raw = prefs.getString(key, "[]")
    try:
        return json.loads(str(raw))
    except Exception:
        return []


def _save_folders(media_type, folders):
    prefs = _get_prefs()
    if media_type == "gif":
        key = GIF_FOLDERS_KEY
    elif media_type == "sticker":
        key = STICKER_FOLDERS_KEY
    else:
        key = EMOJI_FOLDERS_KEY
    prefs.edit().putString(key, json.dumps(folders, ensure_ascii=False)).commit()


def _load_tab_order(media_type):
    prefs = _get_prefs()
    if media_type == "gif":
        key = GIF_TAB_ORDER_KEY
    elif media_type == "sticker":
        key = STICKER_TAB_ORDER_KEY
    else:
        key = EMOJI_TAB_ORDER_KEY
    raw = prefs.getString(key, "null")
    try:
        order = json.loads(str(raw))
        if isinstance(order, list):
            return order
    except Exception:
        pass
    return None


def _save_tab_order(media_type, order):
    prefs = _get_prefs()
    if media_type == "gif":
        key = GIF_TAB_ORDER_KEY
    elif media_type == "sticker":
        key = STICKER_TAB_ORDER_KEY
    else:
        key = EMOJI_TAB_ORDER_KEY
    if order is None:
        prefs.edit().putString(key, "null").commit()
    else:
        prefs.edit().putString(key, json.dumps(order, ensure_ascii=False)).commit()


def _get_ordered_tabs(media_type):
    folders = _load_folders(media_type)
    folder_ids = [f.get("id") for f in folders]
    order = _load_tab_order(media_type)
    if order is None:
        return ["all"] + folder_ids
    valid_ids = set(["all"] + folder_ids)
    result = []
    for tab_id in order:
        if tab_id in valid_ids and tab_id not in result:
            result.append(tab_id)
    for tab_id in ["all"] + folder_ids:
        if tab_id not in result:
            result.append(tab_id)
    return result


def _get_active_folder_id(media_type):
    global _GIF_ACTIVE_FOLDER_CACHE, _STICKER_ACTIVE_FOLDER_CACHE, _EMOJI_ACTIVE_FOLDER_CACHE
    if media_type == "gif":
        if _GIF_ACTIVE_FOLDER_CACHE is None:
            prefs = _get_prefs()
            _GIF_ACTIVE_FOLDER_CACHE = str(prefs.getString("gif_active_folder", "all"))
        return _GIF_ACTIVE_FOLDER_CACHE
    elif media_type == "sticker":
        if _STICKER_ACTIVE_FOLDER_CACHE is None:
            prefs = _get_prefs()
            _STICKER_ACTIVE_FOLDER_CACHE = str(prefs.getString("sticker_active_folder", "all"))
        return _STICKER_ACTIVE_FOLDER_CACHE
    else:
        if _EMOJI_ACTIVE_FOLDER_CACHE is None:
            prefs = _get_prefs()
            _EMOJI_ACTIVE_FOLDER_CACHE = str(prefs.getString("emoji_active_folder", "all"))
        return _EMOJI_ACTIVE_FOLDER_CACHE


def _set_active_folder_id(media_type, folder_id):
    global _GIF_ACTIVE_FOLDER_CACHE, _STICKER_ACTIVE_FOLDER_CACHE, _EMOJI_ACTIVE_FOLDER_CACHE
    prefs = _get_prefs()
    if media_type == "gif":
        _GIF_ACTIVE_FOLDER_CACHE = str(folder_id)
        prefs.edit().putString("gif_active_folder", _GIF_ACTIVE_FOLDER_CACHE).commit()
    elif media_type == "sticker":
        _STICKER_ACTIVE_FOLDER_CACHE = str(folder_id)
        prefs.edit().putString("sticker_active_folder", _STICKER_ACTIVE_FOLDER_CACHE).commit()
    else:
        _EMOJI_ACTIVE_FOLDER_CACHE = str(folder_id)
        prefs.edit().putString("emoji_active_folder", _EMOJI_ACTIVE_FOLDER_CACHE).commit()


def _get_hide_trending():
    global _HIDE_TRENDING_CACHE
    if _HIDE_TRENDING_CACHE is None:
        prefs = _get_prefs()
        _HIDE_TRENDING_CACHE = bool(prefs.getBoolean("hide_trending", False))
    return _HIDE_TRENDING_CACHE


def _set_hide_trending(val):
    global _HIDE_TRENDING_CACHE
    _HIDE_TRENDING_CACHE = bool(val)
    prefs = _get_prefs()
    prefs.edit().putBoolean("hide_trending", _HIDE_TRENDING_CACHE).commit()


def _get_glass_enabled():
    global _GLASS_ENABLED_CACHE
    if _GLASS_ENABLED_CACHE is None:
        prefs = _get_prefs()
        _GLASS_ENABLED_CACHE = bool(prefs.getBoolean("glass_enabled", False))
    return _GLASS_ENABLED_CACHE


def _set_glass_enabled(val):
    global _GLASS_ENABLED_CACHE
    _GLASS_ENABLED_CACHE = bool(val)
    prefs = _get_prefs()
    prefs.edit().putBoolean("glass_enabled", _GLASS_ENABLED_CACHE).commit()


def _get_glass_alpha():
    global _GLASS_ALPHA_CACHE
    if _GLASS_ALPHA_CACHE is None:
        prefs = _get_prefs()
        _GLASS_ALPHA_CACHE = float(prefs.getFloat("glass_alpha", 0.75))
    return _GLASS_ALPHA_CACHE


def _set_glass_alpha(val):
    global _GLASS_ALPHA_CACHE
    try:
        v = float(val)
        v = max(0.1, min(1.0, v))
    except Exception:
        v = 0.75
    _GLASS_ALPHA_CACHE = v
    prefs = _get_prefs()
    prefs.edit().putFloat("glass_alpha", float(v)).commit()


def _get_glass_tabs():
