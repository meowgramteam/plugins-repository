def _get_activity():
    frag = get_last_fragment()
    if frag is None:
        return None
    return frag.getParentActivity()


def _get_self_user_id():
    try:
        return int(UserConfig.getInstance(UserConfig.selectedAccount).getClientUserId())
    except Exception:
        return 0


def _hook_methods_by_name(plugin, java_class, method_name, hook):
    for m in java_class.getDeclaredMethods():
        if str(m.getName()) == method_name:
            try:
                m.setAccessible(True)
                plugin.hook_method(m, hook)
            except Exception:
                pass


def _get_item_id(g):
    if isinstance(g, dict):
        return str(g.get("id", ""))
    return str(g)


def _get_folder_by_id(media_type, folder_id):
    for folder in _load_folders(media_type):
        if folder.get("id") == folder_id:
            return folder
    return None


def _get_all_tab_name(media_type):
    prefs = _get_prefs()
    default = {"gif": "All GIFs", "sticker": "All Stickers", "emoji": "All Emoji"}.get(media_type, "All")
    return str(prefs.getString("all_tab_name_%s" % media_type, default))


def _set_all_tab_name(media_type, name):
    prefs = _get_prefs()
    prefs.edit().putString("all_tab_name_%s" % media_type, str(name)).commit()


def _get_all_tab_hidden(media_type):
