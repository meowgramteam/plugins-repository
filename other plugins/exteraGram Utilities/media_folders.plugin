def _set_all_tab_hidden(media_type, val):
    prefs = _get_prefs()
    prefs.edit().putBoolean("all_tab_hidden_%s" % media_type, bool(val)).commit()


def _get_installed_packs(media_type):
    result = []
    controller = MediaDataController.getInstance(UserConfig.selectedAccount)
    try:
        if media_type == "sticker":
            sets = controller.getStickerSets(MediaDataController.TYPE_IMAGE)
        else:
            sets = controller.getStickerSets(MediaDataController.TYPE_EMOJIPACKS)
        if sets is not None:
            for i in range(sets.size()):
                try:
                    pack = sets.get(i)
                    if pack.set is not None:
                        result.append({"id": str(pack.set.id), "name": str(pack.set.title), "count": int(pack.set.count)})
                except Exception:
                    pass
    except Exception:
        pass
    return result


def _get_pack_documents(media_type, pack_id_str):
    controller = MediaDataController.getInstance(UserConfig.selectedAccount)
    try:
        if media_type == "sticker":
            sets = controller.getStickerSets(MediaDataController.TYPE_IMAGE)
        else:
            sets = controller.getStickerSets(MediaDataController.TYPE_EMOJIPACKS)
        if sets is not None:
            for i in range(sets.size()):
                try:
                    pack = sets.get(i)
                    if str(pack.set.id) == pack_id_str:
                        docs = []
                        if pack.documents is not None:
                            for j in range(pack.documents.size()):
                                docs.append(pack.documents.get(j))
                        return docs
                except Exception:
                    pass
    except Exception:
        pass
    return []


def _safe_color_state_list(color):
    try:
        if color == 0:
            color = Color.argb(30, 128, 128, 128)
        states = jarray(jarray(jint))([jarray(jint)([])])
        colors = jarray(jint)([color])
        return ColorStateList(states, colors)
    except Exception:
        return ColorStateList.valueOf(Color.argb(30, 128, 128, 128))


def _create_ripple_drawable(base_color, radius_dp):
    mask = GradientDrawable()
    mask.setShape(GradientDrawable.RECTANGLE)
    mask.setCornerRadius(float(AndroidUtilities.dp(radius_dp)))
    mask.setColor(Color.WHITE)
    try:
        ripple_color = Theme.getColor(Theme.key_listSelector)
        if ripple_color == 0:
            ripple_color = Color.argb(30, 128, 128, 128)
        csl = _safe_color_state_list(ripple_color)
        return RippleDrawable(csl, None, mask)
    except Exception:
        csl = _safe_color_state_list(Color.argb(30, 128, 128, 128))
        return RippleDrawable(csl, None, mask)


def _nuke_trending_from_adapter(adapter):
    if adapter is None:
        return
    try:
        set_private_field(adapter, "showTrendingWhenSearching", jboolean(False))
    except Exception:
        pass
    try:
        set_private_field(adapter, "trendingSectionItem", jint(-1))
    except Exception:
        pass
    try:
        results = get_private_field(adapter, "results")
        if results is not None and results.size() > 0:
            results.clear()
    except Exception:
        pass
    try:
        set_private_field(adapter, "nextSearchOffset", None)
    except Exception:
        pass
    try:
        set_private_field(adapter, "searchingUser", jboolean(False))
    except Exception:
        pass
    try:
        set_private_field(adapter, "lastSearchIsEmoji", jboolean(False))
    except Exception:
        pass


def _sync_adapter_counts(emoji_view, adapter):
    if adapter is None or emoji_view is None:
        return
    try:
        recent = get_private_field(emoji_view, "recentGifs")
        count = 0
        if recent is not None:
            count = recent.size()
        set_private_field(adapter, "recentItemsCount", jint(count))
    except Exception:
        pass


def _apply_trending_visibility():
    hide = _get_hide_trending()
    for manager in GifFolderBarManager._instances.values():
        try:
            gif_tabs = get_private_field(manager.emoji_view, "gifTabs")
            if gif_tabs is not None:
                bar_height = AndroidUtilities.dp(BAR_HEIGHT_DP)
                if hide:
                    gif_tabs.setVisibility(View.GONE)
                else:
                    gif_tabs.setVisibility(View.VISIBLE)
                    gif_tabs.setTranslationY(float(bar_height))
        except Exception:
            pass


def _create_glass_bar_drawable(alpha_val=0.75):
    is_dark = Theme.isCurrentThemeDark()
    bg_color = Theme.getColor(Theme.key_chat_emojiPanelBackground)
    r = (bg_color >> 16) & 0xFF
    g = (bg_color >> 8) & 0xFF
    b = bg_color & 0xFF
    a = int(alpha_val * 255)
    fill = GradientDrawable()
    fill.setShape(GradientDrawable.RECTANGLE)
    fill.setColor(Color.argb(a, r, g, b))
    if is_dark:
        stroke_color = Color.argb(40, 255, 255, 255)
    else:
        stroke_color = Color.argb(30, 0, 0, 0)
    fill.setStroke(AndroidUtilities.dp(0.5), stroke_color)
    if is_dark:
        hl_color = Color.argb(15, 255, 255, 255)
    else:
        hl_color = Color.argb(20, 255, 255, 255)
    highlight = GradientDrawable()
    highlight.setShape(GradientDrawable.RECTANGLE)
    highlight.setColor(hl_color)
    Drawable = jclass("android.graphics.drawable.Drawable")
    layers = LayerDrawable(jarray(Drawable)([fill, highlight]))
    layers.setLayerInset(1, 0, 0, 0, AndroidUtilities.dp(43))
    return layers


def _create_glass_tab_drawable(is_selected=False, alpha_val=0.75, corner_radius_dp=10):
    is_dark = Theme.isCurrentThemeDark()
    radius = float(AndroidUtilities.dp(corner_radius_dp))
    bg = GradientDrawable()
    bg.setShape(GradientDrawable.RECTANGLE)
    bg.setCornerRadius(radius)
    if is_selected:
        accent = Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine)
        r = (accent >> 16) & 0xFF
        g = (accent >> 8) & 0xFF
        b = accent & 0xFF
        a = int(alpha_val * 255)
        bg.setColor(Color.argb(a, r, g, b))
        if is_dark:
            stroke_color = Color.argb(60, 255, 255, 255)
        else:
            stroke_color = Color.argb(40, 0, 0, 0)
        bg.setStroke(AndroidUtilities.dp(0.5), stroke_color)
    else:
        if is_dark:
            bg.setColor(Color.argb(int(35 * alpha_val), 255, 255, 255))
            bg.setStroke(AndroidUtilities.dp(0.5), Color.argb(30, 255, 255, 255))
        else:
            bg.setColor(Color.argb(int(25 * alpha_val), 0, 0, 0))
            bg.setStroke(AndroidUtilities.dp(0.5), Color.argb(20, 0, 0, 0))
    return bg


class BaseFolderBarManager:
    _instances = {}

    def __init__(self, emoji_view, media_type):
        self.emoji_view = emoji_view
        self.media_type = media_type
        self.folder_bar = None
        self.tabs_container = None
        self.active_folder_id = _get_active_folder_id(media_type)
        self.tab_views = {}
        self.plugin_ref = None
        self.container = None
        self.empty_overlay = None
        self._grid_translated = False
        self._scroll_view = None

    def set_plugin(self, plugin):
        self.plugin_ref = plugin

    def _get_media_label(self):
        if self.media_type == "gif":
            return "GIF"
        elif self.media_type == "sticker":
            return "Sticker"
        else:
            return "Emoji"

    def _get_media_label_plural(self):
        if self.media_type == "gif":
            return "GIFs"
        elif self.media_type == "sticker":
            return "Stickers"
        else:
            return "Emoji"

    def _get_empty_icon(self):
        if self.media_type == "gif":
            return "\U0001F4C2"
        elif self.media_type == "sticker":
            return "\U0001F3AD"
        else:
            return "\U0001F600"

    def _create_empty_overlay(self, context):
        overlay = FrameLayout(context)
        overlay.setBackgroundColor(Theme.getColor(Theme.key_chat_emojiPanelBackground))
        overlay.setClickable(True)
        container = LinearLayout(context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setGravity(Gravity.CENTER)
        icon_tv = TextView(context)
        icon_tv.setText(self._get_empty_icon())
        icon_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 48)
        icon_tv.setGravity(Gravity.CENTER)
        container.addView(icon_tv, LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        label = TextView(context)
        label.setText("No %s in this folder" % self._get_media_label_plural())
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        label.setGravity(Gravity.CENTER)
        lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(12)
        container.addView(label, lp)
        hint = TextView(context)
        hint.setText("Long press a %s to add it here" % self._get_media_label().lower())
        hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
        hint.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        hint.setAlpha(0.6)
        hint.setGravity(Gravity.CENTER)
        hlp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        hlp.topMargin = AndroidUtilities.dp(4)
        container.addView(hint, hlp)
        overlay.addView(container, FrameLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT, Gravity.CENTER))
        return overlay

    def _create_folder_bar(self, context):
        outer = FrameLayout(context)
        glass_on = _get_glass_enabled()
        if glass_on:
            glass_alpha = _get_glass_alpha()
            glass_bg = _create_glass_bar_drawable(alpha_val=glass_alpha)
            outer.setBackground(glass_bg)
        else:
            outer.setBackgroundColor(Theme.getColor(Theme.key_chat_emojiPanelBackground))
        scroll = HorizontalScrollView(context)
        scroll.setHorizontalScrollBarEnabled(False)
        scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
        self.tabs_container = LinearLayout(context)
        self.tabs_container.setOrientation(LinearLayout.HORIZONTAL)
        self.tabs_container.setGravity(Gravity.CENTER_VERTICAL)
        pad_h = AndroidUtilities.dp(6)
        pad_v = AndroidUtilities.dp(6)
        self.tabs_container.setPadding(pad_h, pad_v, pad_h, pad_v)
        scroll.addView(self.tabs_container, FrameLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.MATCH_PARENT))
        self._scroll_view = scroll
        outer.addView(scroll, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))
        separator = View(context)
        if not glass_on:
            separator.setBackgroundColor(Theme.getColor(Theme.key_divider))
        else:
            is_dark = Theme.isCurrentThemeDark()
            if is_dark:
                separator.setBackgroundColor(Color.argb(40, 255, 255, 255))
            else:
                separator.setBackgroundColor(Color.argb(25, 0, 0, 0))
        sep_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(0.5))
        sep_lp.gravity = Gravity.BOTTOM
        outer.addView(separator, sep_lp)
        return outer

    def _rebuild_tabs(self):
        if self.tabs_container is None:
            return
        self.tabs_container.removeAllViews()
        self.tab_views.clear()
        context = self.tabs_container.getContext()
        self.tabs_container.addView(self._create_settings_button(context))
        self.tabs_container.addView(self._create_add_button(context))
        folders = _load_folders(self.media_type)
        folder_map = {f.get("id"): f.get("name", "Folder") for f in folders}
        ordered_tabs = _get_ordered_tabs(self.media_type)
        all_hidden = _get_all_tab_hidden(self.media_type)
        for tab_id in ordered_tabs:
            if tab_id == "all":
                if all_hidden:
                    continue
                all_name = _get_all_tab_name(self.media_type)
                tab = self._create_tab(context, "all", all_name)
            elif tab_id in folder_map:
                tab = self._create_tab(context, tab_id, folder_map[tab_id])
            else:
                continue
            self.tabs_container.addView(tab)
            self.tab_views[tab_id] = tab
        self._update_selection()

    def _create_settings_button(self, context):
        btn = FrameLayout(context)
        size = AndroidUtilities.dp(32)
        params = LinearLayout.LayoutParams(size, size)
        params.setMargins(AndroidUtilities.dp(2), 0, AndroidUtilities.dp(2), 0)
        btn.setLayoutParams(params)
        glass_on = _get_glass_enabled() and _get_glass_tabs()
        if glass_on:
            glass_alpha = _get_glass_alpha()
            glass_drawable = _create_glass_tab_drawable(is_selected=True, alpha_val=glass_alpha, corner_radius_dp=10)
            btn.setBackground(glass_drawable)
        else:
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setCornerRadius(float(AndroidUtilities.dp(10)))
            accent = _get_tab_bg_color()
            if accent is None:
                accent = Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine)
            bg.setColor(accent)
            btn.setBackground(bg)
        btn.setForeground(_create_ripple_drawable(0, 10))
        icon = ImageView(context)
        icon.setImageResource(R.drawable.msg_settings)
        icon_color = _get_tab_text_color()
        if icon_color is None:
            icon_color = -1
        icon.setColorFilter(icon_color, PorterDuff.Mode.SRC_ATOP)
        icon.setScaleType(ImageView.ScaleType.CENTER)
        btn.addView(icon, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        btn.setOnClickListener(OnClickListener(lambda v: manager._open_settings()))
        return btn

    def _open_settings(self):
        if self.plugin_ref is not None:
            self.plugin_ref._open_plugin_settings()

    def _create_add_button(self, context):
        btn = FrameLayout(context)
        size = AndroidUtilities.dp(32)
        params = LinearLayout.LayoutParams(size, size)
        params.setMargins(AndroidUtilities.dp(2), 0, AndroidUtilities.dp(4), 0)
        btn.setLayoutParams(params)
        glass_on = _get_glass_enabled() and _get_glass_tabs()
        if glass_on:
            glass_alpha = _get_glass_alpha()
            glass_drawable = _create_glass_tab_drawable(is_selected=True, alpha_val=glass_alpha, corner_radius_dp=10)
            btn.setBackground(glass_drawable)
        else:
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setCornerRadius(float(AndroidUtilities.dp(10)))
            accent = _get_tab_bg_color()
            if accent is None:
                accent = Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine)
            bg.setColor(accent)
            btn.setBackground(bg)
        btn.setForeground(_create_ripple_drawable(0, 10))
        icon = ImageView(context)
        icon.setImageResource(R.drawable.msg_add)
        icon_color = _get_tab_text_color()
        if icon_color is None:
            icon_color = -1
        icon.setColorFilter(PorterDuffColorFilter(icon_color, PorterDuff.Mode.SRC_IN))
        icon.setScaleType(ImageView.ScaleType.CENTER)
        btn.addView(icon, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        btn.setOnClickListener(OnClickListener(lambda v: manager._show_create_folder_dialog()))
        return btn

    def _create_tab(self, context, folder_id, name):
        tab = FrameLayout(context)
        h = AndroidUtilities.dp(32)
        params = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, h)
        params.setMargins(AndroidUtilities.dp(3), 0, AndroidUtilities.dp(3), 0)
        tab.setLayoutParams(params)
        pad_h = AndroidUtilities.dp(14)
        tab.setPadding(pad_h, 0, pad_h, 0)
        glass_on = _get_glass_enabled() and _get_glass_tabs()
        if glass_on:
            glass_alpha = _get_glass_alpha()
            is_sel = (folder_id == self.active_folder_id)
            glass_drawable = _create_glass_tab_drawable(is_selected=is_sel, alpha_val=glass_alpha, corner_radius_dp=10)
            tab.setBackground(glass_drawable)
        else:
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setCornerRadius(float(AndroidUtilities.dp(10)))
            tab.setBackground(bg)
        tab.setForeground(_create_ripple_drawable(0, 10))
        label = TextView(context)
        label.setText(name)
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
        label.setGravity(Gravity.CENTER)
        label.setSingleLine(True)
        label.setEllipsize(TextUtils.TruncateAt.END)
        label.setTypeface(Typeface.DEFAULT_BOLD)
        tab.addView(label, FrameLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        tab.setOnClickListener(OnClickListener(lambda v: manager._on_folder_selected(folder_id)))
        def on_long(v, fid=folder_id, fname=name):
            manager._show_tab_context_menu(fid, fname)
            return True
        tab.setOnLongClickListener(OnLongClickListener(on_long))
        tab.setTag(folder_id)
        return tab

    def _show_tab_context_menu(self, folder_id, folder_name):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        order = _get_ordered_tabs(self.media_type)
        idx = -1
        for i, tid in enumerate(order):
            if tid == folder_id:
                idx = i
                break
        items = []
        item_actions = []
        if idx > 0:
            items.append("\u2B06\uFE0F  Move left")
            item_actions.append("up")
        if idx >= 0 and idx < len(order) - 1:
            items.append("\u2B07\uFE0F  Move right")
            item_actions.append("down")
        items.append("\u270F\uFE0F  Rename")
        item_actions.append("rename")
        if folder_id == "all":
            is_hidden = _get_all_tab_hidden(self.media_type)
            if not is_hidden:
                items.append("\U0001F6AB  Hide")
                item_actions.append("hide")
        else:
            items.append("\U0001F5D1  Delete")
            item_actions.append("delete")
        def on_item(bld, which):
            bld.dismiss()
            action = item_actions[which]
            if action == "up" or action == "down":
                direction = -1 if action == "up" else 1
                o = _get_ordered_tabs(manager.media_type)
                i = -1
                for x, t in enumerate(o):
                    if t == folder_id:
                        i = x
                        break
                if i >= 0:
                    ni = i + direction
                    if 0 <= ni < len(o):
                        o[i], o[ni] = o[ni], o[i]
                        _save_tab_order(manager.media_type, o)
                        manager._rebuild_tabs()
                        manager._apply_folder_filter()
            elif action == "rename":
                if folder_id == "all":
                    if manager.plugin_ref:
                        manager.plugin_ref._show_rename_all_dialog(manager.media_type, folder_name)
                else:
                    if manager.plugin_ref:
                        manager.plugin_ref._show_rename_folder_dialog(manager.media_type, folder_id, folder_name)
            elif action == "hide":
                _set_all_tab_hidden(manager.media_type, True)
                manager._rebuild_tabs()
                manager._apply_folder_filter()
            elif action == "delete":
                if manager.plugin_ref:
                    manager.plugin_ref._confirm_delete_folder(manager.media_type, folder_id, folder_name)
        builder = AlertDialogBuilder(activity)
        builder.set_title(folder_name)
        builder.set_items(items, on_item)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _update_selection(self):
        accent = Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine)
        custom_bg = _get_tab_bg_color()
        custom_text = _get_tab_text_color()
        glass_on = _get_glass_enabled() and _get_glass_tabs()
        for fid, tab in self.tab_views.items():
            label = tab.getChildAt(0)
            if glass_on:
                glass_alpha = _get_glass_alpha()
                new_bg = _create_glass_tab_drawable(is_selected=(fid == self.active_folder_id), alpha_val=glass_alpha, corner_radius_dp=10)
                tab.setBackground(new_bg)
                if custom_text is not None:
                    label.setTextColor(custom_text)
                elif fid == self.active_folder_id:
                    label.setTextColor(-1)
                else:
                    label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelIcon))
            else:
                bg = tab.getBackground()
                if custom_bg is not None:
                    bg.setColor(custom_bg)
                else:
                    if fid == self.active_folder_id:
                        bg.setColor(accent)
                    else:
                        bg.setColor(Color.TRANSPARENT)
                if custom_text is not None:
                    label.setTextColor(custom_text)
                elif fid == self.active_folder_id:
                    label.setTextColor(-1)
                else:
                    label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelIcon))

    def _on_folder_selected(self, folder_id):
        self.active_folder_id = folder_id
        _set_active_folder_id(self.media_type, folder_id)
        self._update_selection()
        self._apply_folder_filter()

    def _show_create_folder_dialog(self):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        from android.view import WindowManager as WM
        edit_text = EditText(activity)
        edit_text.setHint("Folder name")
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        builder = AlertDialogBuilder(activity)
        builder.set_title("New %s Folder" % manager._get_media_label())
        builder.set_view(container)
        builder.set_positive_button("Create", lambda bld, w: (manager._create_folder(str(edit_text.getText()).strip()), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        dialog = builder.show()
        try:
            window = dialog.getWindow()
            if window is not None:
                window.setSoftInputMode(WM.LayoutParams.SOFT_INPUT_STATE_VISIBLE | WM.LayoutParams.SOFT_INPUT_ADJUST_PAN)
            edit_text.requestFocus()
        except Exception:
            pass

    def _create_folder(self, name):
        if not name:
            return
        folders = _load_folders(self.media_type)
        folder_id = f"{self.media_type}_folder_{int(time.time() * 1000)}"
        folders.append({"id": folder_id, "name": name, "items": []})
        _save_folders(self.media_type, folders)
        order = _get_ordered_tabs(self.media_type)
        order.append(folder_id)
        _save_tab_order(self.media_type, order)
        run_on_ui_thread(lambda: (self._rebuild_tabs(), self._apply_folder_filter()))
        BulletinHelper.show_success('Folder "%s" created' % name)

    def _apply_folder_filter(self):
        pass

    def remove_folder_bar(self):
        pass


class GifFolderBarManager(BaseFolderBarManager):
    _instances = {}

    @classmethod
    def get_or_create(cls, emoji_view):
        obj_id = id(emoji_view)
        if obj_id not in cls._instances:
            cls._instances[obj_id] = GifFolderBarManager(emoji_view)
        return cls._instances[obj_id]

    def __init__(self, emoji_view):
        super().__init__(emoji_view, "gif")

    def inject_folder_bar(self):
        try:
            gif_container = get_private_field(self.emoji_view, "gifContainer")
            if gif_container is None:
                return
            self.container = gif_container
            existing = gif_container.findViewWithTag("media_folders_gif_bar")
            if existing is not None:
                gif_container.removeView(existing)
            existing_overlay = gif_container.findViewWithTag("media_folders_gif_empty")
            if existing_overlay is not None:
                gif_container.removeView(existing_overlay)
            self._reset_offsets()
            bar_height = AndroidUtilities.dp(BAR_HEIGHT_DP)
            context = gif_container.getContext()
            self.folder_bar = self._create_folder_bar(context)
            self.folder_bar.setTag("media_folders_gif_bar")
            bar_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, bar_height)
            bar_lp.gravity = Gravity.TOP | Gravity.LEFT
            gif_container.addView(self.folder_bar, bar_lp)
            self.folder_bar.bringToFront()
            self.empty_overlay = self._create_empty_overlay(context)
            self.empty_overlay.setTag("media_folders_gif_empty")
            self.empty_overlay.setVisibility(View.GONE)
            overlay_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT)
            overlay_lp.topMargin = bar_height
            gif_container.addView(self.empty_overlay, overlay_lp)
            gif_grid = get_private_field(self.emoji_view, "gifGridView")
            if gif_grid is not None:
                lp = gif_grid.getLayoutParams()
                if lp is not None:
                    lp.topMargin = bar_height
                    gif_grid.setLayoutParams(lp)
                    self._grid_translated = True
            gif_tabs = get_private_field(self.emoji_view, "gifTabs")
            if gif_tabs is not None:
                if _get_hide_trending():
                    gif_tabs.setVisibility(View.GONE)
                else:
                    gif_tabs.setTranslationY(float(bar_height))
            gif_search = get_private_field(self.emoji_view, "gifSearchField")
            if gif_search is not None:
                try:
                    sf_lp = gif_search.getLayoutParams()
                    if sf_lp is not None:
                        sf_lp.topMargin = bar_height
                        gif_search.setLayoutParams(sf_lp)
                except Exception:
                    pass
            if self.plugin_ref is not None:
                try:
                    delegate = get_private_field(self.emoji_view, "delegate")
                    if delegate is not None:
                        self.plugin_ref._ensure_gif_delegate_hook(delegate)
                except Exception:
                    pass
                try:
                    gif_adapter = get_private_field(self.emoji_view, "gifAdapter")
                    if gif_adapter is not None:
                        self.plugin_ref._ensure_gif_adapter_hook(gif_adapter, self.emoji_view)
                        if _get_hide_trending():
                            self.plugin_ref._clear_trending_results(gif_adapter, self.emoji_view)
                except Exception:
                    pass
            self._rebuild_tabs()
            self._apply_folder_filter()
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("inject gif folder bar error: %s" % e)

    def _reset_offsets(self):
        gif_grid = get_private_field(self.emoji_view, "gifGridView")
        if gif_grid is not None and self._grid_translated:
            lp = gif_grid.getLayoutParams()
            if lp is not None:
                lp.topMargin = 0
                gif_grid.setLayoutParams(lp)
            self._grid_translated = False
        gif_tabs = get_private_field(self.emoji_view, "gifTabs")
        if gif_tabs is not None:
            try:
                gif_tabs.setVisibility(View.VISIBLE)
                gif_tabs.setTranslationY(0)
            except Exception:
                pass
        gif_search = get_private_field(self.emoji_view, "gifSearchField")
        if gif_search is not None:
            try:
                sf_lp = gif_search.getLayoutParams()
                if sf_lp is not None:
                    sf_lp.topMargin = 0
                    gif_search.setLayoutParams(sf_lp)
            except Exception:
                pass

    def _apply_folder_filter(self):
        try:
            gif_grid = get_private_field(self.emoji_view, "gifGridView")
            if gif_grid is None:
                return
            gif_adapter = get_private_field(self.emoji_view, "gifAdapter")
            if gif_adapter is None:
                return
            controller = MediaDataController.getInstance(UserConfig.selectedAccount)
            source_gifs = controller.getRecentGifs()
            if source_gifs is None:
                source_gifs = JavaArrayList()
            active = self.active_folder_id
            empty_overlay = self.empty_overlay
            if active == "all":
                filtered = JavaArrayList()
                filtered.addAll(source_gifs)
            else:
                folder_data = None
                for f in _load_folders("gif"):
                    if f.get("id") == active:
                        folder_data = f
                        break
                folder_items = folder_data.get("items", []) if folder_data else []
                source_map = {}
                for i in range(source_gifs.size()):
                    try:
                        doc = source_gifs.get(i)
                        source_map[str(doc.id)] = doc
                    except Exception:
                        pass
                filtered = JavaArrayList()
                added_ids = set()
                for g in folder_items:
                    gid = _get_item_id(g)
                    if gid in added_ids:
                        continue
                    if gid in source_map:
                        filtered.add(source_map[gid])
                        added_ids.add(gid)
                if filtered.size() > 0:
                    try:
                        filtered.add(filtered.get(filtered.size() - 1))
                    except Exception:
                        pass
            is_empty = active != "all" and filtered.isEmpty()
            retries = [0]
            def do_update():
                try:
                    if retries[0] > 20:
                        return
                    try:
                        if gif_grid.isComputingLayout() or gif_grid.getScrollState() != 0:
                            retries[0] += 1
                            run_on_ui_thread(do_update, 16)
                            return
                    except Exception:
                        pass
                    current_list = get_private_field(self.emoji_view, "recentGifs")
                    if current_list is not None:
                        current_list.clear()
                        current_list.addAll(filtered)
                    else:
                        set_private_field(self.emoji_view, "recentGifs", filtered)
                    if active != "all" or _get_hide_trending():
                        try:
                            set_private_field(gif_adapter, "trendingSectionItem", jint(-1))
                        except Exception:
                            pass
                        try:
                            set_private_field(gif_adapter, "showTrendingWhenSearching", jboolean(False))
                        except Exception:
                            pass
                        try:
                            results = get_private_field(gif_adapter, "results")
                            if results is not None:
                                results.clear()
                        except Exception:
                            pass
                    else:
                        try:
                            set_private_field(gif_adapter, "showTrendingWhenSearching", jboolean(True))
                        except Exception:
                            pass
                    _sync_adapter_counts(self.emoji_view, gif_adapter)
                    gif_adapter.notifyDataSetChanged()
                    if is_empty:
                        gif_grid.setVisibility(View.INVISIBLE)
                        if empty_overlay:
                            empty_overlay.setVisibility(View.VISIBLE)
                    else:
                        gif_grid.setVisibility(View.VISIBLE)
                        if empty_overlay:
                            empty_overlay.setVisibility(View.GONE)
                except Exception:
                    retries[0] += 1
                    if retries[0] <= 20:
                        run_on_ui_thread(do_update, 32)
            run_on_ui_thread(do_update)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("gif apply_folder_filter error: %s" % e)

    def remove_folder_bar(self):
        try:
            if self.container is not None and self.folder_bar is not None:
                self.container.removeView(self.folder_bar)
                self.folder_bar = None
            if self.container is not None and self.empty_overlay is not None:
                self.container.removeView(self.empty_overlay)
                self.empty_overlay = None
            self._reset_offsets()
            gif_grid = get_private_field(self.emoji_view, "gifGridView")
            if gif_grid is not None:
                gif_grid.setVisibility(View.VISIBLE)
            controller = MediaDataController.getInstance(UserConfig.selectedAccount)
            fresh = controller.getRecentGifs()
            gif_adapter = get_private_field(self.emoji_view, "gifAdapter")
            emoji_view = self.emoji_view
            if fresh is not None and gif_adapter is not None:
                def do_restore():
                    try:
                        current_list = get_private_field(emoji_view, "recentGifs")
                        if current_list is not None:
                            current_list.clear()
                            current_list.addAll(fresh)
                        else:
                            set_private_field(emoji_view, "recentGifs", fresh)
                        gif_adapter.notifyDataSetChanged()
                    except Exception:
                        pass
                run_on_ui_thread(do_restore)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("gif remove_folder_bar error: %s" % e)


class StickerFolderBarManager(BaseFolderBarManager):
    _instances = {}

    @classmethod
    def get_or_create(cls, emoji_view):
        obj_id = id(emoji_view)
        if obj_id not in cls._instances:
            cls._instances[obj_id] = StickerFolderBarManager(emoji_view)
        return cls._instances[obj_id]

    def __init__(self, emoji_view):
        super().__init__(emoji_view, "sticker")
        self.custom_grid = None
        self.custom_scroll = None
        self.sub_tabs_container = None
        self.custom_outer = None
        self._sticker_map_cache = None
        self._active_sub_tab = "custom"

    def inject_folder_bar(self):
        try:
            stickers_container = get_private_field(self.emoji_view, "stickersContainer")
            if stickers_container is None:
                return
            self.container = stickers_container
            existing = stickers_container.findViewWithTag("media_folders_sticker_bar")
            if existing is not None:
                stickers_container.removeView(existing)
            existing_content = stickers_container.findViewWithTag("media_folders_sticker_content")
            if existing_content is not None:
                stickers_container.removeView(existing_content)
            self._reset_offsets()
            bar_height = AndroidUtilities.dp(BAR_HEIGHT_DP)
            tabs_height = AndroidUtilities.dp(48)
            stickers_tab = get_private_field(self.emoji_view, "stickersTab")
            if stickers_tab is not None:
                try:
                    measured = stickers_tab.getMeasuredHeight()
                    if measured > 0:
                        tabs_height = measured
                except Exception:
                    pass
            context = stickers_container.getContext()
            self.folder_bar = self._create_folder_bar(context)
            self.folder_bar.setTag("media_folders_sticker_bar")
            bar_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, bar_height)
            bar_lp.gravity = Gravity.TOP | Gravity.LEFT
            bar_lp.topMargin = tabs_height
            stickers_container.addView(self.folder_bar, bar_lp)
            self.folder_bar.bringToFront()
            self.custom_scroll = self._create_custom_content(context)
            self.custom_scroll.setTag("media_folders_sticker_content")
            self.custom_scroll.setVisibility(View.GONE)
            content_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT)
            content_lp.topMargin = tabs_height + bar_height
            stickers_container.addView(self.custom_scroll, content_lp)
            stickers_grid = get_private_field(self.emoji_view, "stickersGridView")
            if stickers_grid is not None:
                lp = stickers_grid.getLayoutParams()
                if lp is not None:
                    self._original_grid_margin = lp.topMargin
                    lp.topMargin = lp.topMargin + bar_height
                    stickers_grid.setLayoutParams(lp)
                    self._grid_translated = True
            stickers_search = get_private_field(self.emoji_view, "stickersSearchField")
            if stickers_search is not None:
                try:
                    sf_lp = stickers_search.getLayoutParams()
                    if sf_lp is not None:
                        self._original_search_margin = sf_lp.topMargin
                        sf_lp.topMargin = sf_lp.topMargin + bar_height
                        stickers_search.setLayoutParams(sf_lp)
                except Exception:
                    pass
            self.folder_bar.bringToFront()
            self._rebuild_tabs()
            self._apply_folder_filter()
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("inject sticker folder bar error: %s" % e)

    def _create_custom_content(self, context):
        self.custom_outer = LinearLayout(context)
        self.custom_outer.setOrientation(LinearLayout.VERTICAL)
        self.custom_outer.setBackgroundColor(Theme.getColor(Theme.key_chat_emojiPanelBackground))
        sub_scroll = HorizontalScrollView(context)
        sub_scroll.setHorizontalScrollBarEnabled(False)
        sub_scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
        self.sub_tabs_container = LinearLayout(context)
        self.sub_tabs_container.setOrientation(LinearLayout.HORIZONTAL)
        self.sub_tabs_container.setGravity(Gravity.CENTER_VERTICAL)
        p = AndroidUtilities.dp(4)
        self.sub_tabs_container.setPadding(p, p, p, p)
        sub_scroll.addView(self.sub_tabs_container, LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        sub_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(36))
        self.custom_outer.addView(sub_scroll, sub_lp)
        scroll = ScrollView(context)
        scroll.setFillViewport(True)
        self.custom_grid = LinearLayout(context)
        self.custom_grid.setOrientation(LinearLayout.VERTICAL)
        self.custom_grid.setGravity(Gravity.TOP | Gravity.CENTER_HORIZONTAL)
        pad = AndroidUtilities.dp(8)
        self.custom_grid.setPadding(pad, pad, pad, pad)
        scroll.addView(self.custom_grid, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        grid_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 0, 1.0)
        self.custom_outer.addView(scroll, grid_lp)
        return self.custom_outer

    def _build_sub_tabs(self, folder_data):
        if self.sub_tabs_container is None:
            return
        self.sub_tabs_container.removeAllViews()
        context = self.sub_tabs_container.getContext()
        packs = folder_data.get("packs", [])
        self.sub_tabs_container.setVisibility(View.VISIBLE)
        self.sub_tabs_container.addView(self._create_add_pack_button(context))
        self.sub_tabs_container.addView(self._create_sub_tab(context, "custom", "Added"))
        for p in packs:
            self.sub_tabs_container.addView(self._create_sub_tab(context, p.get("id", ""), p.get("name", "Pack")))

    def _create_add_pack_button(self, context):
        btn = FrameLayout(context)
        size = AndroidUtilities.dp(28)
        params = LinearLayout.LayoutParams(size, size)
        params.setMargins(AndroidUtilities.dp(3), 0, AndroidUtilities.dp(3), 0)
        btn.setLayoutParams(params)
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(8)))
        bg.setColor(Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine))
        btn.setBackground(bg)
        btn.setForeground(_create_ripple_drawable(0, 8))
        icon = ImageView(context)
        icon.setImageResource(R.drawable.msg_add)
        icon.setColorFilter(-1, PorterDuff.Mode.SRC_ATOP)
        icon.setScaleType(ImageView.ScaleType.CENTER)
        btn.addView(icon, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        btn.setOnClickListener(OnClickListener(lambda v: manager._show_add_pack_dialog()))
        return btn

    def _show_add_pack_dialog(self):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        installed = _get_installed_packs("sticker")
        if not installed:
            BulletinHelper.show_error("No sticker packs installed")
            return
        folder_data = _get_folder_by_id("sticker", folder_id)
        existing_ids = set(p.get("id") for p in (folder_data.get("packs", []) if folder_data else []))
        names = []
        for p in installed:
            if p["id"] in existing_ids:
                names.append("\u2705  %s (%d)" % (p["name"], p["count"]))
            else:
                names.append("\u2B1C  %s (%d)" % (p["name"], p["count"]))
        def on_select(bld, which):
            bld.dismiss()
            pack = installed[which]
            folders = _load_folders("sticker")
            for f in folders:
                if f.get("id") == folder_id:
                    if "packs" not in f:
                        f["packs"] = []
                    pack_ids = set(p.get("id") for p in f["packs"])
                    if pack["id"] in pack_ids:
                        f["packs"] = [p for p in f["packs"] if p.get("id") != pack["id"]]
                        _save_folders("sticker", folders)
                        BulletinHelper.show_success('Removed "%s"' % pack["name"])
                        manager._apply_folder_filter()
                    else:
                        manager._prompt_pack_name("sticker", folder_id, pack)
                    break
        builder = AlertDialogBuilder(activity)
        builder.set_title("Add sticker pack")
        builder.set_items(names, on_select)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _prompt_pack_name(self, media_type, folder_id, pack):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        edit_text = EditText(activity)
        edit_text.setText(pack["name"])
        edit_text.setHint("Name for this pack tab")
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(pack["name"]))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        def do_add(bld, w):
            name = str(edit_text.getText()).strip()
            if not name:
                name = pack["name"]
            folders = _load_folders(media_type)
            for f in folders:
                if f.get("id") == folder_id:
                    if "packs" not in f:
                        f["packs"] = []
                    f["packs"].append({"id": pack["id"], "name": name})
                    break
            _save_folders(media_type, folders)
            BulletinHelper.show_success('Added "%s"' % name)
            manager._apply_folder_filter()
            bld.dismiss()
        builder = AlertDialogBuilder(activity)
        builder.set_title("Pack name")
        builder.set_view(container)
        builder.set_positive_button("Add", do_add)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _create_sub_tab(self, context, tab_id, name):
        tab = FrameLayout(context)
        h = AndroidUtilities.dp(28)
        params = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, h)
        params.setMargins(AndroidUtilities.dp(3), 0, AndroidUtilities.dp(3), 0)
        tab.setLayoutParams(params)
        pad_h = AndroidUtilities.dp(10)
        tab.setPadding(pad_h, 0, pad_h, 0)
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(8)))
        is_sel = (tab_id == self._active_sub_tab)
        custom_bg = _get_subtab_bg_color()
        custom_text = _get_subtab_text_color()
        if is_sel:
            if custom_bg is not None:
                bg.setColor(custom_bg)
            else:
                bg.setColor(Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine))
        else:
            bg.setColor(Color.TRANSPARENT)
        tab.setBackground(bg)
        tab.setForeground(_create_ripple_drawable(0, 8))
        label = TextView(context)
        label.setText(name)
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
        label.setGravity(Gravity.CENTER)
        label.setSingleLine(True)
        label.setEllipsize(TextUtils.TruncateAt.END)
        label.setMaxWidth(AndroidUtilities.dp(120))
        label.setTypeface(Typeface.DEFAULT_BOLD)
        if custom_text is not None:
            label.setTextColor(custom_text)
        elif is_sel:
            label.setTextColor(-1)
        else:
            label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelIcon))
        tab.addView(label, FrameLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        def on_click(v):
            manager._active_sub_tab = tab_id
            manager._apply_folder_filter()
        def on_long(v, tid=tab_id, tname=name):
            manager._show_subtab_context_menu(tid, tname)
            return True
        tab.setOnClickListener(OnClickListener(on_click))
        tab.setOnLongClickListener(OnLongClickListener(on_long))
        return tab

    def _show_subtab_context_menu(self, tab_id, tab_name):
        if tab_id == "custom":
            return
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        folder_data = _get_folder_by_id("sticker", folder_id)
        packs = folder_data.get("packs", []) if folder_data else []
        idx = -1
        for i, p in enumerate(packs):
            if p.get("id") == tab_id:
                idx = i
                break
        items = []
        item_actions = []
        if idx > 0:
            items.append("\u2B06\uFE0F  Move left")
            item_actions.append("left")
        if idx >= 0 and idx < len(packs) - 1:
            items.append("\u2B07\uFE0F  Move right")
            item_actions.append("right")
        items.append("\u270F\uFE0F  Rename")
        item_actions.append("rename")
        items.append("\U0001F5D1  Remove")
        item_actions.append("delete")
        def on_item(bld, which):
            bld.dismiss()
            action = item_actions[which]
            folders = _load_folders("sticker")
            for f in folders:
                if f.get("id") == folder_id:
                    pk = f.get("packs", [])
                    if action == "left" or action == "right":
                        pi = -1
                        for j, p in enumerate(pk):
                            if p.get("id") == tab_id:
                                pi = j
                                break
                        if pi >= 0:
                            ni = pi + (-1 if action == "left" else 1)
                            if 0 <= ni < len(pk):
                                pk[pi], pk[ni] = pk[ni], pk[pi]
                                _save_folders("sticker", folders)
                                manager._apply_folder_filter()
                    elif action == "rename":
                        manager._show_rename_pack_dialog("sticker", folder_id, tab_id, tab_name)
                    elif action == "delete":
                        f["packs"] = [p for p in pk if p.get("id") != tab_id]
                        _save_folders("sticker", folders)
                        if manager._active_sub_tab == tab_id:
                            manager._active_sub_tab = "custom"
                        manager._apply_folder_filter()
                    break
        builder = AlertDialogBuilder(activity)
        builder.set_title(tab_name)
        builder.set_items(items, on_item)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _show_rename_pack_dialog(self, media_type, folder_id, pack_id, old_name):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        edit_text = EditText(activity)
        edit_text.setText(old_name)
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(old_name))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        def do_rename(bld, w):
            new_name = str(edit_text.getText()).strip()
            if new_name:
                folders = _load_folders(media_type)
                for f in folders:
                    if f.get("id") == folder_id:
                        for p in f.get("packs", []):
                            if p.get("id") == pack_id:
                                p["name"] = new_name
                                break
                        break
                _save_folders(media_type, folders)
                manager._apply_folder_filter()
            bld.dismiss()
        builder = AlertDialogBuilder(activity)
        builder.set_title("Rename")
        builder.set_view(container)
        builder.set_positive_button("Rename", do_rename)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _reset_offsets(self):
        stickers_grid = get_private_field(self.emoji_view, "stickersGridView")
        if stickers_grid is not None and self._grid_translated:
            lp = stickers_grid.getLayoutParams()
            if lp is not None:
                if hasattr(self, "_original_grid_margin"):
                    lp.topMargin = self._original_grid_margin
                else:
                    lp.topMargin = 0
                stickers_grid.setLayoutParams(lp)
            self._grid_translated = False
        stickers_search = get_private_field(self.emoji_view, "stickersSearchField")
        if stickers_search is not None:
            try:
                sf_lp = stickers_search.getLayoutParams()
                if sf_lp is not None:
                    if hasattr(self, "_original_search_margin"):
                        sf_lp.topMargin = self._original_search_margin
                    else:
                        sf_lp.topMargin = 0
                    stickers_search.setLayoutParams(sf_lp)
            except Exception:
                pass

    def _get_all_stickers_map(self):
        if self._sticker_map_cache is not None:
            return self._sticker_map_cache
        result = {}
        controller = MediaDataController.getInstance(UserConfig.selectedAccount)
        try:
            recent = controller.getRecentStickers(MediaDataController.TYPE_IMAGE)
            if recent is not None:
                for i in range(recent.size()):
                    try:
                        doc = recent.get(i)
                        result[str(doc.id)] = doc
                    except Exception:
                        pass
        except Exception:
            pass
        try:
            fav = controller.getRecentStickers(MediaDataController.TYPE_FAVE)
            if fav is not None:
                for i in range(fav.size()):
                    try:
                        doc = fav.get(i)
                        result[str(doc.id)] = doc
                    except Exception:
                        pass
        except Exception:
            pass
        try:
            sets = controller.getStickerSets(MediaDataController.TYPE_IMAGE)
            if sets is not None:
                for i in range(sets.size()):
                    try:
                        pack = sets.get(i)
                        docs = pack.documents
                        if docs is not None:
                            for j in range(docs.size()):
                                doc = docs.get(j)
                                result[str(doc.id)] = doc
                    except Exception:
                        pass
        except Exception:
            pass
        self._sticker_map_cache = result
        run_on_ui_thread(self._invalidate_sticker_cache, 30000)
        return result

    def _invalidate_sticker_cache(self):
        self._sticker_map_cache = None

    def _populate_custom_grid(self, sticker_docs):
        if self.custom_grid is None:
            return
        self.custom_grid.removeAllViews()
        if not sticker_docs:
            self._add_empty_message()
            return
        context = self.custom_grid.getContext()
        screen_width = AndroidUtilities.displaySize.x
        cell_dp = 76
        cell_full = AndroidUtilities.dp(cell_dp)
        cols = max(1, screen_width // cell_full)
        cell_size = (screen_width - AndroidUtilities.dp(16)) // cols
        row = None
        for idx, doc in enumerate(sticker_docs):
            if idx % cols == 0:
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.LEFT)
                self.custom_grid.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
            cell = self._create_sticker_cell(context, doc)
            cell_lp = LinearLayout.LayoutParams(cell_size, cell_size)
            row.addView(cell, cell_lp)

    def _add_empty_message(self):
        context = self.custom_grid.getContext()
        container = LinearLayout(context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setGravity(Gravity.CENTER)
        container.setPadding(0, AndroidUtilities.dp(60), 0, 0)
        icon_tv = TextView(context)
        icon_tv.setText("\U0001F3AD")
        icon_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 48)
        icon_tv.setGravity(Gravity.CENTER)
        container.addView(icon_tv)
        label = TextView(context)
        label.setText("No stickers in this folder")
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        label.setGravity(Gravity.CENTER)
        lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(12)
        container.addView(label, lp)
        hint = TextView(context)
        hint.setText("Long press a sticker to add it here")
        hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
        hint.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        hint.setAlpha(0.6)
        hint.setGravity(Gravity.CENTER)
        hlp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        hlp.topMargin = AndroidUtilities.dp(4)
        container.addView(hint, hlp)
        self.custom_grid.addView(container, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

    def _create_sticker_cell(self, context, doc):
        from org.telegram.messenger import DocumentObject
        cell = BackupImageView(context)
        cell.setRoundRadius(AndroidUtilities.dp(6))
        cell.setAspectFit(True)
        try:
            sz = "66_66"
            thumb = None
            thumbDrawable = None
            if doc.thumbs is not None and doc.thumbs.size() > 0:
                thumb = doc.thumbs.get(0)
            try:
                thumbDrawable = DocumentObject.getSvgThumb(doc, Theme.key_chat_emojiPanelBackground, 0.2)
            except Exception:
                pass
            img_loc = ImageLocation.getForDocument(doc)
            thumb_loc = None
            if thumb is not None:
                thumb_loc = ImageLocation.getForDocument(thumb, doc)
            if thumb_loc is not None:
                cell.setImage(img_loc, sz, thumb_loc, None, thumbDrawable, doc)
            else:
                cell.setImage(img_loc, sz, thumbDrawable, doc)
        except Exception:
            try:
                cell.setImage(ImageLocation.getForDocument(doc), "66_66", None, None, doc)
            except Exception:
                pass
        manager = self
        the_doc = doc
        doc_id = str(doc.id)
        def on_click(v):
            try:
                delegate = get_private_field(manager.emoji_view, "delegate")
                if delegate is not None:
                    delegate.onStickerSelected(v, the_doc, None, None, None, True, 0, 0)
            except Exception:
                pass
        def on_long_click(v):
            manager._show_remove_dialog(doc_id)
            return True
        cell.setOnClickListener(OnClickListener(on_click))
        cell.setOnLongClickListener(OnLongClickListener(on_long_click))
        return cell

    def _show_remove_dialog(self, doc_id):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        builder = AlertDialogBuilder(activity)
        builder.set_title("Remove from folder")
        builder.set_message("Remove this sticker from the current folder?")
        def do_remove(bld, w):
            bld.dismiss()
            folders = _load_folders("sticker")
            for f in folders:
                if f.get("id") == folder_id:
                    f["items"] = [g for g in f["items"] if _get_item_id(g) != doc_id]
                    break
            _save_folders("sticker", folders)
            manager._apply_folder_filter()
        builder.set_positive_button("Remove", do_remove)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _apply_folder_filter(self):
        try:
            stickers_grid = get_private_field(self.emoji_view, "stickersGridView")
            if stickers_grid is None:
                return
            active = self.active_folder_id
            stickers_search = get_private_field(self.emoji_view, "stickersSearchField")
            if active == "all":
                if stickers_search is not None:
                    stickers_search.setVisibility(View.VISIBLE)
                stickers_grid.setVisibility(View.VISIBLE)
                if self.custom_scroll is not None:
                    self.custom_scroll.setVisibility(View.GONE)
                if self.folder_bar is not None:
                    self.folder_bar.bringToFront()
                return
            if stickers_search is not None:
                stickers_search.setVisibility(View.GONE)
            stickers_grid.setVisibility(View.GONE)
            folder_data = None
            for f in _load_folders("sticker"):
                if f.get("id") == active:
                    folder_data = f
                    break
            if folder_data is None:
                folder_data = {"items": [], "packs": []}
            self._build_sub_tabs(folder_data)
            sub = self._active_sub_tab
            if sub == "custom":
                folder_items = folder_data.get("items", [])
                folder_item_ids = set(_get_item_id(g) for g in folder_items)
                all_map = self._get_all_stickers_map()
                docs_to_show = [all_map[iid] for iid in folder_item_ids if iid in all_map]
            else:
                docs_to_show = _get_pack_documents("sticker", sub)
            manager = self
            def do_populate():
                manager._populate_custom_grid(docs_to_show)
                if manager.custom_scroll is not None:
                    manager.custom_scroll.setVisibility(View.VISIBLE)
            run_on_ui_thread(do_populate)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("sticker apply_folder_filter error: %s" % e)

    def remove_folder_bar(self):
        try:
            if self.container is not None and self.folder_bar is not None:
                self.container.removeView(self.folder_bar)
                self.folder_bar = None
            if self.container is not None and self.custom_scroll is not None:
                self.container.removeView(self.custom_scroll)
                self.custom_scroll = None
                self.custom_grid = None
            self._reset_offsets()
            stickers_grid = get_private_field(self.emoji_view, "stickersGridView")
            if stickers_grid is not None:
                stickers_grid.setVisibility(View.VISIBLE)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("sticker remove_folder_bar error: %s" % e)


class EmojiFolderBarManager(BaseFolderBarManager):
    _instances = {}

    @classmethod
    def get_or_create(cls, emoji_view):
        obj_id = id(emoji_view)
        if obj_id not in cls._instances:
            cls._instances[obj_id] = EmojiFolderBarManager(emoji_view)
        return cls._instances[obj_id]

    def __init__(self, emoji_view):
        super().__init__(emoji_view, "emoji")
        self.custom_grid = None
        self.custom_scroll = None
        self.sub_tabs_container = None
        self.custom_outer = None
        self._emoji_map_cache = None
        self._active_sub_tab = "custom"

    def inject_folder_bar(self):
        try:
            emoji_container = get_private_field(self.emoji_view, "emojiContainer")
            if emoji_container is None:
                return
            self.container = emoji_container
            existing = emoji_container.findViewWithTag("media_folders_emoji_bar")
            if existing is not None:
                emoji_container.removeView(existing)
            existing_content = emoji_container.findViewWithTag("media_folders_emoji_content")
            if existing_content is not None:
                emoji_container.removeView(existing_content)
            self._reset_offsets()
            bar_height = AndroidUtilities.dp(BAR_HEIGHT_DP)
            tabs_height = AndroidUtilities.dp(36)
            emoji_tabs = get_private_field(self.emoji_view, "emojiTabs")
            if emoji_tabs is not None:
                try:
                    measured = emoji_tabs.getMeasuredHeight()
                    if measured > 0:
                        tabs_height = measured
                except Exception:
                    pass
            context = emoji_container.getContext()
            self.folder_bar = self._create_folder_bar(context)
            self.folder_bar.setTag("media_folders_emoji_bar")
            bar_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, bar_height)
            bar_lp.gravity = Gravity.TOP | Gravity.LEFT
            bar_lp.topMargin = tabs_height
            emoji_container.addView(self.folder_bar, bar_lp)
            self.folder_bar.bringToFront()
            self.custom_scroll = self._create_custom_content(context)
            self.custom_scroll.setTag("media_folders_emoji_content")
            self.custom_scroll.setVisibility(View.GONE)
            content_lp = FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT)
            content_lp.topMargin = tabs_height + bar_height
            emoji_container.addView(self.custom_scroll, content_lp)
            emoji_grid = get_private_field(self.emoji_view, "emojiGridView")
            if emoji_grid is not None:
                lp = emoji_grid.getLayoutParams()
                if lp is not None:
                    self._original_grid_margin = lp.topMargin
                    lp.topMargin = lp.topMargin + bar_height
                    emoji_grid.setLayoutParams(lp)
                    self._grid_translated = True
            emoji_search = get_private_field(self.emoji_view, "emojiSearchField")
            if emoji_search is not None:
                try:
                    sf_lp = emoji_search.getLayoutParams()
                    if sf_lp is not None:
                        self._original_search_margin = sf_lp.topMargin
                        sf_lp.topMargin = sf_lp.topMargin + bar_height
                        emoji_search.setLayoutParams(sf_lp)
                except Exception:
                    pass
            self._rebuild_tabs()
            self._apply_folder_filter()
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("inject emoji folder bar error: %s" % e)

    def _create_custom_content(self, context):
        self.custom_outer = LinearLayout(context)
        self.custom_outer.setOrientation(LinearLayout.VERTICAL)
        self.custom_outer.setBackgroundColor(Theme.getColor(Theme.key_chat_emojiPanelBackground))
        sub_scroll = HorizontalScrollView(context)
        sub_scroll.setHorizontalScrollBarEnabled(False)
        sub_scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
        self.sub_tabs_container = LinearLayout(context)
        self.sub_tabs_container.setOrientation(LinearLayout.HORIZONTAL)
        self.sub_tabs_container.setGravity(Gravity.CENTER_VERTICAL)
        p = AndroidUtilities.dp(4)
        self.sub_tabs_container.setPadding(p, p, p, p)
        sub_scroll.addView(self.sub_tabs_container, LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        sub_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(36))
        self.custom_outer.addView(sub_scroll, sub_lp)
        scroll = ScrollView(context)
        scroll.setFillViewport(True)
        self.custom_grid = LinearLayout(context)
        self.custom_grid.setOrientation(LinearLayout.VERTICAL)
        self.custom_grid.setGravity(Gravity.TOP | Gravity.CENTER_HORIZONTAL)
        pad = AndroidUtilities.dp(8)
        self.custom_grid.setPadding(pad, pad, pad, pad)
        scroll.addView(self.custom_grid, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        grid_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, 0, 1.0)
        self.custom_outer.addView(scroll, grid_lp)
        return self.custom_outer

    def _build_sub_tabs(self, folder_data):
        if self.sub_tabs_container is None:
            return
        self.sub_tabs_container.removeAllViews()
        context = self.sub_tabs_container.getContext()
        packs = folder_data.get("packs", [])
        self.sub_tabs_container.setVisibility(View.VISIBLE)
        self.sub_tabs_container.addView(self._create_add_pack_button(context))
        self.sub_tabs_container.addView(self._create_sub_tab(context, "custom", "Added"))
        for p in packs:
            self.sub_tabs_container.addView(self._create_sub_tab(context, p.get("id", ""), p.get("name", "Pack")))

    def _create_add_pack_button(self, context):
        btn = FrameLayout(context)
        size = AndroidUtilities.dp(28)
        params = LinearLayout.LayoutParams(size, size)
        params.setMargins(AndroidUtilities.dp(3), 0, AndroidUtilities.dp(3), 0)
        btn.setLayoutParams(params)
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(8)))
        bg.setColor(Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine))
        btn.setBackground(bg)
        btn.setForeground(_create_ripple_drawable(0, 8))
        icon = ImageView(context)
        icon.setImageResource(R.drawable.msg_add)
        icon.setColorFilter(-1, PorterDuff.Mode.SRC_ATOP)
        icon.setScaleType(ImageView.ScaleType.CENTER)
        btn.addView(icon, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        btn.setOnClickListener(OnClickListener(lambda v: manager._show_add_pack_dialog()))
        return btn

    def _show_add_pack_dialog(self):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        installed = _get_installed_packs("emoji")
        if not installed:
            BulletinHelper.show_error("No emoji packs installed")
            return
        folder_data = _get_folder_by_id("emoji", folder_id)
        existing_ids = set(p.get("id") for p in (folder_data.get("packs", []) if folder_data else []))
        names = []
        for p in installed:
            if p["id"] in existing_ids:
                names.append("\u2705  %s (%d)" % (p["name"], p["count"]))
            else:
                names.append("\u2B1C  %s (%d)" % (p["name"], p["count"]))
        def on_select(bld, which):
            bld.dismiss()
            pack = installed[which]
            folders = _load_folders("emoji")
            for f in folders:
                if f.get("id") == folder_id:
                    if "packs" not in f:
                        f["packs"] = []
                    pack_ids = set(p.get("id") for p in f["packs"])
                    if pack["id"] in pack_ids:
                        f["packs"] = [p for p in f["packs"] if p.get("id") != pack["id"]]
                        _save_folders("emoji", folders)
                        BulletinHelper.show_success('Removed "%s"' % pack["name"])
                        manager._apply_folder_filter()
                    else:
                        manager._prompt_pack_name("emoji", folder_id, pack)
                    break
        builder = AlertDialogBuilder(activity)
        builder.set_title("Add emoji pack")
        builder.set_items(names, on_select)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _prompt_pack_name(self, media_type, folder_id, pack):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        edit_text = EditText(activity)
        edit_text.setText(pack["name"])
        edit_text.setHint("Name for this pack tab")
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(pack["name"]))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        def do_add(bld, w):
            name = str(edit_text.getText()).strip()
            if not name:
                name = pack["name"]
            folders = _load_folders(media_type)
            for f in folders:
                if f.get("id") == folder_id:
                    if "packs" not in f:
                        f["packs"] = []
                    f["packs"].append({"id": pack["id"], "name": name})
                    break
            _save_folders(media_type, folders)
            BulletinHelper.show_success('Added "%s"' % name)
            manager._apply_folder_filter()
            bld.dismiss()
        builder = AlertDialogBuilder(activity)
        builder.set_title("Pack name")
        builder.set_view(container)
        builder.set_positive_button("Add", do_add)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _create_sub_tab(self, context, tab_id, name):
        tab = FrameLayout(context)
        h = AndroidUtilities.dp(28)
        params = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, h)
        params.setMargins(AndroidUtilities.dp(3), 0, AndroidUtilities.dp(3), 0)
        tab.setLayoutParams(params)
        pad_h = AndroidUtilities.dp(10)
        tab.setPadding(pad_h, 0, pad_h, 0)
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(8)))
        is_sel = (tab_id == self._active_sub_tab)
        custom_bg = _get_subtab_bg_color()
        custom_text = _get_subtab_text_color()
        if is_sel:
            if custom_bg is not None:
                bg.setColor(custom_bg)
            else:
                bg.setColor(Theme.getColor(Theme.key_chat_emojiPanelStickerPackSelectorLine))
        else:
            bg.setColor(Color.TRANSPARENT)
        tab.setBackground(bg)
        tab.setForeground(_create_ripple_drawable(0, 8))
        label = TextView(context)
        label.setText(name)
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
        label.setGravity(Gravity.CENTER)
        label.setSingleLine(True)
        label.setEllipsize(TextUtils.TruncateAt.END)
        label.setMaxWidth(AndroidUtilities.dp(120))
        label.setTypeface(Typeface.DEFAULT_BOLD)
        if custom_text is not None:
            label.setTextColor(custom_text)
        elif is_sel:
            label.setTextColor(-1)
        else:
            label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelIcon))
        tab.addView(label, FrameLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.MATCH_PARENT, Gravity.CENTER))
        manager = self
        def on_click(v):
            manager._active_sub_tab = tab_id
            manager._apply_folder_filter()
        def on_long(v, tid=tab_id, tname=name):
            manager._show_subtab_context_menu(tid, tname)
            return True
        tab.setOnClickListener(OnClickListener(on_click))
        tab.setOnLongClickListener(OnLongClickListener(on_long))
        return tab

    def _show_subtab_context_menu(self, tab_id, tab_name):
        if tab_id == "custom":
            return
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        folder_data = _get_folder_by_id("emoji", folder_id)
        packs = folder_data.get("packs", []) if folder_data else []
        idx = -1
        for i, p in enumerate(packs):
            if p.get("id") == tab_id:
                idx = i
                break
        items = []
        item_actions = []
        if idx > 0:
            items.append("\u2B06\uFE0F  Move left")
            item_actions.append("left")
        if idx >= 0 and idx < len(packs) - 1:
            items.append("\u2B07\uFE0F  Move right")
            item_actions.append("right")
        items.append("\u270F\uFE0F  Rename")
        item_actions.append("rename")
        items.append("\U0001F5D1  Remove")
        item_actions.append("delete")
        def on_item(bld, which):
            bld.dismiss()
            action = item_actions[which]
            folders = _load_folders("emoji")
            for f in folders:
                if f.get("id") == folder_id:
                    pk = f.get("packs", [])
                    if action == "left" or action == "right":
                        pi = -1
                        for j, p in enumerate(pk):
                            if p.get("id") == tab_id:
                                pi = j
                                break
                        if pi >= 0:
                            ni = pi + (-1 if action == "left" else 1)
                            if 0 <= ni < len(pk):
                                pk[pi], pk[ni] = pk[ni], pk[pi]
                                _save_folders("emoji", folders)
                                manager._apply_folder_filter()
                    elif action == "rename":
                        manager._show_rename_pack_dialog("emoji", folder_id, tab_id, tab_name)
                    elif action == "delete":
                        f["packs"] = [p for p in pk if p.get("id") != tab_id]
                        _save_folders("emoji", folders)
                        if manager._active_sub_tab == tab_id:
                            manager._active_sub_tab = "custom"
                        manager._apply_folder_filter()
                    break
        builder = AlertDialogBuilder(activity)
        builder.set_title(tab_name)
        builder.set_items(items, on_item)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _show_rename_pack_dialog(self, media_type, folder_id, pack_id, old_name):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        edit_text = EditText(activity)
        edit_text.setText(old_name)
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(old_name))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        def do_rename(bld, w):
            new_name = str(edit_text.getText()).strip()
            if new_name:
                folders = _load_folders(media_type)
                for f in folders:
                    if f.get("id") == folder_id:
                        for p in f.get("packs", []):
                            if p.get("id") == pack_id:
                                p["name"] = new_name
                                break
                        break
                _save_folders(media_type, folders)
                manager._apply_folder_filter()
            bld.dismiss()
        builder = AlertDialogBuilder(activity)
        builder.set_title("Rename")
        builder.set_view(container)
        builder.set_positive_button("Rename", do_rename)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _reset_offsets(self):
        emoji_grid = get_private_field(self.emoji_view, "emojiGridView")
        if emoji_grid is not None and self._grid_translated:
            lp = emoji_grid.getLayoutParams()
            if lp is not None:
                if hasattr(self, "_original_grid_margin"):
                    lp.topMargin = self._original_grid_margin
                else:
                    lp.topMargin = 0
                emoji_grid.setLayoutParams(lp)
            self._grid_translated = False
        emoji_search = get_private_field(self.emoji_view, "emojiSearchField")
        if emoji_search is not None:
            try:
                sf_lp = emoji_search.getLayoutParams()
                if sf_lp is not None:
                    if hasattr(self, "_original_search_margin"):
                        sf_lp.topMargin = self._original_search_margin
                    else:
                        sf_lp.topMargin = 0
                    emoji_search.setLayoutParams(sf_lp)
            except Exception:
                pass

    def _get_all_emoji_map(self):
        if self._emoji_map_cache is not None:
            return self._emoji_map_cache
        result = {}
        controller = MediaDataController.getInstance(UserConfig.selectedAccount)
        try:
            sets = controller.getStickerSets(MediaDataController.TYPE_EMOJIPACKS)
            if sets is not None:
                for i in range(sets.size()):
                    try:
                        pack = sets.get(i)
                        docs = pack.documents
                        if docs is not None:
                            for j in range(docs.size()):
                                doc = docs.get(j)
                                result[str(doc.id)] = doc
                    except Exception:
                        pass
        except Exception:
            pass
        try:
            installed = get_private_field(self.emoji_view, "installedEmojiSets")
            if installed is not None:
                for i in range(installed.size()):
                    try:
                        pack = installed.get(i)
                        docs = pack.documents
                        if docs is not None:
                            for j in range(docs.size()):
                                doc = docs.get(j)
                                result[str(doc.id)] = doc
                    except Exception:
                        pass
        except Exception:
            pass
        self._emoji_map_cache = result
        run_on_ui_thread(self._invalidate_emoji_cache, 30000)
        return result

    def _invalidate_emoji_cache(self):
        self._emoji_map_cache = None

    def _populate_custom_grid(self, emoji_docs):
        if self.custom_grid is None:
            return
        self.custom_grid.removeAllViews()
        if not emoji_docs:
            self._add_empty_message()
            return
        context = self.custom_grid.getContext()
        screen_width = AndroidUtilities.displaySize.x
        cell_dp = 44
        cell_full = AndroidUtilities.dp(cell_dp)
        cols = max(1, screen_width // cell_full)
        cell_size = (screen_width - AndroidUtilities.dp(16)) // cols
        row = None
        for idx, doc in enumerate(emoji_docs):
            if idx % cols == 0:
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.LEFT)
                self.custom_grid.addView(row, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
            cell = self._create_emoji_cell(context, doc)
            cell_lp = LinearLayout.LayoutParams(cell_size, cell_size)
            row.addView(cell, cell_lp)

    def _add_empty_message(self):
        context = self.custom_grid.getContext()
        container = LinearLayout(context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setGravity(Gravity.CENTER)
        container.setPadding(0, AndroidUtilities.dp(60), 0, 0)
        icon_tv = TextView(context)
        icon_tv.setText("\U0001F600")
        icon_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 48)
        icon_tv.setGravity(Gravity.CENTER)
        container.addView(icon_tv)
        label = TextView(context)
        label.setText("No emoji in this folder")
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        label.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        label.setGravity(Gravity.CENTER)
        lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        lp.topMargin = AndroidUtilities.dp(12)
        container.addView(label, lp)
        hint = TextView(context)
        hint.setText("Long press an emoji to add it here")
        hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
        hint.setTextColor(Theme.getColor(Theme.key_chat_emojiPanelEmptyText))
        hint.setAlpha(0.6)
        hint.setGravity(Gravity.CENTER)
        hlp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT)
        hlp.topMargin = AndroidUtilities.dp(4)
        container.addView(hint, hlp)
        self.custom_grid.addView(container, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

    def _create_emoji_cell(self, context, doc):
        from org.telegram.messenger import DocumentObject
        cell = BackupImageView(context)
        cell.setAspectFit(True)
        try:
            sz = "36_36"
            thumbDrawable = None
            try:
                thumbDrawable = DocumentObject.getSvgThumb(doc, Theme.key_chat_emojiPanelBackground, 0.2)
            except Exception:
                pass
            thumb = None
            if doc.thumbs is not None and doc.thumbs.size() > 0:
                thumb = doc.thumbs.get(0)
            img_loc = ImageLocation.getForDocument(doc)
            thumb_loc = None
            if thumb is not None:
                thumb_loc = ImageLocation.getForDocument(thumb, doc)
            if thumb_loc is not None:
                cell.setImage(img_loc, sz, thumb_loc, None, thumbDrawable, doc)
            else:
                cell.setImage(img_loc, sz, thumbDrawable, doc)
        except Exception:
            try:
                cell.setImage(ImageLocation.getForDocument(doc), "36_36", None, None, doc)
            except Exception:
                pass
        manager = self
        the_doc = doc
        doc_id = str(doc.id)
        def on_click(v):
            try:
                delegate = get_private_field(manager.emoji_view, "delegate")
                if delegate is not None:
                    delegate.onCustomEmojiSelected(the_doc.id, the_doc, None, False)
            except Exception:
                pass
        def on_long_click(v):
            manager._show_remove_dialog(doc_id)
            return True
        cell.setOnClickListener(OnClickListener(on_click))
        cell.setOnLongClickListener(OnLongClickListener(on_long_click))
        return cell

    def _show_remove_dialog(self, doc_id):
        activity = _get_activity()
        if activity is None:
            return
        manager = self
        folder_id = self.active_folder_id
        builder = AlertDialogBuilder(activity)
        builder.set_title("Remove from folder")
        builder.set_message("Remove this emoji from the current folder?")
        def do_remove(bld, w):
            bld.dismiss()
            folders = _load_folders("emoji")
            for f in folders:
                if f.get("id") == folder_id:
                    f["items"] = [g for g in f["items"] if _get_item_id(g) != doc_id]
                    break
            _save_folders("emoji", folders)
            manager._apply_folder_filter()
        builder.set_positive_button("Remove", do_remove)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _apply_folder_filter(self):
        try:
            emoji_grid = get_private_field(self.emoji_view, "emojiGridView")
            if emoji_grid is None:
                return
            active = self.active_folder_id
            emoji_search = get_private_field(self.emoji_view, "emojiSearchField")
            if active == "all":
                if emoji_search is not None:
                    emoji_search.setVisibility(View.VISIBLE)
                emoji_grid.setVisibility(View.VISIBLE)
                if self.custom_scroll is not None:
                    self.custom_scroll.setVisibility(View.GONE)
                return
            if emoji_search is not None:
                emoji_search.setVisibility(View.GONE)
            emoji_grid.setVisibility(View.GONE)
            folder_data = None
            for f in _load_folders("emoji"):
                if f.get("id") == active:
                    folder_data = f
                    break
            if folder_data is None:
                folder_data = {"items": [], "packs": []}
            self._build_sub_tabs(folder_data)
            sub = self._active_sub_tab
            if sub == "custom":
                folder_items = folder_data.get("items", [])
                folder_item_ids = set(_get_item_id(g) for g in folder_items)
                all_map = self._get_all_emoji_map()
                docs_to_show = [all_map[iid] for iid in folder_item_ids if iid in all_map]
            else:
                docs_to_show = _get_pack_documents("emoji", sub)
            manager = self
            def do_populate():
                manager._populate_custom_grid(docs_to_show)
                if manager.custom_scroll is not None:
                    manager.custom_scroll.setVisibility(View.VISIBLE)
            run_on_ui_thread(do_populate)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("emoji apply_folder_filter error: %s" % e)

    def remove_folder_bar(self):
        try:
            if self.container is not None and self.folder_bar is not None:
                self.container.removeView(self.folder_bar)
                self.folder_bar = None
            if self.container is not None and self.custom_scroll is not None:
                self.container.removeView(self.custom_scroll)
                self.custom_scroll = None
                self.custom_grid = None
            self._reset_offsets()
            emoji_grid = get_private_field(self.emoji_view, "emojiGridView")
            if emoji_grid is not None:
                emoji_grid.setVisibility(View.VISIBLE)
        except Exception as e:
            if self.plugin_ref:
                self.plugin_ref.log("emoji remove_folder_bar error: %s" % e)


class UpdateGifTabsHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            if not _get_hide_trending():
                return
            emoji_view = param.thisObject
            if emoji_view is None:
                return
            gif_tabs = get_private_field(emoji_view, "gifTabs")
            if gif_tabs is not None:
                gif_tabs.setVisibility(View.GONE)
            for manager in GifFolderBarManager._instances.values():
                if manager.emoji_view == emoji_view:
                    manager._apply_folder_filter()
                    break
        except Exception:
            pass


class GifSearchHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            if not _get_hide_trending():
                return
            args = param.args
            if args is None or len(args) == 0:
                return
            query = args[0]
            if query is None or len(str(query).strip()) == 0:
                param.setResult(None)
        except Exception:
            pass


class GifProcessResponseHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            if not _get_hide_trending():
                return
            param.setResult(None)
        except Exception:
            pass


class EmojiViewHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            emoji_view = param.thisObject
            if emoji_view is None:
                return
            def inject():
                try:
                    gif_container = get_private_field(emoji_view, "gifContainer")
                    if gif_container is not None:
                        gif_manager = GifFolderBarManager.get_or_create(emoji_view)
                        gif_manager.set_plugin(self.plugin)
                        gif_manager.inject_folder_bar()
                except Exception as e:
                    self.plugin.log("gif inject error: %s" % e)
                try:
                    stickers_container = get_private_field(emoji_view, "stickersContainer")
                    if stickers_container is not None:
                        sticker_manager = StickerFolderBarManager.get_or_create(emoji_view)
                        sticker_manager.set_plugin(self.plugin)
                        sticker_manager.inject_folder_bar()
                except Exception as e:
                    self.plugin.log("sticker inject error: %s" % e)
                try:
                    emoji_container = get_private_field(emoji_view, "emojiContainer")
                    if emoji_container is not None:
                        emoji_manager = EmojiFolderBarManager.get_or_create(emoji_view)
                        emoji_manager.set_plugin(self.plugin)
                        emoji_manager.inject_folder_bar()
                except Exception as e:
                    self.plugin.log("emoji inject error: %s" % e)
            run_on_ui_thread(inject, 150)
        except Exception:
            pass


class PopupShowHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            cpv = ContentPreviewViewer.getInstance()
            content_type = get_private_field(cpv, "currentContentType")
            if content_type is None:
                return
            ct = int(content_type)
            if ct == 0:
                media_type = "sticker"
            elif ct == 1:
                media_type = "gif"
            elif ct == 2:
                media_type = "emoji"
            else:
                return
            menu_visible = get_private_field(cpv, "menuVisible")
            if not bool(menu_visible):
                return
            doc = get_private_field(cpv, "currentDocument")
            if doc is None:
                return
            popup_window = get_private_field(cpv, "popupWindow")
            if popup_window is None:
                return
            rp = get_private_field(cpv, "resourcesProvider")
            item_id_str = str(doc.id)
            the_doc = doc
            plugin = self.plugin
            if media_type == "gif":
                label = "GIF"
            elif media_type == "sticker":
                label = "Sticker"
            else:
                label = "Emoji"
            def add_button():
                try:
                    pw = get_private_field(cpv, "popupWindow")
                    if pw is None:
                        return
                    cv = pw.getContentView()
                    if cv is None:
                        return
                    layout = cv
                    cn = str(cv.getClass().getName())
                    if "ActionBarPopupWindowLayout" not in cn and hasattr(cv, "getChildCount"):
                        for i in range(cv.getChildCount()):
                            child = cv.getChildAt(i)
                            if "ActionBarPopupWindowLayout" in str(child.getClass().getName()):
                                layout = child
                                break
                    item = ActionBarMenuItem.addItem(layout, R.drawable.msg_fave, "Add to %s folder" % label, False, rp)
                    def on_click(v):
                        try:
                            p = get_private_field(cpv, "popupWindow")
                            if p:
                                p.dismiss()
                        except Exception:
                            pass
                        run_on_ui_thread(lambda: plugin._show_add_to_folder_dialog(media_type, item_id_str, the_doc))
                    item.setOnClickListener(OnClickListener(on_click))
                except Exception as e:
                    plugin.log("add_button error: %s" % e)
            run_on_ui_thread(add_button, 50)
        except Exception:
            pass


class OpenForViewHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            args = param.args
            if args is None or len(args) == 0:
                return
            message = args[0]
            if message is None:
                return
            if "MessageObject" not in str(message.getClass().getName()):
                return
            file_name = str(message.getFileName())
            if file_name.endswith(".mediafolder_backup") or file_name.endswith(".giffolder_backup"):
                param.setResult(True)
                run_on_ui_thread(lambda: self.plugin._handle_backup_file(message))
        except Exception:
            pass


class RecentGifsUpdateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            emoji_view = param.thisObject
            if emoji_view is None:
                return
            for manager in GifFolderBarManager._instances.values():
                if manager.emoji_view == emoji_view:
                    manager._apply_folder_filter()
                    break
        except Exception:
            pass


class StickersUpdateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            emoji_view = param.thisObject
            if emoji_view is None:
                return
            for manager in StickerFolderBarManager._instances.values():
                if manager.emoji_view == emoji_view:
                    manager._apply_folder_filter()
                    break
        except Exception:
            pass


class Plugin(BasePlugin):

    def on_plugin_load(self):
        self._hooked_gif_delegate_classes = set()
        self._hooked_gif_adapter_classes = set()
        self._setup_hooks()

    def on_plugin_unload(self):
        def cleanup():
            for manager in list(GifFolderBarManager._instances.values()):
                try:
                    manager.remove_folder_bar()
                except Exception:
                    pass
            GifFolderBarManager._instances.clear()
            for manager in list(StickerFolderBarManager._instances.values()):
                try:
                    manager.remove_folder_bar()
                except Exception:
                    pass
            StickerFolderBarManager._instances.clear()
            for manager in list(EmojiFolderBarManager._instances.values()):
                try:
                    manager.remove_folder_bar()
                except Exception:
                    pass
            EmojiFolderBarManager._instances.clear()
        run_on_ui_thread(cleanup)

    def _setup_hooks(self):
        ev_cls = JClass.forName("org.telegram.ui.Components.EmojiView")
        ev_hook = EmojiViewHook(self)
        _hook_methods_by_name(self, ev_cls, "onAttachedToWindow", ev_hook)
        _hook_methods_by_name(self, ev_cls, "setAllow", ev_hook)
        _hook_methods_by_name(self, ev_cls, "updateGifTabs", UpdateGifTabsHook(self))
        _hook_methods_by_name(self, ev_cls, "updateRecentGifs", RecentGifsUpdateHook(self))
        _hook_methods_by_name(self, ev_cls, "updateStickerTabs", StickersUpdateHook(self))
        popup_cls = JClass.forName("org.telegram.ui.ActionBar.ActionBarPopupWindow")
        _hook_methods_by_name(self, popup_cls, "showAtLocation", PopupShowHook(self))
        au_cls = JClass.forName("org.telegram.messenger.AndroidUtilities")
        _hook_methods_by_name(self, au_cls, "openForView", OpenForViewHook(self))

    def _ensure_gif_delegate_hook(self, delegate):
        try:
            delegate_class = delegate.getClass()
            class_name = str(delegate_class.getName())
            if class_name in self._hooked_gif_delegate_classes:
                return
            self._hooked_gif_delegate_classes.add(class_name)
        except Exception:
            pass

    def _ensure_gif_adapter_hook(self, adapter, emoji_view=None):
        try:
            if adapter is None:
                return
            adapter_class = adapter.getClass()
            class_name = str(adapter_class.getName())
            if class_name in self._hooked_gif_adapter_classes:
                return
            self._hooked_gif_adapter_classes.add(class_name)
            _hook_methods_by_name(self, adapter_class, "search", GifSearchHook(self))
            _hook_methods_by_name(self, adapter_class, "processResponse", GifProcessResponseHook(self))
        except Exception as e:
            self.log("_ensure_gif_adapter_hook error: %s" % e)

    def _clear_trending_results(self, adapter, emoji_view):
        try:
            gif_grid = get_private_field(emoji_view, "gifGridView")
            def do_clear():
                try:
                    if gif_grid is not None:
                        try:
                            if gif_grid.isComputingLayout() or gif_grid.getScrollState() != 0:
                                run_on_ui_thread(do_clear, 50)
                                return
                        except Exception:
                            pass
                    try:
                        results = get_private_field(adapter, "results")
                        if results is not None and results.size() > 0:
                            results.clear()
                    except Exception:
                        pass
                    try:
                        set_private_field(adapter, "trendingSectionItem", jint(-1))
                    except Exception:
                        pass
                    adapter.notifyDataSetChanged()
                except Exception:
                    pass
            run_on_ui_thread(do_clear, 200)
        except Exception:
            pass

    def _show_add_to_folder_dialog(self, media_type, item_id_str, doc=None):
        activity = _get_activity()
        if activity is None:
            return
        folders = _load_folders(media_type)
        if not folders:
            if media_type == "gif":
                label = "GIF"
            elif media_type == "sticker":
                label = "Sticker"
            else:
                label = "Emoji"
            BulletinHelper.show_error("Create a folder first by tapping + in the %s panel" % label)
            return
        folder_names = []
        for f in folders:
            name = f.get("name", "Folder")
            item_ids = set(_get_item_id(g) for g in f.get("items", []))
            if item_id_str in item_ids:
                folder_names.append("\u2705  %s" % name)
            else:
                folder_names.append("\u2B1C  %s" % name)
        plugin = self
        def on_select(bld, which):
            bld.dismiss()
            fresh = _load_folders(media_type)
            if which >= len(fresh):
                return
            folder = fresh[which]
            item_ids = set(_get_item_id(g) for g in folder.get("items", []))
            if item_id_str in item_ids:
                folder["items"] = [g for g in folder["items"] if _get_item_id(g) != item_id_str]
                _save_folders(media_type, fresh)
                BulletinHelper.show_success('Removed from "%s"' % folder["name"])
            else:
                folder["items"].append({"id": item_id_str})
                _save_folders(media_type, fresh)
                BulletinHelper.show_success('Added to "%s"' % folder["name"])
            run_on_ui_thread(lambda: plugin._refresh_folder_bars(media_type), 100)
        if media_type == "gif":
            title = "Add to GIF folder"
        elif media_type == "sticker":
            title = "Add to Sticker folder"
        else:
            title = "Add to Emoji folder"
        builder = AlertDialogBuilder(activity)
        builder.set_title(title)
        builder.set_items(folder_names, on_select)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _show_folder_manage_dialog(self, media_type, folder_id, folder_name):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        order = _get_ordered_tabs(media_type)
        idx = -1
        for i, tid in enumerate(order):
            if tid == folder_id:
                idx = i
                break
        items = []
        item_actions = []
        if idx > 0:
            items.append("\u2B06\uFE0F  Move up")
            item_actions.append("up")
        if idx >= 0 and idx < len(order) - 1:
            items.append("\u2B07\uFE0F  Move down")
            item_actions.append("down")
        items.append("\u270F\uFE0F  Rename")
        item_actions.append("rename")
        if folder_id == "all":
            is_hidden = _get_all_tab_hidden(media_type)
            if is_hidden:
                items.append("\U0001F441  Show tab")
                item_actions.append("show")
            else:
                items.append("\U0001F6AB  Hide tab")
                item_actions.append("hide")
        else:
            items.append("\U0001F5D1  Delete")
            item_actions.append("delete")
        def on_item(bld, which):
            bld.dismiss()
            action = item_actions[which]
            if action == "up":
                plugin._move_folder(media_type, folder_id, -1)
            elif action == "down":
                plugin._move_folder(media_type, folder_id, 1)
            elif action == "rename":
                if folder_id == "all":
                    plugin._show_rename_all_dialog(media_type, folder_name)
                else:
                    plugin._show_rename_folder_dialog(media_type, folder_id, folder_name)
            elif action == "hide":
                _set_all_tab_hidden(media_type, True)
                plugin._refresh_folder_bars(media_type)
                BulletinHelper.show_success("Tab hidden")
                try:
                    plugin.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
                except Exception:
                    pass
            elif action == "show":
                _set_all_tab_hidden(media_type, False)
                plugin._refresh_folder_bars(media_type)
                BulletinHelper.show_success("Tab shown")
                try:
                    plugin.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
                except Exception:
                    pass
            elif action == "delete":
                plugin._confirm_delete_folder(media_type, folder_id, folder_name)
        builder = AlertDialogBuilder(activity)
        builder.set_title(folder_name)
        builder.set_items(items, on_item)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _move_folder(self, media_type, folder_id, direction):
        order = _get_ordered_tabs(media_type)
        idx = -1
        for i, tid in enumerate(order):
            if tid == folder_id:
                idx = i
                break
        if idx < 0:
            return
        new_idx = idx + direction
        if new_idx < 0 or new_idx >= len(order):
            return
        order[idx], order[new_idx] = order[new_idx], order[idx]
        _save_tab_order(media_type, order)
        self._refresh_folder_bars(media_type)
        BulletinHelper.show_success("Order updated")
        try:
            self.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
        except Exception:
            pass

    def _show_rename_all_dialog(self, media_type, old_name):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        edit_text = EditText(activity)
        edit_text.setText(old_name)
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(old_name))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        def do_rename(bld, w):
            new_name = str(edit_text.getText()).strip()
            if new_name:
                _set_all_tab_name(media_type, new_name)
                plugin._refresh_folder_bars(media_type)
                BulletinHelper.show_success('Renamed to "%s"' % new_name)
                try:
                    plugin.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
                except Exception:
                    pass
            bld.dismiss()
        builder = AlertDialogBuilder(activity)
        builder.set_title("Rename Tab")
        builder.set_view(container)
        builder.set_positive_button("Rename", do_rename)
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _show_rename_folder_dialog(self, media_type, folder_id, old_name):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        edit_text = EditText(activity)
        edit_text.setText(old_name)
        edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
        edit_text.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
        edit_text.setSingleLine(True)
        edit_text.setSelection(len(old_name))
        bg = GradientDrawable()
        bg.setShape(GradientDrawable.RECTANGLE)
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        bg.setColor(Theme.getColor(Theme.key_dialogBackground))
        bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
        edit_text.setBackground(bg)
        container = FrameLayout(activity)
        container.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(8), AndroidUtilities.dp(24), AndroidUtilities.dp(4))
        container.addView(edit_text, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
        builder = AlertDialogBuilder(activity)
        builder.set_title("Rename Folder")
        builder.set_view(container)
        builder.set_positive_button("Rename", lambda bld, w: (plugin._rename_folder(media_type, folder_id, str(edit_text.getText()).strip()), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _rename_folder(self, media_type, folder_id, new_name):
        if not new_name:
            return
        folders = _load_folders(media_type)
        for folder in folders:
            if folder.get("id") == folder_id:
                folder["name"] = new_name
                break
        _save_folders(media_type, folders)
        self._refresh_folder_bars(media_type)
        BulletinHelper.show_success('Folder renamed to "%s"' % new_name)
        try:
            self.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
        except Exception:
            pass

    def _confirm_delete_folder(self, media_type, folder_id, folder_name):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        if media_type == "gif":
            msg = 'Are you sure you want to delete "%s"?\n\nYour saved GIFs will not be removed from Telegram.' % folder_name
        elif media_type == "sticker":
            msg = 'Are you sure you want to delete "%s"?\n\nYour sticker packs will not be removed from Telegram.' % folder_name
        else:
            msg = 'Are you sure you want to delete "%s"?\n\nYour emoji packs will not be removed from Telegram.' % folder_name
        builder = AlertDialogBuilder(activity)
        builder.set_title("Delete Folder")
        builder.set_message(msg)
        builder.set_positive_button("Delete", lambda bld, w: (plugin._delete_folder(media_type, folder_id, folder_name), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _delete_folder(self, media_type, folder_id, folder_name):
        folders = _load_folders(media_type)
        folders = [f for f in folders if f.get("id") != folder_id]
        _save_folders(media_type, folders)
        order = _get_ordered_tabs(media_type)
        order = [t for t in order if t != folder_id]
        _save_tab_order(media_type, order)
        if _get_active_folder_id(media_type) == folder_id:
            _set_active_folder_id(media_type, "all")
        self._refresh_folder_bars(media_type)
        if media_type == "gif":
            managers = GifFolderBarManager._instances
        elif media_type == "sticker":
            managers = StickerFolderBarManager._instances
        else:
            managers = EmojiFolderBarManager._instances
        for manager in managers.values():
            if manager.active_folder_id == folder_id:
                manager.active_folder_id = "all"
        BulletinHelper.show_success('Folder "%s" deleted' % folder_name)
        try:
            self.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
        except Exception:
            pass

    def _do_backup(self):
        try:
            user_id = _get_self_user_id()
            if not user_id:
                BulletinHelper.show_error("Failed to get user ID")
                return
            backup = {
                "type": "media_folders_backup",
                "version": 1,
                "user_id": user_id,
                "timestamp": int(time.time()),
                "hide_trending": _get_hide_trending(),
            }
            for mt in ["gif", "sticker", "emoji"]:
                folders = _load_folders(mt)
                backup_folders = []
                for f in folders:
                    bf = {
                        "id": f.get("id", ""),
                        "name": f.get("name", ""),
                        "item_ids": [_get_item_id(g) for g in f.get("items", [])],
                        "packs": f.get("packs", [])
                    }
                    backup_folders.append(bf)
                backup["%s_folders" % mt] = backup_folders
                backup["%s_tab_order" % mt] = _get_ordered_tabs(mt)
            dir_path = os.path.join(str(ApplicationLoader.applicationContext.getCacheDir().getAbsolutePath()), "media_folders_backup")
            ensure_dir_exists(dir_path)
            file_path = os.path.join(dir_path, "media_folders.mediafolder_backup")
            write_file(file_path, json.dumps(backup, ensure_ascii=False))
            saved_messages_id = user_id
            total_items = 0
            total_folders = 0
            for mt in ["gif", "sticker", "emoji"]:
                flds = backup.get("%s_folders" % mt, [])
                total_folders += len(flds)
                for f in flds:
                    total_items += len(f.get("item_ids", []))
            send_document(saved_messages_id, file_path, caption="\U0001F4BE Media Folders Backup\n\U0001F4C1 %d folders \u00B7 %d items\n\U0001F552 %s" % (total_folders, total_items, time.strftime('%Y-%m-%d %H:%M')))
            BulletinHelper.show_success("Backup sent to Saved Messages")
        except Exception as e:
            self.log("backup error: %s" % e)
            BulletinHelper.show_error("Failed to create backup")

    def _handle_backup_file(self, message):
        try:
            doc = message.getDocument()
            if doc is None:
                return
            file = FileLoader.getInstance(UserConfig.selectedAccount).getPathToAttach(doc)
            if file is None or not file.exists():
                try:
                    file = FileLoader.getInstance(UserConfig.selectedAccount).getPathToMessage(message.messageOwner)
                except Exception:
                    file = None
            if file is None or not file.exists():
                FileLoader.getInstance(UserConfig.selectedAccount).loadFile(doc, message, 1, 0)
                BulletinHelper.show_info("Downloading backup... try again in a moment")
                return
            content = read_file(str(file.getAbsolutePath()))
            if content is None:
                BulletinHelper.show_error("Failed to read backup file")
                return
            data = json.loads(content)
            backup_type = data.get("type", "")
            if backup_type == "media_folders_backup":
                backup_user_id = data.get("user_id", 0)
                current_user_id = _get_self_user_id()
                if int(backup_user_id) != int(current_user_id):
                    BulletinHelper.show_error("This backup belongs to a different account")
                    return
                self._show_restore_dialog(data)
            elif backup_type == "gif_folders_backup":
                backup_user_id = data.get("user_id", 0)
                current_user_id = _get_self_user_id()
                if int(backup_user_id) != int(current_user_id):
                    BulletinHelper.show_error("This backup belongs to a different account")
                    return
                self._show_restore_gif_folders_dialog(data)
            else:
                BulletinHelper.show_error("Invalid backup file")
        except Exception as e:
            self.log("handle backup file error: %s" % e)
            BulletinHelper.show_error("Failed to open backup file")

    def _show_restore_gif_folders_dialog(self, data):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        backup_folders = data.get("folders", [])
        total_gifs = sum(len(f.get("gif_ids", []) or f.get("gifs", [])) for f in backup_folders)
        ts = data.get("timestamp", 0)
        date_str = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts)) if ts else "unknown"
        builder = AlertDialogBuilder(activity)
        builder.set_title("Restore GIF Folders")
        builder.set_message("GIF Folders backup from %s\n\n\U0001F4C1 %d GIF folders \u00B7 %d GIFs\n\nThis will replace your current GIF folders." % (date_str, len(backup_folders), total_gifs))
        builder.set_positive_button("Restore", lambda bld, w: (plugin._do_restore_gif_folders(data), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _do_restore_gif_folders(self, data):
        try:
            backup_folders = data.get("folders", [])
            new_folders = []
            for bf in backup_folders:
                raw_ids = bf.get("gif_ids") or [g.get("id") if isinstance(g, dict) else str(g) for g in bf.get("gifs", [])]
                items = [{"id": str(iid)} for iid in raw_ids if iid]
                new_folders.append({
                    "id": bf.get("id", "gif_folder_%d" % int(time.time() * 1000)),
                    "name": bf.get("name", "Folder"),
                    "items": items,
                    "packs": []
                })
            _save_folders("gif", new_folders)
            tab_order = data.get("tab_order")
            if isinstance(tab_order, list):
                _save_tab_order("gif", tab_order)
            else:
                _save_tab_order("gif", None)
            if "hide_trending" in data:
                _set_hide_trending(bool(data["hide_trending"]))
            _set_active_folder_id("gif", "all")
            for manager in GifFolderBarManager._instances.values():
                try:
                    manager.active_folder_id = "all"
                    manager._rebuild_tabs()
                    manager._apply_folder_filter()
                except Exception:
                    pass
            BulletinHelper.show_success("GIF Folders restored: %d folders" % len(new_folders))
        except Exception as e:
            self.log("restore gif folders error: %s" % e)
            BulletinHelper.show_error("Failed to restore GIF Folders backup")

    def _show_restore_dialog(self, data):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        total_folders = 0
        total_items = 0
        for mt in ["gif", "sticker", "emoji"]:
            flds = data.get("%s_folders" % mt, [])
            total_folders += len(flds)
            for f in flds:
                total_items += len(f.get("item_ids", []))
        ts = data.get("timestamp", 0)
        date_str = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts)) if ts else "unknown"
        builder = AlertDialogBuilder(activity)
        builder.set_title("Restore Media Folders")
        builder.set_message("Backup from %s\n\n\U0001F4C1 %d folders\n\U0001F3AC %d item references\n\nThis will replace your current folders." % (date_str, total_folders, total_items))
        builder.set_positive_button("Restore", lambda bld, w: (plugin._do_restore(data), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _do_restore(self, data):
        try:
            for mt in ["gif", "sticker", "emoji"]:
                backup_folders = data.get("%s_folders" % mt, [])
                new_folders = []
                for bf in backup_folders:
                    item_ids = bf.get("item_ids", [])
                    items = [{"id": str(iid)} for iid in item_ids]
                    packs = bf.get("packs", [])
                    new_folders.append({
                        "id": bf.get("id", "%s_folder_%d" % (mt, int(time.time() * 1000))),
                        "name": bf.get("name", "Folder"),
                        "items": items,
                        "packs": packs
                    })
                _save_folders(mt, new_folders)
                tab_order = data.get("%s_tab_order" % mt)
                if isinstance(tab_order, list):
                    _save_tab_order(mt, tab_order)
                else:
                    _save_tab_order(mt, None)
                _set_active_folder_id(mt, "all")
            if "hide_trending" in data:
                _set_hide_trending(bool(data["hide_trending"]))
            for managers in [GifFolderBarManager._instances, StickerFolderBarManager._instances, EmojiFolderBarManager._instances]:
                for manager in managers.values():
                    try:
                        manager.active_folder_id = "all"
                        manager._rebuild_tabs()
                        manager._apply_folder_filter()
                    except Exception:
                        pass
            BulletinHelper.show_success("Backup restored successfully")
        except Exception as e:
            self.log("restore error: %s" % e)
            BulletinHelper.show_error("Failed to restore backup")

    def _open_plugin_settings(self):
        try:
            PluginsController = jclass("com.exteragram.messenger.plugins.PluginsController")
            controller = PluginsController.getInstance()
            plugin_obj = controller.plugins.get(__id__)
            if plugin_obj is None:
                return
            PluginSettingsActivity = jclass("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            frag = get_last_fragment()
            if frag is not None:
                frag.presentFragment(PluginSettingsActivity(plugin_obj))
        except Exception:
            try:
                PluginsController = jclass("com.exteragram.messenger.plugins.PluginsController")
                controller = PluginsController.getInstance()
                engine = controller.getPluginsEngine()
                if engine is not None:
                    frag = get_last_fragment()
                    engine.openPluginSettings(__id__, frag)
            except Exception:
                pass

    def _open_url_internal(self, url):
        def handler(view):
            try:
                Browser = jclass("org.telegram.messenger.browser.Browser")
                ctx = view.getContext()
                uri = jclass("android.net.Uri").parse(url)
                Browser.openUrl(ctx, uri, True, False, None)
            except Exception:
                try:
                    Browser = jclass("org.telegram.messenger.browser.Browser")
                    ctx = view.getContext()
                    Browser.openInTelegramBrowser(ctx, url, None)
                except Exception as e:
                    self.log("open url error: %s" % e)
        return handler

    def _refresh_folder_bars(self, media_type=None):
        if media_type is None or media_type == "gif":
            for manager in GifFolderBarManager._instances.values():
                try:
                    manager._rebuild_tabs()
                    manager._apply_folder_filter()
                except Exception:
                    pass
        if media_type is None or media_type == "sticker":
            for manager in StickerFolderBarManager._instances.values():
                try:
                    manager._rebuild_tabs()
                    manager._apply_folder_filter()
                except Exception:
                    pass
        if media_type is None or media_type == "emoji":
            for manager in EmojiFolderBarManager._instances.values():
                try:
                    manager._rebuild_tabs()
                    manager._apply_folder_filter()
                except Exception:
                    pass

    def _on_tab_bg_color_change(self, value):
        raw = str(value).strip()
        if raw and _parse_color(raw) is None:
            BulletinHelper.show_error("Use color format like #2F80ED")
            return
        _set_color_setting("tab_bg_color", raw)
        self._refresh_folder_bars()

    def _on_tab_text_color_change(self, value):
        raw = str(value).strip()
        if raw and _parse_color(raw) is None:
            BulletinHelper.show_error("Use color format like #FFFFFF")
            return
        _set_color_setting("tab_text_color", raw)
        self._refresh_folder_bars()

    def _on_subtab_bg_color_change(self, value):
        raw = str(value).strip()
        if raw and _parse_color(raw) is None:
            BulletinHelper.show_error("Use color format like #2F80ED")
            return
        _set_color_setting("subtab_bg_color", raw)
        self._refresh_folder_bars()

    def _on_subtab_text_color_change(self, value):
        raw = str(value).strip()
        if raw and _parse_color(raw) is None:
            BulletinHelper.show_error("Use color format like #FFFFFF")
            return
        _set_color_setting("subtab_text_color", raw)
        self._refresh_folder_bars()

    def _on_glass_toggle(self, new_value):
        _set_glass_enabled(new_value)
        self._refresh_folder_bars()

    def _on_glass_tabs_toggle(self, new_value):
        _set_glass_tabs(new_value)
        self._refresh_folder_bars()

    def _on_glass_alpha_change(self, value):
        raw = str(value).strip()
        try:
            v = float(raw)
            if v < 0.1 or v > 1.0:
                BulletinHelper.show_error("Alpha must be between 0.1 and 1.0")
                return
        except Exception:
            BulletinHelper.show_error("Enter a number between 0.1 and 1.0")
            return
        _set_glass_alpha(v)
        self._refresh_folder_bars()

    def _get_folder_items_for_type(self, media_type):
        items = []
        plugin = self
        order = _get_ordered_tabs(media_type)
        folders = _load_folders(media_type)
        folder_map = {f.get("id"): f.get("name", "Folder") for f in folders}
        if media_type == "gif":
            label_plural = "GIFs"
        elif media_type == "sticker":
            label_plural = "Stickers"
        else:
            label_plural = "Emoji"
        for i, tab_id in enumerate(order):
            if tab_id == "all":
                name = _get_all_tab_name(media_type)
                is_hidden = _get_all_tab_hidden(media_type)
                sub = "\U0001F6AB Hidden" if is_hidden else None
                items.append(Text(
                    text=name,
                    subtext=sub,
                    icon="msg_folder",
                    on_click=lambda v, mt=media_type, tid=tab_id, tname=name: plugin._show_folder_manage_dialog(mt, tid, tname)
                ))
            elif tab_id in folder_map:
                name = folder_map[tab_id]
                items.append(Text(
                    text=name,
                    icon="msg_folder",
                    on_click=lambda v, mt=media_type, tid=tab_id, tname=name: plugin._show_folder_manage_dialog(mt, tid, tname)
                ))
        return items

    def create_settings(self):
        plugin = self
        items = [
            Header(text="\u0418\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f"),
            Text(text="\u041a\u0430\u043d\u0430\u043b \u0430\u0432\u0442\u043e\u0440\u0430", icon="msg_channel", on_click=self._open_url_internal("https://t.me/MaxExteraPlugins")),
            Text(text="\u0414\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u044f", icon="msg_link", on_click=self._open_url_internal("https://telegra.ph/Dokumentaciya-k-plaginu-Media-Folders-07-08")),
            Divider(),
        ]
        for mt, label in [("gif", "GIF"), ("sticker", "Sticker"), ("emoji", "Emoji")]:
            items.append(Header(text="%s Folders" % (label,)))
            items.extend(self._get_folder_items_for_type(mt))
            items.append(Divider())
        items.extend([
            Header(text="Design"),
            Input(key="tab_bg_color", text="Folder tab color", subtext="Hex, e.g. #2F80ED", default=_get_color_setting("tab_bg_color"), icon="msg_edit", on_change=plugin._on_tab_bg_color_change),
            Input(key="tab_text_color", text="Folder tab text color", subtext="Hex, e.g. #FFFFFF", default=_get_color_setting("tab_text_color"), icon="msg_edit", on_change=plugin._on_tab_text_color_change),
            Input(key="subtab_bg_color", text="Sub-tab color", subtext="Color for pack tabs inside folders", default=_get_color_setting("subtab_bg_color"), icon="msg_edit", on_change=plugin._on_subtab_bg_color_change),
            Input(key="subtab_text_color", text="Sub-tab text color", subtext="Text color for pack tabs", default=_get_color_setting("subtab_text_color"), icon="msg_edit", on_change=plugin._on_subtab_text_color_change),
            Divider(),
            Header(text="Liquid Glass"),
            Switch(key="glass_enabled", text="Enable Liquid Glass", subtext="Frosted glass effect for the folder bar", default=_get_glass_enabled(), icon="msg_theme", on_change=plugin._on_glass_toggle),
            Switch(key="glass_tabs", text="Glass tabs", subtext="Glass effect on individual tabs", default=_get_glass_tabs(), icon="msg_photo_settings", on_change=plugin._on_glass_tabs_toggle),
            Input(key="glass_alpha", text="Glass opacity", subtext="0.1 - 1.0", default=str(_get_glass_alpha()), icon="msg_edit", on_change=plugin._on_glass_alpha_change),
            Divider(),
            Header(text="Settings"),
            Switch(key="hide_trending_gifs", text="Hide Trending GIFs", subtext="Hide popular GIFs section in GIF panel", default=_get_hide_trending(), on_change=plugin._on_trending_toggle),
            Divider(),
            Header(text="Backup"),
            Text(text="Backup to Saved Messages", subtext="Save all folder structures to restore later", icon="msg_saved", on_click=lambda v: plugin._do_backup()),
            Divider(text="Tap a .mediafolder_backup file in Saved Messages to restore."),
            Divider(),
            Text(text="Reset All Folders", icon="msg_delete", red=True, on_click=self._on_reset_click),
        ])
        return items

    def _on_trending_toggle(self, new_value):
        _set_hide_trending(new_value)
        plugin = self
        def apply_all():
            _apply_trending_visibility()
            for manager in GifFolderBarManager._instances.values():
                try:
                    if new_value:
                        gif_adapter = get_private_field(manager.emoji_view, "gifAdapter")
                        if gif_adapter is not None:
                            plugin._clear_trending_results(gif_adapter, manager.emoji_view)
                    manager._apply_folder_filter()
                except Exception:
                    pass
        run_on_ui_thread(apply_all)

    def _on_reset_click(self, view):
        activity = _get_activity()
        if activity is None:
            return
        plugin = self
        builder = AlertDialogBuilder(activity)
        builder.set_title("Reset All Folders")
        builder.set_message("This will delete all your GIF, Sticker, and Emoji folders and reset tab order. Your saved media will not be removed from Telegram.")
        builder.set_positive_button("Reset", lambda bld, w: (plugin._do_reset(), bld.dismiss()))
        builder.set_negative_button("Cancel", lambda bld, w: bld.dismiss())
        builder.show()

    def _do_reset(self):
        for mt in ["gif", "sticker", "emoji"]:
            _save_folders(mt, [])
            _save_tab_order(mt, None)
            _set_active_folder_id(mt, "all")
        BulletinHelper.show_success("All folders have been reset")
        def rebuild_all():
            for managers in [GifFolderBarManager._instances, StickerFolderBarManager._instances, EmojiFolderBarManager._instances]:
                for manager in managers.values():
                    try:
                        manager.active_folder_id = "all"
                        manager._rebuild_tabs()
                        manager._apply_folder_filter()
                    except Exception:
                        pass
        run_on_ui_thread(rebuild_all)
        try:
            self.set_setting("_dummy_refresh", str(time.time()), reload_settings=True)
        except Exception:
            pass
