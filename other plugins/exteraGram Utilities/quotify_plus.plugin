def get_telegram_proxy():
    try:
        from org.telegram.messenger import SharedConfig
        if getattr(SharedConfig, "useProxy", False):
            ip = getattr(SharedConfig, "proxyIP", "")
            port = getattr(SharedConfig, "proxyPort", 0)
            user = getattr(SharedConfig, "proxyUsername", "")
            password = getattr(SharedConfig, "proxyPassword", "")
            if ip and port:
                auth = f"{user}:{password}@" if user else ""
                return f"socks5h://{auth}{ip}:{port}"
    except:
        pass
    return None

def _java_proxied_get(url, headers=None, timeout_ms=15000):
    try:
        from java.net import URL, Proxy, InetSocketAddress
        from java.io import ByteArrayOutputStream
        from java import dynamic_proxy, jclass
    except:
        return None
    try:
        p_ip, p_port, p_user, p_pass = None, None, None, None
        from org.telegram.messenger import SharedConfig
        if getattr(SharedConfig, "useProxy", False):
            p_ip = getattr(SharedConfig, "proxyIP", "")
            p_port = getattr(SharedConfig, "proxyPort", 0)
            p_user = getattr(SharedConfig, "proxyUsername", "")
            p_pass = getattr(SharedConfig, "proxyPassword", "")
    except:
        pass
    try:
        java_url = URL(url)
        if p_ip and p_port:
            address = InetSocketAddress(p_ip, int(p_port))
            proxy = Proxy(Proxy.Type.SOCKS, address)
            connection = java_url.openConnection(proxy)
            if p_user and p_pass:
                try:
                    from java.net import Authenticator, PasswordAuthentication
                    class ProxyAuthenticator(dynamic_proxy(jclass("java.net.Authenticator"))):
                        def getPasswordAuthentication(self):
                            return PasswordAuthentication(p_user, list(p_pass))
                    Authenticator.setDefault(ProxyAuthenticator())
                except:
                    pass
        else:
            connection = java_url.openConnection()
        connection.setConnectTimeout(timeout_ms)
        connection.setReadTimeout(timeout_ms)
        connection.setUseCaches(False)
        if headers:
            for k, v in headers.items():
                connection.setRequestProperty(str(k), str(v))
        else:
            connection.setRequestProperty("User-Agent", "Mozilla/5.0")
        response_code = connection.getResponseCode()
        if response_code >= 400:
            input_stream = connection.getErrorStream()
        else:
            input_stream = connection.getInputStream()
        if not input_stream:
            return None
        output_stream = ByteArrayOutputStream()
        buffer = bytearray(8192)
        while True:
            bytes_read = input_stream.read(buffer)
            if bytes_read == -1:
                break
            output_stream.write(buffer, 0, bytes_read)
        content = bytes([b & 0xFF for b in output_stream.toByteArray()])
        class MockResponse:
            def __init__(self, content, status_code):
                self.content = content
                self.status_code = status_code
                self.text = content.decode('utf-8', errors='ignore')
            def json(self):
                import json
                return json.loads(self.text)
        return MockResponse(content, response_code)
    except Exception as e:
        qlog(f"Java proxied GET error: {e}")
        return None

def _java_proxied_post(url, headers=None, json_data=None, timeout_ms=15000):
    try:
        from java.net import URL, Proxy, InetSocketAddress
        from java.io import ByteArrayOutputStream
        from java import dynamic_proxy, jclass
        import json
    except:
        return None
    try:
        p_ip, p_port, p_user, p_pass = None, None, None, None
        from org.telegram.messenger import SharedConfig
        if getattr(SharedConfig, "useProxy", False):
            p_ip = getattr(SharedConfig, "proxyIP", "")
            p_port = getattr(SharedConfig, "proxyPort", 0)
            p_user = getattr(SharedConfig, "proxyUsername", "")
            p_pass = getattr(SharedConfig, "proxyPassword", "")
    except:
        pass
    try:
        java_url = URL(url)
        if p_ip and p_port:
            address = InetSocketAddress(p_ip, int(p_port))
            proxy = Proxy(Proxy.Type.SOCKS, address)
            connection = java_url.openConnection(proxy)
            if p_user and p_pass:
                try:
                    from java.net import Authenticator, PasswordAuthentication
                    class ProxyAuthenticator(dynamic_proxy(jclass("java.net.Authenticator"))):
                        def getPasswordAuthentication(self):
                            return PasswordAuthentication(p_user, list(p_pass))
                    Authenticator.setDefault(ProxyAuthenticator())
                except:
                    pass
        else:
            connection = java_url.openConnection()
        connection.setConnectTimeout(timeout_ms)
        connection.setReadTimeout(timeout_ms)
        connection.setDoOutput(True)
        connection.setRequestMethod("POST")
        if headers:
            for k, v in headers.items():
                connection.setRequestProperty(str(k), str(v))
        else:
            connection.setRequestProperty("Content-Type", "application/json")
        if json_data is not None:
            post_data = json.dumps(json_data).encode('utf-8')
            connection.setRequestProperty("Content-Length", str(len(post_data)))
            os_stream = connection.getOutputStream()
            os_stream.write(post_data)
            os_stream.close()
        response_code = connection.getResponseCode()
        if response_code >= 400:
            input_stream = connection.getErrorStream()
        else:
            input_stream = connection.getInputStream()
        if not input_stream:
            return None
        output_stream = ByteArrayOutputStream()
        buffer = bytearray(8192)
        while True:
            bytes_read = input_stream.read(buffer)
            if bytes_read == -1:
                break
            output_stream.write(buffer, 0, bytes_read)
        content = bytes([b & 0xFF for b in output_stream.toByteArray()])
        class MockResponse:
            def __init__(self, content, status_code):
                self.content = content
                self.status_code = status_code
                self.text = content.decode('utf-8', errors='ignore')
            def json(self):
                import json
                return json.loads(self.text)
        return MockResponse(content, response_code)
    except Exception as e:
        qlog(f"Java proxied POST error: {e}")
        return None

def _proxied_get(url, **kwargs):
    headers = kwargs.get("headers")
    timeout = kwargs.get("timeout", 15)
    p_url = get_telegram_proxy()
    if p_url:
        res = _java_proxied_get(url, headers, int(timeout * 1000))
        if res is not None and res.status_code < 400:
            return res
    try:
        if p_url and "proxies" not in kwargs:
            kwargs["proxies"] = {"http": p_url, "https": p_url}
        return getattr(requests, "get")(url, **kwargs)
    except Exception as e:
        if "proxies" in kwargs:
            del kwargs["proxies"]
        return getattr(requests, "get")(url, **kwargs)

def _proxied_post(url, **kwargs):
    headers = kwargs.get("headers")
    json_data = kwargs.get("json")
    timeout = kwargs.get("timeout", 15)
    p_url = get_telegram_proxy()
    if p_url:
        res = _java_proxied_post(url, headers, json_data, int(timeout * 1000))
        if res is not None and res.status_code < 400:
            return res
    try:
        if p_url and "proxies" not in kwargs:
            kwargs["proxies"] = {"http": p_url, "https": p_url}
        return getattr(requests, "post")(url, **kwargs)
    except Exception as e:
        if "proxies" in kwargs:
            del kwargs["proxies"]
        return getattr(requests, "post")(url, **kwargs)

_r_get = _proxied_get
_r_post = _proxied_post

class SimpleExecutor:
    def submit(self, fn, *args, **kwargs):
        threading.Thread(target=fn, args=args, kwargs=kwargs, daemon=True).start()

    def shutdown(self, wait=False):
        pass

global_executor = SimpleExecutor()
io_executor = SimpleExecutor()
