def safe_recycle(bitmap):
    try:
        if bitmap and not bitmap.isRecycled():
            bitmap.recycle()
    except Exception as e:
        qlog(f"Bitmap recycle error: {e}")

class LRUCache:
    def __init__(self, max_mb=20):
        self.cache = collections.OrderedDict()
        self.max_bytes = max_mb * 1024 * 1024
        self.current_bytes = 0

    def _get_size(self, value):
        try:
            if hasattr(value, 'size') and hasattr(value, 'mode'):
                return value.size[0] * value.size[1] * len(value.getbands())
            return 1024
        except Exception:
            return 1024

    def get(self, key):
        if key not in self.cache: return None
        self.cache.move_to_end(key)
        return self.cache[key][0]

    def put(self, key, value):
        if key in self.cache:
            self.current_bytes -= self.cache[key][1]
        
        size = self._get_size(value)
        self.cache[key] = (value, size)
        self.current_bytes += size
        self.cache.move_to_end(key)
        
        while self.current_bytes > self.max_bytes and len(self.cache) > 0:
            _, (_, item_size) = self.cache.popitem(last=False)
            self.current_bytes -= item_size

    def __contains__(self, key):
        return key in self.cache

    def clear(self):
        self.cache.clear()
        self.current_bytes = 0

    def pop(self, key, default=None):
        if key in self.cache:
            val, size = self.cache.pop(key)
            self.current_bytes -= size
            return val
        return default

    def __len__(self):
        return len(self.cache)

def copy_error_to_clipboard(error_msg):
    try:
        if not plugin_instance.get_setting("copy_error_to_clipboard", True):
            return
        ctx = ApplicationLoader.applicationContext
        service_name = "".join(["cli", "pbo", "ard"])
        clipboard = ctx.getSystemService(service_name)
        clip_class = jclass("android.content.ClipData")
        clip = clip_class.newPlainText("Quotify Error", str(error_msg))
        clipboard.setPrimaryClip(clip)
        run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка скопирована в буфер!"))
    except Exception:
        pass
        
def qlog(message, error=None):
    if not DebugLogger.enabled and error is None:
        return
        
    if error:
        tb = traceback.format_exc()
        full_msg = f"{message}\n[ERROR]: {str(error)}\n[TRACEBACK]:\n{tb}"
    else:
        full_msg = message
        
    log(f"[Quotify_Plus] {full_msg}")
    DebugLogger.log(full_msg, is_error=bool(error))

