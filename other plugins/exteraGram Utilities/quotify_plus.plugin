class ImageProcessingConstants:
    MAX_IMAGE_SIZE = 1600
    MIN_AVATAR_SIZE = 134
    MAX_AVATAR_SIZE = 534
    CANVAS_WIDTH = 1600
    PADDING = 67
    QUALITY = 100

class ImageUtils:
    @staticmethod
    def safe_resize(image, size, resample=None):
        try:
            if resample is None:
                try:
                    return image.resize(size, Image.Resampling.LANCZOS)
                except AttributeError:
                    return image.resize(size, Image.LANCZOS)
            return image.resize(size, resample)
        except Exception as e:
            qlog(f"ImageUtils.safe_resize error: {e}")
            return image

    @staticmethod
    def crop_center(image, target_w, target_h):
        try:
            img_w, img_h = image.size
            scale = max(target_w / img_w, target_h / img_h)
            new_w, new_h = int(img_w * scale), int(img_h * scale)
            resized = ImageUtils.safe_resize(image, (new_w, new_h))
            left = (new_w - target_w) // 2
            top = (new_h - target_h) // 2
            return resized.crop((left, top, left + target_w, top + target_h))
        except Exception as e:
            qlog(f"ImageUtils.crop_center error: {e}")
            return image

class MemoryOptimizer:
    @staticmethod
    def optimize_image_before_processing(image_path, max_size=ImageProcessingConstants.MAX_IMAGE_SIZE):
        try:
            with Image.open(image_path) as img:
                w, h = img.size
                if w > max_size or h > max_size:
                    ratio = min(max_size / w, max_size / h)
                    new_w, new_h = int(w * ratio), int(h * ratio)
                    optimized = ImageUtils.safe_resize(img, (new_w, new_h))
                    temp_dir = Filesystem.get_temp_dir()
                    import uuid
                    optimized_path = os.path.join(temp_dir, f"opt_{uuid.uuid4()}.jpg")
                    optimized.save(optimized_path, "JPEG", quality=ImageProcessingConstants.QUALITY, optimize=True)
                    optimized.close()
                    return optimized_path
                return image_path
        except Exception as e:
            qlog(f"MemoryOptimizer error: {e}")
            return image_path

class DebugLogger:
    logs = []
    enabled = False
    last_log_content = None

    @staticmethod
    def init(plugin_instance=None):
        if plugin_instance:
             DebugLogger.enabled = plugin_instance.get_setting("debug_logging", True)
        else:
            DebugLogger.enabled = False

    @staticmethod
    def log(message, is_error=False):
        if not DebugLogger.enabled:
            return
        try:
            timestamp = datetime.datetime.now().strftime("%d.%m.%Y %H:%M:%S")
            prefix = "[ERROR] " if is_error else "[INFO] "
            log_entry = f"[{timestamp}] {prefix}{message}"
            DebugLogger.logs.append(log_entry)
            if len(DebugLogger.logs) > 500:
                DebugLogger.logs.pop(0)
        except:
            pass

    @staticmethod
    def save_logs(export_dir, is_error=False):
        try:
            if not DebugLogger.logs:
                return None
            
            if not os.path.exists(export_dir):
                os.makedirs(export_dir)
                
            prefix = "quotify_error_log_" if is_error else "quotify_log_"
            filename = f"{prefix}{datetime.datetime.now().strftime('%Y-%m-%d_%H-%M-%S')}.txt"
            file_path = os.path.join(export_dir, filename)
            
            with open(file_path, "w", encoding="utf-8") as f:
                f.write("\n".join(DebugLogger.logs))
                
            return file_path
        except Exception as e:
            log(f"Failed to save logs: {e}")
            return None

    @staticmethod
    def clear_logs():
        DebugLogger.logs.clear()
        DebugLogger.last_log_content = None

class FontManager:
    fonts = []
    custom_font_url = ""
    custom_font_path = None
    last_custom_url = None
    
    @staticmethod
    def init():
        FontManager.fonts = [
            Font("Системный", None, custom_path="/system/fonts/Roboto-Regular.ttf"),
            Font("Hack", "https://github.com/source-foundry/Hack/raw/master/build/ttf/Hack-Bold.ttf"),
            Font("Zpix", "https://github.com/Ar4ikTrirtyFour/windose20/raw/main/fonts/zpix.ttf"),
            Font("Times New Roman", "https://github.com/misuchiru03/font-times-new-roman/raw/master/Times%20New%20Roman.ttf"),
            Font("Bounded Regular", "https://github.com/churkinvlad/Bounded/raw/refs/heads/main/OTF/Bounded-Regular.otf"),
            Font("Кастомный шрифт", None)
        ]
        threading.Thread(target=FontManager._download_fonts, daemon=True).start()

    @staticmethod
    def _download_fonts():
        for font in FontManager.fonts:
            if font.download_uri and not font.exists():
                try:
                    font.download()
                except Exception as e:
                    qlog(f"Ошибка загрузки шрифта {font.name}: {e}")
    
    @staticmethod
    def get(index, plugin=None):
        if index == 5:
            if plugin:
                custom_url = plugin.get_setting("custom_font_url", "").strip()
                custom_path = plugin.get_setting("custom_font_path", "").strip()
                if custom_url:
                    if FontManager.last_custom_url != custom_url:
                        temp_dir = Filesystem.get_temp_dir()
                        font_path = Filesystem.get_absolute_path(temp_dir, "custom_font.ttf")
                        try:
                            response = _r_get(custom_url, timeout=15)
                            with open(font_path, 'wb') as f:
                                f.write(response.content)
                            FontManager.last_custom_url = custom_url
                            FontManager.custom_font_path = font_path
                        except Exception as e:
                            qlog(f"Ошибка загрузки кастомного шрифта: {e}")
                            return FontManager.fonts[0]
                    return Font("Кастомный шрифт", None, custom_path=FontManager.custom_font_path)
                elif custom_path and os.path.exists(custom_path):
                    return Font("Кастомный шрифт", None, custom_path=custom_path)
            return FontManager.fonts[0]
        if index >= len(FontManager.fonts):
            return FontManager.fonts[0]
        return FontManager.fonts[index]

    @staticmethod
    def get_fonts_names():
        return [font.name for font in FontManager.fonts]

class Font:
    def __init__(self, name, download_uri, custom_path=None):
        self.name = name
        self.download_uri = download_uri
        self.custom_path = custom_path
    
    def get_path(self):
        if self.custom_path and os.path.exists(self.custom_path):
            return self.custom_path
        temp_dir = Filesystem.get_temp_dir()
        if not temp_dir:
            return "/system/fonts/DroidSans.ttf"
        fonts_dir = os.path.join(temp_dir, "fonts")
        if not os.path.exists(fonts_dir):
            os.makedirs(fonts_dir)
        file_name = self.name.replace(" ", "_") + ".ttf"
        return os.path.join(fonts_dir, file_name)
    
    def exists(self):
        return os.path.exists(self.get_path())
    
    def download(self):
        if self.exists() or not self.download_uri:
            return
        font_path = self.get_path()
        try:
            response = _r_get(self.download_uri, timeout=15)
            response.raise_for_status()
            content = response.content
            if len(content) > 1000 and (content.startswith(b"\x00\x01\x00\x00") or content.startswith(b"OTTO") or content.startswith(b"ttcf")):
                with open(font_path, "wb") as file:
                    file.write(content)
                qlog(f"Шрифт {self.name} загружен: {font_path}")
            else:
                qlog(f"Валидация шрифта {self.name} не пройдена. Неверный формат файла.")
        except Exception as e:
            qlog(f"Ошибка загрузки {self.name}: {e}")

class Filesystem:
    @staticmethod
    def write_file(file_path, content):
        file_dir = os.path.dirname(file_path)
        if not os.path.exists(file_dir):
            os.makedirs(file_dir)
        with open(file_path, 'wb') as file:
            file.write(content)
    
    @staticmethod
    def get_absolute_path(dir, file_name):
        return os.path.join(dir, file_name)
    
    @staticmethod
    def get_temp_dir():
        try:
            fixed_dir = ApplicationLoader.getFilesDirFixed()
            if not fixed_dir:
                return None
            temp_dir = os.path.join(fixed_dir.getAbsolutePath(), "quotify_fork")
            if not os.path.exists(temp_dir):
                os.makedirs(temp_dir)
            return temp_dir
        except Exception:
            return None

class EmojiRenderer:
    _cache = LRUCache(15)

    @staticmethod
    def render_emoji_to_pil(emoji_char, size_px=64):
        cache_key = f"{emoji_char}_{size_px}"
        cached = EmojiRenderer._cache.get(cache_key)
        if cached:
            return cached

        try:
            result_holder = [None]
            event = threading.Event()

            def run_render():
                try:
                    drawable = Emoji.getEmojiDrawable(emoji_char)
                    success = False
                    
                    if drawable:
                        bitmap = Bitmap.createBitmap(size_px, size_px, Bitmap.Config.ARGB_8888)
                        canvas = Canvas(bitmap)
                        pad = int(size_px * 0.05)
                        drawable.setBounds(pad, pad, size_px - pad, size_px - pad)
                        drawable.draw(canvas)
                        
                        cx, cy = size_px // 2, size_px // 2
                        if bitmap.getPixel(cx, cy) != 0 or \
                           bitmap.getPixel(cx, cy - 5) != 0 or \
                           bitmap.getPixel(cx, cy + 5) != 0:
                            result_holder[0] = bitmap
                            success = True
                        else:
                            safe_recycle(bitmap)

                    if not success:
                        ctx = ApplicationLoader.applicationContext
                        tv = TextView(ctx)
                        tv.setText(emoji_char)
                        tv.setTextSize(0, float(size_px * 0.9))
                        tv.setTextColor(0xFF000000)
                        tv.setGravity(17)
                        tv.setIncludeFontPadding(False)
                        
                        tv.measure(
                            View.MeasureSpec.makeMeasureSpec(size_px, View.MeasureSpec.EXACTLY),
                            View.MeasureSpec.makeMeasureSpec(size_px, View.MeasureSpec.EXACTLY)
                        )
                        tv.layout(0, 0, size_px, size_px)
                        
                        bitmap_sys = Bitmap.createBitmap(size_px, size_px, Bitmap.Config.ARGB_8888)
                        canvas_sys = Canvas(bitmap_sys)
                        tv.draw(canvas_sys)
                        
                        result_holder[0] = bitmap_sys

                except Exception as e:
                    log(f"Emoji render inner error: {e}")
                finally:
                    event.set()

            run_on_ui_thread(run_render)
            event.wait(3.0)

            bitmap = result_holder[0]
            if not bitmap:
                return None

            stream = ByteArrayOutputStream()
            try:
                bitmap.compress(Bitmap.CompressFormat.PNG, 100, stream)
                py_bytes = bytes([b & 0xFF for b in stream.toByteArray()])
            finally:
                stream.close()
                safe_recycle(bitmap)

            pil_img = Image.open(io.BytesIO(py_bytes)).convert("RGBA")
            EmojiRenderer._cache.put(cache_key, pil_img)
            return pil_img

        except Exception as e:
            qlog(f"Emoji render error for '{emoji_char}': {e}")
            return None

class UniversalTextRenderer:
    _cache = LRUCache(20)

    @staticmethod
    def get_typeface():
        try:
            return Typeface.DEFAULT
        except:
            return Typeface.create("sans-serif", Typeface.NORMAL)

    @staticmethod
    def measure(text, size):
        try:
            paint = TextPaint(Paint.ANTI_ALIAS_FLAG)
            paint.setTextSize(float(size))
            paint.setTypeface(UniversalTextRenderer.get_typeface())
            return paint.measureText(text)
        except:
            return 0

    @staticmethod
    def render(text, size, color_int):
        key = f"{text}_{size}_{color_int}"
        cached = UniversalTextRenderer._cache.get(key)
        if cached:
            return cached
        
        try:
            paint = TextPaint(Paint.ANTI_ALIAS_FLAG)
            a = (color_int >> 24) & 0xFF
            r = (color_int >> 16) & 0xFF
            g = (color_int >> 8) & 0xFF
            b = color_int & 0xFF
            paint.setARGB(a, r, g, b)
            
            paint.setTextSize(float(size))
            paint.setTypeface(UniversalTextRenderer.get_typeface())
            
            baseline = abs(paint.ascent())
            width = int(paint.measureText(text) + 2)
            height = int(baseline + paint.descent() + 2)
            
            if width <= 0 or height <= 0:
                return None
                
            bitmap = Bitmap.createBitmap(width, height, Bitmap.Config.ARGB_8888)
            canvas = Canvas(bitmap)
            canvas.drawText(text, 0, baseline, paint)
            
            stream = ByteArrayOutputStream()
            bitmap.compress(Bitmap.CompressFormat.PNG, 100, stream)
            py_bytes = bytes([b & 0xFF for b in stream.toByteArray()])
            stream.close()
            safe_recycle(bitmap)
            
            pil_img = Image.open(io.BytesIO(py_bytes)).convert("RGBA")
            UniversalTextRenderer._cache.put(key, pil_img)
            return pil_img
        except Exception as e:
            qlog(f"Universal render error: {e}")
            return None

class PremiumEmojiRenderer:
    _cache = LRUCache(35)
    _docs_cache = {}
    _in_flight = {}
    _lock = None

    @staticmethod
    def _get_lock():
        if PremiumEmojiRenderer._lock is None:
            import threading
            PremiumEmojiRenderer._lock = threading.Lock()
        return PremiumEmojiRenderer._lock

    @staticmethod
    def prefetch_emojis_async(document_ids, size_px, on_done=None):
        import threading
        
        def run():
            try:
                from java.lang import Long
                import os
                from PIL import Image
                
                current_account = UserConfig.selectedAccount
                temp_dir = Filesystem.get_temp_dir()
                
                my_events = []
                fetch_list = []

                with PremiumEmojiRenderer._get_lock():
                    for doc_id in set(document_ids):
                        doc_id_long = Long(int(doc_id)).longValue()
                        cache_key = f"{doc_id_long}_{size_px}"
                        
                        if cache_key in PremiumEmojiRenderer._cache:
                            continue
                            
                        disk_cache_path = os.path.join(temp_dir, f"emoji_render_{cache_key}.png") if temp_dir else None
                        if disk_cache_path and os.path.exists(disk_cache_path):
                            try:
                                pil_img = Image.open(disk_cache_path).convert("RGBA")
                                PremiumEmojiRenderer._cache.put(cache_key, pil_img)
                                continue
                            except Exception as e:
                                qlog(f"Disk cache load error: {e}")
                        
                        if cache_key in PremiumEmojiRenderer._in_flight:
                            my_events.append(PremiumEmojiRenderer._in_flight[cache_key])
                        else:
                            ev = threading.Event()
                            PremiumEmojiRenderer._in_flight[cache_key] = ev
                            fetch_list.append((doc_id_long, cache_key, ev))

                for ev in my_events:
                    ev.wait(15.0)

                if not fetch_list:
                    return

                docs_map = {}
                still_missing = []

                for doc_id_long, cache_key, ev in fetch_list:
                    if doc_id_long in PremiumEmojiRenderer._docs_cache:
                        docs_map[doc_id_long] = PremiumEmojiRenderer._docs_cache[doc_id_long]
                    else:
                        try:
                            from org.telegram.ui.Components import AnimatedEmojiDrawable
                            doc = AnimatedEmojiDrawable.findDocument(current_account, doc_id_long)
                            if doc:
                                docs_map[doc_id_long] = doc
                                PremiumEmojiRenderer._docs_cache[doc_id_long] = doc
                            else:
                                still_missing.append(doc_id_long)
                        except Exception as e:
                            qlog(f"Local doc find error: {e}")
                            still_missing.append(doc_id_long)

                if still_missing:
                    try:
                        req_cls = getattr(TLRPC, "TL_messages_get" + "CustomEmojiDocuments")
                        req = req_cls()
                        for doc_id_long in still_missing:
                            req.document_id.add(doc_id_long)

                        server_event = threading.Event()
                        server_result = []

                        def on_server_response(response, error):
                            if response:
                                try:
                                    items = getattr(response, 'objects', response)
                                    try:
                                        count = items.size()
                                        for i in range(count):
                                            server_result.append(items.get(i))
                                    except Exception:
                                        for item in items:
                                            server_result.append(item)
                                except Exception as e:
                                    qlog(f"Server response parse error: {e}")
                            server_event.set()

                        send_request(req, RequestCallback(on_server_response))
                        server_event.wait(10.0)

                        for doc in server_result:
                            docs_map[doc.id] = doc
                            PremiumEmojiRenderer._docs_cache[doc.id] = doc
                    except Exception as e:
                        qlog(f"Server request error: {e}")

                file_loader = FileLoader.getInstance(current_account)

                for doc_id_long, cache_key, ev in fetch_list:
                    try:
                        doc = docs_map.get(doc_id_long)
                        if not doc:
                            continue

                        mime = str(getattr(doc, "mime_type", "") or "")
                        if "x-tgsticker" in mime: ext = "tgs"
                        elif "video/webm" in mime: ext = "webm"
                        else: ext = "webp"

                        file_path_obj = None
                        for try_ext in [ext, None]:
                            try:
                                p = file_loader.getPathToAttach(doc, try_ext, True)
                                if p and p.exists() and p.length() > 0:
                                    file_path_obj = p
                                    break
                            except Exception:
                                pass

                        if not file_path_obj or not file_path_obj.exists() or file_path_obj.length() == 0:
                            try:
                                loc = ImageLocation.getForDocument(doc)
                                if loc: file_loader.loadFile(loc, None, "webp", 0, 1)
                            except Exception as e:
                                qlog(f"Image location load error: {e}")

                            try: file_loader.loadFile(doc, ext, 0, 1)
                            except Exception:
                                try: file_loader.loadFile(doc, None, 0, 1)
                                except Exception as e:
                                    qlog(f"Fallback file load error: {e}")

                            for _ in range(20):
                                try:
                                    p = file_loader.getPathToAttach(doc, True)
                                    if p and p.exists() and p.length() > 0:
                                        file_path_obj = p
                                        break
                                    p2 = file_loader.getPathToAttach(doc, ext, True)
                                    if p2 and p2.exists() and p2.length() > 0:
                                        file_path_obj = p2
                                        break
                                except Exception:
                                    pass
                                time.sleep(0.05)

                        if not file_path_obj or not file_path_obj.exists() or file_path_obj.length() == 0:
                            continue

                        abs_path = file_path_obj.getAbsolutePath()
                        actual_ext = os.path.splitext(abs_path)[1].lower().lstrip('.')
                        if actual_ext in ('tgs', 'webm', 'webp', 'jpg', 'jpeg', 'png'):
                            ext = actual_ext

                        thumb_path = None
                        if hasattr(doc, 'thumbs') and doc.thumbs:
                            for i in range(doc.thumbs.size()):
                                t = doc.thumbs.get(i)
                                if isinstance(t, TLRPC.TL_photoSize):
                                    try:
                                        tp = file_loader.getPathToAttach(t, True)
                                        if tp and tp.exists() and tp.length() > 0:
                                            thumb_path = tp.getAbsolutePath()
                                            break
                                    except Exception:
                                        pass

                        if thumb_path and ext in ('tgs', 'webm'):
                            abs_path = thumb_path
                            ext = 'webp'

                        bitmap = None
                        if ext == "tgs":
                            try:
                                render_size = size_px * 4
                                drawable = RLottieDrawable(File(abs_path), render_size, render_size, None, False, None, 0)
                                try: drawable.setAllowDecodeSingleFrame(True)
                                except Exception: pass
                                
                                bitmap = Bitmap.createBitmap(render_size, render_size, Bitmap.Config.ARGB_8888)
                                canvas = Canvas(bitmap)
                                drawable.setBounds(0, 0, render_size, render_size)
                                has_pixels = False
                                
                                cx, cy = render_size // 2, render_size // 2
                                q1, q3 = render_size // 4, (render_size * 3) // 4
                                
                                for _ in range(40):
                                    bitmap.eraseColor(0)
                                    drawable.draw(canvas)
                                    if (bitmap.getPixel(cx, cy) != 0 or 
                                        bitmap.getPixel(q1, q1) != 0 or 
                                        bitmap.getPixel(q3, q3) != 0 or 
                                        bitmap.getPixel(cx, q1) != 0):
                                        has_pixels = True
                                        break
                                    time.sleep(0.05)
                                if has_pixels:
                                    scaled = Bitmap.createScaledBitmap(bitmap, size_px, size_px, True)
                                    if scaled != bitmap:
                                        safe_recycle(bitmap)
                                        bitmap = scaled
                                else:
                                    safe_recycle(bitmap)
                                    bitmap = None
                                try: drawable.recycle(True)
                                except Exception: pass
                            except Exception as e:
                                qlog(f"TGS render error: {e}")
                                bitmap = None
                        elif ext == "webm":
                            try:
                                retriever = MediaMetadataRetriever()
                                retriever.setDataSource(abs_path)
                                bitmap = retriever.getFrameAtTime(0, MediaMetadataRetriever.OPTION_CLOSEST_SYNC)
                                if bitmap is None:
                                    bitmap = retriever.getFrameAtTime()
                                retriever.release()
                                if bitmap:
                                    render_size = size_px * 4
                                    scaled_high = Bitmap.createScaledBitmap(bitmap, render_size, render_size, True)
                                    if scaled_high != bitmap:
                                        safe_recycle(bitmap)
                                        bitmap = scaled_high
                                    scaled = Bitmap.createScaledBitmap(bitmap, size_px, size_px, True)
                                    if scaled != bitmap:
                                        safe_recycle(bitmap)
                                        bitmap = scaled
                            except Exception as e:
                                qlog(f"WebM render error: {e}")
                                bitmap = None
                        else:
                            try:
                                bitmap = BitmapFactory.decodeFile(abs_path)
                                if bitmap:
                                    render_size = size_px * 4
                                    scaled_high = Bitmap.createScaledBitmap(bitmap, render_size, render_size, True)
                                    if scaled_high != bitmap:
                                        safe_recycle(bitmap)
                                        bitmap = scaled_high
                                    scaled = Bitmap.createScaledBitmap(bitmap, size_px, size_px, True)
                                    if scaled != bitmap:
                                        safe_recycle(bitmap)
                                        bitmap = scaled
                            except Exception as e:
                                qlog(f"WebP render error: {e}")
                                bitmap = None

                        if bitmap:
                            try:
                                stream = ByteArrayOutputStream()
                                bitmap.compress(Bitmap.CompressFormat.PNG, 100, stream)
                                py_bytes = bytes([b & 0xFF for b in stream.toByteArray()])
                                stream.close()
                                safe_recycle(bitmap)
                                pil_img = Image.open(io.BytesIO(py_bytes)).convert("RGBA")
                                if ext == "webm":
                                    from PIL import ImageDraw
                                    w, h = pil_img.size
                                    for x, y in [(0, 0), (w - 1, 0), (0, h - 1), (w - 1, h - 1)]:
                                        px = pil_img.getpixel((x, y))
                                        if px[0] < 25 and px[1] < 25 and px[2] < 25:
                                            ImageDraw.floodfill(pil_img, (x, y), (0, 0, 0, 0), thresh=20)
                                PremiumEmojiRenderer._cache.put(cache_key, pil_img)
                                if temp_dir:
                                    try: pil_img.save(os.path.join(temp_dir, f"emoji_render_{cache_key}.png"), "PNG")
                                    except Exception as e: qlog(f"Disk save error: {e}")
                            except Exception as e:
                                qlog(f"Bitmap to PIL error: {e}")
                    finally:
                        ev.set()
                        with PremiumEmojiRenderer._get_lock():
                            PremiumEmojiRenderer._in_flight.pop(cache_key, None)

            finally:
                if on_done:
                    on_done()

        emoji_executor.submit(run)

    @staticmethod
    def render_premium_emoji(document_id, size_px=64):
        doc_id_str = str(int(document_id))
        cache_key = f"{doc_id_str}_{size_px}"
        
        cached = PremiumEmojiRenderer._cache.get(cache_key)
        if cached:
            return cached

        import threading
        ev = threading.Event()
        PremiumEmojiRenderer.prefetch_emojis_async([document_id], size_px, on_done=lambda: ev.set())
        ev.wait(0.8)
        
        return PremiumEmojiRenderer._cache.get(cache_key)

class OpenDocumentHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
    
    def before_hooked_method(self, param):
        try:
            message = param.args[0]
            if not message:
                return
            
            file_name = str(message.getFileName())
            if file_name.lower().endswith(CONFIG_FILE_EXTENSION):
                m_name = param.method.getName()
                if "openForView" in m_name:
                    param.setResult(True)
                else:
                    param.setResult(None)
                
                path = message.messageOwner.attachPath
                if not path or not os.path.exists(str(path)):
                    try:
                        from java import jclass
                        FileLoader = jclass("org.telegram.messenger.FileLoader")
                        f = FileLoader.getInstance(message.currentAccount).getPathToMessage(message.messageOwner)
                        path = f.getAbsolutePath()
                    except:
                        path = None
                
                if path and os.path.exists(str(path)):
                    run_on_ui_thread(lambda: self.plugin._handle_config_file_open(str(path)))
                else:
                    BulletinHelper.show_error("Файл ещё не загружен или не найден")
        except:
            pass

class TelegramUtils:
    @staticmethod
    def get_user(user_id):
        return get_messages_controller().getUser(user_id)
    
    @staticmethod 
    def get_channel(channel_id, callback):
        req_cls = getattr(TLRPC, "TL_channels_get" + "Channels")
        req = req_cls()
        input_channel = get_messages_controller().getInputChannel(channel_id)
        req.id.add(input_channel)
        cb = RequestCallback(callback)
        send_request(req, cb)
        
    @staticmethod
    def get_chat(chat_id, callback):
        req_cls = getattr(TLRPC, "TL_messages_get" + "Chats")
        req = req_cls()
        input_chat = get_messages_controller().getInputChat(chat_id)
        req.id.add(input_chat)
        cb = RequestCallback(callback)
        send_request(req, cb)
        
    @staticmethod
    def create_input_location(photo, size):
        loc_cls = getattr(TLRPC, "TL_inputPhoto" + "FileLocation")
        location = loc_cls()
        location.id = photo.id
        location.access_hash = photo.access_hash
        location.file_reference = photo.file_reference
        location.thumb_size = size.type
        return location
        
    @staticmethod
    def create_peer_input_location(chat, peer):
        loc_cls = getattr(TLRPC, "TL_inputPeer" + "PhotoFileLocation")
        location = loc_cls()
        location.big = True
        location.peer = get_messages_controller().getInputPeer(peer)
        location.photo_id = chat.photo.photo_id
        return location
        
    @staticmethod
    def get_chat_thumbnail(chat, peer, callback):
        req_cls = getattr(TLRPC, "TL_upload_get" + "File")
        req = req_cls()
        cb = RequestCallback(callback)
        location = TelegramUtils.create_peer_input_location(chat, peer)
        req.location = location
        req.offset = 0
        req.limit = 1024 * 1024
        send_request(req, cb)
        
class ReplyerID:
    def __init__(self, peer):
        if peer is None:
            self.channel_id = 0
            self.chat_id = 0
            self.user_id = -1
            self.peer = None
            return
        self.channel_id = peer.channel_id
        self.chat_id = peer.chat_id
        self.user_id = peer.user_id
        self.peer = peer
        
    def get_replyer_type(self):
        if self.channel_id != 0:
            return 2
        elif self.chat_id != 0:
            return 1
        else:
            return 0
        
    def get_id(self):
        if self.channel_id != 0:
            return self.channel_id
        elif self.chat_id != 0:
            return self.chat_id
        else:
            return self.user_id

class Replyer:
    def __init__(self):
        self.name = ""

class QuoteManager:
    def __init__(self, params, font_index, layout_index, fixed_width, plugin, custom_bg_path="", custom_avatar_path="", force_custom_bg=False, force_custom_avatar=False, override_author_name=None, search_query=None):
        self.params = params
        self.user = None
        self.replyer_id = None
        self.replyer = Replyer()
        self.font_index = font_index
        self.layout_index = layout_index
        self.fixed_width = fixed_width
        self.plugin = plugin
        self.override_quote_text = None
        self.custom_bg_path = custom_bg_path
        self.custom_avatar_path = custom_avatar_path
        self.force_custom_bg = force_custom_bg
        self.force_custom_avatar = force_custom_avatar
        self.override_author_name = override_author_name
        self.search_query = search_query
        self.cached_media_path = None
        self.cached_media_paths = []
        self.media_fetch_attempted = False
        self.is_sticker_media = False
        self.is_finalized = False
        self.is_round_media = False
        self.finalize_lock = threading.Lock()

    def _create_base_card(self, w, h, bg=(35, 38, 43, 255), r=45, outline=None):
        from PIL import Image, ImageDraw, ImageFilter
        img = Image.new("RGBA", (w, h), (0, 0, 0, 0))
        shadow = Image.new("RGBA", (w, h), (0, 0, 0, 0))
        ImageDraw.Draw(shadow).rounded_rectangle((10, 10, w - 10, h - 10), radius=r, fill=(0, 0, 0, 90))
        img.paste(shadow.filter(ImageFilter.GaussianBlur(15)), (0, 0))
        draw = ImageDraw.Draw(img)
        kwargs = {"radius": r, "fill": bg}
        if outline: kwargs.update({"outline": outline, "width": 2})
        draw.rounded_rectangle((0, 0, w, h), **kwargs)
        return img, draw

    def _save_card(self, img, prefix):
        import uuid
        p = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"{prefix}_{uuid.uuid4()}.png")
        img.save(p, "PNG")
        return p

    def _load_ttf_font(self, path, size):
        from PIL import ImageFont
        import os
        paths_to_try = []
        if path and os.path.exists(str(path)) and "Traceback" not in str(path):
            paths_to_try.append(str(path))
        paths_to_try.extend([
            "/system/fonts/Roboto-Regular.ttf",
            "/system/fonts/DroidSans.ttf",
            "/system/fonts/NotoSans-Regular.ttf",
            "/system/fonts/LiberationSans-Regular.ttf"
        ])
        for p in paths_to_try:
            try:
                if os.path.exists(p):
                    return ImageFont.truetype(p, size=int(size))
            except:
                pass
        try:
            return ImageFont.load_default()
        except:
            return None

    def _get_fonts(self, sizes):
        p = FontManager.get(self.font_index, self.plugin).get_path()
        fonts = []
        for s in sizes:
            fonts.append(self._load_ttf_font(p, s))
        return fonts

    def _parse_raw_markdown(self, text):
        if not text: return ""
        text = str(text)
        import re
        def repl_pre(m):
            lang = m.group(1) or ''
            code = m.group(2)
            return f"\x01PRE:{lang}\x02{code}\x01/PRE\x02"
        
        text = re.sub(r'```(\w+)?\n?(.*?)```', repl_pre, text, flags=re.DOTALL)
        text = re.sub(r'`(.*?)`', lambda m: f"\x01MONO\x02{m.group(1)}\x01/MONO\x02", text)
        text = re.sub(r'\*\*(.*?)\*\*', lambda m: f"\x01B\x02{m.group(1)}\x01/B\x02", text)
        text = re.sub(r'\_\_(.*?)\_\_', lambda m: f"\x01I\x02{m.group(1)}\x01/I\x02", text)
        text = re.sub(r'\~\~(.*?)\~\~', lambda m: f"\x01S\x02{m.group(1)}\x01/S\x02", text)
        text = re.sub(r'\|\|(.*?)\|\|', lambda m: f"\x01SPOIL\x02{m.group(1)}\x01/SPOIL\x02", text)
        
        lines = text.split('\n')
        in_quote = False
        out_lines = []
        for line in lines:
            if line.startswith('> ') or line == '>':
                content = line[2:] if line.startswith('> ') else line[1:]
                if not in_quote:
                    out_lines.append(f"\x01QUOTE\x02{content}")
                    in_quote = True
                else:
                    out_lines.append(content)
            else:
                if in_quote:
                    out_lines[-1] += "\x01/QUOTE\x02"
                    in_quote = False
                out_lines.append(line)
        if in_quote:
            out_lines[-1] += "\x01/QUOTE\x02"
            
        out_text = '\n'.join(out_lines)
        out_text = out_text.replace('\n\x01/QUOTE\x02', '\x01/QUOTE\x02\n')
        out_text = out_text.replace('\n\x01/PRE\x02', '\x01/PRE\x02\n')
        return out_text

    def _render_tgs_frame(self, sticker_path):
        drawable = None
        bitmap = None
        stream = None
        try:
            drawable = RLottieDrawable(File(sticker_path), 1024, 1024, None, False, None, 0)
            try:
                drawable.setAllowDecodeSingleFrame(True)
            except Exception:
                pass
            bitmap = Bitmap.createBitmap(1024, 1024, Bitmap.Config.ARGB_8888)
            canvas = Canvas(bitmap)
            drawable.setBounds(0, 0, 1024, 1024)
            has_pixels = False
            for _ in range(20):
                bitmap.eraseColor(0)
                drawable.draw(canvas)
                for x in range(128, 1024, 128):
                    for y in range(128, 1024, 128):
                        if bitmap.getPixel(x, y) != 0:
                            has_pixels = True
                            break
                    if has_pixels:
                        break
                if has_pixels:
                    break
                time.sleep(0.02)
            if not has_pixels:
                return None
            out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"sticker_tgs_{uuid.uuid4()}.png")
            stream = FileOutputStream(out_path)
            bitmap.compress(Bitmap.CompressFormat.PNG, 100, stream)
            return out_path
        except Exception:
            return None
        finally:
            try:
                if stream: stream.close()
                if bitmap: bitmap.recycle()
                if drawable: drawable.recycle(True)
            except Exception: pass

    def _get_video_first_frame(self, video_path):
        retriever = None
        bitmap = None
        stream = None
        try:
            from java.io import FileInputStream
            retriever = MediaMetadataRetriever()
            fis = FileInputStream(video_path)
            retriever.setDataSource(fis.getFD())
            fis.close()
            bitmap = retriever.getFrameAtTime(0, MediaMetadataRetriever.OPTION_CLOSEST_SYNC)
            if bitmap is None:
                bitmap = retriever.getFrameAtTime(500000, MediaMetadataRetriever.OPTION_CLOSEST_SYNC)
            if bitmap is None:
                bitmap = retriever.getFrameAtTime()
            if bitmap is not None:
                width = bitmap.getWidth()
                height = bitmap.getHeight()
                if width < 1024 or height < 1024:
                    scale = max(1024.0 / width, 1024.0 / height)
                    scaled = Bitmap.createScaledBitmap(bitmap, int(width * scale), int(height * scale), True)
                    if scaled != bitmap:
                        bitmap.recycle()
                        bitmap = scaled
            if bitmap is None:
                return None
            out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"sticker_video_{uuid.uuid4()}.png")
            stream = FileOutputStream(out_path)
            bitmap.compress(Bitmap.CompressFormat.PNG, 100, stream)
            stream.close()
            try:
                from PIL import Image, ImageDraw
                img = Image.open(out_path).convert("RGBA")
                w, h = img.size
                for cx, cy in [(0, 0), (w - 1, 0), (0, h - 1), (w - 1, h - 1)]:
                    px = img.getpixel((cx, cy))
                    if px[0] < 25 and px[1] < 25 and px[2] < 25:
                        ImageDraw.floodfill(img, (cx, cy), (0, 0, 0, 0), thresh=20)
                img.save(out_path, "PNG")
            except Exception:
                pass
            return out_path
        except Exception:
            return None
        finally:
            try:
                if stream: stream.close()
                if bitmap: bitmap.recycle()
                if retriever: retriever.release()
            except Exception: pass

    def _ensure_raster_image(self, path):
        try:
            bmp = BitmapFactory.decodeFile(path)
            if bmp is None:
                return path
            width = bmp.getWidth()
            height = bmp.getHeight()
            if width < 1024 or height < 1024:
                scale = max(1024.0 / width, 1024.0 / height)
                scaled = Bitmap.createScaledBitmap(bmp, int(width * scale), int(height * scale), True)
                if scaled != bmp:
                    bmp.recycle()
                    bmp = scaled
            out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"raster_{uuid.uuid4()}.png")
            fos = FileOutputStream(out_path)
            try:
                bmp.compress(Bitmap.CompressFormat.PNG, 100, fos)
                fos.flush()
            finally:
                try:
                    fos.close()
                    bmp.recycle()
                except Exception: pass
            return out_path
        except Exception:
            return path

    def _start_emoji_prefetch_from_reply(self):
        try:
            reply_obj = getattr(self.params, 'replyToMsg', None)
            if not reply_obj:
                return

            if hasattr(reply_obj, 'messageOwner'):
                raw_msg = reply_obj.messageOwner
            else:
                raw_msg = reply_obj

            text = getattr(raw_msg, 'message', '') or ''
            if not text:
                text = getattr(raw_msg, 'caption', '') or ''

            if not text or not hasattr(raw_msg, 'entities') or not raw_msg.entities:
                return

            doc_ids = []
            for i in range(raw_msg.entities.size()):
                e = raw_msg.entities.get(i)
                if isinstance(e, TLRPC.TL_messageEntityCustomEmoji):
                    doc_ids.append(e.document_id)

            if not doc_ids:
                return

            try:
                visual_ratio = int(self.plugin.get_setting("emoji_visual_percent", "150")) / 100.0
                quote_font_size = int(self.plugin.get_setting("quote_font_size", "40"))
                author_font_size = int(self.plugin.get_setting("author_font_size", "32"))
            except:
                visual_ratio = 1.30
                quote_font_size = 40
                author_font_size = 32

            size_q = int(quote_font_size * visual_ratio)
            size_a = int(author_font_size * visual_ratio)

            qlog(f"[PREFETCH_EARLY] Starting early prefetch for {len(doc_ids)} doc_id(s), sizes={size_q},{size_a}")
            PremiumEmojiRenderer.prefetch_emojis_async(doc_ids, size_q, on_done=None)
            if size_a != size_q:
                PremiumEmojiRenderer.prefetch_emojis_async(doc_ids, size_a, on_done=None)
        except Exception as e:
            qlog(f"[PREFETCH_EARLY] Error: {e}")

    def generate_quote(self):
        def run():
            try:
                reply_obj = getattr(self.params, 'replyToMsg', None)
                if reply_obj is None:
                    run_on_ui_thread(lambda: BulletinHelper.show_error("⚠️ Ты забыл реплайнуть сообщение!"))
                    return

                if hasattr(reply_obj, 'messageOwner'):
                    real_msg = reply_obj.messageOwner
                else:
                    real_msg = reply_obj

                if self.search_query:
                    if self._resolve_user_from_query(self.search_query):
                        return
                    self.override_author_name = self.search_query
                    self.search_query = None

                self._start_emoji_prefetch_from_reply()
                self.replyer_id = self._init_replyer_id()
                if not self.replyer_id: 
                     self.replyer_id = ReplyerID(None)

                replyer_type = self.replyer_id.get_replyer_type()
                
                if replyer_type == 0:
                    if self.replyer_id.user_id == -1:
                        return self._create_quote_without_input()
                    user = TelegramUtils.get_user(self.replyer_id.user_id)
                    self.user = user
                    self.replyer.name = self._get_full_replyer_name()
                    self._fetch_user_avatar(user)
                elif replyer_type == 1:
                    chat = get_messages_controller().getChat(self.replyer_id.chat_id)
                    if chat:
                        emoji_suffix = ""
                        try:
                            if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                                doc_id = getattr(chat.emoji_status, 'document_id', None)
                                if doc_id: emoji_suffix = f" [CEMOJI:{doc_id}]"
                        except Exception: pass
                        self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
                        self._fetch_chat_avatar(chat, get_messages_controller().getInputPeer(chat.id))
                    else:
                        TelegramUtils.get_chat(self.replyer_id.chat_id, self._handle_get_channels_callback)
                elif replyer_type == 2:
                    chat = get_messages_controller().getChat(self.replyer_id.channel_id)
                    if chat:
                        emoji_suffix = ""
                        try:
                            if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                                doc_id = getattr(chat.emoji_status, 'document_id', None)
                                if doc_id: emoji_suffix = f" [CEMOJI:{doc_id}]"
                        except Exception: pass
                        self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
                        self._fetch_chat_avatar(chat, get_messages_controller().getInputChannel(chat.id))
                    else:
                        TelegramUtils.get_channel(self.replyer_id.channel_id, self._handle_get_channels_callback)
            except Exception as e:
                copy_error_to_clipboard(traceback.format_exc())
        global_executor.submit(run)

    def generate_fake_quote(self, text):
        def run():
            self.override_quote_text = text
            self._start_emoji_prefetch_from_reply()
            
            if self.search_query:
                if self._resolve_user_from_query(self.search_query):
                    return
                self.override_author_name = self.search_query
                self.search_query = None

            if self.override_author_name is not None:
                self.replyer.name = self.override_author_name
                return self._create_quote_without_input()
            
            try:
                reply_obj = getattr(self.params, 'replyToMsg', None)
                if reply_obj is not None:
                    self.replyer_id = self._init_replyer_id()
                    replyer_type = self.replyer_id.get_replyer_type()
                    if replyer_type == 0:
                        if self.replyer_id.user_id == -1:
                            return self._create_quote_without_input()
                        user = TelegramUtils.get_user(self.replyer_id.user_id)
                        self.user = user
                        self.replyer.name = self._get_full_replyer_name()
                        self._fetch_user_avatar(user)
                        return
                    elif replyer_type == 1:
                        chat = get_messages_controller().getChat(self.replyer_id.chat_id)
                        if chat:
                            emoji_suffix = ""
                            try:
                                if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                                    doc_id = getattr(chat.emoji_status, 'document_id', None)
                                    if doc_id: emoji_suffix = f" [CEMOJI:{doc_id}]"
                            except Exception: pass
                            self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
                            self._fetch_chat_avatar(chat, get_messages_controller().getInputPeer(chat.id))
                        else:
                            TelegramUtils.get_chat(self.replyer_id.chat_id, self._handle_get_channels_callback)
                        return
                    elif replyer_type == 2:
                        chat = get_messages_controller().getChat(self.replyer_id.channel_id)
                        if chat:
                            emoji_suffix = ""
                            try:
                                if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                                    doc_id = getattr(chat.emoji_status, 'document_id', None)
                                    if doc_id: emoji_suffix = f" [CEMOJI:{doc_id}]"
                            except Exception: pass
                            self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
                            self._fetch_chat_avatar(chat, get_messages_controller().getInputChannel(chat.id))
                        else:
                            TelegramUtils.get_channel(self.replyer_id.channel_id, self._handle_get_channels_callback)
                        return

                user_id = get_user_config().getClientUserId()
                me = get_messages_controller().getUser(user_id)
                if me:
                    self.user = me
                    self.replyer.name = self._get_full_replyer_name()
                    self._fetch_user_avatar(me)
                else:
                    self.replyer.name = ""
                    self._create_quote_without_input()
            except Exception as e:
                copy_error_to_clipboard(traceback.format_exc())
        global_executor.submit(run)

    def _render_audio_card(self, title, performer, duration, thumb_path, progress=0.0, audio_path=""):
        import uuid
        import io
        import os
        
        qlog(f"[AUDIO_CARD] Start render. Title: '{title}', Performer: '{performer}', Path: '{audio_path}', Thumb: '{thumb_path}'")
        
        try:
            font_path = FontManager.get(self.font_index, self.plugin).get_path()
            title_font = ImageFont.truetype(font_path, 56)
            artist_font = ImageFont.truetype(font_path, 42)
        except:
            title_font = ImageFont.load_default()
            artist_font = ImageFont.load_default()

        temp_img = Image.new("RGBA", (1, 1))
        temp_draw = ImageDraw.Draw(temp_img)
        
        try:
            title_w = temp_draw.textlength(title, font=title_font)
            performer_w = temp_draw.textlength(performer, font=artist_font)
            max_text_w = max(title_w, performer_w)
        except:
            max_text_w = 600

        card_w = int(380 + max_text_w + 50)
        card_w = max(800, min(1800, card_w))
        
        if getattr(self, 'layout_index', 0) == 2:
            card_w = int(card_w * 1.25)

        card_h = 363
        card_img = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        draw = ImageDraw.Draw(card_img)

        bg_color = (35, 35, 35, 255)
        draw.rounded_rectangle((0, 0, card_w, card_h), radius=50, fill=bg_color)

        cover_size = 297
        cover_x, cover_y = 33, 33
        cover_img = None
        
        def process_cover(raw_img):
            cw, ch = raw_img.size
            min_dim = min(cw, ch)
            left = (cw - min_dim) // 2
            top = (ch - min_dim) // 2
            cropped = raw_img.crop((left, top, left + min_dim, top + min_dim))
            resized = cropped.resize((cover_size, cover_size), Image.LANCZOS)
            mask = Image.new("L", (cover_size, cover_size), 0)
            ImageDraw.Draw(mask).rounded_rectangle((0, 0, cover_size, cover_size), radius=33, fill=255)
            resized.putalpha(mask)
            return resized

        if thumb_path and os.path.exists(thumb_path):
            qlog(f"[AUDIO_CARD] Found Telegram thumbnail at: {thumb_path}")
            try:
                cover_img = process_cover(Image.open(thumb_path).convert("RGBA"))
                qlog("[AUDIO_CARD] Successfully loaded Telegram thumbnail.")
            except Exception as e:
                qlog(f"[AUDIO_CARD] Error loading Telegram thumbnail: {e}")
                cover_img = None
                
        if not cover_img and audio_path and os.path.exists(audio_path):
            qlog(f"[AUDIO_CARD] No Telegram thumbnail. Extracting ID3 from audio: {audio_path}")
            try:
                from android.media import MediaMetadataRetriever
                from java.io import FileOutputStream
                retriever = MediaMetadataRetriever()
                retriever.setDataSource(audio_path)
                art = retriever.getEmbeddedPicture()
                
                if art:
                    qlog(f"[AUDIO_CARD] ID3 art found. Size: {len(art)} bytes.")
                    try:
                        temp_art_path = os.path.join(Filesystem.get_temp_dir(), f"temp_art_{uuid.uuid4()}.jpg")
                        fos = FileOutputStream(temp_art_path)
                        fos.write(art)
                        fos.close()
                        
                        raw_cover = Image.open(temp_art_path).convert("RGBA")
                        cover_img = process_cover(raw_cover)
                        qlog("[AUDIO_CARD] Successfully processed ID3 art.")
                    except Exception as e:
                        qlog(f"[AUDIO_CARD] ID3 art decode error: {e}")
                else:
                    qlog("[AUDIO_CARD] No embedded picture in ID3 tags.")
                retriever.release()
            except Exception as e:
                qlog(f"[AUDIO_CARD] MediaMetadataRetriever error: {e}")
        elif not cover_img:
            qlog("[AUDIO_CARD] Audio path is empty or does not exist. Cannot extract ID3.")
        
        if not cover_img:
            qlog("[AUDIO_CARD] Using fallback music icon.")
            cover_img = Image.new("RGBA", (cover_size, cover_size), (60, 60, 60, 255))
            mask = Image.new("L", (cover_size, cover_size), 0)
            ImageDraw.Draw(mask).rounded_rectangle((0, 0, cover_size, cover_size), radius=33, fill=255)
            cover_img.putalpha(mask)
            
            try:
                from org.telegram.messenger import ApplicationLoader
                from androidx.core.content import ContextCompat
                from android.graphics import Bitmap, Canvas as AndroidCanvas, PorterDuff, PorterDuffColorFilter
                from java import jclass
                from java.io import ByteArrayOutputStream
                
                R = jclass("org.telegram.messenger.R")
                ctx = ApplicationLoader.applicationContext
                drawable_id = getattr(R.drawable, "msg_tone_on_solar", getattr(R.drawable, "msg_tone_on", 0))
                
                if drawable_id != 0:
                    drawable = ContextCompat.getDrawable(ctx, drawable_id)
                    if drawable:
                        icon_size = int(cover_size * 0.7)
                        bmp = Bitmap.createBitmap(icon_size, icon_size, Bitmap.Config.ARGB_8888)
                        canvas_android = AndroidCanvas(bmp)
                        drawable.setBounds(0, 0, icon_size, icon_size)
                        drawable.setColorFilter(PorterDuffColorFilter(-1, PorterDuff.Mode.SRC_IN))
                        drawable.draw(canvas_android)
                        
                        stream = ByteArrayOutputStream()
                        bmp.compress(Bitmap.CompressFormat.PNG, 100, stream)
                        py_bytes = bytes([b & 0xFF for b in stream.toByteArray()])
                        stream.close()
                        bmp.recycle()
                        
                        pil_icon = Image.open(io.BytesIO(py_bytes)).convert("RGBA")
                        offset_xy = (cover_size - icon_size) // 2
                        cover_img.paste(pil_icon, (offset_xy, offset_xy), pil_icon)
            except Exception as e:
                qlog(f"[AUDIO_CARD] Music icon fallback error: {e}")

        card_img.paste(cover_img, (cover_x, cover_y), cover_img)

        text_x = cover_x + cover_size + 50
        try:
            font_path = FontManager.get(self.font_index, self.plugin).get_path()
            title_font = ImageFont.truetype(font_path, 56)
            artist_font = ImageFont.truetype(font_path, 42)
            time_font = ImageFont.truetype(font_path, 34)
        except:
            title_font = ImageFont.load_default()
            artist_font = title_font
            time_font = title_font

        def truncate_text(text, font, max_w):
            try:
                if draw.textlength(text, font) <= max_w: return text
                while len(text) > 0 and draw.textlength(text + "...", font) > max_w:
                    text = text[:-1]
                return text + "..."
            except:
                return text[:20] + "..."

        max_text_w = card_w - text_x - 50
        title_disp = truncate_text(title, title_font, max_text_w)
        performer_disp = truncate_text(performer, artist_font, max_text_w)

        try:
            draw.text((text_x, cover_y + 25), title_disp, font=title_font, fill=(255, 255, 255, 255))
        except:
            pass
            
        try:
            draw.text((text_x, cover_y + 100), performer_disp, font=artist_font, fill=(180, 180, 180, 255))
        except:
            pass

        bar_y = cover_y + 223
        bar_w = card_w - text_x - 50
        progress_val = max(0.0, min(1.0, float(progress)))
        
        draw.line((text_x, bar_y, text_x + bar_w, bar_y), fill=(100, 100, 100, 255), width=10)
        
        if progress_val > 0:
            draw.line((text_x, bar_y, text_x + int(bar_w * progress_val), bar_y), fill=(255, 255, 255, 255), width=10)
            cx = text_x + int(bar_w * progress_val)
        else:
            cx = text_x
            
        cy = bar_y
        draw.ellipse((cx - 13, cy - 13, cx + 13, cy + 13), fill=(255, 255, 255, 255))

        def format_time(seconds):
            seconds = int(seconds)
            m = seconds // 60
            s = seconds % 60
            return f"{m}:{s:02d}"

        curr_time_str = format_time(int(duration * progress_val)) if duration > 0 else "0:00"
        tot_time_str = format_time(duration) if duration > 0 else "0:00"

        try:
            draw.text((text_x, bar_y + 30), curr_time_str, font=time_font, fill=(180, 180, 180, 255))
            tot_w = draw.textlength(tot_time_str, font=time_font)
            draw.text((text_x + bar_w - tot_w, bar_y + 30), tot_time_str, font=time_font, fill=(180, 180, 180, 255))
        except:
            pass

        out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"audio_card_{uuid.uuid4()}.png")
        card_img.save(out_path, "PNG")
        return out_path

    def _render_file_card(self, file_name, file_size_str, file_ext, thumb_path=""):
        import os
        from PIL import Image, ImageDraw, ImageOps
        sz, x, y, tx, h = 297, 54, 54, 425, 405
        t_f, s_f = self._get_fonts([92, 69])
        
        sub_text = f"{file_size_str} • {file_ext.upper()}" if file_ext else file_size_str
        def get_w(t, f):
            try: return int(f.getlength(t) if hasattr(f, 'getlength') else ImageDraw.Draw(Image.new("RGB",(1,1))).textlength(t, font=f))
            except: return len(t) * 45

        card_w = int(max(800, min(1800, tx + max(get_w(file_name, t_f), get_w(sub_text, s_f)) + 74)))
        img, draw = self._create_base_card(card_w, h, bg=(35, 35, 35, 255), r=82)

        icon_img = None
        if thumb_path and os.path.exists(thumb_path):
            try:
                raw = Image.open(thumb_path).convert("RGBA")
                icon_img = ImageOps.fit(raw, (sz, sz), Image.LANCZOS)
                mask = Image.new("L", (sz, sz), 0)
                ImageDraw.Draw(mask).rounded_rectangle((0, 0, sz, sz), radius=60, fill=255)
                icon_img.putalpha(mask)
            except: icon_img = None

        if not icon_img:
            colors = {'pdf':(229,57,53), 'doc':(30,136,229), 'xls':(67,160,71), 'zip':(251,140,0), 'apk':(124,179,66)}
            clr = colors.get(file_ext.lower(), (65, 163, 235)) + (255,)
            icon_img = Image.new("RGBA", (sz, sz), (0, 0, 0, 0))
            idraw = ImageDraw.Draw(icon_img)
            idraw.rounded_rectangle((0, 0, sz, sz), radius=60, fill=clr)
            dw, dh = 132, 181
            dx, dy = (sz-dw)//2, (sz-dh)//2
            idraw.rounded_rectangle((dx, dy, dx+dw, dy+dh), radius=20, fill=(255, 255, 255, 255))
            idraw.polygon([(dx+dw-46, dy), (dx+dw, dy), (dx+dw, dy+46)], fill=clr)
            idraw.polygon([(dx+dw-46, dy), (dx+dw-46, dy+46), (dx+dw, dy+46)], fill=(220, 220, 220, 255))

        img.paste(icon_img, (x, y), icon_img)

        def trunc(t, f, m):
            try:
                if get_w(t, f) <= m: return t
                while len(t) > 0 and get_w(t + "...", f) > m: t = t[:-1]
                return t + "..."
            except: return t[:20] + "..."

        draw.text((tx, 109), trunc(file_name, t_f, card_w-tx-74), font=t_f, fill=(255,255,255))
        draw.text((tx, 226), trunc(sub_text, s_f, card_w-tx-74), font=s_f, fill=(180,180,180))

        return self._save_card(img, "file_card")

    def _render_geo_card(self, lat, lon, title, address):
        import requests, os, io
        from PIL import Image, ImageDraw
        card_w, card_h, r = 1200, 800, 64
        t_f, s_f, c_f = self._get_fonts([72, 46, 38])
        cache_key = f"geo_{str(round(lat, 6)).replace('.','_')}_{str(round(lon, 6)).replace('.','_')}"
        cpath = os.path.join(Filesystem.get_temp_dir(), f"{cache_key}.png")

        map_img = None
        if os.path.exists(cpath) and os.path.getsize(cpath) > 1000:
            try: map_img = Image.open(cpath).convert("RGBA").resize((card_w, card_h), Image.LANCZOS)
            except: pass

        if not map_img:
            api_key = self.plugin.get_setting("google_maps_key", "")
            providers = [
                f"https://maps.googleapis.com/maps/api/staticmap?center={lat},{lon}&zoom=15&size=600x400&markers=color:red%7C{lat},{lon}&key={api_key}" if api_key else None,
                f"https://static-maps.yandex.ru/v1?ll={lon},{lat}&zoom=15&size=600,400&l=map&pt={lon},{lat},pm2rdm&lang=ru_RU",
                f"https://static-maps.yandex.ru/1.x/?ll={lon},{lat}&size=600,400&z=15&l=map&pt={lon},{lat},pm2rdm"
            ]
            for url in filter(None, providers):
                try:
                    resp = _r_get(url, timeout=8, headers={"User-Agent": "Mozilla/5.0"})
                    if resp.status_code == 200 and len(resp.content) > 2000:
                        Filesystem.write_file(cpath, resp.content)
                        map_img = Image.open(io.BytesIO(resp.content)).convert("RGBA").resize((card_w, card_h), Image.LANCZOS)
                        break
                except: continue

        if not map_img:
            map_img = Image.new("RGBA", (card_w, card_h), (30, 42, 55, 255))
            d_ph = ImageDraw.Draw(map_img)
            for gx in range(0, card_w, 60): d_ph.line([(gx, 0), (gx, card_h)], fill=(40, 55, 70, 255))
            for gy in range(0, card_h, 60): d_ph.line([(0, gy), (card_w, gy)], fill=(40, 55, 70, 255))
            cx, cy = card_w // 2, card_h // 2
            d_ph.ellipse((cx-20, cy-20, cx+20, cy+20), fill=(220, 60, 60, 255))

        if not address and not title:
            try:
                g_res = _r_get(f"https://nominatim.openstreetmap.org/reverse?lat={lat}&lon={lon}&format=json&accept-language=ru", timeout=5, headers={"User-Agent": "QuotifyBot"}).json()
                a = g_res.get("address", {})
                title = g_res.get("name") or a.get("amenity") or a.get("city") or "Геопозиция"
                address = f"{a.get('road', '')}, {a.get('house_number', '')}".strip(", ") or g_res.get("display_name", "")[:50]
            except: pass

        img, draw = self._create_base_card(card_w, card_h, r=r)
        overlay = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        od = ImageDraw.Draw(overlay)
        for y in range(int(card_h*0.45), card_h):
            alpha = int(220 * (((y-card_h*0.45)/(card_h*0.55))**1.2))
            od.line([(0, y), (card_w, y)], fill=(15, 15, 15, alpha))
        
        map_img = Image.alpha_composite(map_img.convert("RGBA"), overlay)
        mask = Image.new("L", (card_w, card_h), 0)
        ImageDraw.Draw(mask).rounded_rectangle((0, 0, card_w, card_h), radius=r, fill=255)
        map_img.putalpha(mask)
        img.paste(map_img, (0, 0), map_img)

        def trunc(t, f, m):
            try:
                if self._get_text_width(draw, t, f) <= m: return t
                while len(t) > 0 and self._get_text_width(draw, t + "...", f) > m: t = t[:-1]
                return t + "..."
            except: return t[:25] + "..."

        t_txt, s_txt = trunc(title or "Геопозиция", t_f, 1080), trunc(address or "Место на карте", s_f, 1080)
        
        self._prefetch_all_emojis([(t_txt, t_f), (s_txt, s_f)])

        self._draw_text_with_emoji(img, draw, (63, card_h-187), t_txt, t_f, (0, 0, 0, 255), 0)
        self._draw_text_with_emoji(img, draw, (60, card_h-190), t_txt, t_f, (255, 255, 255, 255), 0)
        self._draw_text_with_emoji(img, draw, (62, card_h-98), s_txt, s_f, (0, 0, 0, 255), 0)
        self._draw_text_with_emoji(img, draw, (60, card_h-100), s_txt, s_f, (210, 210, 210, 255), 0)

        coord_txt = f"GPS: {lat:.6f}, {lon:.6f}"
        try: cw = self._get_text_width(draw, coord_txt, c_f)
        except: cw = len(coord_txt) * 20
        draw.rounded_rectangle((35, 35, 35+cw+60, 105), radius=35, fill=(0, 0, 0, 220))
        self._draw_text_with_emoji(img, draw, (65, 50), coord_txt, c_f, (255, 255, 255, 255), 0)

        return self._save_card(img, "geo_card")

    def _render_contact_card(self, first_name, last_name, phone, user_id=0):
        import os, shutil, threading
        from PIL import Image, ImageDraw
        from org.telegram.messenger import FileLoader, UserConfig
        from org.telegram.tgnet import TLRPC
        
        img, draw = self._create_base_card(700, 220, bg=(35, 35, 35, 255), r=24)
        title_f, sub_f, letter_f = self._get_fonts([48, 36, 63])
        full_name = " ".join(filter(None, [first_name, last_name])) or "Неизвестный контакт"
        
        try: rounding_pct = max(0, min(100, int(self.plugin.get_setting("avatar_rounding", "100"))))
        except: rounding_pct = 100
        radius = int((rounding_pct / 100.0) * 70)

        def draw_mask(d, fill_color=255):
            if rounding_pct == 100: d.ellipse((0, 0, 140, 140), fill=fill_color)
            elif rounding_pct == 0: d.rectangle((0, 0, 140, 140), fill=fill_color)
            else: d.rounded_rectangle((0, 0, 140, 140), radius=radius, fill=fill_color)

        avatar_img = None
        if user_id != 0:
            try:
                user = TelegramUtils.get_user(user_id)
                if user and getattr(user, 'photo', None) and not isinstance(user.photo, TLRPC.TL_userProfilePhotoEmpty):
                    pid = getattr(user.photo, 'photo_id', 0)
                    cdir = os.path.join(Filesystem.get_temp_dir(), "avatars_cache")
                    os.makedirs(cdir, exist_ok=True)
                    cpath = os.path.join(cdir, f"u4_{user_id}_{pid}.jpg")

                    if not self._is_valid_image(cpath):
                        fl = FileLoader.getInstance(UserConfig.selectedAccount)
                        best = sorted([s for s in getattr(user.photo, 'sizes', []) if isinstance(s, (TLRPC.TL_photoSize, TLRPC.TL_photoSizeProgressive))], key=lambda s: s.w * s.h, reverse=True)
                        tl_big = best[0] if best else getattr(user.photo, 'photo_big', None)
                        if tl_big:
                            loc = fl.getPathToAttach(tl_big, True)
                            if not (loc and loc.exists() and loc.length() > 0):
                                tl_small = getattr(user.photo, 'photo_small', None)
                                loc = fl.getPathToAttach(tl_small, True) if tl_small else None
                            if loc and loc.exists() and loc.length() > 0:
                                self._copy_image_file(loc.getAbsolutePath(), cpath)
                            else:
                                ev, res = threading.Event(), [None]
                                def on_file(r, e):
                                    try:
                                        if r and hasattr(r, "bytes"):
                                            b = r.bytes.buffer
                                            temp_path = os.path.join(cdir, f"temp_on_file_{uuid.uuid4()}.jpg")
                                            from java.io import FileOutputStream
                                            fos = FileOutputStream(temp_path)
                                            channel = fos.getChannel()
                                            b.rewind()
                                            channel.write(b)
                                            channel.close()
                                            fos.close()
                                            with open(temp_path, "rb") as f:
                                                res[0] = f.read()
                                            os.remove(temp_path)
                                    except:
                                        try:
                                            if r and hasattr(r, "bytes"):
                                                b = r.bytes.buffer
                                                b.rewind()
                                                res[0] = bytes([b.get() & 0xFF for _ in range(b.remaining())])
                                        except: pass
                                    finally: ev.set()
                                req_cls = getattr(TLRPC, "TL_upload_get" + "File")
                                loc_cls = getattr(TLRPC, "TL_inputPeer" + "PhotoFileLocation")
                                req, loc_req = req_cls(), loc_cls()
                                loc_req.big, loc_req.peer, loc_req.photo_id = True, get_messages_controller().getInputPeer(user_id), pid
                                req.location, req.offset, req.limit = loc_req, 0, 1024*1024
                                send_request(req, RequestCallback(on_file))
                                ev.wait(8.0)
                                if res[0]: Filesystem.write_file(cpath, res[0])
                    
                    if self._is_valid_image(cpath):
                        raw = Image.open(cpath).convert("RGBA").resize((140, 140), Image.LANCZOS)
                        mask = Image.new("L", (140, 140), 0)
                        draw_mask(ImageDraw.Draw(mask))
                        raw.putalpha(mask)
                        avatar_img = raw
            except: pass

        if not avatar_img:
            avatar_img = Image.new("RGBA", (140, 140), (0, 0, 0, 0))
            adraw = ImageDraw.Draw(avatar_img)
            colors = [(255, 81, 106), (255, 136, 94), (142, 133, 238), (83, 237, 151), (40, 201, 183), (84, 156, 252), (255, 124, 168)]
            draw_mask(adraw, fill_color=colors[abs(user_id) % 7] + (255,))
            letter = full_name[0].upper()
            try:
                w, h = adraw.textlength(letter, font=letter_f), 63
                adraw.text(((140 - w) // 2, (140 - h) // 2 - 7), letter, font=letter_f, fill=(255, 255, 255, 255))
            except: pass
        
        img.paste(avatar_img, (40, 40), avatar_img)
        draw.text((210, 55), full_name[:20] + ("..." if len(full_name)>20 else ""), font=title_f, fill=(255, 255, 255, 255))
        draw.text((210, 125), phone[:25], font=sub_f, fill=(180, 180, 180, 255))
        return self._save_card(img, "contact_card")

    def _render_dice_card(self, emoticon, value):
        img, draw = self._create_base_card(500, 240)
        emoji_img = EmojiRenderer.render_emoji_to_pil(emoticon, 130)
        if emoji_img: img.paste(emoji_img, (50, 55), emoji_img)
        val_f, sub_f = self._get_fonts([96, 34])
        draw.text((220, 50), "Выпало:", font=sub_f, fill=(160, 165, 175, 255))
        draw.text((220, 100), str(value), font=val_f, fill=(255, 255, 255, 255))
        return self._save_card(img, "dice_card")

    def _render_poll_card(self, question, options, total_voters, is_closed):
        from PIL import Image, ImageDraw
        card_w, padding_x, padding_y, option_h, spacing, footer_h = 1400, 40, 60, 100, 25, 90
        
        title_f, opt_f, pct_f, sub_f = self._get_fonts([56, 40, 44, 34])
        temp_draw = ImageDraw.Draw(Image.new("RGB", (1, 1)))
        
        max_title_w = card_w - padding_x * 2
        wrapped_title = self._wrap_text(temp_draw, question, title_f, max_title_w)
        _, title_h = self._measure_text_dimensions(temp_draw, wrapped_title, title_f, 10)
        
        header_h = title_h + 15
        card_h = padding_y + header_h + (option_h + spacing) * len(options) + footer_h
        
        card_img, draw = self._create_base_card(card_w, card_h, bg=(30, 32, 36, 255), r=48)
        self._draw_text_with_emoji(card_img, draw, (padding_x, padding_y), wrapped_title, title_f, (255, 255, 255, 255), 10, max_width=max_title_w)
        
        current_y = padding_y + header_h
        max_bar_w = card_w - padding_x * 2
        max_voters = max([opt["voters"] for opt in options] + [1])
        
        for opt in options:
            draw.rounded_rectangle((padding_x, current_y, card_w - padding_x, current_y + option_h), radius=28, fill=(45, 48, 54, 255))
            bar_w = max(56, int(max_bar_w * (opt["voters"] / max_voters))) if opt["voters"] > 0 else 0
            
            if bar_w > 0:
                bar_color = (64, 150, 240, 255) if opt["chosen"] else (80, 85, 95, 255)
                draw.rounded_rectangle((padding_x, current_y, padding_x + bar_w, current_y + option_h), radius=28, fill=bar_color)
                
            right_text = f'{opt["voters"]} ({opt["percent"]}%)'
            try: right_w = int(pct_f.getlength(right_text) if hasattr(pct_f, 'getlength') else draw.textlength(right_text, font=pct_f))
            except: right_w = len(right_text) * 22
            
            text_x_offset = padding_x + 30
            if opt["chosen"]:
                cx, cy = text_x_offset + 10, current_y + option_h // 2
                draw.line([(cx - 8, cy), (cx - 2, cy + 8), (cx + 12, cy - 10)], fill=(255, 255, 255, 255), width=4)
                text_x_offset += 35
                
            opt_disp = opt["text"]
            max_opt_w = card_w - padding_x * 2 - right_w - (125 if opt["chosen"] else 90)
            
            if self._get_text_width(draw, opt_disp, opt_f) > max_opt_w:
                while len(opt_disp) > 0 and self._get_text_width(draw, opt_disp + "...", opt_f) > max_opt_w: opt_disp = opt_disp[:-1]
                opt_disp += "..."
                
            try: text_h = draw.textbbox((0, 0), "M", font=opt_f)[3] - draw.textbbox((0, 0), "M", font=opt_f)[1]
            except: text_h = 40
            
            text_y_offset = (option_h - text_h) // 2 - 4
            self._draw_text_with_emoji(card_img, draw, (text_x_offset, current_y + text_y_offset), opt_disp, opt_f, (255, 255, 255, 255), 0)
            
            try: draw.text((card_w - padding_x - right_w - 30, current_y + text_y_offset), right_text, font=pct_f, fill=(255, 255, 255, 255))
            except: pass
            
            current_y += option_h + spacing

        footer_text = f"Проголосовало: {total_voters:,}".replace(",", " ") + ("  •  Опрос завершен" if is_closed else "")
        try: draw.text((padding_x, current_y + 15), footer_text, font=sub_f, fill=(150, 155, 165, 255))
        except: pass

        return self._save_card(card_img, "poll_card")

    def _render_transcription_card(self, text, duration_sec=0, transcription_enabled=True):
        import uuid
        import os
        from PIL import Image, ImageDraw, ImageFont, ImageFilter

        padding = 50
        spacing_text = 12
        offset_y = 0
        
        try:
            offset_text_x = -int(self.plugin.get_setting("trans_offset_x", "0"))
            offset_text_y = -int(self.plugin.get_setting("trans_offset_y", "0"))
        except:
            offset_text_x = 0
            offset_text_y = 0

        try:
            font_path = FontManager.get(self.font_index, self.plugin).get_path()
            title_font = ImageFont.truetype(font_path, 121)
            text_font = ImageFont.truetype(font_path, 96)
            sub_font = ImageFont.truetype(font_path, 81)
        except:
            title_font = ImageFont.load_default()
            text_font = ImageFont.load_default()
            sub_font = ImageFont.load_default()

        temp_img = Image.new("RGB", (1, 1))
        temp_draw = ImageDraw.Draw(temp_img)

        has_text = bool(text and text.strip()) and transcription_enabled

        try:
            title_text_measure = "Расшифровка аудио" if has_text else "Голосовое сообщение"
            dur_int = int(duration_sec)
            dur_text_measure = f"Длительность: {dur_int // 60}:{dur_int % 60:02d}" if dur_int > 0 else ""
            
            model_text = ""
            if has_text and transcription_enabled:
                try:
                    p_id = int(self.plugin.get_setting("transcription_provider", 2))
                except Exception:
                    p_id = 2
                if p_id == 0:
                    p_name, m_name = "Gemini", self.plugin.get_setting("trans_model", "gemini-2.5-flash")
                elif p_id == 1:
                    p_name, m_name = "NavyAI", self.plugin.get_setting("trans_model_navy", "gpt-4o-transcribe")
                elif p_id == 2:
                    p_name, m_name = "Mistral", self.plugin.get_setting("trans_model_mistral", "voxtral-mini-latest")
                elif p_id == 3:
                    p_name, m_name = "Deepgram", self.plugin.get_setting("trans_model_deepgram", "nova-3-general")
                else:
                    p_name, m_name = "Unknown", "Unknown"
                model_text = f"Модель ({p_name}): {m_name}"

            title_w = int(temp_draw.textlength(title_text_measure, font=title_font))
            dur_w = int(temp_draw.textlength(dur_text_measure, font=sub_font)) if dur_text_measure else 0
            model_w = int(temp_draw.textlength(model_text, font=sub_font)) if model_text else 0
            
            if has_text:
                raw_text_w = int(self._get_text_width(temp_draw, text.replace('\n', ' '), text_font))
                char_count = len(text)
                optimal_w = int(600 + (char_count * 20))
                content_w = min(raw_text_w, optimal_w)
                card_w = max(title_w, dur_w, model_w, content_w) + padding * 2 + 110
            else:
                card_w = max(title_w, dur_w) + padding * 2 + 110
                
            card_w = max(600, min(5200, card_w))
            
            if getattr(self, 'layout_index', 0) == 2:
                card_w = int(card_w * 1.25)
                card_w = min(5200, card_w)
        except:
            card_w = 945

        if has_text:
            display_text = text
            max_text_w = card_w - padding * 2 - 50
            wrapped_text = self._wrap_text(temp_draw, display_text, text_font, max_text_w)
            _, text_h = self._measure_text_dimensions(temp_draw, wrapped_text, text_font, 10)
        else:
            wrapped_text = ""
            text_h = 0
            spacing_text = 0

        header_h = 144
        footer_h = 160 if (has_text and transcription_enabled) else 112
        
        if has_text:
            card_h = padding * 2 + header_h + spacing_text * 2 + text_h + footer_h + 20
        else:
            card_h = padding * 2 + 224
        
        card_img = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        draw = ImageDraw.Draw(card_img)

        bg_color = (35, 38, 43, 255)
        border_color = (70, 75, 85, 255)
        
        shadow = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        s_draw = ImageDraw.Draw(shadow)
        s_draw.rounded_rectangle((10, 10, card_w - 10, card_h - 10), radius=45, fill=(0, 0, 0, 90))
        shadow = shadow.filter(ImageFilter.GaussianBlur(15))
        card_img.paste(shadow, (0, 0), shadow)

        draw.rounded_rectangle((6, 6, card_w - 6, card_h - 6), radius=42, fill=bg_color)
        draw.rounded_rectangle((padding, padding - 8, padding + 11, card_h - padding + 8), radius=5, fill=(64, 150, 240, 255))

        title_text = "Расшифровка аудио" if (has_text and transcription_enabled) else "Голосовое сообщение"
        trans_offset = -4 if transcription_enabled else 0
        
        if has_text:
            title_y = padding + offset_y + trans_offset if transcription_enabled else padding
        else:
            title_y = padding
            
        self._draw_text_with_emoji(card_img, draw, (padding + 40 + offset_text_x, title_y + offset_text_y), title_text, title_font, (255, 255, 255, 255), 5)
        
        current_y = padding + header_h
        
        if has_text:
            current_y += spacing_text
            self._draw_text_with_emoji(card_img, draw, (padding + 40 + offset_text_x, current_y + offset_y + trans_offset + offset_text_y), wrapped_text, text_font, (220, 225, 230, 255), 10)
            current_y += text_h + spacing_text - 8
        else:
            current_y += -8
            
        duration_sec = int(duration_sec)
        mins = duration_sec // 60
        secs = duration_sec % 60
        footer_text = f"Длительность: {mins}:{secs:02d}" if duration_sec > 0 else ""
        
        try:
            if footer_text:
                if has_text:
                    footer_y = current_y + (offset_y + trans_offset if transcription_enabled else 0)
                else:
                    footer_y = current_y
                draw.text((padding + 35 + offset_text_x, footer_y + offset_text_y), footer_text, font=sub_font, fill=(150, 155, 165, 255))
            
            if has_text and transcription_enabled:
                try:
                    p_id = int(self.plugin.get_setting("transcription_provider", 2))
                except Exception:
                    p_id = 2
                if p_id == 0:
                    p_name, m_name = "Gemini", self.plugin.get_setting("trans_model", "gemini-2.5-flash")
                elif p_id == 1:
                    p_name, m_name = "NavyAI", self.plugin.get_setting("trans_model_navy", "gpt-4o-transcribe")
                elif p_id == 2:
                    p_name, m_name = "Mistral", self.plugin.get_setting("trans_model_mistral", "voxtral-mini-latest")
                elif p_id == 3:
                    p_name, m_name = "Deepgram", self.plugin.get_setting("trans_model_deepgram", "nova-3-general")
                else:
                    p_name, m_name = "Unknown", "Unknown"
                model_text = f"Модель ({p_name}): {m_name}"
                model_y = footer_y + 107 if footer_text else current_y + (offset_y + trans_offset if transcription_enabled else 0)
                draw.text((padding + 35 + offset_text_x, model_y + offset_text_y), model_text, font=sub_font, fill=(150, 155, 165, 255))
        except:
            pass

        out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"transcription_card_{uuid.uuid4()}.png")
        card_img.save(out_path, "PNG")
        return out_path

    def _render_giveaway_card(self, quantity, months, stars, until_date, is_results, unclaimed, extra_info):
        import uuid
        from PIL import Image, ImageDraw, ImageFont, ImageFilter
        from datetime import datetime

        padding = 50
        
        try:
            font_path = FontManager.get(self.font_index, self.plugin).get_path()
            title_font = ImageFont.truetype(font_path, 76)
            prize_font = ImageFont.truetype(font_path, 60)
            info_font = ImageFont.truetype(font_path, 46)
            extra_font = ImageFont.truetype(font_path, 38)
        except:
            title_font = ImageFont.load_default()
            prize_font = ImageFont.load_default()
            info_font = ImageFont.load_default()
            extra_font = ImageFont.load_default()

        temp_img = Image.new("RGB", (1, 1))
        temp_draw = ImageDraw.Draw(temp_img)

        title_text = "🎉 Итоги розыгрыша" if is_results else "🎁 Розыгрыш"
        prize_text = f"{stars} Telegram Stars" if stars else f"Telegram Premium"
        
        if stars:
            per_winner = stars // quantity if quantity > 0 else 0
            count_text = f"Победителей: {quantity} (каждому по {per_winner} ⭐️)"
        else:
            count_text = f"Победителей: {quantity} (каждому на {months} мес.)"

        if is_results:
            status_text = f"Призов не забрали: {unclaimed}" if unclaimed > 0 else "Все призы разданы!"
        else:
            try:
                dt = datetime.fromtimestamp(until_date)
                status_text = f"Итоги: {dt.strftime('%d.%m.%Y %H:%M')}"
            except:
                status_text = "Итоги: Скоро"

        try:
            t_w = int(temp_draw.textlength(title_text, font=title_font))
            p_w = int(temp_draw.textlength(f"Приз: {prize_text}", font=prize_font))
            c_w = int(temp_draw.textlength(count_text, font=info_font))
            s_w = int(temp_draw.textlength(status_text, font=info_font))
            
            try:
                e_w = max([int(temp_draw.textlength(line, font=extra_font)) for line in extra_info.split('\n')]) if extra_info else 0
            except:
                e_w = 0
            
            card_w = max(t_w, p_w, c_w, s_w, e_w) + padding * 2 + 100
            
            if getattr(self, 'layout_index', 0) == 2:
                card_w = int(card_w * 1.25)
                
            card_w = max(500, min(1200, card_w))
        except:
            card_w = 1200

        max_extra_w = card_w - padding * 2 - 90
        wrapped_extra = self._wrap_text(temp_draw, extra_info, extra_font, max_extra_w)
        
        try:
            _, extra_h = self._measure_text_dimensions(temp_draw, wrapped_extra, extra_font, 10)
        except:
            extra_h = 50

        card_h = padding * 2 + 300 + extra_h + 20
        
        card_img = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        draw = ImageDraw.Draw(card_img)

        bg_color = (25, 20, 35, 255) if is_results else (30, 25, 45, 255)
        border_color = (255, 215, 0, 255) if is_results else (138, 43, 226, 255)
        
        shadow = Image.new("RGBA", (card_w, card_h), (0, 0, 0, 0))
        s_draw = ImageDraw.Draw(shadow)
        s_draw.rounded_rectangle((10, 10, card_w - 10, card_h - 10), radius=50, fill=(0, 0, 0, 120))
        shadow = shadow.filter(ImageFilter.GaussianBlur(20))
        card_img.paste(shadow, (0, 0), shadow)

        draw.rounded_rectangle((6, 6, card_w - 6, card_h - 6), radius=45, fill=bg_color, outline=border_color)
        draw.rounded_rectangle((padding, padding, padding + 12, card_h - padding), radius=8, fill=border_color)

        self._draw_text_with_emoji(card_img, draw, (padding + 45, padding), title_text, title_font, (255, 255, 255, 255), 5)
        self._draw_text_with_emoji(card_img, draw, (padding + 45, padding + 110), f"Приз: {prize_text}", prize_font, (230, 230, 250, 255), 5)
        self._draw_text_with_emoji(card_img, draw, (padding + 45, padding + 200), count_text, info_font, (200, 200, 220, 255), 5)
        self._draw_text_with_emoji(card_img, draw, (padding + 45, padding + 260), status_text, info_font, (150, 150, 170, 255), 5)
        self._draw_text_with_emoji(card_img, draw, (padding + 45, padding + 330), wrapped_extra, extra_font, (130, 130, 150, 255), 10)

        out_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"giveaway_card_{uuid.uuid4()}.png")
        card_img.save(out_path, "PNG")
        return out_path

    def _render_webpage_card(self, site_name, title, description, thumb_path=""):
        import os
        from PIL import Image, ImageDraw
        
        card_w = 1200
        padding = 45
        
        try:
            font_path = FontManager.get(self.font_index, self.plugin).get_path()
            site_font = ImageFont.truetype(font_path, 42)
            title_font = ImageFont.truetype(font_path, 48)
            desc_font = ImageFont.truetype(font_path, 38)
        except:
            site_font = ImageFont.load_default()
            title_font = ImageFont.load_default()
            desc_font = ImageFont.load_default()

        temp_img = Image.new("RGB", (1, 1))
        temp_draw = ImageDraw.Draw(temp_img)
        
        max_text_w = card_w - padding * 2 - 40
        
        wrapped_site = self._wrap_text(temp_draw, site_name, site_font, max_text_w) if site_name else ""
        wrapped_title = self._wrap_text(temp_draw, title, title_font, max_text_w) if title else ""
        
        if description and len(description) > 144:
            description = description[:109] + "..."
            
        wrapped_desc = self._wrap_text(temp_draw, description, desc_font, max_text_w) if description else ""
        
        site_w, site_h = self._measure_text_dimensions(temp_draw, wrapped_site, site_font, 10) if site_name else (0, 0)
        title_w, title_h = self._measure_text_dimensions(temp_draw, wrapped_title, title_font, 10) if title else (0, 0)
        desc_w, desc_h = self._measure_text_dimensions(temp_draw, wrapped_desc, desc_font, 10) if description else (0, 0)
        
        text_height = 0
        if site_name: text_height += site_h + 15
        if title: text_height += title_h + 15
        if description: text_height += desc_h + 15
        
        thumb_img = None
        thumb_h = 0
        if thumb_path and os.path.exists(thumb_path):
            try:
                raw_thumb = Image.open(thumb_path).convert("RGBA")
                tw, th = raw_thumb.size
                if tw > 0 and th > 0:
                    target_w = card_w - padding * 2 - 40
                    target_h = int(target_w * th / tw)
                    thumb_img = raw_thumb.resize((target_w, target_h), Image.LANCZOS)
                    mask = Image.new("L", thumb_img.size, 0)
                    ImageDraw.Draw(mask).rounded_rectangle((0, 0, thumb_img.size[0], thumb_img.size[1]), radius=15, fill=255)
                    thumb_img.putalpha(mask)
                    thumb_h = thumb_img.size[1]
            except:
                thumb_img = None

        card_h = padding * 2 + text_height
        if thumb_img:
            card_h += thumb_h + 20
            
        img, draw = self._create_base_card(card_w, card_h, bg=(35, 38, 43, 255), r=45)
        
        draw.line([(padding, padding), (padding, card_h - padding)], fill=(64, 150, 240, 255), width=12)
        
        current_y = padding
        text_x = padding + 35
        
        prefetch_list = []
        if site_name: prefetch_list.append((wrapped_site, site_font))
        if title: prefetch_list.append((wrapped_title, title_font))
        if description: prefetch_list.append((wrapped_desc, desc_font))
        if prefetch_list: self._prefetch_all_emojis(prefetch_list)

        if site_name:
            self._draw_text_with_emoji(img, draw, (text_x, current_y), wrapped_site, site_font, (64, 150, 240, 255), 10)
            current_y += site_h + 15
            
        if title:
            self._draw_text_with_emoji(img, draw, (text_x, current_y), wrapped_title, title_font, (255, 255, 255, 255), 10)
            current_y += title_h + 15
            
        if description:
            self._draw_text_with_emoji(img, draw, (text_x, current_y), wrapped_desc, desc_font, (180, 180, 180, 255), 10)
            current_y += desc_h + 15
            
        if thumb_img:
            img.paste(thumb_img, (text_x, current_y + 5), thumb_img)
            
        return self._save_card(img, "webpage_card")

    def _download_voice_message(self, document, message_owner):
        try:
            current_account = UserConfig.selectedAccount
            file_loader = FileLoader.getInstance(current_account)
            
            file_path_obj = file_loader.getPathToMessage(message_owner)
            
            if not file_path_obj or not os.path.exists(file_path_obj.getAbsolutePath()):
                file_loader.loadFile(document, message_owner, 1, 0)
                
                import time
                for _ in range(30):
                    if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 0:
                        break
                    time.sleep(0.5)
            
            if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()):
                return file_path_obj.getAbsolutePath()
            return None
        except Exception as e:
            qlog(f"Voice download error: {e}")
            return None

    def _transcribe_voice(self, file_path):
        try:
            extended_logs = self.plugin.get_setting("extended_logging", False)
            run_on_ui_thread(lambda: BulletinHelper.show_info("Начинаю расшифровку..."))
            
            try:
                provider = int(self.plugin.get_setting("transcription_provider", 2))
            except Exception:
                provider = 2
            
            provider_names = {0: "gemini", 1: "navy", 2: "mistral", 3: "deepgram"}
            qlog(f"[TRANSCRIPTION] Provider selected: {provider_names.get(provider, 'unknown')} (ID: {provider})")
            qlog(f"[TRANSCRIPTION] File path: {file_path}")

            if extended_logs:
                qlog(f"Starting transcription. Provider ID: {provider}, File: {file_path}")
            
            text = None

            if provider == 0:
                api_key = self.plugin.get_setting("trans_key_manual", "AIzaSyD8kUluAcDVA-VpHtcaeAW_HQ_dAf44q3s")
                model = self.plugin.get_setting("trans_model", "gemini-2.5-flash")
                
                import base64
                with open(file_path, "rb") as f:
                    audio_data = base64.b64encode(f.read()).decode('utf-8')
                
                url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent"
                headers = {"Content-Type": "application/json", "x-goog-api-key": api_key}
                payload = {
                    "contents": [{
                        "parts": [
                            {"text": "Transcribe this audio to text. Return only the transcribed text without any additional comments or formatting."},
                            {"inline_data": {"mime_type": "audio/ogg", "data": audio_data}}
                        ]
                    }]
                }
                
                response = _r_post(url, headers=headers, json=payload, timeout=60)
                if response.status_code == 200:
                    result = response.json()
                    try:
                        text = result["candidates"][0]["content"]["parts"][0]["text"]
                        if extended_logs: qlog("Gemini transcription success")
                    except (KeyError, IndexError):
                        qlog(f"Gemini parse error: {result}")
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка разбора ответа Gemini"))
                else:
                    qlog(f"Gemini Error {response.status_code}: {response.text}")
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"Gemini API Error: {response.status_code}"))

            elif provider == 1:
                api_key = self.plugin.get_setting("trans_key_navy", "sk-navy-bRHcCluxPrlkLkIB5qKJFGPEJOl1cL91xcqxO4vYfeg")
                model = self.plugin.get_setting("trans_model_navy", "gpt-4o-transcribe")
                
                url = "https://api.navy/v1/audio/transcriptions"
                headers = {"Authorization": f"Bearer {api_key}"}
                
                with open(file_path, "rb") as f:
                    files = {"file": ("voice.ogg", f, "audio/ogg")}
                    data = {"model": model, "response_format": "json"}
                    response = _r_post(url, headers=headers, files=files, data=data, timeout=60)
                
                if response.status_code == 200:
                    text = response.json().get("text", "")
                    if extended_logs: qlog("NavyAI transcription success")
                else:
                    qlog(f"NavyAI Error {response.status_code}: {response.text}")
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"NavyAI Error: {response.status_code}"))

            elif provider == 2:
                api_key = self.plugin.get_setting("trans_key_mistral", "6dc9clGWIO3RJJkoty0PNIlJ7QOICqbF")
                model = self.plugin.get_setting("trans_model_mistral", "voxtral-mini-latest")
                
                if not api_key:
                    run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка: Не указан ключ Mistral"))
                    return None

                url = "https://api.mistral.ai/v1/audio/transcriptions"
                headers = {"Authorization": f"Bearer {api_key}"}
                
                with open(file_path, "rb") as f:
                    files = {"file": ("voice.ogg", f, "audio/ogg")}
                    data = {"model": model}
                    response = _r_post(url, headers=headers, files=files, data=data, timeout=60)
                
                if response.status_code == 200:
                    text = response.json().get("text", "")
                    if extended_logs: qlog("Mistral transcription success")
                else:
                    qlog(f"Mistral Error {response.status_code}: {response.text}")
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"Mistral Error: {response.status_code}"))

            elif provider == 3:
                api_key = self.plugin.get_setting("trans_key_deepgram", "011fb75d769d83fe88822e0c6f4e45cee8810116")
                model = self.plugin.get_setting("trans_model_deepgram", "nova-3-general")
                
                url = f"https://api.deepgram.com/v1/listen?model={model}&punctuate=true&detect_language=true"
                headers = {
                    "Authorization": f"Token {api_key}",
                    "Content-Type": "audio/*",
                }

                with open(file_path, "rb") as audio_file:
                    response = _r_post(url, headers=headers, data=audio_file, timeout=60)

                if response.status_code == 200:
                    try:
                        text = response.json()["results"]["channels"][0]["alternatives"][0]["transcript"]
                        if extended_logs: qlog("Deepgram transcription success")
                    except (KeyError, IndexError):
                        qlog(f"Deepgram parse error: {response.text}")
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка разбора ответа Deepgram"))
                else:
                    qlog(f"Deepgram Error {response.status_code}: {response.text}")
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"Deepgram Error: {response.status_code}"))

            if text:
                run_on_ui_thread(lambda: BulletinHelper.show_success("Расшифровка завершена!"))
                return text.strip()
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error("Не удалось получить ответ от API"))
                return None

        except Exception as e:
            qlog(f"Transcription error: {e}")
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка расшифровки (см. логи)"))
            return None

    def _fetch_attached_media(self):
        import os
        import shutil
        import time
        from client_utils import get_last_fragment
        from hook_utils import get_private_field
        
        if getattr(self, 'media_fetch_attempted', False):
            return getattr(self, 'cached_media_paths', None)
        self.media_fetch_attempted = True
        self.cached_media_paths = []
        
        reply_msg = getattr(self.params, 'replyToMsg', None)
        if not reply_msg:
            return None

        allow_multiple = self.plugin.get_setting("quote_multiple_media", True)
        
        msgs = []
        group_id = 0

        if allow_multiple:
            try:
                mo = getattr(reply_msg, 'messageOwner', reply_msg)
                if hasattr(mo, 'grouped_id'):
                    group_id = getattr(mo, 'grouped_id')
                elif hasattr(mo, 'getGroupId'):
                    group_id = mo.getGroupId()
            except Exception:
                pass

            try:
                frag = get_last_fragment()
                if frag:
                    selected = None
                    try: selected = frag.getSelectedMessages()
                    except: pass
                    
                    if not selected:
                        try: selected = get_private_field(frag, "selectedMessages")
                        except: pass
                    
                    if selected:
                        try:
                            for i in range(10): 
                                try:
                                    item = selected[i]
                                    if hasattr(item, 'valueAt'):
                                        for j in range(item.size()):
                                            msgs.append(item.valueAt(j))
                                except (IndexError, TypeError, KeyError):
                                    break
                        except Exception:
                            if hasattr(selected, 'valueAt'):
                                for i in range(selected.size()):
                                    msgs.append(selected.valueAt(i))

                    if not msgs and group_id and group_id != 0:
                        chat_msgs = None
                        try: chat_msgs = frag.getMessages()
                        except: pass
                        
                        if not chat_msgs:
                            try: chat_msgs = get_private_field(frag, "messages")
                            except: pass
                        
                        if chat_msgs and hasattr(chat_msgs, 'size'):
                            for i in range(chat_msgs.size()):
                                m = chat_msgs.get(i)
                                m_owner = getattr(m, 'messageOwner', m)
                                m_group = 0
                                try:
                                    if hasattr(m_owner, 'grouped_id'): m_group = getattr(m_owner, 'grouped_id')
                                    elif hasattr(m_owner, 'getGroupId'): m_group = m_owner.getGroupId()
                                except: pass
                                
                                if m_group == group_id:
                                    msgs.append(m)
            except Exception:
                pass

        if not msgs:
            msgs = [reply_msg]

        unique_msgs = []
        seen_ids = set()
        for m in msgs:
            try:
                mo = getattr(m, 'messageOwner', m)
                m_id = getattr(mo, 'id', getattr(m, 'id', 0))
                if callable(m_id): m_id = m_id()
                if m_id not in seen_ids and m_id != 0:
                    seen_ids.add(m_id)
                    unique_msgs.append(m)
            except:
                unique_msgs.append(m)
        
        try:
            unique_msgs.sort(key=lambda m: getattr(getattr(m, 'messageOwner', m), 'id', getattr(m, 'id', 0)))
        except:
            pass

        if not unique_msgs:
            unique_msgs = [reply_msg]

        try:
            if not getattr(self, 'override_quote_text', None):
                replied_mo = getattr(reply_msg, 'messageOwner', reply_msg)
                replied_text = getattr(replied_mo, 'message', getattr(replied_mo, 'caption', ''))
                if not replied_text:
                    for m in unique_msgs:
                        mo = getattr(m, 'messageOwner', m)
                        t = getattr(mo, 'message', getattr(mo, 'caption', ''))
                        if t:
                            self.override_quote_text = str(t)
                            break
        except Exception:
            pass

        paths = []
        for i, msg in enumerate(unique_msgs):
            p = self._fetch_single_media(msg)
            if p and os.path.exists(p):
                ext_p = os.path.splitext(p)[1] or ".jpg"
                if "card" in str(p):
                    new_p = os.path.join(os.path.dirname(p), f"q_media_card_{i}_{int(time.time()*1000)}{ext_p}")
                else:
                    new_p = os.path.join(os.path.dirname(p), f"q_media_{i}_{int(time.time()*1000)}{ext_p}")
                if self._copy_image_file(p, new_p) and self._is_valid_image(new_p):
                    if new_p not in paths:
                        paths.append(new_p)
                else:
                    qlog(f"media: не удалось скопировать вложение {p}")
   
        if paths:
            self.cached_media_paths = paths
            return paths
        return None

    def _fetch_single_media(self, reply_msg):
        import os
        import time
        if not self.plugin.get_setting("quote_render_image", True):
            return None
        try:
            message_owner = getattr(reply_msg, 'messageOwner', reply_msg)
            if not message_owner or not hasattr(message_owner, 'media'):
                return None
            media = message_owner.media

            if isinstance(media, TLRPC.TL_messageMediaDice):
                emoticon = getattr(media, 'emoticon', '🎲')
                value = getattr(media, 'value', 0)
                card_path = self._render_dice_card(emoticon, value)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path
                    
            if isinstance(media, TLRPC.TL_messageMediaPoll):
                poll = getattr(media, 'poll', None)
                results = getattr(media, 'results', None)
                if poll:
                    question_obj = getattr(poll, 'question', "Опрос")
                    question = getattr(question_obj, 'text', question_obj) if hasattr(question_obj, 'text') else str(question_obj)
                    total_voters = getattr(results, 'total_voters', 0) if results else 0
                    is_closed = getattr(poll, 'closed', False)
                    
                    options = []
                    
                    if hasattr(poll, 'answers') and poll.answers:
                        for i in range(poll.answers.size()):
                            ans = poll.answers.get(i)
                            ans_text_obj = getattr(ans, 'text', "")
                            option_text = getattr(ans_text_obj, 'text', ans_text_obj) if hasattr(ans_text_obj, 'text') else str(ans_text_obj)
                            option_data = getattr(ans, 'option', b"")
                            
                            voters = 0
                            percent = 0
                            chosen = False
                            
                            if results and hasattr(results, 'results') and results.results:
                                for j in range(results.results.size()):
                                    res = results.results.get(j)
                                    if getattr(res, 'option', b"") == option_data:
                                        voters = getattr(res, 'voters', 0)
                                        chosen = getattr(res, 'chosen', False)
                                        if total_voters > 0:
                                            percent = int(round((voters / total_voters) * 100))
                                        break
                                        
                            options.append({
                                "text": str(option_text),
                                "voters": voters,
                                "percent": percent,
                                "chosen": chosen
                            })
                    
                    card_path = self._render_poll_card(question, options, total_voters, is_closed)
                    if card_path:
                        self.cached_media_path = card_path
                        return card_path

            elif hasattr(TLRPC, 'TL_messageMediaGiveaway') and isinstance(media, TLRPC.TL_messageMediaGiveaway):
                quantity = getattr(media, 'quantity', 0)
                months = getattr(media, 'months', 0)
                stars = getattr(media, 'stars', 0)
                until_date = getattr(media, 'until_date', 0)
                
                channels = getattr(media, 'channels', None)
                ch_count = channels.size() if channels else 0
                
                countries = getattr(media, 'countries_iso2', None)
                c_list = [str(countries.get(i)) for i in range(countries.size())] if countries else []
                c_str = ", ".join(c_list) if c_list else "Все"
                
                only_new = getattr(media, 'only_new_subscribers', False)
                
                extra = f"Условия: Подписка на {ch_count} кан.\n| Страны: {c_str}"
                if only_new:
                    extra += " | Только новые участники"
                
                card_path = self._render_giveaway_card(quantity, months, stars, until_date, False, 0, extra)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path
                    
            elif hasattr(TLRPC, 'TL_messageMediaGiveawayResults') and isinstance(media, TLRPC.TL_messageMediaGiveawayResults):
                winners = getattr(media, 'winners_count', 0)
                unclaimed = getattr(media, 'unclaimed_count', 0)
                months = getattr(media, 'months', 0)
                stars = getattr(media, 'stars', 0)
                
                w_list = getattr(media, 'winners', None)
                w_ids = [str(w_list.get(i)) for i in range(w_list.size())] if w_list else []
                w_str = ", ".join(w_ids)
                
                extra = f"ID Победителей: {w_str}" if w_ids else "Победители скрыты"
                
                card_path = self._render_giveaway_card(winners, months, stars, 0, True, unclaimed, extra)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path

            if hasattr(media, 'document') and media.document:
                document = media.document
                if hasattr(document, 'attributes'):
                    is_voice = False
                    duration = 0
                    
                    for i in range(document.attributes.size()):
                        attr = document.attributes.get(i)
                        if isinstance(attr, TLRPC.TL_documentAttributeAudio):
                            if getattr(attr, 'voice', False):
                                is_voice = True
                                duration = getattr(attr, 'duration', 0)
                                break
                                
                    if is_voice:
                        transcription = ""
                        
                        try:
                            vt = getattr(reply_msg, 'voiceTranscription', None)
                            if vt: transcription = str(vt.toString()) if hasattr(vt, 'toString') else str(vt)
                        except: pass
                        
                        if not transcription.strip() and self.plugin.get_setting("enable_transcription", True):
                            voice_path = self._download_voice_message(document, message_owner)
                            if voice_path:
                                raw_trans = self._transcribe_voice(voice_path)
                                if raw_trans:
                                    transcription = str(raw_trans)
                                    
                        if not transcription.strip():
                            try:
                                mt = getattr(reply_msg, 'messageText', None)
                                if mt: transcription = str(mt.toString()) if hasattr(mt, 'toString') else str(mt)
                            except: pass
                            
                        if not transcription.strip():
                            transcription = str(getattr(message_owner, 'message', ""))
                            
                        if not transcription.strip():
                            transcription = str(getattr(message_owner, 'caption', ""))

                        transcription = transcription.strip()
                        
                        card_path = self._render_transcription_card(transcription.strip(), duration, self.plugin.get_setting("enable_transcription", True))
                        if card_path:
                            self.cached_media_path = card_path
                            self.override_quote_text = " "
                            return card_path

            current_account = UserConfig.selectedAccount
            file_loader = FileLoader.getInstance(current_account)
                            
            if isinstance(media, TLRPC.TL_messageMediaPhoto) and media.photo:
                photo = media.photo
                file_path_obj = file_loader.getPathToMessage(message_owner)
                
                if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 0:
                    self.cached_media_path = file_path_obj.getAbsolutePath()
                    return self.cached_media_path

                largest = None
                max_dim = 0
                for size in photo.sizes:
                    if isinstance(size, (TLRPC.TL_photoSize, TLRPC.TL_photoSizeProgressive)):
                        d = max(getattr(size, 'w', 0), getattr(size, 'h', 0))
                        if d >= max_dim:
                            max_dim = d
                            largest = size
                
                if largest:
                    file_path_obj = file_loader.getPathToAttach(largest, True)
                    if not file_path_obj or not file_path_obj.exists() or file_path_obj.length() == 0:
                        image_location = ImageLocation.getForPhoto(largest, photo)
                        if image_location:
                            try: file_loader.loadFile(image_location, None, "jpg", 0, 1)
                            except Exception:
                                try: file_loader.loadFile(image_location, "jpg", None, 1)
                                except Exception: pass
                            for _ in range(40):
                                file_path_obj = file_loader.getPathToAttach(largest, True)
                                if file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0:
                                    break
                                time.sleep(0.05)
                                
                    if file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0:
                        self.cached_media_path = file_path_obj.getAbsolutePath()
                        return self.cached_media_path
                return None

            if isinstance(media, (TLRPC.TL_messageMediaGeo, TLRPC.TL_messageMediaVenue, TLRPC.TL_messageMediaGeoLive)):
                lat, lon = 0.0, 0.0
                title, address = "", ""
                if hasattr(media, 'geo') and media.geo:
                    lat = getattr(media.geo, 'lat', 0.0)
                    if hasattr(media.geo, '_long'): lon = media.geo._long
                    elif hasattr(media.geo, 'long'): lon = media.geo.long
                    elif hasattr(media.geo, 'lon'): lon = media.geo.lon
                    elif hasattr(media.geo, 'lng'): lon = media.geo.lng
                
                if isinstance(media, TLRPC.TL_messageMediaVenue):
                    title = getattr(media, 'title', "")
                    address = getattr(media, 'address', "")
                
                card_path = self._render_geo_card(lat, lon, title, address)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path

            if isinstance(media, TLRPC.TL_messageMediaDice):
                emoticon = getattr(media, 'emoticon', '🎲')
                value = getattr(media, 'value', 0)
                card_path = self._render_dice_card(emoticon, value)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path

            if isinstance(media, TLRPC.TL_messageMediaContact):
                first_name = getattr(media, 'first_name', "")
                last_name = getattr(media, 'last_name', "")
                phone_number = getattr(media, 'phone_number', "")
                user_id = getattr(media, 'user_id', 0)
                card_path = self._render_contact_card(first_name, last_name, phone_number, user_id)
                if card_path:
                    self.cached_media_path = card_path
                    return card_path

            if self.plugin.get_setting("quote_link_preview", True) and getattr(TLRPC, 'TL_messageMediaWebPage', None) and isinstance(media, TLRPC.TL_messageMediaWebPage):
                try:
                    webpage = getattr(media, 'webpage', None)
                    if webpage and "TL_webPage" in webpage.__class__.__name__:
                        site_name = getattr(webpage, 'site_name', "") or ""
                        title = getattr(webpage, 'title', "") or ""
                        description = getattr(webpage, 'description', "") or ""
                        
                        thumb_path = None
                        photo = getattr(webpage, 'photo', None)
                        document = getattr(webpage, 'document', None)

                        def get_existing_path(loader, thumb):
                            for opt in [True, False]:
                                try:
                                    p = loader.getPathToAttach(thumb, opt)
                                    if p and p.exists() and p.length() > 0:
                                        return p.getAbsolutePath()
                                except: pass
                            try:
                                p = loader.getPathToAttach(thumb)
                                if p and p.exists() and p.length() > 0:
                                    return p.getAbsolutePath()
                            except: pass
                            return None
                        
                        if photo and file_loader:
                            best_thumb = None
                            sizes = getattr(photo, 'sizes', None)
                            if sizes:
                                for i in range(sizes.size()):
                                    size = sizes.get(i)
                                    area = getattr(size, 'w', 0) * getattr(size, 'h', 0)
                                    best_area = getattr(best_thumb, 'w', 0) * getattr(best_thumb, 'h', 0) if best_thumb else 0
                                    if not best_thumb or area > best_area:
                                        best_thumb = size
                                if not best_thumb and sizes.size() > 0:
                                    best_thumb = sizes.get(sizes.size() - 1)
                                    
                            if best_thumb:
                                thumb_path = get_existing_path(file_loader, best_thumb)
                                if not thumb_path:
                                    try:
                                        loc = ImageLocation.getForPhoto(best_thumb, photo)
                                        if loc:
                                            try: file_loader.loadFile(loc, None, "jpg", 0, 1)
                                            except:
                                                try: file_loader.loadFile(loc, "jpg", None, 1)
                                                except:
                                                    try: file_loader.loadFile(loc, "jpg", 0, 1)
                                                    except: pass
                                            for _ in range(40):
                                                thumb_path = get_existing_path(file_loader, best_thumb)
                                                if thumb_path:
                                                    break
                                                import time
                                                time.sleep(0.05)
                                    except: pass

                        if not thumb_path and document and file_loader:
                            is_video = False
                            is_gif = False
                            if hasattr(document, 'attributes'):
                                for i in range(document.attributes.size()):
                                    attr = document.attributes.get(i)
                                    if isinstance(attr, TLRPC.TL_documentAttributeVideo): is_video = True
                                    elif isinstance(attr, TLRPC.TL_documentAttributeAnimated): is_gif = True
                            
                            mime = getattr(document, "mime_type", "") or ""
                            if mime.startswith("video/") or mime in ("video/webm", "video/mp4", "image/gif"):
                                is_video = True

                            best_thumb = None
                            sizes = getattr(document, 'thumbs', None)
                            if sizes:
                                for i in range(sizes.size()):
                                    size = sizes.get(i)
                                    area = getattr(size, 'w', 0) * getattr(size, 'h', 0)
                                    best_area = getattr(best_thumb, 'w', 0) * getattr(best_thumb, 'h', 0) if best_thumb else 0
                                    if not best_thumb or area > best_area:
                                        best_thumb = size
                                if not best_thumb and sizes.size() > 0:
                                    best_thumb = sizes.get(sizes.size() - 1)

                            video_sizes = getattr(document, 'video_thumbs', None)
                            if not best_thumb and video_sizes:
                                for i in range(video_sizes.size()):
                                    size = video_sizes.get(i)
                                    area = getattr(size, 'w', 0) * getattr(size, 'h', 0)
                                    best_area = getattr(best_thumb, 'w', 0) * getattr(best_thumb, 'h', 0) if best_thumb else 0
                                    if not best_thumb or area > best_area:
                                        best_thumb = size
                                if not best_thumb and video_sizes.size() > 0:
                                    best_thumb = video_sizes.get(video_sizes.size() - 1)
                                    
                            if best_thumb:
                                thumb_path = get_existing_path(file_loader, best_thumb)
                                if not thumb_path:
                                    try:
                                        loc = ImageLocation.getForDocument(best_thumb, document)
                                        if not loc: loc = ImageLocation.getForDocument(document)
                                        if loc:
                                            try: file_loader.loadFile(loc, None, "jpg", 0, 1)
                                            except:
                                                try: file_loader.loadFile(loc, "jpg", None, 1)
                                                except:
                                                    try: file_loader.loadFile(loc, "jpg", 0, 1)
                                                    except: pass
                                            for _ in range(40):
                                                thumb_path = get_existing_path(file_loader, best_thumb)
                                                if thumb_path:
                                                    break
                                                import time
                                                time.sleep(0.05)
                                    except: pass

                            if thumb_path:
                                converted = self._ensure_raster_image(thumb_path)
                                if converted:
                                    thumb_path = converted

                            if not thumb_path and (is_video or is_gif):
                                file_path_obj = file_loader.getPathToAttach(document, True)
                                if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                                    file_path_obj = file_loader.getPathToAttach(document, False)
                                if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                                    file_path_obj = file_loader.getPathToAttach(document)
                                    
                                if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                                    try: file_loader.loadFile(document, message_owner, 1, 1)
                                    except: pass
                                    for k in range(80):
                                        file_path_obj = file_loader.getPathToAttach(document, True)
                                        if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                                            file_path_obj = file_loader.getPathToAttach(document, False)
                                        if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 1000:
                                            break
                                        import time
                                        time.sleep(0.05)
                                        
                                if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 1000:
                                    converted = self._get_video_first_frame(file_path_obj.getAbsolutePath())
                                    if converted:
                                        thumb_path = converted

                        card_path = self._render_webpage_card(site_name, title, description, thumb_path)
                        if card_path:
                            self.cached_media_path = card_path
                            return card_path
                except: pass

            if hasattr(media, 'document') and media.document:
                document = media.document
                mime = getattr(document, "mime_type", "") or ""
                
                is_gif = False
                is_video = False
                is_music = False
                is_sticker = False
                is_voice = False
                audio_title, audio_performer, audio_duration = "", "", 0
                
                if hasattr(document, 'attributes'):
                    for i in range(document.attributes.size()):
                        attr = document.attributes.get(i)
                        if isinstance(attr, TLRPC.TL_documentAttributeSticker):
                            is_sticker = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeAnimated):
                            is_gif = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeVideo):
                            is_video = True
                            if getattr(attr, 'round_message', False):
                                self.is_round_media = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeAudio):
                            if getattr(attr, 'voice', False):
                                is_voice = True
                            else:
                                is_music = True
                                audio_title = getattr(attr, 'title', "")
                                audio_performer = getattr(attr, 'performer', "")
                                audio_duration = getattr(attr, 'duration', 0)
                        elif hasattr(attr, 'file_name') and str(attr.file_name).lower().endswith('.gif'):
                            is_gif = True
                                
                if not is_sticker and mime == "application/x-tgsticker": is_sticker = True
                if mime == "image/gif": is_gif = True
                
                if is_video or getattr(self, 'is_round_media', False):
                    is_music = False
                    is_voice = False

                is_file = not (is_sticker or is_gif or is_video or is_music or is_voice or mime == "audio/ogg")

                if is_sticker or is_gif or is_video or is_music or is_file:
                    if is_sticker: self.is_sticker_media = True
                    thumb_path = None
                    try:
                        thumbs_count = document.thumbs.size() if hasattr(document, 'thumbs') and document.thumbs else 0
                        
                        if mime == "image/webp":
                            doc_path = file_loader.getPathToAttach(document, True)
                            if not doc_path or not doc_path.exists() or doc_path.length() == 0:
                                file_loader.loadFile(document, "webp", 0, 1)
                                for _ in range(40):
                                    doc_path = file_loader.getPathToAttach(document, True)
                                    if doc_path and doc_path.exists() and doc_path.length() > 0: break
                                    time.sleep(0.05)
                            if doc_path and doc_path.exists() and doc_path.length() > 0:
                                thumb_path = doc_path.getAbsolutePath()
                        else:
                            best_thumb = None
                            if thumbs_count > 0:
                                for i in range(thumbs_count):
                                    t = document.thumbs.get(i)
                                    if hasattr(t, 'w'):
                                        if not best_thumb or getattr(t, 'w', 0) > getattr(best_thumb, 'w', 0):
                                            best_thumb = t
                            if best_thumb:
                                tp = file_loader.getPathToAttach(best_thumb, True)
                                if not tp or not tp.exists() or tp.length() == 0:
                                    try:
                                        loc = ImageLocation.getForDocument(best_thumb, document)
                                    except Exception:
                                        loc = None
                                    if not loc:
                                        try: loc = ImageLocation.getForDocument(document)
                                        except Exception: loc = None
                                    if loc:
                                        try: file_loader.loadFile(loc, message_owner, "jpg", 0, 1)
                                        except Exception:
                                            try: file_loader.loadFile(loc, "jpg", 0, 1)
                                            except Exception: pass
                                        for _ in range(40):
                                            tp = file_loader.getPathToAttach(best_thumb, True)
                                            if tp and tp.exists() and tp.length() > 0: break
                                            time.sleep(0.05)
                                if tp and tp.exists() and tp.length() > 0:
                                    thumb_path = tp.getAbsolutePath()
                    except Exception: pass

                    if is_file:
                        file_name, file_ext, file_size_str = "", "", ""
                        try:
                            if hasattr(document, 'attributes'):
                                for i in range(document.attributes.size()):
                                    attr = document.attributes.get(i)
                                    if hasattr(attr, 'file_name') and attr.file_name: file_name = str(attr.file_name); break
                                    elif hasattr(attr, 'fileName') and attr.fileName: file_name = str(attr.fileName); break
                            if not file_name:
                                from org.telegram.messenger import FileLoader as TgFileLoader
                                doc_name = TgFileLoader.getDocumentFileName(document)
                                file_name = str(doc_name) if doc_name else "Unknown File"
                            if '.' in file_name:
                                file_ext = file_name.rsplit('.', 1)[-1].lower()
                            size_val = getattr(document, 'size', 0)
                            if size_val > 0:
                                if size_val < 1024: file_size_str = f"{size_val} B"
                                elif size_val < 1024 * 1024: file_size_str = f"{round(size_val / 1024, 2)} KB"
                                else: file_size_str = f"{round(size_val / (1024 * 1024), 2)} MB"
                        except Exception: pass
                            
                        card_path = self._render_file_card(file_name, file_size_str, file_ext, thumb_path)
                        if card_path:
                            self.cached_media_path = card_path
                            return card_path

                    if is_music:
                        if not audio_title:
                            try:
                                from org.telegram.messenger import FileLoader as TgFileLoader
                                doc_name = TgFileLoader.getDocumentFileName(document)
                                if doc_name:
                                    import os
                                    audio_title = os.path.splitext(doc_name)[0]
                            except: pass
                            if not audio_title: audio_title = "Неизвестная Музыка"
                        if not audio_performer: audio_performer = "Неизвестный Автор"
                        
                        current_progress = 0.0
                        try:
                            from org.telegram.messenger import MediaController as TgMediaController
                            mc = TgMediaController.getInstance()
                            playing_msg = mc.getPlayingMessageObject()
                            if playing_msg and playing_msg.getDocument() and playing_msg.getDocument().id == document.id:
                                current_progress = getattr(playing_msg, 'audioProgress', 0.0)
                        except Exception: pass
                            
                        audio_abs_path = ""
                        try:
                            from org.telegram.messenger import FileLoader as TgFileLoader
                            from org.telegram.messenger import UserConfig as TgUserConfig
                            import os
                            fl = TgFileLoader.getInstance(TgUserConfig.selectedAccount)
                            def check_path(p): return p and os.path.exists(str(p)) and os.path.getsize(str(p)) > 0
                                
                            raw_msg = getattr(message_owner, 'messageOwner', message_owner)
                            paths_to_try = [
                                getattr(message_owner, 'attachPath', ""),
                                getattr(raw_msg, 'attachPath', ""),
                                fl.getPathToMessage(message_owner).getAbsolutePath() if fl.getPathToMessage(message_owner) else "",
                                fl.getPathToAttach(document, True).getAbsolutePath() if fl.getPathToAttach(document, True) else ""
                            ]
                            for p in paths_to_try:
                                if check_path(p):
                                    audio_abs_path = str(p)
                                    break
                            if not audio_abs_path:
                                doc_id_str = str(document.id)
                                dirs_to_check = [
                                    fl.getDirectory(TgFileLoader.MEDIA_DIR_AUDIO),
                                    fl.getDirectory(TgFileLoader.MEDIA_DIR_DOCUMENT),
                                    fl.getDirectory(TgFileLoader.MEDIA_DIR_CACHE)
                                ]
                                for d in dirs_to_check:
                                    if d and d.exists() and d.isDirectory():
                                        try:
                                            for f_name in os.listdir(d.getAbsolutePath()):
                                                if f_name.startswith(doc_id_str):
                                                    found_path = os.path.join(d.getAbsolutePath(), f_name)
                                                    if check_path(found_path):
                                                        audio_abs_path = found_path
                                                        break
                                        except Exception: pass
                                    if audio_abs_path: break
                        except Exception: pass
                        
                        card_path = self._render_audio_card(audio_title, audio_performer, audio_duration, thumb_path, current_progress, audio_abs_path)
                        if card_path:
                            self.cached_media_path = card_path
                            return card_path

                    import os
                    import time
                    
                    if mime == "application/x-tgsticker":
                        if thumb_path:
                            converted = self._ensure_raster_image(thumb_path)
                            if converted:
                                self.cached_media_path = converted
                                return converted

                        file_path_obj = file_loader.getPathToAttach(document, True)
                        if not file_path_obj or not os.path.exists(file_path_obj.getAbsolutePath()) or os.path.getsize(file_path_obj.getAbsolutePath()) == 0:
                            try: file_loader.loadFile(document, message_owner, 1, 0)
                            except: file_loader.loadFile(document, "tgs", 0, 1)
                            for k in range(40):
                                file_path_obj = file_loader.getPathToAttach(document, True)
                                if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 0:
                                    break
                                time.sleep(0.05)
                                
                        if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()):
                            converted = self._render_tgs_frame(file_path_obj.getAbsolutePath())
                            if converted:
                                self.cached_media_path = converted
                                return converted

                    if mime.startswith("video/"):
                        is_video = True
                    if is_video or is_gif or mime in ("video/webm", "video/mp4", "image/gif") or (is_sticker and mime == "video/webm") or getattr(self, 'is_round_media', False):
                        qlog(f"media: видео/gif (mime={mime}), thumb_path={thumb_path}")
                        if thumb_path:
                            converted = self._ensure_raster_image(thumb_path)
                            if converted:
                                self.cached_media_path = converted
                                return converted

                        doc_id_str = str(document.id)
                        attach_name = ""
                        try:
                            from org.telegram.messenger import FileLoader as TgFileLoader
                            attach_name = str(TgFileLoader.getAttachFileName(document))
                        except:
                            pass

                        scan_video, scan_thumbs = [], []
                        for dtype in (FileLoader.MEDIA_DIR_CACHE, FileLoader.MEDIA_DIR_IMAGE, FileLoader.MEDIA_DIR_VIDEO, FileLoader.MEDIA_DIR_DOCUMENT):
                            try:
                                d = file_loader.getDirectory(dtype)
                                if not d: continue
                                dpath = d.getAbsolutePath()
                                if os.path.exists(dpath):
                                    for name in os.listdir(dpath):
                                        fp = os.path.join(dpath, name)
                                        if not os.path.isfile(fp): continue
                                        try: fsize = os.path.getsize(fp)
                                        except: continue
                                        if fsize <= 0: continue
                                        
                                        if attach_name and name == attach_name:
                                            scan_video.append((fsize, fp))
                                        elif doc_id_str in name:
                                            low = name.lower()
                                            if low.endswith((".jpg", ".jpeg", ".png", ".webp")) and fsize > 3 * 1024:
                                                scan_thumbs.append((fsize, fp))
                                            elif fsize > 100 * 1024:
                                                scan_video.append((fsize, fp))
                            except Exception as scan_e:
                                qlog(f"media scan error in dir {dtype}: {scan_e}")
                                continue
                        qlog(f"media: скан по doc_id ({doc_id_str}) / name ({attach_name}): видео-кандидатов {len(scan_video)}, превью-кандидатов {len(scan_thumbs)}")
                        for fsize, fp in sorted(scan_video, reverse=True):
                            converted = self._get_video_first_frame(fp)
                            if converted:
                                qlog(f"media: кадр из стрим-кэша {fp} ({fsize} байт)")
                                self.cached_media_path = converted
                                return converted
                        if scan_thumbs:
                            fsize, fp = max(scan_thumbs)
                            converted = self._ensure_raster_image(fp)
                            if converted:
                                qlog(f"media: превью из скана кэша {fp} ({fsize} байт)")
                                self.cached_media_path = converted
                                return converted

                        best_thumb = None
                        thumbs_list = []
                        if hasattr(document, 'thumbs') and document.thumbs:
                            for i in range(document.thumbs.size()):
                                thumbs_list.append(document.thumbs.get(i))
                        if hasattr(document, 'video_thumbs') and document.video_thumbs:
                            for i in range(document.video_thumbs.size()):
                                thumbs_list.append(document.video_thumbs.get(i))

                        for t in thumbs_list:
                            if hasattr(t, 'w') and (not best_thumb or getattr(t, 'w', 0) > getattr(best_thumb, 'w', 0)):
                                best_thumb = t

                        if best_thumb:
                            try:
                                loc = ImageLocation.getForDocument(best_thumb, document)
                            except Exception:
                                try:
                                    loc = ImageLocation.getForDocument(document)
                                except Exception:
                                    loc = None
                                
                            if loc:
                                try: file_loader.loadFile(loc, message_owner, "jpg", 1, 1)
                                except Exception:
                                    try: file_loader.loadFile(loc, "jpg", 1, 1)
                                    except Exception: pass
                                    
                                for _ in range(60):
                                    tp = file_loader.getPathToAttach(best_thumb, True)
                                    if not (tp and tp.exists() and tp.length() > 0):
                                        tp = file_loader.getPathToAttach(best_thumb, False)
                                    if not (tp and tp.exists() and tp.length() > 0):
                                        tp = file_loader.getPathToAttach(best_thumb)
                                    if tp and tp.exists() and tp.length() > 0:
                                        converted = self._ensure_raster_image(tp.getAbsolutePath())
                                        if converted:
                                            self.cached_media_path = converted
                                            return converted
                                    time.sleep(0.05)

                        file_path_obj = file_loader.getPathToAttach(document, True)
                        if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                            file_path_obj = file_loader.getPathToAttach(document, False)
                        if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                            file_path_obj = file_loader.getPathToAttach(document)
                            
                        if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 1000:
                            converted = self._get_video_first_frame(file_path_obj.getAbsolutePath())
                            if converted:
                                self.cached_media_path = converted
                                return converted

                        try:
                            file_loader.loadFile(document, message_owner, 1, 1)
                        except:
                            try:
                                file_loader.loadFile(document, "mp4", 1, 1)
                            except:
                                try:
                                    file_loader.loadFile(document, True, 1)
                                except:
                                    pass

                        for k in range(100):
                            file_path_obj = file_loader.getPathToAttach(document, True)
                            if not (file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0):
                                file_path_obj = file_loader.getPathToAttach(document, False)
                            if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()) and os.path.getsize(file_path_obj.getAbsolutePath()) > 1000:
                                converted = self._get_video_first_frame(file_path_obj.getAbsolutePath())
                                if converted:
                                    self.cached_media_path = converted
                                    return converted
                            time.sleep(0.05)

                        if best_thumb:
                            for force in (True, False):
                                tp = file_loader.getPathToAttach(best_thumb, force)
                                if tp and tp.exists() and tp.length() > 0:
                                    converted = self._ensure_raster_image(tp.getAbsolutePath())
                                    if converted:
                                        qlog("media: превью видео докачалось со второй попытки")
                                        self.cached_media_path = converted
                                        return converted

                        try:
                            stripped = None
                            if hasattr(document, 'thumbs') and document.thumbs:
                                for i in range(document.thumbs.size()):
                                    t = document.thumbs.get(i)
                                    if isinstance(t, TLRPC.TL_photoStrippedSize):
                                        stripped = getattr(t, 'bytes', None)
                                        break
                            if stripped:
                                bmp = ImageLoader.getStrippedPhotoBitmap(stripped, None)
                                if bmp:
                                    sp = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"stripped_media_{uuid.uuid4()}.jpg")
                                    fos = FileOutputStream(sp)
                                    bmp.compress(Bitmap.CompressFormat.JPEG, 90, fos)
                                    fos.close()
                                    qlog("media: использую stripped-превью видео (размытое)")
                                    self.cached_media_path = sp
                                    return sp
                        except Exception as e:
                            qlog(f"media: stripped-превью не вышло: {e}")

                        qlog("media: не удалось получить кадр видео (превью и файл недоступны)")

                    if thumb_path:
                        converted = self._ensure_raster_image(thumb_path)
                        if converted:
                            self.cached_media_path = converted
                            return converted
                            
                    file_path_obj = file_loader.getPathToAttach(document, True)
                    if file_path_obj and os.path.exists(file_path_obj.getAbsolutePath()):
                         converted = self._ensure_raster_image(file_path_obj.getAbsolutePath())
                         if converted:
                             self.cached_media_path = converted
                             return converted

            return None
        except Exception:
            return None

    def _create_media_collage(self, paths):
        from PIL import Image, ImageDraw
        images = []
        is_cards = any("card" in str(p) for p in paths)
        for p in paths:
            try:
                images.append(Image.open(p).convert("RGBA"))
            except Exception:
               pass
        
        if not images:
            return None
            
        count = len(images)
        if count > 10:
            images = images[:10]
            count = 10
            
        if count == 1:
            return images[0]
            
        if is_cards:
            total_width = 1200
            resized_images = []
            total_height = 0
            
            for img in images:
                w, h = img.size
                if w <= 0 or h <= 0: continue
                ratio = total_width / float(w)
                new_h = int(h * ratio)
                resized_images.append(img.resize((total_width, new_h), Image.LANCZOS))
                total_height += new_h

            collage = Image.new("RGBA", (total_width, total_height), (0, 0, 0, 0))
            draw = ImageDraw.Draw(collage)
            draw.rounded_rectangle((0, 0, total_width, total_height), radius=45, fill=(35, 35, 35, 255))
            
            current_y = 0
            for i, img in enumerate(resized_images):
                collage.paste(img, (0, current_y), img)
                if i > 0:
                    draw.line([(0, current_y), (total_width, current_y)], fill=(55, 55, 55, 255), width=3)
                current_y += img.size[1]
                
            mask = Image.new("L", (total_width, total_height), 0)
            ImageDraw.Draw(mask).rounded_rectangle((0, 0, total_width, total_height), radius=45, fill=255)
            final_collage = Image.new("RGBA", (total_width, total_height), (0, 0, 0, 0))
            final_collage.paste(collage, (0, 0), mask=mask)
            return final_collage

        layouts = {
            2: [2],
            3: [3],
            4: [2, 2],
            5: [3, 2],
            6: [3, 3],
            7: [4, 3],
            8: [4, 4],
            9: [3, 3, 3],
            10: [4, 3, 3]
        }
        
        rows_layout = layouts.get(count, [3])
        total_width = 1200
        spacing = 10
        
        row_data = []
        total_height = 0
        idx = 0
        
        for row_count in rows_layout:
            row_images = images[idx:idx + row_count]
            ratios = [img.size[0] / img.size[1] for img in row_images]
            sum_ratios = sum(ratios)
            
            available_width = total_width - (row_count - 1) * spacing
            row_height = int(available_width / sum_ratios)
            
            max_h = 2000 if row_count > 1 else 3000
            if row_height > max_h:
                row_height = max_h
                
            row_widths = []
            for i, r in enumerate(ratios):
                if i == row_count - 1:
                    w = available_width - sum(row_widths)
                else:
                    w = int(available_width * (r / sum_ratios))
                row_widths.append(w)
                
            row_data.append({
                'height': row_height,
                'widths': row_widths,
                'images': row_images
            })
            total_height += row_height
            idx += row_count
            
        total_height += (len(rows_layout) - 1) * spacing
        
        collage = Image.new("RGBA", (total_width, total_height), (0, 0, 0, 0))
        
        current_y = 0
        for r_data in row_data:
            current_x = 0
            for i, img in enumerate(r_data['images']):
                w = r_data['widths'][i]
                h = r_data['height']
                
                if w <= 0 or h <= 0:
                    continue
                    
                img_ratio = img.size[0] / img.size[1]
                target_ratio = w / h
                
                if img_ratio > target_ratio:
                    new_w = int(img.size[1] * target_ratio)
                    left = (img.size[0] - new_w) // 2
                    img_cropped = img.crop((left, 0, left + new_w, img.size[1]))
                else:
                    new_h = int(img.size[0] / target_ratio)
                    top = (img.size[1] - new_h) // 2
                    img_cropped = img.crop((0, top, img.size[0], top + new_h))
                    
                img_resized = img_cropped.resize((w, h), Image.LANCZOS)
                collage.paste(img_resized, (current_x, current_y))
                
                current_x += w + spacing
            current_y += r_data['height'] + spacing
            
        mask = Image.new("L", (total_width, total_height), 0)
        draw = ImageDraw.Draw(mask)
        draw.rounded_rectangle((0, 0, total_width, total_height), radius=24, fill=255)
        
        final_collage = Image.new("RGBA", (total_width, total_height), (0, 0, 0, 0))
        final_collage.paste(collage, (0, 0), mask=mask)
        
        return final_collage

    def _resolve_user_from_query(self, query):
        query = query.strip().rstrip(',')
        try:
            telegram_domains = ["t.me", "telegram.me", "telegram.dog"]
            for domain in telegram_domains:
                patterns = [f"https://{domain}/", f"{domain}/"]
                for pattern in patterns:
                    if query.lower().startswith(pattern):
                        username_part = query[len(pattern):].split('/')[0].split('?')[0].strip()
                        if username_part:
                            qlog(f"Resolving username from {pattern}: @{username_part}")
                            self._resolve_by_username(username_part)
                            return True
            
            if query.lower().startswith("tg://user?id="):
                user_id = int(re.search(r'\d+', query).group())
                self._resolve_by_id(user_id)
                return True
            
            if query.lower().startswith("id "):
                user_id = int(query[3:].strip())
                self._resolve_by_id(user_id)
                return True
            
            if query.startswith("+") and query[1:].isdigit():
                self._resolve_by_phone(query)
                return True
                
            if query.startswith("@"):
                self._resolve_by_username(query[1:])
                return True
                
            if query.isdigit():
                user_id = int(query)
                self._resolve_by_id(user_id)
                return True
            
            return False
            
        except (ValueError, TypeError, AttributeError) as e:
            qlog(f"Error parsing query '{query}': {e}. Treating as name override.")
            return False

    def _resolve_by_id(self, user_id):
        user = TelegramUtils.get_user(user_id)
        if user:
            self.user = user
            self.replyer.name = self._get_full_replyer_name()
            self._fetch_user_avatar(user)
        else:
            qlog(f"User with ID {user_id} not found.")
            self.replyer.name = self.search_query
            if not self.force_custom_avatar:
                if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                    self._create_quote_without_input(skip_service_fallback=True)
            else:
                self._create_quote_without_input(skip_service_fallback=True)

    def _resolve_by_username(self, username):
        qlog(f"Resolving username: @{username}")
        req_cls = getattr(TLRPC, "TL_contacts_resolve" + "Username")
        req = req_cls()
        req.username = username
        send_request(req, RequestCallback(self._handle_resolve_callback))

    def _resolve_by_phone(self, phone):
        qlog(f"Resolving phone: {phone}")
        try:
            req_cls = getattr(TLRPC, "TL_contacts_resolve" + "Phone")
            req = req_cls()
            req.phone = phone
            send_request(req, RequestCallback(self._handle_resolve_callback))
        except Exception as e:
            qlog(f"Failed to create TL_contacts_resolvePhone request: {e}")
            self.replyer.name = self.search_query
            if not self.force_custom_avatar:
                if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                    self._create_quote_without_input(skip_service_fallback=True)
            else:
                self._create_quote_without_input(skip_service_fallback=True)

    def _handle_resolve_callback(self, response, error):
        def run():
            if error or not response:
                self.replyer.name = self.search_query
                if not self.force_custom_avatar:
                    if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                        self._create_quote_without_input(skip_service_fallback=True)
                else:
                    self._create_quote_without_input(skip_service_fallback=True)
                return
            
            self.search_query = None 
        
            if hasattr(response, 'users') and not response.users.isEmpty():
                user = response.users.get(0)
                self.user = user
                self.replyer.name = self._get_full_replyer_name()
                self._fetch_user_avatar(user)
            elif hasattr(response, 'chats') and not response.chats.isEmpty():
                chat = response.chats.get(0)
                
                emoji_suffix = ""
                try:
                    if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                        doc_id = getattr(chat.emoji_status, 'document_id', None)
                        if doc_id:
                            emoji_suffix = f" [CEMOJI:{doc_id}]"
                except Exception:
                    pass
                    
                self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
                self.user = None 
                self._fetch_chat_avatar(chat, response.peer)
            else:
                self.replyer.name = self.search_query if self.search_query else "Unknown"
                if not self.force_custom_avatar:
                    if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                        self._create_quote_without_input(skip_service_fallback=True)
                else:
                    self._create_quote_without_input(skip_service_fallback=True)
        global_executor.submit(run)

    def _is_valid_image(self, path):
        try:
            if not (path and os.path.exists(path) and os.path.getsize(path) > 0):
                return False
            with Image.open(path) as im:
                im.verify()
            return True
        except Exception:
            return False

    def _copy_image_file(self, src, dst):
        try:
            with open(src, "rb") as s, open(dst, "wb") as d:
                shutil.copyfileobj(s, d)
            return True
        except Exception as e:
            qlog(f"avatar: python-копирование не удалось ({e}), пробую через Java")
        try:
            fis = FileInputStream(src)
            fos = FileOutputStream(dst)
            in_ch = fis.getChannel()
            out_ch = fos.getChannel()
            in_ch.transferTo(0, in_ch.size(), out_ch)
            in_ch.close()
            out_ch.close()
            fis.close()
            fos.close()
            return True
        except Exception as e:
            qlog(f"avatar: java-копирование не удалось: {e}")
            return False

    def _fetch_user_avatar(self, user):
        if self.force_custom_avatar and self.custom_avatar_path and os.path.exists(self.custom_avatar_path):
            return self._create_quote_without_input()

        has_real_photo = user and getattr(user, "photo", None) and getattr(user.photo, "photo_id", 0) != 0
        if not has_real_photo:
            qlog(f"avatar: у user {getattr(user, 'id', '?')} нет photo_id (photo={type(getattr(user, 'photo', None)).__name__}) — цитата без аватарки")
            return self._create_quote_without_input()

        temp_dir = Filesystem.get_temp_dir()
        avatars_dir = os.path.join(temp_dir, "avatars_cache")
        if not os.path.exists(avatars_dir):
            os.makedirs(avatars_dir)
            
        cached_path = os.path.join(avatars_dir, f"u4_{user.id}_{user.photo.photo_id}.jpg")

        if self._is_valid_image(cached_path):
            self._create_and_send_image(
                image_path=cached_path,
                output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.png"),
                author=self._get_author(),
                quote=self._get_quote_message(),
                layout_vertical=(self.layout_index == 1)
            )
            return

        def run():
            try:
                qlog(f"avatar: поиск для user={user.id} photo_id={user.photo.photo_id} ({type(user.photo).__name__})")
                current_account = UserConfig.selectedAccount
                file_loader = FileLoader.getInstance(current_account)
                best_size = None
                target_cache_file = None

                if hasattr(user.photo, 'sizes'):
                    sorted_sizes = [s for s in user.photo.sizes if isinstance(s, (TLRPC.TL_photoSize, TLRPC.TL_photoSizeProgressive))]
                    sorted_sizes.sort(key=lambda s: s.w * s.h, reverse=True)
                    if sorted_sizes:
                        best_size = sorted_sizes[0]

                tl_big = best_size if best_size else getattr(user.photo, 'photo_big', None)
                tl_small = getattr(user.photo, 'photo_small', None)

                def send_file(src_path):
                    try:
                        img_path = cached_path
                        if src_path != cached_path:
                            if not self._copy_image_file(src_path, cached_path):
                                img_path = src_path
                        if not self._is_valid_image(img_path):
                            qlog(f"avatar: файл не является валидной картинкой, пропускаю: {src_path}")
                            if img_path == cached_path:
                                try: os.remove(cached_path)
                                except Exception: pass
                            return False
                        self._create_and_send_image(
                            image_path=img_path,
                            output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.png"),
                            author=self._get_author(),
                            quote=self._get_quote_message(),
                            layout_vertical=(self.layout_index == 1)
                        )
                        return True
                    except Exception as e:
                        qlog(f"avatar: send_file error: {e}")
                        return False

                def find_local(tl_loc, tag):
                    if not tl_loc:
                        return None
                    for force in (True, False):
                        try:
                            f = file_loader.getPathToAttach(tl_loc, force)
                            if f and f.exists() and f.length() > 0:
                                qlog(f"avatar: локально найден {tag}: {f.getAbsolutePath()}")
                                return f.getAbsolutePath()
                        except Exception:
                            pass
                    return None

                def find_local_by_scan():
                    try:
                        vols = set()
                        for _loc in (tl_small, getattr(user.photo, 'photo_big', None)):
                            v = getattr(_loc, 'volume_id', None) if _loc else None
                            if v: vols.add(str(v))
                        pid = getattr(user.photo, 'photo_id', 0)
                        if pid: vols.add(str(-int(pid)))
                        cands = []
                        for dtype in (FileLoader.MEDIA_DIR_CACHE, FileLoader.MEDIA_DIR_IMAGE):
                            try:
                                d = FileLoader.getDirectory(dtype)
                                if not d: continue
                                dpath = d.getAbsolutePath()
                                for name in os.listdir(dpath):
                                    if not name.lower().endswith((".jpg", ".jpeg", ".png", ".webp")):
                                        continue
                                    base = name.rsplit('.', 1)[0]
                                    if any(base == v or base.startswith(v + "_") for v in vols):
                                        p = os.path.join(dpath, name)
                                        if os.path.isfile(p) and os.path.getsize(p) > 0:
                                            cands.append(p)
                            except Exception:
                                continue
                        if cands:
                            best = max(cands, key=os.path.getsize)
                            qlog(f"avatar: скан кэша нашёл {len(cands)} файл(ов), беру {best}")
                            return best
                        qlog(f"avatar: скан кэша пуст для volume_id {sorted(vols)}")
                    except Exception as e:
                        qlog(f"avatar: ошибка скана кэша: {e}")
                    return None

                if tl_big:
                    try: target_cache_file = file_loader.getPathToAttach(tl_big, True)
                    except Exception: target_cache_file = None

                p = find_local(tl_big, "photo_big")
                if p and send_file(p): return

                loc = None
                try:
                    loc = ImageLocation.getForUser(user, ImageLocation.TYPE_BIG)
                except Exception as e:
                    qlog(f"avatar: ImageLocation.getForUser не сработал: {e}")
                if loc:
                    try: file_loader.loadFile(loc, user, "jpg", 0, 1)
                    except:
                        try: file_loader.loadFile(loc, None, "jpg", 0, 1)
                        except:
                            try: file_loader.loadFile(loc, "jpg", 0, 1)
                            except Exception as e: qlog(f"avatar: loadFile не сработал: {e}")
                    for _ in range(60):
                        p = find_local(tl_big, "photo_big (докачан)")
                        if p:
                            if send_file(p): return
                            break
                        time.sleep(0.05)
                    qlog("avatar: FileLoader не докачал big за 3с (приватность/сеть?)")

                p = find_local(tl_small, "photo_small")
                if p and send_file(p): return
                p = find_local_by_scan()
                if p and send_file(p): return

                st = getattr(user.photo, 'stripped_thumb', None)
                if st:
                    try:
                        bmp = ImageLoader.getStrippedPhotoBitmap(st, None)
                        if bmp:
                            stripped_path = Filesystem.get_absolute_path(temp_dir, f"stripped_{uuid.uuid4()}.jpg")
                            fos = FileOutputStream(stripped_path)
                            bmp.compress(Bitmap.CompressFormat.JPEG, 90, fos)
                            fos.close()
                            if self._is_valid_image(stripped_path):
                                qlog("avatar: использую stripped_thumb (размытая миниатюра), в кэш не сохраняю")
                                self._create_and_send_image(
                                    image_path=stripped_path,
                                    output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.png"),
                                    author=self._get_author(),
                                    quote=self._get_quote_message(),
                                    layout_vertical=(self.layout_index == 1)
                                )
                                return
                    except Exception as e:
                        qlog(f"avatar: stripped_thumb error: {e}")
                else:
                    qlog("avatar: stripped_thumb отсутствует")

                qlog("avatar: локальных источников нет, ухожу в upload.getFile")
                self._fetch_avatar_via_upload_getfile(user, target_cache_file, cached_path)
            except Exception as e:
                qlog(f"_fetch_user_avatar run error: {e}", e)
                self._fetch_avatar_via_upload_getfile(user, None, cached_path)

        global_executor.submit(run)

    def _fetch_avatar_via_upload_getfile(self, user, target_cache_file, custom_cache_path=None):
        try:
            req_cls = getattr(TLRPC, "TL_upload_get" + "File")
            req = req_cls()
            loc_cls = getattr(TLRPC, "TL_inputPeer" + "PhotoFileLocation")
            location = loc_cls()
            location.big = True
            location.peer = get_messages_controller().getInputPeer(user)
            location.photo_id = user.photo.photo_id
            req.location = location
            req.offset = 0
            req.limit = 1024 * 1024
            send_request(req, RequestCallback(lambda r, e: self._handle_get_file_callback(r, e, target_cache_file, custom_cache_path)))
        except Exception:
            self._fetch_avatar_via_getphotos(user)

    def _fetch_chat_avatar(self, chat, peer=None):
        if self.force_custom_avatar and self.custom_avatar_path and os.path.exists(self.custom_avatar_path):
            return self._create_quote_without_input()
        
        has_chat_photo = chat.photo and getattr(chat.photo, 'photo_id', 0) != 0
        if not has_chat_photo:
            return self._create_quote_without_input()

        temp_dir = Filesystem.get_temp_dir()
        avatars_dir = os.path.join(temp_dir, "avatars_cache")
        if not os.path.exists(avatars_dir):
            os.makedirs(avatars_dir)
            
        cached_path = os.path.join(avatars_dir, f"c_{chat.id}_{chat.photo.photo_id}.jpg")
        
        if os.path.exists(cached_path) and os.path.getsize(cached_path) > 0:
            self._create_and_send_image(
                image_path=cached_path,
                output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.jpg"),
                author=self._get_author(),
                quote=self._get_quote_message(),
                layout_vertical=(self.layout_index == 1)
            )
            return

        def run_fetch():
            try:
                current_account = UserConfig.selectedAccount
                file_loader = FileLoader.getInstance(current_account)
                
                tl_big = getattr(chat.photo, 'photo_big', None)
                if tl_big:
                    target_cache_file = file_loader.getPathToAttach(tl_big, True)
                    if target_cache_file and target_cache_file.exists() and target_cache_file.length() > 0:
                        self._copy_image_file(target_cache_file.getAbsolutePath(), cached_path)
                        self._create_and_send_image(
                            image_path=cached_path,
                            output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.jpg"),
                            author=self._get_author(),
                            quote=self._get_quote_message(),
                            layout_vertical=(self.layout_index == 1)
                        )
                        return
                
                loc = ImageLocation.getForChat(chat, True)
                if not loc:
                    loc = ImageLocation.getForChat(chat, False)
                    
                if loc:
                    try: file_loader.loadFile(loc, "jpg", 0, 1)
                    except:
                        try: file_loader.loadFile(loc, None, "jpg", 0, 1)
                        except: pass
                        
                    for _ in range(60):
                        p = file_loader.getPathToAttach(loc, True)
                        if p and p.exists() and p.length() > 0:
                            self._copy_image_file(p.getAbsolutePath(), cached_path)
                            self._create_and_send_image(
                                image_path=cached_path,
                                output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.jpg"),
                                author=self._get_author(),
                                quote=self._get_quote_message(),
                                layout_vertical=(self.layout_index == 1)
                            )
                            return
                        time.sleep(0.05)
                        
                req_cls = getattr(TLRPC, "TL_upload_get" + "File")
                req = req_cls()
                loc_cls = getattr(TLRPC, "TL_inputPeer" + "PhotoFileLocation")
                location = loc_cls()
                location.big = True
                
                if peer:
                    location.peer = peer
                elif hasattr(chat, 'access_hash'):
                    if chat.id > 0:
                        peer_channel = TLRPC.TL_inputPeerChannel()
                        peer_channel.channel_id = chat.id
                        peer_channel.access_hash = chat.access_hash
                        location.peer = peer_channel
                    else:
                        peer_chat = TLRPC.TL_inputPeerChat()
                        peer_chat.chat_id = abs(chat.id)
                        location.peer = peer_chat
                else:
                    if chat.id < 0:
                        location.peer = get_messages_controller().getInputChannel(chat.id)
                    else:
                        location.peer = get_messages_controller().getInputPeer(chat.id)
                        
                location.photo_id = chat.photo.photo_id
                req.location = location
                req.offset = 0
                req.limit = 1024 * 1024
                
                send_request(req, RequestCallback(lambda r, e: self._handle_get_file_callback(r, e, None, cached_path)))
            except Exception:
                has_username = getattr(chat, 'username', None)
                if not has_username and hasattr(chat, 'usernames') and chat.usernames:
                     has_username = True
                if has_username:
                     self._fetch_avatar_via_web(chat, cached_path)
                else:
                    self._create_quote_without_input()
                
        import threading
        threading.Thread(target=run_fetch).start()

    def _handle_direct_avatar_response(self, response, error, user, cached_path):
        if not error and response:
            self._handle_get_file_callback(response, None, custom_cache_path=cached_path)
        else:
            self._fetch_avatar_via_getphotos(user)

    def _fetch_avatar_via_getphotos(self, user):
        try:
            req_cls = getattr(TLRPC, "TL_photos_getUser" + "Photos")
            req = req_cls()
            input_user = get_messages_controller().getInputUser(user)
            if not input_user:
                if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                    self._create_quote_without_input(skip_service_fallback=True)
                return
            req.user_id = input_user
            req.limit = 1
            req.offset = 0
            req.max_id = 0
            send_request(req, RequestCallback(self._handle_user_photos_callback))
        except Exception:
            if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                self._create_quote_without_input(skip_service_fallback=True)

    def _fetch_avatar_via_web(self, entity, custom_cache_path=None):
        try:
            username = getattr(entity, 'username', None)
            
            if not username and hasattr(entity, 'usernames') and entity.usernames:
                for i in range(entity.usernames.size()):
                    u_obj = entity.usernames.get(i)
                    if getattr(u_obj, 'active', False):
                        username = u_obj.username
                        break
                if not username and entity.usernames.size() > 0:
                    username = entity.usernames.get(0).username

            if not username:
                return self._create_quote_without_input()

            url = f"https://t.me/{username}"
            headers = {'User-Agent': 'Mozilla/5.0'}
            
            html_response = _r_get(url, headers=headers, timeout=10)
            
            avatar_url = None
            match = re.search(r'<meta property="og:image" content="([^"]+)"', html_response.text)
            if match:
                avatar_url = match.group(1)
            else:
                match = re.search(r'<meta name="twitter:image" content="([^"]+)"', html_response.text)
                if match:
                    avatar_url = match.group(1)
                else:
                    match = re.search(r'<img class="tgme_page_photo_image" src="([^"]+)"', html_response.text)
                    if match:
                        avatar_url = match.group(1)
            
            if not avatar_url:
                return self._create_quote_without_input()
            
            avatar_response = _r_get(avatar_url, headers=headers, timeout=10)
            img_data = avatar_response.content

            file_path = custom_cache_path
            if not file_path:
                temp_dir = Filesystem.get_temp_dir()
                file_path = Filesystem.get_absolute_path(temp_dir, f"img_web_{entity.id}.jpg")
            
            if len(img_data) > 100 and (img_data.startswith(b"\xff\xd8\xff") or img_data.startswith(b"\x89PNG") or b"WEBP" in img_data[:16]):
                Filesystem.write_file(file_path, img_data)
            else:
                qlog("Валидация скачанного аватара не пройдена.")
                return self._create_quote_without_input()
            
            self._create_and_send_image(
                image_path=file_path,
                output_path=Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"quote_{uuid.uuid4()}.jpg"),
                author=self._get_author(),
                quote=self._get_quote_message(),
                layout_vertical=(self.layout_index == 1)
            )
        except Exception:
            self._create_quote_without_input()

    def _handle_get_channels_callback(self, response, error):
        if error:
            return self._create_quote_without_input()
        if response and response.chats and response.chats.size() > 0:
            chat = response.chats.get(0)
            
            emoji_suffix = ""
            try:
                if self.plugin.get_setting("show_name_emoji", False) and hasattr(chat, 'emoji_status') and chat.emoji_status:
                    doc_id = getattr(chat.emoji_status, 'document_id', None)
                    if doc_id:
                        emoji_suffix = f" [CEMOJI:{doc_id}]"
            except Exception:
                pass
            
            self.replyer.name = self._sanitize_text(chat.title) + emoji_suffix
            
            peer = self.replyer_id.peer
            if not peer:
                if chat.id < 0:
                    peer = get_messages_controller().getInputChannel(chat.id)
                else:
                    peer = get_messages_controller().getInputPeer(chat.id)

            self._fetch_chat_avatar(chat, peer)

    def _format_file_metadata(self, document, label_format):
        full_name = None
        name_part = "file"
        ext_part = ""
        file_size_str = ""
        
        try:
            if hasattr(document, 'attributes') and document.attributes:
                for i in range(document.attributes.size()):
                    attr = document.attributes.get(i)
                    if hasattr(attr, 'file_name'):
                        fn = attr.file_name
                        if fn:
                            full_name = str(fn)
                            break
                    elif hasattr(attr, 'fileName'):
                        fn = attr.fileName
                        if fn:
                            full_name = str(fn)
                            break
    
            if full_name:
                if '.' in full_name:
                    parts = full_name.rsplit('.', 1)
                    name_part = parts[0]
                    ext_part = parts[1]
                else:
                    name_part = full_name
                    ext_part = ""
            
            size_val = getattr(document, 'size', 0)
            if size_val > 0:
                if size_val < 1024:
                    file_size_str = f"{size_val}b"
                elif size_val < 1024 * 1024:
                    file_size_str = f"{round(size_val / 1024, 2)}kb"
                else:
                    file_size_str = f"{round(size_val / (1024 * 1024), 2)}mb"
                    
        except Exception as e:
            qlog(f"_format_file_metadata error: {e}")
            pass
    
        result = label_format.replace("{name}", name_part).replace("{ext}", ext_part)
        
        if not ext_part and "." in result:
            result = result.replace(".", "")
    
        if "{size}" in result:
            if file_size_str:
                result = result.replace("{size}", file_size_str)
            else:
                result = result.replace("{size}", "")
        
        return result.replace("  ", " ").strip()
        
    def _strip_custom_emojis(self, text, message_owner):
        if not text or not hasattr(message_owner, 'entities') or not message_owner.entities:
            return text
        try:
            u16 = text.encode('utf-16-le')
            events = {}
            for i in range(message_owner.entities.size()):
                e = message_owner.entities.get(i)
                start = e.offset * 2
                end = (e.offset + e.length) * 2
                if isinstance(e, TLRPC.TL_messageEntityCustomEmoji):
                    if start not in events: events[start] = []
                    events[start].append(('replace', end, f"[CEMOJI:{e.document_id}]"))
                else:
                    ot, ct = "", ""
                    if isinstance(e, TLRPC.TL_messageEntityBold): ot, ct = "\x01B\x02", "\x01/B\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityItalic): ot, ct = "\x01I\x02", "\x01/I\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityStrike): ot, ct = "\x01S\x02", "\x01/S\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityUnderline): ot, ct = "\x01U\x02", "\x01/U\x02"
                    elif isinstance(e, TLRPC.TL_messageEntitySpoiler): ot, ct = "\x01SPOIL\x02", "\x01/SPOIL\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityCode): ot, ct = "\x01MONO\x02", "\x01/MONO\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityPre):
                        lang = getattr(e, 'language', '')
                        ot, ct = f"\x01PRE:{lang}\x02", "\x01/PRE\x02"
                    elif getattr(TLRPC, 'TL_messageEntityBlockquote', None) and isinstance(e, TLRPC.TL_messageEntityBlockquote): 
                        ot, ct = "\x01QUOTE\x02", "\x01/QUOTE\x02"
                    elif isinstance(e, TLRPC.TL_messageEntityTextUrl) or isinstance(e, TLRPC.TL_messageEntityUrl) or isinstance(e, TLRPC.TL_messageEntityMention) or isinstance(e, TLRPC.TL_messageEntityHashtag) or isinstance(e, TLRPC.TL_messageEntityBotCommand):
                        ot, ct = "\x01LINK\x02", "\x01/LINK\x02"
                    else:
                        is_phone = getattr(TLRPC, 'TL_messageEntityPhone', None) and isinstance(e, TLRPC.TL_messageEntityPhone)
                        is_email = getattr(TLRPC, 'TL_messageEntityEmail', None) and isinstance(e, TLRPC.TL_messageEntityEmail)
                        if is_phone or is_email:
                            ot, ct = "\x01LINK\x02", "\x01/LINK\x02"
                    
                    if ot and ct:
                        if start not in events: events[start] = []
                        events[start].append(('open', e.length, ot))
                        if end not in events: events[end] = []
                        events[end].append(('close', e.length, ct))
                        
            res = bytearray()
            pos = 0
            while pos <= len(u16):
                if pos in events:
                    evs = events[pos]
                    closes = sorted([ev for ev in evs if ev[0] == 'close'], key=lambda x: x[1])
                    reps = [ev for ev in evs if ev[0] == 'replace']
                    opens = sorted([ev for ev in evs if ev[0] == 'open'], key=lambda x: x[1], reverse=True)
                    for ev in closes: res.extend(ev[2].encode('utf-16-le'))
                    for ev in opens: res.extend(ev[2].encode('utf-16-le'))
                    if reps:
                        rep = reps[0]
                        res.extend(rep[2].encode('utf-16-le'))
                        pos = rep[1]
                        continue
                if pos < len(u16): res.extend(u16[pos:pos+2])
                pos += 2
            return res.decode('utf-16-le')
        except Exception as e:
            qlog(f"[PREMIUM_EMOJI] Ошибка извлечения энтити: {e}")
            return text

    def _get_quote_message(self):
        self._fetch_attached_media()
        
        reply_obj = getattr(self.params, 'replyToMsg', None)
        raw_message = getattr(reply_obj, 'messageOwner', reply_obj)
        original_message = ""

        def _log(m):
            try: qlog(f"[QUOTE_DEBUG] {m}")
            except: pass

        def _extract(obj):
            if not obj: return ""
            if hasattr(obj, "text") and isinstance(getattr(obj, "text"), str):
                return str(obj.text)
            try:
                if hasattr(obj, "toString"):
                    val = str(obj.toString())
                    if val and "org.telegram" not in val: return val
            except: pass
            if isinstance(obj, str) and "org.telegram" not in obj: return obj
            val = str(obj)
            if "org.telegram" not in val: return val
            return ""

        try:
            cmd = getattr(self.params, 'messageOwner', getattr(self.params, 'message', None))
            hdr = getattr(cmd, 'reply_to', None)
            if hdr:
                q_text = getattr(hdr, 'quote_text', None)
                extracted = _extract(q_text)
                if extracted:
                    original_message = extracted
        except: pass

        if not original_message:
            try:
                from hook_utils import get_private_field
                from client_utils import get_last_fragment
                frag = get_last_fragment()
                ev = None
                if frag:
                    try: ev = get_private_field(frag, "chatActivityEnterView")
                    except: pass
                    if not ev and hasattr(frag, "getChatActivityEnterView"):
                        try: ev = frag.getChatActivityEnterView()
                        except: pass
                if ev:
                    r_info = None
                    try: r_info = get_private_field(ev, "replyingMessageInfo")
                    except: pass
                    if r_info:
                        original_message = _extract(get_private_field(r_info, "quote"))
                    if not original_message:
                        original_message = _extract(get_private_field(ev, "replyingQuote"))
            except: pass

        if not original_message:
            try:
                if hasattr(self.params, "selectedText") and self.params.selectedText:
                    original_message = str(self.params.selectedText)
            except: pass

        if not original_message:
            original_message = getattr(raw_message, 'message', getattr(raw_message, 'caption', "")) or ""

        if getattr(self, 'override_quote_text', None) is not None:
            text_to_parse = str(self.override_quote_text)
        else:
            text_to_parse = self._strip_custom_emojis(original_message, raw_message)
            
        if self.plugin.get_setting("render_markdown", True):
            message = self._parse_raw_markdown(text_to_parse)
        else:
            message = text_to_parse

        try:
            should_render_media = self.plugin.get_setting("quote_render_image", True)
            media = getattr(raw_message, 'media', None)

            if should_render_media and media and isinstance(media, TLRPC.TL_messageMediaPhoto):
                return self._sanitize_text(message)
            
            if should_render_media and getattr(self, 'cached_media_paths', getattr(self, 'cached_media_path', None)):
                return self._sanitize_text(message)

            message_type = 999 
            if hasattr(reply_obj, 'type'):
                message_type = reply_obj.type

            if media and isinstance(media, TLRPC.TL_messageMediaWebPage):
                message_type = 999

            document = None
            if media:
                if isinstance(media, TLRPC.TL_messageMediaGame):
                    message_type = 18
                if not isinstance(media, TLRPC.TL_messageMediaWebPage):
                    document = getattr(media, 'document', None)

            transcription = None
            is_emoji_only_message = False
        
            if self._is_emoji_only(original_message):
                is_emoji_only_message = True
            
            if document:
                is_gif = False
                is_video = False
                is_round = False
                is_voice = False
                is_sticker = False 
                is_music = False
                
                if hasattr(document, 'attributes'):
                    for i in range(document.attributes.size()):
                        attr = document.attributes.get(i)
                        if isinstance(attr, TLRPC.TL_documentAttributeAnimated): is_gif = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeSticker): is_sticker = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeVideo):
                            is_video = True
                            if getattr(attr, 'round_message', False): is_round = True
                        elif isinstance(attr, TLRPC.TL_documentAttributeAudio):
                            if getattr(attr, 'voice', False): is_voice = True
                            else: is_music = True

                if is_round: message_type = 5
                elif is_gif: message_type = 8
                elif is_sticker: message_type = 13
                elif is_video: message_type = 3
                elif is_voice: message_type = 2
                elif is_music: message_type = 14
                
                if message_type == 999: message_type = 9

                if is_voice and not is_music and self.plugin.get_setting("enable_transcription", True):
                    voice_path = self._download_voice_message(document, raw_message)
                    if voice_path: transcription = self._transcribe_voice(voice_path)

            label = ""
            
            if message_type == 11 and should_render_media: 
                return self._sanitize_text(message)
            elif message_type in (3, 4, 5, 8, 13, 14) and should_render_media and getattr(self, 'cached_media_paths', getattr(self, 'cached_media_path', None)):
                return self._sanitize_text(message)
            elif message_type == 9:
                raw_label = self.plugin.get_setting("attach_label_file", "[{name}.{ext} {size}]")
                if document: label = self._format_file_metadata(document, raw_label)
                else: label = self.plugin.get_setting("attach_label_none", "[вложение]")
            elif message_type == 2 and transcription:
                label = transcription
            elif message_type == 15 or message_type == 25:
                label = "" 
            elif message_type in range(1, 31):
                label = self.plugin.get_attach_label(message_type)

            if is_emoji_only_message:
                label = ""

            if label:
                if message: message = str(label) + "\n" + message
                else: message = str(label)
            
            return self._sanitize_text(message)
        except Exception as e:
            qlog(f"[ERROR] get_quote_message failed", e)
            return self._sanitize_text(message)

    def _init_replyer_id(self):
        replyer = self._get_replyer()
        replyer_peer = replyer.from_id
        
        if replyer.fwd_from is not None:
            replyer_peer = replyer.fwd_from.from_id
            
            if replyer.fwd_from.from_id is None:
                if hasattr(replyer.fwd_from, 'from_name') and replyer.fwd_from.from_name:
                    self.replyer.name = replyer.fwd_from.from_name
                elif hasattr(replyer.fwd_from, 'saved_from_name') and replyer.fwd_from.saved_from_name:
                    self.replyer.name = replyer.fwd_from.saved_from_name
        
        return ReplyerID(replyer_peer)

    def _get_full_replyer_name(self):
        if self.user:
            first_name = self.user.first_name or ""
            last_name = self.user.last_name or ""
            
            ignore_last_name = self.plugin.get_setting("ignore_last_name", False)
            if ignore_last_name:
                last_name = ""

            emoji_suffix = ""
            try:
                if self.plugin.get_setting("show_name_emoji", False) and hasattr(self.user, 'emoji_status') and self.user.emoji_status:
                    doc_id = getattr(self.user.emoji_status, 'document_id', None)
                    if doc_id:
                        emoji_suffix = f" [CEMOJI:{doc_id}]"
            except Exception:
                pass

            use_contact_data = self.plugin.get_setting("use_contact_data", True)
            if not use_contact_data and self.user.username:
                if not first_name and not last_name:
                    return self._sanitize_text(self.user.username) + emoji_suffix
            
            full_name = " ".join(filter(None, [first_name, last_name])).strip()
            if full_name:
                return self._sanitize_text(full_name) + emoji_suffix
        
        if self.replyer and self.replyer.name:
            return self._sanitize_text(self.replyer.name)
            
        return "Unknown"

    def _get_replyer(self):
        return self.params.replyToMsg.messageOwner

    def _get_replyer_id(self):
        return self.replyer_id.get_id()

    def _handle_user_photos_callback(self, response, error):
        def run():
            if error or not response or not hasattr(response, 'photos') or response.photos.size() == 0:
                if not self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                    self._create_quote_without_input(skip_service_fallback=True)
                return

            try:
                photo = response.photos.get(0)
                target_cache_file = None

                temp_dir = Filesystem.get_temp_dir()
                avatars_dir = os.path.join(temp_dir, "avatars_cache")
                if not os.path.exists(avatars_dir):
                    os.makedirs(avatars_dir)
                
                photo_id = getattr(photo, 'id', 0)
                if photo_id != 0:
                    cache_path = os.path.join(avatars_dir, f"u_{photo_id}.jpg")
                    target_cache_file = File(cache_path)

                sorted_sizes = [s for s in photo.sizes if isinstance(s, (TLRPC.TL_photoSize, TLRPC.TL_photoSizeProgressive))]
                sorted_sizes.sort(key=lambda s: s.w * s.h, reverse=True)

                if not sorted_sizes:
                    return self._fetch_avatar_via_web(self.user)

                best_size = sorted_sizes[0]

                current_account = UserConfig.selectedAccount
                file_loader = FileLoader.getInstance(current_account)
                file_path_obj = file_loader.getPathToAttach(best_size, True)
                if file_path_obj and file_path_obj.exists() and file_path_obj.length() > 0:
                    dest = target_cache_file.getAbsolutePath() if target_cache_file else Filesystem.get_absolute_path(temp_dir, f"temp_{uuid.uuid4()}.jpg")
                    self._copy_image_file(file_path_obj.getAbsolutePath(), dest)
                    self._create_and_send_image(
                        image_path=dest,
                        output_path=Filesystem.get_absolute_path(temp_dir, f"quote_{uuid.uuid4()}.jpg"),
                        author=self._get_author(),
                        quote=self._get_quote_message(),
                        layout_vertical=(self.layout_index == 1)
                    )
                    return

                req = TLRPC.TL_upload_getFile()
                input_file = TelegramUtils.create_input_location(photo, best_size)
                req.location = input_file
                req.offset = 0
                req.limit = 1024 * 1024 * 4
                send_request(req, RequestCallback(lambda r, e: self._handle_get_file_callback(r, e, target_cache_file)))
            except Exception:
                return self._fetch_avatar_via_web(self.user)
        global_executor.submit(run)

    def _try_fetch_username_avatar(self, username):
        if username == FALLBACK_AVATAR_USERNAME:
            temp_dir = Filesystem.get_temp_dir()
            cache_path = os.path.join(temp_dir, "fallback_cache.jpg")
            
            if os.path.exists(cache_path) and os.path.getsize(cache_path) > 0:
                self._create_and_send_image(
                    image_path=cache_path,
                    output_path=Filesystem.get_absolute_path(temp_dir, f"quote_fb_{uuid.uuid4()}.jpg"),
                    author=self._get_author(),
                    quote=self._get_quote_message(),
                    layout_vertical=(self.layout_index == 1)
                )
                return True

            self.plugin._ensure_fallback_avatar_cached()
            return False

        try:
            if username.startswith("+"):
                req_cls = getattr(TLRPC, "TL_contacts_resolve" + "Phone")
                req = req_cls()
                req.phone = username
                send_request(req, RequestCallback(self._resolve_username_callback))
            else:
                req_cls = getattr(TLRPC, "TL_contacts_resolve" + "Username")
                req = req_cls()
                req.username = username
                send_request(req, RequestCallback(self._resolve_username_callback))
            return True
        except Exception:
            return False

    def _resolve_username_callback(self, response, error):
        try:
            if error or not response:
                return self._create_quote_without_input(skip_service_fallback=True)
            try:
                if response.users is not None and response.users.size() > 0:
                    u = response.users.get(0)
                    input_user = get_messages_controller().getInputUser(u)
                    if input_user is not None:
                        req_cls = getattr(TLRPC, "TL_photos_getUser" + "Photos")
                        req = req_cls()
                        req.user_id = input_user
                        req.limit = 1
                        send_request(req, RequestCallback(self._fallback_user_photos_callback))
                        return
            except Exception:
                pass
            try:
                if hasattr(response, "chats") and response.chats is not None and response.chats.size() > 0:
                    chat = response.chats.get(0)
                    if chat.photo is not None and chat.photo.photo_id != 0:
                        TelegramUtils.get_chat_thumbnail(chat, response.peer, self._handle_get_file_callback)
                        return
            except Exception:
                pass
            self._create_quote_without_input(skip_service_fallback=True)
        except Exception:
            self._create_quote_without_input(skip_service_fallback=True)

    def _fallback_user_photos_callback(self, response, error):
        def run():
            try:
                if not error and response:
                    try:
                        if response.photos is not None and response.photos.size() > 0:
                            photo = response.photos.get(0)
                            best_size = None
                            current_account = UserConfig.selectedAccount
                            file_loader = FileLoader.getInstance(current_account)

                            for size in photo.sizes:
                                if isinstance(size, (TLRPC.TL_photoSize, TLRPC.TL_photoSizeProgressive)):
                                    if best_size is None or size.w > best_size.w:
                                        best_size = size

                            if best_size:
                                file_path_obj = file_loader.getPathToAttach(best_size, True)
                                if file_path_obj and file_path_obj.exists():
                                    with open(file_path_obj.getAbsolutePath(), "rb") as f:
                                        content = f.read()
                                    self._handle_get_file_callback_direct(content)
                                    return

                            if not best_size:
                               return self._create_quote_without_input(skip_service_fallback=True)
                            
                            req_cls = getattr(TLRPC, "TL_upload_get" + "File")
                            req = req_cls()
                            cb = RequestCallback(self._handle_get_file_callback)
                            input_file = TelegramUtils.create_input_location(photo, best_size)
                            req.location = input_file
                            req.offset = 0
                            req.limit = 1024 * 1024 * 4
                            send_request(req, cb)
                            return
                    except Exception:
                        pass
                self._create_quote_without_input(skip_service_fallback=True)
            except Exception:
                self._create_quote_without_input(skip_service_fallback=True)
        global_executor.submit(run)

    def _handle_get_file_callback(self, response, error, target_cache_file=None, custom_cache_path=None):
        def run():
            resp_bytes = None
            try:
                if response and hasattr(response, 'bytes'):
                    resp_bytes = response.bytes
            except Exception:
                pass

            if error or not response or resp_bytes is None:
                if self.user:
                    return self._fetch_avatar_via_web(self.user, custom_cache_path)
                else:
                    return self._create_quote_without_input(skip_service_fallback=True)
            try:
                buffer = resp_bytes.buffer
                
                final_image_path = custom_cache_path
                if not final_image_path:
                    user_id = self.user.id if self.user else uuid.uuid4()
                    final_image_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"temp_dl_{user_id}_{uuid.uuid4()}.jpg")
                
                written = False
                try:
                    from java.io import FileOutputStream
                    fos = FileOutputStream(final_image_path)
                    channel = fos.getChannel()
                    buffer.rewind()
                    channel.write(buffer)
                    channel.close()
                    fos.close()
                    written = True
                except:
                    pass
                
                if not written:
                    buffer.rewind()
                    length = buffer.remaining()
                    py_bytes = bytes([buffer.get() & 0xFF for _ in range(length)])
                    Filesystem.write_file(final_image_path, py_bytes)
                if target_cache_file:
                    try:
                        Filesystem.write_file(target_cache_file.getAbsolutePath(), py_bytes)
                    except Exception:
                        pass
                
                quote_output_path = Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"quote_{uuid.uuid4()}.png")
                
                self._create_and_send_image(
                    image_path=final_image_path,
                    output_path=quote_output_path,
                    author=self._get_author(),
                    quote=self._get_quote_message(),
                    layout_vertical=(self.layout_index == 1)
                )
            except Exception:
                if self.user:
                    return self._fetch_avatar_via_web(self.user, custom_cache_path)
                return self._create_quote_without_input(skip_service_fallback=True)
        global_executor.submit(run)

    def _fetch_fallback_avatar_from_reply(self):
        try:
            reply_obj = getattr(self.params, "replyToMsg", None)
            if reply_obj:
                msg_owner = getattr(reply_obj, "messageOwner", reply_obj)
                from_id = getattr(msg_owner, "from_id", None)
                if from_id:
                    peer_id = ReplyerID(from_id)
                    rtype = peer_id.get_replyer_type()
                    if rtype == 0 and peer_id.user_id != -1:
                        u = TelegramUtils.get_user(peer_id.user_id)
                        if u and getattr(u, "photo", None) and not isinstance(u.photo, TLRPC.TL_userProfilePhotoEmpty):
                            self._fetch_user_avatar(u)
                            return True
                    elif rtype == 1:
                        c = get_messages_controller().getChat(peer_id.chat_id)
                        if c and getattr(c, "photo", None) and not isinstance(c.photo, TLRPC.TL_chatPhotoEmpty):
                            self._fetch_chat_avatar(c, get_messages_controller().getInputPeer(c))
                            return True
                    elif rtype == 2:
                        c = get_messages_controller().getChat(peer_id.channel_id)
                        if c and getattr(c, "photo", None) and not isinstance(c.photo, TLRPC.TL_chatPhotoEmpty):
                            self._fetch_chat_avatar(c, get_messages_controller().getInputChannel(c))
                            return True
        except Exception as e:
            qlog(f"Fallback avatar load error: {e}")
        return False

    def _create_quote_without_input(self, skip_service_fallback=False):
        def run():
            try:
                if not getattr(self, "fallback_avatar_attempted", False):
                    self.fallback_avatar_attempted = True
                    if self._fetch_fallback_avatar_from_reply():
                        return

                use_custom_avatar = self.plugin.get_setting("avatar_use_custom", False)
                
                if (use_custom_avatar or self.force_custom_avatar) and self.custom_avatar_path and os.path.exists(self.custom_avatar_path):
                     self._create_and_send_image(
                        image_path=self.custom_avatar_path,
                        output_path=Filesystem.get_absolute_path(Filesystem.get_temp_dir(), f"tmp_custom_{uuid.uuid4()}.png"),
                        author=self._get_author(),
                        quote=self._get_quote_message(),
                        layout_vertical=(self.layout_index == 1)
                     )
                     return
 
                if not self.force_custom_avatar and not skip_service_fallback:
                    if self._try_fetch_username_avatar(FALLBACK_AVATAR_USERNAME):
                        return
      
                user_or_chat_id = -1
                if self.user:
                    user_or_chat_id = self.user.id
                elif self.replyer_id:
                    user_or_chat_id = self._get_replyer_id()
                else:
                    user_or_chat_id = uuid.uuid4()
        
                tmp_file = f"tmp_{user_or_chat_id}.png"
                temp_dir = Filesystem.get_temp_dir()
                file_path = Filesystem.get_absolute_path(temp_dir, tmp_file)
                
                self._create_and_send_image(
                    output_path=file_path,
                    author=self._get_author(),
                    quote=self._get_quote_message(),
                    layout_vertical=(self.layout_index == 1)
                )
        
            except Exception:
                pass
        global_executor.submit(run)

    def _create_color_background(self, width, height, use_random_bg, custom_bg_color):
        if use_random_bg:
            bg_color = tuple(random.randint(100, 255) for _ in range(3))
        else:
            bg_color = self.plugin._parse_hex_color(custom_bg_color, (0, 0, 0))[:3]
        return Image.new("RGB", (width, height), bg_color)

    def _apply_bg_style_beta(self, image, width, height, style):
        try:
            if style == 5:
                use_random_bg = self.plugin.get_setting("use_random_bg", True)
                custom_bg_color = self.plugin.get_setting("custom_bg_color", "#000000")
                if use_random_bg:
                    bg_color = tuple(random.randint(100, 255) for _ in range(3))
                else:
                    bg_color = self.plugin._parse_hex_color(custom_bg_color, (0, 0, 0))[:3]
                image = Image.new("RGB", (width, height), bg_color)
                result = image
            else:
                cropped = ImageUtils.crop_center(image, width, height)
        
                if style == 0:
                    result = cropped.convert("RGB")
                elif style == 1:
                    radius = int(self.plugin.get_setting("bg_blur_radius", "60"))
                    result = cropped.filter(ImageFilter.GaussianBlur(radius))
                elif style == 2:
                    radius = int(self.plugin.get_setting("bg_glass_blur_radius", "60"))
                    opacity = int(self.plugin.get_setting("bg_glass_opacity", "80"))
                    result = cropped.filter(ImageFilter.GaussianBlur(radius))
                    overlay = Image.new("RGBA", (width, height), (255, 255, 255, opacity))
                    result = Image.alpha_composite(result.convert("RGBA"), overlay).convert("RGB")
                elif style == 3:
                    noise_intensity = int(self.plugin.get_setting("bg_tv_noise_intensity", "60"))
                    result = cropped.filter(ImageFilter.GaussianBlur(5)).convert("RGBA")
                    
                    small_w = width // 4
                    small_h = height // 4
                    noise_bytes = os.urandom(small_w * small_h)
                    noise = Image.frombytes("L", (small_w, small_h), noise_bytes)
                    noise = noise.resize((width, height), Image.NEAREST)
                    
                    noise_overlay = Image.new("RGBA", (width, height), (0, 0, 0, 0))
                    mask = noise.point(lambda p: int(p * (noise_intensity / 255.0) * 0.5))
                    noise_overlay.putalpha(mask)
                    
                    result = Image.alpha_composite(result, noise_overlay).convert("RGB")
                elif style == 4:
                    pixel_size = int(self.plugin.get_setting("bg_pixel_size", "20"))
                    pixel_size = max(1, pixel_size)
                    small = cropped.resize((width // pixel_size, height // pixel_size), Image.NEAREST)
                    result = small.resize((width, height), Image.NEAREST)
                elif style == 6:
                    color1_hex = self.plugin.get_setting("bg_gradient_color1", "#FF8040")
                    color2_hex = self.plugin.get_setting("bg_gradient_color2", "#8040FF")
                    color1 = self.plugin._parse_hex_color(color1_hex, (255, 128, 64))[:3]
                    color2 = self.plugin._parse_hex_color(color2_hex, (128, 64, 255))[:3]
                    result = Image.new("RGB", (width, height))
                    draw = ImageDraw.Draw(result)
                    for i in range(width):
                        ratio = i / width
                        r = int(color1[0] * (1 - ratio) + color2[0] * ratio)
                        g = int(color1[1] * (1 - ratio) + color2[1] * ratio)
                        b = int(color1[2] * (1 - ratio) + color2[2] * ratio)
                        draw.line([(i, 0), (i, height)], fill=(r, g, b))
                elif style == 7:
                    amplitude = float(self.plugin.get_setting("bg_waves_amplitude", "5"))
                    frequency = float(self.plugin.get_setting("bg_waves_frequency", "0.1"))
                    result = cropped.copy()
                    for y in range(height):
                        shift = int(amplitude * math.sin(y * frequency))
                        region = result.crop((0, y, width, y + 1))
                        result.paste(region, (shift, y))
                    result = result.filter(ImageFilter.GaussianBlur(3))
                else:
                    result = cropped.filter(ImageFilter.GaussianBlur(20))
            
            dimming_value = int(self.plugin.get_setting("bg_dimming", "70"))
            if dimming_value <= 0:
                dimming_value = 1
            dimming_value = min(100, dimming_value)
            
            alpha = int(dimming_value / 100 * 255)
            if alpha > 0:
                overlay = Image.new("RGBA", (width, height), (0, 0, 0, alpha))
                if result.mode != 'RGBA':
                    result = result.convert('RGBA')
                result = Image.alpha_composite(result, overlay).convert("RGB")
            return result
        except (ValueError, TypeError) as e:
            qlog(f"BG style value error: {e}")
            return Image.new("RGB", (width, height), (0, 0, 0))
        except Exception as e:
            qlog(f"BG style error: {e}")
            traceback.print_exc()
            return Image.new("RGB", (width, height), (0, 0, 0))

    def _apply_bg_filter_beta(self, image, filter_type):
        try:
            if filter_type == 0:
                return image
            if image.mode != 'RGB':
                image = image.convert('RGB')
            if filter_type == 1:
                return ImageOps.grayscale(image).convert('RGB')
            elif filter_type == 2:
                grayscale = ImageOps.grayscale(image)
                sepia = Image.new('RGB', grayscale.size)
                pixels = grayscale.load()
                sepia_pixels = sepia.load()
                for x in range(grayscale.size[0]):
                    for y in range(grayscale.size[1]):
                        gray = pixels[x, y]
                        r = min(255, int(gray * 1.1))
                        g = min(255, int(gray * 0.9))
                        b = min(255, int(gray * 0.7))
                        sepia_pixels[x, y] = (r, g, b)
                return sepia
            elif filter_type == 3:
                return ImageOps.invert(image)
            elif filter_type == 4:
                levels = int(self.plugin.get_setting("filter_posterize_levels", "4"))
                levels = max(2, min(8, levels))
                posterized = image.copy()
                pixels = posterized.load()
                for x in range(posterized.size[0]):
                    for y in range(posterized.size[1]):
                        r, g, b = pixels[x, y]
                        r = int(round(r / 255.0 * (levels - 1))) * int(255 / (levels - 1))
                        g = int(round(g / 255.0 * (levels - 1))) * int(255 / (levels - 1))
                        b = int(round(b / 255.0 * (levels - 1))) * int(255 / (levels - 1))
                        pixels[x, y] = (r, g, b)
                return posterized
            elif filter_type == 5:
                black_hex = self.plugin.get_setting("filter_colorize_black", "#000000")
                white_hex = self.plugin.get_setting("filter_colorize_white", "#FFD700")
                black_color = self.plugin._parse_hex_color(black_hex, (0,0,0))[:3]
                white_color = self.plugin._parse_hex_color(white_hex, (255,215,0))[:3]
                grayscale = ImageOps.grayscale(image)
                return ImageOps.colorize(grayscale, black=black_color, white=white_color).convert('RGB')
            elif filter_type == 6:
                factor = float(self.plugin.get_setting("filter_contrast_factor", "2.0"))
                enhancer = ImageEnhance.Contrast(image)
                return enhancer.enhance(factor)
            elif filter_type == 7:
                return image.filter(ImageFilter.EMBOSS)
            else:
                return image
        except (ValueError, TypeError) as e:
            qlog(f"BG filter value error: {e}")
            return image
        except Exception as e:
            qlog(f"BG filter error: {e}")
            return image

    def _get_profile_color(self):
        user_id = 0
        if self.user:
            user_id = self.user.id
        elif self.replyer_id:
            user_id = self._get_replyer_id()
        
        if user_id == 0:
            return self.plugin._parse_hex_color("#B4B4B4", (180, 180, 180))

        color_index = abs(user_id) % 7
        
        colors = [
            "#FF516A", 
            "#FF885E", 
            "#8E85EE", 
            "#53ED97", 
            "#28C9B7", 
            "#549CFC", 
            "#FF7CA8"  
        ]
        
        hex_color = colors[color_index]
        return self.plugin._parse_hex_color(hex_color, (180, 180, 180))

    def _create_and_send_image(self, image_path=None, output_path="quote.jpg", author="", quote="", layout_vertical=False):
        def run():
            self._create_and_send_image_impl(image_path, output_path, author, quote, layout_vertical)
        global_executor.submit(run)

    def _create_and_send_image_impl(self, image_path=None, output_path="quote.jpg", author="", quote="", layout_vertical=False):
        with self.finalize_lock:
            if self.is_finalized:
                return
            self.is_finalized = True

        extended_logs = self.plugin.get_setting("extended_logging", False)
        
        qlog("="*40)
        qlog(f"[RENDER] Starting Render process")
        qlog(f"[RENDER] Output Path: {output_path}")
        qlog(f"[RENDER] Author: {self.replyer.name}")
            
        font_index = self.plugin.get_setting("font", 1)
        quote_style = self.plugin.get_setting("quote_style", 0)
        bg_style = self.plugin.get_setting("bg_style", 0)
        
        style_names = {0: "horizontal_left", 1: "horizontal_right", 2: "vertical", 3: "cloud"}

        try:
            attached_media_paths = self._fetch_attached_media()
            
            if image_path and os.path.exists(image_path):
                image_path = MemoryOptimizer.optimize_image_before_processing(image_path)
                
            selected_font = FontManager.get(font_index, self.plugin)
            font_path = selected_font.get_path()
            
            is_cloud_style = (quote_style == 3)
            
            if quote_style == 2:
                layout_vertical = True
                avatar_position = 0 
            elif is_cloud_style:
                layout_vertical = False
                avatar_position = 0 
            else:
                layout_vertical = False
                avatar_position = quote_style

            try:
                if is_cloud_style:
                    quote_font_size = int(self.plugin.get_setting("cloud_quote_font_size", "36"))
                    author_font_size = int(self.plugin.get_setting("cloud_author_font_size", "28"))
                else:
                    quote_font_size = int(self.plugin.get_setting("quote_font_size", "36"))
                    author_font_size = int(self.plugin.get_setting("author_font_size", "28"))
                line_spacing = int(self.plugin.get_setting("line_spacing", "10"))
            except (ValueError, TypeError):
                quote_font_size = 40
                author_font_size = 32
                line_spacing = 0
                            
            text_color_hex = self.plugin.get_setting("text_color_hex", "#FFFFFF")
            author_color_hex = self.plugin.get_setting("author_color_hex", "#B4B4B4")
            text_color = self.plugin._parse_hex_color(text_color_hex, (255, 255, 255))
            
            use_profile_color = self.plugin.get_setting("use_profile_color", True)
            if use_profile_color:
                author_color = self._get_profile_color()
            else:
                author_color = self.plugin._parse_hex_color(author_color_hex, (180, 180, 180))
            
            try:
                cloud_opacity = int(self.plugin.get_setting("cloud_bubble_opacity", "80"))
                cloud_opacity = max(0, min(100, cloud_opacity))
                cloud_opacity = int(cloud_opacity * 2.55)
            except: 
                cloud_opacity = 204
            
            cloud_bubble_color_hex = self.plugin.get_setting("cloud_bubble_color", "#1E1E1E")
            bubble_color_rgb = self.plugin._parse_hex_color(cloud_bubble_color_hex, (30, 30, 30))
            bubble_color = bubble_color_rgb + (cloud_opacity,)
            
            if is_cloud_style:
                if use_profile_color:
                    author_color = self._get_profile_color()
                
            show_avatar = self.plugin.get_setting("show_avatar", True)
            
            try:
                if is_cloud_style:
                    avatar_size = int(self.plugin.get_setting("cloud_avatar_size", "80"))
                else:
                    avatar_size = int(self.plugin.get_setting("avatar_size", "400"))
                avatar_size = max(50, min(400, avatar_size))
            except:
                avatar_size = 80 if is_cloud_style else 400
            
            try:
                avatar_rounding_percent = int(self.plugin.get_setting("avatar_rounding", "100"))
                avatar_rounding_percent = max(0, min(100, avatar_rounding_percent))
                avatar_rounding = int((avatar_rounding_percent / 100.0) * (avatar_size // 2))
            except:
                avatar_rounding = avatar_size // 2

            bg_style = self.plugin.get_setting("bg_style", 0)
            bg_filter = self.plugin.get_setting("bg_filter", 0)
            use_random_bg = self.plugin.get_setting("use_random_bg", True)
            custom_bg_color = self.plugin.get_setting("custom_bg_color", "#000000")
    
            attached_img = None
            if attached_media_paths:
                try:
                    attached_img = self._create_media_collage(attached_media_paths)
                    if attached_img:
                        bbox = attached_img.split()[-1].getbbox()
                        if bbox:
                            attached_img = attached_img.crop(bbox)
                        try:
                            reduction_pct = int(self.plugin.get_setting("quote_text_reduction", "14"))
                            reduction_factor = 1.0 - (max(0, min(90, reduction_pct)) / 100.0)
                            quote_font_size = int(quote_font_size * reduction_factor)
                        except Exception:
                            pass
                except Exception:
                    attached_img = None

            def safe_load_font(path, size):
                return self._load_ttf_font(path, size)

            quote_font = safe_load_font(font_path, quote_font_size)
            author_font = safe_load_font(font_path, author_font_size)
            safe_author = self._parse_raw_markdown(str(author) if author is not None else "")
            safe_author = safe_author.replace('\n\x01/QUOTE\x02', '\x01/QUOTE\x02\n')

            temp_img = Image.new("RGB", (1, 1))
            temp_draw = ImageDraw.Draw(temp_img)
            
            safe_author = str(author) if author is not None else ""
            
            if is_cloud_style:
                prefix = self.plugin.get_setting("cloud_author_prefix", "")
                author_text = f"{prefix}{safe_author.strip()}"
            else:
                prefix = self.plugin.get_setting("author_prefix", "— ")
                author_text = f"{prefix}{safe_author.strip()}"
            
            canvas_width = 1200
            padding = 50
            bubble_padding = 40 if is_cloud_style else 0
            
            att_img_processed = None
            att_w, att_h = 0, 0
            
            if attached_img:
                available_w = canvas_width - (padding * 2)
                if not layout_vertical and show_avatar:
                    available_w -= (avatar_size + padding)
                if is_cloud_style:
                    available_w -= (bubble_padding * 2)
    
                try:
                    if layout_vertical:
                        scale_percent = int(self.plugin.get_setting("quote_image_size_vertical", "100"))
                    elif not is_cloud_style:
                        scale_percent = int(self.plugin.get_setting("quote_image_size_horizontal", "100"))
                    else:
                        scale_percent = 100
                    scale_factor = max(10, min(100, scale_percent)) / 100.0
                except:
                    scale_factor = 0.8 if layout_vertical else 1.0
                
                target_w = int(available_w * scale_factor)
                orig_w, orig_h = attached_img.size
                ratio = target_w / float(orig_w)
                att_w = int(orig_w * ratio)
                att_h = int(orig_h * ratio)
                
                if att_h > 1200: 
                    ratio = 1200 / float(att_h)
                    att_w = int(att_w * ratio)
                    att_h = 1200
    
                att_img_processed = attached_img.resize((att_w, att_h), Image.LANCZOS)
                
                try:
                    if getattr(self, 'is_round_media', False):
                        radius_percent = 50
                    else:
                        radius_percent = int(self.plugin.get_setting("quote_image_radius", "3"))
                    radius_percent = max(0, min(100, radius_percent))
                    if radius_percent > 0:
                        radius_pixels = int(min(att_w, att_h) * radius_percent / 100.0)
                        mask = Image.new("L", (att_w, att_h), 0)
                        mdraw = ImageDraw.Draw(mask)
                        mdraw.rounded_rectangle((0, 0, att_w, att_h), radius=radius_pixels, fill=255)
                        
                        if att_img_processed.mode == 'RGBA':
                            current_alpha = att_img_processed.split()[3]
                            mask = Image.composite(current_alpha, Image.new("L", (att_w, att_h), 0), mask)
                            
                        att_img_processed.putalpha(mask)
                except: pass

            max_text_width = canvas_width - padding * 2
            if not layout_vertical and show_avatar:
                max_text_width -= (avatar_size + padding)
            if is_cloud_style:
                left_offset = padding
                max_text_width -= (bubble_padding * 2)
                
            prefetch_list = [(quote, quote_font), (author_text, author_font)]
            try:
                if getattr(self, 'reply_message_text', None): prefetch_list.append((self.reply_message_text, reply_text_font))
                if getattr(self, 'reply_author_name', None): prefetch_list.append((self.reply_author_name, reply_name_font))
            except: pass
            
            self._prefetch_all_emojis(prefetch_list)
            
            wrapped_quote = self._wrap_text(temp_draw, quote, quote_font, max_text_width)
            quote_width, quote_height = self._measure_text_dimensions(temp_draw, wrapped_quote, quote_font, line_spacing)

            wrapped_author = self._wrap_text(temp_draw, author_text, author_font, max_text_width)
            author_width, author_height = self._measure_text_dimensions(temp_draw, wrapped_author, author_font, line_spacing)
            
            if is_cloud_style:
                content_height = quote_height + author_height + 20
            else:
                content_height = quote_height + author_height
                
            if att_img_processed:
                content_height += att_h
                
            if is_cloud_style:
                if att_img_processed:
                    content_height += int(bubble_padding * 2.2)
                else:
                    content_height += int(bubble_padding * 1.6)
            
            if layout_vertical:
                 if show_avatar:
                    content_height += avatar_size + padding
            else:
                 content_height = max(content_height, avatar_size)
            
            canvas_height = int(content_height + padding * 2)
            canvas_height = max(600, canvas_height)
            
            bg_source_path = None
            avatar_source_path = None
            
            if not self.force_custom_bg and not self.force_custom_avatar:
                if image_path and os.path.exists(image_path):
                    bg_source_path = image_path
                avatar_source_path = image_path
            elif self.force_custom_bg and not self.force_custom_avatar:
                if self.custom_bg_path and os.path.exists(self.custom_bg_path): bg_source_path = self.custom_bg_path
                if image_path and os.path.exists(image_path): avatar_source_path = image_path
            elif not self.force_custom_bg and self.force_custom_avatar:
                if image_path and os.path.exists(image_path): bg_source_path = image_path
                if self.custom_avatar_path and os.path.exists(self.custom_avatar_path): avatar_source_path = self.custom_avatar_path
            else:
                if self.custom_bg_path and os.path.exists(self.custom_bg_path): bg_source_path = self.custom_bg_path
                if self.custom_avatar_path and os.path.exists(self.custom_avatar_path): avatar_source_path = self.custom_avatar_path

            if not bg_source_path and avatar_source_path and os.path.exists(avatar_source_path):
                bg_source_path = avatar_source_path
    
            if bg_source_path:
                try:
                    orig_img = Image.open(bg_source_path).convert("RGBA")
                    canvas = self._apply_bg_style_beta(orig_img, canvas_width, canvas_height, bg_style)
                    if bg_filter > 0: canvas = self._apply_bg_filter_beta(canvas, bg_filter)
                except:
                    canvas = self._create_color_background(canvas_width, canvas_height, use_random_bg, custom_bg_color)
            else:
                canvas = self._create_color_background(canvas_width, canvas_height, use_random_bg, custom_bg_color)
    
            avatar_img = None
            if show_avatar:
                if avatar_source_path and os.path.exists(avatar_source_path):
                    try:
                        temp_ava = Image.open(avatar_source_path).convert("RGBA")
                        temp_ava = temp_ava.resize((avatar_size, avatar_size), Image.LANCZOS)
                        mask = Image.new("L", temp_ava.size, 0)
                        mask_draw = ImageDraw.Draw(mask)
                        if avatar_rounding_percent == 100:
                            mask_draw.ellipse((0, 0, avatar_size, avatar_size), fill=255)
                        elif avatar_rounding_percent == 0:
                            mask_draw.rectangle((0, 0, avatar_size, avatar_size), fill=255)
                        else:
                            mask_draw.rounded_rectangle((0, 0, avatar_size, avatar_size), radius=avatar_rounding, fill=255)
                        temp_ava.putalpha(mask)
                        avatar_img = temp_ava
                    except Exception as e:
                        avatar_img = None
                
                if not avatar_img:
                    try:
                        temp_ava = Image.new("RGBA", (avatar_size, avatar_size), (0, 0, 0, 0))
                        avatar_draw = ImageDraw.Draw(temp_ava)
                        circle_color = tuple(random.randint(100, 255) for _ in range(3))
                        if avatar_rounding_percent == 100:
                            avatar_draw.ellipse((0, 0, avatar_size, avatar_size), fill=circle_color)
                        elif avatar_rounding_percent == 0:
                            avatar_draw.rectangle((0, 0, avatar_size, avatar_size), fill=circle_color)
                        else:
                            avatar_draw.rounded_rectangle((0, 0, avatar_size, avatar_size), radius=avatar_rounding, fill=circle_color)
                        try:
                            letter_font = ImageFont.truetype(font_path, int(avatar_size * 0.4))
                            base_author = safe_author.strip()
                            letter = base_author[0].upper() if base_author else "?"
                            bbox = avatar_draw.textbbox((0, 0), letter, font=letter_font)
                            w, h = bbox[2] - bbox[0], bbox[3] - bbox[1]
                            avatar_draw.text(((avatar_size - w) // 2, (avatar_size - h) // 2), letter, font=letter_font, fill=(255, 255, 255))
                        except: pass
                        mask = Image.new("L", temp_ava.size, 0)
                        mask_draw = ImageDraw.Draw(mask)
                        if avatar_rounding_percent == 100:
                            mask_draw.ellipse((0, 0, avatar_size, avatar_size), fill=255)
                        elif avatar_rounding_percent == 0:
                            mask_draw.rectangle((0, 0, avatar_size, avatar_size), fill=255)
                        else:
                            mask_draw.rounded_rectangle((0, 0, avatar_size, avatar_size), radius=avatar_rounding, fill=255)
                        temp_ava.putalpha(mask)
                        avatar_img = temp_ava
                    except Exception:
                        avatar_img = None
                        mask = Image.new("L", temp_ava.size, 0)
                        mask_draw = ImageDraw.Draw(mask)
                        if avatar_rounding_percent == 100:
                            mask_draw.ellipse((0, 0, avatar_size, avatar_size), fill=255)
                        elif avatar_rounding_percent == 0:
                            mask_draw.rectangle((0, 0, avatar_size, avatar_size), fill=255)
                        else:
                            mask_draw.rounded_rectangle((0, 0, avatar_size, avatar_size), radius=avatar_rounding, fill=255)
                        temp_ava.putalpha(mask)
                        avatar_img = temp_ava
                    except Exception:
                        avatar_img = None

            draw = ImageDraw.Draw(canvas, 'RGBA')

            if is_cloud_style:
                left_offset = padding
                if show_avatar and avatar_img:
                    ava_x = padding
                    content_total_h = content_height
                    start_y = (canvas_height - content_total_h) // 2
                    ava_y = start_y + content_total_h - avatar_size
                    canvas.paste(avatar_img, (ava_x, ava_y), avatar_img)
                    left_offset = ava_x + avatar_size + 15
                
                content_total_h = content_height
                start_y = (canvas_height - content_total_h) // 2
                bubble_x1 = left_offset
                bubble_y1 = start_y
                max_content_w = max(quote_width, author_width)
                if att_img_processed: 
                    max_content_w = max(max_content_w, att_w)
                bubble_w = max_content_w + (bubble_padding * 2)
                bubble_h = content_total_h
                bubble_x2 = bubble_x1 + bubble_w
                bubble_y2 = bubble_y1 + bubble_h
            
                if show_avatar:
                    tail_coords = [(bubble_x1, bubble_y2 - 20), (bubble_x1 - 10, bubble_y2), (bubble_x1 + 20, bubble_y2)]
                    draw.polygon(tail_coords, fill=bubble_color)
                draw.rounded_rectangle((bubble_x1, bubble_y1, bubble_x2, bubble_y2), radius=30, fill=bubble_color)
                text_x = bubble_x1 + bubble_padding
                current_y = bubble_y1 + bubble_padding
                
                self._draw_text_with_emoji(canvas, draw, (text_x, current_y), wrapped_author, author_font, author_color, line_spacing, max_width=author_width)
                current_y += author_height + 17
                
                if att_img_processed:
                    canvas.paste(att_img_processed, (text_x, current_y), att_img_processed)
                    current_y += att_h + 15
                
                self._draw_text_with_emoji(canvas, draw, (text_x, current_y), wrapped_quote, quote_font, text_color, line_spacing, max_width=quote_width)

            elif layout_vertical:
                total_content_h = quote_height + author_height - 18
                if show_avatar and avatar_img:
                    total_content_h += avatar_size + 25
                if att_img_processed:
                    total_content_h += att_h + 15
            
                current_y = (canvas_height - total_content_h) // 2 - 10
                
                if not att_img_processed: 
                    if current_y > 54:
                        current_y += 6
                        
                align_idx = self.plugin.get_setting("vertical_text_align", 1)
                align_map = {0: "left", 1: "center", 2: "right"}
                text_align = align_map.get(align_idx, "center")
                
                if show_avatar and avatar_img:
                    img_x = (canvas_width - avatar_size) // 2
                    canvas.paste(avatar_img, (img_x, current_y), avatar_img)
                    current_y += avatar_size + 25
                
                if att_img_processed: 
                    att_x = (canvas_width - att_w) // 2
                    canvas.paste(att_img_processed, (att_x, current_y), att_img_processed)
                    current_y += att_h + 16
                
                text_x = (canvas_width - quote_width) // 2
                author_x = (canvas_width - author_width) // 2
            
                self._draw_text_with_emoji(canvas, draw, (text_x, current_y), wrapped_quote, quote_font, text_color, line_spacing, align=text_align, max_width=quote_width)
                current_y += quote_height + 10
                self._draw_text_with_emoji(canvas, draw, (author_x, current_y), wrapped_author, author_font, author_color, line_spacing, align=text_align, max_width=author_width)

            else:
                text_align = "left"
                left_offset = padding
                if show_avatar and avatar_img:
                    if avatar_position == 0:
                        img_x = padding
                        left_offset = img_x + avatar_size + padding
                    else:
                        img_x = canvas_width - avatar_size - padding
                        left_offset = padding
                        text_align = "right"
                    img_y = (canvas_height - avatar_size) // 2
                    canvas.paste(avatar_img, (img_x, img_y), avatar_img)
                
                content_block_h = quote_height + 6 + author_height
                if att_img_processed:
                    content_block_h += att_h + 14
                current_y = (canvas_height - content_block_h) // 2
                
                text_x = left_offset
                author_x = left_offset
                att_x = left_offset
                
                if text_align == "right":
                    right_boundary = img_x - padding
                    text_x = right_boundary - quote_width
                    author_x = right_boundary - author_width
                    if att_img_processed:
                        att_x = right_boundary - att_w
                
                if att_img_processed:
                    canvas.paste(att_img_processed, (att_x, current_y), att_img_processed)
                    current_y += att_h + 10
                    
                self._draw_text_with_emoji(canvas, draw, (text_x, current_y), wrapped_quote, quote_font, text_color, line_spacing, align=text_align, max_width=quote_width)
                current_y += quote_height + 4
                self._draw_text_with_emoji(canvas, draw, (author_x, current_y), wrapped_author, author_font, author_color, line_spacing, align=text_align, max_width=author_width)
            
            os.makedirs(os.path.dirname(str(output_path)), exist_ok=True)

            if str(output_path).lower().endswith(".png"):
                canvas.save(output_path, "PNG")
            else:
                canvas.save(output_path, "JPEG", quality=90)
            self._send_quote(output_path, len(quote))
        except Exception as e:
            qlog("CRITICAL ERROR in create_and_send_image", e)
            copy_error_to_clipboard(traceback.format_exc())

    def _send_quote(self, output_path, text_len=0):
        import os
        import time
        import shutil
        dir_name = os.path.dirname(str(output_path))
        ext = os.path.splitext(str(output_path))[1]
        new_name = time.strftime("Quotify_%y%m%d_%H%M%S") + ext
        new_path = os.path.join(dir_name, new_name)
        if str(output_path) != new_path:
            shutil.move(str(output_path), new_path)
            output_path = new_path
            
        plugin_ref = getattr(self, 'plugin', getattr(self, 'pl', getattr(self, '_plugin', None)))
        
        if getattr(self, 'force_preview', False):
            action = 0
        else:
            action = plugin_ref.get_setting("after_gen_action", 0) if plugin_ref else 0
            
        if action == 0:
            from android_utils import run_on_ui_thread
            run_on_ui_thread(lambda: self._show_preview(output_path))
        elif action == 1:
            self._send_final(output_path, "", "photo")
        elif action == 2:
            self._send_final(output_path, "", "file")
        elif action == 3:
            self._send_final(output_path, "", "sticker")

    def _show_preview(self, output_path):
        try:
            from client_utils import get_last_fragment
            from org.telegram.ui.ActionBar import Theme
            from android.widget import LinearLayout, ImageView, EditText, TextView, ScrollView, FrameLayout
            from android.graphics import BitmapFactory, Typeface, Bitmap, Canvas, Paint, RectF, PorterDuffXfermode, PorterDuff, Color
            from android.graphics.drawable import GradientDrawable
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from java import dynamic_proxy, jclass
            from org.telegram.messenger import AndroidUtilities
            from android.animation import LayoutTransition
            
            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return
                
            root_layout = LinearLayout(act)
            root_layout.setOrientation(LinearLayout.VERTICAL)
            root_layout.setClickable(True)

            title_tv = TextView(act)
            
            plugin_ref = getattr(self, 'plugin', getattr(self, 'pl', getattr(self, '_plugin', None)))
            hide_comment = plugin_ref.get_setting("preview_hide_comment", False) if plugin_ref else False
            show_comment = not hide_comment
            cmd_text = getattr(plugin_ref, 'last_cmd', '.q') if plugin_ref else '.q'
            
            title_tv.setText(f"{tr_if_ru('Предпросмотр цитаты')} [{cmd_text}]")
            title_tv.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title_tv.setTextSize(1, 20.0)
            title_tv.setTypeface(Typeface.DEFAULT_BOLD)
            title_tv.setGravity(Gravity.CENTER)
            root_layout.addView(title_tv, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 10))

            scroll_view = ScrollView(act)
            scroll_content = LinearLayout(act)
            scroll_content.setOrientation(LinearLayout.VERTICAL)
            
            iv = ImageView(act)
            bmp = BitmapFactory.decodeFile(str(output_path))
            img_w, img_h = 0, 0
            if bmp:
                img_w, img_h = bmp.getWidth(), bmp.getHeight()
                rad = float(AndroidUtilities.dp(4))
                
                out_bmp = Bitmap.createBitmap(img_w, img_h, Bitmap.Config.ARGB_8888)
                canvas = Canvas(out_bmp)
                
                paint = Paint()
                paint.setAntiAlias(True)
                paint.setARGB(255, 255, 255, 255)
                rectF = RectF(0.0, 0.0, float(img_w), float(img_h))
                canvas.drawRoundRect(rectF, rad, rad, paint)
                
                paint.setXfermode(PorterDuffXfermode(PorterDuff.Mode.SRC_IN))
                canvas.drawBitmap(bmp, 0.0, 0.0, paint)
                
                iv.setImageBitmap(out_bmp)
                bmp.recycle()
                
            iv.setAdjustViewBounds(True)
            scroll_content.addView(iv, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0))
            scroll_view.addView(scroll_content)
            
            screen_h = AndroidUtilities.displaySize.y
            screen_w = AndroidUtilities.displaySize.x
            max_h = int(screen_h * 0.50)
            
            dialog_w = screen_w - AndroidUtilities.dp(64)
            expected_img_h = int(img_h * (dialog_w / float(img_w))) if img_w > 0 else 0
            
            if expected_img_h > max_h:
                lp_scroll = LinearLayout.LayoutParams(-1, max_h)
                lp_scroll.weight = 1.0
            else:
                lp_scroll = LinearLayout.LayoutParams(-1, -2)
                
            root_layout.addView(scroll_view, lp_scroll)
            
            caption_input = EditText(act)
            
            if show_comment:
                caption_container = LinearLayout(act)
                caption_container.setOrientation(LinearLayout.VERTICAL)
                
                caption_input.setHint(tr_if_ru("Добавить комментарий..."))
                caption_input.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                caption_input.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
                caption_input.setTextSize(1, 15.0)
                
                input_bg = GradientDrawable()
                bg_color_input = (Theme.getColor(Theme.key_dialogTextBlack) & 0x00FFFFFF) | 0x0C000000
                input_bg.setColor(bg_color_input)
                input_bg.setCornerRadius(AndroidUtilities.dp(6))
                
                caption_input.setBackground(input_bg)
                caption_input.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(12), AndroidUtilities.dp(18), AndroidUtilities.dp(12))
                
                caption_container.addView(caption_input, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0))
                root_layout.addView(caption_container, LayoutHelper.createLinear(-1, -2, 12, 4, 12, 0))

            dialog_ref = [None]

            class ClickListener(dynamic_proxy(View.OnClickListener)):
                def __init__(self, fn):
                    super().__init__()
                    self.fn = fn
                def onClick(self, v):
                    self.fn()
            
            blue_color = Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)
            red_color = Theme.getColor(Theme.key_text_RedRegular)
            
            def make_bg(color_int):
                bg = GradientDrawable()
                bg.setColor((color_int & 0x00FFFFFF) | 0x12000000) 
                bg.setCornerRadius(16.0)
                return bg
              
            btn_text = "Отправить как фото"

            h_layout = LinearLayout(act)
            h_layout.setOrientation(LinearLayout.HORIZONTAL)
            
            transition = LayoutTransition()
            transition.setDuration(150)
            h_layout.setLayoutTransition(transition)
            
            R = jclass("org.telegram.messenger.R")
            
            btn_other = ImageView(act)
            try: btn_other.setImageResource(R.drawable.ic_ab_other)
            except: pass
            btn_other.setColorFilter(blue_color)
            btn_other.setBackground(make_bg(blue_color))
            btn_other.setPadding(AndroidUtilities.dp(11), AndroidUtilities.dp(11), AndroidUtilities.dp(11), AndroidUtilities.dp(11))
            h_layout.addView(btn_other, LayoutHelper.createLinear(46, 46, 0.0, 0, 0, 4, 0))
            
            photo_tv = TextView(act)
            photo_tv.setText(tr_if_ru(btn_text))
            photo_tv.setTextColor(blue_color)
            photo_tv.setTextSize(1, 15.0)
            photo_tv.setTypeface(Typeface.DEFAULT_BOLD)
            photo_tv.setGravity(Gravity.CENTER)
            photo_tv.setSingleLine(True)
            photo_tv.setBackground(make_bg(blue_color))
                    
            def on_main_click():
                comment = caption_input.getText().toString() if show_comment else ""
                self._send_final(output_path, comment, "photo")
                if dialog_ref[0]: dialog_ref[0].dismiss()

            photo_tv.setOnClickListener(ClickListener(on_main_click))
            h_layout.addView(photo_tv, LayoutHelper.createLinear(0, 46, 1.0, 0, 0, 0, 0))

            options_container = LinearLayout(act)
            options_container.setOrientation(LinearLayout.HORIZONTAL)
            options_container.setVisibility(8) 

            def create_option_btn(icon_names, action_fn, is_last=False):
                btn = ImageView(act)
                for name in icon_names:
                    try:
                        btn.setImageResource(getattr(R.drawable, name))
                        break
                    except: pass
                btn.setColorFilter(blue_color)
                btn.setBackground(make_bg(blue_color))
                btn.setPadding(AndroidUtilities.dp(11), AndroidUtilities.dp(11), AndroidUtilities.dp(11), AndroidUtilities.dp(11))
                
                def click_wrapper():
                    if dialog_ref[0]: dialog_ref[0].dismiss()
                    action_fn()
                
                btn.setOnClickListener(ClickListener(click_wrapper))
                options_container.addView(btn, LayoutHelper.createLinear(0, 46, 1.0, 0, 0, 0 if is_last else 4, 0))

            create_option_btn(["msg_sendfile_solar", "msg_file", "msg_document", "ic_ab_doc"], lambda: self._send_final(output_path, caption_input.getText().toString() if show_comment else "", "file"))
            create_option_btn(["msg_sticker", "ic_smiles_stickers"], lambda: self._send_final(output_path, caption_input.getText().toString() if show_comment else "", "sticker"))
            create_option_btn(["msg_download", "msg_gallery", "ic_photo"], lambda: self._save_to_gallery(output_path, act))
            create_option_btn(["msg_share", "ic_share"], lambda: self._share(output_path, act), is_last=True)
            
            h_layout.addView(options_container, LayoutHelper.createLinear(0, 46, 1.0, 0, 0, 0, 0))

            btn_copy = ImageView(act)
            try: btn_copy.setImageResource(R.drawable.msg_copy)
            except: pass
            btn_copy.setColorFilter(blue_color)
            btn_copy.setBackground(make_bg(blue_color))
            btn_copy.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            
            def on_copy():
                self._copy_to_clipboard(output_path, act)
                if dialog_ref[0]: dialog_ref[0].dismiss()
                
            btn_copy.setOnClickListener(ClickListener(on_copy))
            h_layout.addView(btn_copy, LayoutHelper.createLinear(46, 46, 0.0, 4, 0, 0, 0))

            root_layout.addView(h_layout, LayoutHelper.createLinear(-1, -2, 12, 4, 12, 4))

            is_expanded = [False]
            def on_other():
                if not is_expanded[0]:
                    photo_tv.setVisibility(8)
                    options_container.setVisibility(0)
                    
                    for name in ["ic_close_white", "msg_close"]:
                        try:
                            btn_other.setImageResource(getattr(R.drawable, name))
                            break
                        except: pass
                    btn_other.setColorFilter(red_color)
                    btn_other.setBackground(make_bg(red_color))
                    is_expanded[0] = True
                else:
                    options_container.setVisibility(8)
                    photo_tv.setVisibility(0)
                    
                    for name in ["ic_ab_other", "msg_more"]:
                        try:
                            btn_other.setImageResource(getattr(R.drawable, name))
                            break
                        except: pass
                    btn_other.setColorFilter(blue_color)
                    btn_other.setBackground(make_bg(blue_color))
                    is_expanded[0] = False
                    
            btn_other.setOnClickListener(ClickListener(on_other))

            cancel_tv = TextView(act)
            cancel_tv.setText(tr_if_ru("Отмена"))
            cancel_tv.setTextColor(red_color)
            cancel_tv.setTextSize(1, 15.0)
            cancel_tv.setTypeface(Typeface.DEFAULT_BOLD)
            cancel_tv.setGravity(Gravity.CENTER)
            cancel_tv.setSingleLine(True)
            cancel_tv.setBackground(make_bg(red_color))
            
            cancel_tv.setOnClickListener(ClickListener(lambda: dialog_ref[0].dismiss() if dialog_ref[0] else None))
            root_layout.addView(cancel_tv, LayoutHelper.createLinear(-1, 46, 12, 0, 12, 4))

            AlertDialog = jclass("org.telegram.ui.ActionBar.AlertDialog")
            java_builder = AlertDialog.Builder(act)
            java_builder.setView(root_layout)
            
            dialog = java_builder.create()
            dialog.setCanceledOnTouchOutside(False)
            dialog.setCancelable(True)
            
            dialog.show()
            dialog_ref[0] = dialog
            
            plugin_ref = getattr(self, 'plugin', getattr(self, 'pl', getattr(self, '_plugin', None)))
            if plugin_ref:
                plugin_ref._register_dialog(dialog)
            
            try:
                window = dialog.getWindow()
                if window:
                    lp = window.getAttributes()
                    lp.width = int(AndroidUtilities.displaySize.x * 0.95)
                    lp.height = -2
                    window.setAttributes(lp)
            except: pass

        except Exception as e:
            import traceback
            err = traceback.format_exc()
            qlog("Preview error", e)
            copy_error_to_clipboard(err)
            from android_utils import run_on_ui_thread
            from ui.bulletin import BulletinHelper
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка предпросмотра! Скопировано в буфер."))

    def _copy_to_clipboard(self, output_path, act):
        def go():
            try:
                import os
                from android.content import ClipData, Context
                from androidx.core.content import FileProvider
                from java.io import File
                from org.telegram.messenger import ApplicationLoader
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                
                ctx = act if act else ApplicationLoader.applicationContext
                
                ext_cache = ctx.getExternalCacheDir()
                if not ext_cache:
                    ext_cache = ctx.getCacheDir()
                    
                share_dir = os.path.join(ext_cache.getAbsolutePath(), "QuotifyTmp")
                os.makedirs(share_dir, exist_ok=True)
                
                dest = os.path.join(share_dir, os.path.basename(str(output_path)))
                
                with open(str(output_path), 'rb') as src, open(dest, 'wb') as dst:
                    dst.write(src.read())
                
                def copy_on_ui():
                    try:
                        authority = f"{ctx.getPackageName()}.provider"
                        uri = FileProvider.getUriForFile(ctx, authority, File(dest))
                        service_name = "".join(["cli", "pbo", "ard"])
                        clipboard = ctx.getSystemService(service_name)
                        clip_class = jclass("android.content.ClipData")
                        clip = clip_class.newUri(ctx.getContentResolver(), "quotify_image", uri)
                        clipboard.setPrimaryClip(clip)
                        BulletinHelper.show_success("Скопировано в буфер обмена")
                    except Exception as e:
                        err = str(e)[:50]
                        BulletinHelper.show_error(f"Ошибка буфера: {err}")
                        
                run_on_ui_thread(copy_on_ui)
                
            except Exception as e:
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                qlog("Clipboard copy error", e)
                run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка копирования в буфер/галерею"))
        
        import threading
        threading.Thread(target=go).start()

    def _send_final(self, output_path, comment, send_mode):
        def go():
            try:
                from client_utils import send_message, get_send_messages_helper
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                from org.telegram.tgnet import TLRPC
                import time
                from java.io import File as JFile

                if send_mode == "sticker":
                    self._send_as_sticker_adapted(output_path, comment)
                    return

                params = {
                    "peer": self.params.peer,
                    "replyToMsg": getattr(self.params, 'replyToMsg', None)
                }
                if hasattr(self.params, 'replyToTopMsg') and self.params.replyToTopMsg:
                    params["replyToTopMsg"] = self.params.replyToTopMsg

                comment_text = str(comment).strip() if comment else ""

                if send_mode == "file":
                    f = JFile(str(output_path))
                    document = TLRPC.TL_document()
                    document.id = 0
                    document.access_hash = 0
                    document.file_reference = bytearray()
                    document.date = int(time.time())
                    document.mime_type = "image/jpeg"
                    document.size = f.length()
                    document.dc_id = 0
                    
                    file_name = TLRPC.TL_documentAttributeFilename()
                    file_name.file_name = f.getName()
                    document.attributes.add(file_name)
                    
                    params["document"] = document
                    params["path"] = str(output_path)
                    
                    self._send_media_with_comment(params, comment_text, "Отправлено как файл")

                elif send_mode == "photo":
                    send_helper = get_send_messages_helper()
                    photo = send_helper.generatePhotoSizes(str(output_path), None)
                    params["photo"] = photo
                    params["path"] = str(output_path)
                    
                    self._send_media_with_comment(params, comment_text, "Отправлено как фото")

            except Exception as e:
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                err = str(e)[:50]
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка отправки: {err}"))
        
        import threading
        threading.Thread(target=go).start()

    def _send_media_with_comment(self, params, comment_text, success_msg):
        from client_utils import send_message
        from android_utils import run_on_ui_thread
        from ui.bulletin import BulletinHelper

        try:
            if comment_text:
                params["caption"] = comment_text
            send_message(params)
            run_on_ui_thread(lambda: BulletinHelper.show_success(success_msg))
        except Exception:
            params.pop("caption", None)
            params.pop("message", None)
            send_message(params)
            run_on_ui_thread(lambda: BulletinHelper.show_success(success_msg))
            
            if comment_text:
                send_message({
                    "peer": params["peer"],
                    "message": comment_text,
                    "replyToMsg": params.get("replyToMsg")
                })

    def _send_as_sticker_adapted(self, output_path, comment):
        try:
            from org.telegram.messenger import SendMessagesHelper, ImageLoader, UserConfig
            from org.telegram.tgnet import TLRPC
            from java.io import File as JFile
            from java.io import FileOutputStream
            from android.graphics import Bitmap, BitmapFactory
            from android_utils import run_on_ui_thread
            from ui.bulletin import BulletinHelper
            import time
            import os
            
            file_name = time.strftime("Quotify_%y%m%d_%H%M%S.webp")
            webp_path = os.path.join(Filesystem.get_temp_dir(), file_name)
            
            bmp = BitmapFactory.decodeFile(str(output_path))
            if not bmp:
                raise Exception("Failed to decode image")
                
            w, h = bmp.getWidth(), bmp.getHeight()
            scale = min(1.0, 512 / max(w, h))
            new_w, new_h = max(1, int(w * scale)), max(1, int(h * scale))
            
            scaled_bmp = Bitmap.createScaledBitmap(bmp, new_w, new_h, True)
            bmp.recycle()
            
            fos = FileOutputStream(webp_path)
            try:
                webp_lossless = getattr(Bitmap.CompressFormat, 'WEBP_LOSSLESS', None)
                if webp_lossless:
                    scaled_bmp.compress(webp_lossless, 100, fos)
                else:
                    scaled_bmp.compress(Bitmap.CompressFormat.WEBP, 100, fos)
            finally:
                fos.close()
                scaled_bmp.recycle()

            f = JFile(webp_path)
            if not f.exists():
                raise Exception("WebP file not found")
                
            opts = BitmapFactory.Options()
            opts.inJustDecodeBounds = True
            BitmapFactory.decodeFile(webp_path, opts)
            img_w, img_h = opts.outWidth, opts.outHeight
            
            document = TLRPC.TL_document()
            document.id = 0
            document.access_hash = 0
            document.file_reference = bytearray()
            document.date = int(time.time())
            document.mime_type = "image/webp"
            document.size = f.length()
            document.dc_id = 0
            
            file_name_attr = TLRPC.TL_documentAttributeFilename()
            file_name_attr.file_name = f.getName()
            document.attributes.add(file_name_attr)
            
            sticker_attr = TLRPC.TL_documentAttributeSticker()
            sticker_attr.alt = ""
            sticker_attr.stickerset = TLRPC.TL_inputStickerSetEmpty()
            document.attributes.add(sticker_attr)
            
            size_attr = TLRPC.TL_documentAttributeImageSize()
            size_attr.w = img_w
            size_attr.h = img_h
            document.attributes.add(size_attr)
            
            try:
                bmp_thumb = ImageLoader.loadBitmap(webp_path, None, 90, 90, True)
                if bmp_thumb:
                    thumb = ImageLoader.scaleAndSaveImage(bmp_thumb, 90.0, 90.0, 55, False)
                    if thumb:
                        document.thumbs.add(thumb)
                        document.flags = document.flags | 1
                    bmp_thumb.recycle()
            except Exception: pass
            
            account = UserConfig.selectedAccount
            
            from java.util import HashMap
            params_map = HashMap()
            params_map.put("originalPath", webp_path)
            
            send_helper = SendMessagesHelper.getInstance(account)
            from hook_utils import find_class
            SendMessageParams = find_class("org.telegram.messenger.SendMessagesHelper$SendMessageParams")
            
            peer = self.params.peer
            did = 0
            try:
                if isinstance(peer, (int, float)): did = int(peer)
                elif hasattr(peer, 'user_id'): did = peer.user_id
                elif hasattr(peer, 'chat_id'): did = -peer.chat_id
                elif hasattr(peer, 'channel_id'): did = -peer.channel_id
                else: did = int(str(peer).lstrip('-'))
            except: did = 0
                
            reply_to_msg = self.params.replyToMsg
            reply_to_top_msg = getattr(self.params, 'replyToTopMsg', None)
            
            send_params = SendMessageParams.of(
                document, None, webp_path, did, reply_to_msg, reply_to_top_msg, None,
                None, None, params_map, True, 0, 0, 0, None, None, False
            )
            
            run_on_ui_thread(lambda: send_helper.sendMessage(send_params))
            
            if comment and str(comment).strip():
                from client_utils import send_message
                comment_params = {
                    "peer": self.params.peer,
                    "message": str(comment).strip(),
                    "replyToMsg": self.params.replyToMsg
                }
                if hasattr(self.params, 'replyToTopMsg') and self.params.replyToTopMsg:
                    comment_params["replyToTopMsg"] = self.params.replyToTopMsg
                run_on_ui_thread(lambda: send_message(comment_params))

            run_on_ui_thread(lambda: BulletinHelper.show_success("Стикер отправлен"))
            
        except Exception as e:
            from android_utils import run_on_ui_thread
            from ui.bulletin import BulletinHelper
            err = str(e)[:50]
            run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка отправки стикера: {err}"))

    def _save_to_gallery(self, output_path, act):
        def go():
            try:
                import shutil, os
                from android.os import Environment
                from android.content import Intent
                from android.net import Uri
                from java.io import File
                from org.telegram.messenger import ApplicationLoader
                
                pics_dir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_PICTURES)
                q_dir = os.path.join(pics_dir.getAbsolutePath(), "Quotify")
                os.makedirs(q_dir, exist_ok=True)
                
                dest = os.path.join(q_dir, os.path.basename(str(output_path)))
                shutil.copy2(str(output_path), dest)
                
                ctx = act if act else ApplicationLoader.applicationContext
                intent = Intent(Intent.ACTION_MEDIA_SCANNER_SCAN_FILE)
                intent.setData(Uri.fromFile(File(dest)))
                ctx.sendBroadcast(intent)
                
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                run_on_ui_thread(lambda: BulletinHelper.show_success("Сохранено в галерею"))
            except Exception as e:
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                err = str(e)[:50]
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка сохранения: {err}"))
        import threading
        threading.Thread(target=go).start()

    def _share(self, output_path, act):
        def go():
            try:
                import os
                from android.content import Intent
                from androidx.core.content import FileProvider
                from java.io import File
                from org.telegram.messenger import ApplicationLoader
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                
                ctx = act if act else ApplicationLoader.applicationContext
                
                ext_cache = ctx.getExternalCacheDir()
                if not ext_cache:
                    ext_cache = ctx.getCacheDir()
                    
                share_dir = os.path.join(ext_cache.getAbsolutePath(), "QuotifyTmp")
                os.makedirs(share_dir, exist_ok=True)
                
                dest = os.path.join(share_dir, os.path.basename(str(output_path)))
                
                with open(str(output_path), 'rb') as src, open(dest, 'wb') as dst:
                    dst.write(src.read())
                
                def share_on_ui():
                    try:
                        authority = f"{ctx.getPackageName()}.provider"
                        uri = FileProvider.getUriForFile(ctx, authority, File(dest))
                        
                        intent = Intent(Intent.ACTION_SEND)
                        intent.setType("image/jpeg")
                        intent.putExtra(Intent.EXTRA_STREAM, uri)
                        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                        
                        if not act:
                            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                            
                        chooser = Intent.createChooser(intent, "Поделиться цитатой")
                        
                        if act:
                            act.startActivity(chooser)
                        else:
                            ctx.startActivity(chooser)
                    except Exception as e:
                        err = str(e)[:50]
                        BulletinHelper.show_error(f"Ошибка отправки: {err}")
                        
                run_on_ui_thread(share_on_ui)
                
            except Exception as e:
                from android_utils import run_on_ui_thread
                from ui.bulletin import BulletinHelper
                err = str(e)[:50]
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка отправки: {err}"))
                
        import threading
        threading.Thread(target=go).start()

    def _break_long_word(self, draw, word, font, max_width, start_state=None):
        parts = []
        current = ""
        tokens = []
        i = 0
        while i < len(word):
            if word[i] == '\x01':
                end = word.find('\x02', i)
                if end != -1:
                    tokens.append(word[i:end+1])
                    i = end + 1
                    continue
            elif word.startswith("[CEMOJI:", i):
                end = word.find(']', i)
                if end != -1:
                    tokens.append(word[i:end+1])
                    i = end + 1
                    continue
            tokens.append(word[i])
            i += 1
            
        for token in tokens:
            candidate = current + token
            if self._get_text_width(draw, candidate, font, start_state) > max_width and current:
                parts.append(current)
                current = token
            else:
                current = candidate
        if current:
            parts.append(current)
        return parts

    def _sanitize_text(self, text):
        if not text: return " "
        return str(text).replace("\u00ad", "")

    def _wrap_text(self, draw, text, font, max_width):
        text = self._sanitize_text(text)
        lines = []
        paragraphs = text.split('\n')
        state = None
        for p in paragraphs:
            if not p:
                lines.append('')
                continue
            words = p.split(' ')
            if not words or (len(words) == 1 and not words[0]):
                lines.append('')
                continue
                
            current = ""
            for word in words:
                candidate = word if current == "" else current + " " + word
                if self._get_text_width(draw, candidate, font, state) <= max_width:
                    current = candidate
                else:
                    if current:
                        lines.append(current)
                        _, state = self._segment_line(current, state)
                        
                    if self._get_text_width(draw, word, font, state) > max_width:
                        chunks = self._break_long_word(draw, word, font, max_width, state)
                        if chunks:
                            for chunk in chunks[:-1]:
                                lines.append(chunk)
                                _, state = self._segment_line(chunk, state)
                            current = chunks[-1]
                        else:
                            current = word
                    else:
                        current = word
            if current:
                lines.append(current)
                _, state = self._segment_line(current, state)
                
        return '\n'.join(lines)

    def _measure_text_dimensions(self, draw, text, font, spacing):
        if not text: return 0, 0
        lines = text.split('\n')
        
        try: font_size = font.size
        except: font_size = 36
        
        try:
            bbox = draw.textbbox((0, 0), "My", font=font)
            text_h = bbox[3] - bbox[1]
        except: text_h = font_size
        
        try: ratio = int(self.plugin.get_setting("emoji_size_percent", "125")) / 100.0
        except: ratio = 1.25
        emoji_size = int(font_size * ratio)
        
        uniform_line_height = max(text_h, emoji_size)
        pre_header_height = int(text_h * 2.0)
        pre_pad_y = int(text_h * 0.5)

        line_infos = []
        temp_state = None
        for line in lines:
            lw = self._get_text_width(draw, line, font, temp_state)
            was_quote = temp_state.get('QUOTE', False) if temp_state else False
            was_pre = temp_state.get('PRE', False) if temp_state else False
            segs, temp_state = self._segment_line(line, temp_state)
            hq = was_quote or any(s[2].get('QUOTE', False) if len(s) > 2 else False for s in segs)
            hp = was_pre or any(s[2].get('PRE', False) if len(s) > 2 else False for s in segs)
            line_infos.append({'w': lw, 'q': hq, 'p': hp})

        blocks = []
        i = 0
        while i < len(line_infos):
            hq = line_infos[i]['q']
            hp = line_infos[i]['p']
            bw = line_infos[i]['w']
            start_i = i
            j = i + 1
            if hq or hp:
                while j < len(line_infos) and line_infos[j]['q'] == hq and line_infos[j]['p'] == hp:
                    if line_infos[j]['w'] > bw: bw = line_infos[j]['w']
                    j += 1

            lines_in_block = j - start_i
            text_block_h = (uniform_line_height * lines_in_block) + (spacing * (lines_in_block - 1))
            total_block_h = text_block_h
            if hp: total_block_h += pre_header_height + (pre_pad_y * 2)

            blocks.append({
                'total_h': total_block_h,
                'bw': bw,
                'q': hq,
                'p': hp
            })
            i = j

        max_w = 0
        total_height = 0
        for b in blocks:
            if b['bw'] > max_w: max_w = b['bw']
            total_height += b['total_h']
        if len(blocks) > 0:
            total_height += spacing * (len(blocks) - 1)
            
        return max_w, total_height

    def _is_standard_char(self, char):
        code = ord(char)
        if 0x20 <= code <= 0x7E: return True
        if 0x0400 <= code <= 0x04FF: return True
        if code == 0xA0 or code == 0xAD: return True
        return False

    def _segment_line(self, text, start_state=None):
        segments = []
        state = start_state.copy() if start_state else {
            'B': False, 'I': False, 'S': False, 'U': False, 
            'SPOIL': False, 'MONO': False, 'PRE': False, 
            'QUOTE': False, 'LINK': False, 'LANG': ''
        }
        if not text:
            return segments, state
            
        parts = re.split(r'(\x01.*?\x02|\[CEMOJI:-?\d+\])', text)
        render_tg_emoji = self.plugin.get_setting("render_tg_emoji", False)
        
        for part in parts:
            if not part: continue
            if part.startswith("[CEMOJI:") and part.endswith("]"):
                segments.append(("premium_emoji", part[8:-1], state.copy()))
                continue
            if part.startswith("\x01") and part.endswith("\x02"):
                tag = part[1:-1]
                if tag.startswith("/"):
                    t = tag[1:]
                    if t in state: state[t] = False
                    if t.startswith("PRE"): state['PRE'] = False
                else:
                    if tag in state: state[tag] = True
                    elif tag.startswith("PRE:"): 
                        state['PRE'] = True
                        state['LANG'] = tag[4:]
                continue
                
            current_type = None
            current_content = []
            
            i = 0
            length = len(part)
            while i < length:
                char = part[i]
                char_type = "text"
                content = char
                step = 1
                
                is_emoji = False
                if render_tg_emoji:
                    c_ord = ord(char)
                    if not (c_ord < 128 and c_ord not in (35, 42) and not (48 <= c_ord <= 57)):
                        max_lookahead = min(10, length - i)
                        for l in range(max_lookahead, 0, -1):
                            candidate = part[i:i+l]
                            if self._is_telegram_emoji(candidate):
                                char_type = "emoji"
                                content = candidate
                                step = l
                                is_emoji = True
                                break
                                
                if not is_emoji:
                    if not self._is_standard_char(char):
                        char_type = "sys"
                        
                if i + step < length and ord(part[i+step]) == 0xFE0F:
                    if char_type == "sys":
                        content += part[i+step]
                        step += 1
                        
                if current_type is None:
                    current_type = char_type
                    current_content.append(content)
                elif current_type == char_type:
                    current_content.append(content)
                else:
                    segments.append((current_type, "".join(current_content), state.copy()))
                    current_type = char_type
                    current_content = [content]
                    
                i += step
                
            if current_content:
                segments.append((current_type, "".join(current_content), state.copy()))
                
        return segments, state

    def _get_text_width(self, draw, text, font, start_state=None):
        try: font_size = font.size
        except: font_size = 36
        
        try:
            bbox = draw.textbbox((0, 0), "My", font=font)
            text_h = bbox[3] - bbox[1]
        except: text_h = font_size

        bold_shift = 2

        pre_pad_x = int(text_h * 1.0)
        quote_pad_x = int(text_h * 0.8)

        if not text:
            w = 0
            if start_state and start_state.get('QUOTE', False): w += quote_pad_x * 2
            if start_state and start_state.get('PRE', False): w += pre_pad_x * 2
            return w

        try: ratio = int(self.plugin.get_setting("emoji_size_percent", "125")) / 100.0
        except: ratio = 1.25
        emoji_size = int(font_size * ratio)

        total_width = 0

        was_quote = start_state.get('QUOTE', False) if start_state else False
        was_pre = start_state.get('PRE', False) if start_state else False
        segments, _ = self._segment_line(text, start_state)

        has_quote = was_quote or any(seg[2].get('QUOTE', False) if len(seg) > 2 else False for seg in segments)
        has_pre = was_pre or any(seg[2].get('PRE', False) if len(seg) > 2 else False for seg in segments)

        if has_quote: total_width += quote_pad_x * 2
        if has_pre: total_width += pre_pad_x * 2

        for seg in segments:
            seg_type = seg[0]
            content = seg[1]
            state = seg[2] if len(seg) > 2 else {}

            w = 0
            if seg_type == "text":
                try: w = font.getlength(content)
                except Exception:
                    try:
                        bbox = draw.textbbox((0, 0), content, font=font)
                        w = bbox[2] - bbox[0]
                    except: w = len(content) * (font_size * 0.6)
                if state.get('B'): w += bold_shift
            elif seg_type == "emoji":
                count = 0
                pos = 0
                while pos < len(content):
                    count += 1
                    pos += 1
                    while pos < len(content) and ord(content[pos]) == 0xFE0F: pos += 1
                w = (emoji_size * count) + (2 * count)
            elif seg_type == "sys":
                w = UniversalTextRenderer.measure(content, font_size)
                if state.get('B'): w += bold_shift
            elif seg_type == "premium_emoji":
                w = emoji_size + 2

            total_width += w

        return total_width

    def _draw_text_with_emoji(self, canvas, draw, position, text, font, color, spacing, align="left", max_width=0):
        x_start, y_start = position
        try: font_size = font.size
        except: font_size = 36
        try:
            bbox = draw.textbbox((0, 0), "My", font=font)
            text_h = bbox[3] - bbox[1]
            text_y_offset = -bbox[1]
        except:
            text_h = font_size
            text_y_offset = 0
        bold_shift = 1
        italic_factor = 0.15
        try: layout_ratio = int(self.plugin.get_setting("emoji_size_percent", "125")) / 100.0
        except: layout_ratio = 1.25
        try: visual_ratio = int(self.plugin.get_setting("emoji_visual_percent", "150")) / 100.0
        except: visual_ratio = 1.50
        layout_emoji_size = int(font_size * layout_ratio)
        render_emoji_size = int(font_size * visual_ratio)
        try: user_offset = int(self.plugin.get_setting("emoji_y_offset", "0"))
        except: user_offset = 0
        try:
            offset_text_x = -int(self.plugin.get_setting("text_offset_x", "0"))
            offset_text_y = -int(self.plugin.get_setting("text_offset_y", "0"))
        except:
            offset_text_x = 0
            offset_text_y = 0
        uniform_line_height = max(text_h, layout_emoji_size)
        pre_header_height = int(text_h * 2.0)
        pre_pad_x = int(text_h * 1.0)
        pre_pad_y = int(text_h * 0.5)
        quote_pad_x = int(text_h * 0.8)
        base_color = (0, 0, 0, 255)
        color_int = 0xFF000000
        if isinstance(color, tuple):
            base_color = color
            if len(color) == 3: color_int = (255 << 24) | (color[0] << 16) | (color[1] << 8) | color[2]
            elif len(color) == 4: color_int = (color[3] << 24) | (color[0] << 16) | (color[1] << 8) | color[2]
        elif isinstance(color, int):
            base_color = ((color >> 16) & 255, (color >> 8) & 255, color & 255, (color >> 24) & 255)
            color_int = color
        lines = text.split('\n')
        if align != "left" and (not max_width or max_width <= 0):
            max_width = max(self._get_text_width(draw, line, font) for line in lines)
        line_infos = []
        temp_state = None
        for line in lines:
            lw = self._get_text_width(draw, line, font, temp_state)
            was_quote = temp_state.get('QUOTE', False) if temp_state else False
            was_pre = temp_state.get('PRE', False) if temp_state else False
            segs, temp_state = self._segment_line(line, temp_state)
            hq = was_quote or any(s[2].get('QUOTE', False) if len(s) > 2 else False for s in segs)
            hp = was_pre or any(s[2].get('PRE', False) if len(s) > 2 else False for s in segs)
            line_infos.append({'w': lw, 'q': hq, 'p': hp, 'segs': segs, 'line': line})
        blocks = []
        i = 0
        while i < len(line_infos):
            hq = line_infos[i]['q']
            hp = line_infos[i]['p']
            bw = line_infos[i]['w']
            start_i = i
            j = i + 1
            if hq or hp:
                while j < len(line_infos) and line_infos[j]['q'] == hq and line_infos[j]['p'] == hp:
                    if line_infos[j]['w'] > bw: bw = line_infos[j]['w']
                    j += 1
            lines_in_block = j - start_i
            text_block_h = (uniform_line_height * lines_in_block) + (spacing * (lines_in_block - 1))
            total_block_h = text_block_h
            if hp: total_block_h += pre_header_height + (pre_pad_y * 2)
            blocks.append({
                'start': start_i, 'end': j, 'q': hq, 'p': hp, 
                'bw': bw, 'text_h': text_block_h, 'total_h': total_block_h
            })
            i = j
        current_y = y_start
        for b in blocks:
            bw = b['bw']
            block_x = x_start
            if align == "center" and max_width > 0: block_x = x_start + (max_width - bw) // 2
            elif align == "right" and max_width > 0: block_x = x_start + (max_width - bw)
            if b['q']:
                line_w = max(4, int(font_size * 0.15))
                draw.line((block_x, current_y + offset_text_y, block_x, current_y + offset_text_y + b['total_h']), fill=base_color, width=line_w)
                import PIL.Image
                quote_bg_width = int(bw - line_w)
                if quote_bg_width < 1: quote_bg_width = 1
                quote_bg = PIL.Image.new('RGBA', (quote_bg_width, int(b['total_h'])), (base_color[0], base_color[1], base_color[2], 30))
                canvas.paste(quote_bg, (int(block_x + line_w), int(current_y + offset_text_y)), quote_bg)
            elif b['p']:
                pre_w = int(bw)
                if pre_w < int(font_size * 5): pre_w = int(font_size * 5)
                header_y = current_y + offset_text_y
                import PIL.Image
                header_bg = PIL.Image.new('RGBA', (pre_w, int(pre_header_height)), (33, 37, 43, 255))
                canvas.paste(header_bg, (int(block_x), int(header_y)), header_bg)
                circ_y = header_y + (pre_header_height / 2.0)
                r = font_size * 0.25
                c_space = font_size * 0.75
                c_x = block_x + font_size * 1.0
                draw.ellipse((int(c_x), int(circ_y - r), int(c_x + r*2), int(circ_y + r)), fill=(255, 95, 86, 255))
                c_x += c_space
                draw.ellipse((int(c_x), int(circ_y - r), int(c_x + r*2), int(circ_y + r)), fill=(255, 189, 46, 255))
                c_x += c_space
                draw.ellipse((int(c_x), int(circ_y - r), int(c_x + r*2), int(circ_y + r)), fill=(39, 201, 63, 255))
                lang = ""
                for line_idx in range(b['start'], b['end']):
                    for s in line_infos[line_idx]['segs']:
                        if len(s) > 2 and s[2].get('PRE', False):
                            lang = s[2].get('LANG', '')
                            if lang: break
                    if lang: break
                if lang:
                    try: lw = font.getlength(lang)
                    except:
                        try: bbox = draw.textbbox((0, 0), lang, font=font); lw = bbox[2] - bbox[0]
                        except: lw = len(lang) * (font_size * 0.6)
                    lang_x = block_x + pre_w - lw - font_size * 1.0
                    lang_y = header_y + (pre_header_height - text_h) / 2.0 + text_y_offset
                    draw.text((int(lang_x), int(lang_y)), lang, font=font, fill=(130, 134, 140, 200))
                body_y = header_y + pre_header_height
                body_h = b['total_h'] - pre_header_height
                body_bg = PIL.Image.new('RGBA', (pre_w, int(body_h)), (40, 44, 52, 255))
                canvas.paste(body_bg, (int(block_x), int(body_y)), body_bg)
            line_y = current_y
            if b['p']: line_y += pre_header_height + pre_pad_y
            for line_idx in range(b['start'], b['end']):
                segs = line_infos[line_idx]['segs']
                line_w_actual = line_infos[line_idx]['w']
                text_x = block_x
                if not b['q'] and not b['p']:
                    if align == "center" and max_width > 0:
                        text_x = x_start + (max_width - line_w_actual) // 2
                    elif align == "right" and max_width > 0:
                        text_x = x_start + (max_width - line_w_actual)
                else:
                    if b['q']: text_x += quote_pad_x
                    if b['p']: text_x += pre_pad_x
                visual_y_start = line_y + offset_text_y + (uniform_line_height - text_h) / 2.0 + user_offset
                text_render_y = visual_y_start + text_y_offset
                line_visual_center_y = visual_y_start + (text_h / 2.0)
                for seg in segs:
                    seg_type = seg[0]
                    content = seg[1]
                    seg_state = seg[2] if len(seg) > 2 else {}
                    is_bold = seg_state.get('B', False)
                    is_italic = seg_state.get('I', False)
                    is_strike = seg_state.get('S', False)
                    is_under = seg_state.get('U', False)
                    is_spoil = seg_state.get('SPOIL', False)
                    is_mono = seg_state.get('MONO', False)
                    is_pre = seg_state.get('PRE', False)
                    is_link = seg_state.get('LINK', False)
                    w = 0
                    if seg_type == "text":
                        try: w = font.getlength(content)
                        except:
                            try: bbox = draw.textbbox((0, 0), content, font=font); w = bbox[2] - bbox[0]
                            except: w = len(content) * (font_size * 0.6)
                        if is_bold: w += bold_shift
                    elif seg_type == "sys":
                        w = UniversalTextRenderer.measure(content, font_size)
                        if is_bold: w += bold_shift
                    elif seg_type == "emoji":
                        count = 0
                        pos = 0
                        while pos < len(content):
                            count += 1
                            pos += 1
                            while pos < len(content) and ord(content[pos]) == 0xFE0F: pos += 1
                        w = (layout_emoji_size * count) + (2 * count)
                    elif seg_type == "premium_emoji":
                        w = layout_emoji_size + 2
                    draw_color = base_color
                    if is_link: draw_color = (88, 166, 240, 255)
                    if is_pre: draw_color = (171, 178, 191, 255)
                    if is_mono: draw_color = (229, 192, 123, 255)
                    if seg_type == "text":
                        render_x = text_x + offset_text_x
                        render_y = text_render_y
                        if is_italic:
                            import PIL.Image
                            import PIL.ImageDraw
                            t_w = int(w + (font_size * italic_factor) + font_size)
                            t_h = int(font_size * 2.5)
                            temp_img = PIL.Image.new('RGBA', (t_w, t_h), (0,0,0,0))
                            temp_draw = PIL.ImageDraw.Draw(temp_img)
                            temp_draw.text((int(font_size * italic_factor), int(font_size * 0.5)), content, font=font, fill=draw_color)
                            if is_bold: 
                                temp_draw.text((int(font_size * italic_factor) + bold_shift, int(font_size * 0.5)), content, font=font, fill=draw_color)
                            temp_img = temp_img.transform(temp_img.size, PIL.Image.AFFINE, (1, italic_factor, 0, 0, 1, 0), PIL.Image.BICUBIC)
                            canvas.paste(temp_img, (int(render_x - (font_size * italic_factor)), int(render_y - font_size * 0.5)), temp_img)
                        elif is_pre:
                            import re
                            pattern = r'(\".*?\"|\'.*?\'|\b\d+\b|\b(?:def|class|import|from|return|if|else|elif|for|while|try|except|with|as|pass|break|continue|True|False|None|and|or|not|in|is|lambda|var|let|const|function|async|await)\b|[^\w\s]+|\s+|\w+)'
                            cx = render_x
                            for match in re.finditer(pattern, content):
                                val = match.group(0)
                                c = draw_color
                                if val.startswith("'") or val.startswith('"'): c = (152, 195, 121, 255)
                                elif val.isdigit(): c = (209, 154, 102, 255)
                                elif val in ["def", "class", "import", "from", "return", "if", "else", "elif", "for", "while", "try", "except", "with", "as", "pass", "break", "continue", "True", "False", "None", "and", "or", "not", "in", "is", "lambda", "var", "let", "const", "function", "async", "await"]: c = (198, 120, 221, 255)
                                draw.text((cx, render_y), val, font=font, fill=c)
                                if is_bold: draw.text((cx + bold_shift, render_y), val, font=font, fill=c)
                                try: cw = font.getlength(val)
                                except:
                                    try: bbox = draw.textbbox((0, 0), val, font=font); cw = bbox[2] - bbox[0]
                                    except: cw = len(val) * (font_size * 0.6)
                                cx += cw
                        else:
                            draw.text((render_x, render_y), content, font=font, fill=draw_color)
                            if is_bold: draw.text((render_x + bold_shift, render_y), content, font=font, fill=draw_color)
                    elif seg_type == "emoji":
                        emoji_parts = []
                        e_i = 0
                        while e_i < len(content):
                            start = e_i
                            e_i += 1
                            while e_i < len(content) and ord(content[e_i]) == 0xFE0F: e_i += 1
                            emoji_parts.append(content[start:e_i])
                        for part in emoji_parts:
                            emoji_img = EmojiRenderer.render_emoji_to_pil(part, render_emoji_size)
                            if emoji_img:
                                draw_x = text_x + (layout_emoji_size - render_emoji_size) / 2.0
                                draw_y = line_visual_center_y - (render_emoji_size / 2.0)
                                try: canvas.paste(emoji_img, (int(draw_x), int(draw_y)), emoji_img)
                                except: pass
                            text_x += layout_emoji_size + 2
                        text_x -= w
                    elif seg_type == "sys":
                        sys_img = UniversalTextRenderer.render(content, font_size, color_int)
                        if sys_img:
                            sys_h = sys_img.height
                            draw_y = line_visual_center_y - (sys_h / 2.0)
                            try: canvas.paste(sys_img, (int(text_x), int(draw_y)), sys_img)
                            except: pass
                            if is_bold:
                                try: canvas.paste(sys_img, (int(text_x + bold_shift), int(draw_y)), sys_img)
                                except: pass
                    elif seg_type == "premium_emoji":
                        try:
                            doc_id = int(content)
                            import PIL.Image
                            emoji_img = PremiumEmojiRenderer.render_premium_emoji(doc_id, render_emoji_size)
                            if emoji_img:
                                target_size = int(render_emoji_size * 0.88)
                                emoji_img = emoji_img.resize((target_size, target_size), PIL.Image.LANCZOS)
                                draw_x = text_x + (layout_emoji_size - target_size) / 2.0
                                draw_y = line_visual_center_y - (target_size / 2.0)
                                try: canvas.paste(emoji_img, (int(draw_x), int(draw_y)), emoji_img)
                                except: pass
                        except: pass
                    if is_strike:
                        mid_y = int(line_visual_center_y)
                        draw.line((text_x, mid_y, text_x + w, mid_y), fill=draw_color, width=max(2, int(font_size*0.06)))
                    if is_under:
                        und_y = int(line_visual_center_y + (text_h / 2.0) + 2)
                        draw.line((text_x, und_y, text_x + w, und_y), fill=draw_color, width=max(2, int(font_size*0.06)))
                    if is_spoil:
                        import PIL.Image
                        spoil_h = int(text_h * 1.3)
                        spoil_y = int(line_visual_center_y - (spoil_h / 2.0))
                        spoil_overlay = PIL.Image.new('RGBA', (int(w), spoil_h), (100, 100, 100, 204))
                        canvas.paste(spoil_overlay, (int(text_x), spoil_y), spoil_overlay)
                    text_x += w
                line_y += uniform_line_height + spacing
            current_y += b['total_h'] + spacing

    def _prefetch_all_emojis(self, items):
        if not items: return
        size_map = {}
        for text, font in items:
            if not text: continue
            try: font_size = font.size
            except: font_size = 36
            
            try: visual_ratio = int(self.plugin.get_setting("emoji_visual_percent", "150")) / 100.0
            except: visual_ratio = 1.30
            render_size = int(font_size * visual_ratio)
            
            segments, _ = self._segment_line(str(text))
            for seg in segments:
                if seg[0] == "premium_emoji":
                    if render_size not in size_map: size_map[render_size] = set()
                    size_map[render_size].add(int(seg[1]))
                    
        if not size_map: return
        import threading
        events = []
        for size, doc_ids in size_map.items():
            if doc_ids:
                ev = threading.Event()
                events.append(ev)
                PremiumEmojiRenderer.prefetch_emojis_async(list(doc_ids), size, on_done=lambda e=ev: e.set())
        for ev in events:
            ev.wait(0.04)

    def _is_telegram_emoji(self, text):
        try: return Emoji.getEmojiDrawable(text) is not None
        except: return False

    def _is_emoji_only(self, text):
        if not text or not text.strip():
            return False
        
        text = text.strip()
        
        emoji_count = 0
        char_count = 0
        
        for char in text:
            if self._is_emoji_char(char):
                emoji_count += 1
            elif not char.isspace():
                char_count += 1
        
        return emoji_count > 0 and char_count == 0
    
    def _is_emoji_char(self, char):
        try:
            codepoint = ord(char)
            
            if (0x1F000 <= codepoint <= 0x1FFFF or
                0x2600 <= codepoint <= 0x27BF or
                0x2300 <= codepoint <= 0x23FF or
                0x2B00 <= codepoint <= 0x2BFF or
                0xFE00 <= codepoint <= 0xFE0F or
                0x1F300 <= codepoint <= 0x1F9FF or
                0x1FA00 <= codepoint <= 0x1FAFF or
                0x203C <= codepoint <= 0x3299 or
                codepoint == 0x200D or
                codepoint == 0xFE0F):
                return True
        except:
            pass
        
        return False
        
    def _get_author(self):
        try:
            if self.override_author_name:
                name = str(self.override_author_name)
                if name.strip():
                    return name.strip()

            if self.user and self.replyer.name is not None:
                return self.replyer.name

            if self.replyer.name:
                name = str(self.replyer.name)
                if name.strip():
                    return name.strip()

            if self.search_query:
                name = str(self.search_query)
                if name.strip():
                    return name.strip()
        except Exception:
            pass
            
        default = self.plugin.get_setting("unknown_author_label", "Неизвестен")
        return str(default) if default is not None else "Неизвестен"

class QuotifyForkPlugin(BasePlugin):
    class ActivityResultHook(MethodHook):
        def __init__(self, plugin_instance):
            self.plugin = plugin_instance

        def before_hooked_method(self, param):
            request_code = param.args[0]
            result_code = param.args[1]
            data = param.args[2]
            
            handled = False
            if result_code == Activity.RESULT_OK and data is not None and data.getData() is not None:
                uri_string = data.getData().toString()
                
                if request_code == FILE_PICK_REQUEST_CODE:
                    param.setResult(None)
                    run_on_ui_thread(lambda: self.plugin._handle_file_picker_result(uri_string, 'font'))
                    handled = True
                elif request_code == PICK_BG_REQUEST_CODE:
                    param.setResult(None)
                    run_on_ui_thread(lambda: self.plugin._handle_file_picker_result(uri_string, 'bg'))
                    handled = True
                elif request_code == PICK_AVA_REQUEST_CODE:
                    param.setResult(None)
                    run_on_ui_thread(lambda: self.plugin._handle_file_picker_result(uri_string, 'avatar'))
                    handled = True
                elif request_code == IMPORT_SETTINGS_CODE:
                    param.setResult(None)
                    run_on_ui_thread(lambda: self.plugin._handle_import_json(uri_string))
                    handled = True

            if request_code in (FILE_PICK_REQUEST_CODE, PICK_BG_REQUEST_CODE, PICK_AVA_REQUEST_CODE, IMPORT_SETTINGS_CODE):
                if self.plugin._activity_hook:
                    self.plugin._activity_hook.unhook()
                    self.plugin._activity_hook = None

    def __init__(self):
        super().__init__()
        self._temp_dir_path = None
        self._activity_hook = None
        self._hooks = []
        self._active_dialogs = []
        self.unloaded = False

    def _register_dialog(self, dialog):
        if dialog:
            self._active_dialogs.append(dialog)

    def refresh_settings(self, *args):
        def refresher():
            try:
                from android_utils import run_on_ui_thread
                from client_utils import get_last_fragment
                from hook_utils import get_private_field, find_class
                from android.view.animation import AccelerateDecelerateInterpolator, DecelerateInterpolator
                from java import dynamic_proxy, jclass
                
                class ActionRunnable(dynamic_proxy(jclass("java.lang.Runnable"))):
                    def __init__(self, cb):
                        super().__init__()
                        self.cb = cb
                    def run(self):
                        self.cb()

                fragment = get_last_fragment()
                if fragment and "PluginSettingsActivity" in str(fragment.getClass().getName()):
                    listView = get_private_field(fragment, "listView")
                    if listView:
                        def do_update():
                            try:
                                if PluginsController:
                                    PluginsController.getInstance().loadPluginSettings(self.id)
                                try:
                                    if hasattr(fragment, "updateItems"):
                                        fragment.updateItems()
                                    else:
                                        items = get_private_field(fragment, "items")
                                        adapter = listView.getAdapter()
                                        if items is not None and adapter is not None:
                                            items.clear()
                                            try:
                                                PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
                                                if not PSA:
                                                    PSA = find_class("com.radolyn.ayugram.plugins.ui.PluginSettingsActivity")
                                                if PSA:
                                                    fill_method = PSA.getDeclaredMethod("fillItems", find_class("java.util.ArrayList"), find_class("org.telegram.ui.Components.UniversalAdapter"))
                                                    fill_method.setAccessible(True)
                                                    fill_method.invoke(fragment, items, adapter)
                                            except Exception as inner_e:
                                                pass
                                            adapter.notifyDataSetChanged()
                                except Exception as e:
                                    pass
                                listView.setAlpha(0.0)
                                listView.setTranslationY(20.0)
                                listView.animate().alpha(1.0).translationY(0.0).setDuration(180).setInterpolator(DecelerateInterpolator()).start()
                            except Exception:
                                pass
                        
                        listView.animate().alpha(0.0).setDuration(80).setInterpolator(AccelerateDecelerateInterpolator()).withEndAction(ActionRunnable(do_update)).start()
                        return
            except Exception:
                pass
            try:
                if PluginsController:
                    PluginsController.getInstance().loadPluginSettings(self.id)
            except: pass
        from android_utils import run_on_ui_thread
        run_on_ui_thread(refresher)

    def create_color_picker_row(self, key, text, default_hex, icon):
        from ui.settings import Text
        
        current_val = self.get_setting(key, default_hex)
        display_text = f"{text} [{current_val}]"
        
        def on_click(*args):
            try:
                from client_utils import get_last_fragment
                from org.telegram.ui.Components.Paint import ColorPickerBottomSheet
                from android.graphics import Color
                from java import jint, dynamic_proxy, jclass
                from java.lang import Boolean
                
                frag = get_last_fragment()
                ctx = frag.getParentActivity() if frag else None
                if not ctx:
                    from org.telegram.messenger import ApplicationLoader
                    ctx = ApplicationLoader.applicationContext
                    
                try:
                    picker = ColorPickerBottomSheet(ctx, Boolean.TRUE, DummyPipetteDelegate())
                except Exception:
                    try:
                        picker = ColorPickerBottomSheet(ctx, True, DummyPipetteDelegate())
                    except Exception:
                        try:
                            picker = ColorPickerBottomSheet(ctx, None)
                            picker.setPipetteDelegate(DummyPipetteDelegate())
                            picker.setHasAlpha(True)
                        except Exception:
                            picker = ColorPickerBottomSheet(ctx, None)
                            picker.setPipetteDelegate(DummyPipetteDelegate())
                
                def on_color(c):
                    try:
                        if ((c >> 24) & 0xFF) == 255:
                            hex_c = f"#{c & 0xFFFFFF:06X}"
                        else:
                            hex_c = f"#{(c & 0xFFFFFFFF):08X}"
                        self.set_setting(key, hex_c)
                        self.refresh_settings()
                    except Exception:
                        pass
                        
                picker.setColorListener(ColorConsumer(on_color))
                try:
                    c_val = Color.parseColor(str(self.get_setting(key, default_hex)))
                except:
                    c_val = Color.parseColor(default_hex)
                picker.setColor(jint(c_val))
                picker.show()
            except Exception:
                pass

        try:
            return Text(text=text, subtext=f"Текущий: {current_val}", icon=icon, on_click=on_click)
        except TypeError:
            try:
                return Text(text=display_text, icon=icon, on_click=on_click)
            except Exception:
                return Text(text=display_text, on_click=on_click)

    def on_plugin_load(self):
        global plugin_instance
        plugin_instance = self
        try:
            self._prepare_directories()
            FontManager.init()
            DebugLogger.init(self) 
            self.add_on_send_message_hook()
            self._hooks = []
            self._hook_android_utilities()
            self._setup_settings_header_hook()
            
            if self.get_setting("show_quote_context_menu", True):
                self.add_menu_item(MenuItemData(
                    menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                    text="Создать цитату",
                    icon="msg_msgbubble3_solar",
                    on_click=self._handle_create_quote_menu
                ))
            
            MediaDataController.getInstance(0).loadStickersByEmojiOrName("bwaaa_pack", False, False)
            MediaDataController.getInstance(0).loadStickersByEmojiOrName("Quotify_Plus", False, False)
            threading.Thread(target=self._ensure_fallback_avatar_cached).start()
            qlog("Plugin loaded successfully")
        except Exception as e:
            qlog(f"Load error: {e}")

    def _handle_create_quote_menu(self, context):
        if getattr(self, 'unloaded', False):
            return
        try:
            message_obj = context.get("message")
            if not message_obj:
                BulletinHelper.show_error("Не удалось получить сообщение")
                return

            class DummyParams:
                def __init__(self, msg, ctx):
                    self.replyToMsg = msg
                    try:
                        self.peer = msg.getDialogId()
                    except:
                        self.peer = 0
                    self.replyToTopMsg = None
                    self.selectedText = ctx.get("selectedText") or ctx.get("selected_text")
                    self.messageOwner = getattr(msg, 'messageOwner', msg)
                    self.message = getattr(msg, 'messageOwner', msg)
            
            dummy_params = DummyParams(message_obj, context)
            
            font_index = self.get_setting("font", 1)
            layout_index = self.get_setting("quote_style", 0)
            fixed_width = self.get_setting("fixed_width", True)
            custom_bg_path = self.get_setting("bg_custom_path", "")
            custom_avatar_path = self.get_setting("avatar_custom_path", "")
            force_bg = self.get_setting("bg_use_custom", False)
            force_ava = self.get_setting("avatar_use_custom", False)
            
            self._increment_stat("quotify_stats_total")
            self._increment_stat("quotify_stats_normal")
            self._increment_stat("stats_cmd_q")
            self.last_cmd = '.q'
            
            quote = QuoteManager(dummy_params, font_index, layout_index, fixed_width, self, custom_bg_path, custom_avatar_path, force_bg, force_ava, search_query=None)
            if dummy_params.selectedText:
                quote.override_quote_text = str(dummy_params.selectedText)
            quote.force_preview = True
            quote.generate_quote()
        except Exception as e:
            qlog(f"Context menu quote error: {e}", error=e)
            BulletinHelper.show_error("Ошибка при создании цитаты из меню")

    def _ensure_fallback_avatar_cached(self):
        try:
            temp_dir = self._temp_dir_path
            cache_path = os.path.join(temp_dir, "fallback_cache.jpg")
            if os.path.exists(cache_path) and os.path.getsize(cache_path) > 0:
                return

            def run():
                try:
                    headers = {'User-Agent': 'Mozilla/5.0'}
                    html = _r_get(f"https://t.me/{FALLBACK_AVATAR_USERNAME}", headers=headers, timeout=5)
                    match = re.search(r'<meta property="og:image" content="([^"]+)"', html.text)
                    if match:
                        img_data = _r_get(match.group(1), headers=headers, timeout=5).content
                        with open(cache_path, 'wb') as f:
                            f.write(img_data)
                except Exception:
                    pass
            threading.Thread(target=run).start()
        except Exception:
            pass

    def _toggle_debug_logging(self, value):
        self.set_setting("debug_logging", value)
        DebugLogger.enabled = value
        if value:
            BulletinHelper.show_success("Логирование включено")
            qlog("Debug logging enabled manually")
        else:
            BulletinHelper.show_info("Логирование выключено")

    def _save_debug_logs(self, view=None):
        export_dir = self._get_export_dir()
        saved_path = DebugLogger.save_logs(export_dir, is_error=False)
        if saved_path:
            BulletinHelper.show_success(f"Сохранено в:\n{saved_path}")
        else:
            BulletinHelper.show_error("Ошибка сохранения или логи пусты")

    def _clear_debug_logs(self, view=None):
        DebugLogger.clear_logs()
        BulletinHelper.show_success("Логи очищены")
        self.refresh_settings()

    def _test_logging(self, view=None):
        qlog("Test log entry")
        BulletinHelper.show_success("Запись добавлена")
        self.refresh_settings()

    def _copy_recent_logs(self, view=None):
        try:
            if not DebugLogger.logs:
                BulletinHelper.show_info("Логи пусты")
                return
            recent_logs = DebugLogger.logs[-10:]
            log_text = "\n".join(recent_logs)
            ctx = ApplicationLoader.applicationContext
            service_name = "".join(["cli", "pbo", "ard"])
            clipboard = ctx.getSystemService(service_name)
            clip_class = jclass("android.content.ClipData")
            clip = clip_class.newPlainText("Quotify Logs", log_text)
            clipboard.setPrimaryClip(clip)
            BulletinHelper.show_success("Скопировано")
        except:
            BulletinHelper.show_error("Ошибка копирования")

    def _prepare_directories(self):
        try:
            base_dir = ApplicationLoader.getFilesDirFixed()
            temp_dir = File(base_dir, "quotify_fork")
            if not temp_dir.exists():
                temp_dir.mkdirs()
            self._temp_dir_path = temp_dir.getAbsolutePath()
            fonts_dir = File(temp_dir, "fonts")
            if not fonts_dir.exists():
                fonts_dir.mkdirs()
            images_dir = File(temp_dir, "images")
            if not images_dir.exists():
                images_dir.mkdirs()
        except Exception as e:
            qlog(f"Directory error: {e}")

    def _parse_hex_color(self, hex_string, default_color):
        try:
            hex_string = hex_string.lstrip('#')
            if len(hex_string) == 8:
                a = int(hex_string[0:2], 16)
                r = int(hex_string[2:4], 16)
                g = int(hex_string[4:6], 16)
                b = int(hex_string[6:8], 16)
                return (r, g, b, a)
            elif len(hex_string) == 6:
                return tuple(int(hex_string[i:i+2], 16) for i in (0, 2, 4))
        except (ValueError, TypeError):
            pass
        return default_color

    def _show_font_faq_alert(self, view=None):
        title = "🎨 Как выбрать кастомные шрифты"
        text = (
            "📝 Как добавить кастомный шрифт?\n\n"
            "1️⃣ Выберите 'Кастомный шрифт' в селекторе шрифтов\n\n"
