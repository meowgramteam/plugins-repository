def find_class(c: str) -> Any:
    loader = jclass("org.telegram.messenger.ApplicationLoader")
    ctx = loader.applicationContext
    cl = loader.getClassLoader()
    if (
        loader and
        ctx and
        cl
    ): return cl.loadClass(c)
    return None

