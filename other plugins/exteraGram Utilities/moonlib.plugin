def _find_su() -> str:
    su_dir = [
            "/bin",
            "/sbin",
            "/system/bin",
            "/vendor/bin"
            ]
    _su_dir = ""
    for _dir in su_dir:
        file = pathlib.Path(f"{_dir}/su")
        if file.exists(): _su_dir = f"{_dir}/su"
    return _su_dir

def _create_text(text: list) -> str:
    _text = ""
    for line in text:
        _text += line
        index = text.index(_text)
        length = text.__len__()
        if length is not index: _text += "\n"
    return _text

