from java.util import Locale

LOCAL_DEX_PATH = "/storage/emulated/0/Android/media/com.exteragram.messenger/previewaniv.dex"
CLASS_NAME = "aniv.preview.PreviewAnivMain"
METHOD_START = "start"
METHOD_GET_INSTANCE = "getInstance"
METHOD_OPEN_PREVIEW = "openPreview"
METHOD_OPEN_SETTINGS = "showSettings"

class DownloadListener(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    def __init__(self, plugin, account, file_name, download_path, target_path):
        super().__init__()
        self.plugin = plugin
        self.account = account
        self.file_name = file_name
        self.download_path = download_path
        self.target_path = target_path
        self.nc = NotificationCenter.getInstance(account)

    def didReceivedNotification(self, id, account, args):
        try:
            loaded_file_name = str(args[0])
            if self.file_name and loaded_file_name:
                if loaded_file_name != self.file_name and not loaded_file_name.endswith("/" + self.file_name):
                    return

            if id == NotificationCenter.fileLoaded:
                self.plugin.log(f"File {self.file_name} downloaded success")
                if os.path.exists(self.download_path):
                    shutil.copy2(self.download_path, self.target_path)
                    self.plugin.log(f"Successful copy to {self.target_path}")
                    BulletinHelper.show_info("Install completed")
                    self.plugin.on_dex_installed()
                self.cleanup()

            elif id == NotificationCenter.fileLoadFailed:
                self.plugin.log(f"File {self.file_name} download failed")
                self.cleanup()
        except Exception as e:
            self.plugin.log(f"Listener error: {e}")

    def cleanup(self):
        self.nc.removeObserver(self, NotificationCenter.fileLoaded)
        self.nc.removeObserver(self, NotificationCenter.fileLoadFailed)
        self.plugin._remove_download_listener(self)


class InstallHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            span = param.args[0]
            message_obj = param.args[2]

            if span is None or message_obj is None:
                return

            url: str = span.getURL()
            if not url.startswith("tg://previewaniv/install"):
                return

            self.plugin.log(f"Installing: {url}")

            document = message_obj.getDocument()
            if document is None:
                return

            current_account = message_obj.currentAccount
            loader = FileLoader.getInstance(current_account)
            file_name = FileLoader.getAttachFileName(document)

            download_path = loader.getPathToAttach(document, True).getAbsolutePath()
            target_dir = "/storage/emulated/0/Android/media/com.exteragram.messenger/"
            if not os.path.exists(target_dir):
                os.makedirs(target_dir)
            target_path = os.path.join(target_dir, "previewaniv.dex")

            if os.path.exists(download_path):
                shutil.copy2(download_path, target_path)
                self.plugin.log("Installed from cache")
                BulletinHelper.show_info("Updated from cache")
                self.plugin.on_dex_installed()
                return

            self.plugin.log(f"File not found, registering listener for {file_name}...")
            listener = DownloadListener(self.plugin, current_account, file_name, download_path, target_path)
            self.plugin._add_download_listener(listener)

            nc = NotificationCenter.getInstance(current_account)
            nc.addObserver(listener, NotificationCenter.fileLoaded)
            nc.addObserver(listener, NotificationCenter.fileLoadFailed)

            loader.loadFile(document, message_obj, 1, 1)
            BulletinHelper.show_info("Downloading...")

        except Exception as e:
            self.plugin.log(f"InstallHook: {e}")


class Loader:
    def __init__(self, plugin: BasePlugin):
        self.plugin = plugin
        self.instance = None
        self.cache_dir = os.path.join(
            ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(),
            "previewaniv_cache"
        )
        self.cache_file = os.path.join(self.cache_dir, "cached.dat")
        self.dex_loader = None

        if not os.path.exists(self.cache_dir):
            os.makedirs(self.cache_dir)

    def get_instance(self):
        if self.instance is None:
            try:
                method = find_class(CLASS_NAME).getClass().getMethod(METHOD_GET_INSTANCE)
                self.instance = method.invoke(None)
            except Exception as e:
                self.plugin.log(f"Error getting instance: {e}")
        return self.instance

    def start_from_bytes(self, bytesdex: bytes):
        try:
            buffer = ByteBuffer.wrap(bytesdex)
            self.dex_loader = InMemoryDexClassLoader(
                buffer,
                ApplicationLoader.applicationContext.getClassLoader()
            )
            clazz = self.dex_loader.loadClass(CLASS_NAME)
            start_method = clazz.getMethod(METHOD_START)
            instance_method = clazz.getMethod(METHOD_GET_INSTANCE)
            instance = instance_method.invoke(None)
            self.instance = instance
            start_method.invoke(instance)
            self.plugin.log(f"Successfully loaded from bytes. Class: {CLASS_NAME}")
        except Exception as e:
            self.plugin.log(f"Error invoking start method: {e}")
            raise

    def load_and_start(self) -> bool:
        try:
            if os.path.exists(LOCAL_DEX_PATH):
                self.plugin.log(f"Local DEX found at {LOCAL_DEX_PATH}. Loading...")
                with open(LOCAL_DEX_PATH, "rb") as f:
                    local_bytes = f.read()
                self.start_from_bytes(local_bytes)
                self.plugin.log("Loaded from Local Storage")
                return True
            return False
        except Exception as e:
            self.plugin.log(f"Fatal error during loading: {e}")
            return False

    def ensure_loaded(self) -> bool:
        if self.instance is not None:
            return True
        return self.load_and_start()

    def open_settings(self):
        try:
            inst = self.get_instance()
            if inst:
                method = inst.getClass().getMethod(METHOD_OPEN_SETTINGS)
                method.invoke(inst)
        except Exception as e:
            self.plugin.log(f"Error opening settings: {e}")

    def open_preview(self, message_obj) -> bool:
        try:
            inst = self.get_instance()
            if not inst:
                return False
            try:
                method = inst.getClass().getMethod(METHOD_OPEN_PREVIEW, MessageObject.getClass())
                method.invoke(inst, message_obj)
                return True
            except Exception as e:
                self.plugin.log(f"openPreview error: {e}")
                return False
        except Exception as e:
            self.plugin.log(f"openPreview fatal: {e}")
            return False


class Plugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.loader: Optional[Loader] = None
        self.strings = self._get_strings()
        self.pending_preview_message = None
        self.download_listeners = []
        self.default_exts = [
            ".txt", ".py", ".java", ".plugin", ".json", ".xml", ".html", ".css",
            ".js", ".md", ".log", ".ini", ".cfg", ".yaml", ".yml", ".toml"
        ]

    def on_plugin_load(self) -> None:
        self.create_settings()
        self.log(f"Init {__version__}")

        self.loader = Loader(self)
        self._sync_preview_prefs()

        c = ChatActivity.getClass().getDeclaredMethod(
            "didPressMessageUrl",
            CharacterStyle.getClass(),
            Boolean.TYPE,
            MessageObject.getClass(),
            ChatMessageCell.getClass()
        )
        self.hook_method(c, InstallHook(self))

        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text=self.strings["menu_preview"],
                icon="filled_open_message_solar",
                on_click=self._on_preview_click,
                condition="message != null && message.getDocument() != null",
                priority=950
            )
        )

        # Lazy load DEX on first use

    def on_dex_installed(self):
        try:
            if self.pending_preview_message is None:
                return
            if not self.loader:
                self.loader = Loader(self)
            self.loader.load_and_start()
            msg = self.pending_preview_message
            self.pending_preview_message = None
            if not self.loader.open_preview(msg):
                BulletinHelper.show_error(self.strings["preview_error"])
        except Exception as e:
            self.log(f"on_dex_installed error: {e}")

    def create_settings(self):
        items = [
            Header(text=self.strings["oform"]),
            Input(
                key="text_size",
                text=self.strings["header_text_size"],
                subtext=self.strings["pustota"],
                default=self.get_setting("text_size", ""),
                icon="menu_intro_solar",
                on_change=self._on_text_size
            ),
            Selector(
                key="line_numbers",
                text=self.strings["header_line_numbers"],
                default=int(self.get_setting("line_numbers", 0) or 0),
                icon="msg_report_xxx_solar",
                items=[self.strings["off"], self.strings["on"]],
                on_change=self._on_line_numbers
            ),
            Divider(),
            Divider(text=self.strings["moreplugins"]),
            Text(
                text=self.strings["author_channel"],
                icon="msg_reactions_filled_solar",
                on_click=self._open_author_channel
            ),
        ]
        return items

