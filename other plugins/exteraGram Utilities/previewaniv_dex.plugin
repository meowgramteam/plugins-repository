            "settings_title": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 PreviewAniv",
            "header_text_size": "\u0420\u0430\u0437\u043c\u0435\u0440 \u0442\u0435\u043a\u0441\u0442\u0430",
            "oform": "Оформление",
            "header_line_numbers": "\u041d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f \u0441\u0442\u0440\u043e\u043a",
            "line_numbers": "\u041e\u0442\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435",
            "author_channel": "\u041a\u0430\u043d\u0430\u043b \u0430\u0432\u0442\u043e\u0440\u0430",
            "on": "\u0412\u043a\u043b\u044e\u0447\u0435\u043d\u043e",
