    def _normalize_ext(self, ext: str) -> str:
        try:
            e = str(ext).strip().lower()
        except Exception:
            return ""
        if not e:
            return ""
        if not e.startswith("."):
            e = "." + e
        return e

    def _get_ext_list(self):
        raw = self.get_setting("ext_list", "")
        if not raw:
            return list(self.default_exts)
        parts = [self._normalize_ext(p) for p in str(raw).split(",")]
        parts = [p for p in parts if p]
        if not parts:
            return list(self.default_exts)
        return parts

    def _get_allowed_list(self):
        raw = self.get_setting("allowed_exts", "")
        if not raw:
            return list(self.default_exts)
        parts = [self._normalize_ext(p) for p in str(raw).split(",")]
        return [p for p in parts if p]

    def _save_allowed(self, allowed):
        allowed = [self._normalize_ext(x) for x in allowed]
        allowed = [x for x in allowed if x]
        raw = ",".join(allowed)
        self.set_setting("allowed_exts", raw, reload_settings=False)
        try:
            prefs = ApplicationLoader.applicationContext.getSharedPreferences("previewaniv_prefs", 0)
            if prefs:
                ed = prefs.edit()
                if ed:
                    ed.putString("allowed_exts", raw)
                    ed.apply()
        except Exception as e:
            self.log(f"prefs save error: {e}")

    def _on_add_ext(self, new_value):
        try:
            if new_value is None:
                return
            text = str(new_value).strip()
            if not text:
                return
            parts = [p.strip() for p in text.replace(";", ",").replace(" ", ",").split(",") if p.strip()]
            if not parts:
                return
            exts = self._get_ext_list()
            allowed = self._get_allowed_list()
            changed = False
            for p in parts:
                e = self._normalize_ext(p)
                if not e:
                    continue
                if e not in exts:
                    exts.append(e)
                    changed = True
                if e not in allowed:
                    allowed.append(e)
                    changed = True
            if not changed:
                return
            self.set_setting("ext_list", ",".join(exts), reload_settings=False)
            self._save_allowed(allowed)
            self._clear_add_inputs()
            self._increase_add_input_count()
        except Exception as e:
            self.log(f"add ext error: {e}")

    def _on_manage_toggle(self, new_value):
        try:
            self.set_setting("ext_manage_enable", int(new_value), reload_settings=True)
        except Exception:
            self.set_setting("ext_manage_enable", 1, reload_settings=True)

    def _make_toggle_handler(self, ext):
        def _handler(new_value):
            try:
                allowed = set(self._get_allowed_list())
                if int(new_value) == 1:
                    allowed.add(ext)
                else:
                    if ext in allowed:
                        allowed.remove(ext)
                self._save_allowed(sorted(allowed))
            except Exception as e:
                self.log(f"toggle error: {e}")
        return _handler

    def _ext_key(self, ext: str) -> str:
        safe = ext.replace(".", "_").replace("-", "_")
        return f"ext_state{safe}"

    def _get_add_input_count(self) -> int:
        try:
            count = int(self.get_setting("ext_add_count", 1) or 1)
        except Exception:
            count = 1
        if count < 1:
            count = 1
        if count > 20:
            count = 20
        return count

    def _increase_add_input_count(self):
        count = self._get_add_input_count()
        if count < 20:
            count += 1
        self.set_setting("ext_add_count", count, reload_settings=True)

    def _clear_add_inputs(self):
        count = self._get_add_input_count()
        for i in range(1, count + 1):
            self.set_setting(f"ext_add_{i}", "", reload_settings=False)

    def _sync_preview_prefs(self):
        try:
            prefs = ApplicationLoader.applicationContext.getSharedPreferences("previewaniv_prefs", 0)
            if prefs:
                ed = prefs.edit()
                if ed:
                    ed.putString("text_size", str(self.get_setting("text_size", "") or ""))
                    ed.putBoolean("line_numbers", int(self.get_setting("line_numbers", 0) or 0) == 1)
                    ed.apply()
        except Exception as e:
            self.log(f"prefs save error: {e}")

    def _on_text_size(self, new_value):
        try:
            self.set_setting("text_size", str(new_value) if new_value is not None else "", reload_settings=False)
            self._sync_preview_prefs()
        except Exception as e:
            self.log(f"text size error: {e}")

    def _on_line_numbers(self, new_value):
        try:
            self.set_setting("line_numbers", int(new_value), reload_settings=False)
            self._sync_preview_prefs()
        except Exception:
            self.set_setting("line_numbers", 0, reload_settings=False)
            self._sync_preview_prefs()

    def _open_author_channel(self, _=None):
        try:
            Browser.openUrl(ApplicationLoader.applicationContext, "https://anivdev.t.me")
        except Exception as e:
            self.log(f"open channel error: {e}")

    def _add_download_listener(self, listener):
        try:
            self.download_listeners.append(listener)
        except Exception:
            pass

    def _remove_download_listener(self, listener):
        try:
            if listener in self.download_listeners:
                self.download_listeners.remove(listener)
        except Exception:
            pass

    def _on_preview_click(self, context: Dict[str, Any]):
        try:
            message_obj = context.get("message")
            if message_obj is None:
                BulletinHelper.show_error(self.strings["msg_missing"])
                return

            document = message_obj.getDocument()
            if document is None:
                BulletinHelper.show_error(self.strings["file_missing"])
                return

            if not self.loader or not self.loader.ensure_loaded():
                self.pending_preview_message = message_obj
                BulletinHelper.show_with_button(
                    self.strings["dex_missing"],
                    R.raw.info,
                    self.strings["download"],
                    lambda: Browser.openUrl(ApplicationLoader.applicationContext, "https://t.me/anivdev/67")
                )
                return

            if not self.loader.open_preview(message_obj):
                BulletinHelper.show_error(self.strings["preview_error"])
        except Exception as e:
            self.log(f"Preview click error: {e}")
            BulletinHelper.show_error(self.strings["preview_error"])
