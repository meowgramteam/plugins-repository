__name__ = "PreviewAniv"
__description__ = "Предпросмотр любых текстовых файлов через контекстное меню сообщений. Нужен DEX. Работает нативно."
__author__ = "@anivdev"
__version__ = "1.0.1"
__icon__ = "PISUN424242/1"

