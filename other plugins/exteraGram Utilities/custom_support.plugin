ICON3D_TYPE_STARS = 2
PANEL_BG_COLOR = -1560528
SHADER_COLOR = -202777
PARTICLE_COLOR = -202777
BUTTON_COLOR = -1560528
WHITE_COLOR = -1
TITLE_TEXT = "\u042d\u041a\u0421\u0422\u0415\u0420\u0410\u0413\u0420\u0410\u041c"

PANEL_RADIUS_DP = 14

CUSTOM_PARTICLE_PATH_D = "M12.5128 22.4203C15.068 24.9755 17.4619 29.2871 19.2807 33.1366C20.5014 35.7203 24.5113 35.6208 25.4155 32.9101L34.781 4.83324C35.7375 1.96585 33.0086 -0.762224 30.1415 0.195094L2.10017 9.55798C-0.613103 10.4639 -0.708424 14.4831 1.87867 15.7036C5.70113 17.5069 9.97064 19.8782 12.5128 22.4203Z"
_SYSTEM_CLASS = None
_PATH_PARSER_CLASS = None

BINOBJ_ZLIB_B64 = ""
def _dp(v):
    return AndroidUtilities.dp(float(v))


def _safe_text(v):
    if v is None:
        return ""
    try:
        return str(v)
    except Exception:
        return ""


def _java_hash(obj):
    global _SYSTEM_CLASS
    try:
        if _SYSTEM_CLASS is None:
            _SYSTEM_CLASS = jclass("java.lang.System")
        return int(_SYSTEM_CLASS.identityHashCode(obj))
    except Exception:
        pass
    try:
        return int(obj.hashCode())
    except Exception:
        return id(obj)


def _button_text():
    try:
        by_key = _safe_text(LocaleController.getString("SupportDevelopment"))
        if by_key and not by_key.startswith("LOC_ERR"):
            return by_key
    except Exception:
        pass
    try:
        r_string = jclass("org.telegram.messenger.R$string")
        res_id = int(getattr(r_string, "SupportDevelopment", 0))
        if res_id != 0:
            by_id = _safe_text(LocaleController.getString(res_id))
            if by_id and not by_id.startswith("LOC_ERR"):
                return by_id
    except Exception:
        pass
    return "Support Development"


def _make_fragment_shader(argb_color):
    u = int(argb_color) & 0xFFFFFFFF
    r = ((u >> 16) & 0xFF) / 255.0
    g = ((u >> 8) & 0xFF) / 255.0
    b = (u & 0xFF) / 255.0
    return (
        "precision highp float;\n"
        "uniform sampler2D u_Texture;\n"
        "uniform sampler2D u_BackgroundTexture;\n"
        "uniform float f_xOffset;\n"
        "uniform float f_alpha;\n"
        "uniform bool night;\n"
        "uniform bool behind;\n"
        "uniform mat4 world;\n"
        "varying vec3 vNormal;\n"
        "varying vec2 vUV;\n"
        "varying vec3 modelViewVertex;\n"
        "const vec3 MAT_COLOR = vec3(%.6f, %.6f, %.6f);\n"
        "void main() {\n"
        "  vec3 n = normalize(vec3(world * vec4(vNormal, 0.0)));\n"
        "  vec3 p = modelViewVertex / 100.0;\n"
        "  vec3 l = normalize(vec3(-0.45, 0.70, 1.0));\n"
        "  vec3 v = normalize(vec3(0.0, 0.0, 1.2) - p);\n"
        "  float diff = max(dot(n, l), 0.0);\n"
        "  float rim = pow(1.0 - max(dot(n, v), 0.0), 2.0);\n"
        "  vec3 c = MAT_COLOR * (0.32 + 0.88 * diff) + vec3(1.0) * (0.18 * rim);\n"
        "  if (behind) c *= 0.78;\n"
        "  if (night) c *= 0.90;\n"
        "  gl_FragColor = vec4(c, f_alpha);\n"
        "}\n"
    ) % (r, g, b)


def _decode_binobj():
    data = zlib.decompress(base64.b64decode(BINOBJ_ZLIB_B64.encode("ascii")))
    mv = memoryview(data)
    off = 0
    try:
        v_count = struct.unpack_from("<i", mv, off)[0]
        off += 4
        positions = struct.unpack_from("<%df" % v_count, mv, off)
        off += v_count * 4
        t_count = struct.unpack_from("<i", mv, off)[0]
        off += 4
        uvs = struct.unpack_from("<%df" % t_count, mv, off)
        off += t_count * 4
        n_count = struct.unpack_from("<i", mv, off)[0]
        off += 4
        normals = struct.unpack_from("<%df" % n_count, mv, off)
        off += n_count * 4
        face_count = struct.unpack_from("<i", mv, off)[0]
        off += 4
    except Exception:
        return None

    if face_count <= 0:
        return None

    out_pos = []
    out_uv = []
    out_norm = []
    for _ in range(face_count):
        try:
            vi, ti, ni = struct.unpack_from("<iii", mv, off)
        except Exception:
            break
        off += 12
        vp = vi * 3
        tp = ti * 2
        np = ni * 3
        if vp + 2 >= len(positions) or tp + 1 >= len(uvs) or np + 2 >= len(normals):
            continue
        out_pos.extend((positions[vp], positions[vp + 1], positions[vp + 2]))
        out_uv.extend((uvs[tp], uvs[tp + 1]))
        out_norm.extend((normals[np], normals[np + 1], normals[np + 2]))

    if not out_pos:
        return None

    return {
        "positions": out_pos,
        "uvs": out_uv,
        "normals": out_norm,
        "num_faces": int(len(out_pos) / 3),
    }


def _to_float_array(values):
    return jarray(jfloat)([float(v) for v in values])


def _get_path_parser():
    global _PATH_PARSER_CLASS
    if _PATH_PARSER_CLASS is not None:
        return _PATH_PARSER_CLASS
    for cls_name in ("android.util.PathParser", "androidx.core.graphics.PathParser"):
        try:
            _PATH_PARSER_CLASS = jclass(cls_name)
            return _PATH_PARSER_CLASS
        except Exception:
            continue
    return None


def _path_to_bitmap(path_data, size_px, color):
    size = int(max(8, size_px))
    raw = _safe_text(path_data)
    if not raw:
        return None
    parser = _get_path_parser()
    if parser is None:
        return _svg_to_bitmap(raw, size, color)
    try:
        path = parser.createPathFromPathData(raw)
        if path is None:
            return _svg_to_bitmap(raw, size, color)
        cfg = jclass("android.graphics.Bitmap$Config")
        bmp = Bitmap.createBitmap(size, size, cfg.ARGB_8888)
        cv = Canvas(bmp)
        paint = jclass("android.graphics.Paint")(1)
        paint.setStyle(jclass("android.graphics.Paint$Style").FILL)
        paint.setColor(int(color))
        cv.save()
        cv.scale(float(size) / 36.0, float(size) / 36.0)
        cv.drawPath(path, paint)
        cv.restore()
        return bmp
    except Exception:
        return _svg_to_bitmap(raw, size, color)


def _svg_to_bitmap(path_data, size_px, color):
    try:
        SVG = jclass("com.caverock.androidsvg.SVG")
        ByteArrayInputStream = jclass("java.io.ByteArrayInputStream")
        cfg = jclass("android.graphics.Bitmap$Config")
        hex_rgb = ("%06X" % (int(color) & 0xFFFFFF))
        svg_text = (
            "<svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" "
            "fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">"
            "<path d=\"%s\" fill=\"#%s\"/></svg>"
        ) % (path_data, hex_rgb)
        stream = ByteArrayInputStream(svg_text.encode("utf-8"))
        svg = SVG.getFromInputStream(stream)
        svg.setDocumentWidth(float(size_px))
        svg.setDocumentHeight(float(size_px))
        bmp = Bitmap.createBitmap(int(size_px), int(size_px), cfg.ARGB_8888)
        cv = Canvas(bmp)
        svg.renderToCanvas(cv)
        return bmp
    except Exception:
        return None


def _apply_top_round_clip(view):
    if view is None:
        return
    try:
        view.setClipChildren(True)
        view.setClipToPadding(True)
    except Exception:
        pass
    try:
        view.setClipToOutline(True)
    except Exception:
        return
    try:
        view.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
    except Exception:
        pass
    try:
        view.invalidateOutline()
    except Exception:
        pass


def _is_support_http_uri(data):
    try:
        scheme = _safe_text(data.getScheme()).strip().lower()
        host = _safe_text(data.getHost()).strip().lower()
        path = _safe_text(data.getPath()).strip().lower()
        if scheme not in ("http", "https"):
            return False
        if host != "t.me":
            return False
        normalized = path.rstrip("/")
        return normalized == "/support"
    except Exception:
        return False


def _is_support_tg_uri(data):
    try:
        scheme = _safe_text(data.getScheme()).strip().lower()
        if scheme != "tg":
            return False
        host = _safe_text(data.getHost()).strip().lower()
        return host == "support"
    except Exception:
        return False


def _intent_route(intent):
    if intent is None:
        return None
    try:
        data = intent.getData()
        if data is None:
            return None
        if _is_support_http_uri(data):
            return "support"
        if _is_support_tg_uri(data):
            return "support"
        return None
    except Exception:
        return None


def _recommended_particle_count():
    try:
        perf = int(getattr(SharedConfig, "devicePerformanceClass", -1)) if SharedConfig is not None else -1
    except Exception:
        perf = -1
    if perf <= 0:
        return 90
    if perf == 1:
        return 110
    return 140


class LaunchIntentHook(MethodHook):
    def __init__(self, plugin, consume_result):
        self.plugin = plugin
        self.consume_result = consume_result

    def before_hooked_method(self, param):
        try:
            if not param.args:
                return
            intent = param.args[0]
            if not self.plugin._try_open_from_intent(param.thisObject, intent):
                return
            param.setResult(self.consume_result)
        except Exception:
            pass


class LaunchOnCreateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            launch = param.thisObject
            try:
                intent = launch.getIntent()
            except Exception:
                intent = None
            self.plugin._try_open_from_intent(launch, intent, clear_data=True, delay_ms=400)
        except Exception:
            pass


class RendererSurfaceCreatedHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        renderer = param.thisObject
        job = self.plugin.get_renderer_job(renderer)
        if job is not None:
            self.plugin.push_scope(job)

    def after_hooked_method(self, param):
        renderer = param.thisObject
        job = self.plugin.get_renderer_job(renderer)
        if job is not None:
            self.plugin.pop_scope()


class GLLoadShaderHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if len(param.args) < 2:
                return
            if int(param.args[0]) != 0x8B30:
                return
            shader = self.plugin.get_active_shader()
            if shader:
                param.args[1] = shader
        except Exception:
            pass


class ObjLoaderConstructorHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if self.plugin.peek_scope() is None:
                return
            loader = param.thisObject
            idx = self.plugin.next_loader_index()
            self.plugin.apply_model_to_loader(loader, idx)
        except Exception:
            pass


class SupportCardPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._hook_refs = []
        self._hook_ref_ids = set()
        self._renderer_jobs = {}
        self._scopes = {}
        self._model_data = None
        self._particle_bitmaps = {}
        self._last_open_ts = 0.0
        self._last_open_sig = ""
        self._active_sheet = None
        self._cached_shader = _make_fragment_shader(SHADER_COLOR)
        self._empty_float_array = _to_float_array([])
        self._white_color = WHITE_COLOR
        self._panel_bg_color = PANEL_BG_COLOR
        self._button_color = BUTTON_COLOR
        self._particle_color = PARTICLE_COLOR
        self._cls_launch = None
        self._cls_renderer = None
        self._cls_obj_loader = None
        self._cls_support_sheet = None
        self._cls_bottom_sheet = None
        self._cls_frame_lp = None
        self._cls_linear_lp = None
        self._cls_gradient_drawable = None
        self._cls_on_dismiss_listener = None

        self._hook_launch_create = LaunchOnCreateHook(self)
        self._hook_launch_handle = LaunchIntentHook(self, True)
        self._hook_surface = RendererSurfaceCreatedHook(self)
        self._hook_shader = GLLoadShaderHook(self)
        self._hook_obj = ObjLoaderConstructorHook(self)

    def create_settings(self):
        return []

    def _remember_hook(self, ref):
        if not ref:
            return
        if isinstance(ref, (list, tuple, set)):
            for item in ref:
                if item:
                    key = id(item)
                    if key in self._hook_ref_ids:
                        continue
                    self._hook_ref_ids.add(key)
                    self._hook_refs.append(item)
            return
        key = id(ref)
        if key in self._hook_ref_ids:
            return
        self._hook_ref_ids.add(key)
        self._hook_refs.append(ref)

    def _hook_all(self, target_cls, method_name, hook):
        try:
            self._remember_hook(self.hook_all_methods(target_cls, method_name, hook))
        except Exception:
            pass

    def _hook_all_constructors_safe(self, target_cls, hook):
        try:
            self._remember_hook(self.hook_all_constructors(target_cls, hook))
        except Exception:
            pass

    def _try_open_from_intent(self, launch, intent, clear_data=False, delay_ms=0):
        route = _intent_route(intent)
        if route is None:
            return False
        sig = self._intent_signature(route, intent)
        if not self._allow_open(sig):
            return True
        if clear_data:
            try:
                intent.setData(None)
            except Exception:
                pass
        run_on_ui_thread(lambda: self.show_support_popup(launch), delay_ms)
        return True

    def _open_native_support(self, activity):
        fragment, _ = self._resolve_fragment_activity(preferred_activity=activity)
        if self._show_builtin_support_sheet(fragment):
            return
        BulletinHelper.show_error("Unable to open support.")

    def _resolve_launch_fallback(self):
        activity = None
        fragment = None
        launch_cls = self._cls_launch
        if launch_cls is None:
            launch_cls = find_class("org.telegram.ui.LaunchActivity")
            self._cls_launch = launch_cls
        if launch_cls is None:
            return None, None
        try:
            activity = getattr(launch_cls, "instance", None)
        except Exception:
            activity = None
        try:
            fragment = launch_cls.getLastFragment()
        except Exception:
            fragment = None
        return fragment, activity

    def _intent_signature(self, route, intent):
        try:
            data = intent.getData() if intent is not None else None
            uri = _safe_text(data.toString()).strip().lower() if data is not None else ""
        except Exception:
            uri = ""
        return _safe_text(route) + "|" + uri

    def _allow_open(self, sig):
        now = float(time.time())
        if sig and self._last_open_sig == sig and now - self._last_open_ts < 1.0:
            return False
        self._last_open_sig = sig
        self._last_open_ts = now
        return True

    def _thread_id(self):
        try:
            return int(Thread.currentThread().getId())
        except Exception:
            return 0

    def _dismiss_current_sheet(self):
        try:
            if self._active_sheet is not None:
                self._active_sheet.dismiss()
        except Exception:
            pass
        self._active_sheet = None
        self._renderer_jobs.clear()
        self._scopes.clear()

    def _recycle_particle_bitmap(self):
        bitmaps = self._particle_bitmaps
        self._particle_bitmaps = {}
        if not bitmaps:
            return
        for bmp in bitmaps.values():
            try:
                if bmp is not None:
                    bmp.recycle()
            except Exception:
                pass

    def register_renderer_job(self, icon_view):
        try:
            self._renderer_jobs[_java_hash(icon_view.mRenderer)] = {"shader": self._cached_shader, "loader_index": 0}
        except Exception:
            pass

    def unregister_renderer_job(self, icon_view):
        try:
            key = _java_hash(icon_view.mRenderer)
            if key in self._renderer_jobs:
                del self._renderer_jobs[key]
        except Exception:
            pass

    def get_renderer_job(self, renderer):
        return self._renderer_jobs.get(_java_hash(renderer))

    def push_scope(self, job):
        tid = self._thread_id()
        stack = self._scopes.get(tid)
        if stack is None:
            stack = []
            self._scopes[tid] = stack
        stack.append({"shader": job.get("shader"), "loader_index": 0})

    def pop_scope(self):
        tid = self._thread_id()
        stack = self._scopes.get(tid)
        if not stack:
            return
        stack.pop()
        if not stack:
            del self._scopes[tid]

    def peek_scope(self):
        stack = self._scopes.get(self._thread_id())
        return stack[-1] if stack else None

    def get_active_shader(self):
        scope = self.peek_scope()
        return scope.get("shader") if scope else None

    def next_loader_index(self):
        scope = self.peek_scope()
        if scope is None:
            return 0
        idx = int(scope.get("loader_index", 0))
        scope["loader_index"] = idx + 1
        return idx

    def _load_model_data(self):
        if self._model_data is not None:
            return self._model_data
        try:
            parsed = _decode_binobj()
            if not parsed:
                self._model_data = None
                return None
            self._model_data = {
                "positions": _to_float_array(parsed["positions"]),
                "uvs": _to_float_array(parsed["uvs"]),
                "normals": _to_float_array(parsed["normals"]),
                "num_faces": int(parsed["num_faces"]),
            }
            return self._model_data
        except Exception:
            self._model_data = None
            return None

    def apply_model_to_loader(self, loader, loader_index):
        if loader_index > 0:
            try:
                loader.positions = self._empty_float_array
                loader.textureCoordinates = self._empty_float_array
                loader.normals = self._empty_float_array
                loader.numFaces = 0
            except Exception:
                pass
            return
        data = self._load_model_data()
        if not data:
            return
        try:
            loader.positions = data["positions"]
            loader.textureCoordinates = data["uvs"]
            loader.normals = data["normals"]
            loader.numFaces = data["num_faces"]
        except Exception:
            pass

    def _configure_particles(self, particles_view):
        if particles_view is None:
            return
        d = getattr(particles_view, "drawable", None)
        if d is None:
            return

        try:
            d.size1 = 12
            d.size2 = 10
            d.size3 = 8
            d.randLifeTime = 2500

            has_direct_color = False
            try:
                d.color = self._particle_color
                has_direct_color = True
            except Exception:
                has_direct_color = False

            if has_direct_color:
                try:
                    d.overridePaint = None
                except Exception:
                    pass
            else:
                try:
                    Paint = jclass("android.graphics.Paint")
                    PorterDuffColorFilter = jclass("android.graphics.PorterDuffColorFilter")
                    PorterDuffMode = jclass("android.graphics.PorterDuff$Mode")
                    paint = Paint(1)
                    paint.setColorFilter(PorterDuffColorFilter(int(self._particle_color), PorterDuffMode.SRC_IN))
                    d.overridePaint = paint
                except Exception:
                    pass

            d.init()
            self._apply_custom_svg_particle_icons(particles_view)
            run_on_ui_thread(lambda: self._apply_custom_svg_particle_icons(particles_view), 120)
            d.resetPositions()
            particles_view.invalidate()
        except Exception:
            pass

    def _apply_custom_svg_particle_icons(self, particles_view):
        if particles_view is None:
            return
        try:
            d = particles_view.drawable
            stars = getattr(d, "stars", None)
            if stars is None:
                stars = get_private_field(d, "stars")
            if stars is None:
                return

            sizes = [
                max(8, int(getattr(d, "size1", 12))),
                max(8, int(getattr(d, "size2", 10))),
                max(8, int(getattr(d, "size3", 8))),
            ]

            slots_count = min(len(stars), len(sizes))
            custom_slots = []
            if slots_count >= 3:
                custom_slots = [1, 2]
            elif slots_count == 2:
                custom_slots = [1]

            replaced_slots = []
            for idx in custom_slots:
                bmp = self._get_particle_bitmap(_dp(sizes[idx]))
                if bmp is not None:
                    try:
                        stars[idx] = bmp
                        replaced_slots.append(idx)
                    except Exception:
                        pass

            try:
                svg = getattr(d, "svg", None)
                if svg is None:
                    svg = get_private_field(d, "svg")
                if svg is not None:
                    for idx in replaced_slots:
                        if idx >= len(svg):
                            continue
                        try:
                            svg[idx] = False
                        except Exception:
                            pass
            except Exception:
                pass

            try:
                flip = getattr(d, "flip", None)
                if flip is None:
                    flip = get_private_field(d, "flip")
                if flip is not None:
                    for idx in replaced_slots:
                        if idx >= len(flip):
                            continue
                        try:
                            flip[idx] = False
                        except Exception:
                            pass
            except Exception:
                pass

            try:
                d.resetPositions()
            except Exception:
                pass
            try:
                particles_view.invalidate()
            except Exception:
                pass
        except Exception:
            pass

    def _get_particle_bitmap(self, size_px):
        s = int(max(8, size_px))
        cached = self._particle_bitmaps.get(s)
        if cached is not None:
            return cached
        bmp = _path_to_bitmap(CUSTOM_PARTICLE_PATH_D, s, self._particle_color)
        if bmp is not None:
            self._particle_bitmaps[s] = bmp
        return bmp

    def _resolve_fragment_activity(self, preferred_activity=None):
        fragment = None
        activity = preferred_activity
        try:
            fragment = get_last_fragment()
        except Exception:
            fragment = None
        if activity is None and fragment is not None:
            try:
                activity = fragment.getParentActivity()
            except Exception:
                activity = None
        if fragment is None or activity is None:
            fallback_fragment, fallback_activity = self._resolve_launch_fallback()
            if fragment is None:
                fragment = fallback_fragment
            if activity is None:
                activity = fallback_activity
        return fragment, activity

    def _show_builtin_support_sheet(self, fragment):
        if fragment is None:
            return False
        try:
            cls = self._cls_support_sheet
            if cls is None:
                cls = find_class("com.exteragram.messenger.components.SupporterBottomSheet")
                self._cls_support_sheet = cls
            if cls is None:
                return False
            cls.showAlert(fragment)
            return True
        except Exception:
            return False

    def _cache_classes(self):
        self._cls_launch = find_class("org.telegram.ui.LaunchActivity")
        self._cls_renderer = find_class("org.telegram.ui.Components.Premium.GLIcon.GLIconRenderer")
        self._cls_obj_loader = find_class("org.telegram.ui.Components.Premium.GLIcon.ObjLoader")
        self._cls_support_sheet = find_class("com.exteragram.messenger.components.SupporterBottomSheet")

    def _ensure_popup_ui_classes(self):
        if (
            self._cls_bottom_sheet is not None and
            self._cls_frame_lp is not None and
            self._cls_linear_lp is not None and
            self._cls_gradient_drawable is not None and
            self._cls_on_dismiss_listener is not None
        ):
            return True
        try:
            self._cls_bottom_sheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            self._cls_frame_lp = jclass("android.widget.FrameLayout$LayoutParams")
            self._cls_linear_lp = jclass("android.widget.LinearLayout$LayoutParams")
            self._cls_gradient_drawable = jclass("android.graphics.drawable.GradientDrawable")
            self._cls_on_dismiss_listener = jclass("android.content.DialogInterface$OnDismissListener")
            return True
        except Exception:
            self._cls_bottom_sheet = None
            self._cls_frame_lp = None
            self._cls_linear_lp = None
            self._cls_gradient_drawable = None
            self._cls_on_dismiss_listener = None
            return False

    def _present_sheet(self, sheet, fragment, activity):
        try:
            if fragment is not None and fragment.getParentActivity() == activity:
                fragment.showDialog(sheet)
                return True
        except Exception:
            pass
        try:
            sheet.show()
            return True
        except Exception:
            return False

    def _build_panel_container(self, activity, LinearLP, GradientDrawable):
        root = LinearLayout(activity)
        root.setOrientation(1)
        root.setPadding(0, 0, 0, 0)

        panel = FrameLayout(activity)
        bg = GradientDrawable()
        bg.setColor(self._panel_bg_color)
        r = float(_dp(PANEL_RADIUS_DP))
        bg.setCornerRadii(jarray(jfloat)([r, r, r, r, 0.0, 0.0, 0.0, 0.0]))
        panel.setBackground(bg)
        _apply_top_round_clip(panel)

        try:
            screen_w = int(getattr(AndroidUtilities.displaySize, "x", 0))
        except Exception:
            screen_w = 0
        size = max(_dp(220), screen_w)
        root.addView(panel, LinearLP(-1, size))
        return root, panel, size

    def _build_preview(self, activity, panel, size, FrameLP):
        try:
            icon_view = GLIconTextureView(activity, 1, ICON3D_TYPE_STARS)
            icon_view.setPaused(False)
            try:
                icon_view.startEnterAnimation(-180, 120)
            except Exception:
                pass
            self.register_renderer_job(icon_view)

            particles = None
            if StarParticlesView is not None:
                try:
                    particles = StarParticlesView(activity, _recommended_particle_count())
                    particles.setPaused(False)
                    self._configure_particles(particles)
                    icon_view.setStarParticlesView(particles)
                    panel.addView(particles, FrameLP(-1, -1))
                except Exception:
                    particles = None

            icon_size = max(_dp(120), int(size * 0.78))
            ilp = FrameLP(icon_size, icon_size)
            ilp.gravity = Gravity.CENTER
            panel.addView(icon_view, ilp)
            return icon_view, particles
        except Exception:
            fallback = TextView(activity)
            fallback.setText("3D preview unavailable")
            fallback.setTextColor(self._white_color)
            fallback.setTextSize(1, 14.0)
            fallback.setGravity(Gravity.CENTER)
            panel.addView(fallback, FrameLP(-1, -1))
            return None, None

    def _build_footer(self, activity, root, LinearLP):
        title = TextView(activity)
        title.setText(TITLE_TEXT)
        title.setTextColor(self._white_color)
        title.setTextSize(1, 20.0)
        title.setTypeface(AndroidUtilities.bold())
        title.setGravity(Gravity.CENTER)
        tlp = LinearLP(-1, -2)
        tlp.topMargin = _dp(16)
        root.addView(title, tlp)

        button = TextView(activity)
        button.setText(_button_text())
        button.setTextColor(self._white_color)
        button.setTextSize(1, 15.0)
        button.setTypeface(AndroidUtilities.bold())
        button.setGravity(Gravity.CENTER)
        button.setPadding(_dp(16), _dp(12), _dp(16), _dp(12))
        button.setBackground(Theme.createRoundRectDrawable(_dp(12), self._button_color))
        button.setOnClickListener(OnClickListener(lambda v: self._open_native_support(activity)))
        blp = LinearLP(-1, -2)
        blp.topMargin = _dp(12)
        blp.leftMargin = _dp(16)
        blp.rightMargin = _dp(16)
        blp.bottomMargin = _dp(24)
        root.addView(button, blp)

    def _create_sheet(self, activity, root, BottomSheet, OnDismissListener, icon_view, particles):
        sheet = BottomSheet(activity, False)
        try:
            sheet.setApplyTopPadding(False)
            sheet.setApplyBottomPadding(False)
            sheet.setCanDismissWithSwipe(True)
        except Exception:
            pass
        sheet.setCustomView(root)

        class _Dismiss(dynamic_proxy(OnDismissListener)):
            def __init__(self, plugin_ref, icon, parts):
                super().__init__()
                self._plugin = plugin_ref
                self._icon = icon
                self._parts = parts

            def onDismiss(self, dialog):
                try:
                    if self._parts is not None:
                        self._parts.setPaused(True)
                except Exception:
                    pass
                try:
                    if self._icon is not None:
                        self._icon.setPaused(True)
                        self._icon.setDialogVisible(False)
                except Exception:
                    pass
                try:
                    if self._plugin is not None and self._icon is not None:
                        self._plugin.unregister_renderer_job(self._icon)
                except Exception:
                    pass
                if self._plugin is not None:
                    self._plugin._active_sheet = None

        try:
            sheet.setOnDismissListener(_Dismiss(self, icon_view, particles))
        except Exception:
            pass
        return sheet

    def show_support_popup(self, preferred_activity=None):
        stage = "start"
        fragment, activity = self._resolve_fragment_activity(preferred_activity)
        if activity is None:
            BulletinHelper.show_error("No active activity for popup.")
            return
        self._dismiss_current_sheet()

        try:
            stage = "class_lookup"
            if not self._ensure_popup_ui_classes():
                raise Exception("UI classes unavailable")
            BottomSheet = self._cls_bottom_sheet
            FrameLP = self._cls_frame_lp
            LinearLP = self._cls_linear_lp
            GradientDrawable = self._cls_gradient_drawable
            OnDismissListener = self._cls_on_dismiss_listener

            stage = "build_root"
            root, panel, size = self._build_panel_container(activity, LinearLP, GradientDrawable)

            stage = "build_preview"
            icon_view, particles = self._build_preview(activity, panel, size, FrameLP)

            stage = "build_footer"
            self._build_footer(activity, root, LinearLP)

            stage = "create_sheet"
            sheet = self._create_sheet(activity, root, BottomSheet, OnDismissListener, icon_view, particles)

            stage = "show_sheet"
            shown = self._present_sheet(sheet, fragment, activity)

            if shown:
                self._active_sheet = sheet
            else:
                if not self._show_builtin_support_sheet(fragment):
                    BulletinHelper.show_error("Unable to show popup.")
        except Exception as e:
            if not self._show_builtin_support_sheet(fragment):
                BulletinHelper.show_error("Popup error: " + _safe_text(stage) + ": " + _safe_text(e))

    def on_plugin_load(self):
        self._cache_classes()

        launch_cls = self._cls_launch
        if launch_cls is not None:
            self._hook_all(launch_cls, "onCreate", self._hook_launch_create)
            self._hook_all(launch_cls, "handleIntent", self._hook_launch_handle)

        renderer_cls = self._cls_renderer
        if renderer_cls is not None:
            self._hook_all(renderer_cls, "onSurfaceCreated", self._hook_surface)
            self._hook_all(renderer_cls, "loadShader", self._hook_shader)

        obj_cls = self._cls_obj_loader
        if obj_cls is not None:
            self._hook_all_constructors_safe(obj_cls, self._hook_obj)

        try:
            self._load_model_data()
        except Exception:
            pass
        try:
            self._get_particle_bitmap(_dp(12))
        except Exception:
            pass

    def on_plugin_unload(self):
        for ref in list(self._hook_refs):
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._hook_refs.clear()
        self._hook_ref_ids.clear()
        self._dismiss_current_sheet()
        self._renderer_jobs.clear()
        self._scopes.clear()
        self._model_data = None
        self._recycle_particle_bitmap()
        self._cls_launch = None
        self._cls_renderer = None
        self._cls_obj_loader = None
        self._cls_support_sheet = None
        self._cls_bottom_sheet = None
        self._cls_frame_lp = None
        self._cls_linear_lp = None
        self._cls_gradient_drawable = None
        self._cls_on_dismiss_listener = None
