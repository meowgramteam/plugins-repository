def _get_install_dir():
    """Папка для хранения шимеджи внутри папки приложения."""
    try:
        from hook_utils import find_class as fc
        AL  = fc("org.telegram.messenger.ApplicationLoader")
        ctx = AL.applicationContext
        ext = ctx.getExternalFilesDir(None)
        if ext:
            base = str(ext.getAbsolutePath())   # .../Android/data/<pkg>/files
            path = base + "/Shimeji/"
            import os; os.makedirs(path, exist_ok=True)
            return path
    except Exception:
        pass
    return "/sdcard/Shimeji/"   # fallback

INSTALL_DIR  = _get_install_dir()
SPRITES_DIR  = INSTALL_DIR + "img/"

