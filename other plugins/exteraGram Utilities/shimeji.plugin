class SpriteRenderer:
    """Overlay-окно с ImageView. Drag по образцу Stella."""

    def __init__(self, plugin):
        self._plugin  = plugin
        self._wm      = None
        self._root    = None   # FrameLayout (контейнер)
        self._view    = None   # ImageView (спрайт)
        self._lp      = None   # LayoutParams оверлея
        self._alive   = False
        self._x       = 0.0
        self._y       = 0.0
        self._scale   = 1.0
        self._dragging   = False
        self._drag_off_x = 0.0
        self._drag_off_y = 0.0
        self._on_drag_end = None
        self._move_count  = 0

    def create(self, x, y, scale=1.0):
        self._scale = scale
        self._x = float(x)
        self._y = float(y)

        def _do():
            try:
                from hook_utils import find_class as fc
                LP   = fc("android.view.WindowManager$LayoutParams")
                G    = fc("android.view.Gravity")
                FL   = fc("android.widget.FrameLayout")
                FLP  = fc("android.widget.FrameLayout$LayoutParams")
                PF   = fc("android.graphics.PixelFormat")
                B    = fc("android.os.Build")
                AL   = fc("org.telegram.messenger.ApplicationLoader")
                IV   = fc("android.widget.ImageView")
                OTL  = fc("android.view.View$OnTouchListener")
                ME   = fc("android.view.MotionEvent")

                ctx = AL.applicationContext
                if not ctx:
                    self._plugin._log("create: no context")
                    return

                wm = ctx.getSystemService("window")
                if not wm:
                    self._plugin._log("create: no WindowManager")
                    return

                size = int(SPRITE_SIZE * scale)

                iv = IV(ctx)
                iv.setScaleType(IV.ScaleType.FIT_CENTER)

                root = FL(ctx)
                root.addView(iv, FLP(size, size))
                root.setBackgroundColor(0)

                lp_type = LP.TYPE_APPLICATION_OVERLAY if B.VERSION.SDK_INT >= 26 else LP.TYPE_PHONE
                wm_flags = (LP.FLAG_NOT_FOCUSABLE
                            | LP.FLAG_NOT_TOUCH_MODAL
                            | LP.FLAG_LAYOUT_NO_LIMITS
                            | LP.FLAG_HARDWARE_ACCELERATED)

                lp = LP(size, size, int(x), int(y), lp_type, wm_flags, PF.TRANSLUCENT)
                lp.gravity = G.TOP | G.LEFT

                wm.addView(root, lp)

                self._wm   = wm
                self._root = root
                self._view = iv
                self._lp   = lp
                self._alive = True
                self._plugin._log("SpriteRenderer: overlay created")

                # Применяем границы если включено
                self._apply_border()

                # Вешаем touch — точно как Stella
                self._attach_touch(OTL, ME)

            except Exception as e:
                self._plugin._log(f"SpriteRenderer.create: {e}\n{traceback.format_exc()}")

        run_on_ui_thread(_do)

    def _attach_touch(self, OTL_c, MotionEvent):
        """Drag через dynamic_proxy — паттерн Stella."""
        try:
            renderer = self
            plugin   = self._plugin

            class TL(dynamic_proxy(OTL_c)):
                def __init__(self):
                    super().__init__()
                    self._start_x = 0.0
                    self._start_y = 0.0
                    self._moved   = False

                def onTouch(self_t, v, ev):
                    try:
                        a = ev.getActionMasked()
                        if a == MotionEvent.ACTION_DOWN:
                            renderer._dragging   = True
                            renderer._moved      = False
                            self_t._start_x      = ev.getRawX()
                            self_t._start_y      = ev.getRawY()
                            renderer._drag_off_x = ev.getRawX() - renderer._lp.x
                            renderer._drag_off_y = ev.getRawY() - renderer._lp.y
                            # Сброс трекинга скорости
                            self_t._prev_x  = ev.getRawX()
                            self_t._prev_y  = ev.getRawY()
                            self_t._vel_x   = 0.0
                            self_t._vel_y   = 0.0
                            import time as _t2
                            self_t._prev_t  = _t2.time()
                            engine = plugin._engine
                            if engine:
                                engine.on_drag_start()
                            return True

                        elif a == MotionEvent.ACTION_MOVE:
                            if renderer._dragging:
                                nx = int(ev.getRawX() - renderer._drag_off_x)
                                ny = int(ev.getRawY() - renderer._drag_off_y)
                                if abs(nx - int(self_t._start_x - renderer._drag_off_x)) > 10 or                                    abs(ny - int(self_t._start_y - renderer._drag_off_y)) > 10:
                                    renderer._moved = True
                                # Считаем скорость (px/тик ~40мс)
                                import time as _t2
                                now = _t2.time()
                                dt  = now - getattr(self_t, "_prev_t", now)
                                if dt > 0.001:
                                    raw_vx = (ev.getRawX() - getattr(self_t, "_prev_x", ev.getRawX())) / dt * 0.04
                                    raw_vy = (ev.getRawY() - getattr(self_t, "_prev_y", ev.getRawY())) / dt * 0.04
                                    # Сглаживание (EMA)
                                    a_ema  = 0.4
                                    self_t._vel_x = a_ema * raw_vx + (1 - a_ema) * getattr(self_t, "_vel_x", 0.0)
                                    self_t._vel_y = a_ema * raw_vy + (1 - a_ema) * getattr(self_t, "_vel_y", 0.0)
                                self_t._prev_x = ev.getRawX()
                                self_t._prev_y = ev.getRawY()
                                self_t._prev_t = now
                                renderer._lp.x = nx
                                renderer._lp.y = ny
                                renderer._x    = float(nx)
                                renderer._y    = float(ny)
                                try:
                                    renderer._wm.updateViewLayout(renderer._root, renderer._lp)
                                except Exception:
                                    pass
                            return True

                        elif a in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            renderer._dragging = False
                            vx = getattr(self_t, "_vel_x", 0.0)
                            vy = getattr(self_t, "_vel_y", 0.0)
                            engine = plugin._engine
                            if engine:
                                engine.on_drag_end(renderer._x, renderer._y, vx, vy)

                            # Двойное нажатие — скрыть/показать
                            if not renderer._moved:
                                import time as _t
                                now = _t.time()
                                last = getattr(renderer, "_last_tap_time", 0)
                                if now - last < 0.4:
                                    # Двойной тап — выключаем через плагин (как переключатель в настройках)
                                    renderer._last_tap_time = 0
                                    def _toggle():
                                        try:
                                            plugin.ss("enabled", False)
                                            plugin._on_enable_change(False)
                                            BulletinHelper.show_info("Персонаж скрыт — включи в настройках")
                                        except Exception as e:
                                            plugin._log(f"toggle: {e}")
                                    run_on_ui_thread(_toggle)
                                else:
                                    renderer._last_tap_time = now
                            return True

                    except Exception as te:
                        plugin._log(f"onTouch: {te}")
                    return False

            self._root.setOnTouchListener(TL())
            self._plugin._log("touch OK")

        except Exception as e:
            self._plugin._log(f"_attach_touch: {e}\n{traceback.format_exc()}")

    def _apply_border(self):
        try:
            show = self._plugin.gs("show_borders", False)
            color = 0x44FF0000 if show else 0
            self._root.setBackgroundColor(color)
        except Exception as e:
            self._plugin._log(f"_apply_border: {e}")

    def set_border_visible(self, visible):
        if not self._alive:
            return
        run_on_ui_thread(self._apply_border)

    def set_sprite(self, path, flip=False):
        if not self._alive or path is None:
            return
        cache_key = (path, flip)
        if cache_key in _BMP_CACHE:
            bmp = _BMP_CACHE[cache_key]
            def _do_c(b=bmp):
                try:
                    self._view.setImageBitmap(b)
                except Exception as e:
                    self._plugin._log(f"set_sprite cached: {e}")
            run_on_ui_thread(_do_c)
            return

        def _do():
            try:
                from android.graphics import BitmapFactory, Matrix, Bitmap
                bmp = BitmapFactory.decodeFile(path)
                if bmp is None:
                    self._plugin._log(f"set_sprite: null for {path}")
                    return
                if flip:
                    m = Matrix()
                    m.setScale(-1, 1)
                    bmp = Bitmap.createBitmap(bmp, 0, 0, bmp.getWidth(), bmp.getHeight(), m, False)
                _BMP_CACHE[cache_key] = bmp
                self._view.setImageBitmap(bmp)
            except Exception as e:
                self._plugin._log(f"set_sprite: {e}")
        run_on_ui_thread(_do)

    def move_to(self, x, y):
        if not self._alive:
            return
        if self._dragging:
            return  # не перебиваем drag
        self._x = float(x)
        self._y = float(y)
        px, py = int(x), int(y)
        lp = self._lp
        wm = self._wm
        root = self._root
        self._move_count += 1
        log_it = self._move_count <= 3

        def _do():
            try:
                lp.x = px
                lp.y = py
                wm.updateViewLayout(root, lp)
                if log_it:
                    self._plugin._log(f"move_to OK: ({px},{py})")
            except Exception as e:
                self._plugin._log(f"move_to: {e}")
        run_on_ui_thread(_do)

    def enable_drag(self, on_drag_end=None):
        self._on_drag_end = on_drag_end  # не используется, drag в _attach_touch

    def disable_drag(self):
        if not self._alive:
            return
        def _do():
            try:
                self._root.setOnTouchListener(None)
                from hook_utils import find_class as fc
                LP = fc("android.view.WindowManager$LayoutParams")
                self._lp.flags = (LP.FLAG_NOT_FOCUSABLE
                                  | LP.FLAG_NOT_TOUCH_MODAL
                                  | LP.FLAG_NOT_TOUCHABLE
                                  | LP.FLAG_LAYOUT_NO_LIMITS)
                self._wm.updateViewLayout(self._root, self._lp)
            except Exception as e:
                self._plugin._log(f"disable_drag: {e}")
        run_on_ui_thread(_do)

    def destroy(self):
        if not self._alive:
            return
        self._alive = False
        root = self._root
        wm   = self._wm
        def _do():
            try:
                wm.removeView(root)
            except Exception:
                pass
        run_on_ui_thread(_do)


class ShimejiEngine:
    """
    Автомат состояний персонажа.
    Работает в отдельном треде, управляет SpriteRenderer.
    """

    def __init__(self, plugin):
        self._plugin     = plugin
        self._renderer   = SpriteRenderer(plugin)
        self._alive      = False
        self._thread     = None

        # Позиция
        self._x          = 200.0
        self._y          = 0.0
        self._vy         = 0.0   # вертикальная скорость (для падения)
        self._facing_right = False

        # Границы экрана (заполнятся при старте)
        self._screen_w   = 1080
        self._screen_h   = 1920
        self._floor_y    = 0    # Y нижней границы (screen_h - sprite_size)

        # Состояние
        self._state      = "stand"
        self._state_tick = 0
        self._state_dur  = 50

        # Анимация
        self._anim_frames  = ANIM["stand"]
        self._anim_idx     = 0
        self._anim_tick    = 0
        self._anim_spf     = 6    # тиков на кадр

        # Цель движения
        self._target_x   = None
        self._target_y   = None

        # Спрайты
        self._sprites_dir = plugin.gs("sprites_dir", SPRITES_DIR)
        self._scale       = float(plugin.gs("scale", "1.0"))

        # Принудительно запрошенное состояние (из Telegram-событий)
        self._forced_state = None

        # Кеш путей спрайтов {lower_name: full_path}
        self._sprite_cache = {}

        # Флаг — пользователь тащит персонажа
        self._is_dragged = False
        self._pre_drag_state = 'stand'

    # ── публичный API ────────────────────────────────────────

    def start(self):
        self._alive = True
        # Читаем размер экрана синхронно — до создания overlay
        self._read_screen_size()
        self._plugin._log(f"start: floor_y={self._floor_y} screen={self._screen_w}x{self._screen_h}")
        self._x = self._screen_w / 2.0
        self._y = float(self._floor_y)   # стартуем с пола
        self._renderer.create(int(self._x), int(self._y), self._scale)
        self._thread = threading.Thread(target=self._loop, daemon=True)
        self._thread.start()
        self._plugin._log("ShimejiEngine started")

    def stop(self):
        self._alive = False
        self._renderer.destroy()
        self._plugin._log("ShimejiEngine stopped")

    def force_state(self, state):
        """Вызывается из TG-хуков для реакции персонажа."""
        if state in ANIM:
            self._forced_state = state

    def react(self, event):
        """Реагируем на событие Telegram разными анимациями."""
        import random
        if not self._alive or self._is_dragged:
            return
        on_floor = abs(self._y - self._floor_y) < 5

        if event == "send":
            # Отправил сообщение — идёт быстро или карабкается
            if on_floor:
                self._enter_state("run")
                self._facing_right = random.choice([True, False])
                self._state_dur = random.randint(20, 40)
        elif event == "incoming":
            # Входящее — садится и смотрит вверх, потом встаёт
            if on_floor:
                self._forced_state = random.choice(["sit", "spin"])
        elif event == "mention":
            # Упомянули — вскакивает, крутится
            if on_floor:
                self._forced_state = "spin"
        elif event == "reaction":
            # Поставили реакцию — прыгает от радости (wall_jump если у стены)
            if on_floor:
                pad_l = int(SPRITE_PAD_LEFT * self._scale)
                pad_r = int(SPRITE_PAD_RIGHT * self._scale)
                near_left  = self._x <= -pad_l + 20
                near_right = self._x >= self._screen_w - int(SPRITE_SIZE * self._scale) + pad_r - 20
                if near_left or near_right:
                    self._forced_state = "wall_jump"
                else:
                    self._vy = -12
                    self._forced_state = "jump"
        elif event == "typing":
            # Кто-то печатает — ложится отдыхать
            if on_floor:
                self._forced_state = "sprawl"
        elif event == "call":
            # Звонок — паникует, бежит
            self._enter_state("run")
            self._facing_right = not self._facing_right
            self._state_dur = 60

    def on_drag_start(self):
        """Вызывается из TouchListener когда начали тащить."""
        self._pre_drag_state = self._state
        self._is_dragged = True
        self._enter_state("drag")

    def on_drag_end(self, x, y, vx=0.0, vy=0.0):
        """Вызывается из TouchListener когда отпустили. vx/vy — скорость броска."""
        self._is_dragged = False
        self._x = float(x)
        self._y = float(y)

        # Клампим скорость
        MAX_VX = 25.0
        MAX_VY = 30.0
        vx = max(-MAX_VX, min(MAX_VX, vx))
        vy = max(-MAX_VY, min(MAX_VY, vy))

        self._plugin._log(f"drag_end: x={int(x)} y={int(y)} vx={vx:.1f} vy={vy:.1f}")

        size_w  = int(SPRITE_SIZE * self._scale)
        cpl     = int(float(self._plugin.gs("climb_pad_left",  "52") or "52") * self._scale)
        cpr     = int(float(self._plugin.gs("climb_pad_right", "52") or "52") * self._scale)
        on_left_wall  = self._x <= -cpl + 10
        on_right_wall = self._x >= self._screen_w - size_w + cpr - 10

        if self._y >= self._floor_y:
            # На полу
            self._y  = float(self._floor_y)
            self._vy = 0
            self._enter_state("bounce")
        elif (on_left_wall or on_right_wall) and abs(vx) > 3:
            # Бросили в стену — с шансом 60% зацепится
            import random
            if random.random() < 0.6:
                self._wall_side = "left" if on_left_wall else "right"
                self._vy = 0
                self._enter_state("climb_wall")
                return
            else:
                self._vy = vy if abs(vy) > 2 else 0
                self._enter_state("fall")
        elif abs(vx) > 2 or abs(vy) > 2:
            # Бросок с инерцией
            self._throw_vx = vx
            # Бросок вверх: vy < 0 — усиливаем для лучшего ощущения
            if vy < -2:
                self._vy = max(vy * 1.3, -22.0)
            else:
                self._vy = min(vy, 15.0)
            self._enter_state("fling")
        else:
            # Просто отпустили без скорости
            self._vy = 0
            self._enter_state("fall")

    # ── внутренняя логика ────────────────────────────────────

    def _read_screen_size(self):
        try:
            from hook_utils import find_class as fc
            AL = fc("org.telegram.messenger.ApplicationLoader")
            ctx = AL.applicationContext
            dm = ctx.getResources().getDisplayMetrics()
            self._screen_w = dm.widthPixels
            self._screen_h = dm.heightPixels
            size = int(SPRITE_SIZE * self._scale)
            # Получаем высоту nav bar через Android Resources
            nav_bar_h = 0
            try:
                res = ctx.getResources()
                nav_id = res.getIdentifier("navigation_bar_height", "dimen", "android")
                if nav_id > 0:
                    nav_bar_h = res.getDimensionPixelSize(nav_id)
                    self._plugin._log(f"nav_bar_height: {nav_bar_h}px")
            except Exception as e:
                self._plugin._log(f"nav_bar detect: {e}")
            offset = int(float(self._plugin.gs("bottom_offset", "0") or "0"))
            self._floor_y = self._screen_h - size - nav_bar_h - offset
            self._plugin._log(f"floor_y: {self._floor_y} (screen_h={self._screen_h}, visible={visible_h}, size={size}, offset={offset})")
            # Паддинги карабкания из настроек
            global SPRITE_PAD_CLIMB_LEFT, SPRITE_PAD_CLIMB_RIGHT
            SPRITE_PAD_CLIMB_LEFT  = int(float(self._plugin.gs("climb_pad_left",  "75") or "75"))
            SPRITE_PAD_CLIMB_RIGHT = int(float(self._plugin.gs("climb_pad_right", "75") or "75"))
            self._plugin._log(f"climb_pad: L={SPRITE_PAD_CLIMB_LEFT} R={SPRITE_PAD_CLIMB_RIGHT}")
            self._plugin._log(f"Screen: {self._screen_w}x{self._screen_h}")
            # Логируем содержимое папки со спрайтами для диагностики
            sdir = self._plugin.gs("sprites_dir", SPRITES_DIR)
            try:
                self._plugin._log(f"Sprites dir: {sdir}")
                all_png = []
                for root, dirs, files in os.walk(sdir):
                    for f in files:
                        if f.lower().endswith(".png"):
                            all_png.append(os.path.join(root, f))
                self._plugin._log(f"PNG files found (recursive): {len(all_png)}")
                if all_png:
                    self._plugin._log(f"First 3: {all_png[:3]}")
                # Строим кеш спрайтов
                self._sprite_cache = _build_sprite_cache(sdir)
                self._plugin._log(f"Sprite cache keys: {list(self._sprite_cache.keys())[:5]}")
            except Exception as de:
                self._plugin._log(f"Sprites dir error: {de}")
        except Exception as e:
            self._plugin._log(f"_read_screen_size: {e}")

    def _loop(self):
        import time
        while self._alive:
            try:
                self._tick()
            except Exception as e:
                self._plugin._log(f"_loop tick error: {e}\n{traceback.format_exc()}")
            time.sleep(TICK_MS / 1000.0)

    def _tick(self):
        # Пока тащат — только анимация drag, физика и переходы не нужны
        if self._is_dragged:
            self._anim_tick += 1
            if self._anim_tick >= self._anim_spf:
                self._anim_tick = 0
                self._anim_idx  = (self._anim_idx + 1) % len(self._anim_frames)
                self._update_sprite()
            return

        # Проверяем принудительное состояние
        if self._forced_state:
            self._enter_state(self._forced_state)
            self._forced_state = None

        self._state_tick += 1
        self._anim_tick  += 1

        # Обновляем позицию
        self._update_position()

        # Обновляем кадр анимации
        if self._anim_tick >= self._anim_spf:
            self._anim_tick = 0
            self._anim_idx  = (self._anim_idx + 1) % len(self._anim_frames)
            self._update_sprite()

        # Переход в следующее состояние
        # fall/climb_wall/ceiling/jump управляются физикой
        if self._state in ("fall", "climb_wall", "ceiling", "jump", "wall_jump", "fling", "drag"):
            pass  # только физика решает переход
        elif self._state == "bounce":
            # bounce заканчивается когда анимация прошла полный цикл
            total_frames = len(self._anim_frames)
            if self._state_tick >= total_frames * self._anim_spf * 2:
                self._enter_state("stand")
        else:
            if self._state_tick >= self._state_dur:
                self._next_state()

    def _update_position(self):
        state = self._state
        self._state_tick = getattr(self, "_state_tick", 0) + 1
        size  = int(SPRITE_SIZE * self._scale)

        # ═══ ГРАВИТАЦИЯ ════════════════════════════════════════
        # Для всех состояний кроме ceiling/climb_wall/drag/fall/jump
        if state not in ("ceiling", "climb_wall", "drag", "fall", "jump", "wall_jump", "fling"):
            if self._y < self._floor_y - 1:
                # В воздухе — падаем
                self._vy = min(self._vy + 2, 30)
                self._y += self._vy
                if self._y >= self._floor_y:
                    self._y  = float(self._floor_y)
                    self._vy = 0
                    self._enter_state("bounce")
                    self._renderer.move_to(int(self._x), int(self._y))
                    return
            else:
                self._y  = float(self._floor_y)
                self._vy = 0

        # ═══ ДВИЖЕНИЕ ══════════════════════════════════════════
        moved = False

        if state == "fall":
            self._vy = min(self._vy + 2, 30)
            self._y  += self._vy
            if self._y >= self._floor_y:
                self._y  = float(self._floor_y)
                self._vy = 0
                self._enter_state("bounce")
            elif self._y < 0:
                self._y = 0.0
            moved = True

        elif state in ("walk", "run"):
            spd = SPEED[state]
            dx  = spd if self._facing_right else -spd
            self._x += dx
            on_floor = abs(self._y - self._floor_y) < 2
            size_w = int(SPRITE_SIZE * self._scale)
            pad_l  = int(SPRITE_PAD_LEFT  * self._scale)
            pad_r  = int(SPRITE_PAD_RIGHT * self._scale)
            # Края: оверлей заходит за экран на величину паддинга
            left_wall  = -pad_l                          # Рик касается левого края
            right_wall = self._screen_w - size_w + pad_r # Рик касается правого края
            if self._x <= left_wall:
                self._x = float(left_wall)
                if on_floor:
                    self._wall_side = "left"
                    self._enter_state("climb_wall")
                else:
                    self._facing_right = True
            elif self._x >= right_wall:
                self._x = float(right_wall)
                if on_floor:
                    self._wall_side = "right"
                    self._enter_state("climb_wall")
                else:
                    self._facing_right = False
            moved = True

        elif state == "climb_wall":
            if not hasattr(self, "_wall_side") or self._wall_side is None:
                self._wall_side = "left" if self._x < self._screen_w / 2 else "right"
            size_w = int(SPRITE_SIZE * self._scale)
            cpl = int(float(self._plugin.gs("climb_pad_left",  "75") or "75") * self._scale)
            cpr = int(float(self._plugin.gs("climb_pad_right", "75") or "75") * self._scale)
            if self._wall_side == "left":
                self._x = float(-cpl)
            else:
                self._x = float(self._screen_w - size_w + cpr)
            self._y -= SPEED["climb_wall"]
            if self._y <= 0:
                self._y = 0.0
                # Устанавливаем направление чтоб ceiling сразу уходил от угла
                self._facing_right = (self._wall_side == "left")
                self._wall_side = None
                self._enter_state("ceiling")
            elif self._y >= self._floor_y:
                self._y = float(self._floor_y)
                self._wall_side = None
                self._enter_state("stand")
            elif self._y < self._floor_y * 0.7 and random.random() < 0.008:
                # ~20% шанс прыгнуть от стены когда добрался до середины
                self._enter_state("wall_jump")
            moved = True

        elif state == "ceiling":
            self._y = 0.0
            size_w = int(SPRITE_SIZE * self._scale)
            cpl_c = int(float(self._plugin.gs("climb_pad_left",  "75") or "75") * self._scale)
            cpr_c = int(float(self._plugin.gs("climb_pad_right", "75") or "75") * self._scale)
            dx = SPEED["ceiling"] if self._facing_right else -SPEED["ceiling"]
            self._x += dx
            # Кулдаун — не переходим на стену первые N тиков после прихода на потолок
            # _state_tick считается в _next_state, используем его
            ceiling_ticks = getattr(self, "_state_tick", 0)
            if ceiling_ticks > 8:  # ~320мс прежде чем можно уйти на стену
                if self._x <= -cpl_c:
                    self._x = float(-cpl_c)
                    self._wall_side = "left"
                    # При переходе на стену — начинаем чуть ниже 0 чтоб не мигать
                    self._y = float(SPEED["climb_wall"] * 3)
                    self._enter_state("climb_wall")
                elif self._x >= self._screen_w - size_w + cpr_c:
                    self._x = float(self._screen_w - size_w + cpr_c)
                    self._wall_side = "right"
                    self._y = float(SPEED["climb_wall"] * 3)
                    self._enter_state("climb_wall")
            else:
                # В первые тики — просто прижимаемся к краю без перехода
                if self._x <= -cpl_c:
                    self._x = float(-cpl_c)
                elif self._x >= self._screen_w - size_w + cpr_c:
                    self._x = float(self._screen_w - size_w + cpr_c)
            # Иногда отпускается и падает
            if random.random() < 0.002:
                self._enter_state("fall")
            moved = True

        elif state in ("jump", "wall_jump"):
            if state == "wall_jump":
                # Летим к противоположной стене с постоянной скоростью
                vx = getattr(self, "_wall_jump_vx", 0)
                self._x += vx
                self._facing_right = vx > 0
                # Если долетели до другой стены — цепляемся за неё
                size_wj = int(SPRITE_SIZE * self._scale)
                cpl_j = int(float(self._plugin.gs("climb_pad_left",  "75") or "75") * self._scale)
                cpr_j = int(float(self._plugin.gs("climb_pad_right", "75") or "75") * self._scale)
                if self._x <= -cpl_j:
                    self._x = float(-cpl_j)
                    self._wall_jump_vx = 0
                    self._wall_side = "left"
                    self._enter_state("climb_wall")
                elif self._x >= self._screen_w - size_wj + cpr_j:
                    self._x = float(self._screen_w - size_wj + cpr_j)
                    self._wall_jump_vx = 0
                    self._wall_side = "right"
                    self._enter_state("climb_wall")
            # Для wall_jump — мягкая дуга
            gravity = 1 if state == "wall_jump" else 3
            self._vy = min(self._vy + gravity, 20)
            self._y  += self._vy
            if self._y <= 0:
                self._y  = 0.0
                self._vy = 0
                self._enter_state("fall")
            elif self._y >= self._floor_y:
                self._y  = float(self._floor_y)
                self._vy = 0
                self._wall_jump_vx = 0
                self._enter_state("bounce")
            moved = True

        elif state == "fling":
            # Бросок с инерцией — полная физика с гравитацией
            vx = getattr(self, "_throw_vx", 0.0)
            self._x += vx
            # Плавное затухание горизонтальной скорости (воздушное сопротивление)
            self._throw_vx = vx * 0.92

            # Гравитация — мягкая, позволяет лететь вверх
            self._vy = min(self._vy + 1.5, 30)
            self._y  += self._vy

            size_w = int(SPRITE_SIZE * self._scale)
            cpl = int(float(self._plugin.gs("climb_pad_left",  "52") or "52") * self._scale)
            cpr = int(float(self._plugin.gs("climb_pad_right", "52") or "52") * self._scale)

            # Касание потолка — зацепляемся!
            if self._y <= 0:
                self._y = 0.0
                self._vy = 0
                self._throw_vx = 0
                self._enter_state("ceiling")

            # Касание стены — шанс зацепиться и карабкаться
            elif self._x <= -cpl:
                self._x = float(-cpl)
                if random.random() < 0.65:
                    self._wall_side = "left"
                    self._vy = 0; self._throw_vx = 0
                    self._enter_state("climb_wall")
                else:
                    self._throw_vx = abs(vx) * 0.4   # отскок

            elif self._x >= self._screen_w - size_w + cpr:
                self._x = float(self._screen_w - size_w + cpr)
                if random.random() < 0.65:
                    self._wall_side = "right"
                    self._vy = 0; self._throw_vx = 0
                    self._enter_state("climb_wall")
                else:
                    self._throw_vx = -abs(vx) * 0.4

            # Касание пола
            elif self._y >= self._floor_y:
                self._y = float(self._floor_y)
                self._vy = 0; self._throw_vx = 0
                self._enter_state("bounce")

            # Разворачиваем по направлению полёта
            if abs(self._throw_vx) > 0.5:
                self._facing_right = self._throw_vx > 0
            moved = True

        elif state in ("stand", "sit", "sprawl", "bounce", "spin", "drag"):
            moved = True

        if moved:
            self._renderer.move_to(int(self._x), int(self._y))
    def _update_sprite(self):
        name = self._anim_frames[self._anim_idx]
        # Сначала ищем в кеше, потом fallback на os.walk
        path = self._sprite_cache.get(name.lower())
        if path is None:
            path = _find_sprite(self._sprites_dir, name)
            if path:
                self._sprite_cache[name.lower()] = path
        if path:
            self._renderer.set_sprite(path, flip=self._facing_right)
        else:
            self._plugin._log(f"Sprite not found: {name} in cache keys: {list(self._sprite_cache.keys())[:5]}")

    def _enter_state(self, state):
        if state not in ANIM:
            state = "stand"
        self._state      = state
        self._state_tick = 0
        dur_min, dur_max = DURATIONS.get(state, (30, 80))
        self._state_dur  = random.randint(dur_min, dur_max)
        self._anim_frames = ANIM[state]
        self._anim_idx   = 0
        self._anim_tick  = 0

        # Сброс wall_side при наземных состояниях
        if state in ("walk", "run", "stand", "sit", "sprawl"):
            self._wall_side = None

        # wall_jump — прыгаем от стены к противоположной
        if state == "wall_jump":
            side = getattr(self, "_wall_side", "left")
            size_w = int(SPRITE_SIZE * self._scale)
            cpl        = int(float(self._plugin.gs("climb_pad_left",  "75") or "75") * self._scale)
            cpr        = int(float(self._plugin.gs("climb_pad_right", "75") or "75") * self._scale)
            left_wall  = -cpl
            right_wall = self._screen_w - size_w + cpr
            dist = right_wall - left_wall  # полная дистанция от стены до стены
            flight_ticks = 30  # ~1.2 сек полёта
            vx = dist / flight_ticks
            self._wall_jump_vx = vx if side == "left" else -vx
            self._vy = -16  # дуга — приземляется чуть выше точки прыжка
            self._wall_side = None
            self._plugin._log(f"wall_jump from={side} vx={vx:.1f} dist={dist}")

        # Скорость смены кадров зависит от состояния
        if state in ("walk", "run"):
            self._anim_spf = 3
        elif state in ("bounce", "spin"):
            self._anim_spf = 2
        else:
            self._anim_spf = 6

        # Выбираем направление для движущихся состояний
        if state in ("walk", "run"):
            self._facing_right = random.choice([True, False])
            # Если у края — разворачиваем внутрь
            size = int(SPRITE_SIZE * self._scale)
            if self._x <= 20:
                self._facing_right = True
            elif self._x >= self._screen_w - size - 20:
                self._facing_right = False

        elif state == "climb_wall":
            # Карабкаемся всегда вверх; "лицо" смотрит к стене
            self._facing_right = (self._x > self._screen_w / 2)

        elif state == "fall":
            self._vy = 0

        elif state == "jump":
            self._vy = -20

        self._update_sprite()

    def _next_state(self):
        choices = TRANSITIONS.get(self._state, [("stand", 1)])
        next_s  = _weighted_choice(choices)
        self._enter_state(next_s)


# ═══════════════════════════════════════════════════════════
#  ПАЛИТРА ЦВЕТОВ — паттерн из manga_reader
# ═══════════════════════════════════════════════════════════

def _drawable(name):
    """Получает resource ID drawable по имени — паттерн из manga_reader."""
    try:
        return getattr(R.drawable, name)
    except Exception:
        return 0


def _to_int(v):
    """unsigned → signed int32, как в Java."""
    v = int(v) & 0xFFFFFFFF
    if v >= 0x80000000:
        v -= 0x100000000
    return v

def _tc(key, fallback):
    """Читает цвет из темы Telegram. Fallback если не найден."""
    try:
        from org.telegram.ui.ActionBar import Theme
        return _to_int(int(Theme.getColor(getattr(Theme, key))))
    except Exception:
        return _to_int(fallback)

def _palette():
    """Возвращает словарь цветов текущей темы."""
    return {
        "bg":     _tc("key_windowBackgroundGray",           -14935010),
        "card":   _tc("key_windowBackgroundWhite",          -13882322),
        "text":   _tc("key_windowBackgroundWhiteBlackText", -1),
        "hint":   _tc("key_windowBackgroundWhiteGrayText3", -7434605),
        "accent": _tc("key_featuredStickers_addButton",     -12747788),
        "bar":    _tc("key_actionBarDefault",               -14935010),
        "title":  _tc("key_actionBarDefaultTitle",          -1),
    }


# ═══════════════════════════════════════════════════════════
#  TAB BAR — паттерн из manga_reader
# ═══════════════════════════════════════════════════════════

def _rounded_bg(color, radius=18):
    from android.graphics.drawable import GradientDrawable
    bg = GradientDrawable()
    bg.setShape(GradientDrawable.RECTANGLE)
    bg.setCornerRadius(AndroidUtilities.dp(radius))
    bg.setColor(color)
    return bg

def _rounded_stroke(fill, stroke_color, radius=21):
    from android.graphics.drawable import GradientDrawable
    bg = GradientDrawable()
    bg.setShape(GradientDrawable.RECTANGLE)
    bg.setCornerRadius(AndroidUtilities.dp(radius))
    bg.setColor(fill)
    bg.setStroke(AndroidUtilities.dp(1), stroke_color)
    return bg

def _set_ripple(view, ripple_color):
    try:
        from org.telegram.ui.ActionBar import Theme as _T
        mask = int(getattr(_T, "RIPPLE_MASK_ROUNDRECT_6DP", 3))
        sel  = _T.createSelectorDrawable(ripple_color, mask, AndroidUtilities.dp(18))
        try:    view.setForeground(sel)
        except: view.setBackground(sel)
    except: pass

def _alpha(color, a):
    return (int(color) & 0x00FFFFFF) | ((a & 0xFF) << 24)

def _build_pill_tabs(ctx, p, tabs, on_select):
    """
    Горизонтальный таб-бар с пилюлями.
    tabs = [(key, label), ...]
    Возвращает (shell_view, set_active_fn)
    """
    dp = AndroidUtilities.dp
    LP  = LinearLayout.LayoutParams
    FLP = FrameLayout.LayoutParams

    # tab цвета из _palette + fallback
    tab_bg     = _to_int(p.get("card",   p["bg"]))
    tab_stroke = _alpha(p["hint"], 60)
    tab_active = p["accent"]
    tab_text   = p["hint"]
    tab_active_text = p["bg"]

    shell = FrameLayout(ctx)
    shell.setBackground(_rounded_stroke(tab_bg, tab_stroke, radius=21))
    shell.setPadding(dp(4), dp(3), dp(4), dp(3))

    from android.widget import HorizontalScrollView
    h_scroll = HorizontalScrollView(ctx)
    h_scroll.setHorizontalScrollBarEnabled(False)
    try: h_scroll.setOverScrollMode(View.OVER_SCROLL_NEVER)
    except: pass

    row = LinearLayout(ctx)
    row.setOrientation(LinearLayout.HORIZONTAL)
    row.setGravity(Gravity.CENTER_VERTICAL)

    tab_refs = {}

    def _make_pill(key, label):
        pill = LinearLayout(ctx)
        pill.setOrientation(LinearLayout.HORIZONTAL)
        pill.setGravity(Gravity.CENTER)
        pill.setPadding(dp(14), dp(7), dp(14), dp(7))
        pill.setClickable(True)
        pill.setFocusable(True)

        tv = TextView(ctx)
        tv.setText(label)
        tv.setTextSize(13.0)
        tv.setTextColor(tab_text)
        try:
            from android.graphics import Typeface
            tv.setTypeface(Typeface.DEFAULT_BOLD)
        except: pass
        pill.addView(tv, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))
        tab_refs[key] = {"pill": pill, "tv": tv}
        return pill

    def _set_active(key):
        for k, ref in tab_refs.items():
            is_active = k == key
            if is_active:
                ref["pill"].setBackground(_rounded_bg(tab_active, 18))
                ref["tv"].setTextColor(tab_active_text)
            else:
                ref["pill"].setBackground(None)
                ref["tv"].setTextColor(tab_text)

    for key, label in tabs:
        pill = _make_pill(key, label)
        _set_ripple(pill, _alpha(tab_active, 48))
        pill.setOnClickListener(_make_click(lambda v, k=key: (_set_active(k), on_select(k))))
        lp = LP(LP.WRAP_CONTENT, LP.MATCH_PARENT)
        lp.rightMargin = dp(2)
        row.addView(pill, lp)

    if tabs:
        _set_active(tabs[0][0])

    h_scroll.addView(row, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))
    shell.addView(h_scroll, FLP(FLP.MATCH_PARENT, FLP.MATCH_PARENT))
    return shell, _set_active


# ═══════════════════════════════════════════════════════════
#  FILE PICKER HOOK — уровень модуля как в ai_assistant
# ═══════════════════════════════════════════════════════════

class _FileResultHook(MethodHook):
    """Хук onActivityResult для файлпикера. Должен быть на уровне модуля."""
    def __init__(self, plugin, request_code):
        self._p  = plugin
        self._rc = request_code

    def after_hooked_method(self, param):
        try:
            req  = int(param.args[0])
            res  = int(param.args[1])
            data = param.args[2]
            if req != self._rc:
                return
            self._p._log(f"_FileResultHook: req={req} res={res} data={data is not None}")
            RESULT_OK = -1
            cb = self._p._pending_file_callback
            self._p._pending_file_callback = None
            if res != RESULT_OK:
                run_on_ui_thread(lambda: BulletinHelper.show_info("Файл не выбран"))
                return
            if data is None:
                return
            uri = data.getData()
            if uri is None:
                return
            uri_str = str(uri.toString())
            self._p._log(f"_FileResultHook: uri={uri_str[:80]}")
            if cb:
                import threading as _thr
                _thr.Thread(target=lambda: cb(uri_str), daemon=True).start()
        except Exception as e:
            self._p._log(f"_FileResultHook error: {e}\n{traceback.format_exc()}")


# ═══════════════════════════════════════════════════════════
#  ПЛАГИН
# ═══════════════════════════════════════════════════════════

class ShimejiPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self._engine = None
        self._logs   = []

    # ── утилиты ─────────────────────────────────────────────

    def _log(self, msg):
        alog(f"[Shimeji] {msg}")
        self._logs.append(msg)
        if len(self._logs) > 200:
            self._logs.pop(0)

    def gs(self, key, default=None):
        return self.get_setting(key, default)

    def ss(self, key, val, r=False):
        self.set_setting(key, val, reload_settings=r)

    def _get_context(self):
        try:
            f = get_last_fragment()
            if f:
                return f.getParentActivity()
        except Exception:
            pass
        try:
            from org.telegram.messenger import ApplicationLoader
            return ApplicationLoader.applicationContext
        except Exception:
            pass
        return None

    # ── жизненный цикл ──────────────────────────────────────

    def on_plugin_load(self):
        try:
            self._log("Loading...")
            if self.gs("enabled", True):
                self._start_engine()
            self._setup_tg_hooks()
            BulletinHelper.show_success("Shimeji загружен")
            self._log("Loaded OK")
        except Exception as e:
            self._log(f"on_plugin_load: {e}\n{traceback.format_exc()}")

    def _setup_tg_hooks(self):
        """Хуки на события Telegram."""
        try:
            self.add_on_send_message_hook()
            self._log("TG: send_message OK")
        except Exception as e:
            self._log(f"TG send: {e}")

        try:
            from hook_utils import find_class
            from base_plugin import MethodHook
            plugin_ref = self

            # ── Входящие сообщения ──────────────────────────
            class IncomingHook(MethodHook):
                def after_hooked_method(self_h, param):
                    try:
                        eng = plugin_ref._engine
                        if eng and eng._alive:
                            eng.react("incoming")
                    except Exception: pass

            # ── Упоминание (@) ──────────────────────────────
            class MentionHook(MethodHook):
                def after_hooked_method(self_h, param):
                    try:
                        eng = plugin_ref._engine
                        if eng and eng._alive:
                            eng.react("mention")
                    except Exception: pass

            NC = find_class("org.telegram.messenger.NotificationsController")
            if NC:
                methods = {m.getName(): m for m in NC.getDeclaredMethods()}
                for name in ["showNotifications", "processNewMessages"]:
                    if name in methods:
                        methods[name].setAccessible(True)
                        self.hook_method(methods[name], IncomingHook())
                        self._log(f"TG: {name} OK")
                        break

            # ── Звонок — через SendMessagesHelper ───────────
            try:
                SMH = find_class("org.telegram.messenger.SendMessagesHelper")
                if SMH:
                    for m in SMH.getDeclaredMethods():
                        if "call" in m.getName().lower() or "phone" in m.getName().lower():
                            m.setAccessible(True)
                            class CallHook(MethodHook):
                                def before_hooked_method(self_h, param):
                                    try:
                                        eng = plugin_ref._engine
                                        if eng and eng._alive:
                                            eng.react("call")
                                    except Exception: pass
                            self.hook_method(m, CallHook())
                            self._log(f"TG call: {m.getName()} OK")
                            break
            except Exception as e:
                self._log(f"TG call hook: {e}")

            # ── Упоминание — через NotificationCenter ────────
            try:
                NC = find_class("org.telegram.messenger.NotificationCenter")
                if NC:
                    for m in NC.getDeclaredMethods():
                        if m.getName() == "postNotificationName":
                            m.setAccessible(True)
                            params_count = len(m.getParameterTypes())
                            class NcHook(MethodHook):
                                def after_hooked_method(self_h, param):
                                    try:
                                        if not param.args:
                                            return
                                        notif_id = int(str(param.args[0]))
                                        eng = plugin_ref._engine
                                        if not eng or not eng._alive:
                                            return
                                        # NotificationCenter IDs (приблизительные)
                                        # 11 = didReceiveNewMessages
                                        # 10 = updateInterfaces (mention)
                                        if notif_id == 11:
                                            eng.react("incoming")
                                        elif notif_id in (10, 62):
                                            eng.react("mention")
                                    except Exception: pass
                            self.hook_method(m, NcHook())
                            self._log("TG: NotificationCenter.postNotificationName OK")
                            break
            except Exception as e:
                self._log(f"TG NC hook: {e}")

        except Exception as e:
            self._log(f"TG hooks: {e}")


    def on_send_message_hook(self, account, params):
        """Реакция на отправку сообщения."""
        from base_plugin import HookResult
        try:
            if self._engine and self._engine._alive:
                self._engine.react("send")
        except Exception as e:
            self._log(f"on_send_message_hook: {e}")
        return HookResult()

    def on_plugin_unload(self):
        self._stop_engine()
        BulletinHelper.show_info("Shimeji выгружен")

    # ── движок ──────────────────────────────────────────────

    def _start_engine(self):
        if self._engine and self._engine._alive:
            return
        self._engine = ShimejiEngine(self)
        self._engine.start()

    def _stop_engine(self):
        if self._engine:
            self._engine.stop()
            self._engine = None

    def _restart_engine(self, view=None):
        self._stop_engine()
        if self.gs("enabled", True):
            self._start_engine()
        BulletinHelper.show_success("Перезапущен!")

    # ── настройки ───────────────────────────────────────────

    def create_settings(self) -> List[Any]:
        return [
            Header(text="Shimeji"),
            Switch(
                key="enabled",
                text="Включить",
                subtext="Показывать персонажа",
                default=True,
                icon="msg_settings",
                on_change=self._on_enable_change,
            ),
            Divider(),
            Header(text="Персонаж"),
            Input(
                key="sprites_dir",
                text="Путь к персонажу",
                default=INSTALL_DIR + "img/",
                icon="msg_settings",
                on_change=lambda v: self.ss("sprites_dir", str(v).strip()),
            ),
            Input(
                key="scale",
                text="Масштаб (0.5 – 3.0)",
                default="1.0",
                icon="msg_settings",
                on_change=lambda v: self.ss("scale", str(v).strip()),
            ),
            Divider(),
            Header(text="Отступы"),
            Input(
                key="bottom_offset",
                text="Отступ снизу",
                subtext="Если персонаж висит над полом — увеличь значение",
                default="0",
                icon="msg_settings",
                on_change=lambda v: self.ss("bottom_offset", str(v).strip()),
            ),
            Input(
                key="climb_pad_left",
                text="Отступ левой стены",
                subtext="Насколько персонаж заходит за левый край при карабкании (дефолт: 52)",
                default="52",
                icon="msg_settings",
                on_change=lambda v: (self.ss("climb_pad_left", str(v).strip()), self._restart_engine()),
            ),
            Input(
                key="climb_pad_right",
                text="Отступ правой стены",
                subtext="Насколько персонаж заходит за правый край при карабкании (дефолт: 52)",
                default="52",
                icon="msg_settings",
                on_change=lambda v: (self.ss("climb_pad_right", str(v).strip()), self._restart_engine()),
            ),
            Divider(),
            Switch(
                key="drag_enabled",
                text="Перетаскивание",
                subtext="Тащи персонажа пальцем",
                default=True,
                icon="msg_settings",
                on_change=self._on_drag_toggle,
            ),
            Switch(
                key="show_borders",
                text="Показывать границы окна",
                subtext="Красная рамка вокруг спрайта для отладки",
                default=False,
                icon="msg_settings",
                on_change=self._on_borders_change,
            ),
            Text(
                text="Библиотека персонажей",
                icon="msg_settings",
                accent=True,
                on_click=self._open_library,
            ),
            Text(
                text="Локальная библиотека",
                icon="msg_settings",
                on_click=self._open_local_library,
            ),
            Text(
                text="Перезапустить",
                icon="msg_settings",
                accent=True,
                on_click=self._restart_engine,
            ),
            Divider(text=f"v{__version__}"),
        ]

    def _on_enable_change(self, val: bool):
        if val:
            self._start_engine()
        else:
            self._stop_engine()

    def _on_drag_toggle(self, val: bool):
        if self._engine and self._engine._alive:
            if val:
                self._engine._renderer.enable_drag(on_drag_end=self._engine.on_drag_end)
            else:
                self._engine._renderer.disable_drag()

    def _on_borders_change(self, val: bool):
        if self._engine and self._engine._alive:
            self._engine._renderer.set_border_visible(val)

    # ── библиотека ──────────────────────────────────────────

    def _open_library(self, view=None):
        """Открывает BottomSheet с галереей персонажей."""
        def _do():
            try:
                f   = get_last_fragment()
                ctx = f.getParentActivity() if f else None
                if not ctx:
                    BulletinHelper.show_error("Нет контекста")
                    return
                self._show_library_sheet(ctx)
            except Exception as e:
                self._log(f"_open_library: {e}")
        run_on_ui_thread(_do)

    def _show_library_sheet(self, ctx):
        try:
            dp  = AndroidUtilities.dp
            LP  = LinearLayout.LayoutParams
            FLP = FrameLayout.LayoutParams
            p   = _palette()

            sh = BottomSheet(ctx, False)
            try: sh.setFullscreen(True)
            except Exception: pass
            try: sh.setCanDismissWithSwipe(False)
            except Exception: pass
            try: sh.setCanDrag(False)
            except Exception: pass

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setBackgroundColor(p["bg"])

            # Header
            bar = LinearLayout(ctx)
            bar.setOrientation(LinearLayout.HORIZONTAL)
            bar.setGravity(Gravity.CENTER_VERTICAL)
            bar.setPadding(dp(16), dp(14), dp(12), dp(14))
            bar.setBackgroundColor(p["bar"])

            title_tv = TextView(ctx)
            title_tv.setText("Библиотека персонажей")
            title_tv.setTextSize(18.0)
            title_tv.setTextColor(p["title"])
            title_tv.setTypeface(title_tv.getTypeface(), 1)
            bar.addView(title_tv, LP(0, LP.WRAP_CONTENT, 1.0))

            # Кнопка закрыть — иконка drawable
            close_iv = ImageView(ctx)
            close_ic = _drawable("msg_close") or _drawable("ic_close")
            if close_ic:
                close_iv.setImageResource(close_ic)
                close_iv.setColorFilter(p["hint"])
            else:
                close_iv = TextView(ctx)
                close_iv.setText("✕")
                close_iv.setTextSize(20.0)
                close_iv.setTextColor(p["hint"])
            close_iv.setPadding(dp(12), dp(8), dp(12), dp(8))
            close_iv.setOnClickListener(_make_click(lambda v: sh.dismiss()))
            bar.addView(close_iv, LP(dp(44), dp(44)))
            root.addView(bar, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            # Loading
            loading_tv = TextView(ctx)
            loading_tv.setText("Загружаю...")
            loading_tv.setTextColor(p["hint"])
            loading_tv.setTextSize(15.0)
            loading_tv.setGravity(Gravity.CENTER)
            loading_tv.setPadding(dp(20), dp(60), dp(20), dp(60))
            root.addView(loading_tv, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            sh.setCustomView(root)
            sh.show()

            plugin = self
            def _load():
                try:
                    import requests
                    resp = requests.get(GITHUB_INDEX, timeout=10)
                    if resp.status_code != 200:
                        run_on_ui_thread(lambda: loading_tv.setText(f"Ошибка: HTTP {resp.status_code}"))
                        return
                    packs = resp.json()
                    def _build():
                        try:
                            root.removeView(loading_tv)

                            # Группируем по вселенной
                            from collections import OrderedDict
                            universes = OrderedDict()
                            universes["Все"] = packs
                            for pack in packs:
                                u = pack.get("universe", "Другое")
                                universes.setdefault(u, []).append(pack)

                            # ── Таб-бар ──────────────────────────────────────
                            tabs = [(k, k) for k in universes.keys()]
                            current = [tabs[0][0]]   # активный таб

                            tab_shell, set_active = _build_pill_tabs(ctx, p, tabs,
                                lambda k: (current.__setitem__(0, k), _show_tab(k)))

                            lp_tabs = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
                            lp_tabs.topMargin    = dp(8)
                            lp_tabs.bottomMargin = dp(8)
                            lp_tabs.leftMargin   = dp(12)
                            lp_tabs.rightMargin  = dp(12)
                            root.addView(tab_shell, lp_tabs)

                            # ── Контент под табами ───────────────────────────
                            scroll = ScrollView(ctx)
                            scroll.setVerticalScrollBarEnabled(False)
                            grid = LinearLayout(ctx)
                            grid.setOrientation(LinearLayout.VERTICAL)
                            grid.setPadding(dp(12), dp(4), dp(12), dp(80))
                            scroll.addView(grid, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
                            root.addView(scroll, LP(LP.MATCH_PARENT, LP.MATCH_PARENT))

                            def _show_tab(key):
                                def _ui():
                                    grid.removeAllViews()
                                    chars = universes.get(key, [])
                                    for pack in chars:
                                        plugin._add_list_row(ctx, grid, pack, sh, p, dp, LP, FLP)
                                    scroll.scrollTo(0, 0)
                                run_on_ui_thread(_ui)

                            _show_tab(tabs[0][0])
                        except Exception as e:
                            plugin._log(f"_build: {e}\n{traceback.format_exc()}")
                    run_on_ui_thread(_build)
                except Exception as e:
                    plugin._log(f"_load: {e}")
                    run_on_ui_thread(lambda: loading_tv.setText(f"Ошибка: {e}"))
            import threading
            threading.Thread(target=_load, daemon=True).start()

        except Exception as e:
            self._log(f"_show_library_sheet: {e}\n{traceback.format_exc()}")

    def _add_list_row(self, ctx, parent, pack, sh, p, dp, LP, FLP):
        try:
            pid       = pack.get("id", "")
            name      = pack.get("name", pid)
            author    = pack.get("author", "?")
            sprites   = pack.get("sprites", "?")
            scale     = pack.get("scale_recommended", 1.0)
            thumb_url = GITHUB_RAW + pack.get("thumb", "")
            installed = self._is_pack_installed(pid)
            plugin    = self

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(dp(12), dp(10), dp(12), dp(10))
            from android.graphics.drawable import GradientDrawable as _GD
            gd = _GD(); gd.setColor(p["card"]); gd.setCornerRadius(dp(12))
            row.setBackground(gd)
            lp_row = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_row.bottomMargin = dp(8)

            # Превью thumb.png
            iv = ImageView(ctx)
            iv.setScaleType(ImageView.ScaleType.CENTER_CROP)
            gd2 = _GD(); gd2.setColor(p["bg"]); gd2.setCornerRadius(dp(8))
            iv.setBackground(gd2)
            lp_iv = LP(dp(64), dp(64))
            lp_iv.rightMargin = dp(12)
            row.addView(iv, lp_iv)

            def _load_thumb(v=iv, url=thumb_url):
                try:
                    import requests as req
                    r = req.get(url, timeout=10)
                    if r.status_code == 200:
                        data = bytearray(r.content)
                        bm = BitmapFactory.decodeByteArray(data, 0, len(data))
                        if bm:
                            run_on_ui_thread(lambda b=bm, vi=v: (vi.setImageBitmap(b), vi.setBackgroundColor(0)))
                except Exception: pass
            import threading
            threading.Thread(target=_load_thumb, daemon=True).start()

            # Текст
            info = LinearLayout(ctx)
            info.setOrientation(LinearLayout.VERTICAL)

            name_tv = TextView(ctx)
            # Иконка "установлен" — drawable вместо эмодзи
            name_tv.setText(name)
            name_tv.setTextSize(16.0)
            name_tv.setTextColor(p["text"])
            name_tv.setTypeface(name_tv.getTypeface(), 1)
            if installed:
                ic = _drawable("msg_check") or _drawable("checkmark") or _drawable("ic_check")
                if ic:
                    from android.graphics.drawable import Drawable
                    try:
                        d = ctx.getDrawable(ic)
                        if d:
                            d.setColorFilter(p["accent"],
                                android.graphics.PorterDuff.Mode.SRC_IN if hasattr(android.graphics, "PorterDuff") else None)
                            d.setBounds(0, 0, dp(16), dp(16))
                            name_tv.setCompoundDrawables(None, None, d, None)
                            name_tv.setCompoundDrawablePadding(dp(4))
                    except Exception: pass
            info.addView(name_tv, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))

            meta_tv = TextView(ctx)
            meta_tv.setText(f"{author}  •  {sprites} спрайтов  •  x{scale}")
            meta_tv.setTextSize(12.0)
            meta_tv.setTextColor(p["hint"])
            lp_m = LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT)
            lp_m.topMargin = dp(2)
            info.addView(meta_tv, lp_m)
            row.addView(info, LP(0, LP.WRAP_CONTENT, 1.0))

            # Стрелка вперёд — drawable
            arr_iv = ImageView(ctx)
            arr_ic = _drawable("msg_arrow_forward") or _drawable("ic_ab_forward") or _drawable("ic_arrow_right")
            if arr_ic:
                arr_iv.setImageResource(arr_ic)
                arr_iv.setColorFilter(p["hint"])
                arr_iv.setPadding(dp(4), dp(4), dp(4), dp(4))
                row.addView(arr_iv, LP(dp(24), dp(24)))
            else:
                arr_tv = TextView(ctx)
                arr_tv.setText("›")
                arr_tv.setTextSize(24.0)
                arr_tv.setTextColor(p["hint"])
                row.addView(arr_tv, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))

            row.setOnClickListener(_make_click(
                lambda v, pk=pack, nt=name_tv: plugin._open_pack_detail(ctx, pk, sh, p, dp, LP, FLP, nt)
            ))
            parent.addView(row, lp_row)
        except Exception as e:
            self._log(f"_add_list_row: {e}\n{traceback.format_exc()}")

    def _open_pack_detail(self, ctx, pack, parent_sh, p, dp, LP, FLP, name_tv_ref=None):
        try:
            pid       = pack.get("id", "")
            name      = pack.get("name", pid)
            author    = pack.get("author", "?")
            sprites   = pack.get("sprites", "?")
            scale     = pack.get("scale_recommended", 1.0)
            zip_url   = GITHUB_RAW + pack.get("zip", "")
            thumb_url = GITHUB_RAW + pack.get("thumb", "")
            subdir    = pack.get("zip_subdir", "")
            installed = self._is_pack_installed(pid)
            plugin    = self

            sh2 = BottomSheet(ctx, False)
            try: sh2.setFullscreen(False)
            except Exception: pass
            try: sh2.setCanDismissWithSwipe(True)
            except Exception: pass

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setBackgroundColor(p["bg"])
            root.setPadding(dp(16), dp(16), dp(16), dp(32))

            # Имя
            name_tv = TextView(ctx)
            name_tv.setText(name)
            name_tv.setTextSize(22.0)
            name_tv.setTextColor(p["text"])
            name_tv.setTypeface(name_tv.getTypeface(), 1)
            name_tv.setGravity(Gravity.CENTER_HORIZONTAL)
            root.addView(name_tv, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            # Мета — без эмодзи, через строку
            meta_tv = TextView(ctx)
            meta_tv.setText(f"{author}   {sprites} спрайтов   x{scale}")
            meta_tv.setTextSize(13.0)
            meta_tv.setTextColor(p["hint"])
            meta_tv.setGravity(Gravity.CENTER_HORIZONTAL)
            lp_mt = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_mt.topMargin = dp(4)
            lp_mt.bottomMargin = dp(16)
            root.addView(meta_tv, lp_mt)

            # Превью — thumb.png вместо gif
            prev_iv = ImageView(ctx)
            prev_iv.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
            from android.graphics.drawable import GradientDrawable as _GD3
            gd3 = _GD3(); gd3.setColor(p["card"]); gd3.setCornerRadius(dp(16))
            prev_iv.setBackground(gd3)
            lp_img = LP(LP.MATCH_PARENT, dp(280))
            lp_img.bottomMargin = dp(20)
            root.addView(prev_iv, lp_img)

            def _load_preview(v=prev_iv, url=thumb_url):
                try:
                    import requests as req
                    r = req.get(url, timeout=10)
                    if r.status_code == 200:
                        data = bytearray(r.content)
                        bm = BitmapFactory.decodeByteArray(data, 0, len(data))
                        if bm:
                            run_on_ui_thread(lambda b=bm, vi=v: (vi.setImageBitmap(b), vi.setBackgroundColor(0)))
                except Exception: pass
            import threading
            threading.Thread(target=_load_preview, daemon=True).start()

            # Кнопка установить
            btn_install = TextView(ctx)
            btn_install.setText("Переустановить" if installed else "Установить")
            btn_install.setTextSize(16.0)
            btn_install.setTextColor(p["bg"])
            btn_install.setGravity(Gravity.CENTER)
            btn_install.setPadding(dp(16), dp(14), dp(16), dp(14))
            # Иконка скачать
            dl_ic = _drawable("msg_download") or _drawable("attach_file")
            if dl_ic and not installed:
                btn_install.setCompoundDrawablePadding(dp(6))
                try:
                    d = ctx.getDrawable(dl_ic)
                    if d:
                        d.setBounds(0, 0, dp(18), dp(18))
                        btn_install.setCompoundDrawables(d, None, None, None)
                except Exception: pass
            from android.graphics.drawable import GradientDrawable as _GD4
            gd4 = _GD4(); gd4.setColor(p["accent"]); gd4.setCornerRadius(dp(12))
            btn_install.setBackground(gd4)
            lp_btn = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_btn.bottomMargin = dp(10)

            def _on_install(v, z=zip_url, i=pid, s=scale, sd=subdir, n=name):
                btn_install.setText("Скачиваю...")
                btn_install.setEnabled(False)
                def _done(ok):
                    def _ui():
                        btn_install.setText("Установлен" if ok else "Ошибка")
                        btn_install.setEnabled(True)
                        if ok:
                            name_tv.setText(n)
                            if name_tv_ref: name_tv_ref.setText(n)
                            btn_delete.setVisibility(View.VISIBLE)
                    run_on_ui_thread(_ui)
                plugin._install_pack(z, i, s, sd, on_done=_done, name=n)
            btn_install.setOnClickListener(_make_click(_on_install))
            root.addView(btn_install, lp_btn)

            # Кнопка удалить
            btn_delete = TextView(ctx)
            btn_delete.setText("Удалить")
            btn_delete.setTextSize(15.0)
            btn_delete.setTextColor(p["text"])
            btn_delete.setGravity(Gravity.CENTER)
            btn_delete.setPadding(dp(16), dp(12), dp(16), dp(12))
            btn_delete.setVisibility(View.VISIBLE if installed else View.GONE)
            # Иконка удалить
            del_ic = _drawable("msg_delete") or _drawable("ic_delete")
            if del_ic:
                try:
                    d = ctx.getDrawable(del_ic)
                    if d:
                        d.setBounds(0, 0, dp(18), dp(18))
                        btn_delete.setCompoundDrawables(d, None, None, None)
                        btn_delete.setCompoundDrawablePadding(dp(6))
                except Exception: pass
            from android.graphics.drawable import GradientDrawable as _GD5
            gd5 = _GD5(); gd5.setColor(p["card"]); gd5.setCornerRadius(dp(12))
            btn_delete.setBackground(gd5)

            def _on_delete(v, i=pid):
                try:
                    import shutil
                    path = os.path.join(INSTALL_DIR, i)
                    if os.path.isdir(path): shutil.rmtree(path)
                    BulletinHelper.show_success(f"{name} удалён")
                    btn_delete.setVisibility(View.GONE)
                    btn_install.setText("Установить")
                    name_tv.setText(name)
                    if name_tv_ref: name_tv_ref.setText(name)
                    sh2.dismiss()
                except Exception as e:
                    plugin._log(f"delete: {e}")
                    BulletinHelper.show_error(str(e))
            btn_delete.setOnClickListener(_make_click(_on_delete))
            root.addView(btn_delete, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            sh2.setCustomView(root)
            sh2.show()
        except Exception as e:
            self._log(f"_open_pack_detail: {e}\n{traceback.format_exc()}")

    def _add_pack_card(self, ctx, parent, pack, sh, p, dp, LP, FLP):
        self._add_list_row(ctx, parent, pack, sh, p, dp, LP, FLP)


    # ── локальная библиотека ─────────────────────────────────

    def _open_local_library(self, view=None):
        """Открывает локальную библиотеку персонажей."""
        def _do():
            try:
                f   = get_last_fragment()
                ctx = f.getParentActivity() if f else None
                if not ctx:
                    BulletinHelper.show_error("Нет контекста")
                    return
                self._show_local_library_sheet(ctx)
            except Exception as e:
                self._log(f"_open_local_library: {e}")
        run_on_ui_thread(_do)

    def _show_sprite_guide(self, ctx, p, dp, LP, FLP):
        """Окно-инструкция: как называть спрайты в архиве."""
        try:
            sh = BottomSheet(ctx, False)
            try: sh.setFullscreen(True)
            except Exception: pass
            try: sh.setCanDismissWithSwipe(True)
            except Exception: pass

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setBackgroundColor(p["bg"])

            # Header
            bar = LinearLayout(ctx)
            bar.setOrientation(LinearLayout.HORIZONTAL)
            bar.setGravity(Gravity.CENTER_VERTICAL)
            bar.setPadding(dp(16), dp(14), dp(12), dp(14))
            bar.setBackgroundColor(p["bar"])
            title_tv = TextView(ctx)
            title_tv.setText("Как подготовить спрайты")
            title_tv.setTextSize(18.0)
            title_tv.setTextColor(p["title"])
            title_tv.setTypeface(title_tv.getTypeface(), 1)
            bar.addView(title_tv, LP(0, LP.WRAP_CONTENT, 1.0))
            close_iv = ImageView(ctx)
            close_ic = _drawable("msg_close") or _drawable("ic_close")
            if close_ic:
                close_iv.setImageResource(close_ic)
                close_iv.setColorFilter(p["hint"])
            close_iv.setPadding(dp(8), dp(8), dp(12), dp(8))
            close_iv.setOnClickListener(_make_click(lambda v: sh.dismiss()))
            bar.addView(close_iv, LP(dp(44), dp(44)))
            root.addView(bar, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            scroll = ScrollView(ctx)
            body = LinearLayout(ctx)
            body.setOrientation(LinearLayout.VERTICAL)
            body.setPadding(dp(16), dp(16), dp(16), dp(40))

            from android.graphics.drawable import GradientDrawable as _GD

            def _section(title, color=None):
                tv = TextView(ctx)
                tv.setText(title)
                tv.setTextSize(16.0)
                tv.setTextColor(color or p["accent"])
                tv.setTypeface(tv.getTypeface(), 1)
                lp = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
                lp.topMargin = dp(16)
                lp.bottomMargin = dp(8)
                body.addView(tv, lp)

            def _para(text):
                tv = TextView(ctx)
                tv.setText(text)
                tv.setTextSize(14.0)
                tv.setTextColor(p["text"])
                lp = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
                lp.bottomMargin = dp(6)
                body.addView(tv, lp)

            def _chip(name, desc, required=True):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(dp(10), dp(8), dp(10), dp(8))
                gd = _GD()
                gd.setColor(p["card"])
                gd.setCornerRadius(dp(8))
                row.setBackground(gd)
                lp_r = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
                lp_r.bottomMargin = dp(4)

                # Имя файла
                name_tv = TextView(ctx)
                name_tv.setText(name)
                name_tv.setTextSize(13.0)
                name_tv.setTextColor(p["accent"])
                name_tv.setTypeface(name_tv.getTypeface(), 1)
                lp_n = LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT)
                lp_n.rightMargin = dp(8)
                row.addView(name_tv, lp_n)

                # Описание
                desc_tv = TextView(ctx)
                desc_tv.setText(desc)
                desc_tv.setTextSize(12.0)
                desc_tv.setTextColor(p["hint"])
                row.addView(desc_tv, LP(0, LP.WRAP_CONTENT, 1.0))

                # Метка обязательности
                req_tv = TextView(ctx)
                req_tv.setText("обяз." if required else "необяз.")
                req_tv.setTextSize(11.0)
                req_tv.setTextColor(p["accent"] if required else p["hint"])
                row.addView(req_tv, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))

                body.addView(row, lp_r)

            # ── Содержимое ──────────────────────────────────────
            _section("Формат архива")
            _para("ZIP-архив содержащий PNG файлы 128×128 пикселей с прозрачным фоном.")
            _para("Имена файлов: shime1.png, shime2.png, ... (регистр не важен)")
            _para("Файлы могут лежать в корне архива или в одной подпапке.")

            _section("Основные спрайты")
            _chip("shime1.png",  "Стоит — главный спрайт",          True)
            _chip("shime2.png",  "Идёт — шаг 1",                    True)
            _chip("shime3.png",  "Идёт — шаг 2",                    True)
            _chip("shime4.png",  "Падает вниз",                      True)
            _chip("shime11.png", "Сидит на полу",                    True)
            _chip("shime18.png", "Приземление — кадр 1",             True)
            _chip("shime19.png", "Приземление — кадр 2",             True)
            _chip("shime22.png", "Прыжок",                           False)

            _section("Перетаскивание (drag)")
            _chip("shime5.png",  "Тащат — кадр 1",                  False)
            _chip("shime6.png",  "Тащат — кадр 2",                  False)
            _chip("shime7.png",  "Тащат — кадр 3",                  False)
            _chip("shime8-10.png", "Тащат — кадры 4-6",             False)

            _section("Карабкание по стенам")
            _chip("shime12.png", "Стена — кадр 1",                  False)
            _chip("shime13.png", "Стена — кадр 2",                  False)
            _chip("shime14.png", "Стена — кадр 3",                  False)

            _section("Потолок")
            _chip("shime23.png", "Потолок — кадр 1",                False)
            _chip("shime24.png", "Потолок — кадр 2",                False)
            _chip("shime25.png", "Потолок — кадр 3",                False)

            _section("Отдых и другое")
            _chip("shime20.png", "Лежит — кадр 1",                  False)
            _chip("shime21.png", "Лежит — кадр 2",                  False)
            _chip("shime26.png", "Смотрит вверх",                   False)

            _section("Раскадровка")
            # Загружаем изображение-гайд с GitHub
            guide_tv = TextView(ctx)
            guide_tv.setText("Загружаю раскадровку...")
            guide_tv.setTextSize(13.0)
            guide_tv.setTextColor(p["hint"])
            guide_tv.setGravity(Gravity.CENTER)
            body.addView(guide_tv, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            guide_iv = ImageView(ctx)
            guide_iv.setScaleType(ImageView.ScaleType.FIT_CENTER)
            guide_iv.setAdjustViewBounds(True)
            lp_gi = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_gi.topMargin = dp(8)
            body.addView(guide_iv, lp_gi)

            def _load_guide():
                try:
                    import requests as req
                    url = GITHUB_RAW + "sprite_guide.png"
                    r = req.get(url, timeout=15)
                    if r.status_code == 200:
                        data = bytearray(r.content)
                        bm = BitmapFactory.decodeByteArray(data, 0, len(data))
                        if bm:
                            def _ui(b=bm):
                                from android.view import View as _V2
                                guide_tv.setVisibility(_V2.GONE)
                                guide_iv.setImageBitmap(b)
                            run_on_ui_thread(_ui)
                    else:
                        run_on_ui_thread(lambda: guide_tv.setText(
                            f"Раскадровка недоступна (HTTP {r.status_code})"))
                except Exception as e:
                    run_on_ui_thread(lambda: guide_tv.setText(f"Ошибка загрузки: {e}"))
            import threading
            threading.Thread(target=_load_guide, daemon=True).start()

            scroll.addView(body, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
            root.addView(scroll, LP(LP.MATCH_PARENT, LP.MATCH_PARENT))
            sh.setCustomView(root)
            sh.show()
        except Exception as e:
            self._log(f"_show_sprite_guide: {e}\n{traceback.format_exc()}")

    def _show_local_library_sheet(self, ctx):
        try:
            dp  = AndroidUtilities.dp
            LP  = LinearLayout.LayoutParams
            FLP = FrameLayout.LayoutParams
            p   = _palette()
            plugin = self

            sh = BottomSheet(ctx, False)
            try: sh.setFullscreen(True)
            except Exception: pass
            try: sh.setCanDismissWithSwipe(False)
            except Exception: pass
            try: sh.setCanDrag(False)
            except Exception: pass

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setBackgroundColor(p["bg"])

            # Header
            bar = LinearLayout(ctx)
            bar.setOrientation(LinearLayout.HORIZONTAL)
            bar.setGravity(Gravity.CENTER_VERTICAL)
            bar.setPadding(dp(16), dp(14), dp(12), dp(14))
            bar.setBackgroundColor(p["bar"])

            title_tv = TextView(ctx)
            title_tv.setText("Локальная библиотека")
            title_tv.setTextSize(18.0)
            title_tv.setTextColor(p["title"])
            title_tv.setTypeface(title_tv.getTypeface(), 1)
            bar.addView(title_tv, LP(0, LP.WRAP_CONTENT, 1.0))

            # Кнопка info
            info_iv = ImageView(ctx)
            info_ic = _drawable("msg_filled_info") or _drawable("msg_info") or _drawable("info")
            if info_ic:
                info_iv.setImageResource(info_ic)
                info_iv.setColorFilter(p["hint"])
            info_iv.setPadding(dp(10), dp(10), dp(10), dp(10))
            info_iv.setOnClickListener(_make_click(lambda v: plugin._show_sprite_guide(ctx, p, dp, LP, FLP)))

            # Кнопка + добавить с иконкой msg_add
            add_iv = ImageView(ctx)
            add_ic = _drawable("msg_add")
            if add_ic:
                add_iv.setImageResource(add_ic)
                add_iv.setColorFilter(p["accent"])
            add_iv.setPadding(dp(10), dp(10), dp(10), dp(10))
            add_iv.setOnClickListener(_make_click(lambda v: plugin._open_add_local_pack(ctx, sh, root, scroll_ll, p, dp, LP, FLP)))

            # Кнопка закрыть
            close_iv = ImageView(ctx)
            close_ic = _drawable("msg_close") or _drawable("ic_close")
            if close_ic:
                close_iv.setImageResource(close_ic)
                close_iv.setColorFilter(p["hint"])
            else:
                close_iv = TextView(ctx)
                close_iv.setText("✕")
                close_iv.setTextSize(20.0)
                close_iv.setTextColor(p["hint"])
            close_iv.setPadding(dp(8), dp(8), dp(12), dp(8))
            close_iv.setOnClickListener(_make_click(lambda v: sh.dismiss()))

            bar.addView(info_iv, LP(dp(44), dp(44)))
            bar.addView(add_iv, LP(dp(44), dp(44)))
            bar.addView(close_iv, LP(dp(44), dp(44)))
            root.addView(bar, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))

            # Список локальных персонажей
            scroll = ScrollView(ctx)
            scroll_ll = LinearLayout(ctx)
            scroll_ll.setOrientation(LinearLayout.VERTICAL)
            scroll_ll.setPadding(dp(12), dp(12), dp(12), dp(80))
            scroll.addView(scroll_ll, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
            root.addView(scroll, LP(LP.MATCH_PARENT, LP.MATCH_PARENT))

            # Заполняем существующими локальными паками
            plugin._refresh_local_list(ctx, scroll_ll, p, dp, LP, FLP)

            sh.setCustomView(root)
            sh.show()

        except Exception as e:
            self._log(f"_show_local_library_sheet: {e}\n{traceback.format_exc()}")

    def _get_local_packs(self):
        """Возвращает список локально установленных паков из INSTALL_DIR."""
        packs = []
        try:
            if not os.path.isdir(INSTALL_DIR):
                return packs
            for name in sorted(os.listdir(INSTALL_DIR)):
                path = os.path.join(INSTALL_DIR, name)
                if not os.path.isdir(path):
                    continue
                # Считаем спрайты
                sprites = [f for f in os.listdir(path) if f.lower().startswith("shime") and f.lower().endswith(".png")]
                if not sprites:
                    continue
                thumb_path = os.path.join(path, "thumb.png")
                packs.append({
                    "id":         name,
                    "name":       name.replace("_", " ").title(),
                    "path":       path,
                    "sprites":    len(sprites),
                    "thumb_path": thumb_path if os.path.exists(thumb_path) else None,
                })
        except Exception as e:
            self._log(f"_get_local_packs: {e}")
        return packs

    def _refresh_local_list(self, ctx, parent, p, dp, LP, FLP):
        """Очищает и перезаполняет список локальных паков."""
        try:
            # Очищаем
            parent.removeAllViews()
            packs = self._get_local_packs()

            if not packs:
                empty_tv = TextView(ctx)
                empty_tv.setText("Нет локальных персонажей.\nНажми + чтобы добавить")
                empty_tv.setTextColor(p["hint"])
                empty_tv.setTextSize(14.0)
                empty_tv.setGravity(Gravity.CENTER)
                empty_tv.setPadding(dp(20), dp(60), dp(20), dp(20))
                parent.addView(empty_tv, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
                return

            plugin = self
            for pack in packs:
                self._add_local_row(ctx, parent, pack, p, dp, LP, FLP)
        except Exception as e:
            self._log(f"_refresh_local_list: {e}")

    def _add_local_row(self, ctx, parent, pack, p, dp, LP, FLP):
        try:
            plugin = self
            pid   = pack["id"]
            name  = pack["name"]
            path  = pack["path"]
            is_active = self.gs("sprites_dir", "") == path

            from android.graphics.drawable import GradientDrawable as _GD
            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(dp(12), dp(10), dp(12), dp(10))
            gd = _GD(); gd.setColor(p["card"]); gd.setCornerRadius(dp(12))
            row.setBackground(gd)
            lp_row = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_row.bottomMargin = dp(8)

            # Превью
            iv = ImageView(ctx)
            iv.setScaleType(ImageView.ScaleType.CENTER_CROP)
            gd2 = _GD(); gd2.setColor(p["bg"]); gd2.setCornerRadius(dp(8))
            iv.setBackground(gd2)
            lp_iv = LP(dp(64), dp(64))
            lp_iv.rightMargin = dp(12)
            row.addView(iv, lp_iv)

            # Загружаем локальный thumb
            thumb_path = pack.get("thumb_path")
            if thumb_path:
                def _load(v=iv, tp=thumb_path):
                    try:
                        bm = BitmapFactory.decodeFile(tp)
                        if bm:
                            run_on_ui_thread(lambda b=bm, vi=v: (vi.setImageBitmap(b), vi.setBackgroundColor(0)))
                    except Exception: pass
                import threading
                threading.Thread(target=_load, daemon=True).start()
            else:
                # Первый спрайт как превью
                def _load_sprite(v=iv, pp=path):
                    try:
                        for f in sorted(os.listdir(pp)):
                            if f.lower() == "shime1.png":
                                bm = BitmapFactory.decodeFile(os.path.join(pp, f))
                                if bm:
                                    run_on_ui_thread(lambda b=bm, vi=v: (vi.setImageBitmap(b), vi.setBackgroundColor(0)))
                                break
                    except Exception: pass
                import threading
                threading.Thread(target=_load_sprite, daemon=True).start()

            # Текст
            info = LinearLayout(ctx)
            info.setOrientation(LinearLayout.VERTICAL)

            name_tv = TextView(ctx)
            name_tv.setText(name)
            name_tv.setTextSize(15.0)
            name_tv.setTextColor(p["accent"] if is_active else p["text"])
            name_tv.setTypeface(name_tv.getTypeface(), 1 if is_active else 0)
            info.addView(name_tv, LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT))

            meta_tv = TextView(ctx)
            meta_tv.setText(f"{pack['sprites']} спрайтов  •  {'активен' if is_active else path}")
            meta_tv.setTextSize(11.0)
            meta_tv.setTextColor(p["hint"])
            meta_tv.setSingleLine(True)
            lp_m = LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT)
            lp_m.topMargin = dp(2)
            info.addView(meta_tv, lp_m)
            row.addView(info, LP(0, LP.WRAP_CONTENT, 1.0))

            # Кнопка "Выбрать"
            btn = TextView(ctx)
            btn.setText("Выбрать" if not is_active else "Активен")
            btn.setTextSize(12.0)
            btn.setTextColor(p["bg"] if not is_active else p["hint"])
            btn.setPadding(dp(10), dp(6), dp(10), dp(6))
            gd3 = _GD()
            gd3.setColor(p["accent"] if not is_active else p["card"])
            gd3.setCornerRadius(dp(8))
            btn.setBackground(gd3)
            lp_btn = LP(LP.WRAP_CONTENT, LP.WRAP_CONTENT)
            lp_btn.leftMargin = dp(8)

            def _on_select(v, pp=path):
                plugin.ss("sprites_dir", pp)
                plugin._restart_engine()
                BulletinHelper.show_success(f"{name} выбран")
            btn.setOnClickListener(_make_click(_on_select))
            if not is_active:
                row.addView(btn, lp_btn)

            # Кнопка удалить
            del_iv = ImageView(ctx)
            del_ic = _drawable("msg_delete") or _drawable("ic_delete")
            if del_ic:
                del_iv.setImageResource(del_ic)
                del_iv.setColorFilter(p["hint"])
                del_iv.setPadding(dp(6), dp(6), dp(6), dp(6))
                lp_del = LP(dp(36), dp(36))
                lp_del.leftMargin = dp(4)

                def _on_delete(v, pp=path, pn=name, r=row):
                    try:
                        import shutil
                        shutil.rmtree(pp)
                        run_on_ui_thread(lambda: parent.removeView(r))
                        BulletinHelper.show_success(f"{pn} удалён")
                    except Exception as e:
                        BulletinHelper.show_error(str(e))
                del_iv.setOnClickListener(_make_click(_on_delete))
                row.addView(del_iv, lp_del)

            parent.addView(row, lp_row)
        except Exception as e:
            self._log(f"_add_local_row: {e}\n{traceback.format_exc()}")

    def _open_add_local_pack(self, ctx, sh, root, scroll_ll, p, dp, LP, FLP):
        """Открывает меню добавления нового локального персонажа."""
        try:
            plugin = self

            sh2 = BottomSheet(ctx, True)   # needFocus=True для клавиатуры
            try: sh2.setCanDismissWithSwipe(True)
            except Exception: pass

            root2 = LinearLayout(ctx)
            root2.setOrientation(LinearLayout.VERTICAL)
            root2.setBackgroundColor(p["bg"])
            root2.setPadding(dp(16), dp(20), dp(16), dp(40))

            title_tv = TextView(ctx)
            title_tv.setText("Добавить персонажа")
            title_tv.setTextSize(20.0)
            title_tv.setTextColor(p["text"])
            title_tv.setTypeface(title_tv.getTypeface(), 1)
            title_tv.setGravity(Gravity.CENTER_HORIZONTAL)
            lp_t = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_t.bottomMargin = dp(24)
            root2.addView(title_tv, lp_t)

            # Превью выбранного thumb
            from android.graphics.drawable import GradientDrawable as _GD
            prev_iv = ImageView(ctx)
