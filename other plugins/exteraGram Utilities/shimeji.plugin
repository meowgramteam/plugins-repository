            from android.view import View as _View
            lpv_thumb.setVisibility(_View.GONE)
            lp_lpv = LP(LP.MATCH_PARENT, dp(4))
            lp_lpv.topMargin = dp(2)

            btn_zip, lbl_zip = _make_btn("Выбрать архив (ZIP)", "msg_media_doc2")

            # Прогресс-бар архива
            try:
                from org.telegram.ui.Components import LineProgressView as LPV2
                lpv_zip = LPV2(ctx)
                lpv_zip.setProgressColor(p["accent"])
                lpv_zip.setBackColor(p["card"])
            except Exception:
                from android.widget import ProgressBar as PB2
                lpv_zip = PB2(ctx, None, 16842872)
                lpv_zip.setMax(1000)
                lpv_zip.setIndeterminate(False)
            lpv_zip.setVisibility(_View.GONE)
            lp_lpv2 = LP(LP.MATCH_PARENT, dp(4))
            lp_lpv2.topMargin = dp(2)

            # Кнопка "Добавить"
            btn_add = TextView(ctx)
            btn_add.setText("Добавить")
            btn_add.setTextSize(16.0)
            btn_add.setTextColor(p["bg"])
            btn_add.setGravity(Gravity.CENTER)
            btn_add.setPadding(dp(16), dp(14), dp(16), dp(14))
            gd_add = _GD(); gd_add.setColor(p["accent"]); gd_add.setCornerRadius(dp(12))
            btn_add.setBackground(gd_add)
            lp_add = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_add.topMargin = dp(8)

            # Файлпикер через Intent
            def _pick_file(mime_types, on_result):
                try:
                    from android.content import Intent
                    from hook_utils import find_class
                    from java import jclass

                    REQUEST_CODE = 0x5348  # SH — уникальный код

                    intent = Intent(Intent.ACTION_GET_CONTENT)
                    intent.setType("*/*")
                    intent.addCategory(Intent.CATEGORY_OPENABLE)
                    chooser = Intent.createChooser(intent, "Выберите файл")

                    plugin._pending_file_callback = on_result

                    frag = get_last_fragment()
                    act  = frag.getParentActivity() if frag else None
                    if not act:
                        BulletinHelper.show_error("Нет активности")
                        return

                    # Хукаем onActivityResult на activity (PluginSettingsActivity → LaunchActivity)
                    try:
                        int_t      = jclass("java.lang.Integer").TYPE
                        intent_cls = find_class("android.content.Intent")
                        # Ищем метод поднимаясь по иерархии act
                        m = None
                        klass = act.getClass()
                        while klass is not None:
                            try:
                                m = klass.getDeclaredMethod("onActivityResult", int_t, int_t, intent_cls)
                                m.setAccessible(True)
                                plugin._log(f"_pick_file: found onActivityResult on {klass.getSimpleName()}")
                                break
                            except Exception:
                                klass = klass.getSuperclass()
                        if m:
                            plugin._instance_result_hook = plugin.hook_method(
                                m, _FileResultHook(plugin, REQUEST_CODE))
                            plugin._log(f"_pick_file: hooked OK")
                        else:
                            plugin._log("_pick_file: onActivityResult not found on act, trying LaunchActivity")
                            # Fallback — хукаем LaunchActivity напрямую
                            la_cls = find_class("org.telegram.messenger.LaunchActivity")
                            if la_cls:
                                for mm in la_cls.getDeclaredMethods():
                                    if mm.getName() == "onActivityResult":
                                        mm.setAccessible(True)
                                        plugin.hook_method(mm, _FileResultHook(plugin, REQUEST_CODE))
                                        plugin._log("_pick_file: hooked LaunchActivity OK")
                                        break
                    except Exception as he:
                        plugin._log(f"_pick_file hook err: {he}\n{traceback.format_exc()}")

                    # Запускаем через act
                    launched = False
                    for launcher in (act, frag):
                        try:
                            launcher.startActivityForResult(chooser, REQUEST_CODE)
                            launched = True
                            plugin._log(f"_pick_file: launched via {launcher.getClass().getSimpleName()}")
                            break
                        except Exception as le:
                            plugin._log(f"_pick_file launch {launcher.getClass().getSimpleName()}: {le}")
                    if not launched:
                        BulletinHelper.show_error("Не удалось открыть выбор файла")
                except Exception as e:
                    plugin._log(f"_pick_file: {e}\n{traceback.format_exc()}")

            def _show_lpv(lpv, frac):
                """Показывает и обновляет LineProgressView."""
                from android.view import View as _V
                def _ui():
                    lpv.setVisibility(_V.VISIBLE)
                    try: lpv.setProgress(frac, True)
                    except Exception:
                        try: lpv.setProgress(int(frac * 1000))
                        except Exception: pass
                run_on_ui_thread(_ui)

            def _on_thumb_picked(uri_str):
                try:
                    _show_lpv(lpv_thumb, 0.2)
                    run_on_ui_thread(lambda: lbl_thumb.setText("Читаю превью..."))
                    path = plugin._uri_to_path(ctx, uri_str)
                    _show_lpv(lpv_thumb, 0.7)
                    if not path:
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Не удалось прочитать превью"))
                        return
                    state["thumb_path"] = path
                    fname = path.split("/")[-1]
                    bm = BitmapFactory.decodeFile(path)
                    _show_lpv(lpv_thumb, 1.0)
                    def _upd(b=bm, f=fname):
                        lbl_thumb.setText(f"Превью: {f[:30]}")
                        if b:
                            prev_iv.setImageBitmap(b)
                            prev_iv.setBackgroundColor(0)
                    run_on_ui_thread(_upd)
                except Exception as e:
                    plugin._log(f"_on_thumb: {e}")

            def _on_zip_picked(uri_str):
                try:
                    _show_lpv(lpv_zip, 0.2)
                    run_on_ui_thread(lambda: lbl_zip.setText("Читаю архив..."))
                    path = plugin._uri_to_path(ctx, uri_str)
                    _show_lpv(lpv_zip, 1.0)
                    if not path:
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Не удалось прочитать архив"))
                        return
                    state["zip_path"] = path
                    fname = path.split("/")[-1]
                    suggested = fname.replace(".zip","").replace("_pack","").replace("_"," ").strip()
                    def _upd(f=fname, s=suggested):
                        lbl_zip.setText(f"Архив: {f[:30]}")
                        if not str(name_et.getText()).strip() and s:
                            name_et.setText(s)
                            name_et.setSelection(len(s))
                    run_on_ui_thread(_upd)
                except Exception as e:
                    plugin._log(f"_on_zip: {e}")

            btn_thumb.setOnClickListener(_make_click(lambda v: _pick_file(
                ["image/png","image/jpeg","image/webp"], _on_thumb_picked
            )))
            btn_zip.setOnClickListener(_make_click(lambda v: _pick_file(
                ["application/zip","application/x-zip-compressed","*/*"], _on_zip_picked
            )))

            def _on_add(v):
                zip_path   = state.get("zip_path")
                thumb_path = state.get("thumb_path")
                try:
                    raw_name = name_et.getText().toString().strip()
                except Exception:
                    raw_name = str(name_et.getText()).strip()
                if not zip_path:
                    BulletinHelper.show_error("Выбери ZIP архив")
                    return
                if not raw_name:
                    BulletinHelper.show_error("Введи имя персонажа")
                    return
                # Блокируем кнопку
                btn_add.setEnabled(False)
                _set_progress(0.0, "Подготовка...")
                pack_id = raw_name.lower().replace(" ","_")
                plugin._install_local_pack(zip_path, thumb_path, pack_id, raw_name,
                                           sh2, scroll_ll, p, dp, LP, FLP, _set_progress)

            btn_add.setOnClickListener(_make_click(_on_add))

            root2.addView(btn_thumb, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
            root2.addView(lpv_thumb, lp_lpv)
            root2.addView(btn_zip, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
            root2.addView(lpv_zip, lp_lpv2)
            root2.addView(btn_add, lp_add)

            # Прогресс-блок (скрыт до установки)
            from android.view import View
            prog_block = LinearLayout(ctx)
            prog_block.setOrientation(LinearLayout.VERTICAL)
            prog_block.setVisibility(View.GONE)
            lp_pb = LP(LP.MATCH_PARENT, LP.WRAP_CONTENT)
            lp_pb.topMargin = dp(12)

            # LineProgressView как в ai_assistant
            line_prog = [None]
            try:
                from org.telegram.ui.Components import LineProgressView
                lpv = LineProgressView(ctx)
                lpv.setProgressColor(p["accent"])
                lpv.setBackColor(p["card"])
                lp_lpv = LP(LP.MATCH_PARENT, dp(4))
                lp_lpv.bottomMargin = dp(6)
                prog_block.addView(lpv, lp_lpv)
                line_prog[0] = lpv
            except Exception:
                from android.widget import ProgressBar
                pb = ProgressBar(ctx, None, 16842872)
                pb.setMax(1000)
                pb.setIndeterminate(False)
                prog_block.addView(pb, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
                line_prog[0] = pb

            prog_tv = TextView(ctx)
            prog_tv.setTextSize(12.0)
            prog_tv.setGravity(Gravity.CENTER)
            prog_tv.setTextColor(p["hint"])
            prog_block.addView(prog_tv, LP(LP.MATCH_PARENT, LP.WRAP_CONTENT))
            root2.addView(prog_block, lp_pb)

            def _set_progress(frac, text=""):
                def _ui():
                    prog_block.setVisibility(View.VISIBLE)
                    prog_tv.setText(text)
                    lp = line_prog[0]
                    if lp is not None:
                        try: lp.setProgress(frac, True)
                        except Exception:
                            try: lp.setProgress(int(frac * 1000))
                            except Exception: pass
                run_on_ui_thread(_ui)

            sh2.setCustomView(root2)
            sh2.show()

        except Exception as e:
            self._log(f"_open_add_local_pack: {e}\n{traceback.format_exc()}")



    def _uri_to_path(self, ctx, uri_str):
        """Конвертирует URI в локальный файл. Паттерн из ai_assistant."""
        try:
            from android.net import Uri
            uri = Uri.parse(uri_str)
            scheme = str(uri.getScheme() or "")
            self._log(f"_uri_to_path: scheme={scheme} uri={uri_str[:80]}")

            # file:// — прямой путь
            if scheme == "file":
                return str(uri.getPath())

            cr = ctx.getContentResolver()

            # Получаем имя файла через OpenableColumns
            fname = "file"
            try:
                from android.provider import OpenableColumns
                cur = cr.query(uri, None, None, None, None)
                if cur and cur.moveToFirst():
                    col = cur.getColumnIndex(OpenableColumns.DISPLAY_NAME)
                    if col >= 0:
                        fname = str(cur.getString(col))
                    cur.close()
            except Exception as e:
                self._log(f"  fname_err: {e}")

            self._log(f"  fname={fname}")
            ext = fname[fname.rfind("."):].lower() if "." in fname else ""
            is_img = ext in (".png",".jpg",".jpeg",".webp",".bmp")
            suffix = ext if ext else (".png" if is_img else ".zip")

            # Читаем поток побайтово — паттерн из ai_assistant
            inp = cr.openInputStream(uri)
            if inp is None:
                raise RuntimeError("openInputStream=null")

            chunks = []
            try:
                while True:
                    b = inp.read()
                    if b < 0: break
                    chunks.append(b)
            finally:
                try: inp.close()
                except Exception: pass

            raw = bytes(chunks)
            self._log(f"  read {len(raw)} bytes")

            # Сохраняем во временный файл
            import tempfile
            tmp = tempfile.mktemp(suffix=suffix, dir=INSTALL_DIR)
            with open(tmp, "wb") as f_out:
                f_out.write(raw)
            self._log(f"  saved → {tmp}")
            return tmp

        except Exception as e:
            self._log(f"_uri_to_path ERROR: {e}\n{traceback.format_exc()}")
        return None

    def _install_local_pack(self, zip_path, thumb_path, pack_id, display_name, sh2, scroll_ll, p, dp, LP, FLP, on_progress=None):
        """Устанавливает персонажа из локального ZIP файла."""
        if on_progress: on_progress(0.05, "Читаю архив...")
        plugin = self
        ctx_ref = [None]
        try:
            f = get_last_fragment()
            if f: ctx_ref[0] = f.getParentActivity()
        except Exception: pass

        def _worker():
            try:
                import zipfile as zfmod

                install_path = os.path.join(INSTALL_DIR, pack_id)
                os.makedirs(install_path, exist_ok=True)

                # Распаковываем ZIP
                with zfmod.ZipFile(zip_path, "r") as zf:
                    members = zf.infolist()
                    top_dirs = set()
                    for m in members:
                        parts = m.filename.split("/")
                        if len(parts) > 1 and parts[0]:
                            top_dirs.add(parts[0])
                    subdir = list(top_dirs)[0] if len(top_dirs) == 1 else ""
                    total = max(len(members), 1)
                    if on_progress: on_progress(0.1, f"Распаковываю 0/{total}...")
                    for i, member in enumerate(members):
                        parts = member.filename.split("/")
                        if subdir and parts and parts[0] == subdir:
                            parts = parts[1:]
                        if not parts or not parts[0]:
                            continue
                        target = os.path.join(install_path, *parts)
                        if member.is_dir():
                            os.makedirs(target, exist_ok=True)
                        else:
                            os.makedirs(os.path.dirname(target), exist_ok=True)
                            with open(target, "wb") as f_out:
                                f_out.write(zf.read(member.filename))
                        if on_progress and i % 5 == 0:
                            frac = 0.1 + 0.8 * (i / total)
                            on_progress(frac, f"Распаковываю {i+1}/{total}...")

                # Копируем превью если есть
                if thumb_path and os.path.exists(thumb_path):
                    import shutil
                    shutil.copy2(thumb_path, os.path.join(install_path, "thumb.png"))

                if on_progress: on_progress(0.95, "Сохраняю превью...")
                # Активируем
                plugin.ss("sprites_dir", install_path)
                plugin._log(f"Local pack installed: {pack_id} → {install_path}")

                def _done():
                    if on_progress: on_progress(1.0, "Готово!")
                    BulletinHelper.show_success(f"{display_name} добавлен!")
                    sh2.dismiss()
                    # Обновляем список
                    ctx = ctx_ref[0]
                    if ctx:
                        plugin._refresh_local_list(ctx, scroll_ll, p, dp, LP, FLP)
                    plugin._restart_engine()
                run_on_ui_thread(_done)

            except Exception as e:
                plugin._log(f"_install_local_pack: {e}\n{traceback.format_exc()}")
                run_on_ui_thread(lambda: BulletinHelper.show_error(str(e)))

        import threading
        threading.Thread(target=_worker, daemon=True).start()

    def _is_pack_installed(self, pack_id: str) -> bool:
        path = os.path.join(INSTALL_DIR, pack_id)
        return os.path.isdir(path)

    def _install_pack(self, zip_url, pack_id, scale, subdir, on_done=None, name=None):
        display_name = name or pack_id
        BulletinHelper.show_info(f"Скачиваю {display_name}...")
        self._log(f"Installing: {pack_id}")
        plugin = self

        def _worker():
            try:
                import requests, zipfile, io
                resp = requests.get(zip_url, timeout=60)
                if resp.status_code != 200:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(f"HTTP {resp.status_code}"))
                    if on_done: on_done(False)
                    return

                install_path = os.path.join(INSTALL_DIR, pack_id)
                os.makedirs(install_path, exist_ok=True)

                with zipfile.ZipFile(io.BytesIO(resp.content)) as zf:
                    for member in zf.infolist():
                        parts = member.filename.split("/")
                        if subdir and parts and parts[0] == subdir:
                            parts = parts[1:]
                        if not parts or parts[0] == "":
                            continue
                        target = os.path.join(install_path, *parts)
                        if member.is_dir():
                            os.makedirs(target, exist_ok=True)
                        else:
                            os.makedirs(os.path.dirname(target), exist_ok=True)
                            with open(target, "wb") as f:
                                f.write(zf.read(member.filename))

                plugin.ss("sprites_dir", install_path)
                plugin.ss("scale", str(scale))
                plugin._log(f"Installed {pack_id} → {install_path}")

                def _apply():
                    BulletinHelper.show_success(f"{display_name} установлен")
                    plugin._restart_engine()
                    if on_done: on_done(True)
                run_on_ui_thread(_apply)

            except Exception as e:
                plugin._log(f"_install_pack: {e}\n{traceback.format_exc()}")
                run_on_ui_thread(lambda: BulletinHelper.show_error(str(e)))
                if on_done: on_done(False)

        import threading
        threading.Thread(target=_worker, daemon=True).start()

    def _show_character(self, view=None):
        """Показывает персонажа если он был скрыт двойным тапом."""
        try:
            if self._engine and self._engine._alive:
                r = self._engine._renderer
                if r and r._alive:
                    r._hidden = False
                    def _do():
                        try:
                            from android.view import View
                            r._root.setVisibility(View.VISIBLE)
                        except Exception as e:
                            self._log(f"show: {e}")
                    run_on_ui_thread(_do)
                    BulletinHelper.show_success("Персонаж снова здесь!")
        except Exception as e:
            self._log(f"_show_character: {e}")

    def _show_logs(self, view=None):
        def _do():
            try:
                from ui.alert import AlertDialogBuilder
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act:
                    return
                text = "\n".join(self._logs[-100:]) if self._logs else "(пусто)"
                bld = AlertDialogBuilder(act)
                bld.set_title("Логи Shimeji")
                bld.set_message(text)
                bld.set_message_text_view_clickable(True)
                bld.set_positive_button("OK", lambda b, w: b.dismiss())
                bld.set_neutral_button("Очистить", lambda b, w: (self._logs.clear(), b.dismiss()))
                bld.show()
            except Exception as e:
                self._log(f"_show_logs: {e}")
        run_on_ui_thread(_do)
