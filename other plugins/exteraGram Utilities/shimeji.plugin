# Кеш загруженных битмапов {(path, flip): Bitmap}
_BMP_CACHE = {}
# ═══════════════════════════════════════════════════════════

def _weighted_choice(choices):
    """choices: список (значение, вес)"""
    total = sum(w for _, w in choices)
    r = random.uniform(0, total)
    acc = 0
    for val, w in choices:
        acc += w
        if r <= acc:
            return val
    return choices[-1][0]


def _find_sprite(sprites_dir, name):
    """Рекурсивно ищет файл спрайта без учёта регистра."""
    try:
        target = name.lower() + ".png"
        for root, dirs, files in os.walk(sprites_dir):
            for f in files:
                if f.lower() == target:
                    path = os.path.join(root, f)
                    if os.path.isfile(path):
                        return path
    except Exception:
        pass
    return None


def _build_sprite_cache(sprites_dir):
    """Рекурсивно ищет все PNG в папке и подпапках. {lower_name: full_path}"""
    cache = {}
    try:
        for root, dirs, files in os.walk(sprites_dir):
            for f in files:
                if f.lower().endswith(".png"):
                    key = f.lower()[:-4]
                    # Не перезаписываем если уже нашли (приоритет у более глубокого пути)
                    if key not in cache:
                        cache[key] = os.path.join(root, f)
    except Exception:
        pass
    return cache


# ── UI-хелперы ──────────────────────────────────────────────────────────────

def _make_click(fn):
    """Создаёт OnClickListener через dynamic_proxy."""
    try:
        from hook_utils import find_class as fc
        OLC = fc("android.view.View$OnClickListener")
        class _CL(dynamic_proxy(OLC)):
            def __init__(self): super().__init__()
            def onClick(self, v):
                try: fn(v)
                except Exception as e: alog(f"onClick: {e}")
        return _CL()
    except Exception as e:
        alog(f"_make_click: {e}")
        return None


# Словарь активных renderer-ов {id: renderer}
_DRAG_RENDERERS = {}

