# Global state
LAST_TEXT = None
BounceableImageView = CaptionContainerView.BounceableImageView

class Config:
    HIDDEN = 0
    COLLAPSED = 1
    VISIBLE = 2
    SINGLE_SET = [HIDDEN, VISIBLE]
    SET = [HIDDEN, COLLAPSED, VISIBLE]
    
    TOOLBAR_HEIGHT_DP = 48
    BUTTON_SIZE_DP = 48
    CORNER_RADIUS_DP = 24
    
    SCROLL_THRESHOLD = 50
    LEFT_MULTIPLIER = 2
    SCROLL_DELTA_THRESHOLD = 20
    HIDE_DELAY_MS = 1000
    
    DEFAULT_MAX_LINES = 5
    EXPANDED_MAX_LINES = 50
    EXPANDED_MIN_LINES = 5
    MIN_EDIT_TEXT_HEIGHT_DP = 100
    MAX_EDIT_TEXT_HEIGHT_DP = 1200
    AUTO_COLLAPSE_TEXT_LENGTH = 200
    
    MIN_TIME_BETWEEN_UPDATES = 0.05
    KEYBOARD_VISIBILITY_THRESHOLD = 150
    KEYBOARD_HEIGHT_CHANGE_THRESHOLD = 100
    
    KEYBOARD_ANIMATION_DELAY_MS = 350

class Cache:
    dp = lru_cache(128)(AndroidUtilities.dp)
    
    @staticmethod
    @lru_cache(64)
    def icon(name: str) -> int:
        try:
            ctx = get_last_fragment().getContext()
            res = ctx.getResources()
            return res.getIdentifier(name, "drawable", ctx.getPackageName())
        except Exception:
            return 0
    
    @staticmethod
    @lru_cache(64)
    def color(name: str) -> int:
        color_id = Cache._color_id(name)
        return Theme.getColor(color_id) if color_id else 0xFF000000
    
    @staticmethod
    @lru_cache(32)
    def _color_id(name: str) -> int:
        try:
            from org.telegram.ui.ActionBar import ThemeColors
            method = ThemeColors.getClass().getDeclaredMethod("createColorKeysStringMap")
            method.setAccessible(True)
            colors_map = method.invoke(None)
            value = colors_map.get(name)
            return int(value) if value is not None else 0
        except Exception:
            return 0
    
    @classmethod
    def clear_all(cls):
        cls.dp.cache_clear()
        cls.icon.cache_clear()
        cls.color.cache_clear()
        cls._color_id.cache_clear()

def create_runnable(callback):
    class R(dynamic_proxy(jclass("java.lang.Runnable"))):
        def __init__(self):
            super().__init__()
            self.callback = callback
        def run(self):
            if self.callback:
                self.callback()
    return R()

def create_click_listener(callback):
    class ClickListener(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
        def __init__(self, callback_func):
            super().__init__()
            self.callback_func = callback_func
        def onClick(self, view):
            if self.callback_func:
                self.callback_func(view)
    return ClickListener(callback)

def create_scroll_listener(callback):
    class ScrollListener(dynamic_proxy(jclass("android.view.View$OnScrollChangeListener"))):
        def __init__(self, callback_func):
            super().__init__()
            self.callback_func = callback_func
        def onScrollChange(self, v, scrollX, scrollY, oldScrollX, oldScrollY):
            if self.callback_func:
                self.callback_func(v, scrollX, scrollY, oldScrollX, oldScrollY)
    return ScrollListener(callback)

def create_layout_listener(callback):
    class LayoutListener(dynamic_proxy(jclass("android.view.ViewTreeObserver$OnGlobalLayoutListener"))):
        def __init__(self, callback_func):
            super().__init__()
            self.callback_func = callback_func
        def onGlobalLayout(self):
            if self.callback_func:
                self.callback_func()
    return LayoutListener(callback)

class RecyclerScrollListener(dynamic_proxy(jclass("android.view.View$OnScrollChangeListener"))):
    def __init__(self, manager):
        super().__init__()
        self.manager = manager
    
    def onScrollChange(self, v, scrollX, scrollY, oldScrollX, oldScrollY):
        dy = scrollY - oldScrollY
        if abs(dy) > Config.SCROLL_DELTA_THRESHOLD:
            self.manager._toggle_enter_view(False)
            if self.manager.scroll_handler:
                self.manager.scroll_handler.removeCallbacksAndMessages(None)
                self.manager.scroll_handler.postDelayed(
                    create_runnable(lambda: self.manager._toggle_enter_view(True)),
                    Config.HIDE_DELAY_MS
                )

@dataclass(frozen=True)
class LayoutState:
    keyboard_visible: bool
    should_expand: bool
    screen_height: int
    
    def __eq__(self, other):
        if not isinstance(other, LayoutState):
            return False
        return (
            self.keyboard_visible == other.keyboard_visible and
            self.should_expand == other.should_expand and
            abs(self.screen_height - other.screen_height) < Config.KEYBOARD_HEIGHT_CHANGE_THRESHOLD
        )

class LayoutController:
    def __init__(self, manager):
        self.manager = manager
        self._current_state: Optional[LayoutState] = None
        self._destroyed = False
        self._last_update_time = 0.0
        self._layout_listener = None
    
    def install(self, enter_view):
        if self._destroyed or not enter_view:
            return False
        root_view = enter_view.getRootView()
        if not root_view:
            return False
        observer = root_view.getViewTreeObserver()
        if observer and observer.isAlive():
            self._layout_listener = create_layout_listener(self._on_global_layout)
            observer.addOnGlobalLayoutListener(self._layout_listener)
            return True
        return False
    
    def _on_global_layout(self):
        if (self._destroyed or not self.manager or not self.manager.enter_view or
            not self.manager.enter_view.isAttachedToWindow()):
            return
        self._process_update()
    
    def trigger_update(self):
        if self._destroyed:
            return
        current_time = time.time()
        if current_time - self._last_update_time >= Config.MIN_TIME_BETWEEN_UPDATES:
            self._last_update_time = current_time
            self._process_update()
    
    def _process_update(self):
        state = self._get_current_state()
        if state and state != self._current_state:
            self._current_state = state
            self.manager._keyboard_visible = state.keyboard_visible
            self._apply_layout(state)
    
    def _get_current_state(self) -> Optional[LayoutState]:
        try:
            root_view = self.manager.enter_view.getRootView()
            if not root_view:
                return None
            rect = Rect()
            root_view.getWindowVisibleDisplayFrame(rect)
            screen_height = root_view.getHeight()
            keyboard_height = screen_height - rect.bottom
            keyboard_visible = keyboard_height > Config.KEYBOARD_VISIBILITY_THRESHOLD
            should_expand = self.manager._should_expand_input()
            return LayoutState(keyboard_visible, should_expand, screen_height)
        except Exception:
            return None
    
    def _apply_layout(self, state: LayoutState):
        if not self.manager.edit_text:
            return
        try:
            available_height = self.manager._calculate_available_height(state.keyboard_visible)
            
            if state.should_expand != self.manager.input_expanded:
                self._update_expansion(state.should_expand, available_height)
            
            if state.should_expand:
                et_params = self.manager.edit_text.getLayoutParams()
                if et_params and isinstance(et_params, ViewGroup.LayoutParams):
                    if et_params.height != available_height:
                        et_params.height = available_height
                        self.manager.edit_text.setLayoutParams(et_params)
            else:
                et_params = self.manager.edit_text.getLayoutParams()
                if et_params and isinstance(et_params, ViewGroup.LayoutParams):
                    if et_params.height != ViewGroup.LayoutParams.WRAP_CONTENT:
                        et_params.height = ViewGroup.LayoutParams.WRAP_CONTENT
                        self.manager.edit_text.setLayoutParams(et_params)
            
            current_max = self.manager.edit_text.getMaxHeight()
            if current_max != available_height:
                self.manager.edit_text.setMaxHeight(available_height)
            
            self.manager.edit_text.requestLayout()
            self.manager.edit_text.invalidate()
            self.manager.enter_view.requestLayout()
            self.manager.enter_view.invalidate()
        except Exception:
            pass
    
    def _update_expansion(self, should_expand: bool, available_height: int):
        self.manager.input_expanded = should_expand
        if should_expand:
            self.manager.edit_text.setMaxLines(Config.EXPANDED_MAX_LINES)
            self.manager.edit_text.setMinLines(Config.EXPANDED_MIN_LINES)
        else:
            self.manager.edit_text.setMaxLines(self.manager.original_max_lines)
            self.manager.edit_text.setMinLines(1)
    
    def destroy(self):
        self._destroyed = True
        self._current_state = None
        self._layout_listener = None
        self.manager = None

class TextWatcherProxy(dynamic_proxy(jclass("android.text.TextWatcher"))):
    def __init__(self, manager):
        super().__init__()
        self.manager = manager
        self._update_pending = False
    
    def beforeTextChanged(self, s, start, count, after):
        pass
    
    def onTextChanged(self, s, start, before, count):
        pass
    
    def afterTextChanged(self, editable):
        if not self.manager or not self.manager.edit_text:
            return
        text_length = len(editable.toString()) if editable else 0
        if self.manager.char_counter and self.manager._get_setting("show_char_counter", False):
            self.manager.char_counter.setText(str(text_length))
        if not self._update_pending:
            self._update_pending = True
            self.manager.edit_text.post(create_runnable(self._update_line_count))
    
    def _update_line_count(self):
        self._update_pending = False
        if not self.manager or not self.manager.edit_text:
            return
        try:
            should_expand = self.manager._should_expand_input()
            if should_expand != self.manager.input_expanded:
                if self.manager._layout_controller:
                    self.manager._layout_controller.trigger_update()
        except Exception:
            pass

class CommandHandler:
    def __init__(self, manager):
        self.m = manager
        et = manager.edit_text
        fmt_methods = [
            "makeSelectedRegular", "makeSelectedBold", "makeSelectedItalic",
            "makeSelectedMono", "makeSelectedStrike", "makeSelectedUnderline",
            "makeSelectedUrl"
        ]
        self.cmd = {
            0: lambda: et.append("@"),
            40: self._repeat,
            50: self._toggle_kbd,
            **{i+11: lambda m=m: getattr(et, m)() for i, m in enumerate(fmt_methods)},
            18: lambda: et.makeSelectedQuote(True),
            19: lambda: et.makeSelectedSpoiler(),
            21: et.selectAll,
            22: lambda: et.setSelection(0),
            23: lambda: et.setSelection(et.getText().length()),
            24: lambda: self._clip('copy'),
            25: lambda: self._clip('cut'),
            26: lambda: self._clip('paste'),
            27: lambda: et.onTextContextMenuItem(R.id.undo),
            28: lambda: et.onTextContextMenuItem(R.id.redo),
        }
    
    def dispatch(self, cmd_id):
        if cmd_id in self.cmd:
            self.cmd[cmd_id]()
    
    def _clip(self, action: str):
        et = self.m.edit_text
        start = et.getSelectionStart()
        end = et.getSelectionEnd()
        if action in ('copy', 'cut'):
            if start == end:
                return
            text = et.getText().subSequence(start, end).toString()
            AndroidUtilities.addToClipboard(text)
            if action == 'cut':
                et.getText().delete(start, end)
        elif action == 'paste':
            ctx = self.m.enter_view.getContext()
            clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if clipboard and clipboard.hasPrimaryClip():
                clip = clipboard.getPrimaryClip()
                if clip and clip.getItemCount() > 0:
                    pasted = clip.getItemAt(0).coerceToText(ctx)
                    if pasted:
                        et.getText().replace(start, end, pasted)
                        et.setSelection(start + len(pasted))
    
    def _repeat(self):
        global LAST_TEXT
        if LAST_TEXT:
            self.m.edit_text.setText(LAST_TEXT)
            self.m.edit_text.setSelection(len(LAST_TEXT))
    
    def _toggle_kbd(self):
        ctx = self.m.enter_view.getContext()
        imm = ctx.getSystemService(Context.INPUT_METHOD_SERVICE)
        if self.m._keyboard_visible:
            imm.hideSoftInputFromWindow(self.m.edit_text.getWindowToken(), 0)
        else:
            self.m.edit_text.requestFocus()
            imm.showSoftInput(self.m.edit_text, InputMethodManager.SHOW_IMPLICIT)
        
        Handler(Looper.getMainLooper()).postDelayed(
            create_runnable(lambda: self._force_layout_update()),
            Config.KEYBOARD_ANIMATION_DELAY_MS
        )
    
    def _force_layout_update(self):
        if self.m._layout_controller:
            self.m._layout_controller._current_state = None
            self.m._layout_controller.trigger_update()

