from java import jint, dynamic_proxy
from org.telegram.messenger import AndroidUtilities
from org.telegram.ui.ActionBar import Theme, BottomSheet
from org.telegram.ui.Components import NumberPicker, LayoutHelper
from android.view import View, Gravity
from android.widget import LinearLayout, TextView, ScrollView
from android.util import TypedValue
import datetime

__id__ = "dchat_cleaner"
__name__ = "Chat Cleaner"
