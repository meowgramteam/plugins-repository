__id__ = "folders_below"
__name__ = "Folders Below"
__description__ = "Moves folders bar to the bottom of the chat list"
__author__ = "@PESSDES_Plugins"
__min_version__ = "12.5.1"
__icon__ = "VoiceToText7/15"
__version__ = "2.1" 

import base64

from base_plugin import BasePlugin
from dalvik.system import InMemoryDexClassLoader
from java import dynamic_proxy
from java.nio import ByteBuffer

from org.telegram.messenger import ApplicationLoader, Utilities

DEX_CLASS_NAME = "com.pessdes.bottomfolders.Main"

def log(*msg):
    from android_utils import log as logcat
    if len(msg) == 0:
        return
    m = msg if len(msg) > 1 else msg[0]
    if isinstance(m, Exception) and m.__traceback__ is not None:
        m = f"{m.__traceback__.tb_lineno}: {m}"
    logcat(f'[{__id__}] {m}')

dex_bridge = None

class Plugin(BasePlugin):
    def on_plugin_load(self) -> None:
        log("dex loading...")
        global dex_bridge
        if dex_bridge:
            dex_bridge.getDeclaredMethod("unhook").invoke(None)
        dex_bridge = self.load_dex()
        
        dex_bridge.getDeclaredMethod("main", Utilities.Callback.getClass()).invoke(None, DexLogger())
    
    def on_plugin_unload(self):
        if not dex_bridge: return
        dex_bridge.getDeclaredMethod("unhook").invoke(None)
    
    def load_dex(self):
        bytes = base64.b64decode(dex_string)
        app_class_loader = ApplicationLoader.applicationContext.getClassLoader()
        global dex_loader
        dex_loader = InMemoryDexClassLoader(ByteBuffer.wrap(bytes), app_class_loader)
        return dex_loader.loadClass(DEX_CLASS_NAME)
    
class DexLogger(dynamic_proxy(Utilities.Callback)):
    def run(self, objs):
        log('[DEX]', *objs)

# Source code available at https://github.com/Hazzz895/ExteraPluginsAssets/blob/main/bottomfolders/dex/src/main/java/com/pessdes/bottomfolders/Main.java
dex_string = ""
