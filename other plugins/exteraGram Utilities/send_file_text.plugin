__id__ = "send_file_text"
__name__ = "FileText"
__description__ = """Добавляет в контекстное меню отправки сообщения (удержи кнопку отправки) пункт **«Отправить файлом»** — введённый текст будет отправлен как файл.

Adds a **“Send as file”** option to the message send context menu (hold the send button). The entered text will be sent as a file."""
__author__ = "@RnPlugins"
__version__ = "1.0.2"
__icon__ = "RnDev/13"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader, LocaleController
from hook_utils import find_class
from ui.settings import Input, Header, Divider

DEX_B64 = """"""

def get_localized_strings():
    lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
    
    strings = {
        "ru": {
            "header": "Настройки отправки файлом",
            "file_extension": "Расширение файла",
            "file_extension_sub": "По умолчанию: txt",
            "file_name_format": "Формат названия файла",
            "file_name_format_sub": "Переменные: {date} {time} {chars} {lines} {year} {month} {day} {hour} {minute} {second} {dialog_name}",
            "file_signature": "Подпись к файлу",
            "file_signature_sub": "Переменные: {date} {time} {chars} {lines} {dialog_name}. Оставьте пустым чтобы отключить.",
            "help_title": "Переменные:",
            "help_lines": "{date} - дата (20241225)\n{time} - время (143052)\n{year} - год (2024)\n{month} - месяц (12)\n{day} - день (25)\n{hour} - час (14)\n{minute} - минута (30)\n{second} - секунда (52)\n{chars} - количество символов\n{lines} - количество строк\n{dialog_name} - имя диалога"
        },
        "en": {
            "header": "Send-as-file settings",
            "file_extension": "File extension",
            "file_extension_sub": "Default: txt",
            "file_name_format": "File name pattern",
            "file_name_format_sub": "Variables: {date} {time} {chars} {lines} {year} {month} {day} {hour} {minute} {second} {dialog_name}",
            "file_signature": "File signature",
            "file_signature_sub": "Variables: {date} {time} {chars} {lines} {dialog_name}. Leave empty to disable.",
            "help_title": "Variables:",
            "help_lines": "{date} - date (20241225)\n{time} - time (143052)\n{year} - year (2024)\n{month} - month (12)\n{day} - day (25)\n{hour} - hour (14)\n{minute} - minute (30)\n{second} - second (52)\n{chars} - characters count\n{lines} - lines count\n{dialog_name} - dialog name"
        }
    }
    return strings.get(lang, strings["en"])

class SendFileTextPlugin(BasePlugin):
    def on_plugin_load(self):
        try:
            self.log("Loading Java SendFileText module...")
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.sendfiletext.SendFileText")
            
            start_method = self.dex_class.getMethod("start")
            start_method.invoke(None)
            
            self.log("Java SendFileText module loaded and started successfully.")
        except Exception as e:
            self.log(f"Failed to load Java SendFileText module: {e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading Java SendFileText module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(None)
                self.log("Java SendFileText module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
        except Exception as e:
            self.log(f"Failed to unload Java SendFileText module: {e}")

    def create_settings(self):
        s = get_localized_strings()
        return [
            Header(s["header"]),
            Input(
                key="file_extension",
                text=s["file_extension"],
                default="txt",
                subtext=s["file_extension_sub"],
                icon="msg_sendfile"
            ),
            Input(
                key="file_name_format",
                text=s["file_name_format"],
                default="message-{date}-{time}-{chars}-{lines}",
                subtext=s["file_name_format_sub"],
                icon="group_edit_profile"
            ),
            Input(
                key="file_signature",
                text=s["file_signature"],
                default="",
                subtext=s["file_signature_sub"],
                icon="profile_discuss"
            ),
            Divider(),
            Header(s["help_title"]),
            Divider(s["help_lines"]),
        ]
