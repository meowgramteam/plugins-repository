        self.ui_elements['opt_cb_container'] = FrameLayout(self.context)
        self.ui_elements['opt_cb_container'].addView(self.ui_elements['opt_cb'], LayoutHelper.createFrame(-2, -2, 17))
        self.ui_elements['row_opt'].addView(self.ui_elements['opt_cb_container'])

        self.ui_elements['container'].addView(self.ui_elements['row_req'])
        self.ui_elements['container'].addView(self.ui_elements['row_opt'])
        
        anim_wrapper.addView(self.ui_elements['container'], LayoutHelper.createLinear(-1, -2))
        list_root.addView(anim_wrapper, LayoutHelper.createLinear(-1, -2))
        
        self.preview_container.addView(list_root, LayoutHelper.createFrame(-1, -2, 17))
        
        self.overlay_delegate = HighlightOverlayDelegate()
        self.overlay_view = UniversalView(self.context, self.overlay_delegate)
        self.overlay_delegate.view = self.overlay_view
        self.preview_container.addView(self.overlay_view, LayoutHelper.createFrame(-1, -1))
        
        self.root_view.addView(self.preview_container, LayoutHelper.createLinear(-1, -2))

        self._setup_click(self.ui_elements['container'], 'container', is_container=True)
        self._setup_click(self.ui_elements['icon_req'], 'icon')
        self._setup_click(self.ui_elements['icon_opt'], 'icon')
        self._setup_click(self.ui_elements['tl1'], 'req_text')
        self._setup_click(self.ui_elements['tl2'], 'opt_text')
        self._setup_click(self.ui_elements['req_cb_container'], 'req_checkbox')
        self._setup_click(self.ui_elements['opt_cb_container'], 'opt_checkbox')

        anim_state = {"full_height": 0, "current_anim": None, "progress": 0.0, "is_expanded": False}

        class BadgeClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, w, content, arrow, state, c):
                super().__init__()
                self.w = w; self.c = content; self.a = arrow; self.s = state; self.ctrl = c
            def onClick(self, v):
                self.ctrl._clear_selection()
                target_expanded = not self.s["is_expanded"]
                self.s["is_expanded"] = target_expanded
                if self.s["current_anim"]: self.s["current_anim"].cancel()
                if self.s["full_height"] == 0:
                    self.w.setVisibility(0)
                    parent_w = list_root.getWidth()
                    if parent_w == 0: parent_w = AndroidUtilities.displaySize.x
                    self.w.measure(jclass("android.view.View$MeasureSpec").makeMeasureSpec(parent_w, 1073741824), jclass("android.view.View$MeasureSpec").makeMeasureSpec(0, 0))
                    self.s["full_height"] = self.w.getMeasuredHeight()
                    lp = self.c.getLayoutParams()
                    lp.height = self.c.getMeasuredHeight()
                    self.c.setLayoutParams(lp)
                start_val = self.s["progress"]
                end_val = 1.0 if target_expanded else 0.0
                if start_val == end_val: return
                anim = jclass("android.animation.ValueAnimator").ofFloat(jarray(jfloat)([start_val, end_val]))
                distance = abs(end_val - start_val)
                anim.setDuration(int(350 * (0.4 + 0.6 * distance)))
                anim.setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT)
                anim.addUpdateListener(ExpandAnimUpdate(self.w, self.c, self.a, self.s["full_height"], self.s))
                anim.addListener(ExpandAnimListener(self.w))
                self.s["current_anim"] = anim
                anim.start()

        badge.setOnClickListener(BadgeClick(anim_wrapper, self.ui_elements['container'], arrow, anim_state, self))

        divider = View(self.context)
        divider.setBackgroundColor(jint(Theme.getColor(Theme.key_divider)))
        self.root_view.addView(divider, LayoutHelper.createLinear(-1, 1))

        self.settings_scroll = ScrollView(self.context)
        self.settings_scroll.setFillViewport(True)
        self.settings_scroll.setClipToPadding(False)
        
        self.settings_container = LinearLayout(self.context)
        self.settings_container.setOrientation(LinearLayout.VERTICAL)
        self.settings_container.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(16))
        
        self.settings_scroll.addView(self.settings_container, LayoutHelper.createScroll(-1, -2, 0))
        self.root_view.addView(self.settings_scroll, LayoutHelper.createLinear(-1, -1, 1.0))
        self._clear_selection() 

    def _setup_click(self, view, type_str, is_container=False):
        class ClickProxy(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, controller, v, t, is_cont):
                super().__init__(); self.c = controller; self.v = v; self.t = t; self.is_cont = is_cont
            def onClick(self, view_ignored):
                rad = self.c.plugin.get_setting("ds_cont_radius", 16) if self.is_cont else 6
                self.c.overlay_delegate.setTarget(self.v, self.c.mock_list, rad)
                self.c._open_settings_for(self.t)
        view.setOnClickListener(ClickProxy(self, view, type_str, is_container))

    def _update_preview_from_settings(self, animate=True):
        try:
            if animate:
                TransitionManager = jclass("android.transition.TransitionManager")
                AutoTransition = jclass("android.transition.AutoTransition")
                t = AutoTransition()
                t.setDuration(250)
                t.setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT)
                TransitionManager.beginDelayedTransition(self.ui_elements['container'], t)

            has_cont = self.plugin.get_setting("ds_cont_enabled", True)
            if has_cont:
                color = jint(self.plugin.get_setting("ds_cont_color", Theme.getColor(Theme.key_windowBackgroundGray)))
                rad = self.plugin.get_setting("ds_cont_radius", 16)
                bg = Theme.createRoundRectDrawable(AndroidUtilities.dp(rad), AndroidUtilities.dp(rad), color)
                self.ui_elements['container'].setBackground(bg)
                self.ui_elements['container'].setPadding(0, AndroidUtilities.dp(6), 0, AndroidUtilities.dp(6))
            else:
                self.ui_elements['container'].setBackground(None)
                self.ui_elements['container'].setPadding(0, 0, 0, 0)
                
            if self.current_target == 'container':
                rad = self.plugin.get_setting("ds_cont_radius", 16) if has_cont else 0
                self.overlay_delegate.setTarget(self.ui_elements['container'], self.mock_list, rad)
            
            icon_res = self.plugin.get_setting("ds_icon_res", "msg_bot")
            R_draw = jclass("org.telegram.messenger.R").drawable
            res_id = getattr(R_draw, icon_res, getattr(R_draw, "msg_bot"))
            self.ui_elements['icon_req'].setImageResource(res_id)
            self.ui_elements['icon_opt'].setImageResource(res_id)

            self.ui_elements['req_title'].setTextColor(jint(self.plugin.get_setting("ds_req_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))))
            self.ui_elements['req_sub'].setText(self.plugin.get_setting("ds_req_sub_text", "Обязательно"))
            self.ui_elements['req_sub'].setTextColor(jint(self.plugin.get_setting("ds_req_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))))
            
            self.ui_elements['opt_title'].setTextColor(jint(self.plugin.get_setting("ds_opt_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))))
            self.ui_elements['opt_sub'].setText(self.plugin.get_setting("ds_opt_sub_text", "Опционально"))
            self.ui_elements['opt_sub'].setTextColor(jint(self.plugin.get_setting("ds_opt_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))))

            req_g = self.plugin.get_setting("ds_req_gravity", 3)
            self.ui_elements['req_title'].setGravity(req_g)
            self.ui_elements['req_sub'].setGravity(req_g)
            self.ui_elements['tl1'].setGravity(req_g)
            
            opt_g = self.plugin.get_setting("ds_opt_gravity", 3)
            self.ui_elements['opt_title'].setGravity(opt_g)
            self.ui_elements['opt_sub'].setGravity(opt_g)
            self.ui_elements['tl2'].setGravity(opt_g)
            
            self.ui_elements['req_cb'].setColor(Theme.key_featuredStickers_addButton, Theme.key_windowBackgroundWhite, Theme.key_featuredStickers_buttonText)
            req_cb_scale = float(self.plugin.get_setting("ds_req_cb_scale", 1.0))
            req_cb_frame = int(self.plugin.get_setting("ds_req_cb_frame", 26))
            self.ui_elements['req_cb'].setScaleX(req_cb_scale)
            self.ui_elements['req_cb'].setScaleY(req_cb_scale)
            self.ui_elements['req_cb_container'].setLayoutParams(LayoutHelper.createLinear(req_cb_frame, req_cb_frame, 16))
            
            self.ui_elements['opt_cb'].setColor(Theme.key_featuredStickers_addButton, Theme.key_windowBackgroundWhite, Theme.key_featuredStickers_buttonText)
            opt_cb_scale = float(self.plugin.get_setting("ds_opt_cb_scale", 1.0))
            opt_cb_frame = int(self.plugin.get_setting("ds_opt_cb_frame", 26))
            self.ui_elements['opt_cb'].setScaleX(opt_cb_scale)
            self.ui_elements['opt_cb'].setScaleY(opt_cb_scale)
            self.ui_elements['opt_cb_container'].setLayoutParams(LayoutHelper.createLinear(opt_cb_frame, opt_cb_frame, 16))

            if self.current_target == 'req_checkbox':
                self.overlay_delegate.setTarget(self.ui_elements['req_cb_container'], self.mock_list, 6)
            elif self.current_target == 'opt_checkbox':
                self.overlay_delegate.setTarget(self.ui_elements['opt_cb_container'], self.mock_list, 6)

        except Exception as e:
            self.plugin.log(f"UPDATE PREVIEW ERROR: {e}")

    def _open_settings_for(self, type_str):
        if self.current_target == type_str: return
        self.current_target = type_str
        self.settings_container.animate().alpha(0.0).translationY(float(AndroidUtilities.dp(20))).setDuration(150).withEndAction(ActionRunnable(self._build_settings_panel)).start()

    def _build_settings_panel(self):
        try:
            self.settings_container.removeAllViews()
            
            if self.current_target == 'container':
                self._add_title("Настройки контейнера")
                self._add_toggle_btn("ds_cont_enabled", True)
                self._add_color_picker("Цвет контейнера", "ds_cont_color", Theme.getColor(Theme.key_windowBackgroundGray))
                self._add_slider("Скругление (dp)", "ds_cont_radius", 0, 32, 16)
                
            elif self.current_target == 'icon':
                self._add_title("Иконка зависимости")
                self._add_icon_selector_btn()
                
            elif self.current_target == 'req_text':
                self._add_title("Обязательный модуль")
                self._add_color_picker("Цвет заголовка", "ds_req_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                self._add_input("Текст подписи", "ds_req_sub_text", "Обязательно")
                self._add_color_picker("Цвет подписи", "ds_req_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
                self._add_alignment_control("Выравнивание текста", "ds_req_gravity", 3)
                
            elif self.current_target == 'opt_text':
                self._add_title("Опциональный модуль")
                self._add_color_picker("Цвет заголовка", "ds_opt_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                self._add_input("Текст подписи", "ds_opt_sub_text", "Опционально")
                self._add_color_picker("Цвет подписи", "ds_opt_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
                self._add_alignment_control("Выравнивание текста", "ds_opt_gravity", 3)
                
            elif self.current_target == 'req_checkbox':
                self._add_title("Чекбокс (Обязательный)")
                self._add_slider_float("Масштаб галочки (0.5x - 1.5x)", "ds_req_cb_scale", 0.5, 1.5, 1.0)
                self._add_slider("Размер рамки (dp)", "ds_req_cb_frame", 16, 50, 26)

            elif self.current_target == 'opt_checkbox':
                self._add_title("Чекбокс (Опциональный)")
                self._add_slider_float("Масштаб галочки (0.5x - 1.5x)", "ds_opt_cb_scale", 0.5, 1.5, 1.0)
                self._add_slider("Размер рамки (dp)", "ds_opt_cb_frame", 16, 50, 26)
            
            elif self.current_target is None:
                tv = jclass("android.widget.TextView")(self.context)
                tv.setText("Нажмите на любой элемент выше для его настройки")
                tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                tv.setGravity(17)
                self.settings_container.addView(tv, LayoutHelper.createLinear(-1, -2, 0, 16, 40, 16, 0))

            self.settings_container.setTranslationY(float(AndroidUtilities.dp(20)))
            self.settings_container.animate().alpha(1.0).translationY(0.0).setDuration(200).setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT).start()
        except Exception as e:
            self.plugin.log(f"BUILD SETTINGS ERROR: {e}")

    def _add_title(self, text):
        tv = jclass("android.widget.TextView")(self.context)
        tv.setText(text)
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader)))
        tv.setTextSize(1, 14.0)
        tv.setTypeface(AndroidUtilities.bold())
        self.settings_container.addView(tv, LayoutHelper.createLinear(-1, -2, 23, 16, 0, 16))

    def _add_toggle_btn(self, key, default):
        btn = jclass("android.widget.TextView")(self.context)
        btn.setGravity(17)
        btn.setTypeface(AndroidUtilities.bold())
        btn.setTextSize(1, 14.0)
        btn.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
        
        def apply_state(v, is_on):
            if is_on:
                v.setText("КОНТЕЙНЕР ВКЛЮЧЕН")
                v.setTextColor(jint(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                v.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), jint(Theme.getColor(Theme.key_featuredStickers_addButton)), jint(Color.TRANSPARENT)))
            else:
                v.setText("КОНТЕЙНЕР ВЫКЛЮЧЕН")
                v.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhite)))
                v.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), jint(Theme.getColor(Theme.key_text_RedBold)), jint(Color.TRANSPARENT)))

        apply_state(btn, self.plugin.get_setting(key, default))

        class ToggleClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, w, k): super().__init__(); self.w=w; self.k=k
            def onClick(self, v):
                current = self.w.plugin.get_setting(self.k, default)
                new_state = not current
                self.w.plugin.set_setting(self.k, new_state)
                
                def mid_point():
                    apply_state(btn, new_state)
                    btn.animate().alpha(1.0).setDuration(150).start()
                btn.animate().alpha(0.0).setDuration(150).withEndAction(ActionRunnable(mid_point)).start()
                self.w._update_preview_from_settings(animate=True)

        btn.setOnClickListener(ToggleClick(self, key))
        self.settings_container.addView(btn, LayoutHelper.createLinear(-1, -2, 23, 12, 23, 12))

    def _add_color_picker(self, text, key, default):
        row = LinearLayout(self.context)
        row.setOrientation(0)
        row.setGravity(16)
        row.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(12), AndroidUtilities.dp(23), AndroidUtilities.dp(12))
        
        tv = jclass("android.widget.TextView")(self.context)
        tv.setText(text)
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
        tv.setTextSize(1, 16.0)
        row.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))
        
        color_circle = View(self.context)
        current_color = self.plugin.get_setting(key, default)
        
        def update_circle(c):
            bg = Theme.createRoundRectDrawable(AndroidUtilities.dp(15), jint(c))
            color_circle.setBackground(bg)
            
        update_circle(current_color)
        row.addView(color_circle, LayoutHelper.createLinear(30, 30, 16))
        
        class ColorClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, w, k): super().__init__(); self.w=w; self.k=k
            def onClick(self, v):
                picker = ColorPickerBottomSheet(self.w.context, None)
                picker.setPipetteDelegate(DummyPipetteDelegate())
                def on_color(c):
                    self.w.plugin.set_setting(self.k, c)
                    update_circle(c)
                    self.w._update_preview_from_settings(animate=False)
                picker.setColorListener(ColorConsumer(on_color))
                picker.setColor(jint(self.w.plugin.get_setting(self.k, default)))
                picker.show()
                
        row.setOnClickListener(ColorClick(self, key))
        self.settings_container.addView(row, LayoutHelper.createLinear(-1, -2))

    def _add_alignment_control(self, text, key, default):
        row = LinearLayout(self.context)
        row.setOrientation(1)
        row.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(10), AndroidUtilities.dp(23), AndroidUtilities.dp(10))
        
        tv = jclass("android.widget.TextView")(self.context)
        tv.setText(text)
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
        row.addView(tv, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))
        
        btn_row = LinearLayout(self.context)
        btn_row.setOrientation(0)
        
        gravities = [
            ("Лево", 3), 
            ("Центр", 1), 
            ("Право", 5) 
        ]
        
        buttons_refs = []
        
        class AlignClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, w, k, g): super().__init__(); self.w=w; self.k=k; self.g=g
            def onClick(self, v):
                self.w.plugin.set_setting(self.k, self.g)
                self.w._update_preview_from_settings(animate=True)
                
                for b_view, b_g in buttons_refs:
                    is_act = (b_g == self.g)
                    bg_c = jint(Theme.getColor(Theme.key_featuredStickers_addButton)) if is_act else jint(Color.TRANSPARENT)
                    txt_c = jint(Theme.getColor(Theme.key_featuredStickers_buttonText)) if is_act else jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
                    b_view.setTextColor(txt_c)
                    b_view.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), bg_c, jint(Color.TRANSPARENT)))
                
        for name, g in gravities:
            btn = jclass("android.widget.TextView")(self.context)
            btn.setText(name)
            btn.setGravity(17)
            btn.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8))
            
            is_active = self.plugin.get_setting(key, default) == g
            bg_color = jint(Theme.getColor(Theme.key_featuredStickers_addButton)) if is_active else jint(Color.TRANSPARENT)
            txt_color = jint(Theme.getColor(Theme.key_featuredStickers_buttonText)) if is_active else jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
            
            btn.setTextColor(txt_color)
            btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), bg_color, jint(Color.TRANSPARENT)))
            btn.setOnClickListener(AlignClick(self, key, g))
            
            buttons_refs.append((btn, g))
            btn_row.addView(btn, LayoutHelper.createLinear(0, -2, 1.0, 2, 0, 2, 0))
            
        row.addView(btn_row, LayoutHelper.createLinear(-1, -2))
        self.settings_container.addView(row)

    def _style_seekbar(self, sb):
        ColorStateList = jclass("android.content.res.ColorStateList")
        accent = jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
        inactive = jint(Theme.getColor(Theme.key_switchTrack))
        try:
            sb.setProgressTintList(ColorStateList.valueOf(accent))
            sb.setThumbTintList(ColorStateList.valueOf(accent))
            sb.setProgressBackgroundTintList(ColorStateList.valueOf(inactive))
        except: pass

    def _create_seek_touch_proxy(self):
        class SeekTouchProxy(dynamic_proxy(jclass("android.view.View$OnTouchListener"))):
            def onTouch(self, v, event):
                try:
                    MotionEvent = jclass("android.view.MotionEvent")
                    action = event.getActionMasked()
                    if action == MotionEvent.ACTION_DOWN:
                        p = v.getParent()
                        while p:
                            p.requestDisallowInterceptTouchEvent(True)
                            p = p.getParent()
                    elif action == MotionEvent.ACTION_UP or action == MotionEvent.ACTION_CANCEL:
                        p = v.getParent()
                        while p:
                            p.requestDisallowInterceptTouchEvent(False)
                            p = p.getParent()
                except: pass
                return False
        return SeekTouchProxy()

    def _add_slider(self, text, key, min_val, max_val, default):
        ll = LinearLayout(self.context)
        ll.setOrientation(1)
        ll.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(10), AndroidUtilities.dp(23), AndroidUtilities.dp(10))
        tv = jclass("android.widget.TextView")(self.context)
        val = int(self.plugin.get_setting(key, default))
        tv.setText(f"{text}: {val}")
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
        ll.addView(tv)
        sb = SeekBar(self.context)
        self._style_seekbar(sb)
        sb.setMax(max_val - min_val)
        sb.setProgress(val - min_val)
        sb.setOnTouchListener(self._create_seek_touch_proxy())
        def on_change(prog):
            v = prog + min_val
            tv.setText(f"{text}: {v}")
            self.plugin.set_setting(key, v)
            self._update_preview_from_settings(animate=False)
        sb.setOnSeekBarChangeListener(SimpleSeekListener(on_change))
        ll.addView(sb, LayoutHelper.createLinear(-1, -2, 0, 10, 0, 0))
        self.settings_container.addView(ll)

    def _add_slider_float(self, text, key, min_val, max_val, default):
        ll = LinearLayout(self.context)
        ll.setOrientation(1)
        ll.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(10), AndroidUtilities.dp(23), AndroidUtilities.dp(10))
        tv = jclass("android.widget.TextView")(self.context)
        val = float(self.plugin.get_setting(key, default))
        tv.setText(f"{text}: {val:.2f}")
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
        ll.addView(tv)
        sb = SeekBar(self.context)
        self._style_seekbar(sb)
        steps = 100
        sb.setMax(steps)
        sb.setProgress(int((val - min_val) / (max_val - min_val) * steps))
        sb.setOnTouchListener(self._create_seek_touch_proxy())
        def on_change(prog):
            v = min_val + (max_val - min_val) * (prog / float(steps))
            tv.setText(f"{text}: {v:.2f}")
            self.plugin.set_setting(key, v)
            self._update_preview_from_settings(animate=False)
        sb.setOnSeekBarChangeListener(SimpleSeekListener(on_change))
        ll.addView(sb, LayoutHelper.createLinear(-1, -2, 0, 10, 0, 0))
        self.settings_container.addView(ll)

    def _add_input(self, text, key, default):
        ll = LinearLayout(self.context)
        ll.setOrientation(1)
        ll.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(10), AndroidUtilities.dp(23), AndroidUtilities.dp(10))
        tv = jclass("android.widget.TextView")(self.context)
        tv.setText(text)
        tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader)))
        ll.addView(tv)
        et = EditTextBoldCursor(self.context)
        et.setText(self.plugin.get_setting(key, default))
        et.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
        def on_change(s):
            self.plugin.set_setting(key, s)
            self._update_preview_from_settings(animate=False)
        et.addTextChangedListener(SimpleTextWatcher(on_change))
        ll.addView(et, LayoutHelper.createLinear(-1, -2))
        self.settings_container.addView(ll)

    def _add_icon_selector_btn(self):
        btn = jclass("android.widget.TextView")(self.context)
        btn.setText("Выбрать иконку (Поиск)")
        btn.setGravity(17)
        btn.setTextColor(jint(Theme.getColor(Theme.key_featuredStickers_buttonText)))
        btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), jint(Theme.getColor(Theme.key_featuredStickers_addButton)), jint(Color.TRANSPARENT)))
        btn.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
        class IconClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, w): super().__init__(); self.w = w
            def onClick(self, v): self.w._show_icons_bottom_sheet()
        btn.setOnClickListener(IconClick(self))
        self.settings_container.addView(btn, LayoutHelper.createLinear(-1, -2, 23, 16, 23, 0))

    def _show_icons_bottom_sheet(self):
        try:
            def on_selected(name):
                self.plugin.set_setting("ds_icon_res", name)
                self._update_preview_from_settings(animate=False)

            delegate = IconSelectorDelegate(on_selected)
            fragment = UniversalFragment(delegate)
            delegate.fragment = fragment
            
            self.base_fragment.presentFragment(fragment)
            
        except Exception as e:
            self.plugin.log(f"ICON SHEET ERROR: {e}")

class ReMandreLib(BasePlugin):
    def on_plugin_load(self):
        if is_safe_mode():
            mlog("SAFE MODE ACTIVE: ReMandre Core will not load native extensions.")
            return

        mlog("Plugin initializing...")
        try: sys.modules["ReMandre"] = sys.modules[self.__class__.__module__]
        except: pass
        
        self.hooks_list = []
        ReLoad.get()
        try:
            Class = jclass("java.lang.Class")
            sheet_cls = Class.forName("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
            self.hooks_list.append(self.hook_method(sheet_cls.getDeclaredConstructors()[0], InstallSheetHook(self)))
            
            engine_cls = Class.forName("com.exteragram.messenger.plugins.PythonPluginsEngine")
            
            is_plugin_method = engine_cls.getDeclaredMethod("isPlugin", jclass("java.io.File"), jclass("org.telegram.messenger.MessageObject"))
            self.hooks_list.append(self.hook_method(is_plugin_method, Plugin2IsPluginHook(self)))
            
            show_install_method = engine_cls.getDeclaredMethod("showInstallDialog", jclass("org.telegram.ui.ActionBar.BaseFragment"), jclass("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet$PluginInstallParams"))
            self.hooks_list.append(self.hook_method(show_install_method, Plugin2InstallHook(self)))
            
            share_method = engine_cls.getDeclaredMethod("sharePlugin", jclass("java.lang.String"))
            self.hooks_list.append(self.hook_method(share_method, Plugin2ShareHook(self)))
        except Exception as e:
            mlog(f"Error hooking in ReMandre: {e}")

        self._check_and_install_deps_ui()
        
        threading.Thread(target=self._precache_stickers, daemon=True).start()

    def on_plugin_unload(self):
        mlog("Plugin unloading...")
        if hasattr(self, "hooks_list"):
            for h in self.hooks_list:
                try:
                    self.unhook_method(h)
                except Exception as e:
                    mlog(f"Error unhooking: {e}")
            self.hooks_list.clear()
        import gc
        gc.collect()

    def _copy_link(self, full_alias):
        def _cb(view):
            try:
                from client_utils import get_last_fragment
                fragment = get_last_fragment()
                if not fragment: return False

                ItemOptions = jclass("org.telegram.ui.Components.ItemOptions")
                R = jclass("org.telegram.messenger.R")
                Runnable = jclass("java.lang.Runnable")
                
                link = f"https://t.me/exteraSettings?p={__id__}&s={full_alias}"

                class CopyRunnable(dynamic_proxy(Runnable)):
                    def run(self):
                        jclass("org.telegram.messenger.AndroidUtilities").addToClipboard(link)
                        from ui.bulletin import BulletinHelper
                        BulletinHelper.show_success("Ссылка скопирована!")

                ItemOptions.makeOptions(fragment, view).add(
                    R.drawable.msg_copy, 
                    "Скопировать ссылку", 
                    CopyRunnable()
                ).show()
                return True 
            except Exception as e:
                mlog(f"Copy link popup error: {e}")
                return False
        return _cb
        
    def _precache_stickers(self):
        try:
            TLRPC = jclass("org.telegram.tgnet.TLRPC")
            ConnectionsManager = jclass("org.telegram.tgnet.ConnectionsManager")
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            
            req = TLRPC.TL_messages_getStickerSet()
            req.stickerset = TLRPC.TL_inputStickerSetShortName()
            req.stickerset.short_name = "UtyaDuck"
            req.hash = 0 
            
            current_account = UserConfig.selectedAccount
            ConnectionsManager.getInstance(current_account).sendRequest(req, None)
            mlog("Sticker precache requested via API")
        except Exception as e:
            mlog(f"Sticker precache error: {e}")

    def _check_and_install_deps_ui(self):
        needs_install = False
        _, site_pkgs, _ = RePip.get_dirs()
        if site_pkgs not in sys.path: sys.path.insert(0, site_pkgs)
        try:
            RePip.fix_cffi_backend()
            import cffi
            _CFFI_READY.set()
        except:
            needs_install = True
            _CFFI_READY.clear()

        if needs_install:
            threading.Thread(target=self._wait_and_show_installer).start()

    def _wait_and_show_installer(self):
        LaunchActivity = None
        for _ in range(20):
            try:
                LaunchActivity = jclass("org.telegram.ui.LaunchActivity").instance
                if LaunchActivity: break
            except: pass
            time.sleep(0.5)
        
        if LaunchActivity:
            run_on_ui_thread(lambda: CoreInstallerSheet(LaunchActivity).show())
        else:
            mlog("Не удалось найти Activity для показа установщика зависимостей.")
            threading.Timer(10.0, _CFFI_READY.set).start()

    def create_settings(self):
        return [
            Header(text="Основа"),
            Text(text="Дизайн", icon="msg_palette", create_sub_fragment=self._design_sub_page, link_alias="design_link", on_long_click=self._copy_link("design_link")),
            Text(text="Модули", icon="msg_settings", create_sub_fragment=self._modules_sub_page, link_alias="modules_link", on_long_click=self._copy_link("modules_link")),
            Header(text="другое"),
            Text(text="Другие", icon="msg_help", create_sub_fragment=self._others_sub_page, link_alias="others_link", on_long_click=self._copy_link("others_link")),
            Divider()
        ]

    def _others_sub_page(self):
        def kill_app(v):
            try:
                from org.telegram.ui import LaunchActivity
                act = LaunchActivity.instance
                if act:
                    act.finishAffinity()
                jclass("java.lang.System").exit(0)
            except:
                jclass("java.lang.System").exit(0)

        return [
            Header(text="Управление процессом"),
            Divider(),
            Text(
                text="Убить процесс", 
                icon="msg_ST_proxies", 
                red=True, 
                on_click=kill_app
            ),
            Divider(text="Мгновенно завершает работу приложения через System.exit(0). Это безопасный выход, плагин-движок не посчитает это за краш.")
        ]

    def _modules_sub_page(self):
        def clear_all(v):
            try:
                loader = ReLoad.get()
                root = loader.root
                import shutil
                if os.path.exists(root):
                    shutil.rmtree(root)
                os.makedirs(root) 

                loader.choices = {}
                loader._storage = {}
                loader.loaded_modules = ModuleGatekeeper(loader)

                global _CFFI_READY
                _CFFI_READY.clear()

                keys_to_delete = [k for k in sys.modules if 'cffi' in k or 'pycparser' in k or k == '_cffi_backend' or k == 'pip' or k == 'setuptools' or k == 'wheel']
                for k in keys_to_delete:
                    del sys.modules[k]
                    
                BulletinHelper.show_success("Всё успешно выпилено! Обязательно перезапустите клиент Экстеры.")
            except Exception as e:
                BulletinHelper.show_error(f"Не удалось удалить: {e}")

        return [
            Text(
                text="Удалить и очистить всё нахуй", 
                icon="msg_delete", 
                red=True, 
                on_click=clear_all
            ),
            Divider(text="Удалит абсолютно все скачанные модули (.so), пакеты PIP (cffi) и сбросит настройки их установки. Перезапуск клиента обязателен.")
        ]

    def _design_sub_page(self):
        import traceback
        import threading
        from android_utils import run_on_ui_thread
        from client_utils import get_last_fragment
        from ui.settings import Custom, Text

        self.log("Начинаем сборку студии дизайна...")

        view_box = [None]
        error_box = [None]
        sync_event = threading.Event()

        def build_ui_safely():
            try:
                frag = get_last_fragment()
                if not frag:
                    error_box[0] = "Фрагмент не найден"
                    return
                    
                ctx = frag.getParentActivity()
                if not ctx:
                    error_box[0] = "Активность не найдена"
                    return

                studio = DesignStudioController(ctx, self, frag)
                view_box[0] = studio.get_view()
                self.log("Студия дизайна успешно собрана в UI потоке.")
            except Exception as e:
                error_box[0] = f"Ошибка сборки UI: {e}\n{traceback.format_exc()}"
            finally:
                sync_event.set()

        run_on_ui_thread(build_ui_safely)
        
        success = sync_event.wait(3.0)

        if not success:
            self.log("Таймаут при создании UI!")
            return [Text(text="Таймаут загрузки интерфейса", red=True)]

        if error_box[0]:
            self.log(error_box[0])
            return [Text(text="Критическая ошибка создания UI. Смотрите логи.", red=True)]

        if view_box[0]:
            return [Custom(view=view_box[0])]
            
        return [Text(text="Неизвестная ошибка: view не вернулось.", red=True)]