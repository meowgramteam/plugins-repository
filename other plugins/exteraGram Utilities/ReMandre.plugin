UniversalView = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView")
UniversalViewDelegate = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView$UniversalViewDelegate")

class HighlightOverlayDelegate(dynamic_proxy(UniversalViewDelegate)):
    def __init__(self):
        super().__init__()
        self.target_rect = RectF()
        self.current_rect = RectF()
        self.view = None
        self.target_radius = float(AndroidUtilities.dp(6))
        
        self.accent_color = jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
        
        self.stroke_paint = Paint(Paint.ANTI_ALIAS_FLAG)
        self.stroke_paint.setStyle(Paint.Style.STROKE)
        self.stroke_paint.setStrokeWidth(float(AndroidUtilities.dp(2)))
        self.stroke_paint.setColor(self.accent_color)
        
        self.fill_paint = Paint(Paint.ANTI_ALIAS_FLAG)
        self.fill_paint.setStyle(Paint.Style.FILL)
        self.fill_paint.setAlpha(60)
        
        pattern_size = AndroidUtilities.dp(8)
        bitmap = Bitmap.createBitmap(pattern_size, pattern_size, Bitmap.Config.ARGB_8888)
        c = Canvas(bitmap)
        p = Paint(Paint.ANTI_ALIAS_FLAG)
        p.setColor(self.accent_color)
        p.setStrokeWidth(float(AndroidUtilities.dp(1)))
        c.drawLine(0, pattern_size, pattern_size, 0, p)
        
        shader = BitmapShader(bitmap, Shader.TileMode.REPEAT, Shader.TileMode.REPEAT)
        self.fill_paint.setShader(shader)
        
        self.animator = None
        self.loc_view = jarray(jint)(2)
        self.loc_target = jarray(jint)(2)

    def setTarget(self, target_view, parent_view, radius_dp=6):
        if not target_view or not self.view:
            self.target_rect.set(0, 0, 0, 0)
            if self.view: self.view.invalidate()
            return

        self.target_radius = float(AndroidUtilities.dp(radius_dp))

        self.view.getLocationInWindow(self.loc_view)
        target_view.getLocationInWindow(self.loc_target)
        
        x = self.loc_target[0] - self.loc_view[0]
        y = self.loc_target[1] - self.loc_view[1]
            
        self.target_rect.set(float(x), float(y), float(x + target_view.getWidth()), float(y + target_view.getHeight()))
        
        if self.current_rect.isEmpty():
            self.current_rect.set(self.target_rect)
            self.view.invalidate()
        else:
            if self.animator: self.animator.cancel()
            
            class AnimUpdate(dynamic_proxy(jclass("android.animation.ValueAnimator$AnimatorUpdateListener"))):
                def __init__(self, delegate, start_rect, end_rect):
                    super().__init__()
                    self.delegate = delegate
                    self.start_rect = start_rect
                    self.end_rect = end_rect
                def onAnimationUpdate(self, a):
                    p = float(a.getAnimatedValue())
                    self.delegate.current_rect.left = self.start_rect.left + (self.end_rect.left - self.start_rect.left) * p
                    self.delegate.current_rect.top = self.start_rect.top + (self.end_rect.top - self.start_rect.top) * p
                    self.delegate.current_rect.right = self.start_rect.right + (self.end_rect.right - self.start_rect.right) * p
                    self.delegate.current_rect.bottom = self.start_rect.bottom + (self.end_rect.bottom - self.start_rect.bottom) * p
                    if self.delegate.view:
                        self.delegate.view.invalidate()

            self.animator = ValueAnimator.ofFloat(jarray(jfloat)([0.0, 1.0]))
            self.animator.setDuration(250)
            self.animator.setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT)
            self.animator.addUpdateListener(AnimUpdate(self, RectF(self.current_rect), self.target_rect))
            self.animator.start()

    def onDraw(self, canvas, callback):
        if not self.current_rect.isEmpty():
            rad = self.target_radius
            canvas.drawRoundRect(self.current_rect, rad, rad, self.fill_paint)
            canvas.drawRoundRect(self.current_rect, rad, rad, self.stroke_paint)
        callback.run(canvas)
            
    def onAttachedToWindow(self): pass
    def onDetachedFromWindow(self): pass
    def onInitializeAccessibilityNodeInfo(self, info, callback): callback.run(info)
    def onMeasure(self, w, h, callback): callback.run(Integer(w), Integer(h))
    def onTouchEvent(self, event, callback): return Boolean(callback.run(event))


UniversalFragment = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalFragment")
UniversalFragmentDelegate = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalFragment$UniversalFragmentDelegate")
CircularProgressIndicator = jclass("com.google.android.material.progressindicator.CircularProgressIndicator")

class IconSelectorDelegate(dynamic_proxy(UniversalFragmentDelegate)):
    def __init__(self, callback):
        super().__init__()
        self.callback = callback
        self.search_et = None
        self.grid_layout = None
        self.fragment = None
        self.progress = None
        self.search_timer = None
        self.all_icons = []
        self.icon_map = {} # {name: res_id}
        
        try:
            R_tg = jclass("org.telegram.messenger.R").drawable
            for f in dir(R_tg):
                if f.startswith("msg_") or f.startswith("ic_"):
                    self.icon_map[f] = getattr(R_tg, f)
        except: pass

        try:
            R_ext = jclass("com.exteragram.messenger.R").drawable
            for f in dir(R_ext):
                if f.startswith("msg_") or f.startswith("ic_"):
                    self.icon_map[f] = getattr(R_ext, f)
        except: pass
        
        self.all_icons = sorted(list(self.icon_map.keys()))

    def onFragmentCreate(self): pass
    def onFragmentDestroy(self): pass
    def onBackPressed(self): return None 
    def getTitle(self): return "Выбор иконки"
    
    def onMenuItemClick(self, id): pass
    def fillItems(self, items, adapter): pass
    def onClick(self, item, view, position, x, y): pass
    def onLongClick(self, item, view, position, x, y): return False

    def beforeCreateView(self):
        return None 

    def afterCreateView(self, view):
        context = view.getContext()
        root = FrameLayout(context)
        root.setBackgroundColor(jint(Theme.getColor(Theme.key_windowBackgroundWhite)))
        
        search_cont = FrameLayout(context)
        search_cont.setBackgroundColor(jint(Theme.getColor(Theme.key_windowBackgroundWhite)))
        search_cont.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8))
        
        search_bg = View(context)
        search_bg.setBackground(Theme.createRoundRectDrawable(AndroidUtilities.dp(18), jint(Theme.getColor(Theme.key_dialogSearchBackground))))
        search_cont.addView(search_bg, LayoutHelper.createFrame(-1, 36, 51, 14, 0, 14, 0))

        search_icon = jclass("android.widget.ImageView")(context)
        search_icon.setImageResource(jclass("org.telegram.messenger.R").drawable.smiles_inputsearch)
        search_icon.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(jint(Theme.getColor(Theme.key_dialogSearchIcon)), jclass("android.graphics.PorterDuff$Mode").MULTIPLY))
        search_icon.setScaleType(jclass("android.widget.ImageView$ScaleType").CENTER)
        search_cont.addView(search_icon, LayoutHelper.createFrame(36, 36, 51, 16, 0, 0, 0))

        self.search_et = EditTextBoldCursor(context)
        self.search_et.setTextSize(1, 16.0)
        self.search_et.setHintTextColor(jint(Theme.getColor(Theme.key_dialogSearchHint)))
        self.search_et.setTextColor(jint(Theme.getColor(Theme.key_dialogSearchText)))
        self.search_et.setBackgroundDrawable(None)
        self.search_et.setPadding(0,0,0,0)
        self.search_et.setSingleLine(True)
        self.search_et.setHint("Поиск иконки (msg_...)")
        self.search_et.setCursorColor(jint(Theme.getColor(Theme.key_featuredStickers_addedIcon)))
        self.search_et.setImeOptions(jclass("android.view.inputmethod.EditorInfo").IME_ACTION_SEARCH | jclass("android.view.inputmethod.EditorInfo").IME_FLAG_NO_EXTRACT_UI)
        
        class SearchClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, et): super().__init__(); self.et = et
            def onClick(self, v):
                self.et.requestFocus()
                AndroidUtilities.showKeyboard(self.et)
                
        self.search_et.setOnClickListener(SearchClick(self.search_et))
        
        search_cont.addView(self.search_et, LayoutHelper.createFrame(-1, 36, 51, 54, 0, 14, 0))
        root.addView(search_cont, LayoutHelper.createFrame(-1, 52, 48))

        scroll = ScrollView(context)
        self.grid_layout = GridLayout(context)
        self.grid_layout.setColumnCount(4)
        self.grid_layout.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
        scroll.addView(self.grid_layout)
        root.addView(scroll, LayoutHelper.createFrame(-1, -1, 48, 0, 52, 0, 0))

        self.progress = CircularProgressIndicator(context)
        self.progress.setIndeterminate(True)
        self.progress.setIndicatorColor(jint(Theme.getColor(Theme.key_featuredStickers_addButton)))
        self.progress.setVisibility(8)
        root.addView(self.progress, LayoutHelper.createFrame(48, 48, 17))

        self.populate("", context)
        
        class TextChangeProxy(dynamic_proxy(jclass("android.text.TextWatcher"))):
            def __init__(self, delegate, ctx): super().__init__(); self.d = delegate; self.ctx = ctx
            def afterTextChanged(self, s):
                query = str(s.toString())
                if self.d.search_timer: self.d.search_timer.cancel()
                if len(query) > 0:
                    self.d.progress.setVisibility(0)
                    self.d.grid_layout.setAlpha(0.3)
                self.d.search_timer = threading.Timer(0.8, lambda: run_on_ui_thread(lambda: self.d.populate(query, self.ctx)))
                self.d.search_timer.start()
            def beforeTextChanged(self, s, st, c, a): pass
            def onTextChanged(self, s, st, b, c): pass

        self.search_et.addTextChangedListener(TextChangeProxy(self, context))
        return root

    def populate(self, query, context):
        if not self.grid_layout: return
        self.grid_layout.removeAllViews()
        count = 0
        
        class IconClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, f, name): super().__init__(); self.f = f; self.name = name
            def onClick(self, v):
                self.f.callback(self.name)
                if self.f.fragment: self.f.fragment.finishFragment()

        search_terms = query.lower().split()
        
        for ic_name in self.all_icons:
            name_lower = ic_name.lower()
            match = True
            if query:
                for term in search_terms:
                    if term not in name_lower:
                        match = False
                        break
            
            if match:
                try:
                    res_id = self.icon_map[ic_name]
                    iv = jclass("android.widget.ImageView")(context)
                    iv.setImageResource(res_id)
                    iv.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(jint(Theme.getColor(Theme.key_windowBackgroundWhiteGrayIcon)), jclass("android.graphics.PorterDuff$Mode").SRC_IN))
                    iv.setBackground(Theme.createSelectorDrawable(jint(Theme.getColor(Theme.key_listSelector)), 1))
                    iv.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
                    iv.setOnClickListener(IconClick(self, ic_name))
                    
                    params = GridLayout.LayoutParams()
                    params.width = (AndroidUtilities.displaySize.x - AndroidUtilities.dp(32)) // 4
                    params.height = params.width
                    self.grid_layout.addView(iv, params)
                    
                    count += 1
                    if count >= 60 and not query: break 
                    if count >= 300 and query: break 
                except: pass
        
        self.progress.setVisibility(8)
        self.grid_layout.setAlpha(1.0)

class DesignStudioController:
    def __init__(self, context, plugin, base_fragment):
        self.plugin = plugin
        self.base_fragment = base_fragment
        self.context = context
        
        self.current_target = None
        self.ui_elements = {}
        
        self.root_view = LinearLayout(self.context)
        self.root_view.setOrientation(LinearLayout.VERTICAL)
        self.root_view.setBackgroundColor(jint(Theme.getColor(Theme.key_windowBackgroundWhite)))
        
        try:
            self._build_ui()
            self._update_preview_from_settings(animate=False)
        except Exception as e:
            self.plugin.log(f"DesignStudioController BUILD ERROR: {e}")

    def get_view(self):
        return self.root_view

    def _clear_selection(self):
        if self.current_target is not None:
            self.overlay_delegate.setTarget(None, None, 0)
            self.current_target = None
            self.settings_container.animate().alpha(0.0).translationY(float(AndroidUtilities.dp(20))).setDuration(150).start()

    def _build_ui(self):
        self.preview_container = FrameLayout(self.context)
        self.preview_container.setBackgroundColor(jint(Theme.getColor(Theme.key_windowBackgroundGray)))
        
        class RootClick(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
            def __init__(self, c): super().__init__(); self.c = c
            def onClick(self, v): self.c._clear_selection()
            
        self.preview_container.setOnClickListener(RootClick(self))
        
        list_root = LinearLayout(self.context)
        list_root.setOrientation(LinearLayout.VERTICAL)
        list_root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
        
        badge_cont = LinearLayout(self.context)
        badge_cont.setOrientation(0)
        badge_cont.setGravity(1) 
        
