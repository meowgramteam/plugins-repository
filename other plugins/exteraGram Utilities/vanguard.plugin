            def _open_note_editor(_v=None):
                try:
                    nb = AlertDialogBuilder(ctx)
                    nb.set_title(self._tr("moderator_note"))
                    nroot = LinearLayout(ctx)
                    nroot.setOrientation(LinearLayout.VERTICAL)
                    nroot.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))
                    nedit = EditTextBoldCursor(ctx)
                    nedit.setHint(self._tr("add_private_note"))
                    nedit.setInputType(InputType.TYPE_CLASS_TEXT)
                    nedit.setSingleLine(False)
                    nedit.setMinLines(3)
                    nedit.setMaxLines(6)
                    nedit.setText(str(inp_tag.getText().toString() if inp_tag.getText() is not None else ""))
                    self._style_dialog_input(nedit, multiline=True)
                    nroot.addView(nedit, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                    nb.set_view(nroot)

                    def _save_note(dd, _ww):
                        try:
                            val = str(nedit.getText().toString() if nedit.getText() is not None else "").strip()
                            inp_tag.setText(val)
                            if dd:
                                dd.dismiss()
                        except Exception:
                            BulletinHelper.show_info(self._tr("failed_save_note"))

                    nb.set_positive_button(self._tr("save"), _save_note)
                    nb.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
                    nb.show()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_note"))

            inp_tag.setOnClickListener(OnClickListener(_open_note_editor))

            def _open_tag_details(_v=None):
                try:
                    from org.telegram.ui.ActionBar import BottomSheet
                    from android.widget import LinearLayout as _LL, TextView as _TV
                    sh_root = _LL(ctx)
                    sh_root.setOrientation(_LL.VERTICAL)
                    sh_root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
                    t1 = _TV(ctx)
