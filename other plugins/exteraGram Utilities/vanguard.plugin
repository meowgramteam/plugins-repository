    def _open_supporters_subfragment(self):
        try:
            try:
                self._ensure_settings_header_assets()
            except Exception:
                pass
            try:
                self._refresh_supporters_async()
            except Exception:
                pass
            fragment = get_last_fragment()
            controller = PluginsController.getInstance()
            plugin = controller.plugins.get(self.id) if controller else None
            if not plugin or fragment is None:
                return
            activity = PluginSettingsActivity(plugin)
            self._settings_activity_ref = activity
            try:
                self._set_subfragment_callback(activity, self._create_supporters_subfragment)
            except Exception:
                self._supporters_open_pending = True
            fragment.presentFragment(activity)
        except Exception as e:
            self._dlog("open supporters subfragment fail: {0}".format(e))

    def _read_json_file(self, path):
        try:
            if not path or not os.path.isfile(path):
                return None
            with open(path, "r", encoding="utf-8-sig") as f:
                return json.load(f)
        except Exception:
            return None

    def _supporters_payload(self):
        try:
            candidates = []
            try:
                candidates.append(SUPPORTERS_CACHE_FILE)
            except Exception:
                pass
            try:
                candidates.append(os.path.join(os.getcwd(), SUPPORTERS_PLUGIN_FILE))
            except Exception:
                pass
            try:
                base = os.path.dirname(os.path.abspath(__file__))
                candidates.append(os.path.join(base, SUPPORTERS_PLUGIN_FILE))
            except Exception:
                pass
            seen = set()
            for p in candidates:
                try:
                    if not p or p in seen or not os.path.isfile(p):
                        continue
                    seen.add(p)
                except Exception:
                    continue
                data = self._read_json_file(p)
                if isinstance(data, dict) or isinstance(data, list):
                    return data
        except Exception:
            pass
        return {"supporters": []}

    def _supporters_list(self):
        try:
            data = self._supporters_payload()
            arr = []
            if isinstance(data, list):
                arr = data
            elif isinstance(data, dict):
                if isinstance(data.get("supporters"), list):
                    arr = data.get("supporters", [])
                elif isinstance(data.get("items"), list):
                    arr = data.get("items", [])
                elif isinstance(data.get("data"), list):
                    arr = data.get("data", [])
            out = []
            for it in arr:
                if not isinstance(it, dict):
                    continue
                name = str(it.get("name", "") or "").strip()
                username = str(it.get("username", "") or "").strip()
                avatar = str(it.get("avatar", "") or "").strip()
                if not name and not username and not avatar:
                    continue
                out.append({"name": name, "username": username, "avatar": avatar})
            return out
        except Exception:
            return []

    def _refresh_supporters_async(self, on_done=None):
        try:
            if bool(self._supporters_refreshing):
                return
            self._supporters_refreshing = True

            def _finish():
                try:
                    self._supporters_refreshing = False
                except Exception:
                    pass
                try:
                    if callable(on_done):
                        run_on_ui_thread(on_done)
                except Exception:
                    pass
                try:
                    self._refresh_supporters_subfragment_view()
                except Exception:
                    pass

            def _worker():
                try:
                    os.makedirs(_CACHE_DIR, exist_ok=True)
                    req = Request(
                        SUPPORTERS_URL,
                        headers={
                            "User-Agent": "Vanguard/1.0",
                            "Cache-Control": "no-cache",
                            "Pragma": "no-cache",
                        },
                    )
                    with urlopen(req, timeout=8) as resp:
                        raw = resp.read().decode("utf-8-sig", errors="replace")
                    data = json.loads(raw)
                    if isinstance(data, dict) or isinstance(data, list):
                        with open(SUPPORTERS_CACHE_FILE, "w", encoding="utf-8") as f:
                            json.dump(data, f, ensure_ascii=False, indent=2)
                except Exception as e:
                    self._dlog("supporters refresh fail: {0}".format(e))
                finally:
                    _finish()

            try:
                run_on_queue(_worker)
            except Exception:
                threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            self._supporters_refreshing = False

    def _toggle_logs_silent(self):
        try:
