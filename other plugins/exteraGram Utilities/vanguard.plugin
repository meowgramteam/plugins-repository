            def _remove_alias(_v=None):
                try:
                    if self._user_alias_del(uid):
                        inp_alias.setText("")
                        _set_alias_remove_enabled(False)
                        BulletinHelper.show_success(self._tr("nickname_removed"))
                        try:
                            self._rerender_vanguard_beacon_panel(cell, nonce)
                        except Exception:
                            pass
                    else:
                        BulletinHelper.show_info(self._tr("no_nickname_to_remove"))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_save_nickname"))

