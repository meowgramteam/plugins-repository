            },
        ]

    def _load_warning_templates(self):
        raw = self.get_setting("tagged_warning_templates_v1", "")
        custom_templates = []
        try:
            data = json.loads(str(raw or "[]"))
            if isinstance(data, list):
                for item in data:
                    if not isinstance(item, dict):
                        continue
                    title = str(item.get("title", "") or "").strip()
                    body = str(item.get("body", "") or "").strip()
                    tid = str(item.get("id", "") or "").strip() or "tpl_{0}".format(random.randint(1000, 999999))
                    action = str(item.get("action", "warn") or "warn").strip().lower()
                    action, body = self._extract_action_and_body(action, body)
                    icon = str(item.get("icon", "") or "").strip() or self._default_icon_for_action(action)
                    if title and body:
                        custom_templates.append({"id": tid, "title": title, "icon": icon, "action": action, "body": body, "is_fixed": False})
        except Exception:
            custom_templates = []
        custom_templates = custom_templates[:5]
        self._warning_templates = self._default_templates() + custom_templates
        self._save_warning_templates()

    def _save_warning_templates(self):
        try:
            custom = [t for t in list(self._warning_templates) if isinstance(t, dict) and not bool(t.get("is_fixed"))]
            self.set_setting("tagged_warning_templates_v1", json.dumps(custom, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _load_federations(self):
        out = []
        try:
            raw = self.get_setting("tagged_federations_v1", "[]")
            data = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            if isinstance(data, list):
                for it in data:
                    if not isinstance(it, dict):
                        continue
                    fid = int(it.get("id", 0) or 0)
                    name = str(it.get("name", "") or "").strip()
                    if fid == 0:
                        continue
                    if not name:
                        name = "Federation {0}".format(abs(int(fid)))
                    out.append({
                        "id": int(fid),
                        "name": name,
                        "added_at": int(it.get("added_at", int(time.time())) or int(time.time())),
                    })
        except Exception:
            out = []
        uniq = {}
        for f in out:
            uniq[str(int(f.get("id", 0)))] = f
        self._federations = list(uniq.values())
        self._save_federations()

    def _save_federations(self):
        try:
            self.set_setting("tagged_federations_v1", json.dumps(list(self._federations or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _load_reason_presets(self):
        try:
            raw = self.get_setting("tagged_reason_presets_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            out = []
            for it in (arr or []):
                if not isinstance(it, dict):
                    continue
                title = str(it.get("title", "") or "").strip()
                reason = str(it.get("reason", "") or "").strip()
                if not title or not reason:
                    continue
                rid = str(it.get("id", "") or "").strip()
                if not rid:
                    rid = "rp_{0}".format(int(time.time() * 1000))
                out.append({"id": rid, "title": title, "reason": reason})
            self._reason_presets = out[:20]
            self._save_reason_presets()
        except Exception:
            self._reason_presets = []

    def _save_reason_presets(self):
        try:
            self.set_setting("tagged_reason_presets_v1", json.dumps(list(self._reason_presets or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _load_shortcuts(self):
        try:
            raw = self.get_setting("tagged_shortcuts_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            out = []
            for it in (arr or []):
                if not isinstance(it, dict):
                    continue
                title = str(it.get("title", "") or "").strip()
                command = str(it.get("command", "") or "").strip()
                if not title or not command:
