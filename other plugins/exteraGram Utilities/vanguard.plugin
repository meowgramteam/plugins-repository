            def _refresh_tpl_ui():
                tpl = selected.get("tpl")
                if isinstance(tpl, dict):
                    title = str(tpl.get("title", "") or "Template")
                    action = str(tpl.get("action", "warn") or "warn").upper()
                    selected_tpl_txt.setText(self._tr("selected_action_fmt").format(title, action))
                else:
                    selected_tpl_txt.setText(self._tr("no_action_selected"))
                _set_apply_enabled(isinstance(tpl, dict))

            def _open_template_selector(_v=None):
                try:
                    from org.telegram.ui.ActionBar import BottomSheet
                    from android.widget import ImageView
                    sheet = BottomSheet(ctx, True)
                    container = LinearLayout(ctx)
                    container.setOrientation(LinearLayout.VERTICAL)
                    container.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

                    handle = View(ctx)
                    try:
                        hbg = GradientDrawable()
                        hbg.setCornerRadius(AndroidUtilities.dp(2))
                        hbg.setColor(Color.parseColor("#C7CDD4"))
                        handle.setBackground(hbg)
                    except Exception:
                        pass
                    lp_h = LinearLayout.LayoutParams(AndroidUtilities.dp(40), AndroidUtilities.dp(4))
                    lp_h.gravity = Gravity.CENTER_HORIZONTAL
                    lp_h.bottomMargin = AndroidUtilities.dp(10)
                    container.addView(handle, lp_h)

                    hdr = TextView(ctx)
                    hdr.setText(self._tr("select_admin_action"))
                    hdr.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
                    hdr.setGravity(Gravity.CENTER_HORIZONTAL)
                    try:
                        hdr.setTextColor(c_title)
                    except Exception:
                        pass
                    lp_hdr = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_hdr.bottomMargin = AndroidUtilities.dp(6)
                    container.addView(hdr, lp_hdr)

                    cur_id = str((selected.get("tpl") or {}).get("id", "") or "")
                    items = list(self._warning_templates)
                    for i, tpl in enumerate(items):
                        row = LinearLayout(ctx)
                        row.setOrientation(LinearLayout.HORIZONTAL)
                        row.setGravity(Gravity.CENTER_VERTICAL)
                        row.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(10), AndroidUtilities.dp(6), AndroidUtilities.dp(10))
                        row.setMinimumHeight(AndroidUtilities.dp(54))

                        iconv = ImageView(ctx)
                        tid = str(tpl.get("id", "") or "")
                        title = str(tpl.get("title", "") or "Template").strip()
                        action = str(tpl.get("action", "warn") or "warn").upper()
                        is_sel = bool(cur_id and tid == cur_id)
                        try:
                            rbg = GradientDrawable()
                            rbg.setCornerRadius(AndroidUtilities.dp(10))
                            if is_sel:
                                rbg.setColor(Color.parseColor("#2B3F57"))
                                rbg.setStroke(AndroidUtilities.dp(1), Color.parseColor("#6FA8FF"))
                            else:
                                rbg.setColor(Color.TRANSPARENT)
                            row.setBackground(rbg)
                        except Exception:
                            pass
                        rid = self._resolve_icon_res(ctx, str(tpl.get("icon", "") or ""), fallback="msg_permissions")
                        if rid > 0:
                            iconv.setImageResource(rid)
                        try:
                            iconv.setColorFilter(c_title)
                        except Exception:
                            pass
                        lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                        lp_icon.rightMargin = AndroidUtilities.dp(12)
                        lp_icon.gravity = Gravity.CENTER_VERTICAL
                        row.addView(iconv, lp_icon)

                        tcol = LinearLayout(ctx)
                        tcol.setOrientation(LinearLayout.VERTICAL)
                        lp_tcol = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                        lp_tcol.gravity = Gravity.CENTER_VERTICAL
                        row.addView(tcol, lp_tcol)

                        t1 = TextView(ctx)
                        t1.setText(title)
                        t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                        try:
                            t1.setTextColor(c_title)
                        except Exception:
                            pass
                        tcol.addView(t1)

                        t2 = TextView(ctx)
                        t2.setText(self._tr("action_fmt").format(action))
                        t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                        try:
                            t2.setTextColor(c_sub)
                        except Exception:
                            pass
                        tcol.addView(t2)

                        def _pick(v=None, t=tpl, tt=tid):
                            prev_id = str((selected.get("tpl") or {}).get("id", "") or "")
                            selected["tpl"] = None if (prev_id and prev_id == tt) else t
                            _refresh_tpl_ui()
                            try:
                                sheet.dismiss()
                            except Exception:
                                pass

                        row.setOnClickListener(OnClickListener(_pick))
                        lp_rb = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                        container.addView(row, lp_rb)
                        if i < (len(items) - 1):
                            div = View(ctx)
                            try:
                                div.setBackgroundColor(Color.parseColor("#33465A"))
                            except Exception:
                                pass
                            lp_d = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(1))
                            lp_d.leftMargin = AndroidUtilities.dp(38)
                            container.addView(div, lp_d)

                    sheet.setCustomView(container)
                    sheet.show()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_action_selector"))

