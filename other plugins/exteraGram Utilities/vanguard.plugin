                icon = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, "msg_info", fallback="msg_info")
                if rid > 0:
                    icon.setImageResource(rid)
                try:
                    icon.setColorFilter(int(c_danger))
                except Exception:
                    pass
