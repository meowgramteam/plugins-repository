    def _save_shortcuts(self):
        try:
            self.set_setting("tagged_shortcuts_v1", json.dumps(list(self._shortcuts or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _load_mentions_hub(self):
        try:
            raw = self.get_setting("tagged_mentions_hub_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
        except Exception:
            data = {}
        if not isinstance(data, dict):
            data = {}
        sources = []
        for it in list(data.get("sources", []) or []):
            try:
                did = int(it or 0)
            except Exception:
                did = 0
            if did < 0 and did not in sources:
                sources.append(did)
        try:
            inbox_did = int(data.get("inbox_dialog_id", 0) or 0)
        except Exception:
            inbox_did = 0
        try:
            events = max(0, int(data.get("events", 0) or 0))
        except Exception:
            events = 0
        self._mentions_hub = {
            "inbox_dialog_id": int(inbox_did if inbox_did < 0 else 0),
            "sources": sources,
            "events": int(events),
        }
        self._save_mentions_hub()

    def _save_mentions_hub(self):
        try:
            data = {
                "inbox_dialog_id": int((self._mentions_hub or {}).get("inbox_dialog_id", 0) or 0),
                "sources": [int(x) for x in list((self._mentions_hub or {}).get("sources", []) or []) if int(x) < 0],
                "events": max(0, int((self._mentions_hub or {}).get("events", 0) or 0)),
            }
            self._mentions_hub = data
            self.set_setting("tagged_mentions_hub_v1", json.dumps(data, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _mentions_hub_inbox_did(self):
        try:
            return int((self._mentions_hub or {}).get("inbox_dialog_id", 0) or 0)
        except Exception:
            return 0

    def _mentions_hub_sources(self):
        try:
            return [int(x) for x in list((self._mentions_hub or {}).get("sources", []) or []) if int(x) < 0]
        except Exception:
            return []

    def _mentions_hub_has_inbox(self):
        try:
            return int(self._mentions_hub_inbox_did() or 0) < 0
        except Exception:
            return False

    def _mentions_hub_has_source(self, dialog_id):
        try:
            return int(dialog_id or 0) in set(self._mentions_hub_sources())
        except Exception:
            return False

    def _mentions_hub_is_configured(self):
        try:
            did = int(self._mentions_hub_inbox_did() or 0)
            return did < 0
        except Exception:
            return False

    def _mentions_hub_find_existing_inbox(self, ignore_did=0):
        try:
            expected = str(self._tr("mentions_hub_group_name") or "").strip()
            if not expected:
                return 0
            mc = get_messages_controller()
            if mc is None:
                return 0
            dialogs = None
            try:
                dialogs = mc.getDialogs(0)
            except Exception:
                dialogs = getattr(mc, "allDialogs", None)
            if dialogs is None:
                return 0
            size = int(dialogs.size() if hasattr(dialogs, "size") else len(dialogs))
            best = 0
            ignored = int(ignore_did or 0)
            for i in range(size):
                try:
                    d = dialogs.get(i) if hasattr(dialogs, "get") else dialogs[i]
                except Exception:
                    d = None
                if d is None:
                    continue
                try:
                    did = int(getattr(d, "id", 0) or 0)
                except Exception:
                    did = 0
                if did >= 0:
                    continue
                if ignored < 0 and int(did) == ignored:
                    continue
                ch = self._chat_by_dialog_id(did)
                if ch is None:
                    continue
                title = str(getattr(ch, "title", "") or "").strip()
                if title == expected:
                    if best == 0 or abs(int(did)) > abs(int(best)):
                        best = int(did)
            return int(best)
        except Exception:
            return 0

    def _mentions_hub_resolve_inbox(self):
        try:
            did = int(self._mentions_hub_inbox_did() or 0)
            if did < 0:
                return did
            return 0
        except Exception:
            return 0

    def _mentions_hub_events_text(self):
        try:
            count = max(0, int((self._mentions_hub or {}).get("events", 0) or 0))
            if count <= 0:
                return self._tr("mentions_hub_total_empty")
            if count == 1:
                return self._tr("mentions_hub_total_one")
            return self._tr("mentions_hub_total_fmt").format(int(count))
        except Exception:
            return self._tr("mentions_hub_total_empty")

    def _load_admin_custom_actions(self):
        try:
            raw = self.get_setting("tagged_admin_custom_actions_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            out = []
            for it in (arr or []):
                if not isinstance(it, dict):
                    continue
                title = str(it.get("title", "") or "").strip()
                desc = str(it.get("description", "") or "").strip()
                cmd = str(it.get("command", "") or "").strip()
                cid = str(it.get("id", "") or "").strip()
                if not title or not cmd:
                    continue
                if not cid:
                    cid = "ac_{0}".format(int(time.time() * 1000))
                out.append({"id": cid, "title": title, "description": desc, "command": cmd})
            self._admin_custom_actions = out[:20]
            self._save_admin_custom_actions()
        except Exception:
            self._admin_custom_actions = []

    def _save_admin_custom_actions(self):
        try:
            self.set_setting("tagged_admin_custom_actions_v1", json.dumps(list(self._admin_custom_actions or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _dialog_to_chat_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did >= 0:
                return 0
            ad = abs(int(did))
            s = str(ad)
            if len(s) > 3 and s.startswith("100"):
                return int(s[3:])
            return int(ad)
        except Exception:
            return 0

    def _chat_by_dialog_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did >= 0:
                return None
            mc = get_messages_controller()
            if mc is None:
                return None
            cid = int(self._dialog_to_chat_id(did) or 0)
            if cid > 0:
                try:
                    ch = mc.getChat(int(cid))
                    if ch is not None:
                        return ch
                except Exception:
                    pass
            try:
                return mc.getChat(abs(int(did)))
            except Exception:
                return None
        except Exception:
            return None

    def _supports_group_settings_dialog(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did >= 0:
                return False
            ch = self._chat_by_dialog_id(did)
            if ch is None:
                return False
            is_mega = bool(getattr(ch, "megagroup", False))
            is_forum = bool(getattr(ch, "forum", False))
            is_broadcast = bool(getattr(ch, "broadcast", False))
            return bool(is_mega or is_forum or (not is_broadcast))
        except Exception:
            return False

    def _has_group_admin_access(self, dialog_id):
        try:
            ch = self._chat_by_dialog_id(dialog_id)
            if ch is None:
                return False
            if bool(getattr(ch, "creator", False)):
                return True
            rights = getattr(ch, "admin_rights", None)
            return bool(rights is not None)
        except Exception:
            return False

    def _group_chat_id(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            cid = int(self._dialog_to_chat_id(did) or 0)
            if cid > 0:
                return cid
            return abs(int(did))
        except Exception:
            return 0

    def _present_native_fragment(self, fragment):
        try:
            host = get_last_fragment()
            if host is None or fragment is None:
                return False
            host.presentFragment(fragment)
            return True
        except Exception:
            return False

    def _open_group_edit_native(self, dialog_id):
        try:
            cid = int(self._group_chat_id(dialog_id) or 0)
            if cid <= 0:
                return False
            Bundle = jclass("android.os.Bundle")
            ChatEditActivity = find_class("org.telegram.ui.ChatEditActivity")
            if ChatEditActivity is None:
                return False
            args = Bundle()
            args.putLong("chat_id", int(cid))
            return self._present_native_fragment(ChatEditActivity(args))
        except Exception:
            return False

    def _open_group_users_native(self, dialog_id, users_type):
        try:
            cid = int(self._group_chat_id(dialog_id) or 0)
            if cid <= 0:
                return False
            Bundle = jclass("android.os.Bundle")
            ChatUsersActivity = find_class("org.telegram.ui.ChatUsersActivity")
            if ChatUsersActivity is None:
                return False
            args = Bundle()
            args.putLong("chat_id", int(cid))
            args.putInt("type", int(users_type))
            return self._present_native_fragment(ChatUsersActivity(args))
        except Exception:
            return False

    def _group_members_count(self, dialog_id):
        try:
            ch = self._chat_by_dialog_id(dialog_id)
            try:
                cnt = int(getattr(ch, "participants_count", 0) or 0)
            except Exception:
                cnt = 0
            if cnt > 0:
                return cnt
            mc = get_messages_controller()
            cid = int(self._group_chat_id(dialog_id) or 0)
            if mc is not None and cid > 0:
                try:
                    full = mc.getChatFull(int(cid))
                except Exception:
                    full = None
                if full is not None:
                    try:
                        cnt = int(getattr(full, "participants_count", 0) or 0)
                    except Exception:
                        cnt = 0
                    if cnt > 0:
                        return cnt
                    try:
                        parts = getattr(full, "participants", None)
                        if parts is not None:
                            users = getattr(parts, "participants", None)
                            if users is not None:
                                return int(users.size() if hasattr(users, "size") else len(list(users)))
                    except Exception:
                        pass
            return 0
        except Exception:
            return 0

    def _open_group_settings_panel(self, dialog_id):
        try:
            if not self._supports_group_settings_dialog(dialog_id):
                BulletinHelper.show_info(self._tr("group_settings_group_only"))
                return False
            if not self._has_group_admin_access(dialog_id):
                BulletinHelper.show_info(self._tr("group_settings_no_admin"))
                return False

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("dialog_unavailable"))
                return False

            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView, FrameLayout
            from android.view import Gravity, View
            from android.util import TypedValue
            from android.graphics import Typeface
            from android.graphics import Color
            from android.graphics.drawable import GradientDrawable
            from org.telegram.ui.Components import BackupImageView, AvatarDrawable

            did = int(dialog_id or 0)
            title_txt = self._dialog_title_by_id(did) or self._tr("group_settings")
            chat_obj = self._chat_by_dialog_id(did)
            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_sep = self._theme_color("key_divider", 0x22384A62)
            c_bg = self._theme_color("key_dialogBackground", 0xFF1D2434)
            c_card = self._theme_color("key_dialogBackgroundGray", 0x1A2A3A52)
            c_arrow = self._theme_color("key_chat_emojiPanelIcon", 0xFF9AA8BA)

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setColor(c_bg)
                root_bg.setCornerRadius(float(AndroidUtilities.dp(22)))
                root.setBackground(root_bg)
            except Exception:
                pass

            head = LinearLayout(ctx)
            head.setOrientation(LinearLayout.HORIZONTAL)
            head.setGravity(Gravity.CENTER_VERTICAL)
            root.addView(head, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            avatar_wrap = FrameLayout(ctx)
            try:
                av_bg = GradientDrawable()
                av_bg.setColor(c_card)
                av_bg.setCornerRadius(float(AndroidUtilities.dp(24)))
                avatar_wrap.setBackground(av_bg)
            except Exception:
                pass
            lp_aw = LinearLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48))
            lp_aw.rightMargin = AndroidUtilities.dp(12)
            head.addView(avatar_wrap, lp_aw)

            avatar = BackupImageView(ctx)
            try:
                avatar.setRoundRadius(AndroidUtilities.dp(24))
                if chat_obj is not None:
                    avatar.setForUserOrChat(chat_obj, AvatarDrawable(chat_obj))
                else:
                    avatar.setImageDrawable(AvatarDrawable())
            except Exception:
                try:
                    avatar.setImageDrawable(AvatarDrawable())
                except Exception:
                    pass
            avatar_wrap.addView(avatar, FrameLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48), Gravity.CENTER))

            titles = LinearLayout(ctx)
            titles.setOrientation(LinearLayout.VERTICAL)
            head.addView(titles, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

            title = TextView(ctx)
            title.setText(str(title_txt))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            title.setTypeface(Typeface.DEFAULT_BOLD)
            title.setTextColor(c_title)
            titles.addView(title)

            members_count = int(self._group_members_count(did) or 0)
            subtitle = TextView(ctx)
            subtitle.setText(self._tr("group_members_count_fmt").format(int(members_count)))
            subtitle.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            subtitle.setTextColor(c_sub)
            lp_sub = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sub.topMargin = AndroidUtilities.dp(2)
            titles.addView(subtitle, lp_sub)

            desc = TextView(ctx)
            desc.setText(self._tr("group_settings_desc"))
            desc.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            desc.setTextColor(c_sub)
            desc.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(10))
            root.addView(desc, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            ChatUsersActivity = find_class("org.telegram.ui.ChatUsersActivity")
            type_admin = int(getattr(ChatUsersActivity, "TYPE_ADMIN", 1) if ChatUsersActivity is not None else 1)
            type_users = int(getattr(ChatUsersActivity, "TYPE_USERS", 2) if ChatUsersActivity is not None else 2)
            type_banned = int(getattr(ChatUsersActivity, "TYPE_BANNED", 0) if ChatUsersActivity is not None else 0)
            type_kicked = int(getattr(ChatUsersActivity, "TYPE_KICKED", 3) if ChatUsersActivity is not None else 3)

            def _add_row(icon_name, text, subtext, on_click):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                try:
                    row.setClickable(True)
                    row.setFocusable(True)
                    row_bg = GradientDrawable()
                    row_bg.setColor(c_card)
                    row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                    row.setBackground(row_bg)
                except Exception:
                    pass

                icon_shell = FrameLayout(ctx)
                try:
                    shell_bg = GradientDrawable()
                    shell_bg.setColor({
                        "msg_edit": Color.parseColor("#5A74D6"),
                        "msg_groups_solar": Color.parseColor("#44B89A"),
                        "msg_permissions": Color.parseColor("#6E58D6"),
                        "msg_block2": Color.parseColor("#C7A436"),
                        "msg_delete": Color.parseColor("#C55D6F"),
                    }.get(str(icon_name), self._theme_color("key_featuredStickers_addButton", 0xFF4D8DFF)))
                    shell_bg.setCornerRadius(float(AndroidUtilities.dp(21)))
                    icon_shell.setBackground(shell_bg)
                except Exception:
                    pass
                lp_shell = LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(42))
                lp_shell.rightMargin = AndroidUtilities.dp(14)
                row.addView(icon_shell, lp_shell)

                icon = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, icon_name, fallback="msg_permissions")
                if rid > 0:
                    icon.setImageResource(rid)
                try:
                    icon.setColorFilter(Color.WHITE)
                except Exception:
                    pass
                icon_shell.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20), Gravity.CENTER))

                tw = LinearLayout(ctx)
                tw.setOrientation(LinearLayout.VERTICAL)
                row.addView(tw, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

                t1 = TextView(ctx)
                t1.setText(text)
                t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                t1.setTypeface(Typeface.DEFAULT_BOLD)
                t1.setTextColor(c_title)
                tw.addView(t1)

                t2 = TextView(ctx)
                t2.setText(subtext)
                t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                t2.setTextColor(c_sub)
                tw.addView(t2)

                chev = ImageView(ctx)
                rid_chev = self._resolve_icon_res(ctx, "msg_arrowright", fallback="msg_arrowright")
                if rid_chev <= 0:
                    rid_chev = self._resolve_icon_res(ctx, "msg_arrow_forward", fallback="msg_arrow_forward")
                if rid_chev > 0:
                    chev.setImageResource(rid_chev)
                try:
                    chev.setColorFilter(c_arrow)
                except Exception:
                    pass
                row.addView(chev, LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18)))

                row.setOnClickListener(OnClickListener(lambda _v=None: (sheet.dismiss(), on_click())))
                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(10)
                root.addView(row, lp_row)

            _add_row(
                "msg_edit",
                self._tr("group_manage"),
                self._tr("group_manage_desc"),
                lambda: (self._open_group_edit_native(did) or BulletinHelper.show_info(self._tr("failed_open_group_manage"))),
            )
            _add_row(
                "msg_groups_solar",
                self._tr("group_members"),
                self._tr("group_members_desc"),
                lambda: (self._open_group_users_native(did, type_users) or BulletinHelper.show_info(self._tr("failed_open_group_members"))),
            )
            _add_row(
                "outline_shield_lock_24",
                self._tr("group_admins"),
                self._tr("group_admins_desc"),
                lambda: (self._open_group_users_native(did, type_admin) or BulletinHelper.show_info(self._tr("failed_open_group_admins"))),
            )
            _add_row(
                "msg_block2",
                self._tr("group_banned"),
                self._tr("group_banned_desc"),
                lambda: (self._open_group_users_native(did, type_banned) or BulletinHelper.show_info(self._tr("failed_open_group_banned"))),
            )
            _add_row(
                "msg_delete",
                self._tr("group_removed"),
                self._tr("group_removed_desc"),
                lambda: (self._open_group_users_native(did, type_kicked) or BulletinHelper.show_info(self._tr("failed_open_group_kicked"))),
            )

            sheet.setCustomView(root)
            sheet.show()
            return True
        except Exception as e:
            self._dlog("group settings panel fail: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_group_manage"))
            return False

    def _mentions_hub_open_inbox(self):
        try:
            did = int(self._mentions_hub_resolve_inbox() or 0)
            if did >= 0:
                BulletinHelper.show_info(self._tr("mentions_hub_not_configured"))
                return False
            if self._chat_by_dialog_id(did) is None:
                self._mentions_hub_invalidate_inbox()
                BulletinHelper.show_info(self._tr("mentions_hub_invalid_inbox"))
                return False
            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            args.putLong("chat_id", int(self._group_chat_id(did) or 0))
            ok = bool(self._present_native_fragment(ChatActivity(args)))
            if ok:
                try:
                    self._mentions_hub["events"] = 0
                    self._save_mentions_hub()
                except Exception:
                    pass
            return ok
        except Exception:
            BulletinHelper.show_info(self._tr("mentions_hub_open_failed"))
            return False

    def _mentions_hub_test_connection(self):
        try:
            did = int(self._mentions_hub_resolve_inbox() or 0)
            if did >= 0:
                BulletinHelper.show_info(self._tr("mentions_hub_not_configured"))
                return False
            if self._chat_by_dialog_id(did) is None:
                self._mentions_hub_invalidate_inbox()
                BulletinHelper.show_info(self._tr("mentions_hub_invalid_inbox"))
                return False
            ok = bool(self._send_warning_message(did, self._tr("mentions_hub_test_message"), parse_markdown_mode=False))
            if ok:
                BulletinHelper.show_success(self._tr("mentions_hub_test_sent"))
            else:
                BulletinHelper.show_info(self._tr("failed_send_command"))
            return ok
        except Exception:
            BulletinHelper.show_info(self._tr("failed_send_command"))
            return False

    def _mentions_hub_save_manual_group_id(self, raw_text):
        try:
            s = str(raw_text or "").strip()
            if not s:
                return bool(self._mentions_hub_delete_inbox())
            did = int(s)
            if did >= 0:
                did = -int("100{0}".format(int(did)))
            ch = self._chat_by_dialog_id(did)
            if ch is None or bool(getattr(ch, "broadcast", False)):
                BulletinHelper.show_info(self._tr("mentions_hub_invalid_group"))
                return False
            self._mentions_hub["inbox_dialog_id"] = int(did)
            self._save_mentions_hub()
            try:
                if callable(self._mentions_hub_sheet_refresh):
                    self._mentions_hub_sheet_refresh()
            except Exception:
                pass
            BulletinHelper.show_success(self._tr("mentions_hub_saved"))
            return True
        except Exception:
            BulletinHelper.show_info(self._tr("mentions_hub_invalid_group"))
            return False

    def _mentions_hub_delete_inbox(self):
        try:
            try:
                self._mentions_hub_create_ignore_did = int(self._mentions_hub_inbox_did() or 0)
            except Exception:
                self._mentions_hub_create_ignore_did = 0
            self._mentions_hub["inbox_dialog_id"] = 0
            self._mentions_hub["events"] = 0
            self._mentions_hub["sources"] = []
            self._save_mentions_hub()
            try:
                if callable(self._mentions_hub_sheet_refresh):
                    self._mentions_hub_sheet_refresh()
            except Exception:
                pass
            BulletinHelper.show_success(self._tr("mentions_hub_deleted"))
            return True
        except Exception:
            return False

    def _mentions_hub_invalidate_inbox(self):
        try:
            try:
                self._mentions_hub_create_ignore_did = int(self._mentions_hub_inbox_did() or 0)
            except Exception:
                self._mentions_hub_create_ignore_did = 0
            self._mentions_hub["inbox_dialog_id"] = 0
            self._mentions_hub["events"] = 0
            self._save_mentions_hub()
            try:
                if callable(self._mentions_hub_sheet_refresh):
                    self._mentions_hub_sheet_refresh()
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _mentions_hub_prompt_manual_group_id(self):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            from android.widget import LinearLayout
            from org.telegram.ui.Components import EditTextBoldCursor
            wrap = LinearLayout(ctx)
            wrap.setOrientation(1)
            wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(6))
            inp = EditTextBoldCursor(ctx)
            inp.setSingleLine(True)
            inp.setHint(self._tr("mentions_hub_manual_hint"))
            self._style_dialog_input(inp, multiline=False)
            cur = int(self._mentions_hub_inbox_did() or 0)
            if cur < 0:
                inp.setText(str(cur))
            wrap.addView(inp)
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("mentions_hub_manual_title"))
            b.set_message(self._tr("mentions_hub_manual_desc"))
            b.set_view(wrap)

            def _save(_d, _w):
                try:
                    raw = inp.getText().toString() if inp.getText() is not None else ""
                except Exception:
                    raw = ""
                if self._mentions_hub_save_manual_group_id(raw) and _d:
                    _d.dismiss()

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, _w: d.dismiss() if d else None)
            b.show()
            return True
        except Exception:
            return False

    def _mentions_hub_tag_current_group(self):
        try:
            if int(self._mentions_hub_resolve_inbox() or 0) >= 0:
                BulletinHelper.show_info(self._tr("mentions_hub_not_configured"))
                return False
            did = int(self._active_dialog_id() or 0)
            if not self._supports_group_settings_dialog(did):
                BulletinHelper.show_info(self._tr("mentions_hub_group_only"))
                return False
            if self._mentions_hub_has_source(did):
                BulletinHelper.show_info(self._tr("mentions_hub_source_exists"))
                return True
            arr = list(self._mentions_hub_sources())
            arr.append(int(did))
            self._mentions_hub["sources"] = arr
            self._save_mentions_hub()
            try:
                if callable(self._mentions_hub_sheet_refresh):
                    self._mentions_hub_sheet_refresh()
            except Exception:
                pass
            BulletinHelper.show_success(self._tr("mentions_hub_source_added"))
            return True
        except Exception:
            BulletinHelper.show_info(self._tr("mentions_hub_group_only"))
            return False

    def _mentions_hub_remove_source(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            self._mentions_hub["sources"] = [int(x) for x in list(self._mentions_hub_sources()) if int(x) != did]
            self._save_mentions_hub()
            try:
                if callable(self._mentions_hub_sheet_refresh):
                    self._mentions_hub_sheet_refresh()
            except Exception:
                pass
            BulletinHelper.show_success(self._tr("mentions_hub_source_removed"))
            return True
        except Exception:
            return False

    def _open_mentions_hub_sources_sheet(self):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("dialog_unavailable"))
                return False
            from org.telegram.ui.ActionBar import BottomSheet
            from android.widget import LinearLayout, TextView
            from android.util import TypedValue
            from android.graphics import Typeface
            from android.graphics.drawable import GradientDrawable

            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_bg = self._theme_color("key_dialogBackground", 0xFF1D2434)
            c_card = self._theme_color("key_dialogBackgroundGray", 0x1A2A3A52)
            c_action = self._theme_color("key_featuredStickers_addButton", 0xFF4D8DFF)
            c_action_text = self._theme_color("key_featuredStickers_buttonText", 0xFFFFFFFF)

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            bg = GradientDrawable()
            bg.setCornerRadius(float(AndroidUtilities.dp(22)))
            bg.setColor(c_bg)
            root.setBackground(bg)

            title = TextView(ctx)
            title.setText(self._tr("mentions_hub_sources_title"))
            title.setTypeface(Typeface.DEFAULT_BOLD)
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTextColor(c_title)
            root.addView(title)

            desc = TextView(ctx)
            desc.setText(self._tr("mentions_hub_sources_desc"))
            desc.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            desc.setTextColor(c_sub)
            lp_desc = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_desc.topMargin = AndroidUtilities.dp(6)
            root.addView(desc, lp_desc)

            body = LinearLayout(ctx)
            body.setOrientation(LinearLayout.VERTICAL)
            lp_body = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_body.topMargin = AndroidUtilities.dp(12)
            root.addView(body, lp_body)

            sources = [int(x) for x in self._mentions_hub_sources()]
            if not sources:
                empty = TextView(ctx)
                empty.setText(self._tr("mentions_hub_no_sources"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                empty.setTextColor(c_sub)
                body.addView(empty)
            else:
                for did in sources:
                    row = LinearLayout(ctx)
                    row.setOrientation(LinearLayout.HORIZONTAL)
                    row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                    row_bg = GradientDrawable()
                    row_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
                    row_bg.setColor(c_card)
                    row.setBackground(row_bg)

                    info = LinearLayout(ctx)
                    info.setOrientation(LinearLayout.VERTICAL)
                    lp_info = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    row.addView(info, lp_info)

                    t1 = TextView(ctx)
                    t1.setText(self._dialog_title_by_id(did) or self._tr("mentions_hub_group_only"))
                    t1.setTypeface(Typeface.DEFAULT_BOLD)
                    t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                    t1.setTextColor(c_title)
                    info.addView(t1)

                    t2 = TextView(ctx)
                    t2.setText(self._tr("id_fmt").format(int(did)))
                    t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    t2.setTextColor(c_sub)
                    lp_t2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_t2.topMargin = AndroidUtilities.dp(2)
                    info.addView(t2, lp_t2)

                    remove_btn = TextView(ctx)
                    remove_btn.setText(self._tr("mentions_hub_remove"))
                    remove_btn.setTypeface(Typeface.DEFAULT_BOLD)
                    remove_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    remove_btn.setTextColor(c_action_text)
                    remove_btn.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(9), AndroidUtilities.dp(14), AndroidUtilities.dp(9))
                    remove_bg = GradientDrawable()
                    remove_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                    remove_bg.setColor(c_action)
                    remove_btn.setBackground(remove_bg)
                    remove_btn.setOnClickListener(OnClickListener(lambda _v=None, _did=did: (self._mentions_hub_remove_source(_did), sheet.dismiss(), self._open_mentions_hub_sources_sheet())))
                    row.addView(remove_btn)

                    lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_row.topMargin = AndroidUtilities.dp(10)
                    body.addView(row, lp_row)

            sheet.setCustomView(root)
            sheet.show()
            return True
        except Exception:
            return False

    def _mentions_hub_create(self):
        try:
            if bool(self._mentions_hub_create_pending):
                BulletinHelper.show_info(self._tr("mentions_hub_creating_text"))
                return False
            if bool(self._mentions_hub_is_configured()) or int(self._mentions_hub_resolve_inbox() or 0) < 0:
                BulletinHelper.show_info(self._tr("mentions_hub_already_configured"))
                return False
            frag = get_last_fragment()
            if frag is None:
                BulletinHelper.show_info(self._tr("dialog_unavailable"))
                return False
            MC = jclass("org.telegram.messenger.MessagesController")
            UC = jclass("org.telegram.messenger.UserConfig")
            ChatObject = jclass("org.telegram.messenger.ChatObject")
            account = int(getattr(UC, "selectedAccount", 0) or 0)
            mc = MC.getInstance(account)
            req_id = int(mc.createChat(self._tr("mentions_hub_group_name"), ArrayList(), "", int(getattr(ChatObject, "CHAT_TYPE_MEGAGROUP", 4)), False, None, None, -1, frag) or 0)
            if req_id <= 0:
                BulletinHelper.show_info(self._tr("mentions_hub_create_failed"))
                return False
            try:
                current_did = int(self._mentions_hub_inbox_did() or 0)
            except Exception:
                current_did = 0
            if current_did < 0:
                self._mentions_hub_create_ignore_did = int(current_did)
            self._mentions_hub_create_pending = True
            self._mentions_hub_create_watchdog = True
            self._mentions_hub_watch_create_result()
            return True
        except Exception:
            BulletinHelper.show_info(self._tr("mentions_hub_create_failed"))
            return False

    def _open_mentions_hub_sheet(self):
        try:
            try:
                if self._mentions_hub_sheet_dialog is not None:
                    self._mentions_hub_sheet_dialog.dismiss()
            except Exception:
                pass
            self._mentions_hub_sheet_dialog = None
            self._mentions_hub_sheet_refresh = None
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("dialog_unavailable"))
                return False
            from org.telegram.ui.ActionBar import BottomSheet
            from android.widget import LinearLayout, TextView, ImageView, FrameLayout
            from android.graphics import Color
            from android.util import TypedValue
            from android.graphics import Typeface
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity, View

            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_bg = self._theme_color("key_dialogBackground", 0xFF1D2434)
            c_card = self._theme_color("key_dialogBackgroundGray", 0x1A2A3A52)
            c_primary = self._theme_color("key_featuredStickers_addButton", 0xFF4D8DFF)
            c_primary_text = self._theme_color("key_featuredStickers_buttonText", 0xFFFFFFFF)
            c_danger = self._theme_color("key_text_RedBold", 0xFFFF5D6E)

            def _add_btn(parent, title_key, subtext, on_click, primary=False, on_long=None):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(16)))
                bg.setColor(c_primary if primary else c_card)
                row.setBackground(bg)
                row.setClickable(True)
                row.setFocusable(True)

                t1 = TextView(ctx)
                t1.setText(self._tr(title_key))
                t1.setTypeface(Typeface.DEFAULT_BOLD)
                t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                t1.setTextColor(c_primary_text if primary else c_title)
                row.addView(t1)

                t2 = TextView(ctx)
                sub_val = str(subtext or "").strip()
                if sub_val:
                    t2.setText(sub_val)
                    t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    t2.setTextColor(c_primary_text if primary else c_sub)
                    lp_t2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_t2.topMargin = AndroidUtilities.dp(3)
                    row.addView(t2, lp_t2)

                row.setOnClickListener(OnClickListener(lambda _v=None: on_click()))
                if on_long is not None:
                    row.setOnLongClickListener(OnLongClickListener(lambda _v=None: (on_long(), True)[1]))

                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(10)
                parent.addView(row, lp)
                return row

            def _add_small_btn(parent, title_key, on_click, primary=False):
                btn = TextView(ctx)
                btn.setText(self._tr(title_key))
                btn.setTypeface(Typeface.DEFAULT_BOLD)
                btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                btn.setGravity(Gravity.CENTER)
                btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(11), AndroidUtilities.dp(16), AndroidUtilities.dp(11))
                bg_btn = GradientDrawable()
                bg_btn.setCornerRadius(float(AndroidUtilities.dp(14)))
                bg_btn.setColor(c_primary if primary else c_card)
                btn.setBackground(bg_btn)
                btn.setTextColor(c_primary_text if primary else c_title)
                btn.setClickable(True)
                btn.setFocusable(True)
                btn.setOnClickListener(OnClickListener(lambda _v=None: on_click()))
                lp_btn = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                parent.addView(btn, lp_btn)
                return btn

            def _add_icon_btn(parent, icon_name, on_click, tint_color):
                icon = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, icon_name, fallback="msg_delete_solar")
                if rid > 0:
                    icon.setImageResource(rid)
                try:
                    icon.setColorFilter(int(tint_color))
                except Exception:
                    try:
                        icon.setColorFilter(Color.parseColor("#FF5D6E"))
                    except Exception:
                        pass
                icon.setClickable(True)
                icon.setFocusable(True)
                icon.setOnClickListener(OnClickListener(lambda _v=None: on_click()))
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22))
                lp_icon.leftMargin = AndroidUtilities.dp(10)
                lp_icon.gravity = Gravity.CENTER_VERTICAL
                parent.addView(icon, lp_icon)
                return icon

            def _add_end_btn(parent, title_key, on_click):
                wrap = LinearLayout(ctx)
                wrap.setOrientation(LinearLayout.HORIZONTAL)
                wrap.setGravity(Gravity.END)
                lp_wrap = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_wrap.topMargin = AndroidUtilities.dp(12)
                parent.addView(wrap, lp_wrap)

                btn = TextView(ctx)
                btn.setText(self._tr(title_key))
                btn.setTypeface(Typeface.DEFAULT_BOLD)
                btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                btn.setGravity(Gravity.CENTER)
                btn.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(11), AndroidUtilities.dp(18), AndroidUtilities.dp(11))
                bg_btn = GradientDrawable()
                bg_btn.setCornerRadius(float(AndroidUtilities.dp(15)))
                bg_btn.setColor(c_primary)
                btn.setBackground(bg_btn)
                btn.setTextColor(c_primary_text)
                btn.setClickable(True)
                btn.setFocusable(True)
                btn.setOnClickListener(OnClickListener(lambda _v=None: on_click()))
                wrap.addView(btn)
                return btn

            def _add_main_action(parent, icon_name, title_key, subtext, on_click, on_long=None):
                card = LinearLayout(ctx)
                card.setOrientation(LinearLayout.HORIZONTAL)
                card.setGravity(Gravity.CENTER_VERTICAL)
                card.setClickable(True)
                card.setFocusable(True)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))
                bg_card = GradientDrawable()
                bg_card.setCornerRadius(float(AndroidUtilities.dp(18)))
                bg_card.setColor(c_primary)
