    def _hook_notification_center(self):
        try:
            if self._notification_refs:
                return
            cls = self._cache_notification_center_info()
            if cls is None:
                return
            for m in (cls.getDeclaredMethods() or []):
                try:
                    if str(m.getName() or "") != "postNotificationNameInternal":
                        continue
                    if len(list(m.getParameterTypes() or [])) != 3:
                        continue
                    try:
                        m.setAccessible(True)
                    except Exception:
                        pass
                    ref = self.hook_method(m, _NotificationHook(self), priority=2147483647)
                    if ref is not None:
                        self._notification_refs.append(ref)
                        break
                except Exception:
                    pass
        except Exception:
            pass

    def _find_declared_ctor(self, clazz, *params):
        try:
            ctor = clazz.getDeclaredConstructor(*params)
            ctor.setAccessible(True)
            return ctor
        except Exception:
            return None

    def _find_declared_method(self, clazz, name, *params):
        try:
            m = clazz.getDeclaredMethod(name, *params)
            m.setAccessible(True)
            return m
        except Exception:
            return None

    def _get_java_class(self, name):
        try:
            return jclass("java.lang.Class").forName(str(name))
        except Exception:
            return None

    def _setup_admin_tab_hooks(self):
        try:
            if self._admin_tab_hooks:
                return
            emoji_view = self._get_java_class("org.telegram.ui.Components.EmojiView")
            if emoji_view is None:
                self._dlog("admin_tab: EmojiView class not found")
                return
            bool_type = jclass("java.lang.Boolean").TYPE
            int_type = jclass("java.lang.Integer").TYPE
            float_type = jclass("java.lang.Float").TYPE
            base_fragment = self._get_java_class("org.telegram.ui.ActionBar.BaseFragment")
            resources_provider = self._get_java_class("org.telegram.ui.ActionBar.Theme$ResourcesProvider")
            chat_full = self._get_java_class("org.telegram.tgnet.TLRPC$ChatFull")
            context = self._get_java_class("android.content.Context")
            view_group = self._get_java_class("android.view.ViewGroup")

            ctor = self._find_declared_ctor(
                emoji_view,
                base_fragment,
                bool_type,
                bool_type,
                bool_type,
                context,
                bool_type,
                chat_full,
                view_group,
                bool_type,
                resources_provider,
                bool_type,
                bool_type,
            )
            if ctor is None:
                ctor = self._find_declared_ctor(
                    emoji_view,
                    base_fragment,
                    bool_type,
                    bool_type,
                    bool_type,
                    context,
                    bool_type,
                    chat_full,
                    view_group,
                    bool_type,
                    resources_provider,
                    bool_type,
                )
            if ctor is not None:
                r = self.hook_method(ctor, _AdminTabCtorHook(self))
                if r is not None:
                    self._admin_tab_hooks.append(r)
                    self._dlog("admin_tab: ctor hook exact ok")
            else:
                try:
                    for c in emoji_view.getDeclaredConstructors():
                        try:
                            c.setAccessible(True)
                        except Exception:
                            pass
                        try:
                            rr = self.hook_method(c, _AdminTabCtorHook(self))
                            if rr is not None:
                                self._admin_tab_hooks.append(rr)
                                self._dlog("admin_tab: ctor hook fallback ok")
                                break
                        except Exception:
                            pass
                except Exception:
                    pass

            set_allow = self._find_declared_method(emoji_view, "setAllow", bool_type, bool_type, bool_type)
            if set_allow is not None:
                r = self.hook_method(set_allow, _AdminTabSetAllowHook(self))
                if r is not None:
                    self._admin_tab_hooks.append(r)
                    self._dlog("admin_tab: setAllow hook ok")
                else:
                    self._dlog("admin_tab: setAllow hook returned None")
            else:
                self._dlog("admin_tab: setAllow method not found")

            check_grid = self._find_declared_method(emoji_view, "checkGridVisibility", int_type, float_type)
            if check_grid is not None:
                r = self.hook_method(check_grid, _AdminTabCheckGridHook(self))
                if r is not None:
                    self._admin_tab_hooks.append(r)
                    self._dlog("admin_tab: checkGridVisibility hook ok")
                else:
                    self._dlog("admin_tab: checkGridVisibility hook returned None")
            else:
                self._dlog("admin_tab: checkGridVisibility method not found")

            adapter_class = self._get_java_class("org.telegram.ui.Components.EmojiView$EmojiPagesAdapter")
            if adapter_class is not None:
                get_icon = self._find_declared_method(adapter_class, "getPageIconDrawable", int_type)
                if get_icon is not None:
                    r = self.hook_method(get_icon, _AdminTabGetIconHook(self))
                    if r is not None:
                        self._admin_tab_hooks.append(r)
                        self._dlog("admin_tab: getPageIconDrawable hook ok")
                    else:
                        self._dlog("admin_tab: getPageIconDrawable hook returned None")
                else:
                    self._dlog("admin_tab: getPageIconDrawable method not found")
                get_title = self._find_declared_method(adapter_class, "getPageTitle", int_type)
                if get_title is not None:
                    r = self.hook_method(get_title, _AdminTabGetTitleHook(self))
                    if r is not None:
                        self._admin_tab_hooks.append(r)
                        self._dlog("admin_tab: getPageTitle hook ok")
                    else:
                        self._dlog("admin_tab: getPageTitle hook returned None")
                else:
                    self._dlog("admin_tab: getPageTitle method not found")

            self._dlog("admin_tab: hooks installed={0}".format(len(self._admin_tab_hooks)))
            run_on_ui_thread(lambda: self._rebuild_admin_tab_current_emoji())
        except Exception:
            pass

    def _remove_admin_tab_hooks(self):
        try:
            for h in list(self._admin_tab_hooks or []):
                try:
                    self.unhook_method(h)
                except Exception:
                    pass
            self._admin_tab_hooks = []
            self._admin_tab_views = {}
        except Exception:
            pass

    def _schedule_admin_tab_rebuild(self, delay_ms=90):
        try:
            if bool(self._admin_tab_rebuild_pending):
                return
            self._admin_tab_rebuild_pending = True

            def _run():
                try:
                    self._admin_tab_rebuild_pending = False
                    self._rebuild_admin_tab_current_emoji()
                except Exception:
                    self._admin_tab_rebuild_pending = False

            try:
                AndroidUtilities.runOnUIThread(_run, int(delay_ms or 0))
            except Exception:
                run_on_ui_thread(_run)
        except Exception:
            pass

    def _schedule_admin_tab_refresh(self, delay_ms=120):
        try:
            if bool(self._admin_tab_refresh_pending):
                return
            self._admin_tab_refresh_pending = True

            def _run():
                try:
                    self._admin_tab_refresh_pending = False
                    self._refresh_admin_tab_view()
                except Exception:
                    self._admin_tab_refresh_pending = False

            try:
                AndroidUtilities.runOnUIThread(_run, int(delay_ms or 0))
            except Exception:
                run_on_ui_thread(_run)
        except Exception:
            pass

    def _is_admin_tab_pager_busy(self, emoji_view):
        try:
            pager = get_private_field(emoji_view, "pager")
            if pager is None:
                return False
            try:
                if bool(pager.isLayoutRequested()):
                    return True
            except Exception:
                pass
            try:
                if bool(pager.isInLayout()):
                    return True
            except Exception:
                pass
            return False
        except Exception:
            return False

    def _force_emoji_view_update(self, emoji_view):
        try:
            type_tabs = get_private_field(emoji_view, "typeTabs")
            pager = get_private_field(emoji_view, "pager")
            if pager is not None and pager.getAdapter() is not None:
                pager.getAdapter().notifyDataSetChanged()
                try:
                    pager.requestLayout()
                    pager.invalidate()
                except Exception:
                    pass
            if type_tabs is not None and pager is not None:
                methods = type_tabs.getClass().getMethods()
                for m in methods:
                    try:
                        if str(m.getName() or "") == "setViewPager" and len(m.getParameterTypes()) == 1:
                            m.invoke(type_tabs, pager)
                            break
                    except Exception:
                        pass
        except Exception:
            pass

    def _is_chat_dialog(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                return False
            return did < 0
        except Exception:
            return False

    def _active_dialog_id(self):
        try:
            frag = get_last_fragment()
            if frag is None or not hasattr(frag, "getDialogId"):
                return 0
            return int(frag.getDialogId() or 0)
        except Exception:
            return 0

    def _active_connect_chat_id(self):
        try:
            frag = get_last_fragment()
            cid = 0
            if frag is not None:
                for fn in ("chatId", "chat_id", "currentChatId"):
                    try:
                        v = int(_pf(frag, fn, 0) or 0)
                        if v > 0:
                            cid = v
                            break
                    except Exception:
                        pass
                if cid <= 0:
                    try:
                        ch = _pf(frag, "currentChat", None)
                        cid = int(getattr(ch, "id", 0) or 0) if ch is not None else 0
                    except Exception:
                        cid = 0
            if cid > 0:
                return -int("100{0}".format(int(cid)))
        except Exception:
            pass
        try:
            did = int(self._active_dialog_id() or 0)
            if did >= 0:
                return 0
            abs_did = abs(int(did))
            if abs_did >= 1000000000000:
                return int(did)
            return -int("100{0}".format(abs_did))
        except Exception:
            return 0

    def _set_admin_connect_pending(self, dialog_id):
        try:
            self._admin_connect_pending = {"did": int(dialog_id or 0), "ts": int(time.time())}
        except Exception:
            self._admin_connect_pending = {"did": 0, "ts": 0}

    def _is_admin_connect_pending(self, dialog_id):
        try:
            st = self._admin_connect_pending if isinstance(self._admin_connect_pending, dict) else {}
            did = int(st.get("did", 0) or 0)
            ts = int(st.get("ts", 0) or 0)
            if did == 0 or ts <= 0:
                return False
            if int(did) != int(dialog_id or 0):
                return False
            return int(time.time()) - ts <= 30
        except Exception:
            return False

    def _clear_admin_connect_pending(self):
        try:
            self._admin_connect_pending = {"did": 0, "ts": 0}
        except Exception:
            pass

    def _extract_connect_url_from_rose_msg(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            rm = getattr(mo, "reply_markup", None) if mo is not None else None
            rows = getattr(rm, "rows", None) if rm is not None else None
            if rows is not None:
                try:
                    rcount = int(rows.size())
                except Exception:
                    rcount = 0
                for ri in range(rcount):
                    try:
                        row = rows.get(ri)
                    except Exception:
                        row = None
                    if row is None:
                        continue
                    btns = getattr(row, "buttons", None)
                    if btns is None:
                        continue
                    try:
                        bcount = int(btns.size())
                    except Exception:
                        bcount = 0
                    for bi in range(bcount):
                        try:
                            b = btns.get(bi)
                        except Exception:
                            b = None
                        if b is None:
                            continue
                        url = str(getattr(b, "url", "") or "").strip()
                        if not url:
                            continue
                        low = url.lower()
                        if "start=connect_" in low and "t.me/" in low:
                            if low.startswith("http://") or low.startswith("https://"):
                                return url
                            return "https://" + url.lstrip("/")
            tx = str(self._message_text(msg_obj) or "")
            if tx:
                m = re.search(r"(?i)\b((?:https?://)?t\.me/[A-Za-z0-9_]+(?:\?start=connect_[^\s]+))", tx)
                if m:
                    u = str(m.group(1) or "").strip()
                    if u.lower().startswith("http://") or u.lower().startswith("https://"):
                        return u
                    return "https://" + u
            return ""
        except Exception:
            return ""

    def _admin_tab_send_connect(self):
        try:
            if self._admin_tab_commands_locked():
                BulletinHelper.show_info(self._tr("admin_tab_commands_locked_hint"))
                return
            did = int(self._active_dialog_id() or 0)
            self._dlog("admin_tab: connect click did={0}".format(int(did)))
            if not self._is_chat_dialog(did):
                self._dlog("admin_tab: connect blocked (not chat dialog)")
                BulletinHelper.show_info(self._tr("admin_tab_chat_only"))
                return
            ok = self._send_warning_message(int(did), "!connect", reply_to=None)
            try:
                if ok:
                    self._telemetry_queue_event("feature_use", feature="admin_tab_connect", count=1, force_flush=False)
            except Exception:
                pass
            self._dlog("admin_tab: connect command !connect sent ok={0}".format(bool(ok)))
            if ok:
                connect_chat_id = int(self._active_connect_chat_id() or 0)
                self._dlog("admin_tab: connect computed chat_id={0}".format(int(connect_chat_id)))
                if connect_chat_id != 0:
                    link = "https://t.me/MissRose_bot?start=connect_{0}".format(int(connect_chat_id))
                    self._dlog("admin_tab: connect open_url={0}".format(link))
                    try:
                        self.open_url(link)
                    except Exception:
                        self._set_admin_connect_pending(int(did))
                else:
                    self._set_admin_connect_pending(int(did))
            else:
                BulletinHelper.show_info(self._tr("admin_tab_connect_failed"))
        except Exception as e:
            self._dlog("admin_tab: connect exception: {0}".format(e))
            BulletinHelper.show_info(self._tr("admin_tab_connect_failed"))

    def _admin_tab_send_lock(self):
        try:
            if self._admin_tab_commands_locked():
                BulletinHelper.show_info(self._tr("admin_tab_commands_locked_hint"))
                return
            did = int(self._active_dialog_id() or 0)
            self._dlog("admin_tab: lock click did={0}".format(int(did)))
            if not self._is_chat_dialog(did):
                self._dlog("admin_tab: lock blocked (not chat dialog)")
                BulletinHelper.show_info(self._tr("admin_tab_chat_only"))
                return
            ok = self._send_warning_message(int(did), "!lock all", reply_to=None)
            try:
                if ok:
                    self._telemetry_queue_event("feature_use", feature="admin_tab_lock", count=1, force_flush=False)
            except Exception:
                pass
            self._dlog("admin_tab: lock send ok={0}".format(bool(ok)))
            if not ok:
                BulletinHelper.show_info(self._tr("failed_send_command"))
        except Exception as e:
            self._dlog("admin_tab: lock exception: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_send_command"))

