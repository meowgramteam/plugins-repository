            view = self._build_supporters_subfragment_view(ctx)
            if view is None:
                return
            it = UItem.asCustom(view)
            try:
                it.object2 = "__vanguard_supporters_subfragment__"
            except Exception:
                pass
            try:
                it.setTransparent(True)
            except Exception:
