            user_id_tv.setGravity(Gravity.CENTER)
            user_id_tv.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(3), AndroidUtilities.dp(8), AndroidUtilities.dp(3))
            try:
                user_id_tv.setTextColor(c_link)
                idbg = GradientDrawable()
                idbg.setCornerRadius(AndroidUtilities.dp(9))
                idbg.setColor(c_chip_bg)
                idbg.setStroke(AndroidUtilities.dp(1), c_chip_stroke)
                user_id_tv.setBackground(idbg)
            except Exception:
                pass
            user_row.addView(user_id_tv, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            info_id_btn = None
            if self._is_admin_mode():
                info_id_btn = ImageView(ctx)
                rid_info = self._resolve_icon_res(ctx, "msg_info", fallback="msg_info")
                if rid_info > 0:
                    info_id_btn.setImageResource(rid_info)
                try:
                    info_id_btn.setColorFilter(Theme.getColor(Theme.key_dialogTextLink))
                except Exception:
