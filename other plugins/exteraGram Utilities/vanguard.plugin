                lp_icon.topMargin = AndroidUtilities.dp(2)
                card.addView(icon, lp_icon)

                texts = LinearLayout(ctx)
                texts.setOrientation(LinearLayout.VERTICAL)
                lp_texts = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                lp_texts.leftMargin = AndroidUtilities.dp(10)
                card.addView(texts, lp_texts)

                title_reset = TextView(ctx)
                title_reset.setText(self._tr("mentions_hub_reset"))
                title_reset.setTypeface(Typeface.DEFAULT_BOLD)
                title_reset.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
