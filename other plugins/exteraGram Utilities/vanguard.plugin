    def _user_mode(self):
        try:
            runtime_mode = str(getattr(self, "_user_mode_runtime", "") or "").strip().lower()
            if runtime_mode in ("common", "admin"):
                return runtime_mode
            try:
                idx = int(self.get_setting("tagged_user_mode_selector", -1) or -1)
                if idx in (0, 1):
                    return "common" if idx == 1 else "admin"
            except Exception:
                pass
            try:
                force_common = self.get_setting("tagged_common_mode_enabled", None)
                if force_common is not None:
                    if isinstance(force_common, bool):
                        if force_common:
                            return "common"
                    elif isinstance(force_common, (int, float)):
                        if int(force_common) != 0:
                            return "common"
                    else:
                        if str(force_common).strip().lower() in ("1", "true", "yes", "on", "common"):
                            return "common"
            except Exception:
                pass
            m = str(self.get_setting("tagged_user_mode", "admin") or "admin").strip().lower()
            return "common" if m == "common" else "admin"
        except Exception:
            return "admin"

    def _is_admin_mode(self):
        return self._user_mode() == "admin"

    def _on_user_mode_selector_changed(self, idx=None):
        try:
            if idx is not None:
                i0 = int(idx)
                self._set_user_mode("common" if i0 == 1 else "admin")
                try:
                    self.reload_settings()
                except Exception:
                    pass
                try:
                    run_on_ui_thread(lambda: self.reload_settings())
                except Exception:
                    pass
        except Exception:
            pass

        def _sync_from_selector():
            try:
                i = int(self.get_setting("tagged_user_mode_selector", 0) or 0)
            except Exception:
                i = 0
            self._set_user_mode("common" if i == 1 else "admin")
            try:
                self.reload_settings()
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: self.reload_settings())
            except Exception:
                pass
        try:
            _sync_from_selector()
        except Exception:
            pass
        try:
            AndroidUtilities.runOnUIThread(_sync_from_selector, 80)
            AndroidUtilities.runOnUIThread(_sync_from_selector, 220)
        except Exception:
            pass

    def _set_user_mode(self, mode):
        try:
            m = "common" if str(mode or "").strip().lower() == "common" else "admin"
            try:
                self._user_mode_runtime = m
            except Exception:
                pass
            self.set_setting("tagged_user_mode", m)
            try:
                self.set_setting("tagged_user_mode_selector", 0 if m == "admin" else 1)
            except Exception:
                pass
            try:
                self.set_setting("tagged_common_mode_enabled", 1 if m == "common" else 0)
            except Exception:
                pass
        except Exception:
            pass

    def _open_user_mode_sheet(self):
        try:
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView
            from android.util import TypedValue
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
            title = TextView(ctx)
            title.setText(self._tr("settings_user_mode_title"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)
            sub = TextView(ctx)
            sub.setText(self._tr("settings_user_mode_info"))
            sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_sub = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sub.topMargin = AndroidUtilities.dp(6)
            lp_sub.bottomMargin = AndroidUtilities.dp(6)
            root.addView(sub, lp_sub)
            sheet.setCustomView(root)
            sheet.show()
            return True
        except Exception:
            return False

    def _get_uitem_setting_key(self, uitem):
        try:
            si = getattr(uitem, "settingItem", None)
            if not si:
                return None
            try:
                k = getattr(si, "key", None)
                if k:
                    return str(k)
            except Exception:
                pass
            try:
                m = si.getClass().getMethod("getKey")
                m.setAccessible(True)
                k = m.invoke(si)
                if k:
                    return str(k)
            except Exception:
                pass
            try:
                f = si.getClass().getDeclaredField("key")
                f.setAccessible(True)
                k = f.get(si)
                if k:
                    return str(k)
            except Exception:
                pass
        except Exception:
            pass
        return None

    def _inject_action_mode_slide(self, activity, items):
        try:
            from org.telegram.ui.Components import UItem
            from org.telegram.messenger import Utilities
            from java import dynamic_proxy, jarray, jclass

            insert_idx = -1
            rm = []
            for i in range(items.size()):
                try:
                    it = items.get(i)
                    key = self._get_uitem_setting_key(it)
                    if key == "tagged_action_mode_profile":
                        rm.append(i)
                        if insert_idx < 0:
                            insert_idx = i
                except Exception:
                    pass
            if insert_idx < 0:
                return
            for i in reversed(rm):
                try:
                    items.remove(i)
                except Exception:
                    pass

            try:
                current = int(self.get_setting("tagged_action_mode_profile", 0) or 0)
            except Exception:
                current = 0
            if current < 0:
                current = 0
            if current > 1:
                current = 1
            labels = [self._tr("action_mode_default"), self._tr("action_mode_pro")]
            CallbackInterface = Utilities.Callback
            String = jclass("java.lang.String")
            plugin = self

            class _ActionModeSlideCallback(dynamic_proxy(CallbackInterface)):
                def run(self_cb, value):
                    try:
                        v = int(str(value))
                    except Exception:
                        v = 0
                    if v < 0:
                        v = 0
                    if v > 1:
                        v = 1
                    try:
                        plugin.set_setting("tagged_action_mode_profile", v)
                    except Exception:
                        pass
                    try:
                        plugin.reload_settings()
                    except Exception:
                        pass

            slide_items = jarray(String)(labels)
            items.add(insert_idx, UItem.asSlideView(slide_items, current, _ActionModeSlideCallback()))
            try:
                items.add(insert_idx + 1, UItem.asShadow())
            except Exception:
                pass
        except Exception as e:
            self._dlog("inject action mode slide fail: {0}".format(e))

    def _create_shortcuts_subfragment(self, parent_view=None):
        items = []
        try:
            items.append(
                Divider(
