                    icon="menu_feature_links",
                    on_change=lambda _v=None: run_on_ui_thread(lambda: self.reload_settings()),
                )
            )
            if self._shortcuts_enabled():
                items.append(
                    Text(
                        text=self._tr("settings_manage_shortcuts"),
                        icon="msg_add",
                        on_click=lambda v=None: self._open_shortcuts_manager(),
                        on_long_click=lambda v=None: self._open_shortcuts_manager(),
                    )
                )
        except Exception as e:
            try:
                self._dlog("shortcuts subfragment fail: {0}".format(e))
            except Exception:
                pass
        return items

    def _logs_silent(self):
        try:
            v = self.get_setting("tagged_logs_silent", None)
            if v is None:
                return True
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            return bool(v)
        except Exception:
            return True

    def _show_loaded_bulletin_enabled(self):
        try:
            v = self.get_setting("tagged_show_loaded_bulletin", None)
            if v is None:
                return False
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            return bool(v)
        except Exception:
            return False

    def _native_log(self, text):
        try:
            if self._logs_silent():
                return
            log("[Tagged] {0}".format(str(text or "")))
        except Exception:
            pass

    def _jcolor(self, value):
        try:
            if hasattr(value, "intValue"):
                iv = value.intValue()
            else:
                iv = int(value)
            iv = iv & 0xFFFFFFFF
            if iv > 0x7FFFFFFF:
                iv -= 0x100000000
            return iv
        except Exception:
            return 0

    def _dlog(self, text):
        try:
            msg = str(text or "")
            ts = time.strftime("%H:%M:%S")
            full_msg = "[{0}][DEBUG] {1}".format(ts, msg)
            self._native_log(msg)
            self._log_buffer.append(full_msg)
            self._debug_logs.append(full_msg)
            if bool(getattr(self, "_live_log_enabled", False)):
                self._update_live_log(full_msg)
        except Exception:
            pass

    def _wlog(self, text):
        try:
            msg = str(text or "")
            ts = time.strftime("%H:%M:%S")
            full_msg = "[{0}][INFO] [Welcome] {1}".format(ts, msg)
            if not self._logs_silent():
                log("[Vanguard][Welcome] {0}".format(msg))
            self._log_buffer.append(full_msg)
            self._debug_logs.append(full_msg)
            if bool(getattr(self, "_live_log_enabled", False)):
                self._update_live_log(full_msg)
        except Exception:
            pass

    def _copy_text_to_clipboard(self, text):
        try:
            from android.content import Context, ClipData
            ctx = AndroidUtilities.getApplicationContext()
            if ctx is None:
                return False
            cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if cm is None:
                return False
            cm.setPrimaryClip(ClipData.newPlainText("vanguard_logs", str(text or "")))
            return True
        except Exception:
            return False

    def _remove_live_log(self, target_view=None):
        try:
            captured_view = target_view if target_view is not None else self._live_log_view
            def _rem():
                try:
                    if captured_view is not None:
                        par = captured_view.getParent()
                        if par is not None and hasattr(par, "removeView"):
                            par.removeView(captured_view)
                except Exception:
                    pass
                try:
                    if self._live_log_view is captured_view:
                        self._live_log_view = None
                        self._live_log_expanded = None
                        self._live_log_chip = None
                        self._log_text_view = None
                        self._log_scroll_view = None
                except Exception:
                    pass
            run_on_ui_thread(_rem)
        except Exception:
            pass

    def _set_live_log_enabled(self, enabled, host_ctx=None, prefer_collapsed=None):
        try:
            self._native_log("live_log set enabled={0} prefer_collapsed={1} host_ctx={2}".format(bool(enabled), prefer_collapsed, host_ctx is not None))
            self._live_log_enabled = bool(enabled)
            self.set_setting("vanguard_live_log", bool(enabled))
            if enabled and prefer_collapsed is not None:
                self._live_log_collapsed = bool(prefer_collapsed)
                self.set_setting("vanguard_live_log_collapsed", bool(prefer_collapsed))
            if not enabled:
                self._remove_live_log()
                try:
                    BulletinHelper.show_info(self._tr("live_log_disabled_bulletin"))
                except Exception:
                    pass
            else:
                try:
                    BulletinHelper.show_success(self._tr("live_log_enabled_bulletin"))
                except Exception:
                    pass
                self._show_live_log(host_ctx)
        except Exception:
            try:
                BulletinHelper.show_info(self._tr("live_log_toggle_failed_bulletin"))
            except Exception:
                pass
            pass

    def _toggle_live_log(self, host_ctx=None, prefer_collapsed=None):
        try:
            self._native_log("live_log toggle current={0} prefer_collapsed={1} host_ctx={2}".format(bool(getattr(self, "_live_log_enabled", False)), prefer_collapsed, host_ctx is not None))
            self._set_live_log_enabled(not bool(getattr(self, "_live_log_enabled", False)), host_ctx, prefer_collapsed)
        except Exception:
            pass

    def _clamp_live_log_margins(self, root=None):
        try:
            root = root or self._live_log_view
            if root is None:
                return
            par = root.getParent()
            if par is None:
                return
            lp = root.getLayoutParams()
            if lp is None:
                return
            dw = int(par.getWidth() or 0)
            dh = int(par.getHeight() or 0)
            w = int(lp.width or 0)
            h = int(lp.height or 0)
            if dw <= 0 or dh <= 0 or w <= 0 or h <= 0:
                return
            rm = int(getattr(lp, "rightMargin", 0) or 0)
            tm = int(getattr(lp, "topMargin", 0) or 0)
            lp.rightMargin = max(0, min(rm, dw - w))
            lp.topMargin = max(0, min(tm, dh - h))
            root.setLayoutParams(lp)
        except Exception:
            pass

    def _attach_live_log_drag_listener(self, target_view, drag_mode):
        try:
            from java import dynamic_proxy
            touch_cls = find_class("android.view.View$OnTouchListener")
            MotionEvent = jclass("android.view.MotionEvent")
            if touch_cls is None or target_view is None:
                return
            plugin = self

            class _Drag(dynamic_proxy(touch_cls)):
                def onTouch(self_obj, v, event):
                    try:
                        action = int(event.getActionMasked())
                        root = plugin._live_log_view
                        if root is None:
                            return False
                        par = root.getParent()
                        if par is None:
                            return False
                        lp = root.getLayoutParams()
                        if lp is None:
                            return False
                        dw = int(par.getWidth() or 0)
                        dh = int(par.getHeight() or 0)
                        if action == MotionEvent.ACTION_DOWN:
                            plugin._log_drag_moved = False
                            plugin._log_drag_sx = float(event.getRawX())
                            plugin._log_drag_sy = float(event.getRawY())
                            plugin._log_drag_rm0 = int(getattr(lp, "rightMargin", 0) or 0)
                            plugin._log_drag_tm0 = int(getattr(lp, "topMargin", 0) or 0)
                            return True
                        if action == MotionEvent.ACTION_MOVE:
                            dx = float(event.getRawX()) - plugin._log_drag_sx
                            dy = float(event.getRawY()) - plugin._log_drag_sy
                            if abs(dx) > 6 or abs(dy) > 6:
                                plugin._log_drag_moved = True
                            w = int(lp.width or 0)
                            h = int(lp.height or 0)
                            lp.rightMargin = max(0, min(int(plugin._log_drag_rm0 - dx), max(0, dw - w)))
                            lp.topMargin = max(0, min(int(plugin._log_drag_tm0 + dy), max(0, dh - h)))
                            root.setLayoutParams(lp)
                            return True
                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            if plugin._log_drag_moved:
                                plugin.set_setting("vanguard_live_log_rm", int(getattr(lp, "rightMargin", 0) or 0))
                                plugin.set_setting("vanguard_live_log_tm", int(getattr(lp, "topMargin", 0) or 0))
                            elif drag_mode == "chip" and action == MotionEvent.ACTION_UP:
                                plugin._set_live_log_collapsed(False)
                            return True
                    except Exception:
                        pass
                    return False

            target_view.setOnTouchListener(_Drag())
        except Exception:
            pass

    def _set_live_log_collapsed(self, collapsed):
        try:
            collapsed = bool(collapsed)
            self._live_log_collapsed = collapsed
            self.set_setting("vanguard_live_log_collapsed", collapsed)

            def _ui():
                try:
                    if self._live_log_view is None:
                        return
                    if self._live_log_expanded is not None:
                        self._live_log_expanded.setVisibility(jclass("android.view.View").GONE if collapsed else jclass("android.view.View").VISIBLE)
                    if self._live_log_chip is not None:
                        self._live_log_chip.setVisibility(jclass("android.view.View").VISIBLE if collapsed else jclass("android.view.View").GONE)
                    lp = self._live_log_view.getLayoutParams()
                    if lp is not None:
                        lp.width = AndroidUtilities.dp(48) if collapsed else AndroidUtilities.dp(272)
                        lp.height = AndroidUtilities.dp(48) if collapsed else AndroidUtilities.dp(204)
                        self._live_log_view.setLayoutParams(lp)
                        self._clamp_live_log_margins(self._live_log_view)
                except Exception:
                    pass
            run_on_ui_thread(_ui)
        except Exception:
            pass

    def _update_live_log(self, message):
        try:
            def _upd():
                try:
                    if self._log_text_view is None:
                        return
                    cur = str(self._log_text_view.getText() or "")
                    lines = cur.split("\n") if cur else []
                    if len(lines) > 20:
                        lines = lines[-20:]
                    new_text = ("\n".join(lines) + ("\n" if lines else "") + str(message or "")).strip()
                    self._log_text_view.setText(new_text)
                    if self._log_scroll_view is not None:
                        self._log_scroll_view.post(lambda: self._log_scroll_view.fullScroll(jclass("android.view.View").FOCUS_DOWN))
                except Exception:
                    pass
            run_on_ui_thread(_upd)
        except Exception:
            pass

    def _show_live_log(self, host_ctx=None):
        try:
            from java import dynamic_proxy
            from org.telegram.messenger import ApplicationLoader
            self._native_log("live_log show start host_ctx={0}".format(host_ctx is not None))
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None and host_ctx is not None and hasattr(host_ctx, "getWindow"):
                ctx = host_ctx
            if ctx is None:
                self._native_log("live_log show abort: ctx unavailable")
                try:
                    BulletinHelper.show_info(self._tr("live_log_ctx_unavailable_bulletin"))
                except Exception:
                    pass
                return
            self._native_log("live_log show ctx resolved")
            if self._live_log_view is not None:
                try:
                    par = self._live_log_view.getParent()
                    if par is None:
                        self._native_log("live_log stale view detected, resetting refs")
                        self._live_log_view = None
                        self._live_log_expanded = None
                        self._live_log_chip = None
                        self._log_text_view = None
                        self._log_scroll_view = None
                    else:
                        self._native_log("live_log show skipped: already attached")
                        try:
                            BulletinHelper.show_info(self._tr("live_log_attached_bulletin"))
                        except Exception:
                            pass
                        return
                except Exception:
                    self._live_log_view = None
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            FrameLayout = jclass("android.widget.FrameLayout")
            ImageView = jclass("android.widget.ImageView")
            ScrollView = jclass("android.widget.ScrollView")
            View = jclass("android.view.View")
            Gravity = jclass("android.view.Gravity")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            PorterDuff = jclass("android.graphics.PorterDuff")
            listener_cls = find_class("android.view.View$OnClickListener")
            long_listener_cls = find_class("android.view.View$OnLongClickListener")
            collapsed = bool(getattr(self, "_live_log_collapsed", False))
            root = FrameLayout(ctx)
            expanded = LinearLayout(ctx)
            expanded.setOrientation(LinearLayout.VERTICAL)
            bg = GradientDrawable()
            bg.setColor(self._jcolor(0xAA000000))
            bg.setCornerRadius(float(AndroidUtilities.dp(10)))
            expanded.setBackground(bg)
            expanded.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
            header_row = LinearLayout(ctx)
            header_row.setOrientation(LinearLayout.HORIZONTAL)
            header_row.setGravity(Gravity.CENTER_VERTICAL)
            header = TextView(ctx)
            header.setText(self._tr("live_log_title"))
            header.setTextSize(11)
            header.setTypeface(None, 1)
            header.setTextColor(self._jcolor(0xFF8BE28B))
            header_row.addView(header, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))
            min_btn = TextView(ctx)
            min_btn.setText("")
            min_btn.setTextSize(18)
            min_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            try:
                min_btn.setContentDescription(self._tr("live_log_minimize"))
            except Exception:
                pass
            try:
                res = ApplicationLoader.applicationContext.getResources()
                pkg = ApplicationLoader.applicationContext.getPackageName()
                min_id = res.getIdentifier("ic_ab_new", "drawable", pkg)
                if min_id:
                    dr = res.getDrawable(int(min_id))
                    dr.setColorFilter(self._jcolor(0xFFBBBBBB), PorterDuff.Mode.SRC_IN)
                    min_btn.setCompoundDrawablesWithIntrinsicBounds(dr, None, None, None)
            except Exception:
                min_btn.setText("-")
                min_btn.setTextColor(self._jcolor(0xFFBBBBBB))
            if listener_cls is not None:
                min_btn.setOnClickListener(OnClickListener(lambda _v=None: self._set_live_log_collapsed(True)))
            header_row.addView(min_btn)
            expanded.addView(header_row)
            scroll = ScrollView(ctx)
            self._log_scroll_view = scroll
            log_tv = TextView(ctx)
            log_tv.setTextSize(9)
            log_tv.setTextColor(self._jcolor(0xFFE8E8E8))
            log_tv.setText("\n".join(list(self._log_buffer or [])))
            try:
                log_tv.setMinimumHeight(AndroidUtilities.dp(148))
                log_tv.setClickable(True)
            except Exception:
                pass
            self._log_text_view = log_tv
            scroll.addView(log_tv)
            if listener_cls is not None:
                log_tv.setOnClickListener(OnClickListener(lambda _v=None: (self._copy_text_to_clipboard(str(log_tv.getText() or "").strip()) and BulletinHelper.show_info(self._tr("log_copied_clipboard")))))
            if long_listener_cls is not None:
                class _ClearLogs(dynamic_proxy(long_listener_cls)):
                    def onLongClick(self_obj, _v):
                        try:
                            self._log_buffer.clear()
                            if self._log_text_view is not None:
                                self._log_text_view.setText("")
                            BulletinHelper.show_info(self._tr("log_cleared"))
                            return True
                        except Exception:
                            return False
                log_tv.setOnLongClickListener(_ClearLogs())
            expanded.addView(scroll, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(148)))
            self._live_log_expanded = expanded

            chip = FrameLayout(ctx)
            chip_bg = GradientDrawable()
            chip_bg.setColor(self._jcolor(0xDD101010))
            chip_bg.setCornerRadius(float(AndroidUtilities.dp(24)))
            chip.setBackground(chip_bg)
            chip.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            log_icon = ImageView(ctx)
            try:
                res = ApplicationLoader.applicationContext.getResources()
                pkg = ApplicationLoader.applicationContext.getPackageName()
                lid = res.getIdentifier("device_phone_ios", "drawable", pkg)
                if not lid:
                    lid = res.getIdentifier("msg_log", "drawable", pkg)
                if lid:
                    log_icon.setImageResource(int(lid))
                    log_icon.setColorFilter(self._jcolor(0xFFE24444), PorterDuff.Mode.SRC_IN)
            except Exception:
                pass
            chip.addView(log_icon, FrameLayout.LayoutParams(AndroidUtilities.dp(30), AndroidUtilities.dp(30), Gravity.CENTER))
            self._live_log_chip = chip
            expanded.setVisibility(View.GONE if collapsed else View.VISIBLE)
            chip.setVisibility(View.VISIBLE if collapsed else View.GONE)
            root.addView(expanded, FrameLayout.LayoutParams(-1, -1, Gravity.TOP | Gravity.LEFT))
            root.addView(chip, FrameLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48), Gravity.TOP | Gravity.RIGHT))
            window = ctx.getWindow() if hasattr(ctx, "getWindow") else None
            decor = window.getDecorView() if window is not None else None
            if decor is None or not hasattr(decor, "addView"):
                self._native_log("live_log show abort: decor unavailable")
                try:
                    BulletinHelper.show_info(self._tr("live_log_decor_unavailable_bulletin"))
                except Exception:
                    pass
                return
            self._native_log("live_log decor resolved")
            tw = AndroidUtilities.dp(48) if collapsed else AndroidUtilities.dp(272)
            th = AndroidUtilities.dp(48) if collapsed else AndroidUtilities.dp(204)
            dw = int(decor.getWidth() or 0) or AndroidUtilities.dp(360)
            dh = int(decor.getHeight() or 0) or AndroidUtilities.dp(720)
            rm = self.get_setting("vanguard_live_log_rm", None)
            tm = self.get_setting("vanguard_live_log_tm", None)
            rm = AndroidUtilities.dp(10) if rm is None else int(rm)
            tm = AndroidUtilities.dp(60) if tm is None else int(tm)
            rm = max(0, min(rm, dw - tw))
            tm = max(0, min(tm, dh - th))
            lp = FrameLayout.LayoutParams(tw, th)
            lp.gravity = Gravity.TOP | Gravity.RIGHT
            lp.topMargin = tm
            lp.rightMargin = rm
            decor.addView(root, lp)
            self._live_log_view = root
            try:
                self._set_live_log_collapsed(collapsed)
            except Exception:
                pass
            try:
                root.setVisibility(View.VISIBLE)
            except Exception:
                pass
            try:
                expanded.setVisibility(View.GONE if collapsed else View.VISIBLE)
            except Exception:
                pass
            try:
                chip.setVisibility(View.VISIBLE if collapsed else View.GONE)
            except Exception:
                pass
            try:
                root.bringToFront()
            except Exception:
                pass
            try:
                chip.bringToFront()
            except Exception:
                pass
            try:
                root.requestLayout()
                root.invalidate()
            except Exception:
                pass
            try:
                if hasattr(root, "setElevation"):
                    root.setElevation(float(AndroidUtilities.dp(24)))
                if hasattr(chip, "setElevation"):
                    chip.setElevation(float(AndroidUtilities.dp(26)))
            except Exception:
                pass
            self._native_log("live_log overlay added collapsed={0} top={1} right={2} w={3} h={4}".format(collapsed, tm, rm, tw, th))
            try:
                BulletinHelper.show_success(self._tr("live_log_added_bulletin"))
            except Exception:
                pass
            self._attach_live_log_drag_listener(chip, "chip")
            self._attach_live_log_drag_listener(header_row, "header")
            try:
                decor.post(lambda: self._clamp_live_log_margins(root))
            except Exception:
                pass
        except Exception as e:
            try:
                self._native_log("live_log show failed: {0}".format(e))
                BulletinHelper.show_info(self._tr("live_log_show_failed_bulletin").format(str(e)))
            except Exception:
                pass
            pass

    def _auto_delete_rose_info(self):
        try:
            v = self.get_setting("tagged_auto_delete_rose_info", True)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            return bool(v)
        except Exception:
            return True

    def _quick_panel_enabled(self):
        try:
            if not self._is_admin_mode():
                return False
            idx = int(self.get_setting("tagged_quick_panel_mode", 0) or 0)
            return idx == 0
        except Exception:
            return True

    def _action_mode_is_pro(self):
        try:
            idx = int(self.get_setting("tagged_action_mode_profile", 0) or 0)
            return idx == 1
        except Exception:
            return False

    def _on_plugin_language_changed(self):
        try:
            self._lang_code_cache = None
        except Exception:
            pass
        try:
            run_on_ui_thread(lambda: self.reload_settings())
        except Exception:
            try:
                self.reload_settings()
            except Exception:
                pass

    def _load_admin_stats(self):
        try:
            raw = self.get_setting("tagged_admin_stats_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
            self._admin_stats = data if isinstance(data, dict) else {}
        except Exception:
            self._admin_stats = {}

    def _stats_opt_in_enabled(self):
        try:
            v = self.get_setting("tagged_stats_opt_in", True)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            return bool(v)
        except Exception:
            return False

    def _admin_tab_nowfy_compat_enabled(self):
        try:
            v = self.get_setting("tagged_admin_tab_nowfy_compat", True)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            return bool(v)
        except Exception:
            return True

    def _telemetry_track_opt_in_transition(self):
        try:
            cur = bool(self._stats_opt_in_enabled())
            prev_raw = self.get_setting("tagged_stats_opt_in_prev_state_v1", None)
            if prev_raw is None:
                self.set_setting("tagged_stats_opt_in_prev_state_v1", bool(cur))
                if cur:
                    self._telemetry_queue_event("opt_in_enabled", feature="", count=1, force_flush=True)
                    self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                    if not bool(self.get_setting("tagged_stats_install_event_sent_v1", False)):
                        self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                        self.set_setting("tagged_stats_install_event_sent_v1", True)
                return
            prev = bool(prev_raw)
            if cur and (not prev):
                self._telemetry_queue_event("opt_in_enabled", feature="", count=1, force_flush=True)
                self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                if not bool(self.get_setting("tagged_stats_install_event_sent_v1", False)):
                    self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                    self.set_setting("tagged_stats_install_event_sent_v1", True)
            self.set_setting("tagged_stats_opt_in_prev_state_v1", bool(cur))
        except Exception:
            pass

    def _load_telemetry_queue(self):
        try:
            raw = self.get_setting("tagged_stats_queue_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            self._telemetry_queue = arr if isinstance(arr, list) else []
        except Exception:
            self._telemetry_queue = []

    def _save_telemetry_queue(self):
        try:
            self.set_setting("tagged_stats_queue_v1", json.dumps(list(self._telemetry_queue or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _schedule_telemetry_queue_persist(self, delay_ms=1200):
        try:
            now_ms = int(time.time() * 1000)
            with self._telemetry_lock:
                self._telemetry_persist_due_ts = max(int(self._telemetry_persist_due_ts or 0), now_ms + int(delay_ms or 0))
                if self._telemetry_persist_scheduled:
                    return
                self._telemetry_persist_scheduled = True

            def _worker():
                try:
                    while True:
                        with self._telemetry_lock:
                            due_ts = int(self._telemetry_persist_due_ts or 0)
                        wait_ms = int(due_ts - int(time.time() * 1000))
                        if wait_ms <= 0:
                            break
                        time.sleep(float(min(wait_ms, 250)) / 1000.0)
                    self._save_telemetry_queue()
                except Exception:
                    pass
                finally:
                    reschedule = False
                    with self._telemetry_lock:
                        self._telemetry_persist_scheduled = False
                        if int(self._telemetry_persist_due_ts or 0) > int(time.time() * 1000):
                            reschedule = True
                    if reschedule:
                        self._schedule_telemetry_queue_persist(0)

            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            try:
                self._save_telemetry_queue()
            except Exception:
                pass

    def _telemetry_install_id_get(self):
        try:
            if self._telemetry_install_id:
                return str(self._telemetry_install_id)
            cached = str(self.get_setting("tagged_stats_install_id", "") or "").strip()
            if cached:
                self._telemetry_install_id = cached
                return cached
            sid = "vgd_{0:x}{1:x}".format(int(time.time() * 1000), random.randint(0, 0xFFFFFF))
            self.set_setting("tagged_stats_install_id", sid)
            self._telemetry_install_id = sid
            return sid
        except Exception:
            return "vgd_unknown"

    def _telemetry_app_snapshot(self):
        out = {
            "app_id": "unknown",
            "app_variant": "unknown",
            "app_version": "unknown",
            "plugin_version": str(__version__),
            "mode": "admin" if self._is_admin_mode() else "common",
        }
        try:
            from org.telegram.messenger import ApplicationLoader
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return out
            pkg = str(ctx.getPackageName() or "unknown").strip() or "unknown"
            out["app_id"] = pkg
            l = pkg.lower()
            if "ayu" in l:
                out["app_variant"] = "ayugram"
            elif "extera" in l:
                out["app_variant"] = "exteragram"
            else:
                out["app_variant"] = "telegram_mod"
            try:
                pm = ctx.getPackageManager()
                pi = pm.getPackageInfo(pkg, 0)
                out["app_version"] = str(getattr(pi, "versionName", "") or getattr(pi, "versionCode", "unknown"))
            except Exception:
                pass
        except Exception:
            pass
        return out

    def _telemetry_queue_event(self, event_name, feature=None, count=1, force_flush=False):
        try:
            if not self._stats_opt_in_enabled():
                return
            name = str(event_name or "").strip()
            if not name:
                return
            ev = {
                "ts": int(time.time()),
                "event": name,
                "feature": str(feature or "").strip(),
                "count": int(count or 1),
            }
            with self._telemetry_lock:
                q = list(self._telemetry_queue or [])
                q.append(ev)
                if len(q) > 220:
                    q = q[-220:]
                self._telemetry_queue = q
            if force_flush:
                self._save_telemetry_queue()
            else:
                self._schedule_telemetry_queue_persist()
            now_ts = int(time.time())
            if force_flush or (now_ts - int(self._telemetry_last_flush_ts or 0) >= 20):
                self._telemetry_flush_async()
        except Exception:
            pass

    def _telemetry_flush_async(self):
        try:
            if not self._stats_opt_in_enabled():
                return
            with self._telemetry_lock:
                if self._telemetry_sending:
                    return
                queue = list(self._telemetry_queue or [])
                if not queue:
                    return
                self._telemetry_sending = True
            install_id = self._telemetry_install_id_get()
            app = self._telemetry_app_snapshot()
            payload = {
                "plugin": "vanguard",
                "install_id": install_id,
                "sent_at": int(time.time()),
                "app": app,
                "events": queue[:120],
            }

            def _worker():
                ok = False
                try:
                    ok = self._telemetry_post(payload)
                except Exception:
                    ok = False
                try:
                    with self._telemetry_lock:
                        if ok:
                            cur = list(self._telemetry_queue or [])
                            drop = min(len(cur), len(payload.get("events", []) or []))
                            self._telemetry_queue = cur[drop:]
                            self._telemetry_last_flush_ts = int(time.time())
                            self._save_telemetry_queue()
                        self._telemetry_sending = False
                except Exception:
                    try:
                        self._telemetry_sending = False
                    except Exception:
                        pass

            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            try:
                self._telemetry_sending = False
            except Exception:
                pass

    def _telemetry_post(self, payload):
        try:
            raw = json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
            headers = {
                "User-Agent": "VanguardStats/1.0",
                "Content-Type": "application/json",
                "Cache-Control": "no-cache",
            }
            token = str(GEEKSTATS_INGEST_TOKEN or "").strip()
            if token:
                headers["X-Ingest-Token"] = token
            req = Request(GEEKSTATS_INGEST_URL, data=raw, headers=headers, method="POST")
            with urlopen(req, timeout=6) as resp:
                code = int(getattr(resp, "status", 200) or 200)
                return 200 <= code < 300
        except Exception as e:
            self._dlog("stats post fail: {0}".format(e))
            return False

    def _save_admin_stats(self):
        try:
            self.set_setting("tagged_admin_stats_v1", json.dumps(self._admin_stats, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _schedule_admin_stats_persist(self, delay_ms=1500):
        try:
            now_ms = int(time.time() * 1000)
            with self._admin_stats_persist_lock:
                self._admin_stats_persist_due_ts = max(int(self._admin_stats_persist_due_ts or 0), now_ms + int(delay_ms or 0))
                if self._admin_stats_persist_scheduled:
                    return
                self._admin_stats_persist_scheduled = True

            def _worker():
                try:
                    while True:
                        with self._admin_stats_persist_lock:
                            due_ts = int(self._admin_stats_persist_due_ts or 0)
                        wait_ms = int(due_ts - int(time.time() * 1000))
                        if wait_ms <= 0:
                            break
                        time.sleep(float(min(wait_ms, 250)) / 1000.0)
                    self._save_admin_stats()
                except Exception:
                    pass
                finally:
                    reschedule = False
                    with self._admin_stats_persist_lock:
                        self._admin_stats_persist_scheduled = False
                        if int(self._admin_stats_persist_due_ts or 0) > int(time.time() * 1000):
                            reschedule = True
                    if reschedule:
                        self._schedule_admin_stats_persist(0)

            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            try:
                self._save_admin_stats()
            except Exception:
                pass

    def _stats_touch(self, uid, key):
        try:
            k = str(int(uid))
            rec = self._admin_stats.get(k, {})
            if not isinstance(rec, dict):
                rec = {}
            rec["name"] = self._user_name(uid)
            rec["username"] = self._user_username(uid)
            rec[key] = int(rec.get(key, 0) or 0) + 1
            rec["updated_at"] = int(time.time())
            self._admin_stats[k] = rec
            self._schedule_admin_stats_persist()
            try:
                self._telemetry_queue_event("feature_use", feature=str(key or ""), count=1, force_flush=False)
            except Exception:
                pass
        except Exception:
            pass

    def _style_dialog_input(self, view, multiline=False):
        try:
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable
            from android.graphics import Color
            text_c = 0xFFF2F5FA
            hint_c = 0xFFA6B0BE
            bg_c = 0xFF223043
            stroke_c = 0xFF6C7B8E
            try:
                bg_c = int(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                pass
            try:
                text_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                try:
                    text_c = int(Theme.getColor(Theme.key_dialogTextBlack))
                except Exception:
                    pass
            try:
                hint_c = int(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            try:
                stroke_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText4))
            except Exception:
                pass

            br = (bg_c >> 16) & 0xFF
            bg = (bg_c >> 8) & 0xFF
            bb = bg_c & 0xFF
            tr = (text_c >> 16) & 0xFF
            tg = (text_c >> 8) & 0xFF
            tb = text_c & 0xFF
            bg_l = (0.299 * br) + (0.587 * bg) + (0.114 * bb)
            tx_l = (0.299 * tr) + (0.587 * tg) + (0.114 * tb)
            if bg_l < 110 and tx_l < 130:
                text_c = 0xFFF2F5FA
                hint_c = 0xFFA6B0BE
                stroke_c = 0xFF6C7B8E

            view.setTextColor(text_c)
            view.setHintTextColor(hint_c)
            try:
                view.setCursorColor(Theme.getColor(Theme.key_dialogTextLink))
            except Exception:
                pass
            bg = GradientDrawable()
            bg.setCornerRadius(AndroidUtilities.dp(12))
            bg.setColor(bg_c)
            bg.setStroke(AndroidUtilities.dp(1), stroke_c)
            view.setBackground(bg)
            if multiline:
                view.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
        except Exception:
            pass

    def _theme_color(self, key_name, fallback):
        try:
            from org.telegram.ui.ActionBar import Theme
            return int(Theme.getColor(getattr(Theme, str(key_name))))
        except Exception:
            return int(fallback)

    def _is_dark_color(self, color_int):
        try:
            c = int(color_int) & 0xFFFFFFFF
            r = (c >> 16) & 0xFF
            g = (c >> 8) & 0xFF
            b = c & 0xFF
            lum = (0.299 * r) + (0.587 * g) + (0.114 * b)
            return lum < 140.0
        except Exception:
            return True

    def _invalidate_draw_cache(self):
        try:
            self._latest_cache = {}
            self._msg_tag_cache = {}
            self._tag_hit_regions = {}
            self._tag_hit_regions_last_prune_ts = 0
            self._tags_rev = int(self._tags_rev) + 1
        except Exception:
            self._latest_cache = {}
            self._msg_tag_cache = {}
            self._tag_hit_regions = {}
            self._tag_hit_regions_last_prune_ts = 0

