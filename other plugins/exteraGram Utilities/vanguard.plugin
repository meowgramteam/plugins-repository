    def _download_asset(self, url, out_path):
        try:
            if not url or not out_path:
                return False
            os.makedirs(os.path.dirname(out_path), exist_ok=True)
            req = Request(str(url), headers={"User-Agent": "Vanguard/1.0"})
            with urlopen(req, timeout=12) as resp:
                data = resp.read()
            if not data:
                return False
            with open(out_path, "wb") as f:
                f.write(data)
            return True
        except Exception as e:
            self._dlog("asset download fail {0}: {1}".format(str(url), e))
            return False

    def _ensure_settings_header_assets(self):
        try:
            now = int(time.time())
            if int(now - int(self._assets_last_sync_ts or 0)) < 300:
                return
            if bool(self._assets_syncing):
                return
            self._assets_last_sync_ts = now
            self._assets_syncing = True

            def _worker():
                try:
                    bust = str(int(time.time() / 60))
                    targets = [
                        ("{0}?v={1}".format(HEADER_IMAGE_URL_DARK, bust), HEADER_IMAGE_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(HEADER_IMAGE_URL_LIGHT, bust), HEADER_IMAGE_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(SUPPORT_ICON_URL, bust), SUPPORT_ICON_CACHE_FILE),
                        ("{0}?v={1}".format(TOP_ICON_URL_DARK, bust), TOP_ICON_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(TOP_ICON_URL_LIGHT, bust), TOP_ICON_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(SPONSOR_ICON_URL, bust), SPONSOR_ICON_CACHE_FILE),
                        ("{0}?v={1}".format(SPONSOR_BANNER_URL, bust), SPONSOR_BANNER_CACHE_FILE),
                        ("{0}?v={1}".format(EXTENDED_ICON_URL_DARK, bust), EXTENDED_ICON_CACHE_FILE_DARK),
                        ("{0}?v={1}".format(EXTENDED_ICON_URL_LIGHT, bust), EXTENDED_ICON_CACHE_FILE_LIGHT),
                        ("{0}?v={1}".format(ABOUT_AVATAR_URL, bust), ABOUT_AVATAR_CACHE_FILE),
                    ]
                    for url, path in targets:
                        try:
                            self._download_asset(url, path)
                        except Exception:
                            pass
                finally:
                    self._assets_syncing = False

            try:
                run_on_queue(_worker)
            except Exception:
                try:
                    import threading
                    threading.Thread(target=_worker, daemon=True).start()
                except Exception:
                    self._assets_syncing = False
        except Exception:
            self._assets_syncing = False

    def _load_welcome_bg_remote(self):
        try:
            bust = str(int(time.time() / 60))
            self._download_asset("{0}?v={1}".format(WELCOME_BG_URL, bust), WELCOME_BG_CACHE_FILE)
        except Exception:
            pass

    def _ensure_mentions_hub_avatar_asset(self):
        try:
            path = str(MENTIONS_HUB_AVATAR_CACHE_FILE or "")
            if path and os.path.isfile(path) and os.path.getsize(path) > 0:
                return path
        except Exception:
            pass
        try:
            bust = str(int(time.time() / 60))
            ok = bool(self._download_asset("{0}?v={1}".format(MENTIONS_HUB_AVATAR_URL, bust), MENTIONS_HUB_AVATAR_CACHE_FILE))
            if ok and os.path.isfile(MENTIONS_HUB_AVATAR_CACHE_FILE) and os.path.getsize(MENTIONS_HUB_AVATAR_CACHE_FILE) > 0:
                return str(MENTIONS_HUB_AVATAR_CACHE_FILE)
        except Exception:
            pass
        return ""

    def _apply_mentions_hub_avatar(self, inbox_did):
        try:
            did = int(inbox_did or 0)
            chat_id = int(self._dialog_to_chat_id(did) or 0)
            if did >= 0 or chat_id <= 0:
                return False
            path = str(self._ensure_mentions_hub_avatar_asset() or "").strip()
            if not path or not os.path.isfile(path):
                self._dlog("[MentionsHub] avatar asset unavailable")
                return False
            from java import dynamic_proxy
            from android.graphics import BitmapFactory
            from org.telegram.messenger import ImageLoader, FileLoader, NotificationCenter
            from org.telegram.tgnet import ConnectionsManager
            UC = jclass("org.telegram.messenger.UserConfig")
            MC = jclass("org.telegram.messenger.MessagesController")
            Delegate = jclass("org.telegram.messenger.NotificationCenter$NotificationCenterDelegate")
            plugin_ref = self
            bitmap = BitmapFactory.decodeFile(path)
            if bitmap is None:
                self._dlog("[MentionsHub] avatar decode failed")
                return False
            big_photo = ImageLoader.scaleAndSaveImage(bitmap, 800, 800, 80, False, 320, 320)
            small_photo = ImageLoader.scaleAndSaveImage(bitmap, 150, 150, 80, False, 150, 150)
            try:
                bitmap.recycle()
            except Exception:
                pass
            if big_photo is None or small_photo is None:
                self._dlog("[MentionsHub] avatar sizes failed")
                return False
            current_account = int(getattr(UC, "selectedAccount", 0) or 0)
            file_loader = FileLoader.getInstance(current_account)
            big_photo_file = file_loader.getPathToAttach(big_photo, True)
            if big_photo_file is None or not big_photo_file.exists():
                self._dlog("[MentionsHub] avatar upload file missing")
                return False
            self._mentions_hub_avatar_upload_path = str(big_photo_file.getAbsolutePath() or "")
            self._mentions_hub_avatar_big = big_photo
            self._mentions_hub_avatar_small = small_photo
            self._mentions_hub_avatar_chat_id = int(chat_id)

            class _MentionsHubAvatarObserver(dynamic_proxy(Delegate)):
                def didReceivedNotification(self_delegate, notification_id, account, *args):
                    try:
                        if len(args) > 0 and hasattr(args[0], "__getitem__"):
                            arr = args[0]
                            location = arr[0] if len(arr) > 0 else None
                            input_file = arr[1] if len(arr) > 1 else None
                        else:
                            location = args[0] if len(args) > 0 else None
                            input_file = args[1] if len(args) > 1 else None
                        if int(notification_id or 0) == int(NotificationCenter.fileUploaded):
                            if str(location or "") == str(plugin_ref._mentions_hub_avatar_upload_path or "") and input_file is not None:
                                try:
                                    target_chat_id = int(plugin_ref._mentions_hub_avatar_chat_id or 0)
                                    small_loc = getattr(plugin_ref._mentions_hub_avatar_small, "location", None)
                                    big_loc = getattr(plugin_ref._mentions_hub_avatar_big, "location", None)
                                    mc = MC.getInstance(current_account)
                                    mc.changeChatAvatar(
                                        int(target_chat_id),
                                        None,
                                        input_file,
                                        None,
                                        None,
                                        0.0,
                                        None,
                                        small_loc,
                                        big_loc,
                                        None,
                                    )
                                    plugin_ref._dlog("[MentionsHub] avatar applied chat_id={0}".format(int(target_chat_id)))
                                except Exception as e:
                                    plugin_ref._dlog("[MentionsHub] avatar apply failed: {0}".format(e))
                                finally:
                                    plugin_ref._mentions_hub_avatar_cleanup_observer()
                        elif int(notification_id or 0) == int(NotificationCenter.fileUploadFailed):
                            if str(location or "") == str(plugin_ref._mentions_hub_avatar_upload_path or ""):
                                plugin_ref._dlog("[MentionsHub] avatar upload failed")
                                plugin_ref._mentions_hub_avatar_cleanup_observer()
                    except Exception as e:
                        plugin_ref._dlog("[MentionsHub] avatar observer error: {0}".format(e))

            nc = NotificationCenter.getInstance(current_account)
            obs = _MentionsHubAvatarObserver()
            self._mentions_hub_avatar_observer = obs
            nc.addObserver(obs, NotificationCenter.fileUploaded)
            nc.addObserver(obs, NotificationCenter.fileUploadFailed)
            file_loader.uploadFile(self._mentions_hub_avatar_upload_path, False, True, ConnectionsManager.FileTypePhoto)
            self._dlog("[MentionsHub] avatar upload started chat_id={0}".format(int(chat_id)))
            return True
        except Exception as e:
            self._dlog("[MentionsHub] avatar setup failed: {0}".format(e))
            self._mentions_hub_avatar_cleanup_observer()
            return False

    def _mentions_hub_avatar_cleanup_observer(self):
        try:
            obs = self._mentions_hub_avatar_observer
            if obs is not None:
                from org.telegram.messenger import NotificationCenter
                current_account = int(getattr(jclass("org.telegram.messenger.UserConfig"), "selectedAccount", 0) or 0)
                nc = NotificationCenter.getInstance(current_account)
                try:
                    nc.removeObserver(obs, NotificationCenter.fileUploaded)
                except Exception:
                    pass
                try:
                    nc.removeObserver(obs, NotificationCenter.fileUploadFailed)
                except Exception:
                    pass
        except Exception:
            pass
        self._mentions_hub_avatar_observer = None
        self._mentions_hub_avatar_uploader = None
        self._mentions_hub_avatar_upload_path = ""
        self._mentions_hub_avatar_big = None
        self._mentions_hub_avatar_small = None
        self._mentions_hub_avatar_chat_id = 0

    def _apply_mentions_hub_avatar_async(self, inbox_did):
        try:
            did = int(inbox_did or 0)
        except Exception:
            did = 0
        if did >= 0:
            return
        def _try_apply():
            try:
                self._apply_mentions_hub_avatar(did)
            except Exception:
                pass
        def _worker():
            try:
                self._ensure_mentions_hub_avatar_asset()
            except Exception:
                pass
            delays = [300, 1400, 3200]
            for delay in delays:
                try:
                    AndroidUtilities.runOnUIThread(_try_apply, int(delay))
                except Exception:
                    pass
        try:
            run_on_queue(_worker)
        except Exception:
            threading.Thread(target=_worker, daemon=True).start()

    def _dismiss_keyboard_focus(self, ctx):
        try:
            from android.view.inputmethod import InputMethodManager
            imm = ctx.getSystemService(ctx.INPUT_METHOD_SERVICE)
            if imm is not None:
                try:
                    view = None
                    try:
                        view = get_last_fragment().getParentActivity().getCurrentFocus()
                    except Exception:
                        view = None
                    if view is not None:
                        imm.hideSoftInputFromWindow(view.getWindowToken(), 0)
                except Exception:
                    pass
        except Exception:
            pass

    def _get_user_first_name(self):
        try:
            uc = get_user_config()
            if uc is not None:
                u = uc.getCurrentUser()
                if u is not None:
                    name = str(getattr(u, "first_name", "") or "").strip()
                    if name:
                        return name
        except Exception:
            pass
        return "User"

    def _resolve_current_user(self):
        try:
            UC = jclass("org.telegram.messenger.UserConfig")
            MC = jclass("org.telegram.messenger.MessagesController")
            account = int(getattr(UC, "selectedAccount", 0))
            uc = UC.getInstance(account) if UC is not None else None
            mc = MC.getInstance(account) if MC is not None else None
            user = None
            try:
                if uc is not None:
                    user = uc.getCurrentUser()
            except Exception:
                user = None
            if user is None:
                try:
                    if uc is not None and mc is not None:
                        user = mc.getUser(uc.getClientUserId())
                except Exception:
                    user = None
            return user
        except Exception:
            return None

    def _make_avatar_fallback_drawable(self, user=None):
        try:
            from org.telegram.ui.Components import AvatarDrawable
            if user is not None:
                try:
                    return AvatarDrawable(user)
                except Exception:
                    pass
            d = AvatarDrawable()
            try:
                name = str(self._get_user_first_name() or "User").strip()
                try:
                    d.setInfo(0, name, "", False)
                except Exception:
                    try:
                        d.setInfo(0, name, "")
                    except Exception:
                        pass
            except Exception:
                pass
            return d
        except Exception:
            from org.telegram.ui.Components import AvatarDrawable
            return AvatarDrawable()

    def _show_welcome_sheet(self, ctx_override=None):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_welcome_sheet", count=1, force_flush=False)
            except Exception:
                pass
            from java import dynamic_proxy, jarray
            from android.widget import FrameLayout, ImageView, LinearLayout, TextView
            from android.view import Gravity, View, ViewOutlineProvider
            from android.graphics import BitmapFactory, Color, Bitmap
            from android.graphics.drawable import GradientDrawable
            from org.telegram.ui.ActionBar import BottomSheet
            from org.telegram.messenger import ApplicationLoader
            from org.telegram.ui.Components import BackupImageView, AvatarDrawable
            ctx = ctx_override
            if ctx is None:
                frag = get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else ApplicationLoader.applicationContext
            if ctx is None:
                return False

            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass

            sheet = BottomSheet(ctx, False)
            try:
                sheet.setApplyTopPadding(False)
                sheet.setApplyBottomPadding(False)
                try:
                    sheet.setBackgroundColor(0x00000000)
                except Exception:
                    pass
            except Exception:
                pass
            root = FrameLayout(ctx)
            try:
                root.setBackgroundColor(0x00000000)
            except Exception:
                pass
            hero = FrameLayout(ctx)
            content = LinearLayout(ctx)
            content.setOrientation(LinearLayout.VERTICAL)
            content.setGravity(Gravity.CENTER_HORIZONTAL)
            hero_bg = None
            hero_radius = float(AndroidUtilities.dp(22))
            try:
                content.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(22), AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                hero_bg = GradientDrawable(GradientDrawable.Orientation.TOP_BOTTOM, jarray(jarray.int)([
                    0x00000000,
                    0x00000000,
                    0x00000000,
                ]))
                hero_bg.setCornerRadius(hero_radius)
                try:
                    hero_bg.setStroke(AndroidUtilities.dp(1), Color.parseColor("#2A3A58"))
                except Exception:
                    pass
                hero.setBackground(hero_bg)
                hero.setClipToOutline(True)
                hero.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass

            try:
                bg_wrap = FrameLayout(ctx)
                try:
                    wrap_bg = GradientDrawable()
                    wrap_bg.setColor(0x00000000)
                    wrap_bg.setCornerRadius(hero_radius)
                    bg_wrap.setBackground(wrap_bg)
                    bg_wrap.setClipToOutline(True)
                    bg_wrap.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                except Exception:
                    pass
                bg = ImageView(ctx)
                bg.setScaleType(ImageView.ScaleType.CENTER_CROP)
                if os.path.exists(WELCOME_BG_CACHE_FILE):
                    bmp_bg = BitmapFactory.decodeFile(WELCOME_BG_CACHE_FILE)
                    if bmp_bg:
                        bg.setImageBitmap(bmp_bg)
                bg_wrap.addView(bg, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
                hero.addView(bg_wrap, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
            except Exception:
                pass

            try:
                overlay = View(ctx)
                ov = GradientDrawable(
                    GradientDrawable.Orientation.TOP_BOTTOM,
                    jarray(jarray.int)([
                        0x55000000,
                        0x33000000,
                        0x99000000,
                    ]),
                )
                try:
                    ov.setCornerRadius(hero_radius)
                except Exception:
                    pass
                overlay.setBackground(ov)
                hero.addView(
                    overlay,
                    FrameLayout.LayoutParams(
                        FrameLayout.LayoutParams.MATCH_PARENT,
                        FrameLayout.LayoutParams.MATCH_PARENT,
                        Gravity.CENTER,
                    ),
                )
            except Exception:
                pass

            try:
                handle = View(ctx)
                hb = GradientDrawable()
                hb.setCornerRadius(float(AndroidUtilities.dp(2)))
                hb.setColor(Color.parseColor("#88FFFFFF"))
                handle.setBackground(hb)
                lp_handle = FrameLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(4), Gravity.TOP | Gravity.CENTER_HORIZONTAL)
                lp_handle.topMargin = AndroidUtilities.dp(10)
                hero.addView(handle, lp_handle)
            except Exception:
                pass

            try:
                from android.animation import ValueAnimator, ArgbEvaluator
                if hero_bg is not None:
                    evaluator = ArgbEvaluator()
                    anim = ValueAnimator.ofFloat(0.0, 1.0)
                    anim.setDuration(2600)
                    anim.setRepeatCount(-1)
                    anim.setRepeatMode(ValueAnimator.REVERSE)

                    class _Upd(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                        def onAnimationUpdate(self_obj, va):
                            try:
                                t = float(va.getAnimatedValue())
                                c1 = int(evaluator.evaluate(t, Color.parseColor("#0A0F16"), Color.parseColor("#0B1020")))
                                c2 = int(evaluator.evaluate(t, Color.parseColor("#101827"), Color.parseColor("#13203A")))
                                c3 = int(evaluator.evaluate(t, Color.parseColor("#0C1320"), Color.parseColor("#0E1524")))
                                try:
                                    hero_bg.setColors(jarray(jarray.int)([c1, c2, c3]))
                                except Exception:
                                    pass
                            except Exception:
                                pass

                    anim.addUpdateListener(_Upd())
                    anim.start()
            except Exception:
                pass

            try:
                grain_view = ImageView(ctx)
                try:
                    gw = 220
                    gh = 220
                    grain = Bitmap.createBitmap(gw, gh, Bitmap.Config.ARGB_8888)
                    import random as _rnd
                    rnd = _rnd.Random(73)
                    for yy in range(gh):
                        for xx in range(gw):
                            a = 8 + rnd.randint(0, 18)
                            c = (a << 24) | (255 << 16) | (255 << 8) | 255
                            grain.setPixel(xx, yy, c)
                    grain_view.setImageBitmap(grain)
                    grain_view.setScaleType(ImageView.ScaleType.FIT_XY)
                    grain_view.setAlpha(0.09)
                except Exception:
                    pass
                hero.addView(grain_view, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT, Gravity.CENTER))
            except Exception:
                pass

            avatar_shell = FrameLayout(ctx)
            try:
                sh = GradientDrawable()
                sh.setCornerRadius(float(AndroidUtilities.dp(18)))
                sh.setColor(0x00000000)
                avatar_shell.setBackground(sh)
                avatar_shell.setClipToOutline(True)
                avatar_shell.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass
            avatar_view = None
            try:
                avatar_view = BackupImageView(ctx)
                avatar_view.setRoundRadius(AndroidUtilities.dp(18))
                user = self._resolve_current_user()
                if user is not None:
                    drawable = AvatarDrawable(user)
                    avatar_view.setForUserOrChat(user, drawable)
                else:
                    avatar_view.setImageDrawable(self._make_avatar_fallback_drawable(None))
            except Exception:
                avatar_view = None
            if avatar_view is None:
                iv = ImageView(ctx)
                try:
                    iv.setScaleType(ImageView.ScaleType.CENTER_CROP)
                    iv.setImageDrawable(self._make_avatar_fallback_drawable(None))
                except Exception:
                    pass
                avatar_view = iv
            avatar_shell.addView(avatar_view, FrameLayout.LayoutParams(AndroidUtilities.dp(108), AndroidUtilities.dp(108), Gravity.CENTER))
            lp_avatar = LinearLayout.LayoutParams(AndroidUtilities.dp(108), AndroidUtilities.dp(108))
            lp_avatar.topMargin = AndroidUtilities.dp(6)
            content.addView(avatar_shell, lp_avatar)

            title = TextView(ctx)
            user_name = self._get_user_first_name()
            try:
                txt = str(self._tr("first_welcome_text")).replace("{name}", user_name)
            except Exception:
                txt = str(self._tr("first_welcome_text", "Hi, {name}!")).replace("{name}", user_name)
            title.setText(txt)
            title.setGravity(Gravity.CENTER)
            title.setTextSize(30)
            try:
                title.setTextColor(Color.WHITE)
                title.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
            except Exception:
                pass
            lp_t = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_t.topMargin = AndroidUtilities.dp(26)
            content.addView(title, lp_t)

            desc = TextView(ctx)
            desc.setText(self._tr("welcome_text"))
            desc.setGravity(Gravity.CENTER)
            desc.setTextSize(15)
            try:
                desc.setTextColor(Color.parseColor("#E3ECF8"))
            except Exception:
                pass
            lp_d = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_d.topMargin = AndroidUtilities.dp(12)
            content.addView(desc, lp_d)

            open_btn = TextView(ctx)
            open_btn.setText(self._tr("first_welcome_button"))
            open_btn.setGravity(Gravity.CENTER)
            open_btn.setTextSize(18)
            try:
                open_btn.setTextColor(Color.BLACK)
                btn_bg = GradientDrawable()
                btn_bg.setColor(Color.parseColor("#F4FAFF"))
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(22)))
                open_btn.setBackground(btn_bg)
                open_btn.setPadding(AndroidUtilities.dp(22), AndroidUtilities.dp(14), AndroidUtilities.dp(22), AndroidUtilities.dp(14))
            except Exception:
                pass

            class _OpenSettings(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_plugin_settings()
                    except Exception:
                        pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            resources_btn = TextView(ctx)
            resources_btn.setText(self._tr("resources_menu"))
            resources_btn.setGravity(Gravity.CENTER)
            resources_btn.setTextSize(17)
            try:
                resources_btn.setTextColor(Color.WHITE)
                resources_bg = GradientDrawable()
                resources_bg.setColor(Color.parseColor("#1F2C3E"))
                resources_bg.setCornerRadius(float(AndroidUtilities.dp(22)))
                resources_btn.setBackground(resources_bg)
                resources_btn.setPadding(AndroidUtilities.dp(22), AndroidUtilities.dp(13), AndroidUtilities.dp(22), AndroidUtilities.dp(13))
            except Exception:
                pass

            class _ResourcesClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._download_resources_async(ctx=ctx, close_dialog=None, bulletin_key="resources_welcome_bulletin")
                    except Exception:
                        pass

            resources_btn.setOnClickListener(_ResourcesClick())
            hero.addView(resources_btn, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL))
            try:
                rlp = resources_btn.getLayoutParams()
                rlp.leftMargin = AndroidUtilities.dp(24)
                rlp.rightMargin = AndroidUtilities.dp(24)
                rlp.bottomMargin = AndroidUtilities.dp(82)
                resources_btn.setLayoutParams(rlp)
            except Exception:
                pass

            open_btn.setOnClickListener(_OpenSettings())
            hero.addView(open_btn, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL))
            try:
                blp = open_btn.getLayoutParams()
                blp.leftMargin = AndroidUtilities.dp(24)
                blp.rightMargin = AndroidUtilities.dp(24)
                blp.bottomMargin = AndroidUtilities.dp(22)
                open_btn.setLayoutParams(blp)
            except Exception:
                pass

            content_lp = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.TOP | Gravity.CENTER_HORIZONTAL)
            content_lp.topMargin = AndroidUtilities.dp(18)
            hero.addView(content, content_lp)

            lp_hero = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(458), Gravity.CENTER)
            lp_hero.leftMargin = AndroidUtilities.dp(16)
            lp_hero.rightMargin = AndroidUtilities.dp(16)
            lp_hero.topMargin = AndroidUtilities.dp(16)
            lp_hero.bottomMargin = AndroidUtilities.dp(18)
            root.addView(hero, lp_hero)
            sheet.setCustomView(root)
            try:
                self._style_welcome_sheet_surface(sheet)
            except Exception:
                pass
            run_on_ui_thread(sheet.show)
            try:
                class _AfterShow(dynamic_proxy("java.lang.Runnable")):
                    def run(self_obj):
                        try:
                            self._style_welcome_sheet_surface(sheet)
                        except Exception:
                            pass
                root.postDelayed(_AfterShow(), 32)
            except Exception:
                pass
            return True
        except Exception as e:
            self._dlog("welcome sheet fail: {0}".format(e))
            return False

    def _style_welcome_sheet_surface(self, sheet):
        try:
            if not sheet:
                return
            targets = []
            try:
                c = sheet.getContainer()
                if c is not None and c not in targets:
                    targets.append(c)
            except Exception:
                pass
            for fname in ("containerView", "container", "sheetContainer", "sheetView"):
                try:
                    v = _pf(sheet, fname, None)
                except Exception:
                    v = None
                if v is not None and v not in targets:
                    targets.append(v)
            for v in targets:
                try:
                    try:
                        v.setBackgroundColor(0x00000000)
                    except Exception:
                        pass
                    try:
                        v.setBackground(None)
                    except Exception:
                        pass
                    try:
                        v.setPadding(0, 0, 0, 0)
                    except Exception:
                        pass
                    try:
                        v.setAlpha(1.0)
                    except Exception:
                        pass
                    try:
                        v.setElevation(0.0)
                    except Exception:
                        pass
                except Exception:
                    pass
            try:
                w = sheet.getWindow()
            except Exception:
                w = None
            if w is None:
                return
            try:
                w.setBackgroundDrawable(None)
            except Exception:
                pass
            try:
                w.setDimAmount(0.0)
            except Exception:
                pass
            try:
                WM = jclass("android.view.WindowManager")
                w.clearFlags(WM.LayoutParams.FLAG_DIM_BEHIND)
            except Exception:
                pass
            try:
                Build = jclass("android.os.Build")
                if int(Build.VERSION.SDK_INT) >= 31:
                    w.setBackgroundBlurRadius(0)
            except Exception:
                pass
        except Exception:
            pass

    def _maybe_show_first_install_welcome(self):
        try:
            seen_ver = str(self.get_setting("vanguard_welcome_seen_ver", "") or "")
            if seen_ver == str(__version__):
                return
            if bool(getattr(self, "_welcome_launching", False)):
                return
            self._welcome_launching = True

            def _worker():
                try:
                    target_ctx = None
                    for _ in range(40):
                        try:
                            frag = get_last_fragment()
                            if frag:
                                act = frag.getParentActivity()
                                if act:
                                    target_ctx = act
                                    break
                        except Exception:
                            pass
                        try:
                            time.sleep(0.25)
                        except Exception:
                            break
                    if target_ctx is None:
                        return
                    try:
                        self._load_welcome_bg_remote()
                    except Exception:
                        pass

                    def _show():
                        try:
                            shown = bool(self._show_welcome_sheet(target_ctx))
                            if shown:
                                self.set_setting("vanguard_welcome_seen_ver", str(__version__))
                                self.set_setting("vanguard_first_welcome_done", True)
                        except Exception:
                            pass
                    run_on_ui_thread(_show)
                finally:
                    self._welcome_launching = False

            import threading
            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            pass

    def _show_welcome_once_with_ctx(self, ctx):
        try:
            seen_ver = str(self.get_setting("vanguard_welcome_seen_ver", "") or "")
            if seen_ver == str(__version__):
                return
            if bool(getattr(self, "_welcome_launching", False)):
                return
            self._welcome_launching = True
            try:
                shown = bool(self._show_welcome_sheet(ctx))
                if shown:
                    self.set_setting("vanguard_welcome_seen_ver", str(__version__))
                    self.set_setting("vanguard_first_welcome_done", True)
            finally:
                self._welcome_launching = False
        except Exception:
            pass

    def _build_settings_header_view(self, ctx):
        try:
            from java import dynamic_proxy
            from android.widget import LinearLayout, TextView, FrameLayout, ImageView
            from android.view import View, Gravity, ViewOutlineProvider
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable
            from android.graphics import BitmapFactory, Color
            from android.util import TypedValue

            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            try:
                outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(6), AndroidUtilities.dp(16), AndroidUtilities.dp(2))
            except Exception:
                pass

            card = LinearLayout(ctx)
            card.setOrientation(LinearLayout.VERTICAL)
            try:
                card.setPadding(AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(2))
            except Exception:
                pass
            try:
                card.setBackgroundColor(0x00000000)
            except Exception:
                pass

            hero = FrameLayout(ctx)
            try:
                hero_bg = GradientDrawable()
                hero_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                hero_bg.setColor(0x00000000)
                hero.setBackground(hero_bg)
                hero.setClipToOutline(True)
                hero.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass

            banner = ImageView(ctx)
            try:
                banner.setScaleType(ImageView.ScaleType.CENTER_CROP)
            except Exception:
                pass
            try:
                is_dark = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark = True
            try:
                banner_path = HEADER_IMAGE_CACHE_FILE_DARK if is_dark else HEADER_IMAGE_CACHE_FILE_LIGHT
                if os.path.exists(banner_path):
                    bmp = BitmapFactory.decodeFile(banner_path)
                    if bmp:
                        banner.setImageBitmap(bmp)
            except Exception:
                pass
            hero.addView(
                banner,
                FrameLayout.LayoutParams(
                    FrameLayout.LayoutParams.MATCH_PARENT,
                    AndroidUtilities.dp(200),
                ),
            )

            top_icon = ImageView(ctx)
            try:
                top_icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                top_path = TOP_ICON_CACHE_FILE_DARK if is_dark else TOP_ICON_CACHE_FILE_LIGHT
                if os.path.exists(top_path):
                    bmp_t = BitmapFactory.decodeFile(top_path)
                    if bmp_t:
                        top_icon.setImageBitmap(bmp_t)
            except Exception:
                pass
            class _OpenDotted(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_extera_channel()
                    except Exception:
                        pass
            class _TopLong(dynamic_proxy(View.OnLongClickListener)):
                def onLongClick(self_obj, v):
                    try:
                        self._toggle_logs_silent()
                    except Exception:
                        pass
                    return True
            try:
                top_icon.setOnClickListener(_OpenDotted())
            except Exception:
                pass
            try:
                top_icon.setOnLongClickListener(_TopLong())
            except Exception:
                pass
            try:
                lp_top = FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.TOP | Gravity.END)
                lp_top.topMargin = AndroidUtilities.dp(10)
                lp_top.rightMargin = AndroidUtilities.dp(10)
                hero.addView(top_icon, lp_top)
            except Exception:
                hero.addView(top_icon)

            sponsor_icon = ImageView(ctx)
            try:
                sponsor_icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                if os.path.exists(SPONSOR_ICON_CACHE_FILE):
                    bmp_s = BitmapFactory.decodeFile(SPONSOR_ICON_CACHE_FILE)
                    if bmp_s:
                        sponsor_icon.setImageBitmap(bmp_s)
            except Exception:
                pass
            try:
                sponsor_icon.setColorFilter(Color.WHITE if is_dark else Color.BLACK)
            except Exception:
                pass

            class _OpenSupporters(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_supporters_subfragment()
                    except Exception:
                        pass

            try:
                sponsor_icon.setOnClickListener(_OpenSupporters())
            except Exception:
                pass
            try:
                lp_sponsor = FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.TOP | Gravity.END)
                lp_sponsor.topMargin = AndroidUtilities.dp(10)
                lp_sponsor.rightMargin = AndroidUtilities.dp(42)
                hero.addView(sponsor_icon, lp_sponsor)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            try:
                row.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass
            try:
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                row_bg.setColor(Color.WHITE if is_dark else Color.BLACK)
                row.setBackground(row_bg)
            except Exception:
                pass

            btn = LinearLayout(ctx)
            btn.setOrientation(LinearLayout.HORIZONTAL)
            btn.setGravity(Gravity.CENTER_VERTICAL)
            try:
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(Color.parseColor("#6C4CFF"))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            btn_icon = ImageView(ctx)
            try:
                btn_icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                if os.path.exists(SUPPORT_ICON_CACHE_FILE):
                    bmp_i = BitmapFactory.decodeFile(SUPPORT_ICON_CACHE_FILE)
                    if bmp_i:
                        btn_icon.setImageBitmap(bmp_i)
                btn_icon.setColorFilter(Color.WHITE)
            except Exception:
                pass
            btn.addView(btn_icon, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))

            btn_text = TextView(ctx)
            btn_text.setText(self._tr("welcome_dotted_button"))
            btn_text.setTextSize(16)
            try:
                btn_text.setTextColor(Color.WHITE)
            except Exception:
                pass
            try:
                btn_text.setSingleLine(True)
                btn_text.setMaxLines(1)
            except Exception:
                pass
            try:
                lp_btn_text = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_btn_text.leftMargin = AndroidUtilities.dp(8)
                btn.addView(btn_text, lp_btn_text)
            except Exception:
                btn.addView(btn_text)

            class _OpenDottedChat(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self._open_dotted_chat()
                    except Exception:
                        pass

            btn.setOnClickListener(_OpenDottedChat())
            row.addView(btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            info = TextView(ctx)
            info.setText(self._tr("welcome_dotted_desc"))
            info.setTextSize(14)
            try:
                info.setTextColor(Color.BLACK if is_dark else Color.WHITE)
            except Exception:
                pass
            try:
                info.setMaxLines(2)
                info.setSingleLine(False)
            except Exception:
                pass
            try:
                lp_info = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                lp_info.leftMargin = AndroidUtilities.dp(12)
                lp_info.gravity = Gravity.CENTER_VERTICAL
                row.addView(info, lp_info)
            except Exception:
                row.addView(info)

            try:
                lp_row = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.BOTTOM | Gravity.START)
                lp_row.leftMargin = AndroidUtilities.dp(12)
                lp_row.rightMargin = AndroidUtilities.dp(12)
                lp_row.bottomMargin = AndroidUtilities.dp(8)
                hero.addView(row, lp_row)
            except Exception:
                hero.addView(row)

            card.addView(hero, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(228)))
            outer.addView(card, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            return outer
        except Exception as e:
            self._dlog("build settings header fail: {0}".format(e))
            return None

    def _build_settings_version_view(self, ctx):
        try:
            from android.widget import FrameLayout, TextView
            from android.view import Gravity
            from org.telegram.ui.ActionBar import Theme

            wrap = FrameLayout(ctx)
            wrap.setBackgroundColor(0x00000000)
            try:
                wrap.setPadding(0, AndroidUtilities.dp(2), 0, AndroidUtilities.dp(4))
            except Exception:
                pass
            tv = TextView(ctx)
            tv.setText("\nVanguard • v{0}".format(str(__version__)))
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(13)
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2)))
            except Exception:
                pass
            wrap.addView(tv, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT, Gravity.CENTER))
            return wrap
        except Exception as e:
            self._dlog("build version view fail: {0}".format(e))
            return None

    def _inject_settings_header(self, activity, items):
        try:
            if not self._is_our_settings_activity(activity):
                return
            try:
                cb = _pf(activity, "createSubFragmentCallback", None)
                if cb is not None:
                    try:
                        self._inject_action_mode_slide(activity, items)
                    except Exception:
                        pass
                    try:
                        cb_name = str(getattr(cb, "__name__", "") or "")
                        if cb == self._create_supporters_subfragment or cb_name == "_create_supporters_subfragment" or "_create_supporters_subfragment" in str(cb):
                            self._inject_supporters_subfragment(activity, items)
                    except Exception:
                        pass
                    return
            except Exception:
                pass
            try:
                if bool(getattr(self, "_supporters_open_pending", False)):
                    self._supporters_open_pending = False
                    try:
                        self._inject_action_mode_slide(activity, items)
                    except Exception:
                        pass
                    self._inject_supporters_subfragment(activity, items)
                    return
            except Exception:
                pass
            has_header = False
            has_version = False
            try:
                for i in range(items.size()):
                    it = items.get(i)
                    mk = str(getattr(it, "object2", "") or "")
                    if mk == "__vanguard_settings_header__":
                        has_header = True
                    elif mk == "__vanguard_settings_version__":
                        has_version = True
            except Exception:
                has_header = False
                has_version = False
            if has_header:
                pass

            ctx = activity.getContext() if hasattr(activity, "getContext") else None
            if not ctx:
                return
            try:
                self._settings_activity_ref = activity
            except Exception:
                pass
            try:
                self._show_welcome_once_with_ctx(ctx)
            except Exception:
                pass
            self._ensure_settings_header_assets()
            UItem = find_class("org.telegram.ui.Components.UItem")
            if UItem is None:
                return
            if not has_header:
                view = self._build_settings_header_view(ctx)
                if view is not None:
                    hi = UItem.asCustom(view)
                    try:
                        hi.object2 = "__vanguard_settings_header__"
                    except Exception:
                        pass
                    try:
                        hi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(0, hi)
            if not has_version:
                v = self._build_settings_version_view(ctx)
                if v is not None:
                    vi = UItem.asCustom(v)
                    try:
                        vi.object2 = "__vanguard_settings_version__"
                    except Exception:
                        pass
                    try:
                        vi.setTransparent(True)
                    except Exception:
                        pass
                    items.add(vi)
        except Exception as e:
            self._dlog("inject settings header fail: {0}".format(e))

    def _setup_settings_header_hook(self):
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            if PSA is None:
                return
            arr_cls = find_class("java.util.ArrayList")
            ua_cls = find_class("org.telegram.ui.Components.UniversalAdapter")
            if arr_cls is None or ua_cls is None:
                return
            m = PSA.getClass().getDeclaredMethod("fillItems", arr_cls, ua_cls)
            m.setAccessible(True)
            self._settings_header_hook = self.hook_method(m, _SettingsHeaderHook(self))
            self._dlog("settings header hook ok")
        except Exception as e:
            self._dlog("settings header hook fail: {0}".format(e))

    def on_send_message_hook(self, account, params):
        try:
            msg = getattr(params, "message", None)
            if not isinstance(msg, str):
                return HookResult()
            raw = msg.strip()
            if not raw:
                return HookResult()
            low = raw.lower()
            first = low.split(" ", 1)[0]
            is_tag = (first == "!tag" or first.startswith("!tag@"))
            is_info = (first == "!info" or first.startswith("!info@"))
            is_fed = (first == "!fedstat" or first.startswith("!fedstat@"))
            is_ftag = (first == "!ftag" or first.startswith("!ftag@"))
            is_peek = (first == "!peek" or first.startswith("!peek@"))
            try:
                if is_tag:
                    self._telemetry_queue_event("feature_use", feature="cmd_!tag", count=1, force_flush=False)
                elif is_info:
                    self._telemetry_queue_event("feature_use", feature="cmd_!info", count=1, force_flush=False)
                elif is_fed:
                    self._telemetry_queue_event("feature_use", feature="cmd_!fedstat", count=1, force_flush=False)
                elif is_ftag:
                    self._telemetry_queue_event("feature_use", feature="cmd_!ftag", count=1, force_flush=False)
                elif is_peek:
                    self._telemetry_queue_event("feature_use", feature="cmd_!peek", count=1, force_flush=False)
            except Exception:
                pass
            if not (is_tag or is_info or is_fed or is_ftag or is_peek):
                return HookResult()

            did = self._dialog_id(params)
            if did is None:
                run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("chat_unavailable")))
                return HookResult(strategy=HookStrategy.CANCEL)

            if is_ftag:
                fed_id = int(did or 0)
                if fed_id == 0:
                    run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("chat_unavailable")))
                    return HookResult(strategy=HookStrategy.CANCEL)
                fed_name = self._dialog_title_by_id(fed_id)
                if not fed_name:
                    fed_name = "Federation {0}".format(abs(int(fed_id)))
                ok = self._fed_add_or_update(fed_id, fed_name)
                run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("federation_tagged")) if ok else BulletinHelper.show_info(self._tr("failed_tag_fed")))
                try:
                    params.message = ""
                except Exception:
                    pass
                return HookResult(strategy=HookStrategy.CANCEL)

            if is_peek:
                peek_id = int(did or 0)
                if peek_id >= 0:
                    run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("admin_tab_chat_only")))
                    return HookResult(strategy=HookStrategy.CANCEL)
                ok, status = self._peek_add_or_update(peek_id, self._dialog_title_by_id(peek_id))
                if ok:
                    run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("peek_added")))
                else:
                    if status == "limit":
                        run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("peek_limit")))
                    else:
                        run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("peek_group_only")))
                try:
                    params.message = ""
                except Exception:
                    pass
                return HookResult(strategy=HookStrategy.CANCEL)

            reply_obj = getattr(params, "replyToMsg", None)
            uid = 0
            if is_tag:
                uid = self._uid_from_reply(reply_obj)
                if uid <= 0:
                    run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("reply_then_tag")))
                    return HookResult(strategy=HookStrategy.CANCEL)
            else:
                m = re.search(r"\b(\d{5,})\b", raw)
                if m:
                    try:
                        uid = int(m.group(1))
                    except Exception:
                        uid = 0
                if uid <= 0:
                    uid = self._uid_from_reply(reply_obj)
                if uid <= 0:
                    run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("provide_id_or_reply")))
                    return HookResult(strategy=HookStrategy.CANCEL)

            if is_tag:
                try:
                    params.message = ""
                except Exception:
                    pass
                self._emit_vanguard_beacon_panel(int(did), int(uid), source_reply=reply_obj)
                return HookResult(strategy=HookStrategy.CANCEL)

            cmd = "!info {0}".format(int(uid)) if is_info else "!fedstat {0}".format(int(uid))
            kind = "info" if is_info else "fed"
            self._set_pending_request(int(did), int(uid), kind, cmd_text=cmd)
            return HookResult()
        except Exception:
            return HookResult()

    def _dialog_id(self, params):
        try:
            if isinstance(getattr(params, "peer", None), int):
                return int(params.peer)
        except Exception:
            pass
        try:
            f = get_last_fragment()
            return int(f.getDialogId()) if f and hasattr(f, "getDialogId") else None
        except Exception:
            return None

    def _uid_from_reply(self, r):
        try:
            mo = getattr(r, "messageOwner", None)
            fid = getattr(mo, "from_id", None)
            return int(getattr(fid, "user_id", 0) or 0)
        except Exception:
            return 0

    def _load_tags(self):
        try:
            raw = self.get_setting("tagged_store_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
            users = data.get("users", {}) if isinstance(data, dict) else {}
            self._tags = users if isinstance(users, dict) else {}
        except Exception:
            self._tags = {}
        self._invalidate_draw_cache()

    def _save_tags(self):
        try:
            self.set_setting("tagged_store_v1", json.dumps({"users": self._tags}, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _load_user_aliases(self):
        try:
            raw = self.get_setting("tagged_user_aliases_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
            out = {}
            changed = False
            if isinstance(data, dict):
                for k, v in data.items():
                    try:
                        uid = int(k)
                    except Exception:
                        continue
                    if isinstance(v, dict):
                        nm = str(v.get("name", "") or "").strip()
                    else:
                        nm = str(v or "").strip()
                        changed = True
                    if nm:
                        out[str(uid)] = {"name": nm, "updated_at": int(time.time())}
            if not out:
                try:
                    for k, v in (self._tags or {}).items():
                        if not isinstance(v, dict):
                            continue
                        alias = str(v.get("alias", "") or "").strip()
                        if not alias:
                            continue
                        try:
                            uid = int(k)
                        except Exception:
                            continue
                        out[str(uid)] = {"name": alias, "updated_at": int(v.get("updated_at", int(time.time())) or int(time.time()))}
                        changed = True
                except Exception:
                    pass
            self._user_aliases = out
            if changed:
                self._save_user_aliases()
        except Exception:
            self._user_aliases = {}

    def _save_user_aliases(self):
        try:
            self.set_setting("tagged_user_aliases_v1", json.dumps(dict(self._user_aliases or {}), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _tag_get(self, uid):
        v = self._tags.get(str(int(uid)))
        return v if isinstance(v, dict) else None

    def _user_alias_get(self, uid):
        try:
            rec = (self._user_aliases or {}).get(str(int(uid)))
            if not isinstance(rec, dict):
                return ""
            return str(rec.get("name", "") or "").strip()
        except Exception:
            return ""

    def _user_alias_set(self, uid, alias_text):
        try:
            key = str(int(uid))
            name = str(alias_text or "").strip()
            if not name:
                if key in (self._user_aliases or {}):
                    self._user_aliases.pop(key, None)
                    self._save_user_aliases()
                    self._invalidate_draw_cache()
                    try:
                        run_on_ui_thread(lambda: self._refresh_chat_name_aliases(int(uid)))
                    except Exception:
                        pass
                return True
            self._user_aliases[key] = {"name": name, "updated_at": int(time.time())}
            self._save_user_aliases()
            self._invalidate_draw_cache()
            try:
                run_on_ui_thread(lambda: self._refresh_chat_name_aliases(int(uid)))
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _user_alias_del(self, uid):
        try:
            key = str(int(uid))
            rec = (self._user_aliases or {}).get(key)
            if not isinstance(rec, dict):
                return False
            if str(rec.get("name", "") or "").strip() == "":
                return False
            self._user_aliases.pop(key, None)
            self._save_user_aliases()
            self._invalidate_draw_cache()
            try:
                run_on_ui_thread(lambda: self._refresh_chat_name_aliases(int(uid)))
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _tag_set(self, uid, name, tag, spam=False):
        self._tags[str(int(uid))] = {
            "name": str(name or "").strip(),
            "tag": str(tag or "").strip(),
            "spam": bool(spam),
            "updated_at": int(time.time()),
        }
        self._save_tags()
        self._invalidate_draw_cache()
        self._stats_touch(uid, "tag")

    def _tag_del(self, uid):
        k = str(int(uid))
        if k in self._tags:
            del self._tags[k]
            self._save_tags()
            self._invalidate_draw_cache()
            return True
        return False

    def _user_name(self, uid):
        try:
            alias = self._user_alias_get(uid)
            if alias:
                return alias
            u = get_messages_controller().getUser(int(uid))
            if u is None:
                return "user_{0}".format(int(uid))
            first = str(getattr(u, "first_name", "") or "").strip()
            if first:
                return first
            un = str(getattr(u, "username", "") or "").strip()
            return ("@" + un) if un else "user_{0}".format(int(uid))
        except Exception:
            return "user_{0}".format(int(uid))

    def _user_username(self, uid):
        try:
            u = get_messages_controller().getUser(int(uid))
            if u is None:
                return ""
            return str(getattr(u, "username", "") or "").strip()
        except Exception:
            return ""

    def _render_warning_template(self, template_body, uid):
        name = self._user_name(uid)
        uname = self._user_username(uid)
        mention = ("@" + uname) if uname else name
        out = str(template_body or "")
        out = out.replace("{name}", name)
        out = out.replace("{username}", uname)
        out = out.replace("{mention}", mention)
        out = out.replace("{id}", str(int(uid)))
        return out

    def _build_rose_command(self, action, uid, reason="", reply_to=None):
        act = str(action or "").strip().lstrip("/!").lower()
        rsn = " ".join(str(reason or "").split()).strip()
        uname = self._user_username(uid)
        if reply_to is not None:
            return "!{0}{1}".format(act, (" " + rsn) if rsn else "")
        if uname:
            return "!{0} @{1}{2}".format(act, uname, (" " + rsn) if rsn else "")
        return "!{0} {1}{2}".format(act, int(uid), (" " + rsn) if rsn else "")

    def _extract_action_and_body(self, action_hint, body):
        allowed = ("warn", "mute", "ban", "kick", "rmwarn", "resetwarn")
        act = str(action_hint or "warn").strip().lower().lstrip("/!")
        txt = str(body or "").strip()
        if txt.startswith("!") or txt.startswith("/"):
            sp = txt.split(" ", 1)
            cmd = str(sp[0]).strip().lstrip("/!").lower()
            rest = str(sp[1]).strip() if len(sp) > 1 else ""
            if cmd in allowed:
                return cmd, rest
        if act not in allowed:
            act = "warn"
        return act, txt

    def _default_icon_for_action(self, action):
        act = str(action or "warn").strip().lower()
        if act == "mute":
            return "msg_mute"
        if act == "ban":
            return "msg_user_remove"
        if act == "kick":
            return "msg_delete"
        if act == "rmwarn":
            return "msg_unmute"
        if act == "resetwarn":
            return "msg_clear"
        return "msg_permissions"

    def _resolve_icon_res(self, ctx, icon_name, fallback="msg_permissions"):
        try:
            name = str(icon_name or "").strip()
            if not name:
                name = str(fallback or "msg_permissions")
            rid = int(ctx.getResources().getIdentifier(name, "drawable", ctx.getPackageName()) or 0)
            if rid <= 0 and fallback and str(fallback) != name:
                rid = int(ctx.getResources().getIdentifier(str(fallback), "drawable", ctx.getPackageName()) or 0)
            return rid if rid > 0 else 0
        except Exception:
            return 0

    def _send_warning_message(self, dialog_id, text, reply_to=None, parse_markdown_mode=True):
        try:
            payload = str(text or "").strip()
            if not payload:
                return False
            try:
                if payload.startswith("!"):
                    cmd = str(payload.split(" ", 1)[0] or "").strip().lower()
                    if cmd:
                        self._telemetry_queue_event("feature_use", feature="cmd_" + cmd[:28], count=1, force_flush=False)
            except Exception:
                pass
            if bool(parse_markdown_mode):
                try:
                    from markdown_utils import parse_markdown
                    parsed = parse_markdown(payload)
                    entities = []
                    for e in getattr(parsed, "entities", []) or []:
                        try:
                            entities.append(e.to_tlrpc_object())
                        except Exception:
                            pass
                    params = {"peer": int(dialog_id), "message": parsed.text, "entities": entities}
                    if reply_to is not None:
                        params["replyToMsg"] = reply_to
                    send_message(params)
                    return True
                except Exception:
                    pass
            params = {"peer": int(dialog_id), "message": payload}
            if reply_to is not None:
                params["replyToMsg"] = reply_to
            send_message(params)
            return True
        except Exception:
            return False

    def _mentions_hub_current_username(self):
        try:
            u = self._resolve_current_user()
            return str(getattr(u, "username", "") or "").strip().lower() if u is not None else ""
        except Exception:
            return ""

    def _mentions_hub_sender_id(self, msg_obj):
        try:
            sid = int(self._uid_from_cell_message(msg_obj) or 0)
            if sid > 0:
                return sid
        except Exception:
            pass
        try:
            fid = getattr(msg_obj, "from_id", None)
            uid = int(getattr(fid, "user_id", 0) or 0)
            if uid > 0:
                return uid
            cid = int(getattr(fid, "channel_id", 0) or 0)
            if cid > 0:
                return -cid
        except Exception:
            pass
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            fid = getattr(mo, "from_id", None)
            cid = int(getattr(fid, "channel_id", 0) or 0)
            if cid > 0:
                return -cid
        except Exception:
            pass
        return 0

    def _mentions_hub_sender_name(self, msg_obj):
        try:
            sid = int(self._mentions_hub_sender_id(msg_obj) or 0)
            if sid > 0:
                return self._user_name(sid)
            if sid < 0:
                ch = get_messages_controller().getChat(abs(int(sid)))
                title = str(getattr(ch, "title", "") or "").strip()
                if title:
                    return title
        except Exception:
            pass
        return "Unknown"

    def _mentions_hub_track_own_message(self, dialog_id, msg_obj):
        try:
            did = int(dialog_id or 0)
            if did >= 0 or msg_obj is None:
                return
            uc = get_user_config()
            my_uid = int(uc.getClientUserId()) if uc is not None else 0
            sid = int(self._uid_from_cell_message(msg_obj) or 0)
            if not (self._is_outgoing(msg_obj) or (my_uid > 0 and sid == my_uid)):
                return
            try:
                mid = int(msg_obj.getId() or 0)
            except Exception:
                mid = int(getattr(getattr(msg_obj, "messageOwner", None), "id", 0) or getattr(msg_obj, "id", 0) or 0)
            if mid <= 0:
                return
            key = str(did)
            arr = list((self._mentions_own_cache or {}).get(key, []) or [])
            if mid not in arr:
                arr.append(mid)
            self._mentions_own_cache[key] = arr[-150:]
        except Exception:
            pass

    def _mentions_hub_is_reply_to_me(self, dialog_id, msg_obj):
        try:
            uc = get_user_config()
            my_uid = int(uc.getClientUserId()) if uc is not None else 0
            if my_uid <= 0 or msg_obj is None:
                return False
            reply_obj = getattr(msg_obj, "replyMessageObject", None)
            if reply_obj is not None and int(self._uid_from_cell_message(reply_obj) or 0) == my_uid:
                return True
            mo = getattr(msg_obj, "messageOwner", None)
            rh = getattr(mo, "reply_to", None)
            if rh is None:
                rh = getattr(msg_obj, "reply_to", None)
            reply_mid = int(getattr(rh, "reply_to_msg_id", 0) or 0)
            if reply_mid <= 0:
                return False
            cached = list((self._mentions_own_cache or {}).get(str(int(dialog_id or 0)), []) or [])
            return int(reply_mid) in cached
        except Exception:
            return False

    def _mentions_hub_is_mention(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            if bool(getattr(mo, "mentioned", False)):
                return True
        except Exception:
            pass
        try:
            if bool(getattr(msg_obj, "mentioned", False)):
                return True
        except Exception:
            pass
        try:
            uname = str(self._mentions_hub_current_username() or "").strip().lower()
            if not uname:
                return False
            tx = str(self._message_text(msg_obj) or "").strip().lower()
            return bool(tx and re.search(r"(^|\\W)@{0}\\b".format(re.escape(uname)), tx))
        except Exception:
            return False

    def _mentions_hub_message_link(self, dialog_id, msg_obj):
        try:
            cid = int(self._dialog_to_chat_id(dialog_id) or 0)
            try:
                mid = int(msg_obj.getId() or 0)
            except Exception:
                mid = int(getattr(getattr(msg_obj, "messageOwner", None), "id", 0) or getattr(msg_obj, "id", 0) or 0)
            if cid > 0 and mid > 0:
                return "https://t.me/c/{0}/{1}".format(int(cid), int(mid))
        except Exception:
            pass
        return "-"

    def _mentions_hub_mark_seen(self, dialog_id, msg_obj):
        try:
            try:
                mid = int(msg_obj.getId() or 0)
            except Exception:
                mid = int(getattr(getattr(msg_obj, "messageOwner", None), "id", 0) or getattr(msg_obj, "id", 0) or 0)
            if mid <= 0:
                return False
            key = "{0}:{1}".format(int(dialog_id or 0), int(mid))
            if key in self._mentions_seen:
                return False
            self._mentions_seen[key] = int(time.time())
            if len(self._mentions_seen) > 900:
                keys = sorted(self._mentions_seen.keys(), key=lambda k: int(self._mentions_seen.get(k, 0) or 0))
                for old in keys[:250]:
                    self._mentions_seen.pop(old, None)
            return True
        except Exception:
            return False

    def _markdown_escape(self, text, code_mode=False):
        try:
            s = str(text or "")
            if not s:
                return ""
            if bool(code_mode):
                return s.replace("\\", "\\\\").replace("`", "\\`")
            for ch in ("\\", "*", "_", "~", "|", "`", "[", "]"):
                s = s.replace(ch, "\\" + ch)
            return s
        except Exception:
            return str(text or "")

    def _mentions_hub_quote_markdown(self, text):
        try:
            clean = str(text or "").strip()
            if not clean:
                return '_{0}_'.format(self._markdown_escape(self._tr("message_empty")))
            escaped = self._markdown_escape(clean)
            words = [w for w in re.split(r"\s+", clean) if w]
            if len(words) > 15:
                return "> _{0}_".format(escaped)
            return "_{0}_".format(escaped)
        except Exception:
            return "_{0}_".format(self._markdown_escape(text or ""))

    def _mentions_hub_log_markdown(self, source_dialog_id, msg_obj):
        try:
            tx = str(self._message_text(msg_obj) or "").strip()
            if not tx:
                tx = self._tr("message_empty")
            tx = tx.replace("\r", " ").replace("\n", " ").strip()
            if len(tx) > 400:
                tx = tx[:397].rstrip() + "..."
            sender_name = str(self._mentions_hub_sender_name(msg_obj) or "Unknown").strip() or "Unknown"
            sender_id = int(self._mentions_hub_sender_id(msg_obj) or 0)
            link = str(self._mentions_hub_message_link(int(source_dialog_id or 0), msg_obj) or "").strip()
            safe_name = self._markdown_escape(sender_name)
            safe_id = self._markdown_escape(str(int(sender_id)), code_mode=True)
            safe_link = link.replace("(", "%28").replace(")", "%29")
            parts = [
                "*{0}*".format(self._markdown_escape(self._tr("mentions_hub_log_title"))),
                "",
                self._mentions_hub_quote_markdown(tx),
                "",
                "{0} *{1}*".format(self._markdown_escape("via"), safe_name),
                "*{0}* `{1}`".format(self._markdown_escape(self._tr("mentions_hub_log_id")), safe_id),
                "[{0}]({1})".format(self._markdown_escape(self._tr("mentions_hub_log_link")), safe_link or "https://t.me"),
            ]
            return "\n".join(parts)
        except Exception:
            return ""

    def _mentions_hub_append_log(self, source_dialog_id, msg_obj):
        try:
            inbox_did = int(self._mentions_hub_resolve_inbox() or 0)
            if inbox_did >= 0:
                self._dlog("[MentionsHub] append skipped: inbox not configured")
                return False
            body = str(self._mentions_hub_log_markdown(source_dialog_id, msg_obj) or "").strip()
            if not body:
                return False
            ok = bool(self._send_warning_message(int(inbox_did), body, parse_markdown_mode=True))
            self._dlog("[MentionsHub] append send did={0} inbox={1} ok={2}".format(int(source_dialog_id or 0), int(inbox_did), bool(ok)))
            if ok:
                self._mentions_hub["events"] = max(0, int((self._mentions_hub or {}).get("events", 0) or 0)) + 1
                self._save_mentions_hub()
            return ok
        except Exception as e:
            self._dlog("[MentionsHub] append error: {0}".format(e))
            return False

    def _mentions_hub_process_messages(self, dialog_id, messages):
        try:
            did = int(dialog_id or 0)
            inbox_did = int(self._mentions_hub_resolve_inbox() or 0)
            if did >= 0 or did == inbox_did:
                self._dlog("[MentionsHub] process skipped did={0} inbox={1}".format(did, inbox_did))
                return
            if inbox_did >= 0:
                self._dlog("[MentionsHub] process skipped: invalid inbox")
                return
            if not self._mentions_hub_has_source(did):
                self._dlog("[MentionsHub] process skipped: source not tagged did={0}".format(did))
                return
            if messages is None:
                self._dlog("[MentionsHub] process skipped: no messages did={0}".format(did))
                return
            size = int(messages.size() if hasattr(messages, "size") else len(messages))
            self._dlog("[MentionsHub] processing did={0} count={1}".format(did, size))
            for i in range(size):
                mo = messages.get(i) if hasattr(messages, "get") else messages[i]
                if mo is None:
                    continue
                self._mentions_hub_track_own_message(did, mo)
                if self._is_outgoing(mo):
                    self._dlog("[MentionsHub] skip outgoing did={0} mid={1}".format(did, int(self._msg_id(mo) or 0)))
                    continue
                is_mention = bool(self._mentions_hub_is_mention(mo))
                is_reply = bool(self._mentions_hub_is_reply_to_me(did, mo))
                self._dlog("[MentionsHub] inspect did={0} mid={1} mention={2} reply={3}".format(did, int(self._msg_id(mo) or 0), is_mention, is_reply))
                if not (is_mention or is_reply):
                    continue
                if not self._mentions_hub_mark_seen(did, mo):
                    self._dlog("[MentionsHub] skip duplicate did={0} mid={1}".format(did, int(self._msg_id(mo) or 0)))
                    continue
                self._mentions_hub_append_log(did, mo)
        except Exception as e:
            self._dlog("[MentionsHub] process error: {0}".format(e))
            pass

    def _notification_unpack(self, hook_args):
        try:
            if not hook_args:
                return 0, []
            nid = int(hook_args[0] or 0)
            raw = hook_args[2] if len(hook_args) > 2 else None
            out = []
            if raw is None:
                return nid, out
            try:
                for i in range(len(raw)):
                    out.append(raw[i])
                return nid, out
            except Exception:
                pass
            try:
                for i in range(int(raw.size() or 0)):
                    out.append(raw.get(i))
            except Exception:
                pass
            return nid, out
        except Exception:
            return 0, []

    def _mentions_hub_on_chat_created(self, chat_id):
        try:
            if not self._mentions_hub_create_pending:
                return
            cid = int(chat_id or 0)
            if cid == 0:
                return
            inbox_did = int(cid if cid < 0 else -int("100{0}".format(int(cid))))
            self._mentions_hub_finish_created(inbox_did)
        except Exception:
            self._mentions_hub_create_pending = False
            self._mentions_hub_create_watchdog = False

    def _cache_notification_center_info(self):
        try:
            if self._notification_center_cls is None:
                self._notification_center_cls = find_class("org.telegram.messenger.NotificationCenter")
            NC = self._notification_center_cls
            if NC is None:
                return None
            if int(self._nc_did_receive_new_messages or 0) == 0:
                self._nc_did_receive_new_messages = int(getattr(NC, "didReceiveNewMessages", 0) or 0)
            if int(self._nc_chat_did_created or 0) == 0:
                self._nc_chat_did_created = int(getattr(NC, "chatDidCreated", 0) or 0)
            if int(self._nc_chat_did_fail_create or 0) == 0:
                self._nc_chat_did_fail_create = int(getattr(NC, "chatDidFailCreate", 0) or 0)
            return NC
        except Exception:
            return None

    def _on_notification_center_event(self, nc_obj, hook_args):
        try:
            if self._cache_notification_center_info() is None:
                return
            nid, payload = self._notification_unpack(hook_args)
            if nid == int(self._nc_did_receive_new_messages or 0):
                did = int(payload[0] or 0) if len(payload) > 0 else 0
                messages = payload[1] if len(payload) > 1 else None
                self._mentions_hub_process_messages(did, messages)
            elif nid == int(self._nc_chat_did_created or 0):
                self._mentions_hub_on_chat_created(payload[0] if payload else 0)
            elif nid == int(self._nc_chat_did_fail_create or 0):
                if self._mentions_hub_create_pending:
                    self._mentions_hub_create_pending = False
                    self._mentions_hub_create_watchdog = False
                    def _fail():
                        try:
                            if self._mentions_hub_loading_dialog is not None:
                                self._mentions_hub_loading_dialog.dismiss()
                        except Exception:
                            pass
                        self._mentions_hub_loading_dialog = None
                        try:
                            if callable(self._mentions_hub_sheet_refresh):
                                self._mentions_hub_sheet_refresh()
                        except Exception:
                            pass
                        BulletinHelper.show_info(self._tr("mentions_hub_create_failed"))
                    run_on_ui_thread(_fail)
        except Exception:
            pass

    def _apply_markdown_to_tl_message(self, tl_msg, raw_text):
        try:
            from markdown_utils import parse_markdown
            parsed = parse_markdown(str(raw_text or ""))
            tl_msg.message = str(getattr(parsed, "text", "") or "")
            arr = ArrayList()
            count = 0
            for raw in (getattr(parsed, "entities", []) or []):
                try:
                    ent = raw.to_tlrpc_object()
                    if ent is not None:
                        arr.add(ent)
                        count += 1
                except Exception:
                    pass
            if count > 0:
                tl_msg.entities = arr
                tl_msg.flags |= 128
            return int(count)
        except Exception as e:
            self._dlog("markdown parse failed: {0}".format(e))
            return 0

    def _check_fb_connection_global(self):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="federations_test_connection", count=1, force_flush=False)
            except Exception:
                pass
            feds = list(self._federations or [])
            if not feds:
                BulletinHelper.show_info(self._tr("no_federations_saved"))
                return
            sent = 0
            msg = "😎 Connected!"
            for fed in feds:
                try:
                    peer = int((fed or {}).get("id", 0) or 0)
                    if peer == 0:
                        continue
                    if self._send_warning_message(int(peer), msg, reply_to=None):
                        sent += 1
                        self._queue_ephemeral_delete(int(peer), msg, delay_ms=5000)
                except Exception:
                    pass
            if sent > 0:
                BulletinHelper.show_success(self._tr("connection_ping_sent_fmt").format(int(sent)))
            else:
                BulletinHelper.show_info(self._tr("failed_send_connection_ping"))
        except Exception:
            BulletinHelper.show_info(self._tr("failed_check_connection"))

    def _open_template_editor(self, template=None, on_saved=None):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable

            template = template if isinstance(template, dict) else None
            is_new = template is None
            custom_count = len([t for t in self._warning_templates if isinstance(t, dict) and not bool(t.get("is_fixed"))])
            if is_new and custom_count >= 5:
                BulletinHelper.show_info(self._tr("template_limit"))
                return

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp_title = EditTextBoldCursor(ctx)
            inp_title.setHint(self._tr("template_title"))
            inp_title.setSingleLine(True)
            inp_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_title.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_title.setText(str((template or {}).get("title", "") or ""))
            inp_title.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            inp_icon = EditTextBoldCursor(ctx)
            inp_icon.setHint(self._tr("icon_name_hint"))
            inp_icon.setSingleLine(True)
            inp_icon.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_icon.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_icon.setText(str((template or {}).get("icon", "") or ""))
            inp_icon.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            inp_body = EditTextBoldCursor(ctx)
            inp_body.setHint(self._tr("description_action"))
            inp_body.setSingleLine(False)
            inp_body.setMinLines(4)
            inp_body.setMaxLines(8)
            inp_body.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            inp_body.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_body.setText(str((template or {}).get("body", "") or ""))
            inp_body.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            self._style_dialog_input(inp_title, multiline=False)
            self._style_dialog_input(inp_icon, multiline=False)
            self._style_dialog_input(inp_body, multiline=True)

            root.addView(inp_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            lp_i = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_i.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_icon, lp_i)
            lp_b = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_b.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_body, lp_b)

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("add_template") if is_new else self._tr("edit_template"))
            b.set_view(root)

            def _save_template(d, w):
                title = str(inp_title.getText().toString() if inp_title.getText() is not None else "").strip()
                icon = str(inp_icon.getText().toString() if inp_icon.getText() is not None else "").strip()
                body = str(inp_body.getText().toString() if inp_body.getText() is not None else "").strip()
                if not title or not body:
                    BulletinHelper.show_info(self._tr("title_message_required"))
                    return
                action, body = self._extract_action_and_body("warn", body)
                if not icon:
                    icon = self._default_icon_for_action(action)
                if is_new:
                    new_tpl = {
                        "id": "tpl_{0}".format(int(time.time() * 1000)),
                        "title": title,
                        "icon": icon,
                        "action": action,
                        "body": body,
                        "is_fixed": False,
                    }
                    self._warning_templates.append(new_tpl)
                else:
                    template["title"] = title
                    template["icon"] = icon
                    template["action"] = action
                    template["body"] = body
                self._save_warning_templates()
                BulletinHelper.show_success(self._tr("template_saved"))
                try:
                    if d:
                        d.dismiss()
                except Exception:
                    pass
                if callable(on_saved):
                    on_saved()

            b.set_positive_button(self._tr("save"), _save_template)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_template_editor"))

    def _open_templates_manager(self):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_templates_manager", count=1, force_flush=False)
            except Exception:
                pass
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("action_templates"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)

            hint = TextView(ctx)
            hint.setText(self._tr("custom_templates_hint"))
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                hint.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_hint = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_hint.topMargin = AndroidUtilities.dp(4)
            root.addView(hint, lp_hint)

            def _reload():
                try:
                    self._open_templates_manager()
                except Exception:
                    pass

            for tpl in [x for x in list(self._warning_templates) if isinstance(x, dict) and not bool(x.get("is_fixed"))]:
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                iconv = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, str(tpl.get("icon", "") or ""), fallback="msg_permissions")
                if rid > 0:
                    iconv.setImageResource(rid)
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                lp_icon.rightMargin = AndroidUtilities.dp(10)
                lp_icon.gravity = Gravity.CENTER_VERTICAL
                row.addView(iconv, lp_icon)

                text_wrap = LinearLayout(ctx)
                text_wrap.setOrientation(LinearLayout.VERTICAL)
                lp_tw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                row.addView(text_wrap, lp_tw)

                row_title = TextView(ctx)
                ttl = str(tpl.get("title", "") or "").strip()
                row_title.setText(ttl)
                row_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                try:
                    row_title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                except Exception:
                    pass
                text_wrap.addView(row_title)

                row_sub = TextView(ctx)
                row_sub.setText("icon={0} | action={1}".format(str(tpl.get("icon", "") or "-"), str(tpl.get("action", "warn") or "warn")))
                row_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    row_sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                text_wrap.addView(row_sub)

                row.setOnClickListener(OnClickListener(lambda v, t=tpl: self._open_template_editor(t, on_saved=_reload)))
                def _delete_tpl(v, t=tpl):
                    try:
                        self._warning_templates = [x for x in self._warning_templates if str(x.get("id")) != str(t.get("id"))]
                        self._save_warning_templates()
                        BulletinHelper.show_success(self._tr("template_removed"))
                        sheet.dismiss()
                        _reload()
                    except Exception:
                        pass
                    return True
                row.setOnLongClickListener(OnLongClickListener(lambda v, fn=_delete_tpl: fn(v)))
                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(6)
                root.addView(row, lp)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("add_template_btn"))
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            add_btn.setGravity(17)
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            try:
                add_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                abg = GradientDrawable()
                abg.setCornerRadius(float(AndroidUtilities.dp(12)))
                abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(abg)
            except Exception:
                pass
            add_btn.setOnClickListener(OnClickListener(lambda v: self._open_template_editor(None, on_saved=_reload)))
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.gravity = 5
            lp_add.topMargin = AndroidUtilities.dp(10)
            root.addView(add_btn, lp_add)

            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_templates_manager"))

    def _open_federation_editor(self, fed=None, on_saved=None):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            fed = fed if isinstance(fed, dict) else None
            is_new = fed is None

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp_name = EditTextBoldCursor(ctx)
            inp_name.setHint(self._tr("fed_name_hint"))
            inp_name.setSingleLine(True)
            inp_name.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_name.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_name.setText(str((fed or {}).get("name", "") or ""))
            inp_name.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            inp_id = EditTextBoldCursor(ctx)
            inp_id.setHint(self._tr("id_hint"))
            inp_id.setSingleLine(True)
            inp_id.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_id.setInputType(InputType.TYPE_CLASS_NUMBER | InputType.TYPE_NUMBER_FLAG_SIGNED)
            inp_id.setText(str((fed or {}).get("id", "") or ""))
            inp_id.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            self._style_dialog_input(inp_name, multiline=False)
            self._style_dialog_input(inp_id, multiline=False)
            root.addView(inp_name, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            lp2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp2.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_id, lp2)

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("add_federation") if is_new else self._tr("edit_federation"))
            b.set_view(root)

            def _save(d, _w):
                try:
                    nm = str(inp_name.getText().toString() if inp_name.getText() is not None else "").strip()
                    raw_id = str(inp_id.getText().toString() if inp_id.getText() is not None else "").strip()
                    fid = int(raw_id or 0)
                    if fid == 0:
                        BulletinHelper.show_info(self._tr("id_required"))
                        return
                    if not nm:
                        nm = "Federation {0}".format(abs(int(fid)))
                    ok = self._fed_add_or_update(fid, nm)
                    if ok:
                        BulletinHelper.show_success(self._tr("federation_saved"))
                        try:
                            if d:
                                d.dismiss()
                        except Exception:
                            pass
                        if callable(on_saved):
                            on_saved()
                    else:
                        BulletinHelper.show_info(self._tr("failed_save_federation"))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_save_federation"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            self._show_builder_dialog(b, frag)
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_fed_editor"))

    def _open_federations_manager(self):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_federations_manager", count=1, force_flush=False)
            except Exception:
                pass
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("federations"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)

            hint = TextView(ctx)
            hint.setText(self._tr("fed_manager_hint"))
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                hint.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_hint = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_hint.topMargin = AndroidUtilities.dp(4)
            root.addView(hint, lp_hint)

            def _reload():
                try:
                    sheet.dismiss()
                except Exception:
                    pass
                self._open_federations_manager()

            for fed in list(self._federations or []):
                if not isinstance(fed, dict):
                    continue
                fid = int(fed.get("id", 0) or 0)
                if fid == 0:
                    continue
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                iconv = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, "msg_groups_solar", fallback="msg_groups_solar")
                if rid > 0:
                    iconv.setImageResource(rid)
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                lp_icon.rightMargin = AndroidUtilities.dp(10)
                lp_icon.gravity = Gravity.CENTER_VERTICAL
                row.addView(iconv, lp_icon)

                text_wrap = LinearLayout(ctx)
                text_wrap.setOrientation(LinearLayout.VERTICAL)
                lp_tw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                row.addView(text_wrap, lp_tw)

                row_title = TextView(ctx)
                row_title.setText(str(fed.get("name", "") or ""))
                row_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                try:
                    row_title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                except Exception:
                    pass
                text_wrap.addView(row_title)

                row_sub = TextView(ctx)
                row_sub.setText(self._tr("id_fmt").format(int(fid)))
                row_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    row_sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                text_wrap.addView(row_sub)

                del_btn = ImageView(ctx)
                rid_del = self._resolve_icon_res(ctx, "msg_delete", fallback="msg_delete")
                if rid_del > 0:
                    del_btn.setImageResource(rid_del)
                lp_del = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_del.leftMargin = AndroidUtilities.dp(8)
                lp_del.gravity = Gravity.CENTER_VERTICAL
                row.addView(del_btn, lp_del)

                def _remove_fed(_v=None, _fid=fid):
                    ok = self._fed_remove(int(_fid))
                    BulletinHelper.show_success(self._tr("federation_removed")) if ok else BulletinHelper.show_info(self._tr("federation_not_found"))
                    _reload()
                    return True

                row.setOnClickListener(OnClickListener(lambda v, f=fed: self._open_federation_editor(f, on_saved=_reload)))
                row.setOnLongClickListener(OnLongClickListener(lambda v, f=fid: _remove_fed(v, f)))
                del_btn.setOnClickListener(OnClickListener(lambda v, f=fid: _remove_fed(v, f)))

                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(8)
                root.addView(row, lp_row)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("add_federation"))
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            add_btn.setGravity(17)
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            try:
                add_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                abg = GradientDrawable()
                abg.setCornerRadius(float(AndroidUtilities.dp(12)))
                abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(abg)
            except Exception:
                pass
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.gravity = 5
            lp_add.topMargin = AndroidUtilities.dp(10)
            root.addView(add_btn, lp_add)
            add_btn.setOnClickListener(OnClickListener(lambda v: self._open_federation_editor(None, on_saved=_reload)))

            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_fed_manager"))

    def _open_reason_preset_editor(self, preset=None, on_saved=None):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            preset = preset if isinstance(preset, dict) else None
            is_new = preset is None

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp_title = EditTextBoldCursor(ctx)
            inp_title.setHint(self._tr("reason_preset_title_hint"))
            inp_title.setSingleLine(True)
            inp_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_title.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_title.setText(str((preset or {}).get("title", "") or ""))
            inp_title.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            inp_reason = EditTextBoldCursor(ctx)
            inp_reason.setHint(self._tr("reason_preset_reason_hint"))
            inp_reason.setSingleLine(False)
            inp_reason.setMinLines(2)
            inp_reason.setMaxLines(5)
            inp_reason.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            inp_reason.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_reason.setText(str((preset or {}).get("reason", "") or ""))
            inp_reason.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            self._style_dialog_input(inp_title, multiline=False)
            self._style_dialog_input(inp_reason, multiline=True)
            root.addView(inp_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            lp2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp2.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_reason, lp2)

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("add_reason_preset") if is_new else self._tr("edit_reason_preset"))
            b.set_view(root)

            def _save(d, _w):
                try:
                    title = str(inp_title.getText().toString() if inp_title.getText() is not None else "").strip()
                    reason = str(inp_reason.getText().toString() if inp_reason.getText() is not None else "").strip()
                    if not title or not reason:
                        BulletinHelper.show_info(self._tr("title_message_required"))
                        return
                    if is_new:
                        rid = "rp_{0}".format(int(time.time() * 1000))
                        self._reason_presets.append({"id": rid, "title": title, "reason": reason})
                    else:
                        preset["title"] = title
                        preset["reason"] = reason
                    self._reason_presets = list(self._reason_presets or [])[:20]
                    self._save_reason_presets()
                    BulletinHelper.show_success(self._tr("reason_preset_saved"))
                    try:
                        if d:
                            d.dismiss()
                    except Exception:
                        pass
                    if callable(on_saved):
                        on_saved()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_save_reason_preset"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            self._show_builder_dialog(b, frag)
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_reason_preset_editor"))

    def _open_reason_presets_manager(self):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_reason_presets_manager", count=1, force_flush=False)
            except Exception:
                pass
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("reason_presets"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)

            hint = TextView(ctx)
            hint.setText(self._tr("reason_presets_hint"))
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                hint.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_hint = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_hint.topMargin = AndroidUtilities.dp(4)
            root.addView(hint, lp_hint)

            def _reload():
                try:
                    sheet.dismiss()
                except Exception:
                    pass
                self._open_reason_presets_manager()

            items = list(self._reason_presets or [])
            if not items:
                empty = TextView(ctx)
                empty.setText(self._tr("no_reason_presets"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                try:
                    empty.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                lp_empty = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_empty.topMargin = AndroidUtilities.dp(10)
                root.addView(empty, lp_empty)

            for it in items:
                if not isinstance(it, dict):
                    continue
                rid = str(it.get("id", "") or "").strip()
                if not rid:
                    continue
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                iconv = ImageView(ctx)
                ir = self._resolve_icon_res(ctx, "profile_list", fallback="profile_list")
                if ir > 0:
                    iconv.setImageResource(ir)
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                lp_icon.rightMargin = AndroidUtilities.dp(10)
                lp_icon.gravity = Gravity.CENTER_VERTICAL
                row.addView(iconv, lp_icon)

                text_wrap = LinearLayout(ctx)
                text_wrap.setOrientation(LinearLayout.VERTICAL)
                lp_tw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                row.addView(text_wrap, lp_tw)

                row_title = TextView(ctx)
                row_title.setText(str(it.get("title", "") or ""))
                row_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                try:
                    row_title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                except Exception:
                    pass
                text_wrap.addView(row_title)

                row_sub = TextView(ctx)
                row_sub.setText(str(it.get("reason", "") or ""))
                row_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    row_sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                text_wrap.addView(row_sub)

                del_btn = ImageView(ctx)
                rid_del = self._resolve_icon_res(ctx, "msg_delete", fallback="msg_delete")
                if rid_del > 0:
                    del_btn.setImageResource(rid_del)
                lp_del = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_del.leftMargin = AndroidUtilities.dp(8)
                lp_del.gravity = Gravity.CENTER_VERTICAL
                row.addView(del_btn, lp_del)

                def _remove_rp(_v=None, _rid=rid):
                    before = len(self._reason_presets or [])
                    self._reason_presets = [x for x in list(self._reason_presets or []) if str((x or {}).get("id", "")) != str(_rid)]
                    self._save_reason_presets()
                    if len(self._reason_presets or []) != before:
                        BulletinHelper.show_success(self._tr("reason_preset_removed"))
                    _reload()
                    return True

                row.setOnClickListener(OnClickListener(lambda v, p=it: self._open_reason_preset_editor(p, on_saved=_reload)))
                row.setOnLongClickListener(OnLongClickListener(lambda v, _rid=rid: _remove_rp(v, _rid)))
                del_btn.setOnClickListener(OnClickListener(lambda v, _rid=rid: _remove_rp(v, _rid)))

                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(8)
                root.addView(row, lp_row)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("add_reason_preset"))
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            add_btn.setGravity(17)
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            try:
                add_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                abg = GradientDrawable()
                abg.setCornerRadius(float(AndroidUtilities.dp(12)))
                abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(abg)
            except Exception:
                pass
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.gravity = 5
            lp_add.topMargin = AndroidUtilities.dp(10)
            root.addView(add_btn, lp_add)
            add_btn.setOnClickListener(OnClickListener(lambda v: self._open_reason_preset_editor(None, on_saved=_reload)))

            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_reason_presets_manager"))

    def _open_shortcut_editor(self, shortcut=None, on_saved=None):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            shortcut = shortcut if isinstance(shortcut, dict) else None
            is_new = shortcut is None

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp_title = EditTextBoldCursor(ctx)
            inp_title.setHint(self._tr("shortcut_title", "Button title"))
            inp_title.setSingleLine(True)
            inp_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_title.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_title.setText(str((shortcut or {}).get("title", "") or ""))
            inp_title.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            inp_cmd = EditTextBoldCursor(ctx)
            inp_cmd.setHint(self._tr("shortcut_command", "Command text"))
            inp_cmd.setSingleLine(False)
            inp_cmd.setMinLines(2)
            inp_cmd.setMaxLines(5)
            inp_cmd.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            inp_cmd.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_cmd.setText(str((shortcut or {}).get("command", "") or ""))
            inp_cmd.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            self._style_dialog_input(inp_title, multiline=False)
            self._style_dialog_input(inp_cmd, multiline=True)
            root.addView(inp_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            lp2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp2.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_cmd, lp2)

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("add_shortcut", "Add Shortcut") if is_new else self._tr("edit_shortcut", "Edit Shortcut"))
            b.set_view(root)

            def _save(d, _w):
                try:
                    title = str(inp_title.getText().toString() if inp_title.getText() is not None else "").strip()
                    command = str(inp_cmd.getText().toString() if inp_cmd.getText() is not None else "").strip()
                    if not title or not command:
                        BulletinHelper.show_info(self._tr("title_message_required"))
                        return
                    if is_new:
                        sid = "sc_{0}".format(int(time.time() * 1000))
                        self._shortcuts.append({"id": sid, "title": title, "command": command})
                    else:
                        shortcut["title"] = title
                        shortcut["command"] = command
                    self._shortcuts = list(self._shortcuts or [])[:20]
                    self._save_shortcuts()
                    BulletinHelper.show_success(self._tr("shortcut_saved", "Shortcut saved"))
                    try:
                        if d:
                            d.dismiss()
                    except Exception:
                        pass
                    if callable(on_saved):
                        on_saved()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_save_shortcut", "Failed to save shortcut"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            self._show_builder_dialog(b, frag)
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_shortcut_editor", "Failed to open shortcut editor"))

    def _open_shortcuts_manager(self):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_shortcuts_manager", count=1, force_flush=False)
            except Exception:
                pass
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("shortcuts", "My Shortcuts"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)

            hint = TextView(ctx)
            hint.setText(self._tr("shortcut_manager_hint", "Tap to edit. Long press or tap delete icon to remove."))
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                hint.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_hint = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_hint.topMargin = AndroidUtilities.dp(4)
            root.addView(hint, lp_hint)

            def _reload():
                try:
                    sheet.dismiss()
                except Exception:
                    pass
                self._open_shortcuts_manager()

            items = list(self._shortcuts or [])
            if not items:
                empty = TextView(ctx)
                empty.setText(self._tr("no_shortcuts_saved", "No shortcuts saved yet"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                try:
                    empty.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                lp_empty = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_empty.topMargin = AndroidUtilities.dp(10)
                root.addView(empty, lp_empty)

            for sc in items:
                if not isinstance(sc, dict):
                    continue
                sid = str(sc.get("id", "") or "").strip()
                if not sid:
                    continue
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                iconv = ImageView(ctx)
                rid = self._resolve_icon_res(ctx, "menu_feature_links", fallback="menu_feature_links")
                if rid > 0:
                    iconv.setImageResource(rid)
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                lp_icon.rightMargin = AndroidUtilities.dp(10)
                lp_icon.gravity = Gravity.CENTER_VERTICAL
                row.addView(iconv, lp_icon)

                text_wrap = LinearLayout(ctx)
                text_wrap.setOrientation(LinearLayout.VERTICAL)
                lp_tw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                row.addView(text_wrap, lp_tw)

                row_title = TextView(ctx)
                row_title.setText(str(sc.get("title", "") or ""))
                row_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                try:
                    row_title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                except Exception:
                    pass
                text_wrap.addView(row_title)

                row_sub = TextView(ctx)
                row_sub.setText(str(sc.get("command", "") or ""))
                row_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    row_sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                text_wrap.addView(row_sub)

                del_btn = ImageView(ctx)
                rid_del = self._resolve_icon_res(ctx, "msg_delete", fallback="msg_delete")
                if rid_del > 0:
                    del_btn.setImageResource(rid_del)
                lp_del = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_del.leftMargin = AndroidUtilities.dp(8)
                lp_del.gravity = Gravity.CENTER_VERTICAL
                row.addView(del_btn, lp_del)

                def _remove_sc(_v=None, _sid=sid):
                    before = len(self._shortcuts or [])
                    self._shortcuts = [x for x in list(self._shortcuts or []) if str((x or {}).get("id", "")) != str(_sid)]
                    self._save_shortcuts()
                    if len(self._shortcuts or []) != before:
                        BulletinHelper.show_success(self._tr("shortcut_removed", "Shortcut removed"))
                    _reload()
                    return True

                row.setOnClickListener(OnClickListener(lambda v, s=sc: self._open_shortcut_editor(s, on_saved=_reload)))
                row.setOnLongClickListener(OnLongClickListener(lambda v, s=sid: _remove_sc(v, s)))
                del_btn.setOnClickListener(OnClickListener(lambda v, s=sid: _remove_sc(v, s)))

                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(8)
                root.addView(row, lp_row)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("add_shortcut", "Add Shortcut"))
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            add_btn.setGravity(17)
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            try:
                add_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                abg = GradientDrawable()
                abg.setCornerRadius(float(AndroidUtilities.dp(12)))
                abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(abg)
            except Exception:
                pass
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.gravity = 5
            lp_add.topMargin = AndroidUtilities.dp(10)
            root.addView(add_btn, lp_add)
            add_btn.setOnClickListener(OnClickListener(lambda v: self._open_shortcut_editor(None, on_saved=_reload)))

            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_shortcuts_manager", "Failed to open shortcuts manager"))

    def _hook_delegate(self):
        try:
            dcls = find_class("org.telegram.ui.ChatActivity$ChatMessageCellDelegate")
            if dcls is None:
                return
            methods = []
            try:
                methods = dcls.getDeclaredMethods()
            except Exception:
                methods = dcls.getClass().getDeclaredMethods()
            press = None
            avatar = None
            longp = None
            for m in methods:
                n = str(m.getName() or "")
                if n == "didPressBotButton" and press is None:
                    press = m
                if n == "didLongPressUserAvatar" and avatar is None:
                    avatar = m
                if n == "didLongPress" and longp is None:
                    longp = m
            if press is not None:
                try:
                    press.setAccessible(True)
                except Exception:
                    pass
                r = self.hook_method(press, _BeaconTapHook(self), priority=2147483647)
                if r is not None:
                    self._refs.append(r)
            if avatar is not None:
                try:
                    avatar.setAccessible(True)
                except Exception:
                    pass
                r2 = self.hook_method(avatar, _AvatarLongHook(self), priority=2147483647)
                if r2 is not None:
                    self._refs.append(r2)
            if longp is not None:
                try:
                    longp.setAccessible(True)
                except Exception:
                    pass
                r3 = self.hook_method(longp, _CellLongPressHook(self), priority=2147483647)
                if r3 is not None:
                    self._refs.append(r3)
            self._dlog("[Tagged] hooks installed: {0}".format(len(self._refs)))
        except Exception as e:
            self._dlog("[Tagged] hook error: {0}".format(e))

    def _hook_context_menu(self):
        try:
            cls = find_class("org.telegram.ui.ChatActivity")
            if cls is None:
                return
            methods = []
            try:
                methods = cls.getDeclaredMethods()
            except Exception:
                try:
                    methods = cls.getClass().getDeclaredMethods()
                except Exception:
                    methods = []
            for m in methods:
                try:
                    if str(m.getName() or "") != "createMenu":
                        continue
                    ptypes = m.getParameterTypes()
                    plen = int(len(ptypes)) if ptypes is not None else 0
                    if plen not in (5, 6):
                        continue
                    try:
                        m.setAccessible(True)
                    except Exception:
                        pass
                    r = self.hook_method(m, _CreateMenuHook(self), priority=2147483647)
                    if r is not None:
                        self._refs.append(r)
                except Exception:
                    pass
        except Exception:
            pass

    def _hook_draw(self):
        try:
            if self._draw_refs:
                return

            cls = find_class("org.telegram.ui.Cells.ChatMessageCell")
            if cls is None:
                return

            ccls = find_class("android.graphics.Canvas")
            m = None

            try:
                if ccls is not None:
                    m = cls.getDeclaredMethod("onDraw", ccls)
            except Exception:
                m = None

            if m is None:
                try:
                    if ccls is not None:
                        m = cls.getClass().getDeclaredMethod("onDraw", ccls)
                except Exception:
                    m = None

            if m is None:
                declared = []
                try:
                    declared = cls.getDeclaredMethods()
                except Exception:
                    try:
                        declared = cls.getClass().getDeclaredMethods()
                    except Exception:
                        declared = []

                for cand in declared:
                    try:
                        nm = str(cand.getName() or "")
                        if nm == "onDraw":
                            m = cand
                            break
                    except Exception:
                        pass

            if m is None:
                return

            try:
                m.setAccessible(True)
            except Exception:
                pass

            r = self.hook_method(m, _DrawHook(self), priority=2147483647)
            if r is not None:
                self._draw_refs.append(r)

            try:
                self._dlog("[Tagged] draw hook installed: {0}".format(len(self._draw_refs)))
            except Exception:
                pass

        except Exception:
            pass

