                        for line in lines[:80]:
                            tv = TextView(ctx)
                            tv.setText(line)
                            tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                            tv.setTextColor(c_item_text)
                            lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                            lp.topMargin = AndroidUtilities.dp(6)
                            sh_root.addView(tv, lp)
                    sh = BottomSheet(ctx, True)
                    sh.setCustomView(sh_root)
                    sh.show()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_stats"))

            open_list = TextView(ctx)
            open_list.setText(self._tr("open_active_users_list"))
            open_list.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            open_list.setGravity(Gravity.CENTER)
            open_list.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                open_list.setTextColor(c_link)
                obg = GradientDrawable()
                obg.setCornerRadius(AndroidUtilities.dp(10))
                obg.setColor(c_card_bg)
                obg.setStroke(AndroidUtilities.dp(1), c_card_stroke)
                open_list.setBackground(obg)
            except Exception:
                pass
            open_list.setOnClickListener(OnClickListener(_open_stats_sheet))
            root.addView(open_list, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            open_list_sub = TextView(ctx)
            open_list_sub.setText(self._tr("advanced_open_list_sub", "View all active users and action counters."))
            open_list_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 11)
            open_list_sub.setTextColor(c_sub)
            lp_ols = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_ols.leftMargin = AndroidUtilities.dp(4)
            lp_ols.topMargin = AndroidUtilities.dp(4)
            lp_ols.bottomMargin = AndroidUtilities.dp(8)
            root.addView(open_list_sub, lp_ols)

            reset_stats = TextView(ctx)
            reset_stats.setText(self._tr("reset_stats"))
            reset_stats.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            reset_stats.setGravity(Gravity.CENTER)
            reset_stats.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            reset_stats.setTextColor(c_danger_text)
            try:
                rbg = GradientDrawable()
                rbg.setCornerRadius(AndroidUtilities.dp(10))
                rbg.setColor(c_danger_bg)
                rbg.setStroke(AndroidUtilities.dp(1), c_danger_stroke)
                reset_stats.setBackground(rbg)
            except Exception:
                pass

            def _do_reset(_v=None):
                self._admin_stats = {}
                self._save_admin_stats()
                BulletinHelper.show_success(self._tr("stats_reset"))

            reset_stats.setOnClickListener(OnClickListener(_do_reset))
            lp_rs = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_rs.topMargin = AndroidUtilities.dp(4)
            root.addView(reset_stats, lp_rs)
            reset_sub = TextView(ctx)
            reset_sub.setText(self._tr("advanced_reset_stats_sub", "Clear all local analytics data from Vanguard."))
            reset_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 11)
            reset_sub.setTextColor(c_sub)
            lp_rss = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_rss.leftMargin = AndroidUtilities.dp(4)
            lp_rss.topMargin = AndroidUtilities.dp(4)
            root.addView(reset_sub, lp_rss)

            b.set_view(root)
            b.set_positive_button(
                self._tr("back"),
                lambda d, w: (
                    d.dismiss() if d else None,
                    on_back() if callable(on_back) else None
                ),
            )
            b.set_negative_button(
                self._tr("close"),
                lambda d, w: (
                    d.dismiss() if d else None,
                    on_back() if callable(on_back) else None
                ),
            )
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_advanced"))

    def _gf(self, obj, name, default=None):
        if obj is None:
            return default
        try:
            cls = obj.getClass()
        except Exception:
            return default
        k = "{0}:{1}".format(str(cls), str(name))
        f = self._field_cache.get(k)
        if f is None:
            c = cls
            while c is not None:
                try:
                    ff = c.getDeclaredField(name)
                    ff.setAccessible(True)
                    f = ff
                    break
                except Exception:
                    try:
                        c = c.getSuperclass()
                    except Exception:
                        c = None
            self._field_cache[k] = f
        try:
            return f.get(obj) if f is not None else default
        except Exception:
            return default

    def on_plugin_unload(self):
        try:
            self._save_telemetry_queue()
        except Exception:
            pass
        try:
            self._save_admin_stats()
        except Exception:
            pass
        for r in list(self._refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._refs = []
        for r in list(self._draw_refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._draw_refs = []
        for r in list(self._bind_refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._bind_refs = []
        for r in list(self._touch_refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._touch_refs = []
        for r in list(self._incoming_refs):
            try:
                self.unhook_method(r)
            except Exception:
                pass
        self._incoming_refs = []
        self._remove_admin_tab_hooks()
        try:
            if self._settings_header_hook:
                self.unhook_method(self._settings_header_hook)
                self._settings_header_hook = None
        except Exception:
            pass
        try:
            if self._chat_menu_item:
                self.remove_menu_item(self._chat_menu_item)
                self._chat_menu_item = None
        except Exception:
            pass
        try:
            self._remove_live_log()
        except Exception:
            pass

    def _is_our_settings_activity(self, activity):
        try:
            if activity is None:
                return False
            p = None
            try:
                p = _pf(activity, "plugin", None)
            except Exception:
                p = None
            if not p:
                return False
            pid = ""
            try:
                pid = str(p.getId() or "").strip().lower()
            except Exception:
                pid = ""
            if pid == str(__id__).strip().lower():
                return True
            try:
                nm = str(p.getName() or "").strip().lower()
            except Exception:
                nm = ""
            return nm == str(__name__).strip().lower()
        except Exception:
            return False

