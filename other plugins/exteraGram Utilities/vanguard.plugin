                rr_fallback.setOrientation(LinearLayout.HORIZONTAL)
                rr_fallback.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
                lp_rrf = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_rrf.topMargin = AndroidUtilities.dp(6)
                rr_fallback.addView(remove_btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                note_wrap.addView(rr_fallback, lp_rrf)

            sub_actions_row = LinearLayout(ctx)
            sub_actions_row.setOrientation(LinearLayout.HORIZONTAL)
            sub_actions_row.setGravity(Gravity.CENTER_VERTICAL)
            lp_sar = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sar.topMargin = AndroidUtilities.dp(8)
            root.addView(sub_actions_row, lp_sar)

            left_actions = LinearLayout(ctx)
            left_actions.setOrientation(LinearLayout.HORIZONTAL)
            left_actions.setGravity(Gravity.CENTER_VERTICAL)
            lp_la = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            sub_actions_row.addView(left_actions, lp_la)

            badge_icon = ImageView(ctx)
            rid_badge = self._resolve_icon_res(ctx, "msg_emoji_smiles", fallback="msg_emoji_smiles")
            if rid_badge > 0:
                badge_icon.setImageResource(rid_badge)
            try:
                badge_icon.setColorFilter(c_link)
            except Exception:
                pass
            lp_bi = LinearLayout.LayoutParams(AndroidUtilities.dp(16), AndroidUtilities.dp(16))
            lp_bi.rightMargin = AndroidUtilities.dp(6)
            left_actions.addView(badge_icon, lp_bi)
            left_actions.addView(pick_emoji, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            details_btn = TextView(ctx)
            details_btn.setText(self._tr("tag_details"))
            details_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                details_btn.setTextColor(c_link)
            except Exception:
                pass
            details_btn.setPadding(AndroidUtilities.dp(2), AndroidUtilities.dp(6), AndroidUtilities.dp(2), AndroidUtilities.dp(6))
            sub_actions_row.addView(details_btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            pick_emoji.setOnClickListener(OnClickListener(lambda v: self._open_emoji_picker(ctx, frag, inp_name)))
            inp_name.setOnClickListener(OnClickListener(lambda v: _clear_label()))

            sep_alias = View(ctx)
            try:
                sep_alias.setBackgroundColor(c_sep)
            except Exception:
                pass
            lp_sep_alias = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(1))
            lp_sep_alias.topMargin = AndroidUtilities.dp(8)
            lp_sep_alias.bottomMargin = AndroidUtilities.dp(8)
            root.addView(sep_alias, lp_sep_alias)

            alias_row = LinearLayout(ctx)
            alias_row.setOrientation(LinearLayout.HORIZONTAL)
            alias_row.setGravity(Gravity.CENTER_VERTICAL)
            root.addView(alias_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            inp_alias = EditTextBoldCursor(ctx)
            inp_alias.setHint(self._tr("add_nickname"))
            inp_alias.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_alias.setSingleLine(True)
            inp_alias.setMaxLines(1)
            inp_alias.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_alias.setText(d_alias)
            inp_alias.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(110), AndroidUtilities.dp(12))
            self._style_dialog_input(inp_alias, multiline=False)
            inp_alias.setFocusable(False)
            inp_alias.setFocusableInTouchMode(False)
            inp_alias.setCursorVisible(False)
            try:
                inp_alias.setShowSoftInputOnFocus(False)
            except Exception:
                pass

            alias_wrap = FrameLayout(ctx) if FrameLayout is not None else LinearLayout(ctx)
            if FrameLayout is None:
                alias_wrap.setOrientation(LinearLayout.VERTICAL)
            alias_row.addView(alias_wrap, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))
            if FrameLayout is not None:
                alias_wrap.addView(inp_alias, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT))
            else:
                alias_wrap.addView(inp_alias, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            alias_remove_btn = TextView(ctx)
            alias_remove_btn.setText(self._tr("remove"))
            alias_remove_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            alias_remove_btn.setGravity(Gravity.CENTER)
            alias_remove_btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(6), AndroidUtilities.dp(10), AndroidUtilities.dp(6))

            def _set_alias_remove_enabled(enabled):
                try:
                    en = bool(enabled)
                    alias_remove_btn.setEnabled(en)
                    bg = GradientDrawable()
                    bg.setCornerRadius(AndroidUtilities.dp(10))
                    if en:
                        bg.setColor(c_warn_bg)
                        bg.setStroke(AndroidUtilities.dp(1), c_warn_stroke)
                        alias_remove_btn.setTextColor(c_warn_text)
                    else:
                        bg.setColor(Color.parseColor("#5C6675"))
                        bg.setStroke(AndroidUtilities.dp(1), Color.parseColor("#7A8798"))
                        alias_remove_btn.setTextColor(Color.parseColor("#D4D9E0"))
                    alias_remove_btn.setBackground(bg)
                except Exception:
                    pass

            if FrameLayout is not None:
                lp_arb = FrameLayout.LayoutParams(FrameLayout.LayoutParams.WRAP_CONTENT, FrameLayout.LayoutParams.WRAP_CONTENT)
                lp_arb.gravity = Gravity.END | Gravity.CENTER_VERTICAL
                lp_arb.rightMargin = AndroidUtilities.dp(8)
                alias_wrap.addView(alias_remove_btn, lp_arb)
            else:
                alias_rf = LinearLayout(ctx)
                alias_rf.setOrientation(LinearLayout.HORIZONTAL)
                alias_rf.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
                lp_alias_rf = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_alias_rf.topMargin = AndroidUtilities.dp(6)
                alias_rf.addView(alias_remove_btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                alias_wrap.addView(alias_rf, lp_alias_rf)

            _set_alias_remove_enabled(bool(str(d_alias or "").strip()))

            def _open_alias_editor(_v=None):
                try:
                    nb = AlertDialogBuilder(ctx)
                    nb.set_title(self._tr("nickname_title"))
                    nroot = LinearLayout(ctx)
                    nroot.setOrientation(LinearLayout.VERTICAL)
                    nroot.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))
                    nedit = EditTextBoldCursor(ctx)
                    nedit.setHint(self._tr("add_nickname"))
                    nedit.setInputType(InputType.TYPE_CLASS_TEXT)
                    nedit.setSingleLine(True)
                    nedit.setText(str(inp_alias.getText().toString() if inp_alias.getText() is not None else ""))
                    self._style_dialog_input(nedit, multiline=False)
                    nroot.addView(nedit, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                    nb.set_view(nroot)

                    def _save_alias(dd, _ww):
                        try:
                            val = str(nedit.getText().toString() if nedit.getText() is not None else "").strip()
                            if self._user_alias_set(uid, val):
                                inp_alias.setText(val)
                                _set_alias_remove_enabled(bool(val))
                                BulletinHelper.show_success(self._tr("nickname_saved"))
                                if dd:
                                    dd.dismiss()
                                try:
                                    self._rerender_vanguard_beacon_panel(cell, nonce)
                                except Exception:
                                    pass
                            else:
                                BulletinHelper.show_info(self._tr("failed_save_nickname"))
                        except Exception:
                            BulletinHelper.show_info(self._tr("failed_save_nickname"))

                    nb.set_positive_button(self._tr("save"), _save_alias)
                    nb.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
                    nb.show()
                except Exception:
