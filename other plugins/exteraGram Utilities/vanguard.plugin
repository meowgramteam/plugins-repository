                info_id_btn.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
                lp_iid = LinearLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24))
                lp_iid.leftMargin = AndroidUtilities.dp(6)
                user_row.addView(info_id_btn, lp_iid)

            def _copy_user_id(_v=None):
                try:
                    cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
                    cm.setPrimaryClip(ClipData.newPlainText("user_id", str(int(uid))))
                    BulletinHelper.show_success("User ID copied")
                except Exception:
                    BulletinHelper.show_info("Failed to copy User ID")

            user_id_tv.setOnClickListener(OnClickListener(_copy_user_id))

            inp_name = EditTextBoldCursor(ctx)
            inp_name.setHint("")
            inp_name.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_name.setSingleLine(True)
            inp_name.setMaxLines(1)
            inp_name.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_name.setText(d_name)
            inp_name.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
            inp_name.setGravity(Gravity.CENTER)
            try:
                inp_name.setTextAlignment(Gravity.CENTER)
            except Exception:
                pass
            inp_name.setFocusable(False)
            inp_name.setFocusableInTouchMode(False)
            inp_name.setCursorVisible(False)
            try:
                inp_name.setShowSoftInputOnFocus(False)
            except Exception:
                pass

            inp_tag = EditTextBoldCursor(ctx)
            inp_tag.setHint(self._tr("add_note"))
            inp_tag.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_tag.setSingleLine(True)
            inp_tag.setMaxLines(1)
            inp_tag.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_tag.setText(d_tag)
            inp_tag.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(110), AndroidUtilities.dp(12))
            self._style_dialog_input(inp_name, multiline=False)
            self._style_dialog_input(inp_tag, multiline=False)
            inp_tag.setFocusable(False)
            inp_tag.setFocusableInTouchMode(False)
            inp_tag.setCursorVisible(False)
            try:
                inp_tag.setShowSoftInputOnFocus(False)
            except Exception:
                pass
            try:
                ebg = GradientDrawable()
                ebg.setShape(GradientDrawable.OVAL)
                ebg.setColor(c_chip_bg)
                ebg.setStroke(AndroidUtilities.dp(1), c_chip_stroke)
                inp_name.setBackground(ebg)
                inp_name.setPadding(AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(0), AndroidUtilities.dp(0))
            except Exception:
                pass
            pick_emoji = TextView(ctx)
            pick_emoji.setText(self._tr("change_badge"))
            pick_emoji.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            pick_emoji.setPadding(AndroidUtilities.dp(2), AndroidUtilities.dp(8), AndroidUtilities.dp(2), AndroidUtilities.dp(8))
            try:
                pick_emoji.setTextColor(Theme.getColor(Theme.key_dialogTextLink))
            except Exception:
                pass

            def _clear_label():
                try:
                    cur = str(inp_name.getText().toString() if inp_name.getText() is not None else "").strip()
                    if not cur:
                        BulletinHelper.show_info(self._tr("no_badge_to_clear"))
                        return
                    inp_name.setText("")
                    BulletinHelper.show_info(self._tr("label_cleared"))
                except Exception:
                    pass

            main_editor_row = LinearLayout(ctx)
            main_editor_row.setOrientation(LinearLayout.HORIZONTAL)
            main_editor_row.setGravity(Gravity.CENTER_VERTICAL)
            lp_mer = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_mer.topMargin = AndroidUtilities.dp(8)
            root.addView(main_editor_row, lp_mer)

            lp_name = LinearLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48))
            main_editor_row.addView(inp_name, lp_name)

            FrameLayout = None
            try:
                from android.widget import FrameLayout as _FrameLayout
                FrameLayout = _FrameLayout
            except Exception:
                FrameLayout = None

            note_wrap = FrameLayout(ctx) if FrameLayout is not None else LinearLayout(ctx)
            if FrameLayout is None:
                note_wrap.setOrientation(LinearLayout.VERTICAL)
            lp_input = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_input.leftMargin = AndroidUtilities.dp(8)
            main_editor_row.addView(note_wrap, lp_input)
            if FrameLayout is not None:
                note_wrap.addView(inp_tag, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT))
            else:
                note_wrap.addView(inp_tag, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            remove_btn = TextView(ctx)
            remove_btn.setText(self._tr("remove_tag"))
            remove_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            remove_btn.setGravity(Gravity.CENTER)
            remove_btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(6), AndroidUtilities.dp(10), AndroidUtilities.dp(6))
            try:
                rmbg = GradientDrawable()
                rmbg.setCornerRadius(AndroidUtilities.dp(10))
                rmbg.setColor(c_danger_bg)
                rmbg.setStroke(AndroidUtilities.dp(1), c_danger_stroke)
                remove_btn.setBackground(rmbg)
                remove_btn.setTextColor(c_danger_text)
            except Exception:
