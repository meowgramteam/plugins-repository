    def _admin_tab_open_native_search(self):
        try:
            frag = get_last_fragment()
            if frag is None:
                return
            self._dlog("admin_tab: open native search")
            def _invoke_candidates(obj, names):
                if obj is None:
                    return False
                cls = obj.getClass()
                methods = []
                while cls is not None:
                    try:
                        methods.extend(list(cls.getDeclaredMethods() or []))
                    except Exception:
                        pass
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
                for nm in names:
                    for mm in methods:
                        try:
                            if str(mm.getName() or "") != str(nm):
                                continue
                            mm.setAccessible(True)
                            ptypes = list(mm.getParameterTypes() or [])
                            argc = int(len(ptypes))
                            if argc == 0:
                                mm.invoke(obj)
                                self._dlog("admin_tab: native search invoked {0}()".format(str(nm)))
                                return True
                            if argc == 1:
                                t0 = str(ptypes[0].getName() or "")
                                if t0 == "boolean":
                                    mm.invoke(obj, True)
                                    self._dlog("admin_tab: native search invoked {0}(bool)".format(str(nm)))
                                    return True
                                if t0 == "java.lang.String":
                                    mm.invoke(obj, "")
                                    self._dlog("admin_tab: native search invoked {0}(str)".format(str(nm)))
                                    return True
                            if argc == 2:
                                t0 = str(ptypes[0].getName() or "")
                                t1 = str(ptypes[1].getName() or "")
                                if t0 == "java.lang.String" and t1 == "boolean":
                                    mm.invoke(obj, "", True)
                                    self._dlog("admin_tab: native search invoked {0}(str,bool)".format(str(nm)))
                                    return True
                        except Exception:
                            pass
                return False

            if _invoke_candidates(frag, ("openSearchWithText", "openSearchField", "openSearch", "showSearch", "onSearchPressed", "showSearchView")):
                try:
                    self._telemetry_queue_event("feature_use", feature="admin_tab_search", count=1, force_flush=False)
                except Exception:
                    pass
                return
            ab = None
            try:
                ab = frag.getActionBar() if hasattr(frag, "getActionBar") else None
            except Exception:
                ab = None
            if _invoke_candidates(ab, ("openSearchField", "openSearch", "showSearchField", "onSearchFieldVisibilityChanged")):
                try:
                    self._telemetry_queue_event("feature_use", feature="admin_tab_search", count=1, force_flush=False)
                except Exception:
                    pass
                return
            try:
                if hasattr(frag, "onSearchPressed"):
                    frag.onSearchPressed()
                    self._dlog("admin_tab: native search fallback onSearchPressed")
                    try:
                        self._telemetry_queue_event("feature_use", feature="admin_tab_search", count=1, force_flush=False)
                    except Exception:
                        pass
                    return
            except Exception:
                pass
            BulletinHelper.show_info(self._tr("failed_open_search"))
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_search"))

    def _admin_tab_send_custom(self, item):
        try:
            if self._admin_tab_commands_locked():
                BulletinHelper.show_info(self._tr("admin_tab_commands_locked_hint"))
                return
            did = int(self._active_dialog_id() or 0)
            if not self._is_chat_dialog(did):
                BulletinHelper.show_info(self._tr("admin_tab_chat_only"))
                return
            cmd = str((item or {}).get("command", "") or "").strip()
            if not cmd:
                BulletinHelper.show_info(self._tr("message_empty"))
                return
            self._dlog("admin_tab: custom send did={0} cmd={1}".format(int(did), cmd))
            ok = self._send_warning_message(int(did), cmd, reply_to=None)
            try:
                if ok:
                    self._telemetry_queue_event("feature_use", feature="admin_tab_custom", count=1, force_flush=False)
            except Exception:
                pass
            if not ok:
                BulletinHelper.show_info(self._tr("failed_send_command"))
        except Exception:
            BulletinHelper.show_info(self._tr("failed_send_command"))

    def _admin_tab_commands_locked(self):
        try:
            v = self.get_setting("tagged_admin_tab_commands_locked", False)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            return s in ("1", "true", "on", "yes", "enabled", "locked")
        except Exception:
            return False

    def _set_admin_tab_commands_locked(self, locked):
        try:
            self.set_setting("tagged_admin_tab_commands_locked", bool(locked))
        except Exception:
            pass

    def _run_admin_tab_ui_mutation(self, fn, delay_ms=16):
        try:
            def _wrap():
                try:
                    fn()
                except Exception:
                    pass
            try:
                AndroidUtilities.runOnUIThread(_wrap, int(delay_ms or 0))
                return True
            except Exception:
                pass
            try:
                run_on_ui_thread(_wrap)
                return True
            except Exception:
                pass
        except Exception:
            pass
        return False

    def _toggle_admin_tab_commands_locked(self):
        try:
            locked = not bool(self._admin_tab_commands_locked())
            self._set_admin_tab_commands_locked(locked)
            if locked:
                BulletinHelper.show_info(self._tr("admin_tab_commands_locked"))
            else:
                BulletinHelper.show_success(self._tr("admin_tab_commands_unlocked"))
            self._schedule_admin_tab_refresh(80)
        except Exception:
            pass

    def _open_admin_custom_editor(self, context, item=None, on_saved=None):
        try:
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            it = item if isinstance(item, dict) else None
            is_new = it is None

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp_title = EditTextBoldCursor(context)
            inp_title.setHint(self._tr("admin_custom_title"))
            inp_title.setSingleLine(True)
            inp_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            inp_title.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_title.setText(str((it or {}).get("title", "") or ""))
            self._style_dialog_input(inp_title, multiline=False)
            try:
                inp_title.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(11), AndroidUtilities.dp(14), AndroidUtilities.dp(11))
            except Exception:
                pass

            inp_desc = EditTextBoldCursor(context)
            inp_desc.setHint(self._tr("admin_custom_description"))
            inp_desc.setSingleLine(True)
            inp_desc.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            inp_desc.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_desc.setText(str((it or {}).get("description", "") or ""))
            self._style_dialog_input(inp_desc, multiline=False)
            try:
                inp_desc.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(11), AndroidUtilities.dp(14), AndroidUtilities.dp(11))
            except Exception:
                pass

            inp_cmd = EditTextBoldCursor(context)
            inp_cmd.setHint(self._tr("admin_custom_command"))
            inp_cmd.setSingleLine(True)
            inp_cmd.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            inp_cmd.setInputType(InputType.TYPE_CLASS_TEXT)
            inp_cmd.setText(str((it or {}).get("command", "") or ""))
            self._style_dialog_input(inp_cmd, multiline=False)
            try:
                inp_cmd.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(11), AndroidUtilities.dp(14), AndroidUtilities.dp(11))
            except Exception:
                pass

            root.addView(inp_title)
            lp_d = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_d.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_desc, lp_d)
            lp_c = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_c.topMargin = AndroidUtilities.dp(10)
            root.addView(inp_cmd, lp_c)

            b = AlertDialogBuilder(context)
            b.set_title(self._tr("admin_custom_add") if is_new else self._tr("admin_custom_edit"))
            b.set_view(root)

            def _save(_d, _w):
                try:
                    title = str(inp_title.getText().toString() if inp_title.getText() is not None else "").strip()
                    desc = str(inp_desc.getText().toString() if inp_desc.getText() is not None else "").strip()
                    cmd = str(inp_cmd.getText().toString() if inp_cmd.getText() is not None else "").strip()
                    if not title or not cmd:
                        BulletinHelper.show_info(self._tr("title_message_required"))
                        return
                    if is_new:
                        self._admin_custom_actions.append({
                            "id": "ac_{0}".format(int(time.time() * 1000)),
                            "title": title,
                            "description": desc,
                            "command": cmd,
                        })
                    else:
                        it["title"] = title
                        it["description"] = desc
                        it["command"] = cmd
                    self._admin_custom_actions = list(self._admin_custom_actions or [])[:20]
                    self._save_admin_custom_actions()
                    self._schedule_admin_tab_refresh(120)
                    BulletinHelper.show_success(self._tr("admin_custom_saved"))
                    if _d:
                        _d.dismiss()
                    if callable(on_saved):
                        on_saved()
                except Exception:
                    BulletinHelper.show_info(self._tr("admin_custom_failed_save"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("admin_custom_failed_open"))

    def _open_admin_custom_sheet(self, context):
        try:
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity

            sheet = BottomSheet(context, True)
            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(context)
            title.setText(self._tr("admin_custom_title_sheet"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            try:
                title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            root.addView(title)

            hint = TextView(context)
            hint.setText(self._tr("admin_custom_hint"))
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            try:
                hint.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_hint = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_hint.topMargin = AndroidUtilities.dp(4)
            root.addView(hint, lp_hint)

            def _reload():
                try:
                    sheet.dismiss()
                except Exception:
                    pass
                self._open_admin_custom_sheet(context)

            items = list(self._admin_custom_actions or [])
            for it in items:
                if not isinstance(it, dict):
                    continue
                cid = str(it.get("id", "") or "").strip()
                if not cid:
                    continue
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                iconv = ImageView(context)
                ir = self._resolve_icon_res(context, "profile_list", fallback="profile_list")
                if ir > 0:
                    iconv.setImageResource(ir)
                lp_icon = LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20))
                lp_icon.rightMargin = AndroidUtilities.dp(10)
                row.addView(iconv, lp_icon)

                tw = LinearLayout(context)
                tw.setOrientation(LinearLayout.VERTICAL)
                lp_tw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                row.addView(tw, lp_tw)

                rt = TextView(context)
                rt.setText(str(it.get("title", "") or ""))
                rt.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                try:
                    rt.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                except Exception:
                    pass
                tw.addView(rt)

                rs = TextView(context)
                rs.setText(str(it.get("description", "") or ""))
                rs.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    rs.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
                except Exception:
                    pass
                tw.addView(rs)

                del_btn = ImageView(context)
                rid_del = self._resolve_icon_res(context, "msg_delete", fallback="msg_delete")
                if rid_del > 0:
                    del_btn.setImageResource(rid_del)
                lp_del = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_del.leftMargin = AndroidUtilities.dp(8)
                row.addView(del_btn, lp_del)

                def _remove(_v=None, _cid=cid):
                    before = len(self._admin_custom_actions or [])
                    self._admin_custom_actions = [x for x in list(self._admin_custom_actions or []) if str((x or {}).get("id", "")) != str(_cid)]
                    self._save_admin_custom_actions()
                    self._schedule_admin_tab_refresh(120)
                    if len(self._admin_custom_actions or []) != before:
                        BulletinHelper.show_success(self._tr("admin_custom_removed"))
                    _reload()
                    return True

                row.setOnClickListener(OnClickListener(lambda v, p=it: self._open_admin_custom_editor(context, p, on_saved=_reload)))
                row.setOnLongClickListener(OnLongClickListener(lambda v, _cid=cid: _remove(v, _cid)))
                del_btn.setOnClickListener(OnClickListener(lambda v, _cid=cid: _remove(v, _cid)))

                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(8)
                root.addView(row, lp_row)

            add_btn = TextView(context)
            add_btn.setText(self._tr("admin_custom_add"))
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            add_btn.setGravity(17)
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            try:
                add_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                abg = GradientDrawable()
                abg.setCornerRadius(float(AndroidUtilities.dp(12)))
                abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(abg)
            except Exception:
                pass
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.gravity = 5
            lp_add.topMargin = AndroidUtilities.dp(10)
            root.addView(add_btn, lp_add)
            add_btn.setOnClickListener(OnClickListener(lambda v: self._open_admin_custom_editor(context, None, on_saved=_reload)))

            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("admin_custom_failed_open"))

    def _admin_tab_open_lock_actions(self, context):
        try:
            self._dlog("admin_tab: open lock actions")
            b = AlertDialogBuilder(context)
            b.set_title(self._tr("admin_tab_lock_sheet_title"))
            b.set_message(self._tr("admin_tab_lock_sheet_sub"))
            b.set_positive_button(self._tr("admin_tab_lock_all"), lambda d, _w: (self._admin_tab_send_lock(), d.dismiss() if d else None))
            b.set_neutral_button(self._tr("admin_tab_unlock_action"), lambda d, _w: (self._admin_tab_send_unlock(), d.dismiss() if d else None))
            b.set_negative_button(self._tr("cancel"), lambda d, _w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_send_command"))

    def _refresh_admin_tab_view(self):
        try:
            frag = get_last_fragment()
            if frag is None:
                return
            enter_view = _pf(frag, "chatActivityEnterView", None)
            emoji_view = _pf(enter_view, "emojiView", None) if enter_view is not None else None
            if emoji_view is None:
                return
            all_tabs = get_private_field(emoji_view, "allTabs")
            if all_tabs is None:
                return
            for i in range(int(all_tabs.size() or 0)):
                try:
                    t = all_tabs.get(i)
                    old_view = get_private_field(t, "view")
                    tg = old_view.getTag() if old_view is not None and hasattr(old_view, "getTag") else None
                    if str(tg or "") != str(VANGUARD_ADMIN_TAB_VIEW_TAG):
                        continue
                    ctx = old_view.getContext() if old_view is not None and hasattr(old_view, "getContext") else emoji_view.getContext()
                    new_view = self._create_admin_tab_view(ctx)
                    if new_view is None:
                        return
                    if old_view is not None and hasattr(old_view, "removeAllViews") and hasattr(new_view, "getChildCount"):
                        try:
                            old_view.removeAllViews()
                        except Exception:
                            pass
                        try:
                            old_view.setPadding(
                                int(new_view.getPaddingLeft()),
                                int(new_view.getPaddingTop()),
                                int(new_view.getPaddingRight()),
                                int(new_view.getPaddingBottom()),
                            )
                        except Exception:
                            pass
                        try:
                            old_view.setBackground(new_view.getBackground())
                        except Exception:
                            pass
                        while True:
                            try:
                                cnt = int(new_view.getChildCount() or 0)
                            except Exception:
                                cnt = 0
                            if cnt <= 0:
                                break
                            child = None
                            try:
                                child = new_view.getChildAt(0)
                            except Exception:
                                child = None
                            if child is None:
                                break
                            try:
                                new_view.removeView(child)
                            except Exception:
                                pass
                            try:
                                old_view.addView(child)
                            except Exception:
                                pass
                        self._admin_tab_views[str(emoji_view)] = old_view
                        self._attach_admin_tab_pager_listener(emoji_view, old_view)
                        try:
                            old_view.invalidate()
                            old_view.requestLayout()
                        except Exception:
                            pass
                    return
                except Exception:
                    pass
        except Exception:
            pass

    def _parse_peek_dialog_id(self, raw_text):
        try:
            s = str(raw_text or "").strip()
            if not s:
                return 0
            v = int(s)
            if v < 0:
                return int(v)
            return -int("100{0}".format(int(v)))
        except Exception:
            return 0

    def _admin_tab_open_add_peek(self, context):
        try:
            if len(list(self._peek_groups or [])) >= 5:
                BulletinHelper.show_info(self._tr("peek_limit"))
                return
            b = AlertDialogBuilder(context)
            b.set_title(self._tr("peek_add_title"))
            b.set_message(self._tr("peek_add_sub"))
            wrap = jclass("android.widget.LinearLayout")(context)
            wrap.setOrientation(1)
            wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(6))
            inp = jclass("org.telegram.ui.Components.EditTextBoldCursor")(context)
            inp.setSingleLine(True)
            inp.setHint(self._tr("peek_input_hint"))
            self._style_dialog_input(inp, multiline=False)
            wrap.addView(inp)
            b.set_view(wrap)

            def _save(_d, _w):
                try:
                    did = int(self._parse_peek_dialog_id(inp.getText().toString() if inp.getText() is not None else "") or 0)
                    if did >= 0:
                        BulletinHelper.show_info(self._tr("peek_group_only"))
                        return
                    ok, status = self._peek_add_or_update(did, self._dialog_title_by_id(did))
                    if ok:
                        try:
                            self._telemetry_queue_event("feature_use", feature="peek_add", count=1, force_flush=False)
                        except Exception:
                            pass
                        BulletinHelper.show_success(self._tr("peek_added"))
                    elif status == "limit":
                        BulletinHelper.show_info(self._tr("peek_limit"))
                    else:
                        BulletinHelper.show_info(self._tr("peek_group_only"))
                    if _d:
                        _d.dismiss()
                except Exception:
                    BulletinHelper.show_info(self._tr("peek_group_only"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, _w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("peek_group_only"))

    def _admin_tab_add_current_chat_peek(self):
        try:
            did = int(self._active_dialog_id() or 0)
            if did >= 0:
                BulletinHelper.show_info(self._tr("peek_group_only"))
                return
            ok, status = self._peek_add_or_update(int(did), self._dialog_title_by_id(int(did)))
            if ok:
                try:
                    self._telemetry_queue_event("feature_use", feature="peek_add", count=1, force_flush=False)
                except Exception:
                    pass
                BulletinHelper.show_success(self._tr("peek_added"))
            elif status == "limit":
                BulletinHelper.show_info(self._tr("peek_limit"))
            else:
                BulletinHelper.show_info(self._tr("peek_group_only"))
        except Exception:
            BulletinHelper.show_info(self._tr("peek_group_only"))

    def _admin_tab_open_peek(self, item):
        try:
            did = int((item or {}).get("id", 0) or 0)
            if did >= 0:
                BulletinHelper.show_info(self._tr("peek_group_only"))
                return
            self._dlog("admin_tab: open peek did={0}".format(int(did)))
            ok = bool(self._present_chat_preview(int(did), panel_dialog=None))
            try:
                if ok:
                    self._telemetry_queue_event("feature_use", feature="peek_open", count=1, force_flush=False)
            except Exception:
                pass
            if not ok:
                BulletinHelper.show_info(self._tr("peek_open_failed"))
        except Exception:
            BulletinHelper.show_info(self._tr("peek_open_failed"))

    def _admin_tab_remove_peek(self, item):
        try:
            did = int((item or {}).get("id", 0) or 0)
            if did == 0:
                return
            if self._peek_remove(did):
                try:
                    self._telemetry_queue_event("feature_use", feature="peek_remove", count=1, force_flush=False)
                except Exception:
                    pass
                BulletinHelper.show_success(self._tr("peek_removed"))
            else:
                BulletinHelper.show_info(self._tr("peek_remove_failed"))
        except Exception:
            BulletinHelper.show_info(self._tr("peek_remove_failed"))

    def _create_admin_tab_view(self, context):
        try:
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable
            from android.graphics import Color

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setTag(VANGUARD_ADMIN_TAB_VIEW_TAG)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            try:
                V = find_class("android.view.View")
                root.setVisibility(int(getattr(V, "INVISIBLE", 4)))
            except Exception:
                pass
            try:
                root.setBackgroundColor(int(Theme.getColor(Theme.key_chat_emojiPanelBackground)))
            except Exception:
                pass
            try:
                c_hello = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                c_hello = 0xFFF2F5FA
            try:
                c_sub = int(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                c_sub = 0xFFD7E0EC

            top_row = LinearLayout(context)
            top_row.setOrientation(LinearLayout.HORIZONTAL)
            top_row.setGravity(16)
            root.addView(top_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            left = LinearLayout(context)
            left.setOrientation(LinearLayout.VERTICAL)
            lp_left = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            top_row.addView(left, lp_left)

            hello_row = LinearLayout(context)
            hello_row.setOrientation(LinearLayout.HORIZONTAL)
            hello_row.setGravity(16)
            left.addView(hello_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            hello = TextView(context)
            hello.setText(self._tr("admin_tab_hello_fmt").format(name=str(self._get_user_first_name() or "User")))
            hello.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            try:
                hello.setTextColor(c_hello)
                hello.setAlpha(0.98)
            except Exception:
                pass
            hello_row.addView(hello, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            av = None
            try:
                from org.telegram.ui.Components import BackupImageView, AvatarDrawable
                uc = get_user_config()
                admin_uid = int(uc.getClientUserId()) if uc is not None else 0
                admin_user = get_messages_controller().getUser(int(admin_uid)) if admin_uid > 0 else None
                av = BackupImageView(context)
                av.setRoundRadius(AndroidUtilities.dp(9))
                if admin_user is not None:
                    try:
                        av.setForUserOrChat(admin_user, AvatarDrawable(admin_user))
                    except Exception:
                        av.setImageDrawable(AvatarDrawable(admin_user))
                else:
                    av.setImageDrawable(AvatarDrawable())
            except Exception:
                av = ImageView(context)
                try:
                    rid_avatar = self._resolve_icon_res(context, "msg_contact_status", fallback="msg_contact_status")
                    if rid_avatar > 0:
                        av.setImageResource(rid_avatar)
                    av.setColorFilter(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                except Exception:
                    pass
            if av is not None:
                lp_av = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_av.leftMargin = AndroidUtilities.dp(6)
                hello_row.addView(av, lp_av)

            sub = TextView(context)
            sub.setText(self._tr("admin_tab_welcome_sub"))
            sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            try:
                sub.setTextColor(c_sub)
                sub.setAlpha(0.86)
            except Exception:
                pass
            lp_sub = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sub.topMargin = AndroidUtilities.dp(3)
            left.addView(sub, lp_sub)

            search_btn = ImageView(context)
            rid_search = self._resolve_icon_res(context, "msg_search", fallback="msg_search")
            if rid_search > 0:
                search_btn.setImageResource(rid_search)
            try:
                search_btn.setColorFilter(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
            except Exception:
                pass
            search_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
            lp_se = LinearLayout.LayoutParams(AndroidUtilities.dp(34), AndroidUtilities.dp(34))
            lp_se.leftMargin = AndroidUtilities.dp(8)
            lp_se.gravity = 48
            top_row.addView(search_btn, lp_se)
            search_btn.setOnClickListener(OnClickListener(lambda _v=None: self._admin_tab_open_native_search()))

            lock_btn = ImageView(context)
            is_cmd_locked = bool(self._admin_tab_commands_locked())
            lock_icon_name = "outline_header_locked_24" if is_cmd_locked else "outline_header_lock_24"
            rid_lock = self._resolve_icon_res(context, lock_icon_name, fallback=lock_icon_name)
            if rid_lock > 0:
                lock_btn.setImageResource(rid_lock)
            try:
                lock_btn.setColorFilter(Color.parseColor("#FF4D4F") if is_cmd_locked else Color.parseColor("#39C86A"))
            except Exception:
                pass
            lock_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
            lp_lb = LinearLayout.LayoutParams(AndroidUtilities.dp(34), AndroidUtilities.dp(34))
            lp_lb.leftMargin = AndroidUtilities.dp(4)
            lp_lb.gravity = 48
            top_row.addView(lock_btn, lp_lb)
            lock_btn.setOnClickListener(OnClickListener(lambda _v=None: self._toggle_admin_tab_commands_locked()))

            live_log_btn = ImageView(context)
            rid_log = self._resolve_icon_res(context, "msg_log", fallback="msg_log")
            if rid_log > 0:
                live_log_btn.setImageResource(rid_log)
            try:
                live_log_btn.setColorFilter(Color.parseColor("#E24444") if bool(getattr(self, "_live_log_enabled", False)) else int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
            except Exception:
                pass
            live_log_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
            lp_ll = LinearLayout.LayoutParams(AndroidUtilities.dp(34), AndroidUtilities.dp(34))
            lp_ll.leftMargin = AndroidUtilities.dp(4)
            lp_ll.gravity = 48
            top_row.addView(live_log_btn, lp_ll)
            def _toggle_admin_live_log(_v=None):
                try:
                    enable_now = not bool(getattr(self, "_live_log_enabled", False))
                    self._native_log("admin_tab msg_log clicked enable_now={0}".format(enable_now))
                    self._toggle_live_log(context, True if enable_now else None)
                    live_log_btn.setColorFilter(Color.parseColor("#E24444") if bool(getattr(self, "_live_log_enabled", False)) else int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                except Exception:
                    pass
            live_log_btn.setOnClickListener(OnClickListener(_toggle_admin_live_log))

            settings_btn = ImageView(context)
            rid_set = self._resolve_icon_res(context, "msg_settings_old", fallback="msg_settings_old")
            if rid_set > 0:
                settings_btn.setImageResource(rid_set)
            try:
                settings_btn.setColorFilter(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
            except Exception:
                pass
            settings_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
            lp_sb = LinearLayout.LayoutParams(AndroidUtilities.dp(34), AndroidUtilities.dp(34))
            lp_sb.leftMargin = AndroidUtilities.dp(4)
            lp_sb.gravity = 48
            top_row.addView(settings_btn, lp_sb)
            settings_btn.setOnClickListener(OnClickListener(lambda _v=None: run_on_ui_thread(self._open_plugin_settings)))

            def _mk_btn(label_key):
                btn = TextView(context)
                btn.setText(self._tr(label_key))
                btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                btn.setGravity(17)
                btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
                try:
                    btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                    bg = GradientDrawable()
                    bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                    bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    btn.setBackground(bg)
                except Exception:
                    pass
                return btn

            actions_wrap = LinearLayout(context)
            actions_wrap.setOrientation(LinearLayout.VERTICAL)
            lp_aw = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_aw.topMargin = AndroidUtilities.dp(10)
            root.addView(actions_wrap, lp_aw)

            nav_row = LinearLayout(context)
            nav_row.setOrientation(LinearLayout.HORIZONTAL)
            nav_row.setGravity(16)
            actions_wrap.addView(nav_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            nav_left = LinearLayout(context)
            nav_left.setOrientation(LinearLayout.HORIZONTAL)
            nav_left.setGravity(3 | 16)
            lp_nl = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nav_row.addView(nav_left, lp_nl)

            nav_spacer = LinearLayout(context)
            lp_ns = LinearLayout.LayoutParams(0, 1, 1.0)
            nav_row.addView(nav_spacer, lp_ns)

            nav_right = LinearLayout(context)
            nav_right.setOrientation(LinearLayout.HORIZONTAL)
            nav_right.setGravity(5 | 16)
            lp_nr = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nav_row.addView(nav_right, lp_nr)

            def _mk_nav_btn(key, outlined=True):
                v = TextView(context)
                v.setText(self._tr(key))
                v.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 11)
                v.setGravity(17)
                v.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(5), AndroidUtilities.dp(10), AndroidUtilities.dp(5))
                try:
                    v.setTextColor(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                    if outlined:
                        bg = GradientDrawable()
                        bg.setCornerRadius(float(AndroidUtilities.dp(9)))
                        bg.setColor(0x00000000)
                        bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                        v.setBackground(bg)
                except Exception:
                    pass
                return v

            def _mk_nav_icon(icon_name):
                v = ImageView(context)
                rid = self._resolve_icon_res(context, icon_name, fallback=icon_name)
                if rid > 0:
                    v.setImageResource(rid)
                try:
                    v.setColorFilter(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                except Exception:
                    pass
                v.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
                return v

            custom_btn = _mk_nav_btn("admin_tab_custom")
            custom_btn.setOnClickListener(OnClickListener(lambda _v=None: self._open_admin_custom_sheet(context)))
            prev_btn = _mk_nav_btn("admin_tab_page_prev")
            next_btn = _mk_nav_btn("admin_tab_page_next")
            group_settings_btn = _mk_nav_btn("group_settings")
            group_settings_btn.setOnClickListener(OnClickListener(lambda _v=None: self._open_group_settings_panel(int(self._active_dialog_id() or 0))))
            mentions_hub_btn = _mk_nav_icon("msg_mention")
            mentions_hub_btn.setOnClickListener(OnClickListener(lambda _v=None: BulletinHelper.show_info(self._tr("mentions_hub_hold_open"))))
            mentions_hub_btn.setOnLongClickListener(OnLongClickListener(lambda _v=None: (self._open_mentions_hub_sheet(), True)[1]))

            pages_wrap = LinearLayout(context)
            pages_wrap.setOrientation(LinearLayout.VERTICAL)
            lp_pw = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_pw.topMargin = AndroidUtilities.dp(2)
            actions_wrap.addView(pages_wrap, lp_pw)

            page_state = {"idx": 0}

            def _add_action_row(parent, btn_key, sub_key, on_click, on_long=None):
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(16)
                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(12)
                parent.addView(row, lp_row)

                btn = _mk_btn(btn_key)
                lp_btn = LinearLayout.LayoutParams(AndroidUtilities.dp(130), LinearLayout.LayoutParams.WRAP_CONTENT)
                row.addView(btn, lp_btn)

                subtx = TextView(context)
                subtx.setText(self._tr(sub_key))
                subtx.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    subtx.setTextColor(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                    subtx.setAlpha(0.82)
                except Exception:
                    pass
                lp_st = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                lp_st.leftMargin = AndroidUtilities.dp(10)
                row.addView(subtx, lp_st)

                btn.setOnClickListener(OnClickListener(lambda _v=None: on_click()))
                if on_long is not None:
                    btn.setOnLongClickListener(OnLongClickListener(lambda _v=None: (on_long(), True)[1]))

            def _add_custom_row(parent, item):
                try:
                    row = LinearLayout(context)
                    row.setOrientation(LinearLayout.HORIZONTAL)
                    row.setGravity(16)
                    lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_row.topMargin = AndroidUtilities.dp(12)
                    parent.addView(row, lp_row)

                    btn = _mk_btn("admin_tab_custom")
                    btn.setText(str((item or {}).get("title", self._tr("admin_tab_custom")) or self._tr("admin_tab_custom")))
                    lp_btn = LinearLayout.LayoutParams(AndroidUtilities.dp(130), LinearLayout.LayoutParams.WRAP_CONTENT)
                    row.addView(btn, lp_btn)

                    subtx = TextView(context)
                    desc = str((item or {}).get("description", "") or "").strip()
                    if not desc:
                        desc = str((item or {}).get("command", "") or "").strip()
                    subtx.setText(desc)
                    subtx.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    try:
                        subtx.setTextColor(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                        subtx.setAlpha(0.82)
                    except Exception:
                        pass
                    lp_st = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp_st.leftMargin = AndroidUtilities.dp(10)
                    row.addView(subtx, lp_st)

                    btn.setOnClickListener(OnClickListener(lambda _v=None, it=item: self._admin_tab_send_custom(it)))
                except Exception:
                    pass

            def _total_pages():
                try:
                    cc = len(list(self._admin_custom_actions_snapshot() or []))
                    tp = 3
                    try:
                        self._dlog("admin_tab: total_pages={0} custom_count={1}".format(int(tp), int(cc)))
                    except Exception:
                        pass
                    return tp
                except Exception:
                    return 2

            def _set_page(idx):
                try:
                    t = int(_total_pages())
                    i = int(idx)
                    if i < 0:
                        i = 0
                    if i >= t:
                        i = t - 1
                    page_state["idx"] = i
                except Exception:
                    page_state["idx"] = 0

            def _render_actions_page():
                try:
                    pages_wrap.removeAllViews()
                except Exception:
                    pass
                try:
                    nav_left.removeAllViews()
                    nav_right.removeAllViews()
                except Exception:
                    pass
                nav_left.addView(custom_btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                idx = int(page_state.get("idx", 0) or 0)
                tpages = int(_total_pages())
                if idx == 0:
                    _add_action_row(pages_wrap, "admin_tab_chat", "admin_tab_chat_connect_sub", self._admin_tab_send_connect, None)
                    _add_action_row(pages_wrap, "admin_tab_lock", "admin_tab_lock_sub", lambda: None, lambda: self._admin_tab_open_lock_actions(context))
                elif idx == 1:
                    _add_action_row(pages_wrap, "admin_tab_rules", "admin_tab_rules_sub", self._admin_tab_send_rules, None)
                    _add_action_row(pages_wrap, "admin_tab_notes", "admin_tab_notes_sub", self._admin_tab_send_notes, None)
                else:
                    customs = list(self._admin_custom_actions_snapshot() or [])
                    if not customs:
                        emp = TextView(context)
                        emp.setText(self._tr("admin_custom_empty_hint"))
                        emp.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                        try:
                            emp.setTextColor(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                            emp.setAlpha(0.82)
                        except Exception:
                            pass
                        pages_wrap.addView(emp)
                    else:
                        for it in customs[:20]:
                            if isinstance(it, dict):
                                _add_custom_row(pages_wrap, it)

                if idx > 0:
                    lp_prev = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_prev.leftMargin = AndroidUtilities.dp(6)
                    nav_left.addView(prev_btn, lp_prev)
                if idx < (tpages - 1):
                    lp_nx = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_nx.leftMargin = AndroidUtilities.dp(6)
                    nav_left.addView(next_btn, lp_nx)
                try:
                    did_active = int(self._active_dialog_id() or 0)
                    can_group_settings = bool(self._supports_group_settings_dialog(did_active) and self._has_group_admin_access(did_active))
                    group_settings_btn.setEnabled(can_group_settings)
                    group_settings_btn.setAlpha(1.0 if can_group_settings else 0.55)
                except Exception:
                    pass
                lp_gs = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_gs.rightMargin = AndroidUtilities.dp(8)
                nav_right.addView(group_settings_btn, lp_gs)
                lp_mh = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
                lp_mh.leftMargin = AndroidUtilities.dp(0)
                lp_mh.gravity = 16
                nav_right.addView(mentions_hub_btn, lp_mh)

            prev_btn.setOnClickListener(OnClickListener(lambda _v=None: (_set_page(int(page_state.get("idx", 0) or 0) - 1), _render_actions_page())))
            next_btn.setOnClickListener(OnClickListener(lambda _v=None: (_set_page(int(page_state.get("idx", 0) or 0) + 1), _render_actions_page())))
            _render_actions_page()

            strip = LinearLayout(context)
            strip.setOrientation(LinearLayout.HORIZONTAL)
            strip.setGravity(16)
            lp_strip = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_strip.topMargin = AndroidUtilities.dp(16)
            root.addView(strip, lp_strip)

            peeks = list(self._peek_groups or [])[:5]
            has_peeks = bool(peeks)
            maxed_peeks = len(list(self._peek_groups or [])) >= 5
            if has_peeks:
                add_btn = ImageView(context)
                rid_add = self._resolve_icon_res(context, "emoji_tabs_new3", fallback="emoji_tabs_new3")
                if rid_add > 0:
                    add_btn.setImageResource(rid_add)
                try:
                    add_btn.setColorFilter(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                except Exception:
                    pass
                add_btn.setPadding(AndroidUtilities.dp(7), AndroidUtilities.dp(7), AndroidUtilities.dp(7), AndroidUtilities.dp(7))
                try:
                    abg = GradientDrawable()
                    abg.setCornerRadius(float(AndroidUtilities.dp(10)))
                    abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    add_btn.setBackground(abg)
                except Exception:
                    pass
                lp_add = LinearLayout.LayoutParams(AndroidUtilities.dp(32), AndroidUtilities.dp(32))
                lp_add.rightMargin = AndroidUtilities.dp(10)
                strip.addView(add_btn, lp_add)
                try:
                    add_btn.setAlpha(0.55 if maxed_peeks else 1.0)
                except Exception:
                    pass
                add_btn.setOnClickListener(OnClickListener(lambda _v=None: self._admin_tab_open_add_peek(context)))
                add_btn.setOnLongClickListener(OnLongClickListener(lambda _v=None: (self._admin_tab_add_current_chat_peek(), True)[1]))
            else:
                peek_row = LinearLayout(context)
                peek_row.setOrientation(LinearLayout.HORIZONTAL)
                peek_row.setGravity(16)
                lp_pr = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_pr.topMargin = AndroidUtilities.dp(2)
                root.addView(peek_row, lp_pr)

                add_wrap = LinearLayout(context)
                add_wrap.setOrientation(LinearLayout.VERTICAL)
                add_wrap.setGravity(17)
                lp_aw2 = LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(42))
                peek_row.addView(add_wrap, lp_aw2)

                add_btn = ImageView(context)
                rid_add = self._resolve_icon_res(context, "emoji_tabs_new3", fallback="emoji_tabs_new3")
                if rid_add > 0:
                    add_btn.setImageResource(rid_add)
                try:
                    add_btn.setColorFilter(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                except Exception:
                    pass
                add_btn.setPadding(AndroidUtilities.dp(7), AndroidUtilities.dp(7), AndroidUtilities.dp(7), AndroidUtilities.dp(7))
                try:
                    abg = GradientDrawable()
                    abg.setCornerRadius(float(AndroidUtilities.dp(10)))
                    abg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    add_btn.setBackground(abg)
                except Exception:
                    pass
                add_wrap.addView(add_btn, LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36)))

                peek_texts = LinearLayout(context)
                peek_texts.setOrientation(LinearLayout.VERTICAL)
                lp_pts = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                lp_pts.leftMargin = AndroidUtilities.dp(10)
                peek_row.addView(peek_texts, lp_pts)

                peek_title = TextView(context)
                peek_title.setText(self._tr("peek_title"))
                peek_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
                try:
                    peek_title.setTextColor(c_hello)
                except Exception:
                    pass
                peek_texts.addView(peek_title, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

                peek_sub = TextView(context)
                peek_sub.setText(self._tr("peek_sub"))
                peek_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                try:
                    peek_sub.setTextColor(int(Theme.getColor(Theme.key_chat_emojiPanelIcon)))
                    peek_sub.setAlpha(0.82)
                except Exception:
                    pass
                lp_ps = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_ps.topMargin = AndroidUtilities.dp(2)
                peek_texts.addView(peek_sub, lp_ps)
                add_btn.setOnClickListener(OnClickListener(lambda _v=None: self._admin_tab_open_add_peek(context)))
                add_btn.setOnLongClickListener(OnLongClickListener(lambda _v=None: (self._admin_tab_add_current_chat_peek(), True)[1]))
                try:
                    add_btn.setAlpha(0.55 if maxed_peeks else 1.0)
                except Exception:
                    pass

            if peeks:
                try:
                    from org.telegram.ui.Components import BackupImageView, AvatarDrawable
                except Exception:
                    BackupImageView = None
                    AvatarDrawable = None
                for it in peeks:
                    try:
                        did = int((it or {}).get("id", 0) or 0)
                        chat = self._chat_by_dialog_id(did)
                        holder = LinearLayout(context)
                        holder.setOrientation(LinearLayout.VERTICAL)
                        holder.setGravity(17)
                        lp_h = LinearLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48))
                        lp_h.rightMargin = AndroidUtilities.dp(8)
                        strip.addView(holder, lp_h)

                        if BackupImageView is not None and AvatarDrawable is not None:
                            icon = BackupImageView(context)
                            try:
                                icon.setRoundRadius(AndroidUtilities.dp(21))
                            except Exception:
                                pass
                            try:
                                if chat is not None:
                                    icon.setForUserOrChat(chat, AvatarDrawable(chat))
                                else:
                                    icon.setImageDrawable(AvatarDrawable())
                            except Exception:
                                pass
                        else:
                            icon = ImageView(context)
                            rid_grp = self._resolve_icon_res(context, "msg_groups_solar", fallback="msg_groups_solar")
                            if rid_grp > 0:
                                icon.setImageResource(rid_grp)
                        holder.addView(icon, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(42)))

                        holder.setOnClickListener(OnClickListener(lambda _v=None, item=it: self._admin_tab_open_peek(item)))
                        holder.setOnLongClickListener(OnLongClickListener(lambda _v=None, item=it: (self._admin_tab_remove_peek(item), True)[1]))
                    except Exception:
                        pass
            return root
        except Exception:
            return None

    def _find_admin_tab(self, all_tabs):
        try:
            if all_tabs is None:
                return None
            for i in range(int(all_tabs.size() or 0)):
                t = all_tabs.get(i)
                try:
                    vv = get_private_field(t, "view")
                    tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else None
                    if str(tg or "") == str(VANGUARD_ADMIN_TAB_VIEW_TAG):
                        return t
                except Exception:
                    pass
        except Exception:
            pass
        return None

    def _resolve_emoji_view_obj(self, any_obj):
        try:
            if any_obj is None:
                return getattr(self, "_admin_tab_last_emoji_view", None)
            cn = str(any_obj.getClass().getName() or "")
            if "EmojiView" in cn:
                self._admin_tab_last_emoji_view = any_obj
                return any_obj
            try:
                outer = get_private_field(any_obj, "this$0")
                if outer is not None:
                    ocn = str(outer.getClass().getName() or "")
                    if "EmojiView" in ocn:
                        self._admin_tab_last_emoji_view = outer
                        return outer
            except Exception:
                pass
            try:
                cls = any_obj.getClass()
                while cls is not None:
                    try:
                        fields = cls.getDeclaredFields()
                    except Exception:
                        fields = []
                    for f in fields:
                        try:
                            f.setAccessible(True)
                            val = f.get(any_obj)
                            if val is None:
                                continue
                            vcn = str(val.getClass().getName() or "")
                            if "EmojiView" in vcn:
                                self._admin_tab_last_emoji_view = val
                                return val
                        except Exception:
                            pass
                    try:
                        cls = cls.getSuperclass()
                    except Exception:
                        cls = None
            except Exception:
                pass
            return getattr(self, "_admin_tab_last_emoji_view", None)
        except Exception:
            return getattr(self, "_admin_tab_last_emoji_view", None)

    def _admin_tab_position_for_emoji_view(self, emoji_view):
        try:
            if emoji_view is None:
                return -1
            current_tabs = get_private_field(emoji_view, "currentTabs")
            if current_tabs is None:
                current_tabs = get_private_field(emoji_view, "allTabs")
            if current_tabs is None:
                return -1
            for i in range(int(current_tabs.size() or 0)):
                try:
                    t = current_tabs.get(i)
                    vv = get_private_field(t, "view")
                    tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else None
                    if str(tg or "") == str(VANGUARD_ADMIN_TAB_VIEW_TAG):
                        return int(i)
                except Exception:
                    pass
            return -1
        except Exception:
            return -1

    def _admin_tab_at_position(self, emoji_view, position):
        try:
            if emoji_view is None:
                return False
            pos = int(position)
            ok = (str(self._admin_tab_tag_at_position(emoji_view, pos) or "") == str(VANGUARD_ADMIN_TAB_VIEW_TAG))
            try:
                self._dlog("admin_tab: at_pos check pos={0} tag={1} ok={2}".format(int(pos), str(self._admin_tab_tag_at_position(emoji_view, pos) or ""), bool(ok)))
            except Exception:
                pass
            return ok
        except Exception:
            return False

    def _admin_tab_tag_at_position(self, emoji_view, position):
        try:
            if emoji_view is None:
                return ""
            pos = int(position)
            for src_name in ("currentTabs", "allTabs"):
                tabs = get_private_field(emoji_view, src_name)
                if tabs is None:
                    continue
                if pos < 0 or pos >= int(tabs.size() or 0):
                    continue
                try:
                    t = tabs.get(pos)
                    vv = get_private_field(t, "view")
                    tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else ""
                    if str(tg or ""):
                        return str(tg or "")
                except Exception:
                    pass
            return ""
        except Exception:
            return ""

    def _admin_custom_actions_snapshot(self):
        try:
            arr = list(self._admin_custom_actions or [])
            if arr:
                return arr
            raw = self.get_setting("tagged_admin_custom_actions_v1", "[]")
            parsed = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            out = []
            for it in (parsed or []):
                if not isinstance(it, dict):
                    continue
                title = str(it.get("title", "") or "").strip()
                cmd = str(it.get("command", "") or "").strip()
                if not title or not cmd:
                    continue
                out.append({
                    "id": str(it.get("id", "") or "").strip() or "ac_{0}".format(int(time.time() * 1000)),
                    "title": title,
                    "description": str(it.get("description", "") or "").strip(),
                    "command": cmd,
                })
            self._admin_custom_actions = out[:20]
            return list(self._admin_custom_actions or [])
        except Exception:
            return list(self._admin_custom_actions or [])

    def _is_nowfy_plugin_loaded(self):
        try:
            controller = PluginsController.getInstance()
            if controller is None:
                return False
            try:
                p = controller.plugins.get("nowfy")
                return p is not None
            except Exception:
                pass
            try:
                p2 = controller.plugins.get("Nowfy")
                return p2 is not None
            except Exception:
                pass
            return False
        except Exception:
            return False

    def _nowfy_tab_present(self, emoji_view):
        try:
            if emoji_view is None:
                return False
            tabs = get_private_field(emoji_view, "currentTabs")
            if tabs is None:
                tabs = get_private_field(emoji_view, "allTabs")
            if tabs is None:
                return False
            for i in range(int(tabs.size() or 0)):
                try:
                    t = tabs.get(i)
                    vv = get_private_field(t, "view")
                    tg = str(vv.getTag() if vv is not None and hasattr(vv, "getTag") else "" or "")
                    tp = int(get_private_field(t, "type") or -1)
                    if tg == "NOWFY_CUSTOM_TAB_VIEW_TAG" or tp == 3:
                        return True
                except Exception:
                    pass
            return False
        except Exception:
            return False

    def _has_admin_tab_view(self, all_tabs):
        try:
            if all_tabs is None:
                return False
            for i in range(int(all_tabs.size() or 0)):
                t = all_tabs.get(i)
                try:
                    vv = get_private_field(t, "view")
                    tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else None
                    if str(tg or "") == str(VANGUARD_ADMIN_TAB_VIEW_TAG):
                        return True
                except Exception:
                    pass
        except Exception:
            pass
        return False

    def _ensure_admin_tab_on_emoji_view(self, emoji_view, context=None):
        scheduled_async = False
        try:
            if not self._is_admin_mode():
                self._dlog("admin_tab: skipped ensure (not admin mode)")
                return
            if emoji_view is None:
                self._dlog("admin_tab: skipped ensure (emoji_view none)")
                return
            self._admin_tab_last_emoji_view = emoji_view
            all_tabs = get_private_field(emoji_view, "allTabs")
            current_tabs = get_private_field(emoji_view, "currentTabs")
            if all_tabs is None or current_tabs is None:
                self._dlog("admin_tab: skipped ensure (tabs lists unavailable)")
                return
            k = str(emoji_view)
            if bool((self._admin_tab_ensure_inflight or {}).get(k, False)):
                self._dlog("admin_tab: skipped ensure (inflight)")
                return
            self._admin_tab_ensure_inflight[k] = True
            if self._is_admin_tab_pager_busy(emoji_view):
                self._dlog("admin_tab: defer ensure (pager busy)")
                self._schedule_admin_tab_rebuild(140)
                return
            compat_mode = bool(self._admin_tab_nowfy_compat_enabled())
            try:
                nowfy_loaded = bool(self._is_nowfy_plugin_loaded()) if compat_mode else False
            except Exception:
                nowfy_loaded = False
            if nowfy_loaded and compat_mode:
                has_nowfy_tab = bool(self._nowfy_tab_present(emoji_view))
                try:
                    self._dlog("admin_tab: nowfy loaded={0} nowfy_tab_present={1}".format(bool(nowfy_loaded), bool(has_nowfy_tab)))
                except Exception:
                    pass
                if not has_nowfy_tab:
                    try:
                        now_ts = float(time.time())
                        if float(self._admin_tab_wait_nowfy_until or 0.0) <= 0.0:
                            self._admin_tab_wait_nowfy_until = now_ts + 1.4
                        if now_ts < float(self._admin_tab_wait_nowfy_until or 0.0):
                            self._dlog("admin_tab: defer inject waiting nowfy tab")
                            self._schedule_admin_tab_rebuild(180)
                            return
                    except Exception:
                        pass
            else:
                self._admin_tab_wait_nowfy_until = 0.0
                if not compat_mode:
                    try:
                        self._dlog("admin_tab: compat off -> fixed injection mode")
                    except Exception:
                        pass
            try:
                dbg = []
                for i in range(int(current_tabs.size() or 0)):
                    try:
                        tt = current_tabs.get(i)
                        vv = get_private_field(tt, "view")
                        tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else ""
                        dbg.append("#{0}:{1}".format(int(i), str(tg or "-")))
                    except Exception:
                        pass
                self._dlog("admin_tab: current_tabs before ensure -> " + ", ".join(dbg))
            except Exception:
                pass
            py_all_tabs = list(ArrayList(all_tabs).toArray()) if all_tabs else []
            if len(py_all_tabs) <= 1:
                self._dlog("admin_tab: skipped ensure (tabs count too low={0})".format(len(py_all_tabs)))
                return
            if self._has_admin_tab_view(all_tabs):
                self._dlog("admin_tab: already present by view")
                return
            if self._find_admin_tab(all_tabs) is not None:
                self._dlog("admin_tab: already present")
                return
            ctx = context
            if ctx is None:
                try:
                    ctx = emoji_view.getContext()
                except Exception:
                    ctx = None
            view = self._create_admin_tab_view(ctx)
            if view is None:
                self._dlog("admin_tab: failed create view")
                return
            tab_class = self._get_java_class("org.telegram.ui.Components.EmojiView$Tab")
            if tab_class is None:
                self._dlog("admin_tab: tab class unavailable")
                return
            try:
                tab_ctor = tab_class.getDeclaredConstructors()[0]
                tab_ctor.setAccessible(True)
                new_tab = tab_ctor.newInstance(emoji_view)
            except Exception as e_ctor:
                try:
                    ev_cls = str(emoji_view.getClass().getName() or "?")
                except Exception:
                    ev_cls = "?"
                self._dlog("admin_tab: failed to instantiate EmojiView$Tab: {0}; emoji_view={1}".format(e_ctor, ev_cls))
                return
            try:
                self._admin_tab_position = int(current_tabs.size() or int(VANGUARD_ADMIN_TAB_INDEX))
            except Exception:
                self._admin_tab_position = int(VANGUARD_ADMIN_TAB_INDEX)
            def _mutate():
                try:
                    all_tabs2 = get_private_field(emoji_view, "allTabs")
                    current_tabs2 = get_private_field(emoji_view, "currentTabs")
                    if all_tabs2 is None or current_tabs2 is None:
                        return
                    if self._has_admin_tab_view(all_tabs2):
                        self._dlog("admin_tab: posted ensure skipped by view")
                        return
                    if self._find_admin_tab(all_tabs2) is not None:
                        self._dlog("admin_tab: posted ensure skipped already present")
                        return
                    set_private_field(new_tab, "view", view)
                    all_tabs2.add(new_tab)
                    current_tabs2.add(new_tab)
                    self._admin_tab_wait_nowfy_until = 0.0
                    self._dlog("admin_tab: injected type={0} pos={1} tabs={2}".format(int(VANGUARD_ADMIN_TAB_TYPE), int(self._admin_tab_position), int(current_tabs2.size() or 0)))
                    try:
                        dbg2 = []
                        for i in range(int(current_tabs2.size() or 0)):
                            try:
                                tt = current_tabs2.get(i)
                                vv = get_private_field(tt, "view")
                                tg = vv.getTag() if vv is not None and hasattr(vv, "getTag") else ""
                                dbg2.append("#{0}:{1}".format(int(i), str(tg or "-")))
                            except Exception:
                                pass
                        self._dlog("admin_tab: current_tabs after ensure -> " + ", ".join(dbg2))
                    except Exception:
                        pass
                    try:
                        self._admin_tab_views[str(emoji_view)] = view
                    except Exception:
                        pass
                    try:
                        self._attach_admin_tab_pager_listener(emoji_view, view)
                    except Exception:
                        pass
                    self._force_emoji_view_update(emoji_view)
                finally:
                    try:
                        self._admin_tab_ensure_inflight.pop(str(emoji_view), None)
                    except Exception:
                        pass
            scheduled_async = bool(self._run_admin_tab_ui_mutation(_mutate, 16))
            if not scheduled_async:
                _mutate()
        except Exception as e:
            try:
                self._dlog("admin_tab: ensure error: {0}".format(e))
            except Exception:
                pass
        finally:
            try:
                if not bool(scheduled_async):
                    self._admin_tab_ensure_inflight.pop(str(emoji_view), None)
            except Exception:
                pass

    def _rebuild_admin_tab_current_emoji(self):
        try:
            frag = get_last_fragment()
            if frag is None:
                self._dlog("admin_tab: rebuild skipped (fragment none)")
                return
            enter_view = get_private_field(frag, "chatActivityEnterView")
            if enter_view is None:
                enter_view = _pf(frag, "chatActivityEnterView", None)
            emoji_view = None
            if enter_view is not None:
                emoji_view = get_private_field(enter_view, "emojiView")
                if emoji_view is None:
                    emoji_view = _pf(enter_view, "emojiView", None)
            if emoji_view is not None:
                self._admin_tab_last_emoji_view = emoji_view
                if self._is_admin_tab_pager_busy(emoji_view):
                    self._dlog("admin_tab: rebuild deferred (pager busy)")
                    self._schedule_admin_tab_rebuild(120)
                    return
                self._dlog("admin_tab: rebuild on current emoji")
                self._ensure_admin_tab_on_emoji_view(emoji_view, None)
            else:
                self._dlog("admin_tab: rebuild skipped (emoji view none)")
        except Exception:
            pass

    def _attach_admin_tab_pager_listener(self, emoji_view, my_view):
        try:
            pager = get_private_field(emoji_view, "pager")
            if pager is None or my_view is None:
                return
            listener_cls = find_class("androidx.viewpager.widget.ViewPager$OnPageChangeListener")
            if listener_cls is None:
                listener_cls = find_class("android.support.v4.view.ViewPager$OnPageChangeListener")
            if listener_cls is None:
                return

            class _OnPageChange(dynamic_proxy(listener_cls)):
                def onPageScrolled(self_obj, a, b, c):
                    pass
                def onPageSelected(self_obj, pos):
                    try:
                        V = find_class("android.view.View")
                        vis = int(getattr(V, "VISIBLE", 0))
                        invis = int(getattr(V, "INVISIBLE", 4))
                        tg = str(self._admin_tab_tag_at_position(emoji_view, int(pos)) or "")
                        is_ours = (tg == str(VANGUARD_ADMIN_TAB_VIEW_TAG))
                        try:
                            self._dlog("admin_tab: onPageSelected pos={0} tag={1} ours={2}".format(int(pos), tg, bool(is_ours)))
                        except Exception:
                            pass
                        my_view.setVisibility(vis if is_ours else invis)
                    except Exception:
                        pass
                def onPageScrollStateChanged(self_obj, state):
                    pass

            listener = _OnPageChange()
            try:
                pager.addOnPageChangeListener(listener)
            except Exception:
                return
            try:
                current_item = int(pager.getCurrentItem())
            except Exception:
                current_item = -1
            try:
                V = find_class("android.view.View")
                vis = int(getattr(V, "VISIBLE", 0))
                invis = int(getattr(V, "INVISIBLE", 4))
                my_view.setVisibility(vis if self._admin_tab_at_position(emoji_view, int(current_item)) else invis)
            except Exception:
                pass
        except Exception:
            pass

    def _on_admin_tab_ctor(self, param):
        try:
            emoji_view = param.thisObject
            try:
                self._admin_tab_last_emoji_view = emoji_view
            except Exception:
                pass
            self._schedule_admin_tab_rebuild(180)
        except Exception:
            pass

    def _on_admin_tab_set_allow(self, param):
        try:
            emoji_view = param.thisObject
            if self._is_admin_tab_pager_busy(emoji_view):
                self._dlog("admin_tab: setAllow defer (pager busy)")
                self._schedule_admin_tab_rebuild(120)
                return
            all_tabs = get_private_field(emoji_view, "allTabs")
            current_tabs = get_private_field(emoji_view, "currentTabs")
            if all_tabs is None or current_tabs is None:
                return
            my_tab = self._find_admin_tab(all_tabs)
            enabled = bool(self._is_admin_mode())
            if not enabled:
                if my_tab is not None and current_tabs.contains(my_tab):
                    def _remove_tab():
                        try:
                            all_tabs2 = get_private_field(emoji_view, "allTabs")
                            current_tabs2 = get_private_field(emoji_view, "currentTabs")
                            if all_tabs2 is None or current_tabs2 is None:
                                return
                            my_tab2 = self._find_admin_tab(all_tabs2)
                            if my_tab2 is not None and current_tabs2.contains(my_tab2):
                                current_tabs2.remove(my_tab2)
                                self._force_emoji_view_update(emoji_view)
                        except Exception:
                            pass
                    self._run_admin_tab_ui_mutation(_remove_tab, 16)
                return
            if my_tab is None:
                self._schedule_admin_tab_rebuild(90)
                all_tabs = get_private_field(emoji_view, "allTabs")
                current_tabs = get_private_field(emoji_view, "currentTabs")
                my_tab = self._find_admin_tab(all_tabs)
                if my_tab is None:
                    return
            if not current_tabs.contains(my_tab):
                def _add_tab():
                    try:
                        all_tabs2 = get_private_field(emoji_view, "allTabs")
                        current_tabs2 = get_private_field(emoji_view, "currentTabs")
                        if all_tabs2 is None or current_tabs2 is None:
                            return
                        my_tab2 = self._find_admin_tab(all_tabs2)
                        if my_tab2 is not None and not current_tabs2.contains(my_tab2):
                            current_tabs2.add(my_tab2)
                            self._force_emoji_view_update(emoji_view)
                    except Exception:
                        pass
                self._run_admin_tab_ui_mutation(_add_tab, 16)
        except Exception:
            pass

    def _on_admin_tab_get_icon(self, param):
        try:
            position = int(param.args[0] if param.args else -1)
            emoji_view = self._resolve_emoji_view_obj(param.thisObject)
            is_ours = self._admin_tab_at_position(emoji_view, position)
            try:
                self._dlog("admin_tab: get_icon pos={0} ours={1}".format(int(position), bool(is_ours)))
            except Exception:
                pass
            if is_ours:
                param.setResult(None)
        except Exception:
            pass

    def _on_admin_tab_get_title(self, param):
        try:
            position = int(param.args[0] if param.args else -1)
            emoji_view = self._resolve_emoji_view_obj(param.thisObject)
            is_ours = self._admin_tab_at_position(emoji_view, position)
            try:
                self._dlog("admin_tab: get_title pos={0} ours={1}".format(int(position), bool(is_ours)))
            except Exception:
                pass
            if (not is_ours) and emoji_view is None:
                try:
                    if int(position) == int(getattr(self, "_admin_tab_position", -999)):
                        is_ours = True
                        self._dlog("admin_tab: get_title fallback by stored position")
                except Exception:
                    pass
            if (not is_ours):
                try:
                    if int(position) == int(getattr(self, "_admin_tab_position", -999)):
                        is_ours = True
                        self._dlog("admin_tab: get_title fallback by stored position (generic)")
                except Exception:
                    pass
            if is_ours:
                param.setResult("Admin")
            else:
                try:
                    self._dlog("admin_tab: get_title unresolved pos={0} stored={1} tag={2}".format(int(position), int(getattr(self, "_admin_tab_position", -999)), str(self._admin_tab_tag_at_position(emoji_view, position) or "")))
                except Exception:
                    pass
        except Exception:
            pass

    def _on_admin_tab_check_grid(self, param):
        try:
            emoji_view = param.thisObject
            position = int(param.args[0] if param.args else -1)
            pager = get_private_field(emoji_view, "pager")
            my_view = emoji_view.findViewWithTag(VANGUARD_ADMIN_TAB_VIEW_TAG)
            stickers = get_private_field(emoji_view, "stickersTabContainer")
            search = get_private_field(emoji_view, "emojiSearchField")
            enabled = bool(self._is_admin_mode())
            V = find_class("android.view.View")
            vis = int(getattr(V, "VISIBLE", 0))
            gone = int(getattr(V, "GONE", 8))
            invis = int(getattr(V, "INVISIBLE", 4))
            is_our_tab_pos = bool(self._admin_tab_at_position(emoji_view, position))
            if is_our_tab_pos and enabled:
                if my_view is not None:
                    try:
                        if int(my_view.getVisibility()) != vis:
                            my_view.setVisibility(vis)
                    except Exception:
                        pass
                if stickers is not None:
                    try:
                        stickers.setVisibility(gone)
                    except Exception:
                        pass
                if search is not None:
                    try:
                        search.setVisibility(gone)
                    except Exception:
                        pass
            else:
                if my_view is not None:
                    try:
                        current_item = int(pager.getCurrentItem()) if pager is not None else -1
                    except Exception:
                        current_item = -1
                    cur_tag = str(self._admin_tab_tag_at_position(emoji_view, current_item) or "")
                    target = vis if cur_tag == str(VANGUARD_ADMIN_TAB_VIEW_TAG) else invis
                    try:
                        self._dlog("admin_tab: checkGrid pos={0} cur={1} cur_tag={2} ours_pos={3}".format(int(position), int(current_item), cur_tag, bool(is_our_tab_pos)))
                    except Exception:
                        pass
                    try:
                        if int(my_view.getVisibility()) != int(target):
                            my_view.setVisibility(int(target))
                    except Exception:
                        pass
        except Exception:
            pass

    def _forge_beacon_nonce(self):
        seed = "geeketg"
        raw = "{0}:{1}:{2}".format(seed, int(time.time_ns()), int(random.getrandbits(48)))
        return hashlib.sha1(raw.encode("utf-8")).hexdigest()[:8]

    def _compose_vanguard_beacon_text(self, uid, view_mode="main"):
        rec = self._tag_get(uid)
        nm = self._user_name(uid)
        wc = self._warn_count(uid)
        head = "{0}\n{1}\n\n".format(
            self._tr("quick_panel_title_md"),
            self._tr("quick_actions_sub_md") if str(view_mode or "main") == "shortcuts" else self._tr("quick_panel_sub_md"),
        )
        base = "{0}: {1}\n{2}: {3}\n{4}: {5}".format(
            self._tr("name"),
            nm,
            self._tr("id"),
            int(uid),
            self._tr("warnings"),
            int(wc),
        )
        if str(view_mode or "main") == "shortcuts":
            return "{0}{1}: {2}\n{3}: {4}".format(
                head,
                self._tr("name"),
                nm,
                self._tr("id"),
                int(uid),
            )
        if not rec:
            return head + base
        emoji = str(rec.get("name", "") or "").strip() or "-"
        note = str(rec.get("tag", "") or "").strip() or "-"
        return head + "{0}\n{1}: {2}\n{3}: {4}".format(
            base,
            self._tr("emoji_tag"),
            emoji,
            self._tr("note"),
            note,
        )

    def _vanguard_beacon_payload(self, nonce, action):
        try:
            return bytes(("{0}:{1}:{2}".format(VANGUARD_BEACON_GATE, str(nonce or ""), str(action or ""))).encode("utf-8"))
        except Exception:
            return bytes()

    def _decode_vanguard_beacon_payload(self, payload):
        try:
            raw = str(payload or "")
            prefix = "{0}:".format(VANGUARD_BEACON_GATE)
            if not raw.startswith(prefix):
                return ("", "")
            body = raw[len(prefix):]
            nonce, _, action = body.partition(":")
            return (str(nonce or "").strip(), str(action or "").strip().lower())
        except Exception:
            return ("", "")

    def _compose_vanguard_beacon_markup(self, uid, nonce, view_mode="main"):
        try:
            from org.telegram.tgnet import TLRPC
            mk = TLRPC.TL_replyInlineMarkup()
            if str(view_mode or "main") == "shortcuts":
                items = list(self._shortcuts or [])
                if items:
                    i = 0
                    while i < len(items):
                        row = TLRPC.TL_keyboardButtonRow()
                        left = items[i]
                        b1 = TLRPC.TL_keyboardButtonCallback()
                        b1.text = str(left.get("title", "") or "...")
                        b1.data = self._vanguard_beacon_payload(nonce, "sc_{0}".format(str(left.get("id", "") or "")))
                        b1.requires_password = False
                        row.buttons.add(b1)
                        if (i + 1) < len(items):
                            right = items[i + 1]
                            b2 = TLRPC.TL_keyboardButtonCallback()
                            b2.text = str(right.get("title", "") or "...")
                            b2.data = self._vanguard_beacon_payload(nonce, "sc_{0}".format(str(right.get("id", "") or "")))
                            b2.requires_password = False
                            row.buttons.add(b2)
                        mk.rows.add(row)
                        i += 2
                nav = TLRPC.TL_keyboardButtonRow()
                b_back = TLRPC.TL_keyboardButtonCallback()
                b_back.text = self._tr("back")
                b_back.data = self._vanguard_beacon_payload(nonce, "back")
                b_back.requires_password = False
                nav.buttons.add(b_back)
                b_close = TLRPC.TL_keyboardButtonCallback()
                b_close.text = self._tr("close")
                b_close.data = self._vanguard_beacon_payload(nonce, "close")
                b_close.requires_password = False
                nav.buttons.add(b_close)
                mk.rows.add(nav)
                return mk
            rec = self._tag_get(uid)
            action_ctx = self._vanguard_beacon_sessions.get(str(nonce)) if isinstance(self._vanguard_beacon_sessions.get(str(nonce)), dict) else {}
            can_group_settings = self._supports_group_settings_dialog(int((action_ctx or {}).get("dialog_id", 0) or 0))
            if rec:
                r1 = TLRPC.TL_keyboardButtonRow()
                for txt, act in ((self._tr("open_panel"), "edit"),):
                    b = TLRPC.TL_keyboardButtonCallback()
                    b.text = txt
                    b.data = self._vanguard_beacon_payload(nonce, act)
                    b.requires_password = False
                    r1.buttons.add(b)
                mk.rows.add(r1)
                if can_group_settings:
                    rgs = TLRPC.TL_keyboardButtonRow()
                    bgs = TLRPC.TL_keyboardButtonCallback()
                    bgs.text = self._tr("group_settings")
                    bgs.data = self._vanguard_beacon_payload(nonce, "group_settings")
                    bgs.requires_password = False
                    rgs.buttons.add(bgs)
                    mk.rows.add(rgs)
                r2 = TLRPC.TL_keyboardButtonRow()
                b_del = TLRPC.TL_keyboardButtonCallback()
                b_del.text = self._tr("remove_tag")
                b_del.data = self._vanguard_beacon_payload(nonce, "del")
                b_del.requires_password = False
                r2.buttons.add(b_del)
                b_spam = TLRPC.TL_keyboardButtonCallback()
                b_spam.text = self._tr("spam")
                b_spam.data = self._vanguard_beacon_payload(nonce, "spam")
                b_spam.requires_password = False
                r2.buttons.add(b_spam)
                mk.rows.add(r2)
                r3 = TLRPC.TL_keyboardButtonRow()
                b_close = TLRPC.TL_keyboardButtonCallback()
                b_close.text = self._tr("close")
                b_close.data = self._vanguard_beacon_payload(nonce, "close")
                b_close.requires_password = False
                r3.buttons.add(b_close)
                if self._shortcuts_enabled() and len(list(self._shortcuts or [])) > 0:
                    mk.rows.add(r3)
                    r4 = TLRPC.TL_keyboardButtonRow()
                    b_q = TLRPC.TL_keyboardButtonCallback()
                    b_q.text = self._tr("quick_actions_button", "Quick Actions")
                    b_q.data = self._vanguard_beacon_payload(nonce, "shortcuts")
                    b_q.requires_password = False
                    r4.buttons.add(b_q)
                    mk.rows.add(r4)
                else:
                    mk.rows.add(r3)
            else:
                r1 = TLRPC.TL_keyboardButtonRow()
                for txt, act in ((self._tr("open_panel"), "add"),):
                    b = TLRPC.TL_keyboardButtonCallback()
                    b.text = txt
                    b.data = self._vanguard_beacon_payload(nonce, act)
                    b.requires_password = False
                    r1.buttons.add(b)
                mk.rows.add(r1)
                if can_group_settings:
                    rgs = TLRPC.TL_keyboardButtonRow()
                    bgs = TLRPC.TL_keyboardButtonCallback()
                    bgs.text = self._tr("group_settings")
                    bgs.data = self._vanguard_beacon_payload(nonce, "group_settings")
                    bgs.requires_password = False
                    rgs.buttons.add(bgs)
                    mk.rows.add(rgs)
                r2 = TLRPC.TL_keyboardButtonRow()
                b_spam = TLRPC.TL_keyboardButtonCallback()
                b_spam.text = self._tr("spam")
                b_spam.data = self._vanguard_beacon_payload(nonce, "spam")
                b_spam.requires_password = False
                r2.buttons.add(b_spam)
                b_close = TLRPC.TL_keyboardButtonCallback()
                b_close.text = self._tr("close")
                b_close.data = self._vanguard_beacon_payload(nonce, "close")
                b_close.requires_password = False
                r2.buttons.add(b_close)
                mk.rows.add(r2)
                if self._shortcuts_enabled() and len(list(self._shortcuts or [])) > 0:
                    r4 = TLRPC.TL_keyboardButtonRow()
                    b_q = TLRPC.TL_keyboardButtonCallback()
                    b_q.text = self._tr("quick_actions_button", "Quick Actions")
                    b_q.data = self._vanguard_beacon_payload(nonce, "shortcuts")
                    b_q.requires_password = False
                    r4.buttons.add(b_q)
                    mk.rows.add(r4)
            return mk
        except Exception:
            return None

    def _emit_vanguard_beacon_panel(self, did, uid, nonce=None, source_reply=None):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="beacon_open", count=1, force_flush=False)
            except Exception:
                pass
            t = str(nonce or self._forge_beacon_nonce())
            old = self._vanguard_beacon_sessions.get(t) if isinstance(self._vanguard_beacon_sessions.get(t), dict) else {}
            src_reply = source_reply if source_reply is not None else old.get("source_reply")
            view_mode = str(old.get("beacon_state", "main") or "main")
            self._vanguard_beacon_sessions[t] = {
                "dialog_id": int(did),
                "uid": int(uid),
                "source_reply": src_reply,
                "beacon_state": view_mode,
                "beacon_echo": old.get("beacon_echo", None),
            }
            txt = self._compose_vanguard_beacon_text(uid, view_mode=view_mode)
            mk = self._compose_vanguard_beacon_markup(uid, t, view_mode=view_mode)
            if mk is None:
                return False
            run_on_ui_thread(lambda: self._mount_vanguard_beacon_panel(int(did), txt, mk, nonce=t))
            return True
        except Exception:
            return False

    def _open_from_long(self, uid):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="beacon_open_long_press", count=1, force_flush=False)
            except Exception:
                pass
            f = get_last_fragment()
            did = int(f.getDialogId()) if f and hasattr(f, "getDialogId") else 0
            if not did:
                return False
            if self._is_admin_mode() and self._quick_panel_enabled():
                return bool(self._emit_vanguard_beacon_panel(did, int(uid)))
            nonce = self._forge_beacon_nonce()
            self._vanguard_beacon_sessions[nonce] = {"dialog_id": int(did), "uid": int(uid), "source_reply": None, "beacon_state": "main"}
            run_on_ui_thread(lambda: self._open_vanguard_beacon_editor(int(uid), nonce, None, create=(self._tag_get(uid) is None)))
            return True
        except Exception:
            return False

    def _mount_vanguard_beacon_panel(self, dialog_id, text, markup, nonce=None):
        try:
            chat = self._chat(dialog_id)
            if chat is None:
                return
            try:
                t = str(nonce or "")
                if t:
                    c = self._vanguard_beacon_sessions.get(t)
                    prev = c.get("beacon_echo", None) if isinstance(c, dict) else None
                    if prev is not None:
                        self._remove_local_message_obj(chat, prev)
            except Exception:
                pass
            topic_id = 0
            try:
                if hasattr(chat, "getTopicId"):
                    topic_id = int(chat.getTopicId() or 0)
            except Exception:
                pass
            mo = self._build_local(dialog_id, topic_id, text, markup)
            if mo is None:
                return
            m = chat.getClass().getDeclaredMethod("processNewMessages", ArrayList)
            m.setAccessible(True)
            arr = ArrayList()
            arr.add(mo)
            m.invoke(chat, arr)
            try:
                t = str(nonce or "")
                if t and isinstance(self._vanguard_beacon_sessions.get(t), dict):
                    self._vanguard_beacon_sessions[t]["beacon_echo"] = mo
            except Exception:
                pass
        except Exception:
            pass

    def _build_local(self, dialog_id, topic_id, text, markup):
        try:
            from org.telegram.tgnet import TLRPC
            uc = get_user_config()
            account = int(getattr(uc, "selectedAccount", 0)) if uc is not None else 0
            my_id = int(uc.getClientUserId()) if uc is not None else 0
            msg = TLRPC.TL_message()
            msg.id = -random.randint(1, 2000000000)
            msg.date = int(time.time())
            raw_text = str(text or "")
            msg.message = raw_text
            self._apply_markdown_to_tl_message(msg, raw_text)
            peer = get_messages_controller().getPeer(int(dialog_id))
            msg.peer_id = peer
            if my_id > 0:
                p = TLRPC.TL_peerUser()
                p.user_id = my_id
                msg.from_id = p
            msg.out = False
            msg.flags |= 256
            if int(topic_id or 0):
                rh = TLRPC.TL_messageReplyHeader()
                rh.reply_to_top_id = int(topic_id)
                msg.reply_to = rh
                msg.flags |= 8
            msg.reply_markup = markup
            msg.flags |= 64
            return MessageObject(account, msg, False, False)
        except Exception:
            return None

    def _chat(self, dialog_id):
        try:
            frag = get_last_fragment()
            if frag is None:
                return None
            if hasattr(frag, "getDialogId") and int(frag.getDialogId()) != int(dialog_id):
                return None
            cc = self._chat_activity_cls
            return frag if (cc is None or isinstance(frag, cc)) else None
        except Exception:
            return None

    def _remove_local(self, cell):
        try:
            mo = cell.getMessageObject() if cell else None
            if mo is None:
                return
            chat = self._chat(int(mo.getDialogId()))
            if chat is None:
                return
            m = chat.getClass().getDeclaredMethod("removeMessageObject", MessageObject)
            m.setAccessible(True)
            m.invoke(chat, mo)
        except Exception:
            pass

    def _handle_vanguard_beacon_tap(self, cell, btn, hook):
        try:
            if not self._is_admin_mode():
                return
            if btn is None:
                return
            raw = getattr(btn, "data", None)
            if raw is None:
                return
            payload = bytes(raw).decode("utf-8", errors="ignore")
            nonce, act = self._decode_vanguard_beacon_payload(payload)
            if not nonce:
                return
            hook.setResult(None)
            run_on_queue(lambda: self._route_vanguard_beacon_action(cell, nonce, act))
        except Exception:
            pass

    def _build_shortcut_command(self, raw_cmd, uid):
        try:
            uid_s = int(uid or 0)
            if uid_s <= 0:
                return str(raw_cmd or "").strip()
            cmd = str(raw_cmd or "").strip()
            if not cmd:
                return ""
            uname = self._user_username(uid_s)
            uname_tag = ("@" + uname) if uname else str(uid_s)
            cmd = cmd.replace("{id}", str(uid_s)).replace("{uid}", str(uid_s)).replace("{username}", uname_tag)
            low_cmd = str(cmd).lower()
            has_target = (str(uid_s) in cmd) or (bool(uname) and (("@" + str(uname).lower()) in low_cmd))
            if not has_target:
                parts = str(cmd).strip().split(" ", 1)
                head = str(parts[0] if len(parts) > 0 else "").strip()
                tail = str(parts[1] if len(parts) > 1 else "").strip()
                if head:
                    cmd = "{0} {1}{2}".format(head, str(uid_s), (" " + tail) if tail else "").strip()
                else:
                    cmd = "{0} {1}".format(str(cmd).strip(), str(uid_s)).strip()
            return cmd
        except Exception:
            return str(raw_cmd or "").strip()

    def _send_shortcut(self, dialog_id, uid, source_reply, shortcut_obj):
        try:
            did = int(dialog_id or 0)
            if did == 0 or not isinstance(shortcut_obj, dict):
                return False
            raw_cmd = str(shortcut_obj.get("command", "") or "").strip()
            cmd = self._build_shortcut_command(raw_cmd, uid)
            if not cmd:
                return False
            ok = self._send_warning_message(did, cmd, reply_to=source_reply)
            if ok:
                self._stats_touch(uid, "shortcut")
            return bool(ok)
        except Exception:
            return False

    def _route_vanguard_beacon_action(self, cell, nonce, act):
        c = self._vanguard_beacon_sessions.get(str(nonce))
        if not isinstance(c, dict):
            run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("panel_expired")))
            return
        uid = int(c.get("uid", 0) or 0)
        if uid <= 0:
            return
        if act == "close":
            run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("panel_closed")))
            run_on_ui_thread(lambda: self._remove_local(cell))
            try:
                if isinstance(c, dict):
                    c["beacon_echo"] = None
            except Exception:
                pass
            self._vanguard_beacon_sessions.pop(str(nonce), None)
            return
        if act == "del":
            ok = self._tag_del(uid)
            run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("tag_removed")) if ok else BulletinHelper.show_info(self._tr("no_tag_remove")))
            run_on_ui_thread(lambda: self._rerender_vanguard_beacon_panel(cell, nonce))
            return
        if act == "spam":
            self._tag_set(uid, "⚠️", self._tr("possible_spam"), True)
            self._stats_touch(uid, "spam")
            run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("marked_spam")))
            run_on_ui_thread(lambda: self._rerender_vanguard_beacon_panel(cell, nonce))
            return
        if act == "settings":
            run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("settings_manage_templates")))
            return
        if act == "group_settings":
            did = int(c.get("dialog_id", 0) or 0)
            if not self._supports_group_settings_dialog(did):
                run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("group_settings_group_only")))
                return
            if not self._has_group_admin_access(did):
                run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("group_settings_no_admin")))
                return
            run_on_ui_thread(lambda: self._open_group_settings_panel(did))
            return
        if act == "templates":
            run_on_ui_thread(lambda: self._open_templates_manager())
            return
        if act == "shortcuts":
            c["beacon_state"] = "shortcuts"
            run_on_ui_thread(lambda: self._rerender_vanguard_beacon_panel(cell, nonce))
            return
        if act == "back":
            c["beacon_state"] = "main"
            run_on_ui_thread(lambda: self._rerender_vanguard_beacon_panel(cell, nonce))
            return
        if act.startswith("sc_"):
            try:
                sid = str(act[3:] or "").strip()
                did = int(c.get("dialog_id", 0) or 0)
                src_reply = c.get("source_reply")
                sc = None
                for it in list(self._shortcuts or []):
                    if isinstance(it, dict) and str(it.get("id", "") or "") == sid:
                        sc = it
                        break
                if did != 0 and isinstance(sc, dict):
                    ok = self._send_shortcut(int(did), int(uid), src_reply, sc)
                    run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("shortcut_sent", "Shortcut sent")) if ok else BulletinHelper.show_info(self._tr("failed_send_shortcut", "Failed to send shortcut")))
                run_on_ui_thread(lambda: self._rerender_vanguard_beacon_panel(cell, nonce))
            except Exception:
                run_on_ui_thread(lambda: BulletinHelper.show_info(self._tr("failed_send_shortcut", "Failed to send shortcut")))
            return
        if act == "advanced":
            did = int(c.get("dialog_id", 0) or 0)
            run_on_ui_thread(lambda: self._open_advanced_dialog(did, uid))
            return
        if act in ("add", "edit"):
            run_on_ui_thread(lambda: self._open_vanguard_beacon_editor(uid, nonce, cell, create=(act == "add")))

    def _rerender_vanguard_beacon_panel(self, cell, nonce):
        try:
            if not self._is_admin_mode():
                return
            c = self._vanguard_beacon_sessions.get(str(nonce))
            if not isinstance(c, dict):
                return
            uid = int(c.get("uid", 0) or 0)
            did = int(c.get("dialog_id", 0) or 0)
            removed_ok = False
            had_beacon_echo = False
            try:
                pobj = c.get("beacon_echo", None)
                if pobj is not None:
                    had_beacon_echo = True
                    chat = self._chat(did)
                    if chat is not None:
                        self._remove_local_message_obj(chat, pobj)
                        c["beacon_echo"] = None
                        removed_ok = True
                else:
                    self._remove_local(cell)
                    removed_ok = True
            except Exception:
                try:
                    self._remove_local(cell)
                    removed_ok = True
                except Exception:
                    pass
            if had_beacon_echo and (not removed_ok):
                try:
                    self._dlog("vanguard_beacon_refresh skipped nonce={0}".format(str(nonce)))
                except Exception:
                    pass
                return
            if uid > 0 and did != 0:
                self._emit_vanguard_beacon_panel(did, uid, nonce=nonce)
        except Exception:
            pass

    def _open_vanguard_beacon_editor(self, uid, nonce, cell, create=False):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("dialog_unavailable"))
                return
            self._dlog("vanguard_beacon_editor uid={0} nonce={1} silent={2}".format(int(uid), str(nonce), bool(self._logs_silent())))
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout, TextView, ImageView
            from android.text import InputType
            from android.util import TypedValue
            from android.view import Gravity, View
            from android.content import Context, ClipData
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable
            from android.graphics import Color

            old = self._tag_get(uid) or {}
            d_name = str(old.get("name", "") or "").strip()
            d_tag = str(old.get("tag", "") or "").lstrip(".").strip()
            d_alias = str(self._user_alias_get(uid) or "").strip()
            cctx = self._vanguard_beacon_sessions.get(str(nonce)) if isinstance(self._vanguard_beacon_sessions.get(str(nonce)), dict) else {}
            did = int(cctx.get("dialog_id", 0) or 0)
            try:
                if isinstance(self._vanguard_beacon_sessions.get(str(nonce)), dict) and cctx.get("beacon_echo", None) is None and cell is not None:
                    mo_cur = cell.getMessageObject() if hasattr(cell, "getMessageObject") else None
                    if mo_cur is not None:
                        self._vanguard_beacon_sessions[str(nonce)]["beacon_echo"] = mo_cur
                        cctx["beacon_echo"] = mo_cur
            except Exception:
                pass
            blur_target = self._chat(did) if int(did or 0) != 0 else None
            if blur_target is None:
                blur_target = frag
            def _panel_blur(enable):
                try:
                    self._set_chat_blur(blur_target, bool(enable))
                except Exception:
                    pass
                try:
                    if frag is not None and frag is not blur_target:
                        self._set_chat_blur(frag, bool(enable))
                except Exception:
                    pass
                try:
                    AndroidUtilities.runOnUIThread(lambda: self._set_chat_blur(blur_target, bool(enable)), 60)
                    AndroidUtilities.runOnUIThread(lambda: self._set_chat_blur(blur_target, bool(enable)), 180)
                except Exception:
                    pass
            uname = self._user_username(uid)
            uname_show = ("@" + uname) if uname else "no_username"
            warn_count = self._sync_warn_count(did, uid, fallback_delta=0)
            self._scan_rose_history_for_user(did, uid)

            c_dialog_bg = self._theme_color("key_dialogBackground", 0xFF223043)
            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_link = self._theme_color("key_dialogTextLink", 0xFF71B7FF)
            dark_ui = self._is_dark_color(c_dialog_bg)
            if dark_ui:
                c_chip_bg = Color.parseColor("#2B3D53")
                c_chip_stroke = Color.parseColor("#4F6C8A")
                c_chip_text = Color.parseColor("#D8E5F4")
                c_sep = Color.parseColor("#38506A")
                c_warn_bg = Color.parseColor("#2A3C5A")
                c_warn_stroke = Color.parseColor("#5C8DF5")
                c_warn_text = Color.parseColor("#E6F0FF")
                c_danger_bg = Color.parseColor("#5A2A2A")
                c_danger_stroke = Color.parseColor("#E53935")
                c_danger_text = Color.parseColor("#FFE9E8")
            else:
                c_chip_bg = Color.parseColor("#EEF4FB")
                c_chip_stroke = Color.parseColor("#B6CBE2")
                c_chip_text = Color.parseColor("#233447")
                c_sep = Color.parseColor("#D7E2EF")
                c_warn_bg = Color.parseColor("#EAF3FF")
                c_warn_stroke = Color.parseColor("#5C8DF5")
                c_warn_text = Color.parseColor("#1E3A5B")
                c_danger_bg = Color.parseColor("#FDECEC")
                c_danger_stroke = Color.parseColor("#D43C3C")
                c_danger_text = Color.parseColor("#962626")

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(22), AndroidUtilities.dp(0), AndroidUtilities.dp(22), AndroidUtilities.dp(6))

            header_row = LinearLayout(ctx)
            header_row.setOrientation(LinearLayout.HORIZONTAL)
            header_row.setGravity(Gravity.TOP)
            lp_hr = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            root.addView(header_row, lp_hr)

            header_left = LinearLayout(ctx)
            header_left.setOrientation(LinearLayout.VERTICAL)
            header_left.setGravity(Gravity.START)
            lp_hl = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            header_row.addView(header_left, lp_hl)

            hdr_title = TextView(ctx)
            hdr_title.setText("Vanguard" if not self._is_admin_mode() else self._tr("moderation"))
            hdr_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            try:
                hdr_title.setTextColor(c_title)
            except Exception:
                pass
            header_left.addView(hdr_title)

            sub = TextView(ctx)
            sub.setText(self._tr("only_you_see"))
            sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            sub.setGravity(Gravity.START)
            try:
                sub.setTextColor(Theme.getColor(Theme.key_dialogTextHint))
            except Exception:
                pass
            lp_sub = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sub.topMargin = AndroidUtilities.dp(2)
            header_left.addView(sub, lp_sub)

            admin_row = LinearLayout(ctx)
            admin_row.setOrientation(LinearLayout.HORIZONTAL)
            admin_row.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_ar = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_ar.leftMargin = AndroidUtilities.dp(10)
            header_row.addView(admin_row, lp_ar)

            admin_uid = 0
            admin_name = "Admin"
            admin_name_short = "Admin"
            admin_user = None
            try:
                uc = get_user_config()
                admin_uid = int(uc.getClientUserId()) if uc is not None else 0
            except Exception:
                admin_uid = 0
            try:
                if admin_uid > 0:
                    admin_user = get_messages_controller().getUser(int(admin_uid))
                    if admin_user is not None:
                        first = str(getattr(admin_user, "first_name", "") or "").strip()
                        last = str(getattr(admin_user, "last_name", "") or "").strip()
                        admin_name = (first + " " + last).strip() or admin_name
                        admin_name_short = (first or admin_name).strip() or admin_name
            except Exception:
                pass

            admin_name_tv = TextView(ctx)
            admin_name_tv.setText(self._tr("hi_user").format(str(admin_name_short)))
            admin_name_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 11)
            try:
                admin_name_tv.setTextColor(c_sub)
            except Exception:
                pass
            lp_ant = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_ant.rightMargin = AndroidUtilities.dp(6)
            admin_row.addView(admin_name_tv, lp_ant)

            admin_avatar_view = None
            try:
                from org.telegram.ui.Components import BackupImageView, AvatarDrawable
                av = BackupImageView(ctx)
                av.setRoundRadius(AndroidUtilities.dp(9))
                if admin_user is not None:
                    try:
                        av.setForUserOrChat(admin_user, AvatarDrawable(admin_user))
                    except Exception:
                        av.setImageDrawable(AvatarDrawable(admin_user))
                else:
                    av.setImageDrawable(AvatarDrawable())
                admin_avatar_view = av
            except Exception:
                try:
                    av_txt = TextView(ctx)
                    av_txt.setText((str(admin_name)[:1] or "A").upper())
                    av_txt.setGravity(Gravity.CENTER)
                    av_txt.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 10)
                    av_txt.setTextColor(c_title)
                    abg = GradientDrawable()
                    abg.setShape(GradientDrawable.OVAL)
                    abg.setColor(Color.parseColor("#496A8E"))
                    av_txt.setBackground(abg)
                    admin_avatar_view = av_txt
                except Exception:
                    admin_avatar_view = None
            if admin_avatar_view is not None:
                lp_aav = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                lp_aav.gravity = Gravity.CENTER_VERTICAL
                admin_row.addView(admin_avatar_view, lp_aav)

            user_row = LinearLayout(ctx)
