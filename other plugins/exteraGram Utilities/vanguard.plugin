            def _mk_action_btn(text, bg_col, stroke_col, txt_col):
                from android.graphics.drawable import GradientDrawable
                v = TextView(ctx)
                v.setText(str(text))
                v.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                v.setGravity(Gravity.CENTER)
                v.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8))
                try:
                    v.setTextColor(Color.parseColor(str(txt_col)))
                except Exception:
                    pass
                try:
                    bg = GradientDrawable()
                    bg.setCornerRadius(AndroidUtilities.dp(9))
                    bg.setColor(Color.parseColor(str(bg_col)))
                    bg.setStroke(AndroidUtilities.dp(1), Color.parseColor(str(stroke_col)))
                    v.setBackground(bg)
                except Exception:
                    pass
                return v

            src_reply = cctx.get("source_reply", None) if isinstance(cctx, dict) else None
            panel_ref = {"dlg": None}

            def _open_cmd_confirm(title, cmd, success_msg, on_ok=None, target_peer=None, open_preview_uid=0, panel_dialog=None):
                eb = AlertDialogBuilder(ctx)
                eb.set_title(title)
                eb.set_message(self._tr("review_command_before_send"))
                from org.telegram.ui.Components import EditTextBoldCursor
                from android.text import InputType
                wrap = LinearLayout(ctx)
                wrap.setOrientation(LinearLayout.VERTICAL)
                wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(6))
                et = EditTextBoldCursor(ctx)
                et.setInputType(InputType.TYPE_CLASS_TEXT)
                et.setSingleLine(False)
                et.setMinLines(3)
                et.setMaxLines(6)
                et.setText(str(cmd or ""))
                self._style_dialog_input(et, multiline=True)
                wrap.addView(et, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                eb.set_view(wrap)

                def _confirm_send(dd, _w):
                    out = str(et.getText().toString() if et.getText() is not None else "").strip()
                    if not out:
                        BulletinHelper.show_info(self._tr("message_empty"))
                        return
                    peer = int(target_peer) if target_peer is not None else int(did)
                    ok = self._send_warning_message(peer, out, reply_to=None if target_peer is not None else src_reply)
                    if ok:
                        try:
                            if dd:
                                dd.dismiss()
                        except Exception:
                            pass
                        if callable(on_ok):
                            on_ok()
                        if int(open_preview_uid or 0) > 0:
                            def _open_prev():
                                try:
                                    pd = panel_dialog if panel_dialog is not None else panel_ref.get("dlg")
                                except Exception:
                                    pd = panel_dialog
                                self._present_user_preview(int(open_preview_uid), panel_dialog=pd)
                            run_on_ui_thread(_open_prev)
                        BulletinHelper.show_success(success_msg)
                        self._dlog("cmd_confirm sent peer={0} open_preview_uid={1}".format(int(peer), int(open_preview_uid or 0)))
                    else:
                        BulletinHelper.show_info(self._tr("failed_send_command"))
                        self._dlog("cmd_confirm failed peer={0}".format(int(peer)))

                eb.set_positive_button("Confirm", _confirm_send)
                eb.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
                self._show_builder_dialog(eb, frag)

            def _do_unwarn(_v):
                cmd = self._build_rose_command("rmwarn", uid, "", reply_to=src_reply)
                _open_cmd_confirm(
                    self._tr("remove_one_warning"),
                    cmd,
                    self._tr("rose_command_sent"),
                    on_ok=lambda: _refresh_warns_label(self._sync_warn_count(did, uid, fallback_delta=-1)),
                )

            def _do_reset(_v):
                cmd = self._build_rose_command("resetwarn", uid, "", reply_to=src_reply)
                _open_cmd_confirm(
                    self._tr("reset_all_warnings"),
                    cmd,
                    self._tr("rose_command_sent"),
                    on_ok=lambda: _refresh_warns_label(self._sync_warn_count(did, uid, fallback_set=0)),
                )

            def _do_info(_v=None):
                rose_uid = int(self._resolve_rose_uid(did) or 0)
                cmd = "!info {0}".format(int(uid))
                _open_cmd_confirm(
                    self._tr("rose_info"),
                    cmd,
                    self._tr("info_requested_dm"),
                    on_ok=None,
                    target_peer=rose_uid if rose_uid > 0 else None,
                    open_preview_uid=rose_uid,
                    panel_dialog=panel_ref.get("dlg"),
                )

            def _do_fed(_v=None):
                rose_uid = int(self._resolve_rose_uid(did) or 0)
                cmd = "!fedstat {0}".format(int(uid))
                _open_cmd_confirm(
                    self._tr("federation_info"),
                    cmd,
                    self._tr("fed_info_requested_dm"),
                    on_ok=None,
                    target_peer=rose_uid if rose_uid > 0 else None,
                    open_preview_uid=rose_uid,
                    panel_dialog=panel_ref.get("dlg"),
                )

            def _do_warns(_v=None):
                cmd = "!warns {0}".format(int(uid))
                _open_cmd_confirm(self._tr("warnings"), cmd, self._tr("warns_requested"))

            def _do_fban(_v=None):
                cmd = "!fban {0} Federation action".format(int(uid))
                _open_cmd_confirm("FBAN", cmd, self._tr("fban_requested"))

            def _do_funban(_v=None):
                cmd = "!unfban {0}".format(int(uid))
                _open_cmd_confirm("FUNBAN", cmd, self._tr("funban_requested"))

            selected_reason = {"item": None}

            def _run_fban_massive(reason_text):
                try:
                    reason = " ".join(str(reason_text or "").split()).strip()
                    if not reason:
                        cur = selected_reason.get("item", None)
                        if isinstance(cur, dict):
                            reason = " ".join(str(cur.get("reason", "") or "").split()).strip()
                    if not reason:
                        reason = str(self._tr("federation_action") or "").strip()
                    feds = list(self._federations or [])
                    if not feds:
                        BulletinHelper.show_info(self._tr("no_federations_saved"))
                        return
                    sent = 0
                    for fed in feds:
                        try:
                            peer = int((fed or {}).get("id", 0) or 0)
                            if peer == 0:
                                continue
                            cmd = "!fban {0} {1}".format(int(uid), reason)
                            if self._send_warning_message(int(peer), cmd, reply_to=None):
                                sent += 1
                        except Exception:
                            pass
                    if sent > 0:
                        self._stats_touch(uid, "fban")
                        BulletinHelper.show_success(self._tr("fban_massive_sent_fmt").format(int(sent)))
                    else:
                        BulletinHelper.show_info(self._tr("failed_send_fban_massive"))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_run_fban_massive"))

            def _do_fban_massive(_v=None):
                try:
                    eb = AlertDialogBuilder(ctx)
                    eb.set_title(self._tr("run_fban_massive_title"))
                    eb.set_message(self._tr("review_reason_fban_massive"))
                    from org.telegram.ui.Components import EditTextBoldCursor
                    from android.text import InputType
                    wrap = LinearLayout(ctx)
                    wrap.setOrientation(LinearLayout.VERTICAL)
                    wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(6))
                    et = EditTextBoldCursor(ctx)
                    et.setInputType(InputType.TYPE_CLASS_TEXT)
                    et.setSingleLine(False)
                    et.setMinLines(2)
                    et.setMaxLines(5)
                    cur = selected_reason.get("item", None)
                    if isinstance(cur, dict):
                        et.setText(str(cur.get("reason", "") or ""))
                    else:
                        et.setText(self._tr("federation_action"))
                    self._style_dialog_input(et, multiline=True)
                    wrap.addView(et, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                    eb.set_view(wrap)
                    eb.set_positive_button(
                        "Confirm",
                        lambda d, w: (
                            _run_fban_massive(str(et.getText().toString() if et.getText() is not None else "")),
                            d.dismiss() if d else None
                        ),
                    )
                    eb.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
                    self._show_builder_dialog(eb, frag)
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_run_fban_massive"))

            def _do_check_fb_connection(_v=None):
                try:
                    feds = list(self._federations or [])
                    if not feds:
                        BulletinHelper.show_info(self._tr("no_federations_saved"))
                        return
                    sent = 0
                    msg = "😎 Connected!"
                    for fed in feds:
                        try:
                            peer = int((fed or {}).get("id", 0) or 0)
                            if peer == 0:
                                continue
                            if self._send_warning_message(int(peer), msg, reply_to=None):
                                sent += 1
                                self._queue_ephemeral_delete(int(peer), msg, delay_ms=5000)
                        except Exception:
                            pass
                    if sent > 0:
                        BulletinHelper.show_success(self._tr("connection_ping_sent_fmt").format(int(sent)))
                    else:
                        BulletinHelper.show_info(self._tr("failed_send_connection_ping"))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_check_connection"))

            def _open_tools_dialog(_v=None):
                try:
                    dlg_root = LinearLayout(ctx)
                    dlg_root.setOrientation(LinearLayout.VERTICAL)
                    dlg_root.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(8), AndroidUtilities.dp(18), AndroidUtilities.dp(8))
                    tools_info = TextView(ctx)
                    tools_info.setText(self._tr("manage_warning_tools"))
                    tools_info.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    try:
                        tools_info.setTextColor(c_sub)
                    except Exception:
                        pass
                    lp_ti2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_ti2.bottomMargin = AndroidUtilities.dp(8)
                    dlg_root.addView(tools_info, lp_ti2)
                    row_tools = LinearLayout(ctx)
                    row_tools.setOrientation(LinearLayout.HORIZONTAL)
                    row_tools.setGravity(Gravity.CENTER_VERTICAL)
                    warns_btn = ImageView(ctx)
                    rid_warns = self._resolve_icon_res(ctx, "msg_search", fallback="msg_search")
                    if rid_warns > 0:
                        warns_btn.setImageResource(rid_warns)
                    warns_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
                    try:
                        warns_btn.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                    except Exception:
                        pass
                    try:
                        warns_btn.setColorFilter(c_link)
                    except Exception:
                        pass
                    unwarn_btn = _mk_action_btn("UNWARN", "#{0:06X}".format(c_warn_bg & 0xFFFFFF), "#{0:06X}".format(c_warn_stroke & 0xFFFFFF), "#{0:06X}".format(c_warn_text & 0xFFFFFF))
                    reset_btn = _mk_action_btn("RESET WARNS", "#{0:06X}".format(c_danger_bg & 0xFFFFFF), "#{0:06X}".format(c_danger_stroke & 0xFFFFFF), "#{0:06X}".format(c_danger_text & 0xFFFFFF))
                    lp_wi = LinearLayout.LayoutParams(AndroidUtilities.dp(34), AndroidUtilities.dp(34))
                    try:
                        lp_wi.gravity = Gravity.CENTER_VERTICAL
                    except Exception:
                        pass
                    lp_uw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp_rw = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp_uw.leftMargin = AndroidUtilities.dp(6)
                    lp_rw.leftMargin = AndroidUtilities.dp(6)
                    row_tools.addView(warns_btn, lp_wi)
                    row_tools.addView(unwarn_btn, lp_uw)
                    row_tools.addView(reset_btn, lp_rw)
                    dlg_root.addView(row_tools)

                    td = AlertDialogBuilder(ctx)
                    td.set_title(self._tr("warning_settings"))
                    td.set_view(dlg_root)
                    td.set_negative_button(self._tr("close"), lambda d, w: d.dismiss() if d else None)
                    td.show()
                    warns_btn.setOnClickListener(OnClickListener(_do_warns))
                    unwarn_btn.setOnClickListener(OnClickListener(_do_unwarn))
                    reset_btn.setOnClickListener(OnClickListener(_do_reset))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_details"))

            def _open_fed_dialog(_v=None):
                try:
                    dlg_root = LinearLayout(ctx)
                    dlg_root.setOrientation(LinearLayout.VERTICAL)
                    dlg_root.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(8), AndroidUtilities.dp(18), AndroidUtilities.dp(8))
                    info = TextView(ctx)
                    info.setText(self._tr("fed_commands_for_user"))
                    info.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    info.setTextColor(c_sub)
                    dlg_root.addView(info)
                    row = LinearLayout(ctx)
                    row.setOrientation(LinearLayout.HORIZONTAL)
                    b1 = _mk_action_btn("FEDSTAT", "#{0:06X}".format(c_warn_bg & 0xFFFFFF), "#{0:06X}".format(c_warn_stroke & 0xFFFFFF), "#{0:06X}".format(c_warn_text & 0xFFFFFF))
                    b2 = _mk_action_btn("FBAN", "#{0:06X}".format(c_danger_bg & 0xFFFFFF), "#{0:06X}".format(c_danger_stroke & 0xFFFFFF), "#{0:06X}".format(c_danger_text & 0xFFFFFF))
                    b3 = _mk_action_btn("FUNBAN", "#{0:06X}".format(c_warn_bg & 0xFFFFFF), "#{0:06X}".format(c_warn_stroke & 0xFFFFFF), "#{0:06X}".format(c_warn_text & 0xFFFFFF))
                    lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp2 = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp3 = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lp2.leftMargin = AndroidUtilities.dp(6)
                    lp3.leftMargin = AndroidUtilities.dp(6)
                    row.addView(b1, lp)
                    row.addView(b2, lp2)
                    row.addView(b3, lp3)
                    lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_row.topMargin = AndroidUtilities.dp(8)
                    dlg_root.addView(row, lp_row)

                    sep = View(ctx)
                    try:
                        sep.setBackgroundColor(c_sep)
                    except Exception:
                        pass
                    lp_sep = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(1))
                    lp_sep.topMargin = AndroidUtilities.dp(10)
                    lp_sep.bottomMargin = AndroidUtilities.dp(8)
                    dlg_root.addView(sep, lp_sep)

                    ttl_mass = TextView(ctx)
                    ttl_mass.setText(self._tr("fban_massive_title"))
                    ttl_mass.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    try:
                        ttl_mass.setTextColor(c_title)
                    except Exception:
                        pass
                    dlg_root.addView(ttl_mass)

                    massive_btn = _mk_action_btn(
                        self._tr("run_fban_massive"),
                        "#{0:06X}".format(c_danger_bg & 0xFFFFFF),
                        "#{0:06X}".format(c_danger_stroke & 0xFFFFFF),
                        "#{0:06X}".format(c_danger_text & 0xFFFFFF),
                    )
                    lp_mass = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_mass.topMargin = AndroidUtilities.dp(8)
                    dlg_root.addView(massive_btn, lp_mass)

                    reason_sel_btn = _mk_action_btn(
                        self._tr("reason_preset_selector"),
                        "#{0:06X}".format(c_warn_bg & 0xFFFFFF),
                        "#{0:06X}".format(c_warn_stroke & 0xFFFFFF),
                        "#{0:06X}".format(c_warn_text & 0xFFFFFF),
                    )
                    try:
                        rid_rs = self._resolve_icon_res(ctx, "profile_list", fallback="profile_list")
                        if rid_rs > 0:
                            reason_sel_btn.setCompoundDrawablePadding(AndroidUtilities.dp(6))
                            try:
                                reason_sel_btn.setCompoundDrawablesWithIntrinsicBounds(rid_rs, 0, 0, 0)
                            except Exception:
                                reason_sel_btn.setCompoundDrawablesRelativeWithIntrinsicBounds(rid_rs, 0, 0, 0)
                    except Exception:
                        pass
                    lp_rsel = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_rsel.topMargin = AndroidUtilities.dp(8)
                    dlg_root.addView(reason_sel_btn, lp_rsel)

                    def _refresh_reason_ui():
                        try:
                            cur = selected_reason.get("item", None)
                            if isinstance(cur, dict):
                                reason_sel_btn.setText(
                                    self._tr("reason_preset_selected_fmt").format(str(cur.get("title", "") or ""))
                                )
                            else:
                                reason_sel_btn.setText(self._tr("reason_preset_selector"))
                        except Exception:
                            pass

                    def _open_reason_selector(_v=None):
                        try:
                            from org.telegram.ui.ActionBar import BottomSheet
                            items = [x for x in list(self._reason_presets or []) if isinstance(x, dict)]
                            if not items:
                                BulletinHelper.show_info(self._tr("no_reason_presets"))
                                return
                            sheet = BottomSheet(ctx, True)
                            container = LinearLayout(ctx)
                            container.setOrientation(LinearLayout.VERTICAL)
                            container.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
                            hdr = TextView(ctx)
                            hdr.setText(self._tr("select_reason_preset"))
                            hdr.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                            try:
                                hdr.setTextColor(c_title)
                            except Exception:
                                pass
                            container.addView(hdr)

                            for i, rp in enumerate(items):
                                row = LinearLayout(ctx)
                                row.setOrientation(LinearLayout.HORIZONTAL)
                                row.setGravity(Gravity.CENTER_VERTICAL)
                                row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))

                                iv = ImageView(ctx)
                                rid = self._resolve_icon_res(ctx, "profile_list", fallback="profile_list")
                                if rid > 0:
                                    iv.setImageResource(rid)
                                lp_i = LinearLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18))
                                lp_i.rightMargin = AndroidUtilities.dp(10)
                                row.addView(iv, lp_i)

                                tw = LinearLayout(ctx)
                                tw.setOrientation(LinearLayout.VERTICAL)
                                row.addView(tw, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

                                t1 = TextView(ctx)
                                t1.setText(str(rp.get("title", "") or ""))
                                t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                                try:
                                    t1.setTextColor(c_title)
                                except Exception:
                                    pass
                                tw.addView(t1)

                                t2 = TextView(ctx)
                                t2.setText(str(rp.get("reason", "") or ""))
                                t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                                try:
                                    t2.setTextColor(c_sub)
                                except Exception:
                                    pass
                                tw.addView(t2)

                                def _pick(v=None, rr=rp):
                                    cur = selected_reason.get("item", None)
                                    cur_id = str((cur or {}).get("id", "") or "")
                                    ridx = str(rr.get("id", "") or "")
                                    selected_reason["item"] = None if (cur_id and cur_id == ridx) else rr
                                    _refresh_reason_ui()
                                    try:
                                        sheet.dismiss()
                                    except Exception:
                                        pass

                                row.setOnClickListener(OnClickListener(_pick))
                                container.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                                if i < (len(items) - 1):
                                    div = View(ctx)
                                    try:
                                        div.setBackgroundColor(c_sep)
                                    except Exception:
                                        pass
                                    lp_d = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(1))
                                    lp_d.leftMargin = AndroidUtilities.dp(36)
                                    container.addView(div, lp_d)
                            sheet.setCustomView(container)
                            sheet.show()
                        except Exception:
                            BulletinHelper.show_info(self._tr("failed_open_reason_selector"))

                    td = AlertDialogBuilder(ctx)
                    td.set_title(self._tr("fed_settings"))
                    td.set_view(dlg_root)
                    td.set_negative_button(self._tr("close"), lambda d, w: d.dismiss() if d else None)
                    self._show_builder_dialog(td, frag)
                    _refresh_reason_ui()
                    b1.setOnClickListener(OnClickListener(_do_fed))
                    b2.setOnClickListener(OnClickListener(_do_fban))
                    b3.setOnClickListener(OnClickListener(_do_funban))
                    massive_btn.setOnClickListener(OnClickListener(_do_fban_massive))
                    reason_sel_btn.setOnClickListener(OnClickListener(_open_reason_selector))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_fed_settings"))

            def _open_quick_actions_dialog(_v=None):
                try:
                    items = [x for x in list(self._shortcuts or []) if isinstance(x, dict)]
                    if not items:
                        BulletinHelper.show_info(self._tr("no_shortcuts_saved", "No shortcuts saved yet"))
                        return
                    dlg_root = LinearLayout(ctx)
                    dlg_root.setOrientation(LinearLayout.VERTICAL)
                    dlg_root.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(8), AndroidUtilities.dp(18), AndroidUtilities.dp(8))

                    row = None
                    idx = 0
                    for sc in items:
                        if idx % 2 == 0:
                            row = LinearLayout(ctx)
                            row.setOrientation(LinearLayout.HORIZONTAL)
                            lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                            lp_row.topMargin = AndroidUtilities.dp(8)
                            dlg_root.addView(row, lp_row)
                        b = _mk_action_btn(
                            str(sc.get("title", "") or "..."),
                            "#{0:06X}".format(c_warn_bg & 0xFFFFFF),
                            "#{0:06X}".format(c_warn_stroke & 0xFFFFFF),
                            "#{0:06X}".format(c_warn_text & 0xFFFFFF),
                        )
                        lp_b = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                        if idx % 2 == 1:
                            lp_b.leftMargin = AndroidUtilities.dp(6)
                        row.addView(b, lp_b)
                        b.setOnClickListener(
                            OnClickListener(
                                lambda _vv, s=sc: (
                                    BulletinHelper.show_success(self._tr("shortcut_sent", "Shortcut sent"))
                                    if self._send_shortcut(int(did), int(uid), src_reply, s)
                                    else BulletinHelper.show_info(self._tr("failed_send_shortcut", "Failed to send shortcut"))
                                )
                            )
                        )
                        idx += 1

                    td = AlertDialogBuilder(ctx)
                    td.set_title(self._tr("quick_actions_button", "Quick Actions"))
                    td.set_view(dlg_root)
                    td.set_negative_button(self._tr("close"), lambda d, w: d.dismiss() if d else None)
                    self._show_builder_dialog(td, frag)
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_shortcuts_manager", "Failed to open shortcuts manager"))

            tools_btn.setOnClickListener(OnClickListener(_open_tools_dialog))
            if info_id_btn is not None:
                info_id_btn.setOnClickListener(OnClickListener(_do_info))
            fed_btn.setOnClickListener(OnClickListener(_open_fed_dialog))
            quick_btn.setOnClickListener(OnClickListener(_open_quick_actions_dialog))
            history_btn.setOnClickListener(OnClickListener(lambda _v=None: self._open_user_history_sheet(ctx, did, uid)))

            def _open_apply_confirm():
                tpl = selected.get("tpl")
                if not isinstance(tpl, dict):
                    BulletinHelper.show_info(self._tr("select_admin_action_first"))
                    return
                if int(did or 0) == 0:
                    BulletinHelper.show_info(self._tr("chat_unavailable"))
                    return
                reason = self._render_warning_template(str(tpl.get("body", "") or ""), uid)
                reason = " ".join(str(reason or "").split())
                action = str(tpl.get("action", "warn") or "warn").strip().lower()
                if action not in ("warn", "mute", "ban", "kick"):
                    action = "warn"
                self._stats_touch(uid, action)
                body = self._build_rose_command(action, uid, reason, reply_to=src_reply)
                eb = AlertDialogBuilder(ctx)
                eb.set_title(self._tr("confirm_warning"))
                eb.set_message(self._tr("review_warning_before_send"))
                from org.telegram.ui.Components import EditTextBoldCursor
                from android.text import InputType
                wrap = LinearLayout(ctx)
                wrap.setOrientation(LinearLayout.VERTICAL)
                wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(6))
                et = EditTextBoldCursor(ctx)
                et.setInputType(InputType.TYPE_CLASS_TEXT)
                et.setSingleLine(False)
                et.setMinLines(3)
                et.setMaxLines(6)
                et.setText(body)
                self._style_dialog_input(et, multiline=True)
                wrap.addView(et, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                eb.set_view(wrap)

                def _confirm_send(dd, _w):
                    out = str(et.getText().toString() if et.getText() is not None else "").strip()
                    if not out:
                        BulletinHelper.show_info(self._tr("message_empty"))
                        return
                    ok = self._send_warning_message(int(did), out, reply_to=src_reply)
                    if ok:
                        _refresh_warns_label(self._sync_warn_count(did, uid, fallback_delta=1))
                        BulletinHelper.show_success(self._tr("warning_sent"))
                        try:
                            dd.dismiss()
                        except Exception:
                            pass
                    else:
                        BulletinHelper.show_info(self._tr("failed_send_warning"))

                eb.set_positive_button("Confirm", _confirm_send)
                eb.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
                self._show_builder_dialog(eb, frag)

            apply_btn.setOnClickListener(OnClickListener(lambda v: _open_apply_confirm()))

            b = AlertDialogBuilder(ctx)
            b.set_view(root)

            def _save(d, w):
                try:
                    nm_raw = str(inp_name.getText().toString() if inp_name.getText() is not None else "").strip()
                    tg = str(inp_tag.getText().toString() if inp_tag.getText() is not None else "").strip()
                    if not nm_raw:
                        BulletinHelper.show_info(self._tr("emoji_required"))
                        return
                    if not tg:
                        BulletinHelper.show_info(self._tr("note_required"))
                        return
                    self._dlog("[Tagged] save uid={0} label='{1}'".format(int(uid), nm_raw))
                    self._tag_set(uid, nm_raw, tg, bool(old.get("spam", False)))
                    BulletinHelper.show_success(self._tr("tag_saved"))
                    try:
                        _panel_blur(False)
                        if d:
                            d.dismiss()
                    except Exception:
                        pass
                    self._rerender_vanguard_beacon_panel(cell, nonce)
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_save_tag"))

            b.set_positive_button(self._tr("save"), _save)
            b.set_negative_button(self._tr("cancel"), lambda d, w: (_panel_blur(False), d.dismiss() if d else None))
            b.set_neutral_button(
                self._tr("advanced"),
                lambda d, w: (
                    self._dialog_hide(d),
                    self._open_advanced_dialog(
                        did,
                        uid,
                        on_back=lambda: (self._dialog_show(d), _panel_blur(True)),
                    ),
                ),
            )
            dlg = self._show_builder_dialog(b, frag)
            if dlg is None:
                try:
                    dlg = self._get_visible_dialog(frag)
                except Exception:
                    dlg = None
            panel_ref["dlg"] = dlg
            self._dlog("panel_shown dialog_ref={0}".format("yes" if panel_ref.get("dlg") is not None else "no"))
            _panel_blur(True)

        except Exception as e:
            self._dlog("[Tagged] _show_edit failed: {0}".format(e))
            BulletinHelper.show_info(self._tr("failed_open_editor"))

    def _open_emoji_picker(self, activity, fragment, target_input):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="emoji_picker_open", count=1, force_flush=False)
            except Exception:
                pass
            from java import jclass, dynamic_proxy
            from org.telegram.ui.ActionBar import Theme, BottomSheet
            from android.widget import FrameLayout, LinearLayout
            from android.view import View, ViewGroup

            dp = AndroidUtilities.dp
            container = LinearLayout(activity)
            container.setOrientation(LinearLayout.VERTICAL)
            try:
                container.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundWhite))
            except Exception:
                pass
            emoji_container = FrameLayout(activity)

            EmojiView = jclass("org.telegram.ui.Components.EmojiView")
            EmojiViewDelegate = jclass("org.telegram.ui.Components.EmojiView$EmojiViewDelegate")
            sheet_ref = [None]

            class EmojiDelegate(dynamic_proxy(EmojiViewDelegate)):
                def onEmojiSelected(self_delegate, emoji):
                    try:
                        if emoji:
                            target_input.setText(str(emoji))
                            self._dlog("[Tagged] picker emoji='{0}'".format(str(emoji)))
                            if sheet_ref[0]:
                                sheet_ref[0].dismiss()
                    except Exception:
                        pass

                def onCustomEmojiSelected(self_delegate, documentId, document, emoticon, isRecent):
                    return

                def onBackspace(self_delegate): return False
                def isSearchOpened(self_delegate): return False
                def isExpanded(self_delegate): return False
                def isUserSelf(self_delegate): return False
                def getDialogId(self_delegate): return 0
                def getThreadId(self_delegate): return 0
                def canSchedule(self_delegate): return False
                def isInScheduleMode(self_delegate): return False
                def getProgressToSearchOpened(self_delegate): return 0.0
                def onStickerSelected(self_delegate, view, sticker, query, parent, sendAnimationData, notify, scheduleDate, scheduleRepeatPeriod): pass
                def onStickersSettingsClick(self_delegate): pass
                def onEmojiSettingsClick(self_delegate, frozenEmojiPacks): pass
                def onStickersGroupClick(self_delegate, chatId): pass
                def onGifSelected(self_delegate, view, gif, query, parent, notify, scheduleDate, scheduleRepeatPeriod): pass
                def onTabOpened(self_delegate, type): pass
                def onClearEmojiRecent(self_delegate): pass
                def onShowStickerSet(self_delegate, stickerSet, inputStickerSet, edit): pass
                def onStickerSetAdd(self_delegate, stickerSet): pass
                def onStickerSetRemove(self_delegate, stickerSet): pass
                def onSearchOpenClose(self_delegate, type): pass
                def onAnimatedEmojiUnlockClick(self_delegate): pass
                def showTrendingStickersAlert(self_delegate, layout): pass
                def invalidateEnterView(self_delegate): pass

            emoji_view = EmojiView(fragment, True, False, False, activity, False, None, None, True, None, False)
            try:
                for _m in ("setAllowStickers", "setAllowGifs", "setAllowAnimatedEmoji", "setAllowCustomEmoji"):
                    try:
                        fn = getattr(emoji_view, _m, None)
                        if callable(fn):
                            fn(False)
                    except Exception:
                        pass
            except Exception:
                pass
            emoji_view.setDelegate(EmojiDelegate())
            emoji_view.setVisibility(View.VISIBLE)

            emoji_container.addView(emoji_view, FrameLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, dp(300)))
            container.addView(emoji_container, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, dp(300)))

            b = BottomSheet.Builder(activity, True)
            b.setCustomView(container)
            sheet = b.create()
            sheet.setCanDismissWithSwipe(False)
            sheet_ref[0] = sheet
            sheet.show()
        except Exception as e:
            self._dlog("[Tagged] emoji picker unavailable: {0}".format(e))
            BulletinHelper.show_info(self._tr("emoji_picker_unavailable"))

    def _uid_from_cell_message(self, msg_obj):
        try:
            try:
                sid = int(msg_obj.getSenderId() or 0)
                if sid > 0:
                    return sid
            except Exception:
                pass
            mo = getattr(msg_obj, "messageOwner", None)
            fid = getattr(mo, "from_id", None)
            uid = int(getattr(fid, "user_id", 0) or 0)
            if uid > 0:
                return uid
            pid = getattr(mo, "peer_id", None)
            uid = int(getattr(pid, "user_id", 0) or 0)
            if uid > 0:
                return uid
            try:
                uid = int(msg_obj.getFromChatId() or 0)
                if uid > 0:
                    return uid
            except Exception:
                pass
            return 0
        except Exception:
            return 0

    def _apply_local_alias_to_message(self, msg_obj):
        try:
            if msg_obj is None:
                return
            uid = int(self._uid_from_cell_message(msg_obj) or 0)
            if uid <= 0:
                return
            alias = str(self._user_alias_get(uid) or "").strip()
            if not alias:
                return
            try:
                setattr(msg_obj, "customName", alias)
                return
            except Exception:
                pass
            try:
                c = msg_obj.getClass()
                while c is not None:
                    try:
                        f = c.getDeclaredField("customName")
                        f.setAccessible(True)
                        f.set(msg_obj, alias)
                        return
                    except Exception:
                        c = c.getSuperclass()
            except Exception:
                pass
        except Exception:
            pass

    def _refresh_chat_name_aliases(self, uid=None):
        try:
            target_uid = int(uid or 0)
        except Exception:
            target_uid = 0
        try:
            frag = get_last_fragment()
            if frag is None:
                return
            self._refresh_aliases_in_view(_pf(frag, "chatListView", None), target_uid)
            self._refresh_aliases_in_view(_pf(frag, "listView", None), target_uid)
            try:
                gm = getattr(frag, "getMessagesAdapter", None)
                adapter = gm() if callable(gm) else None
                if adapter is not None:
                    try:
                        adapter.notifyDataSetChanged()
                    except Exception:
                        pass
            except Exception:
                pass
        except Exception:
            pass

    def _refresh_aliases_in_view(self, root, target_uid=0):
        try:
            if root is None:
                return
            count = int(root.getChildCount() or 0) if hasattr(root, "getChildCount") else 0
            for i in range(count):
                try:
                    child = root.getChildAt(i)
                except Exception:
                    child = None
                if child is None:
                    continue
                self._refresh_aliases_in_cell_recursive(child, int(target_uid or 0))
        except Exception:
            pass

    def _refresh_aliases_in_cell_recursive(self, view, target_uid=0):
        try:
            if view is None:
                return
            try:
                cls_name = str(view.getClass().getName() or "")
            except Exception:
                cls_name = ""
            if cls_name.endswith(".ChatMessageCell"):
                msg_obj = _pf(view, "currentMessageObject", None)
                if msg_obj is not None:
                    mu = int(self._uid_from_cell_message(msg_obj) or 0)
                    if int(target_uid or 0) <= 0 or mu == int(target_uid or 0):
                        self._apply_local_alias_to_message(msg_obj)
                        try:
                            view.invalidate()
                        except Exception:
                            pass
                        try:
                            view.requestLayout()
                        except Exception:
                            pass
                return
            try:
                count = int(view.getChildCount() or 0) if hasattr(view, "getChildCount") else 0
            except Exception:
                count = 0
            for i in range(count):
                try:
                    self._refresh_aliases_in_cell_recursive(view.getChildAt(i), target_uid)
                except Exception:
                    pass
        except Exception:
            pass

    def _msg_id(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            mid = int(getattr(mo, "id", 0) or 0)
            if mid:
                return mid
        except Exception:
            pass
        try:
            return int(getattr(msg_obj, "getId")() or 0)
        except Exception:
            return 0

    def _msg_date(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            return int(getattr(mo, "date", 0) or 0)
        except Exception:
            return 0

    def _get_latest_map_cached(self, did, arr):
        rec = self._get_latest_cache_payload(did, arr)
        try:
            mp = rec.get("map", {}) if isinstance(rec, dict) else {}
            return mp if isinstance(mp, dict) else {}
        except Exception:
            return {}

    def _get_latest_cache_payload(self, did, arr):
        now_ms = int(time.time() * 1000)
        key = int(did)
        try:
            sz_now = int(arr.size())
        except Exception:
            sz_now = 0
        last_id_now = 0
        if sz_now > 0:
            try:
                last_obj = arr.get(sz_now - 1)
                if last_obj is not None:
                    last_id_now = int(self._msg_id(last_obj) or 0)
            except Exception:
                last_id_now = 0
        rec = self._latest_cache.get(key)
        if isinstance(rec, dict):
            try:
                if int(rec.get("size", -1)) == int(sz_now) and int(rec.get("last_id", -1)) == int(last_id_now):
                    return rec
                if int(now_ms - int(rec.get("ts", 0))) <= int(self._latest_cache_ttl_ms):
                    return rec
            except Exception:
                pass

        latest = {}
        tagged_uids = set()
        try:
            for k in self._tags.keys():
                try:
                    tagged_uids.add(int(k))
                except Exception:
                    pass
        except Exception:
            tagged_uids = set()

        if not tagged_uids:
            rec = {"ts": now_ms, "map": latest, "size": int(sz_now), "last_id": int(last_id_now)}
            self._latest_cache[key] = rec
            return rec

        found = set()
        for i in range(int(sz_now) - 1, -1, -1):
            try:
                mo2 = arr.get(i)
                if mo2 is None:
                    continue
                uid2 = int(self._uid_from_cell_message(mo2) or 0)
                if uid2 <= 0 or uid2 not in tagged_uids or uid2 in found:
                    continue
                d2 = int(self._msg_date(mo2) or 0)
                id2 = int(self._msg_id(mo2) or 0)
                latest[uid2] = (d2, id2)
                found.add(uid2)
                if len(found) >= len(tagged_uids):
                    break
            except Exception:
                pass

        rec = {"ts": now_ms, "map": latest, "size": int(sz_now), "last_id": int(last_id_now)}
        self._latest_cache[key] = rec
        if len(self._latest_cache) > int(self._latest_cache_limit):
            try:
                items = sorted(
                    list((self._latest_cache or {}).items()),
                    key=lambda it: int(((it[1] or {}).get("ts", 0) if isinstance(it[1], dict) else 0) or 0)
                )
                for k, _ in items[:-int(self._latest_cache_limit)]:
                    self._latest_cache.pop(k, None)
            except Exception:
                pass
        return rec

    def _prune_tag_hit_regions(self, now_ms=None, force=False):
        try:
            cur_ms = int(now_ms or (time.time() * 1000))
            if (not force) and len(self._tag_hit_regions or {}) < int(self._tag_hit_regions_limit):
                if int(cur_ms - int(self._tag_hit_regions_last_prune_ts or 0)) < 3000:
                    return
            ttl_ms = int(self._tag_hit_regions_ttl_ms or 12000)
            fresh = {}
            for k, rec in list((self._tag_hit_regions or {}).items()):
                if not isinstance(rec, dict):
                    continue
                ts = int(rec.get("ts", 0) or 0)
                if ts <= 0 or int(cur_ms - ts) > ttl_ms:
                    continue
                fresh[k] = rec
            if len(fresh) > int(self._tag_hit_regions_limit):
                items = sorted(fresh.items(), key=lambda it: int(((it[1] or {}).get("ts", 0) if isinstance(it[1], dict) else 0) or 0), reverse=True)
                fresh = dict(items[:int(self._tag_hit_regions_limit)])
            self._tag_hit_regions = fresh
            self._tag_hit_regions_last_prune_ts = cur_ms
        except Exception:
            pass

    def _is_latest_visible_for_user(self, cell, msg_obj, uid):
        try:
            if cell is None or msg_obj is None or int(uid or 0) <= 0:
                return False
            cur_id = int(self._msg_id(msg_obj) or 0)
            cur_date = int(self._msg_date(msg_obj) or 0)
            if cur_id <= 0:
                return False
            parent = None
            try:
                parent = cell.getParent()
            except Exception:
                parent = None
            if parent is None or not hasattr(parent, "getChildCount") or not hasattr(parent, "getChildAt"):
                return _is_last(cell)
            cnt = int(parent.getChildCount())
            for i in range(cnt):
                try:
                    ch = parent.getChildAt(i)
                    if ch is None:
                        continue
                    mo2 = None
                    try:
                        mo2 = ch.getMessageObject() if hasattr(ch, "getMessageObject") else None
                    except Exception:
                        mo2 = None
                    if mo2 is None:
                        mo2 = self._gf(ch, "currentMessageObject", None)
                    if mo2 is None:
                        continue
                    uid2 = int(self._uid_from_cell_message(mo2) or 0)
                    if uid2 != int(uid):
                        continue
                    d2 = int(self._msg_date(mo2) or 0)
                    id2 = int(self._msg_id(mo2) or 0)
                    if d2 > cur_date or (d2 == cur_date and id2 > cur_id):
                        return False
                except Exception:
                    pass
            return True
        except Exception:
            return False

    def _draw_tag(self, cell, canvas):
        try:
            if canvas is None or cell is None:
                return
            mo = None
            try:
                mo = cell.getMessageObject() if hasattr(cell, "getMessageObject") else None
            except Exception:
                mo = None
            if mo is None:
                mo = self._gf(cell, "currentMessageObject", None)
            uid = self._uid_from_cell_message(mo)
            if uid <= 0:
                return
            mid = int(self._msg_id(mo) or 0)
            if mid <= 0:
                return

            ce = self._msg_tag_cache.get(mid)
            if not isinstance(ce, dict) or int(ce.get("rev", -1)) != int(self._tags_rev):
                rec = self._tag_get(uid)
                label = str((rec or {}).get("name", "") or "").strip() if isinstance(rec, dict) else ""
                text_w = 0.0
                pill_w = float(self._pill_min_size)
                if label:
                    try:
                        text_w = float(self._emoji_paint.measureText(label))
                        pill_w = max(self._pill_min_size, text_w + (self._pill_text_hpad * 2.0))
                    except Exception:
                        pass
                ce = {
                    "rev": int(self._tags_rev),
                    "uid": int(uid),
                    "label": label,
                    "text_w": float(text_w),
                    "pill_w": float(pill_w),
                }
                self._msg_tag_cache[mid] = ce
                if len(self._msg_tag_cache) > 2048:
                    try:
                        ks = list(self._msg_tag_cache.keys())
                        for mk in ks[:-2048]:
                            self._msg_tag_cache.pop(mk, None)
                    except Exception:
                        pass
            label = str(ce.get("label", "") or "").strip()
            if not label:
                return
            did = int(mo.getDialogId()) if mo is not None else 0
            latest_ok = False
            latest_source_ready = False
            if did != 0:
                chat = self._chat(did)
                arr = self._gf(chat, "messages", None) if chat is not None else None
                if arr is not None:
                    latest_source_ready = True
                    payload = self._get_latest_cache_payload(did, arr)
                    sig = None
                    try:
                        sig = (int(did), int(payload.get("size", -1) or -1), int(payload.get("last_id", -1) or -1))
                    except Exception:
                        sig = None
                    if sig is not None and ce.get("latest_sig") == sig:
                        latest_ok = bool(ce.get("latest_ok"))
                    else:
                        latest_map = payload.get("map", {}) if isinstance(payload, dict) else {}
                        latest_rec = latest_map.get(int(uid)) if isinstance(latest_map, dict) else None
                        if isinstance(latest_rec, tuple) and len(latest_rec) >= 2:
                            latest_mid = int(latest_rec[1] or 0)
                            if latest_mid > 0 and latest_mid == int(mid):
                                latest_ok = True
                        ce["latest_sig"] = sig
                        ce["latest_ok"] = bool(latest_ok)
            if (not latest_ok) and (not latest_source_ready):
                latest_ok = self._is_latest_visible_for_user(cell, mo, uid)
            if not latest_ok:
                return
            left = float(int(self._gf(cell, "backgroundDrawableLeft", -1) or -1))
            right_w = float(int(self._gf(cell, "backgroundDrawableRight", -1) or -1))
            top = float(int(self._gf(cell, "backgroundDrawableTop", -1) or -1))
            if left < 0 or right_w <= 0:
                return

            bubble_right = float(left + right_w)
            fm = self._emoji_paint.getFontMetrics()
            text_h = float(fm.bottom - fm.top)
            pill_h = max(self._pill_min_size, text_h + (self._pill_text_vpad * 2.0))
            text_w = float(ce.get("text_w", 0.0) or 0.0)
            pill_w = float(ce.get("pill_w", self._pill_min_size) or self._pill_min_size)

            x = float(bubble_right + self._emoji_gap)
            try:
                cw = float(int(cell.getMeasuredWidth() or 0))
                if cw > 0:
                    max_x = float(cw - pill_w - AndroidUtilities.dp(2))
                    if x > max_x:
                        x = max_x
            except Exception:
                pass
            y_top = float((top if top > 0 else AndroidUtilities.dp(2)) + self._emoji_top_gap)
            (rgb, lum) = self._get_theme_rgb_cached()
            self._pill_paint.setARGB(
                255,
                int(rgb[0] & 0xFF),
                int(rgb[1] & 0xFF),
                int(rgb[2] & 0xFF),
            )
            self._tmp_rect.set(
                x - self._pill_pad,
                y_top - self._pill_pad,
                x + pill_w + self._pill_pad,
                y_top + pill_h + self._pill_pad,
            )
            canvas.drawRoundRect(self._tmp_rect, self._pill_r, self._pill_r, self._pill_paint)
            try:
                cid = int(cell.hashCode()) if cell is not None else 0
            except Exception:
                cid = 0
            try:
                now_ms = int(time.time() * 1000)
                self._tag_hit_regions[int(mid)] = {
                    "l": float(x - self._pill_pad),
                    "t": float(y_top - self._pill_pad),
                    "r": float(x + pill_w + self._pill_pad),
                    "b": float(y_top + pill_h + self._pill_pad),
                    "uid": int(uid),
                    "ts": now_ms,
                }
                if cid > 0:
                    self._tag_hit_regions["c:{0}".format(int(cid))] = {
                        "l": float(x - self._pill_pad),
                        "t": float(y_top - self._pill_pad),
                        "r": float(x + pill_w + self._pill_pad),
                        "b": float(y_top + pill_h + self._pill_pad),
                        "uid": int(uid),
                        "mid": int(mid),
                        "ts": now_ms,
                    }
                self._prune_tag_hit_regions(now_ms)
            except Exception:
                pass

            if lum < 130:
                self._emoji_paint.setARGB(255, 242, 245, 250)
            else:
                self._emoji_paint.setARGB(255, 24, 26, 30)

            tx = float(x + ((pill_w - text_w) * 0.5))
            ty = float(y_top + ((pill_h - text_h) * 0.5) - fm.top)
            canvas.drawText(label, tx, ty, self._emoji_paint)
        except Exception:
            pass

    def _on_cell_touch(self, cell, event):
        try:
            if cell is None or event is None:
                return False
            act = 0
            try:
                act = int(event.getActionMasked())
            except Exception:
                try:
                    act = int(event.getAction() & 0xFF)
                except Exception:
                    act = 0
            if act != 1:
                return False
            mo = None
            try:
                mo = cell.getMessageObject() if hasattr(cell, "getMessageObject") else None
            except Exception:
                mo = None
            if mo is None:
                mo = self._gf(cell, "currentMessageObject", None)
            uid = int(self._uid_from_cell_message(mo) or 0)
            mid = int(self._msg_id(mo) or 0)
            if uid <= 0 or mid <= 0:
                return False
            rec = self._find_tag_hit_record(cell, mid)
            if not isinstance(rec, dict):
                return False
            try:
                if int(time.time() * 1000) - int(rec.get("ts", 0) or 0) > 5000:
                    return False
            except Exception:
                pass
            if int(rec.get("uid", 0) or 0) != int(uid):
                return False
            x = float(event.getX())
            y = float(event.getY())
            pad = float(AndroidUtilities.dp(2))
            l = float(rec.get("l", 0.0)) - pad
            t = float(rec.get("t", 0.0)) - pad
            r = float(rec.get("r", 0.0)) + pad
            b = float(rec.get("b", 0.0)) + pad
            if (x < l) or (x > r) or (y < t) or (y > b):
                return False
            run_on_ui_thread(lambda: self._show_tag_note_preview(int(uid)))
            return True
        except Exception:
            return False

    def _find_tag_hit_record(self, cell, mid):
        try:
            self._prune_tag_hit_regions()
            rec = None
            try:
                cid = int(cell.hashCode()) if cell is not None else 0
            except Exception:
                cid = 0
            if cid > 0:
                rec = self._tag_hit_regions.get("c:{0}".format(int(cid)))
            if not isinstance(rec, dict):
                rec = self._tag_hit_regions.get(int(mid))
            return rec if isinstance(rec, dict) else None
        except Exception:
            return None

    def _hit_in_tag_region(self, rec, x, y, pad_dp=3):
        try:
            if not isinstance(rec, dict):
                return False
            px = float(x)
            py = float(y)
            pad = float(AndroidUtilities.dp(int(pad_dp)))
            l = float(rec.get("l", 0.0)) - pad
            t = float(rec.get("t", 0.0)) - pad
            r = float(rec.get("r", 0.0)) + pad
            b = float(rec.get("b", 0.0)) + pad
            return not ((px < l) or (px > r) or (py < t) or (py > b))
        except Exception:
            return False

    def _intercept_context_menu(self, view_obj, x, y):
        try:
            cell = view_obj
            if cell is None:
                return False
            mo = None
            try:
                mo = cell.getMessageObject() if hasattr(cell, "getMessageObject") else None
            except Exception:
                mo = None
            if mo is None:
                mo = self._gf(cell, "currentMessageObject", None)
            uid = int(self._uid_from_cell_message(mo) or 0)
            mid = int(self._msg_id(mo) or 0)
            if uid <= 0 or mid <= 0:
                return False
            rec = self._find_tag_hit_record(cell, mid)
            if not isinstance(rec, dict):
                return False
            try:
                if int(time.time() * 1000) - int(rec.get("ts", 0) or 0) > 7000:
                    return False
            except Exception:
                pass
            if not self._hit_in_tag_region(rec, x, y, pad_dp=4):
                return False
            run_on_ui_thread(lambda: self._show_tag_note_preview(int(uid)))
            return True
        except Exception:
            return False

    def _show_tag_note_preview(self, uid):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="tag_preview_open", count=1, force_flush=False)
            except Exception:
                pass
            rec = self._tag_get(uid)
            if not isinstance(rec, dict):
                return
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from android.widget import LinearLayout, TextView, ImageView
            from android.util import TypedValue
            from android.view import Gravity, View
            from org.telegram.ui.ActionBar import Theme
            emoji = str(rec.get("name", "") or "").strip() or "-"
            note = str(rec.get("tag", "") or "").strip() or "-"
            display_name = str(self._user_name(uid) or "-").strip() or "-"
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("tag_note_preview_title_fmt").format(display_name))

            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_div = self._theme_color("key_divider", 0x665B6A7E)
            try:
                if ((int(c_div) >> 24) & 0xFF) < 0x55:
                    c_div = (0x66 << 24) | (int(c_div) & 0x00FFFFFF)
            except Exception:
                c_div = 0x665B6A7E
            c_value = self._theme_color("key_windowBackgroundWhiteBlackText", 0xFFF2F5FA)

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(12), AndroidUtilities.dp(20), AndroidUtilities.dp(12))

            def _divider():
                d = View(ctx)
                try:
                    d.setBackgroundColor(int(c_div))
                except Exception:
                    pass
                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, max(1, int(AndroidUtilities.dp(1))))
                lp.topMargin = AndroidUtilities.dp(10)
                lp.bottomMargin = AndroidUtilities.dp(10)
                return d, lp

            def _section(_icon_name, label_text, value_text, sub_text=None, value_size=15):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.VERTICAL)
                row.setGravity(Gravity.TOP)

                txt = LinearLayout(ctx)
                txt.setOrientation(LinearLayout.VERTICAL)
                lp_t = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                row.addView(txt, lp_t)

                lb = TextView(ctx)
                lb.setText(str(label_text or ""))
                lb.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                lb.setTextColor(c_sub)
                txt.addView(lb)

                val = TextView(ctx)
                val.setText(str(value_text or ""))
                val.setTextSize(TypedValue.COMPLEX_UNIT_DIP, value_size)
                val.setTextColor(c_value)
                txt.addView(val)

                if sub_text is not None:
                    sb = TextView(ctx)
                    sb.setText(str(sub_text or ""))
                    sb.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    sb.setTextColor(c_sub)
                    txt.addView(sb)
                return row

            root.addView(
                _section(
                    "msg_openprofile",
                    self._tr("tag_note_section_profile"),
                    display_name,
                    self._tr("tag_note_id_fmt").format(int(uid)),
                    value_size=18,
                )
            )
            dv1, lp1 = _divider()
            root.addView(dv1, lp1)
            root.addView(
                _section(
                    "menu_tag_plus_solar",
                    self._tr("tag_note_section_tag"),
                    emoji,
                    None,
                    value_size=16,
                )
            )
            dv2, lp2 = _divider()
            root.addView(dv2, lp2)
            root.addView(
                _section(
                    "msg_log",
                    self._tr("tag_note_section_note"),
                    note,
                    None,
                    value_size=16,
                )
            )

            b.set_view(root)
            b.set_positive_button(self._tr("close"), lambda d, w: d.dismiss() if d else None)
            self._show_builder_dialog(b, frag)
        except Exception:
            pass

    def _on_cell_long_press(self, cell, x, y):
        try:
            if cell is None:
                return False
            mo = None
            try:
                mo = cell.getMessageObject() if hasattr(cell, "getMessageObject") else None
            except Exception:
                mo = None
            if mo is None:
                mo = self._gf(cell, "currentMessageObject", None)
            uid = int(self._uid_from_cell_message(mo) or 0)
            mid = int(self._msg_id(mo) or 0)
            if uid <= 0 or mid <= 0:
                return False
            rec = self._find_tag_hit_record(cell, mid)
            if not isinstance(rec, dict):
                return False
            try:
                if int(time.time() * 1000) - int(rec.get("ts", 0) or 0) > 6000:
                    return False
            except Exception:
                pass
            if not self._hit_in_tag_region(rec, x, y, pad_dp=4):
                return False
            run_on_ui_thread(lambda: self._show_tag_note_preview(int(uid)))
            return True
        except Exception:
            return False

    def _get_theme_color_component(self, idx):
        try:
            from org.telegram.ui.ActionBar import Theme
            keys = [
                "key_chat_inBubble",
                "key_chat_inBubbleSelected",
                "key_chat_messagePanelBackground",
                "key_windowBackgroundWhite",
            ]
            c = 0xFF23262C
            for kn in keys:
                try:
                    k = getattr(Theme, kn)
                    c = int(Theme.getColor(k))
                    if c:
                        break
                except Exception:
                    pass
            if idx == 0:
                return (c >> 16)
            if idx == 1:
                return (c >> 8)
            return c
        except Exception:
            if idx == 0:
                return 35
            if idx == 1:
                return 38
            return 44

    def _get_theme_rgb_cached(self):
        now_ms = int(time.time() * 1000)
        rec = self._theme_rgb_cache
        try:
            if int(now_ms - int(rec.get("ts", 0))) <= 1200:
                return rec.get("rgb", (35, 38, 44)), float(rec.get("lum", 42.0))
        except Exception:
            pass
        r = int(self._get_theme_color_component(0) & 0xFF)
        g = int(self._get_theme_color_component(1) & 0xFF)
        b = int(self._get_theme_color_component(2) & 0xFF)
        lum = float((0.299 * r) + (0.587 * g) + (0.114 * b))
        self._theme_rgb_cache = {"ts": now_ms, "rgb": (r, g, b), "lum": lum}
        return (r, g, b), lum

    def _ellipsize(self, text, max_w):
        try:
            s = str(text or "").strip()
            if not s:
                return ""
            if float(self._note_paint.measureText(s)) <= float(max_w):
                return s
            dots = "..."
            cur = s
            while cur:
                c = cur + dots
                if float(self._note_paint.measureText(c)) <= float(max_w):
                    return c
                cur = cur[:-1]
            return dots
        except Exception:
            return str(text or "")
