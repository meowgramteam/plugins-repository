                lp_desc_reset = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_desc_reset.topMargin = AndroidUtilities.dp(4)
                texts.addView(desc_reset, lp_desc_reset)
                return card

            sheet = BottomSheet(ctx, True)
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            bg = GradientDrawable()
            bg.setCornerRadius(float(AndroidUtilities.dp(22)))
            bg.setColor(c_bg)
            root.setBackground(bg)

            title = TextView(ctx)
            title.setText(self._tr("mentions_hub_welcome_title"))
            title.setTypeface(Typeface.DEFAULT_BOLD)
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTextColor(c_title)
            root.addView(title)

            desc = TextView(ctx)
            desc.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            desc.setTextColor(c_sub)
            lp_desc = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_desc.topMargin = AndroidUtilities.dp(6)
            root.addView(desc, lp_desc)

            def _show_create_loading():
                try:
                    b = AlertDialogBuilder(ctx)
                    b.set_title(self._tr("mentions_hub_creating_title"))
                    b.set_message(self._tr("mentions_hub_creating_text"))
                    self._mentions_hub_loading_dialog = b.show()
                except Exception:
                    self._mentions_hub_loading_dialog = None

            def _start_create():
                try:
                    if self._mentions_hub_sheet_dialog is not None:
                        self._mentions_hub_sheet_dialog.dismiss()
                except Exception:
                    pass
                self._mentions_hub_sheet_dialog = None
                self._mentions_hub_sheet_refresh = None
                _show_create_loading()
                ok = bool(self._mentions_hub_create())
                if not ok:
                    try:
                        if self._mentions_hub_loading_dialog is not None:
                            self._mentions_hub_loading_dialog.dismiss()
                    except Exception:
                        pass
                    self._mentions_hub_loading_dialog = None

            def _confirm_reset():
                try:
                    b = AlertDialogBuilder(ctx)
                    b.set_title(self._tr("mentions_hub_reset_confirm_title"))
                    b.set_message(self._tr("mentions_hub_reset_confirm_text"))
                    b.set_negative_button(self._tr("mentions_hub_reset_confirm_no"), None)
                    b.set_positive_button(self._tr("mentions_hub_reset_confirm_yes"), lambda _d=None, _w=None: self._mentions_hub_delete_inbox())
                    b.show()
                except Exception:
                    self._mentions_hub_delete_inbox()

            def _render():
                inbox_did = int(self._mentions_hub_resolve_inbox() or 0)
                is_configured = bool(self._mentions_hub_is_configured())
                try:
                    while int(root.getChildCount() or 0) > 2:
                        root.removeViewAt(2)
                except Exception:
                    pass
                if not is_configured:
                    desc.setText(self._tr("mentions_hub_welcome_text"))
                    _add_end_btn(root, "mentions_hub_create", _start_create)
                else:
                    desc.setText(self._tr("mentions_hub_desc"))
                    events_text = self._mentions_hub_events_text()
                    _add_main_action(
                        root,
                        "mini_mention_filled_16",
                        "mentions_hub_open_inbox",
                        events_text,
                        lambda: (sheet.dismiss(), self._mentions_hub_open_inbox()),
                        on_long=lambda: self._mentions_hub_prompt_manual_group_id(),
                    )
                    actions = LinearLayout(ctx)
                    actions.setOrientation(LinearLayout.HORIZONTAL)
                    actions.setGravity(Gravity.CENTER_VERTICAL)
                    lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_actions.topMargin = AndroidUtilities.dp(16)
                    root.addView(actions, lp_actions)
                    _add_secondary_action(actions, "msg_instant_link_solar", "mentions_hub_edit", lambda: self._mentions_hub_prompt_manual_group_id())
                    spacer = View(ctx)
                    actions.addView(spacer, LinearLayout.LayoutParams(AndroidUtilities.dp(8), 1))
                    _add_secondary_action(actions, "menu_factcheck", "mentions_hub_test", lambda: (sheet.dismiss(), self._mentions_hub_test_connection()))
                    _add_reset_action(root, _confirm_reset)
                    did = int(self._active_dialog_id() or 0)
                    if self._supports_group_settings_dialog(did):
                        _add_tag_item(root, lambda: self._mentions_hub_tag_current_group(), on_long=lambda: self._open_mentions_hub_sources_sheet())
                        explain = TextView(ctx)
                        explain.setText(self._tr("mentions_hub_tag_group_sub"))
                        explain.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                        explain.setTextColor(c_sub)
                        lp_explain = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                        lp_explain.topMargin = AndroidUtilities.dp(8)
                        explain.setPadding(AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4), 0)
                        root.addView(explain, lp_explain)

            self._mentions_hub_sheet_refresh = _render
            _render()

            sheet.setCustomView(root)
            self._mentions_hub_sheet_dialog = sheet
            sheet.show()
            return True
        except Exception:
            BulletinHelper.show_info(self._tr("dialog_unavailable"))
            return False

    def _mentions_hub_finish_created(self, inbox_did):
        try:
            self._mentions_hub["inbox_dialog_id"] = int(inbox_did)
            self._save_mentions_hub()
            self._mentions_hub_create_pending = False
            self._mentions_hub_create_watchdog = False
            self._mentions_hub_create_ignore_did = 0
            try:
                self._apply_mentions_hub_avatar_async(int(inbox_did))
            except Exception:
                pass
            def _finish():
                try:
                    if self._mentions_hub_loading_dialog is not None:
                        self._mentions_hub_loading_dialog.dismiss()
                except Exception:
                    pass
                self._mentions_hub_loading_dialog = None
                try:
                    if self._mentions_hub_sheet_dialog is not None:
                        self._mentions_hub_sheet_dialog.dismiss()
                except Exception:
                    pass
                self._mentions_hub_sheet_dialog = None
                self._mentions_hub_sheet_refresh = None
                try:
                    self._open_mentions_hub_sheet()
                except Exception:
                    pass
                BulletinHelper.show_success(self._tr("mentions_hub_created"))
            run_on_ui_thread(_finish)
            return True
        except Exception:
            return False

    def _mentions_hub_watch_create_result(self, remaining=20):
        try:
            if not bool(self._mentions_hub_create_pending):
                self._mentions_hub_create_watchdog = False
                return
            found = int(self._mentions_hub_find_existing_inbox(int(self._mentions_hub_create_ignore_did or 0)) or 0)
            if found < 0:
                self._mentions_hub_finish_created(found)
                return
            if int(remaining or 0) <= 0:
                self._mentions_hub_create_pending = False
                self._mentions_hub_create_watchdog = False
                def _fail():
                    try:
                        if self._mentions_hub_loading_dialog is not None:
                            self._mentions_hub_loading_dialog.dismiss()
                    except Exception:
                        pass
                    self._mentions_hub_loading_dialog = None
                    try:
                        self._open_mentions_hub_sheet()
                    except Exception:
                        pass
                    BulletinHelper.show_info(self._tr("mentions_hub_create_failed"))
                run_on_ui_thread(_fail)
                return

            def _tick():
                self._mentions_hub_watch_create_result(int(remaining) - 1)
            t = threading.Timer(0.5, _tick)
            t.daemon = True
            t.start()
        except Exception:
            self._mentions_hub_create_pending = False
            self._mentions_hub_create_watchdog = False

    def _is_supported_peek_dialog(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did >= 0:
                return False
            ch = self._chat_by_dialog_id(did)
            if ch is None:
                return False
            is_mega = bool(getattr(ch, "megagroup", False))
            is_forum = bool(getattr(ch, "forum", False))
            is_broadcast = bool(getattr(ch, "broadcast", False))
            return bool(is_mega or is_forum or (not is_broadcast))
        except Exception:
            return False

    def _load_peek_groups(self):
        try:
            raw = self.get_setting("tagged_peek_groups_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            out = []
            for it in (arr or []):
                if not isinstance(it, dict):
                    continue
                did = int(it.get("id", 0) or 0)
                chat_id = int(it.get("chat_id", 0) or 0)
                name = str(it.get("name", "") or "").strip()
                if did >= 0:
                    continue
                if chat_id <= 0:
                    chat_id = int(self._dialog_to_chat_id(did) or 0)
                if chat_id <= 0:
                    continue
                if not name:
                    name = self._dialog_title_by_id(did) or "Group {0}".format(int(chat_id))
                out.append({
                    "id": int(did),
                    "chat_id": int(chat_id),
                    "name": str(name),
                    "added_at": int(it.get("added_at", int(time.time())) or int(time.time())),
                })
            uniq = {}
            for p in out:
                uniq[str(int(p.get("id", 0)))] = p
            self._peek_groups = list(uniq.values())[:5]
            self._save_peek_groups()
        except Exception:
            self._peek_groups = []

    def _save_peek_groups(self):
        try:
            self.set_setting("tagged_peek_groups_v1", json.dumps(list(self._peek_groups or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _peek_add_or_update(self, dialog_id, name=None):
        try:
            did = int(dialog_id or 0)
            if did >= 0 or (not self._is_supported_peek_dialog(did)):
                return False, "invalid"
            cid = int(self._dialog_to_chat_id(did) or 0)
            if cid <= 0:
                return False, "invalid"
            nm = str(name or "").strip() or self._dialog_title_by_id(did) or "Group {0}".format(int(cid))
            arr = list(self._peek_groups or [])
            found = False
            for it in arr:
                if not isinstance(it, dict):
                    continue
                if int(it.get("id", 0) or 0) == did:
                    it["chat_id"] = int(cid)
                    it["name"] = str(nm)
                    it["added_at"] = int(time.time())
                    found = True
                    break
            if not found:
                if len(arr) >= 5:
                    return False, "limit"
                arr.append({"id": int(did), "chat_id": int(cid), "name": str(nm), "added_at": int(time.time())})
            self._peek_groups = arr[:5]
            self._save_peek_groups()
            self._schedule_admin_tab_refresh(180)
            return True, "ok"
        except Exception:
            return False, "error"

    def _peek_remove(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            before = len(list(self._peek_groups or []))
            self._peek_groups = [x for x in list(self._peek_groups or []) if int((x or {}).get("id", 0) or 0) != did]
            self._save_peek_groups()
            self._schedule_admin_tab_refresh(180)
            return len(self._peek_groups) != before
        except Exception:
            return False

    def _shortcuts_enabled(self):
        try:
            return bool(self.get_setting("tagged_my_shortcuts_enabled", False))
        except Exception:
            return False

    def _fed_add_or_update(self, fed_id, fed_name):
        try:
            fid = int(fed_id or 0)
            if fid == 0:
                return False
            nm = str(fed_name or "").strip() or "Federation {0}".format(abs(fid))
            arr = list(self._federations or [])
            found = False
            for it in arr:
                if not isinstance(it, dict):
                    continue
                if int(it.get("id", 0) or 0) == fid:
                    it["name"] = nm
                    it["added_at"] = int(time.time())
                    found = True
                    break
            if not found:
                arr.append({"id": fid, "name": nm, "added_at": int(time.time())})
            self._federations = arr
            self._save_federations()
            return True
        except Exception:
            return False

    def _fed_remove(self, fed_id):
        try:
            fid = int(fed_id or 0)
            before = len(list(self._federations or []))
            self._federations = [x for x in list(self._federations or []) if int((x or {}).get("id", 0) or 0) != fid]
            self._save_federations()
            return len(self._federations) != before
        except Exception:
            return False

    def _dialog_title_by_id(self, dialog_id):
        did = int(dialog_id or 0)
        if did == 0:
            return ""
        try:
            if did < 0:
                chat = get_messages_controller().getChat(abs(int(did)))
                if chat is not None:
                    ttl = str(getattr(chat, "title", "") or "").strip()
                    if ttl:
                        return ttl
        except Exception:
            pass
        try:
            if did > 0:
                usr = get_messages_controller().getUser(int(did))
                if usr is not None:
                    first = str(getattr(usr, "first_name", "") or "").strip()
                    last = str(getattr(usr, "last_name", "") or "").strip()
                    nm = (first + " " + last).strip()
                    if nm:
                        return nm
        except Exception:
            pass
        return ""

    def _load_warn_counts(self):
        try:
            raw = self.get_setting("tagged_warn_counts_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
            self._warn_counts = data if isinstance(data, dict) else {}
        except Exception:
            self._warn_counts = {}

    def _save_warn_counts(self):
        try:
            self.set_setting("tagged_warn_counts_v1", json.dumps(self._warn_counts, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _warn_count(self, uid):
        try:
            return int(self._warn_counts.get(str(int(uid)), 0) or 0)
        except Exception:
            return 0

    def _inc_warn(self, uid, delta=1):
        try:
            k = str(int(uid))
            cur = int(self._warn_counts.get(k, 0) or 0)
            nxt = cur + int(delta or 0)
            self._warn_counts[k] = nxt if nxt > 0 else 0
            self._save_warn_counts()
        except Exception:
            pass

    def _set_warn_count(self, uid, count):
        try:
            k = str(int(uid))
            self._warn_counts[k] = max(0, int(count or 0))
            self._save_warn_counts()
        except Exception:
            pass

    def _load_rose_history(self):
        try:
            raw = self.get_setting("tagged_rose_history_v1", "{}")
            data = raw if isinstance(raw, dict) else json.loads(str(raw or "{}"))
            self._rose_history = data if isinstance(data, dict) else {}
        except Exception:
            self._rose_history = {}

    def _save_rose_history(self):
        try:
            self.set_setting("tagged_rose_history_v1", json.dumps(self._rose_history, ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _open_plugin_settings(self):
        try:
            fragment = get_last_fragment()
            if fragment is None:
                return False
            controller = PluginsController.getInstance()
            plugin = controller.plugins.get(self.id) if controller else None
            if plugin is None:
                return False
            fragment.presentFragment(PluginSettingsActivity(plugin))
            return True
        except Exception:
            return False

    def _add_menu_items(self):
        try:
            if self._chat_menu_item is not None:
                return
            self._chat_menu_item = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Vanguard",
                    icon="msg2_policy",
                    priority=5,
                    on_click=lambda _ctx: run_on_ui_thread(self._open_plugin_settings),
                )
            )
        except Exception as e:
            self._dlog("add menu item fail: {0}".format(e))

    def _show_about_sheet(self, ctx_override=None):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="settings_about_open", count=1, force_flush=False)
            except Exception:
                pass
            from java import dynamic_proxy
            from android.widget import LinearLayout, TextView, ImageView
            from android.view import Gravity, View, ViewOutlineProvider
            from android.graphics import BitmapFactory
            from android.graphics.drawable import GradientDrawable
            from org.telegram.ui.ActionBar import Theme, BottomSheet
            from org.telegram.messenger import ApplicationLoader

            frag = get_last_fragment()
            ctx = None
            try:
                if frag and frag.getParentActivity():
                    ctx = frag.getParentActivity()
            except Exception:
                ctx = None
            if ctx is None:
                ctx = ctx_override
            if ctx is None:
                ctx = ApplicationLoader.applicationContext
            if not ctx:
                return
            try:
                self._ensure_settings_header_assets()
            except Exception:
                pass
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass

            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                root_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                root.setBackground(root_bg)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            try:
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                row_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                row.setBackground(row_bg)
            except Exception:
                pass

            avatar = ImageView(ctx)
            try:
                avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                av_bg = GradientDrawable()
                av_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                av_bg.setColor(0x00000000)
                avatar.setBackground(av_bg)
                avatar.setClipToOutline(True)
                avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                if os.path.exists(ABOUT_AVATAR_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(ABOUT_AVATAR_CACHE_FILE)
                    if bmp:
                        avatar.setImageBitmap(bmp)
                avatar.setCameraDistance(float(AndroidUtilities.dp(800)))
                avatar.setAlpha(0.0)
                avatar.setTranslationY(float(AndroidUtilities.dp(26)))
                avatar.setRotationY(-120.0)
            except Exception:
                pass
            row.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            try:
                desc.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_desc.leftMargin = AndroidUtilities.dp(10)
            row.addView(desc, lp_desc)
            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            btn = TextView(ctx)
            btn.setText(self._tr("about_button"))
            btn.setGravity(Gravity.CENTER)
            btn.setTextSize(16)
            try:
                btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            extended_btn = ImageView(ctx)
            try:
                extended_btn.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                is_dark = bool(Theme.isCurrentThemeDark())
                icon_path = EXTENDED_ICON_CACHE_FILE_DARK if is_dark else EXTENDED_ICON_CACHE_FILE_LIGHT
                if os.path.exists(icon_path):
                    bmp = BitmapFactory.decodeFile(icon_path)
                    if bmp:
                        extended_btn.setImageBitmap(bmp)
                extended_btn.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            except Exception:
                pass

            class _AboutOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        get_messages_controller().openByUserName("AGeekApple", get_last_fragment(), 1)
                    except Exception:
                        try:
                            self.open_url("https://t.me/AGeekApple")
                        except Exception:
                            pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            btn.setOnClickListener(_AboutOpen())

            class _ExtendedOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self.open_url("tg://resolve?domain=ApplesBio&post=4")
                    except Exception:
                        try:
                            get_messages_controller().openByUserName("ApplesBio", get_last_fragment(), 1)
                        except Exception:
                            try:
                                self.open_url("https://t.me/ApplesBio/4")
                            except Exception:
                                pass

            extended_btn.setOnClickListener(_ExtendedOpen())

            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_actions.topMargin = AndroidUtilities.dp(10)

            lp_ext = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
            lp_ext.rightMargin = AndroidUtilities.dp(8)
            actions.addView(extended_btn, lp_ext)
            lp_btn = LinearLayout.LayoutParams(AndroidUtilities.dp(120), LinearLayout.LayoutParams.WRAP_CONTENT)
            actions.addView(btn, lp_btn)
            root.addView(actions, lp_actions)

            try:
                max_w = int(AndroidUtilities.displaySize.x) - AndroidUtilities.dp(36)
            except Exception:
                max_w = LinearLayout.LayoutParams.MATCH_PARENT
            lp_root = LinearLayout.LayoutParams(max_w, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_root.gravity = Gravity.CENTER_HORIZONTAL
            outer.addView(root, lp_root)

            sheet.setCustomView(outer)
            sheet.show()
            try:
                avatar.post(lambda: avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start())
            except Exception:
                try:
                    avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start()
                except Exception:
                    pass
        except Exception as e:
            self._dlog("about sheet fail: {0}".format(e))

    def _on_about_click(self, _view=None):
        try:
            run_on_ui_thread(lambda: self._show_about_sheet(None))
        except Exception:
            self._show_about_sheet(None)

    def _resolve_rose_uid(self, dialog_id=0):
        try:
            cached = int(self.get_setting("tagged_rose_uid_cache", 0) or 0)
            if cached > 0:
                return cached
        except Exception:
            pass
        try:
            did = int(dialog_id or 0)
            if did != 0:
                for mo in reversed(self._iter_dialog_messages(did, limit=220)):
                    try:
                        if not self._is_rose_msg(mo):
                            continue
                        sid = int(self._uid_from_cell_message(mo) or 0)
                        if sid > 0:
                            try:
                                self.set_setting("tagged_rose_uid_cache", int(sid))
                            except Exception:
                                pass
                            return sid
                    except Exception:
                        pass
        except Exception:
            pass
        return 609517172

    def _dialog_hide(self, dlg):
        try:
            if dlg is None:
                return
            self._dlog("dialog_hide: {0}".format(str(dlg.getClass()) if hasattr(dlg, "getClass") else "unknown"))
            if hasattr(dlg, "hide"):
                dlg.hide()
        except Exception:
            pass

    def _dismiss_current_dialog(self, fragment):
        try:
            if fragment is None:
                return
            self._dlog("dismiss_current_dialog: {0}".format(str(fragment.getClass()) if hasattr(fragment, "getClass") else "unknown"))
            if hasattr(fragment, "dismissCurrentDialog"):
                fragment.dismissCurrentDialog()
        except Exception:
            pass

    def _dialog_show(self, dlg):
        try:
            if dlg is None:
                return
            self._dlog("dialog_show: {0}".format(str(dlg.getClass()) if hasattr(dlg, "getClass") else "unknown"))
            if hasattr(dlg, "show"):
                dlg.show()
        except Exception:
            pass

    def _dialog_dismiss(self, dlg):
        try:
            if dlg is None:
                return
            self._dlog("dialog_dismiss: {0}".format(str(dlg.getClass()) if hasattr(dlg, "getClass") else "unknown"))
            if hasattr(dlg, "dismiss"):
                dlg.dismiss()
        except Exception:
            pass

    def _get_visible_dialog(self, fragment):
        try:
            if fragment is None:
                return None
            if hasattr(fragment, "getVisibleDialog"):
                vd = fragment.getVisibleDialog()
                if vd is not None:
                    return vd
        except Exception:
            pass
        try:
            vd = _pf(fragment, "visibleDialog", None)
            return vd if vd is not None else None
        except Exception:
            return None

    def _show_builder_dialog(self, builder, fragment=None):
        dlg = None
        try:
            if builder is not None and fragment is not None and hasattr(fragment, "showDialog"):
                created = None
                try:
                    if hasattr(builder, "create"):
                        created = builder.create()
                except Exception:
                    created = None
                if created is None:
                    try:
                        m = builder.getClass().getDeclaredMethod("create")
                        m.setAccessible(True)
                        created = m.invoke(builder)
                    except Exception:
                        created = None
                if created is not None:
                    dlg = fragment.showDialog(created)
                    self._dlog("show_builder_dialog via fragment.showDialog")
        except Exception as e:
            self._dlog("show_builder_dialog fallback reason: {0}".format(e))
            dlg = None
        try:
            if dlg is None:
                dlg = builder.show()
                self._dlog("show_builder_dialog via builder.show")
        except Exception as e:
            self._dlog("show_builder_dialog failed: {0}".format(e))
            dlg = None
        return dlg

    def _set_chat_blur(self, fragment, enable):
        try:
            if fragment is None:
                self._dlog("set_chat_blur skipped: fragment=None")
                return
            self._dlog("set_chat_blur start enable={0}".format(bool(enable)))
            m = None
            c = None
            try:
                c = fragment.getClass()
            except Exception:
                c = None
            target_boolean = None
            try:
                target_boolean = jclass("boolean")
            except Exception:
                target_boolean = None
            while c is not None and m is None:
                try:
                    if target_boolean is not None:
                        m = c.getDeclaredMethod("checkShowBlur", target_boolean)
                except Exception:
                    m = None
                if m is None:
                    try:
                        methods = c.getDeclaredMethods()
                        for mm in methods:
                            if str(mm.getName() or "") != "checkShowBlur":
                                continue
                            pcount = 0
                            try:
                                ptypes = mm.getParameterTypes()
                                try:
                                    pcount = int(len(ptypes))
                                except Exception:
                                    pcount = int(getattr(ptypes, "length", 0) or 0)
                            except Exception:
                                pcount = 0
                            if pcount == 1:
                                m = mm
                                break
                    except Exception:
                        m = None
                if m is None:
                    try:
                        c = c.getSuperclass()
                    except Exception:
                        c = None
            if m is None:
                self._dlog("set_chat_blur: checkShowBlur not found")
                return
            try:
                m.setAccessible(True)
            except Exception:
                pass
            m.invoke(fragment, bool(enable))
            self._dlog("set_chat_blur invoked")
            try:
                AndroidUtilities.runOnUIThread(lambda: m.invoke(fragment, bool(enable)), 40)
            except Exception:
                pass
            try:
                AndroidUtilities.runOnUIThread(lambda: m.invoke(fragment, bool(enable)), 140)
            except Exception:
                pass
        except Exception as e:
            self._dlog("set_chat_blur failed: {0}".format(e))

    def _present_user_preview(self, uid, panel_dialog=None):
        try:
            frag = get_last_fragment()
            if frag is None:
                self._dlog("present_preview aborted: no fragment")
                return False
            pd = panel_dialog
            if pd is None:
                pd = self._get_visible_dialog(frag)
            self._dlog("present_preview uid={0} panel_dialog={1}".format(int(uid), "yes" if pd is not None else "no"))
            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            args.putLong("user_id", int(uid))
            preview_fragment = ChatActivity(args)
            try:
                allow_field = preview_fragment.getClass().getDeclaredField("allowExpandPreviewByClick")
                allow_field.setAccessible(True)
                allow_field.setBoolean(preview_fragment, False)
            except Exception:
                pass
            self._dialog_hide(pd)
            self._dialog_dismiss(pd)
            self._dismiss_current_dialog(frag)
            menu = self._build_preview_menu_simple(
                frag,
                on_close=lambda: (
                    self._dialog_show(pd),
                    self._set_chat_blur(frag, True if pd is not None else False),
                ),
                on_expand=lambda: self._set_chat_blur(frag, False),
                enable_quick_reply=False,
            )
            if menu is None:
                self._dlog("present_preview aborted: menu=None")
                self._dialog_show(pd)
                return False
            try:
                frag.presentFragmentAsPreviewWithMenu(preview_fragment, menu)
            except Exception:
                AndroidUtilities.runOnUIThread(lambda: frag.presentFragmentAsPreviewWithMenu(preview_fragment, menu), 50)
            self._set_chat_blur(frag, True)
            self._dlog("present_preview shown")
            return True
        except Exception as e:
            self._dlog("present_preview failed: {0}".format(e))
            try:
                self._dialog_show(panel_dialog)
            except Exception:
                pass
            return False

    def _present_chat_preview(self, dialog_id, panel_dialog=None):
        try:
            did = int(dialog_id or 0)
            if did >= 0:
                return False
            chat_id = int(self._dialog_to_chat_id(did) or 0)
            if chat_id <= 0:
                return False
            frag = get_last_fragment()
            if frag is None:
                self._dlog("present_chat_preview aborted: no fragment")
                return False
            pd = panel_dialog
            if pd is None:
                pd = self._get_visible_dialog(frag)
            self._dlog("present_chat_preview did={0} cid={1}".format(int(did), int(chat_id)))
            Bundle = jclass("android.os.Bundle")
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            args = Bundle()
            args.putLong("chat_id", int(chat_id))
            preview_fragment = ChatActivity(args)
            try:
                allow_field = preview_fragment.getClass().getDeclaredField("allowExpandPreviewByClick")
                allow_field.setAccessible(True)
                allow_field.setBoolean(preview_fragment, False)
            except Exception:
                pass
            self._dialog_hide(pd)
            self._dialog_dismiss(pd)
            self._dismiss_current_dialog(frag)
            menu = self._build_preview_menu_simple(
                frag,
                on_close=lambda: (
                    self._dialog_show(pd),
                    self._set_chat_blur(frag, True if pd is not None else False),
                ),
                on_expand=lambda: self._set_chat_blur(frag, False),
                enable_quick_reply=True,
                quick_reply_dialog_id=int(did),
            )
            if menu is None:
                self._dialog_show(pd)
                return False
            try:
                frag.presentFragmentAsPreviewWithMenu(preview_fragment, menu)
            except Exception:
                AndroidUtilities.runOnUIThread(lambda: frag.presentFragmentAsPreviewWithMenu(preview_fragment, menu), 50)
            self._set_chat_blur(frag, True)
            return True
        except Exception as e:
            self._dlog("present_chat_preview failed: {0}".format(e))
            try:
                self._dialog_show(panel_dialog)
            except Exception:
                pass
            return False

    def _build_preview_menu_simple(self, fragment, on_close=None, on_expand=None, enable_quick_reply=False, quick_reply_dialog_id=0):
        try:
            ActionBarPopupLayout = jclass("org.telegram.ui.ActionBar.ActionBarPopupWindow$ActionBarPopupWindowLayout")
            ActionBarMenuSubItem = jclass("org.telegram.ui.ActionBar.ActionBarMenuSubItem")
            R_drawable = jclass("org.telegram.messenger.R$drawable")
            ctx = None
            try:
                ctx = fragment.getContext()
            except Exception:
                pass
            if ctx is None:
                try:
                    ctx = fragment.getParentActivity()
                except Exception:
                    ctx = None
            if ctx is None:
                return None
            flags = int(getattr(ActionBarPopupLayout, "FLAG_SHOWN_FROM_BOTTOM", 0) or 0)
            rp = None
            try:
                if hasattr(fragment, "getResourceProvider"):
                    rp = fragment.getResourceProvider()
            except Exception:
                rp = None
            menu = ActionBarPopupLayout(ctx, int(R_drawable.popup_fixed_alert4), rp, flags)
            open_item = ActionBarMenuSubItem(ctx, False, False)
            open_item.setTextAndIcon("Open chat", int(R_drawable.msg_discussion))
            open_item.setMinimumWidth(160)
            open_item.setOnClickListener(OnClickListener(lambda _v: self._expand_preview(fragment, on_expand)))
            menu.addView(open_item)
            if bool(enable_quick_reply):
                reply_item = ActionBarMenuSubItem(ctx, False, False)
                kb_icon = int(getattr(R_drawable, "input_keyboard", 0) or 0)
                if kb_icon <= 0:
                    kb_icon = int(getattr(R_drawable, "msg_edit", 0) or 0)
                reply_item.setTextAndIcon(self._tr("peek_preview_go_chat"), kb_icon)
                reply_item.setMinimumWidth(160)
                reply_item.setOnClickListener(OnClickListener(lambda _v: self._open_peek_floating_reply_input(int(quick_reply_dialog_id or 0))))
                menu.addView(reply_item)
            close_item = ActionBarMenuSubItem(ctx, False, False)
            close_item.setTextAndIcon("Close preview", int(R_drawable.msg_clear))
            close_item.setMinimumWidth(160)
            close_item.setOnClickListener(OnClickListener(lambda _v: self._close_preview(fragment, on_close)))
            menu.addView(close_item)
            return menu
        except Exception:
            return None

    def _expand_preview(self, fragment, cb=None):
        try:
            parent_layout = None
            try:
                pf = fragment.getClass().getSuperclass().getDeclaredField("parentLayout")
                pf.setAccessible(True)
                parent_layout = pf.get(fragment)
            except Exception:
                parent_layout = None
            if parent_layout is not None:
                parent_layout.expandPreviewFragment()
            if callable(cb):
                cb()
        except Exception:
            pass

    def _close_preview(self, fragment, cb=None):
        try:
            fragment.finishPreviewFragment()
            if callable(cb):
                cb()
        except Exception:
            pass

    def _open_peek_floating_reply_input(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                BulletinHelper.show_info(self._tr("peek_reply_unavailable"))
                return
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                BulletinHelper.show_info(self._tr("peek_reply_unavailable"))
                return
            from org.telegram.ui.Components import EditTextBoldCursor
            from android.widget import LinearLayout
            from android.text import InputType
            from android.util import TypedValue

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(6), AndroidUtilities.dp(20), AndroidUtilities.dp(8))

            inp = EditTextBoldCursor(ctx)
            inp.setHint(self._tr("peek_reply_hint"))
            inp.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_MULTI_LINE)
            inp.setSingleLine(False)
            inp.setMinLines(3)
            inp.setMaxLines(6)
            inp.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            self._style_dialog_input(inp, multiline=True)
            try:
                inp.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(11), AndroidUtilities.dp(14), AndroidUtilities.dp(11))
            except Exception:
                pass
            root.addView(inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("peek_reply_title"))
            b.set_view(root)

            def _send(d, _w):
                try:
                    out = str(inp.getText().toString() if inp.getText() is not None else "").strip()
                    if not out:
                        BulletinHelper.show_info(self._tr("message_empty"))
                        return
                    ok = self._send_warning_message(int(did), out, reply_to=None)
                    if ok:
                        BulletinHelper.show_success(self._tr("peek_reply_sent"))
                        if d:
                            d.dismiss()
                    else:
                        BulletinHelper.show_info(self._tr("peek_reply_failed"))
                except Exception:
                    BulletinHelper.show_info(self._tr("peek_reply_failed"))

            b.set_positive_button(self._tr("send"), _send)
            b.set_negative_button(self._tr("cancel"), lambda d, w: d.dismiss() if d else None)
            b.show()
        except Exception:
            BulletinHelper.show_info(self._tr("peek_reply_unavailable"))

    def _message_text(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            tx = str(getattr(mo, "message", "") or "").strip()
            if tx:
                return tx
        except Exception:
            pass
        try:
            tx = str(getattr(msg_obj, "message", "") or "").strip()
            if tx:
                return tx
        except Exception:
            pass
        try:
            tx = str(msg_obj.getMessageText() or "").strip()
            if tx:
                return tx
        except Exception:
            pass
        try:
            tx = str(getattr(msg_obj, "messageText", "") or "").strip()
            if tx:
                return tx
        except Exception:
            pass
        return ""

    def _is_outgoing(self, msg_obj):
        try:
            mo = getattr(msg_obj, "messageOwner", None)
            return bool(getattr(mo, "out", False))
        except Exception:
            pass
        try:
            return bool(getattr(msg_obj, "out", False))
        except Exception:
            pass
        try:
            return bool(msg_obj.isOut())
        except Exception:
            return False

    def _msg_sender_username(self, msg_obj):
        try:
            sid = int(self._uid_from_cell_message(msg_obj) or 0)
            if sid <= 0:
                return ""
            u = get_messages_controller().getUser(int(sid))
            return str(getattr(u, "username", "") or "").strip().lower() if u is not None else ""
        except Exception:
            return ""

    def _is_rose_msg(self, msg_obj):
        try:
            un = self._msg_sender_username(msg_obj)
            if un == "missrose_bot":
                return True
            sid = int(self._uid_from_cell_message(msg_obj) or 0)
            if sid > 0:
                u = get_messages_controller().getUser(int(sid))
                if u is not None:
                    uname = str(getattr(u, "username", "") or "").strip().lower()
                    if uname == "missrose_bot":
                        return True
                    first = str(getattr(u, "first_name", "") or "").strip().lower()
                    is_bot = bool(getattr(u, "bot", False))
                    if is_bot and "rose" in first:
                        return True
            return False
        except Exception:
            return False

    def _iter_dialog_messages(self, dialog_id, limit=350):
        out = []
        try:
            chat = self._chat(int(dialog_id))
            arr = self._gf(chat, "messages", None) if chat is not None else None
            if arr is None:
                return out
            sz = int(arr.size())
            start = max(0, sz - int(limit or 0))
            for i in range(start, sz):
                try:
                    mo = arr.get(i)
                    if mo is not None:
                        out.append(mo)
                except Exception:
                    pass
        except Exception:
            pass
        return out

    def _text_refs_user(self, text, uid, uname, name):
        t = str(text or "").lower()
        if not t:
            return False
        u = str(uname or "").strip().lower()
        n = str(name or "").strip().lower()
        if u and ("@" + u) in t:
            return True
        if str(int(uid)) in t:
            return True
        if n and n in t:
            return True
        return False

    def _extract_uid_from_text(self, text):
        try:
            tx = str(text or "")
            if not tx:
                return 0
            m = re.search(r"(?im)^\s*id\s*:\s*(\d{5,})\b", tx)
            if m:
                return int(m.group(1))
            m = re.search(r"(?i)\b(?:!|/)?(?:info|fedstat)\s+(\d{5,})\b", tx)
            if m:
                return int(m.group(1))
            return 0
        except Exception:
            return 0

    def _rose_msg_matches_request(self, text, req):
        try:
            tx = str(text or "").lower()
            if not tx:
                return False
            uid = int(req.get("uid", 0) or 0)
            kind = str(req.get("kind", "") or "").strip().lower()
            if uid <= 0:
                return False
            uid_s = str(uid)
            if kind == "info":
                if ("info " + uid_s) in tx or ("!info " + uid_s) in tx:
                    return True
                if ("id: " + uid_s) in tx or ("id:" + uid_s) in tx:
                    return True
                if "user info" in tx and uid_s in tx:
                    return True
                return False
            if kind == "fed":
                if ("fedstat " + uid_s) in tx or ("!fedstat " + uid_s) in tx:
                    return True
                if uid_s in tx and ("fban" in tx or "fed" in tx or "federat" in tx):
                    return True
                return False
            return self._text_refs_user(tx, uid, self._user_username(uid), self._user_name(uid))
        except Exception:
            return False

    def _extract_warn_count_from_rose_text(self, text):
        t = str(text or "")
        if not t:
            return None
        patterns = [
            r"(?i)\b(\d+)\s*warn(?:ing)?s?\b",
            r"(?i)\bwarn(?:ing)?s?\s*[:=]\s*(\d+)\b",
            r"(?i)\bhas\s+(\d+)\s+warn(?:ing)?s?\b",
        ]
        for p in patterns:
            m = re.search(p, t)
            if m:
                try:
                    return max(0, int(m.group(1)))
                except Exception:
                    pass
        return None

    def _get_warn_count_from_rose(self, dialog_id, uid):
        try:
            uname = self._user_username(uid)
            name = self._user_name(uid)
            found = None
            for msg_obj in reversed(self._iter_dialog_messages(dialog_id, limit=400)):
                if not self._is_rose_msg(msg_obj):
                    continue
                tx = self._message_text(msg_obj)
                if not tx or not self._text_refs_user(tx, uid, uname, name):
                    continue
                val = self._extract_warn_count_from_rose_text(tx)
                if val is not None:
                    found = int(val)
                    break
            return found
        except Exception:
            return None

    def _sync_warn_count(self, dialog_id, uid, fallback_delta=0, fallback_set=None):
        rose_count = self._get_warn_count_from_rose(dialog_id, uid)
        if rose_count is not None:
            self._set_warn_count(uid, rose_count)
            return int(rose_count)
        if fallback_set is not None:
            self._set_warn_count(uid, int(fallback_set))
            return int(max(0, int(fallback_set)))
        if int(fallback_delta or 0) != 0:
            self._inc_warn(uid, int(fallback_delta))
        return self._warn_count(uid)

    def _push_rose_history(self, uid, entry):
        try:
            k = str(int(uid))
            arr = self._rose_history.get(k, [])
            if not isinstance(arr, list):
                arr = []
            mid = int(entry.get("mid", 0) or 0)
            txt = str(entry.get("text", "") or "").strip().lower()
            if mid and any(int(x.get("mid", 0) or 0) == mid for x in arr if isinstance(x, dict)):
                return
            if txt and any(str(x.get("text", "") or "").strip().lower() == txt for x in arr[-15:] if isinstance(x, dict)):
                return
            arr.append(entry)
            if len(arr) > 120:
                arr = arr[-120:]
            self._rose_history[k] = arr
            self._save_rose_history()
        except Exception:
            pass

    def _remove_local_message_obj(self, chat_activity, msg_obj):
        try:
            if chat_activity is None or msg_obj is None:
                return
            m = chat_activity.getClass().getDeclaredMethod("removeMessageObject", MessageObject)
            m.setAccessible(True)
            m.invoke(chat_activity, msg_obj)
        except Exception:
            pass

    def _delete_message_ids_server(self, dialog_id, mids, revoke=True):
        try:
            ids = [int(x) for x in (mids or []) if int(x or 0) > 0]
            if not ids:
                return False
            mc = get_messages_controller()
            if mc is None:
                return False
            ok = {"v": False}

            def _do_delete():
                try:
                    jids = ArrayList()
                    for mid in ids:
                        try:
                            jids.add(jint(mid))
                        except Exception:
                            pass
                    if jids.isEmpty():
                        return
                    mc.deleteMessages(jids, None, None, dialog_id, 0, bool(revoke), 0)
                    ok["v"] = True
                except Exception:
                    pass

            run_on_ui_thread(_do_delete)
            try:
                run_on_queue(_do_delete)
            except Exception:
                pass
            if not bool(ok["v"]):
                return False
            return True
        except Exception:
            return False

    def _make_pending_key(self, dialog_id, uid, kind):
        return "{0}:{1}:{2}".format(int(dialog_id), int(uid), str(kind or "").strip().lower())

    def _set_pending_request(self, dialog_id, uid, kind, cmd_text=""):
        try:
            key = self._make_pending_key(dialog_id, uid, kind)
            self._rose_pending[key] = {
                "ts": int(time.time()),
                "dialog_id": int(dialog_id),
                "uid": int(uid),
                "kind": str(kind),
                "cmd_text": str(cmd_text or "").strip(),
            }
        except Exception:
            pass

    def _queue_ephemeral_delete(self, dialog_id, text, delay_ms=5000):
        try:
            did = int(dialog_id or 0)
            tx = str(text or "").strip()
            if did == 0 or not tx:
                return
            self._pending_ephemeral.append({
                "did": did,
                "text": tx,
                "text_low": tx.lower(),
                "delay_ms": int(delay_ms or 5000),
                "ts": int(time.time()),
            })
            if len(self._pending_ephemeral) > 120:
                self._pending_ephemeral = self._pending_ephemeral[-120:]
        except Exception:
            pass

    def _maybe_handle_ephemeral_message(self, chat_activity, msg_obj):
        try:
            if msg_obj is None:
                return
            tx = self._message_text(msg_obj).strip()
            if not tx:
                return
            tx_low = tx.lower()
            did = 0
            try:
                did = int(msg_obj.getDialogId() or 0)
            except Exception:
                did = 0
            mid = int(self._msg_id(msg_obj) or 0)
            if did == 0 or mid <= 0:
                return
            now = int(time.time())
            matched = None
            kept = []
            for it in list(self._pending_ephemeral or []):
                try:
                    if int(now - int(it.get("ts", 0) or 0)) > 90:
                        continue
                    if int(it.get("did", 0) or 0) == int(did) and matched is None:
                        want = str(it.get("text", "") or "").strip()
                        want_low = str(it.get("text_low", "") or "").strip().lower()
                        if tx == want or tx_low == want_low or (
                            "connected" in tx_low and "connected" in want_low
                        ):
                            matched = it
                            continue
                    kept.append(it)
                except Exception:
                    pass
            self._pending_ephemeral = kept
            if not isinstance(matched, dict):
                return
            delay_ms = int(matched.get("delay_ms", 5000) or 5000)

            def _del_later():
                try:
                    self._delete_message_ids_server(int(did), [int(mid)], revoke=True)
                    self._remove_local_message_obj(chat_activity, msg_obj)
                except Exception:
                    pass

            try:
                AndroidUtilities.runOnUIThread(_del_later, int(delay_ms))
            except Exception:
                _del_later()
        except Exception:
            pass

    def _cleanup_local_own_commands(self, dialog_id, cmd_texts):
        try:
            if not cmd_texts:
                return
            chat = self._chat(int(dialog_id))
            if chat is None:
                return
            uc = get_user_config()
            my_uid = int(uc.getClientUserId()) if uc is not None else 0
            if my_uid <= 0:
                return
            wanted = set(str(x or "").strip().lower() for x in cmd_texts if str(x or "").strip())
            if not wanted:
                return
            for mo in reversed(self._iter_dialog_messages(dialog_id, limit=120)):
                try:
                    sid = int(self._uid_from_cell_message(mo) or 0)
                    if sid != my_uid:
                        continue
                    tx = self._message_text(mo).strip().lower()
                    tx_no_bang = tx[1:].strip() if tx.startswith("!") else tx
                    if tx in wanted or tx_no_bang in wanted:
                        self._remove_local_message_obj(chat, mo)
                except Exception:
                    pass
        except Exception:
            pass

    def _delete_own_info_fed_commands(self, dialog_id, uid):
        try:
            did = int(dialog_id or 0)
            tuid = int(uid or 0)
            if did == 0 or tuid <= 0:
                return
            chat = self._chat(did)
            uc = get_user_config()
            my_uid = int(uc.getClientUserId()) if uc is not None else 0
            if my_uid <= 0:
                return
            uid_s = str(tuid)
            for mo in reversed(self._iter_dialog_messages(did, limit=120)):
                try:
                    sid = int(self._uid_from_cell_message(mo) or 0)
                    if sid != my_uid:
                        continue
                    mid = int(self._msg_id(mo) or 0)
                    if mid <= 0:
                        continue
                    tx = self._message_text(mo).strip().lower()
                    tx_nb = tx[1:].strip() if tx.startswith("!") else tx
                    is_info_cmd = tx_nb.startswith("info ") and uid_s in tx_nb
                    is_fed_cmd = tx_nb.startswith("fedstat ") and uid_s in tx_nb
                    if not (is_info_cmd or is_fed_cmd):
                        continue
                    self._delete_message_ids_server(did, [mid], revoke=True)
                    if chat is not None:
                        self._remove_local_message_obj(chat, mo)
                except Exception:
                    pass
        except Exception:
            pass

    def _consume_pending_matches(self, dialog_id, msg_obj):
        matched = []
        try:
            now = int(time.time())
            tx = self._message_text(msg_obj)
            if not tx:
                return matched
            extracted_uid = int(self._extract_uid_from_text(tx) or 0)
            for k, req in list(self._rose_pending.items()):
                if not isinstance(req, dict):
                    continue
                if int(req.get("dialog_id", 0) or 0) != int(dialog_id):
                    continue
                if int(now - int(req.get("ts", 0) or 0)) > 180:
                    self._rose_pending.pop(k, None)
                    continue
                uid = int(req.get("uid", 0) or 0)
                if uid <= 0:
                    continue
                ok = self._rose_msg_matches_request(tx, req)
                if (not ok) and extracted_uid > 0 and extracted_uid == uid:
                    ok = True
                if not ok:
                    continue
                matched.append(req)
                self._rose_pending.pop(k, None)
        except Exception:
            pass
        return matched

    def _on_chat_new_messages(self, chat_activity, arr):
        try:
            if chat_activity is None or arr is None:
                return
            did = 0
            try:
                if hasattr(chat_activity, "getDialogId"):
                    did = int(chat_activity.getDialogId() or 0)
            except Exception:
                did = 0
            if did == 0:
                return
            try:
                self._mentions_hub_process_messages(did, arr)
            except Exception:
                pass
            uc = get_user_config()
            my_uid = int(uc.getClientUserId()) if uc is not None else 0
            try:
                cnt = int(arr.size())
            except Exception:
                cnt = 0
            for i in range(cnt):
                try:
                    mo = arr.get(i)
                except Exception:
                    mo = None
                if mo is None:
                    continue

                try:
                    sid = int(self._uid_from_cell_message(mo) or 0)
                    is_own = bool((my_uid > 0 and sid == my_uid) or self._is_outgoing(mo))
                    if is_own:
                        self._maybe_handle_ephemeral_message(chat_activity, mo)
                        tx_own = self._message_text(mo).strip().lower()
                        tx_nb = tx_own[1:].strip() if tx_own.startswith("!") else tx_own
                        first_tok = tx_nb.split(" ", 1)[0] if tx_nb else ""
                        if tx_own.startswith("!") and first_tok != "tag":
                            mid_own = int(self._msg_id(mo) or 0)
                            own_did = 0
                            try:
                                own_did = int(mo.getDialogId() or 0)
                            except Exception:
                                own_did = int(did)
                            if mid_own > 0:
                                self._delete_message_ids_server(int(own_did or did), [mid_own], revoke=True)
                                self._remove_local_message_obj(chat_activity, mo)
                            continue
                except Exception:
                    pass

                if not self._is_rose_msg(mo):
                    continue
                tx = self._message_text(mo)
                if not tx:
                    continue
                try:
                    if self._is_admin_connect_pending(did):
                        c_url = str(self._extract_connect_url_from_rose_msg(mo) or "").strip()
                        if c_url:
                            self._dlog("admin_tab: connect auto-open url={0}".format(c_url))
                            self.open_url(c_url)
                            BulletinHelper.show_success(self._tr("admin_tab_connect_opened"))
                            self._clear_admin_connect_pending()
                except Exception as e:
                    self._dlog("admin_tab: connect auto-open fail: {0}".format(e))
                for req in self._consume_pending_matches(did, mo):
                    uid = int(req.get("uid", 0) or 0)
                    self._push_rose_history(uid, {
                        "mid": int(self._msg_id(mo) or 0),
                        "date": int(self._msg_date(mo) or int(time.time())),
                        "text": str(tx),
                    })
                    c = self._extract_warn_count_from_rose_text(tx)
                    if c is not None:
                        self._set_warn_count(uid, c)
                    if self._auto_delete_rose_info() and str(req.get("kind", "")).lower() in ("info", "fed"):
                        rose_mid = int(self._msg_id(mo) or 0)
                        rose_did = 0
                        try:
                            rose_did = int(mo.getDialogId() or 0)
                        except Exception:
                            rose_did = int(did)
                        self._delete_message_ids_server(int(rose_did or did), [rose_mid], revoke=True)
                        self._remove_local_message_obj(chat_activity, mo)
                        self._delete_own_info_fed_commands(int(rose_did or did), uid)
                        cmd = str(req.get("cmd_text", "") or "").strip()
                        cleanup = [cmd] if cmd else []
                        self._cleanup_local_own_commands(int(rose_did or did), cleanup)
        except Exception:
            pass

    def _scan_rose_history_for_user(self, dialog_id, uid):
        try:
            uname = self._user_username(uid)
            name = self._user_name(uid)
            for msg_obj in self._iter_dialog_messages(dialog_id, limit=450):
                if not self._is_rose_msg(msg_obj):
                    continue
                tx = self._message_text(msg_obj)
                if not tx or not self._text_refs_user(tx, uid, uname, name):
                    continue
                low = tx.lower()
                if not any(k in low for k in ("warn", "unwarn", "ban", "fban", "kick", "mute", "info", "reset")):
                    continue
                self._push_rose_history(uid, {
                    "mid": int(self._msg_id(msg_obj) or 0),
                    "date": int(self._msg_date(msg_obj) or int(time.time())),
                    "text": str(tx),
                })
        except Exception:
            pass

    def _open_user_history_sheet(self, ctx, dialog_id, uid):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="panel_user_history", count=1, force_flush=False)
            except Exception:
                pass
            self._scan_rose_history_for_user(dialog_id, uid)
            from org.telegram.ui.ActionBar import BottomSheet
            from android.widget import LinearLayout, TextView
            from android.util import TypedValue
            from android.graphics import Color
            from android.graphics.drawable import GradientDrawable

            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_bg = self._theme_color("key_dialogBackground", 0xFF223043)
            dark_ui = self._is_dark_color(c_bg)
            c_item_bg = Color.parseColor("#2B3D53") if dark_ui else Color.parseColor("#EEF4FB")
            c_item_stroke = Color.parseColor("#4F6C8A") if dark_ui else Color.parseColor("#B6CBE2")
            c_item_text = Color.parseColor("#D8E5F4") if dark_ui else Color.parseColor("#233447")

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))

            title = TextView(ctx)
            title.setText(self._tr("user_history"))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            title.setTextColor(c_title)
            root.addView(title)

            k = str(int(uid))
            items = self._rose_history.get(k, [])
            if not isinstance(items, list):
                items = []
            items = items[-30:]
            if not items:
                empty = TextView(ctx)
                empty.setText(self._tr("no_rose_history"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                empty.setTextColor(c_sub)
                lp_e = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_e.topMargin = AndroidUtilities.dp(10)
                root.addView(empty, lp_e)
            else:
                for it in reversed(items):
                    if not isinstance(it, dict):
                        continue
                    tx = str(it.get("text", "") or "").strip()
                    if not tx:
                        continue
                    row = TextView(ctx)
                    row.setText(tx)
                    row.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    row.setTextColor(c_item_text)
                    row.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8))
                    try:
                        bg = GradientDrawable()
                        bg.setCornerRadius(AndroidUtilities.dp(8))
                        bg.setColor(c_item_bg)
                        bg.setStroke(AndroidUtilities.dp(1), c_item_stroke)
                        row.setBackground(bg)
                    except Exception:
                        pass
                    lp_r = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_r.topMargin = AndroidUtilities.dp(8)
                    root.addView(row, lp_r)

            sheet = BottomSheet(ctx, True)
            sheet.setCustomView(root)
            sheet.show()
        except Exception:
            BulletinHelper.show_info(self._tr("failed_open_history"))

    def _open_advanced_dialog(self, dialog_id, uid, on_back=None):
        try:
            try:
                self._telemetry_queue_event("feature_use", feature="panel_advanced_open", count=1, force_flush=False)
            except Exception:
                pass
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            from android.widget import LinearLayout, TextView
            from android.util import TypedValue
            from android.graphics import Color
            from android.graphics.drawable import GradientDrawable
            from android.view import Gravity
            from org.telegram.ui.ActionBar import BottomSheet

            c_title = self._theme_color("key_dialogTextBlack", 0xFFF2F5FA)
            c_sub = self._theme_color("key_dialogTextHint", 0xFFA6B0BE)
            c_link = self._theme_color("key_dialogTextLink", 0xFF71B7FF)
            c_bg = self._theme_color("key_dialogBackground", 0xFF223043)
            dark_ui = self._is_dark_color(c_bg)
            c_item_text = Color.parseColor("#D8E5F4") if dark_ui else Color.parseColor("#233447")
            c_card_bg = Color.parseColor("#2B3D53") if dark_ui else Color.parseColor("#EEF4FB")
            c_card_stroke = Color.parseColor("#4F6C8A") if dark_ui else Color.parseColor("#B6CBE2")
            c_danger_bg = Color.parseColor("#5A2A2A") if dark_ui else Color.parseColor("#FDECEC")
            c_danger_stroke = Color.parseColor("#E53935") if dark_ui else Color.parseColor("#D43C3C")
            c_danger_text = Color.parseColor("#FFE9E8") if dark_ui else Color.parseColor("#962626")

            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("advanced"))
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(8), AndroidUtilities.dp(18), AndroidUtilities.dp(8))
            sub = TextView(ctx)
            sub.setText(self._tr("advanced_tools_sub", "Manage local moderation analytics and maintenance actions."))
            sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            sub.setTextColor(c_sub)
            lp_sub = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_sub.bottomMargin = AndroidUtilities.dp(10)
            root.addView(sub, lp_sub)

            def _open_stats_sheet(_v=None):
                try:
                    sh_root = LinearLayout(ctx)
                    sh_root.setOrientation(LinearLayout.VERTICAL)
                    sh_root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
                    ttl = TextView(ctx)
                    ttl.setText(self._tr("active_users_stats"))
                    ttl.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
                    ttl.setTextColor(c_title)
                    sh_root.addView(ttl)
                    lines = []
                    for k, rec in self._admin_stats.items():
                        if not isinstance(rec, dict):
                            continue
                        nm = str(rec.get("name", k) or k)
                        un = str(rec.get("username", "") or "").strip()
                        base = "{0} ({1})".format(nm, ("@" + un) if un else k)
                        vals = []
                        for key in ("tag", "warn", "mute", "ban", "kick", "spam"):
                            c = int(rec.get(key, 0) or 0)
                            if c > 0:
                                vals.append("{0}:{1}".format(key, c))
                        if vals:
                            lines.append(base + " | " + ", ".join(vals))
                    if not lines:
                        em = TextView(ctx)
