                    t1.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                    t1.setTextColor(c_title)
                    sh_root.addView(t1)
                    t2 = _TV(ctx)
                    t2.setText(self._tr("tag_details_sub"))
                    t2.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    t2.setTextColor(c_sub)
                    lp_t2 = _LL.LayoutParams(_LL.LayoutParams.MATCH_PARENT, _LL.LayoutParams.WRAP_CONTENT)
                    lp_t2.topMargin = AndroidUtilities.dp(6)
                    sh_root.addView(t2, lp_t2)
                    sh = BottomSheet(ctx, True)
                    sh.setCustomView(sh_root)
                    sh.show()
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_open_details"))

            details_btn.setOnClickListener(OnClickListener(_open_tag_details))

            def _do_remove_tag(_v=None):
                try:
                    ok = self._tag_del(uid)
                    if ok:
                        inp_name.setText("")
                        inp_tag.setText("")
                        BulletinHelper.show_success(self._tr("tag_removed"))
                        if self._is_admin_mode():
                            self._rerender_vanguard_beacon_panel(cell, nonce)
                    else:
                        BulletinHelper.show_info(self._tr("no_tag_remove"))
                except Exception:
                    BulletinHelper.show_info(self._tr("failed_remove_tag"))

