def _pf(obj, name, default=None):
    try:
        cls = obj.getClass()
        while cls is not None:
            try:
                f = cls.getDeclaredField(name)
                f.setAccessible(True)
                return f.get(obj)
            except Exception:
                cls = cls.getSuperclass()
    except Exception:
        pass
    return default


def _is_last(cell):
    try:
        pos = _pf(cell, "currentPosition", None)
        return True if pos is None else bool(getattr(pos, "last"))
    except Exception:
        return True


class _BeaconTapHook(MethodHook):
    def __init__(self, p):
        super().__init__()
        self.p = p

    def before_hooked_method(self, param):
        try:
            self.p._handle_vanguard_beacon_tap(param.args[0] if param.args else None, param.args[1] if len(param.args) > 1 else None, param)
        except Exception:
            pass


class _AvatarLongHook(MethodHook):
    def __init__(self, p):
        super().__init__()
        self.p = p

    def before_hooked_method(self, param):
        try:
            user = param.args[1] if len(param.args) > 1 else None
            uid = int(getattr(user, "id", 0) or 0)
            if uid > 0 and self.p._open_from_long(uid):
                param.setResult(True)
        except Exception:
            pass


class _CellLongPressHook(MethodHook):
    def __init__(self, p):
        super().__init__()
        self.p = p

    def before_hooked_method(self, param):
        try:
            cell = param.args[0] if len(param.args) > 0 else None
            x = float(param.args[1]) if len(param.args) > 1 else 0.0
            y = float(param.args[2]) if len(param.args) > 2 else 0.0
            if self.p._on_cell_long_press(cell, x, y):
                param.setResult(None)
        except Exception:
            pass


class _CreateMenuHook(MethodHook):
    def __init__(self, p):
        super().__init__()
        self.p = p

    def before_hooked_method(self, param):
        try:
            v = param.args[0] if len(param.args) > 0 else None
            x = float(param.args[3]) if len(param.args) > 3 else 0.0
            y = float(param.args[4]) if len(param.args) > 4 else 0.0
            if self.p._intercept_context_menu(v, x, y):
                param.setResult(False)
        except Exception:
            pass


