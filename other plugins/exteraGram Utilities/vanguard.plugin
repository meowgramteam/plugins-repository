    def _current_ui_lang(self):
        try:
            pidx = int(self.get_setting("vanguard_plugin_lang", 0) or 0)
            if pidx < 0 or pidx >= len(PLUGIN_LANG_OPTIONS):
                pidx = 0
            forced = str(PLUGIN_LANG_OPTIONS[pidx][1] or "system")
            if forced != "system":
                return forced
        except Exception:
            pass
        try:
            lc = jclass("org.telegram.messenger.LocaleController").getInstance()
            code = ""
            try:
                info = lc.getCurrentLocaleInfo()
                if info is not None:
                    code = str(getattr(info, "pluralLangCode", "") or "").strip().lower()
            except Exception:
                code = ""
            if not code:
                try:
                    cur = lc.getCurrentLocale()
                    code = str(cur.getLanguage() if cur is not None else "").strip().lower()
                except Exception:
                    code = ""
            if not code:
                try:
                    Locale = jclass("java.util.Locale")
                    code = str(Locale.getDefault().getLanguage() or "").strip().lower()
                except Exception:
                    code = ""
            if code.startswith("ru"):
                self._lang_code_cache = "ru"
            elif code.startswith("pt"):
                self._lang_code_cache = "pt"
            else:
                self._lang_code_cache = "en"
            return self._lang_code_cache
        except Exception:
            return "en"

    def _lang_code(self):
        return self._current_ui_lang()

    def _looks_broken_text(self, value):
        try:
            s = str(value or "")
            marks = ("\u00c3", "\u00c2", "\u00f0\u0178", "\u00d0", "\u00d1", "\u00e2\u20ac")
            return any(m in s for m in marks)
        except Exception:
            return False

    def _is_broken_translation_value(self, value):
        try:
            s = str(value or "")
            if not s:
                return False
            if "???" in s:
                return True
            if "\ufffd" in s:
                return True
            if len(s) >= 8:
                q = s.count("?")
                if q >= 4 and (float(q) / float(len(s))) > 0.22:
                    return True
            return False
        except Exception:
            return False

    def _try_fix_mojibake(self, value):
        try:
            s = str(value or "")
            cur = s
            for _ in range(3):
                try:
                    nxt = cur.encode("latin1").decode("utf-8")
                except Exception:
                    break
                if nxt == cur:
                    break
                cur = nxt
            return cur
        except Exception:
            return str(value or "")

    def _tr(self, key, default=None):
        try:
            if not TRANSLATIONS:
                try:
                    self._load_translations_from_plugin_file()
                except Exception:
                    pass
                try:
                    self._load_translations_local()
                except Exception:
                    pass
            lang = self._lang_code()
            base = TRANSLATIONS.get("en", {})
            cur = TRANSLATIONS.get(lang, {})
            if key in cur:
                val = str(cur.get(key))
                if self._looks_broken_text(val):
                    fixed = self._try_fix_mojibake(val)
                    if not self._looks_broken_text(fixed) and fixed:
                        return fixed
                    if key in base:
                        return str(base.get(key))
                return val
            if key in base:
                return str(base.get(key))
            return str(default if default is not None else key)
        except Exception:
            return str(default if default is not None else key)

    def _merge_translations(self, data):
        global TRANSLATIONS
        try:
            if not isinstance(data, dict):
                return False
            en = data.get("en", {})
            if not isinstance(en, dict) or not en:
                return False
            out = {}
            try:
                if isinstance(TRANSLATIONS, dict):
                    for lang, tbl in TRANSLATIONS.items():
                        if isinstance(tbl, dict):
                            out[str(lang)] = dict(tbl)
            except Exception:
                out = {}
            for lang, tbl in data.items():
                if isinstance(tbl, dict):
                    key = str(lang)
                    cur = out.get(key, {})
                    if not isinstance(cur, dict):
                        cur = {}
                    for k, v in tbl.items():
                        try:
                            new_v = str(v)
                            old_v = str(cur.get(k, ""))
                            if self._is_broken_translation_value(new_v) and old_v and (not self._is_broken_translation_value(old_v)):
                                continue
                            cur[k] = v
                        except Exception:
                            cur[k] = v
                    out[key] = cur
            if "en" not in out:
                return False
            TRANSLATIONS = out
            return True
        except Exception:
            return False

    def _apply_translation_patch(self):
        try:
            self._merge_translations(TRANSLATIONS_PATCH)
        except Exception:
            pass
        try:
            self._merge_translations(MENTIONS_HUB_PATCH)
        except Exception:
            pass

    def _load_translations_from_plugin_file(self):
        try:
            base = os.path.dirname(os.path.abspath(__file__))
            p = os.path.join(base, TRANSLATIONS_PLUGIN_FILE)
            if not os.path.exists(p):
                p = os.path.join(os.getcwd(), TRANSLATIONS_PLUGIN_FILE)
            if not os.path.exists(p):
                return False
            with open(p, "r", encoding="utf-8-sig") as f:
                data = json.load(f)
            ok = self._merge_translations(data)
            self._apply_translation_patch()
            if ok:
                self._dlog("translations plugin file loaded")
            return ok
        except Exception as e:
            self._dlog("translations plugin file load fail: {0}".format(e))
            return False

    def _load_translations_local(self):
        try:
            os.makedirs(_CACHE_DIR, exist_ok=True)
            if not os.path.exists(TRANSLATIONS_CACHE_FILE):
                return False
            with open(TRANSLATIONS_CACHE_FILE, "r", encoding="utf-8") as f:
                data = json.load(f)
            ok = self._merge_translations(data)
            self._apply_translation_patch()
            if ok:
                self._dlog("translations local loaded")
            return ok
        except Exception as e:
            self._dlog("translations local load fail: {0}".format(e))
            return False

    def _load_translations_remote(self):
        try:
            os.makedirs(_CACHE_DIR, exist_ok=True)
            req = Request(
                TRANSLATIONS_URL,
                headers={
                    "User-Agent": "Vanguard/1.0",
                    "Cache-Control": "no-cache",
                    "Pragma": "no-cache",
                },
            )
            with urlopen(req, timeout=6) as resp:
                raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(raw)
            try:
                broken_hits = 0
                for lang in ("ru", "pt"):
                    tbl = data.get(lang, {}) if isinstance(data, dict) else {}
                    if not isinstance(tbl, dict):
                        continue
                    for _k, _v in tbl.items():
                        try:
                            if self._is_broken_translation_value(_v):
                                broken_hits += 1
                                if broken_hits >= 3:
                                    self._dlog("translations remote ignored (broken qmark payload)")
                                    return False
                        except Exception:
                            pass
            except Exception:
                pass
            try:
                cur_en = TRANSLATIONS.get("en", {}) if isinstance(TRANSLATIONS, dict) else {}
                rem_en = data.get("en", {}) if isinstance(data, dict) else {}
                if isinstance(cur_en, dict) and isinstance(rem_en, dict) and len(rem_en) < len(cur_en):
                    self._dlog("translations remote ignored (older keyset): {0} < {1}".format(len(rem_en), len(cur_en)))
                    return False
            except Exception:
                pass
            ok = self._merge_translations(data)
            self._apply_translation_patch()
            if ok:
                with open(TRANSLATIONS_CACHE_FILE, "w", encoding="utf-8") as f:
                    json.dump(data, f, ensure_ascii=False, indent=2)
                self._dlog("translations remote loaded")
            return ok
        except Exception as e:
            self._dlog("translations remote load fail: {0}".format(e))
            return False

    def _show_resources_loading_dialog(self, ctx):
        try:
            if ctx is None:
                return None
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("resources_loading_title"))
            b.set_message(self._tr("resources_loading_text"))
            return b.show()
        except Exception as e:
            self._dlog("resources loading dialog fail: {0}".format(e))
            return None

    def _download_resources_async(self, ctx=None, close_dialog=None, bulletin_key="resources_done_bulletin"):
        try:
            loading_dialog = self._show_resources_loading_dialog(ctx)
        except Exception:
            loading_dialog = None

        def _worker():
            ok = False
            try:
                try:
                    self._load_translations_from_plugin_file()
                except Exception:
                    pass
                self._load_translations_remote()
                try:
                    self._refresh_supporters_async()
                except Exception:
                    pass
                try:
                    self._ensure_settings_header_assets()
                except Exception:
                    pass
                try:
                    self._load_welcome_bg_remote()
                except Exception:
                    pass
                ok = True
            except Exception as e:
                self._dlog("download resources async fail: {0}".format(e))

            def _finish():
                try:
                    if loading_dialog is not None:
                        loading_dialog.dismiss()
                except Exception:
                    pass
                try:
                    if close_dialog is not None:
                        close_dialog.dismiss()
                except Exception:
                    pass
                try:
                    BulletinHelper.show_success(self._tr(bulletin_key) if ok else self._tr("resources_failed_bulletin"))
                except Exception:
                    pass

            try:
                run_on_ui_thread(_finish)
            except Exception:
                _finish()

        try:
            run_on_queue(_worker)
        except Exception:
            threading.Thread(target=_worker, daemon=True).start()

    def on_plugin_load(self):
        try:
            self._load_translations_from_plugin_file()
        except Exception:
            pass
        try:
            self._load_translations_local()
        except Exception:
            pass
        try:
            self._apply_translation_patch()
        except Exception:
            pass
        try:
            run_on_queue(lambda: self._load_translations_remote())
        except Exception:
            pass
        try:
            self._cache_notification_center_info()
        except Exception:
            pass
        self.add_on_send_message_hook()
        try:
            self.add_hook("TL_updateNewMessage")
            self.add_hook("TL_updateNewChannelMessage")
        except Exception:
            pass
        self._load_tags()
        self._load_user_aliases()
        self._load_warning_templates()
        self._load_federations()
        self._load_peek_groups()
        self._load_admin_custom_actions()
        self._load_reason_presets()
        self._load_shortcuts()
        self._load_mentions_hub()
        self._load_warn_counts()
        self._load_rose_history()
        self._load_admin_stats()
        self._load_telemetry_queue()
        try:
            self._chat_activity_cls = find_class("org.telegram.ui.ChatActivity")
        except Exception:
            self._chat_activity_cls = None
        self._hook_delegate()
        self._hook_context_menu()
        self._hook_draw()
        self._hook_cell_bind()
        self._hook_touch()
        self._hook_incoming_messages()
        self._hook_notification_center()
        self._setup_admin_tab_hooks()
        self._setup_settings_header_hook()
        self._add_menu_items()
        try:
            run_on_ui_thread(self._maybe_show_first_install_welcome)
        except Exception:
            pass
        self._dlog("plugin_load complete; logs_silent={0}".format(bool(self._logs_silent())))
        try:
            self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
        except Exception:
            pass
        try:
            if not bool(self.get_setting("tagged_stats_install_event_sent_v1", False)):
                self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                self.set_setting("tagged_stats_install_event_sent_v1", True)
        except Exception:
            pass
        if bool(getattr(self, "_live_log_enabled", False)):
            try:
                run_on_ui_thread(self._show_live_log)
            except Exception:
                pass
        if self._show_loaded_bulletin_enabled():
            run_on_ui_thread(lambda: BulletinHelper.show_success(self._tr("tagged_loaded")))

    def on_update_hook(self, update_name, account, update):
        try:
            name = str(update_name or "").strip()
            if name not in ("TL_updateNewMessage", "TL_updateNewChannelMessage"):
                return HookResult()
            msg = getattr(update, "message", None)
            if msg is None:
                return HookResult()
            try:
                mo = MessageObject(account, msg, False, True)
            except Exception as e:
                self._dlog("[MentionsHub] failed to build MessageObject from {0}: {1}".format(name, e))
                return HookResult()
            if mo is None:
                return HookResult()
            try:
                did = int(mo.getDialogId() or 0)
            except Exception:
                did = 0
            if did == 0:
                return HookResult()
            self._dlog("[MentionsHub] update {0} did={1} mid={2}".format(name, did, int(self._msg_id(mo) or 0)))
            self._mentions_hub_process_messages(did, [mo])
        except Exception as e:
            self._dlog("[MentionsHub] on_update_hook error: {0}".format(e))
        return HookResult()

    def create_settings(self):
        try:
            try:
                self._telemetry_track_opt_in_transition()
            except Exception:
                pass
            try:
                self._telemetry_queue_event("settings_open", feature="", count=1, force_flush=False)
            except Exception:
                pass
            items = []
            items.append(Divider(text=self._settings_home_welcome_text()))
            items.append(
                Selector(
                    key="tagged_user_mode_selector",
                    text=self._tr("settings_user_mode_title"),
                    default=0 if self._is_admin_mode() else 1,
                    items=[self._tr("mode_admin_label"), self._tr("mode_common_label")],
                    icon="msg_channel_hw_remix",
                    on_change=lambda idx=None: self._on_user_mode_selector_changed(idx),
                )
            )
            items.append(
                Text(
                    text=self._tr("settings_user_mode_know_more"),
                    icon="msg_info",
                    on_click=lambda v=None: self._open_user_mode_sheet(),
                )
            )
            try:
                _mode_idx = int(self.get_setting("tagged_user_mode_selector", 0) or 0)
                mode_now = "common" if _mode_idx == 1 else "admin"
            except Exception:
                mode_now = str(self._user_mode() or "admin").strip().lower()
            if mode_now != "common":
                items.append(
                    Selector(
                        key="tagged_quick_panel_mode",
                        text=self._tr("settings_quick_panel"),
                        default=0,
                        items=[self._tr("enabled"), self._tr("disabled")],
                        icon="chats_pin",
                    )
                )
            items.append(Divider())
            items.append(
                Text(
                    text="Vanguard Core",
                    icon="outline_shield_lock_24",
                    create_sub_fragment=self._create_action_settings_subfragment,
                    link_alias="vanguard_action_settings_subfragment",
                )
            )
            items.append(Divider())
            items.append(
                Selector(
                    key="vanguard_plugin_lang",
                    text=self._tr("settings_plugin_lang"),
                    items=[x[0] for x in PLUGIN_LANG_OPTIONS],
                    default=0,
                    icon="menu_feature_translate",
                    on_change=lambda _i=None: self._on_plugin_language_changed(),
                )
            )
            items.append(
                Text(
                    text=self._tr("settings_about"),
                    icon="msg2_reactions2",
                    on_click=self._on_about_click,
                )
            )
            return items
        except Exception as e:
            try:
                self._dlog("create_settings fallback: {0}".format(e))
            except Exception:
                pass
            return [
                Header(text=self._tr("settings_title")),
                Text(text=self._tr("settings_manage_templates"), icon="files_storage", on_click=lambda v=None: self._open_templates_manager()),
                Text(text=self._tr("settings_manage_federations"), icon="msg2_policy", on_click=lambda v=None: self._open_federations_manager()),
                Text(text=self._tr("settings_about"), icon="msg2_reactions2", on_click=self._on_about_click),
            ]

    def _settings_home_welcome_text(self):
        try:
            name = str(self._get_user_first_name() or "User").strip() or "User"
            key = "settings_home_welcome_fmt_admin" if self._is_admin_mode() else "settings_home_welcome_fmt_common"
            txt = self._tr(key)
            return str(txt).format(name=name)
        except Exception:
            key = "settings_home_welcome_fmt_admin" if self._is_admin_mode() else "settings_home_welcome_fmt_common"
            return str(self._tr(key)).format(name="User")

    def _create_supporters_subfragment(self, parent_view=None):
        try:
            return [Header(text=self._tr("supporters_title"))]
        except Exception:
            return [Header(text="Supporters")]

    def _start_supporter_card_anim(self, view, idx):
        try:
            from android.animation import ValueAnimator
            dist = float(AndroidUtilities.dp(4))
            anim = ValueAnimator.ofFloat(0.0, 1.0)
            anim.setDuration(int(1900 + (idx % 3) * 180 + (idx // 3) * 60))
            anim.setRepeatCount(-1)
            anim.setRepeatMode(ValueAnimator.REVERSE)
            try:
                anim.setStartDelay(int((idx % 3) * 110))
            except Exception:
                pass

            class _Upd(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                def onAnimationUpdate(self_obj, va):
                    try:
                        t = float(va.getAnimatedValue() or 0.0)
                        view.setTranslationY(float((0.5 - t) * dist))
                    except Exception:
                        pass

            anim.addUpdateListener(_Upd())
            anim.start()
            self._supporters_anim_refs.append(anim)
        except Exception:
            pass

    def _render_supporters_grid(self, ctx, grid):
        try:
            from android.widget import LinearLayout, TextView, ImageView
            from android.view import Gravity, View
            from android.util import TypedValue
            from org.telegram.ui.ActionBar import Theme
            from org.telegram.ui.Components import BackupImageView, AvatarDrawable

            if grid is None:
                return
            try:
                grid.removeAllViews()
            except Exception:
                pass
            self._supporters_anim_refs = []

            items = self._supporters_list()
            if not items:
                empty = TextView(ctx)
                empty.setText(self._tr("supporters_empty"))
                empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                empty.setGravity(Gravity.CENTER)
                try:
                    empty.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                except Exception:
                    pass
                lp_empty = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_empty.topMargin = AndroidUtilities.dp(18)
                grid.addView(empty, lp_empty)
                return

            c_name = 0xFFFFFFFF
            c_user = 0xB3FFFFFF
            try:
                c_name = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            try:
                c_user = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                pass

            for start in range(0, len(items), 3):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.TOP)
                lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_row.topMargin = AndroidUtilities.dp(12 if start > 0 else 4)
                grid.addView(row, lp_row)

                chunk = items[start:start + 3]
                for rel_idx in range(3):
                    cell = LinearLayout(ctx)
                    cell.setOrientation(LinearLayout.VERTICAL)
                    cell.setGravity(Gravity.TOP | Gravity.CENTER_HORIZONTAL)
                    cell.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(6))
                    lp_cell = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    if rel_idx < 2:
                        lp_cell.rightMargin = AndroidUtilities.dp(2)
                    row.addView(cell, lp_cell)

                    if rel_idx >= len(chunk):
                        cell.setVisibility(View.INVISIBLE)
                        continue

                    item = chunk[rel_idx]
                    avatar = BackupImageView(ctx)
                    avatar.setRoundRadius(AndroidUtilities.dp(18))
                    try:
                        avatar.setAspectFit(False)
                    except Exception:
                        pass
                    try:
                        url = str(item.get("avatar", "") or "").strip()
                        if url:
                            avatar.setImage(url, "120_120", None)
                        else:
                            avatar.setImageDrawable(AvatarDrawable())
                    except Exception:
                        try:
                            avatar.setImageDrawable(AvatarDrawable())
                        except Exception:
                            pass
                    lp_avatar = LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72))
                    cell.addView(avatar, lp_avatar)

                    name = TextView(ctx)
                    name.setText(str(item.get("name", "") or "").strip() or "Supporter")
                    name.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                    try:
                        from android.graphics import Typeface
                        name.setTypeface(Typeface.DEFAULT_BOLD)
                    except Exception:
                        pass
                    name.setGravity(Gravity.CENTER)
                    name.setSingleLine(True)
                    try:
                        name.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                    except Exception:
                        pass
                    try:
                        name.setTextColor(c_name)
                    except Exception:
                        pass
                    lp_name = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_name.topMargin = AndroidUtilities.dp(8)
                    cell.addView(name, lp_name)

                    user = TextView(ctx)
                    user.setText(str(item.get("username", "") or "").strip())
                    user.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    user.setGravity(Gravity.CENTER)
                    user.setSingleLine(True)
                    try:
                        user.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                    except Exception:
                        pass
                    try:
                        user.setTextColor(c_user)
                        user.setAlpha(0.82)
                    except Exception:
                        pass
                    lp_user = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_user.topMargin = AndroidUtilities.dp(2)
                    cell.addView(user, lp_user)

                    uname = str(item.get("username", "") or "").strip()
                    if uname:
                        cell.setClickable(True)
                        cell.setFocusable(True)
                        cell.setOnClickListener(OnClickListener(lambda _v=None, u=uname: self._open_username(u)))

                    self._start_supporter_card_anim(cell, start + rel_idx)
        except Exception as e:
            self._dlog("render supporters grid fail: {0}".format(e))

    def _build_supporters_subfragment_view(self, ctx):
        try:
            from android.widget import LinearLayout, TextView, ImageView
            from android.view import Gravity
            from android.util import TypedValue
            from org.telegram.ui.ActionBar import Theme
            from android.graphics.drawable import GradientDrawable
            from android.graphics import BitmapFactory, Color

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(18))
            try:
                root.setBackgroundColor(0x00000000)
            except Exception:
                pass

            banner = ImageView(ctx)
            try:
                banner.setScaleType(ImageView.ScaleType.CENTER_CROP)
            except Exception:
                pass
            try:
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                bg.setColor(0x00000000)
                banner.setBackground(bg)
                banner.setClipToOutline(True)
            except Exception:
                pass
            try:
                if os.path.exists(SPONSOR_BANNER_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(SPONSOR_BANNER_CACHE_FILE)
                    if bmp is not None:
                        banner.setImageBitmap(bmp)
            except Exception:
                pass
            lp_banner = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(124))
            root.addView(banner, lp_banner)

            divider_row = LinearLayout(ctx)
            divider_row.setOrientation(LinearLayout.HORIZONTAL)
            divider_row.setGravity(Gravity.CENTER_VERTICAL)
            lp_div = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_div.topMargin = AndroidUtilities.dp(14)
            root.addView(divider_row, lp_div)

            line_color = 0x66FFFFFF
            text_color = 0xB3FFFFFF
            try:
                base_line = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
                line_color = int((base_line & 0x00FFFFFF) | (0x66 << 24))
            except Exception:
                pass
            try:
                text_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                pass

            line_l = ImageView(ctx)
            try:
                line_l.setBackgroundColor(line_color)
            except Exception:
                pass
            divider_row.addView(line_l, LinearLayout.LayoutParams(0, AndroidUtilities.dp(1), 1.0))

            thanks = TextView(ctx)
            thanks.setText(self._tr("supporters_thanks"))
            thanks.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            thanks.setGravity(Gravity.CENTER)
            try:
                thanks.setTextColor(text_color)
                thanks.setAlpha(0.88)
            except Exception:
                pass
            lp_thanks = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_thanks.leftMargin = AndroidUtilities.dp(10)
            lp_thanks.rightMargin = AndroidUtilities.dp(10)
