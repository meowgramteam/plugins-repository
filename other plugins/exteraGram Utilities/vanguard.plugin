                lp_rb = FrameLayout.LayoutParams(FrameLayout.LayoutParams.WRAP_CONTENT, FrameLayout.LayoutParams.WRAP_CONTENT)
                lp_rb.gravity = Gravity.END | Gravity.CENTER_VERTICAL
                lp_rb.rightMargin = AndroidUtilities.dp(8)
                note_wrap.addView(remove_btn, lp_rb)
            else:
