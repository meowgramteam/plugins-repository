import re
import threading
import time
from typing import Any, Dict, List, Optional

from java.lang import Class
from java.util import ArrayList

from android_utils import log, run_on_ui_thread
from base_plugin import BasePlugin, XposedHook
from client_utils import send_message
from ui.settings import Divider, Header, Input, Switch, Text

__id__ = "nometa_auto_reply"
__name__ = "NoMeta Auto Reply"
__description__ = "Авто-ответ @nometaxxx на входящие мета-вопросы."
__author__ = "hyponomic"
__version__ = "2.2.0"
__icon__ = "msg_mention"
__min_version__ = "11.9.0"

_DEFAULT_ENABLED = True
_DEFAULT_MENTION = "@nometaxxx"
_DEFAULT_STRICT = True
_DEFAULT_PRIVATE_ONLY = False
_DEFAULT_COOLDOWN_SEC = 20
_DEFAULT_SKIP_IF_ALREADY_TAGGED = True

_META_RE = re.compile(
    r"(?:\bmeta\b|meta[-_\s]?question|мета(?:[-_\s]?вопрос\w*)?|метад(?:анные|ата)?)",
    re.I,
)
_META_PREFACE_RE = re.compile(
    r"(?:"
    r"^\s*(?:привет|здравствуй(?:те)?|hello|hi)\s*(?:[,!.\-]\s*)?(?:ты\s+тут|here)?\s*\??\s*$|"
    r"^\s*(?:пинг|ping)\s*[!?. ]*$|"
    r"\b(?:можно|можно\s+ли)\s+(?:задать\s+)?вопрос(?:ик)?\b|"
    r"\bможно\s+спросить\b|"
    r"\bесть\s+кто\s+(?:разбира(?:ется|ются)|шарит|знает)\b|"
    r"\bкто\s+(?:разбира(?:ется|ются)|шарит|знает)\b|"
    r"\bесть\s+вопрос(?:ик)?(?:\s+по\b|\b)|"
    r"\bесть\s+минутк(?:а|у)\b|"
    r"\bcan\s+i\s+ask\s+a\s+question\b|"
    r"\banyone\s+(?:who\s+)?(?:knows|familiar\s+with)\b|"
    r"\bi\s+have\s+a\s+question(?:\s+about)?\b"
    r")",
    re.I,
)
_QUESTION_RE = re.compile(
    r"(?:\?|"
    r"\b(как|что|кто|где|когда|почему|зачем|какой|какая|какие|вопрос)\b|"
    r"\b(how|what|who|where|when|why|question)\b)",
    re.I,
)
_USERNAME_RE = re.compile(r"^[A-Za-z0-9_]{4,32}$")
_SPACE_RE = re.compile(r"\s+")

