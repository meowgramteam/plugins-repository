    def _safe_json_loads(self, raw: str, default):
        try:
            if raw is None:
                return default
            if isinstance(raw, (dict, list)):
                return raw
            raw = str(raw).strip()
            if raw == "":
                return default
            return json.loads(raw)
        except Exception:
            return default

    def _get_by_path(self, obj, path: str):
        if not path:
            return obj
        try:
            cur = obj
            for part in str(path).split("."):
                if cur is None:
                    return None
                if isinstance(cur, dict):
                    cur = cur.get(part)
                elif isinstance(cur, list):
                    idx = int(part)
                    cur = cur[idx] if 0 <= idx < len(cur) else None
                else:
                    return None
            return cur
        except Exception:
            return None

    def _build_search_tags(self, tags_in_setting: str, tags_ex_setting: str, query: str) -> str:
        query_parts = str(query or "").split()
        include_tags = [p for p in query_parts if not p.startswith('-')]
        exclude_tags = [p[1:] for p in query_parts if p.startswith('-')]

        all_include = []
        if tags_in_setting:
            all_include.extend(str(tags_in_setting).split())
        all_include.extend(include_tags)
        search_tags = ' '.join([t for t in all_include if str(t).strip()])

        all_exclude_tags = str(tags_ex_setting or "").split("; ") + exclude_tags
        tags_ex = [tag.strip() for tag in all_exclude_tags if tag and str(tag).strip()]
        if tags_ex:
            for tag in tags_ex:
                search_tags += f' -{tag}'
        return search_tags.strip()

    def _dapi_get_random_post(self, base_url: str, tags: str, limit: int, use_proxy: bool, url_for_proxy_check: str | None = None):
        params = {
            'page': 'dapi',
            's': 'post',
            'q': 'index',
            'tags': tags,
            'limit': limit,
            'json': 1,
        }
        req_headers = get_request_headers()
        try:
            response = requests.get(base_url, params=params, headers=req_headers, timeout=10)
            response.raise_for_status()
        except Exception:
            if use_proxy:
                proxy_dict = get_working_proxy(url_for_proxy_check) if url_for_proxy_check else get_working_proxy()
                if proxy_dict:
                    response = requests.get(base_url, params=params, headers=req_headers, timeout=10, proxies=proxy_dict)
                    response.raise_for_status()
                else:
                    response = requests.get(base_url, params=params, headers=req_headers, timeout=10)
                    response.raise_for_status()
            else:
                response = requests.get(base_url, params=params, headers=req_headers, timeout=10)
                response.raise_for_status()

        data = response.json()
        posts = None
        if isinstance(data, list):
            posts = data
        elif isinstance(data, dict):
            if 'post' in data:
                posts = data.get('post')
        if posts is None:
            posts = []
        if isinstance(posts, dict):
            posts = [posts]
        if not isinstance(posts, list) or not posts:
            return None
        return random.choice(posts)

    def _custom_sources(self):
        raw = self.get_setting("custom_sources_json", "[]")
        sources = self._safe_json_loads(raw, [])
        if not isinstance(sources, list):
            return []
        normalized = []
        for s in sources:
            try:
                if not isinstance(s, dict):
                    continue
                name = str(s.get('name') or '').strip()
                if not name:
                    continue
                normalized.append(s)
            except Exception:
                continue
        return normalized

    def _get_custom_source(self, name: str):
        wanted = str(name or "").strip().lower()
        if not wanted:
            return None
        for s in self._custom_sources():
            try:
                n = str(s.get('name') or '').strip().lower()
                if n == wanted:
                    return s
            except Exception:
                continue
        return None

    def get_image_xbooru(self, query):
        try:
            tags_in_setting = self.get_setting("xbooru_tags_in", "")
            tags_ex_setting = self.get_setting("xbooru_tags_ex", "")
            posts_count = min(int(self.get_setting("xbooru_posts_count", "100")), 1000)
            use_proxy = self.get_setting("use_proxy", True)

            search_tags = self._build_search_tags(tags_in_setting, tags_ex_setting, query)
            rating_filter_raw = self.get_setting("xbooru_rating", "")
            rating_filter = ""
            try:
                rating_idx = int(rating_filter_raw)
                rating_filter = {0: "", 1: "s", 2: "q", 3: "e"}.get(rating_idx, "")
            except Exception:
                rating_filter = str(rating_filter_raw).strip().lower() if rating_filter_raw else ""
                rating_filter = {'safe': 's', 'questionable': 'q', 'explicit': 'e'}.get(rating_filter, rating_filter)
            if rating_filter:
                search_tags += f" rating:{rating_filter}"
            post = self._dapi_get_random_post("https://xbooru.com/index.php", search_tags, posts_count, use_proxy, "https://xbooru.com/index.php?page=dapi&s=post&q=index&limit=1&json=1")
            if not post:
                return localise("not_found")
            tags = post.get('tags', '').split() if isinstance(post.get('tags'), str) else []
            image_url = None
            for field in ('file_url', 'large_file_url', 'jpeg_url', 'sample_url', 'image', 'preview_url', 'preview_file_url', 'source'):
                image_url = post.get(field)
                if image_url:
                    break
            if not image_url:
                return localise("not_found")
            return {
                'id': post.get('id'),
                'file_url': image_url,
                'tags': tags,
                'rating': post.get('rating', '')
            }
        except Exception as e:
            log(f"[BooruSearch] Ошибка Xbooru: {e}")
            return None

    def get_image_custom(self, source_cfg: dict, query: str):
        try:
            use_proxy = self.get_setting("use_proxy", True)
            src_type = str(source_cfg.get('type') or '').strip().lower()
            base_url = str(source_cfg.get('base_url') or '').strip().rstrip('/')
            endpoint = str(source_cfg.get('endpoint') or '').strip()

            if not base_url or not endpoint:
                return None

            tags_in_setting = str(source_cfg.get('tags_in') or '')
            tags_ex_setting = str(source_cfg.get('tags_ex') or '')
            search_tags = self._build_search_tags(tags_in_setting, tags_ex_setting, query)

            url = base_url + endpoint

            if src_type == 'gelbooru_dapi':
                params = {}
                tags_param = str(source_cfg.get('tags_param') or 'tags')
                limit_param = str(source_cfg.get('limit_param') or 'limit')
                page_param = str(source_cfg.get('page_param') or 'pid')
                params[tags_param] = search_tags
                params[limit_param] = int(source_cfg.get('limit') or 100)
                params[page_param] = int(source_cfg.get('page') or 0)
                if str(source_cfg.get('json_param') or 'json'):
                    params[str(source_cfg.get('json_param') or 'json')] = int(source_cfg.get('json_value') or 1)

                req_headers = get_request_headers()
                try:
                    response = requests.get(url, params=params, headers=req_headers, timeout=10)
                    response.raise_for_status()
                except Exception:
                    if use_proxy:
                        proxy_dict = get_working_proxy(url)
                        if proxy_dict:
                            response = requests.get(url, params=params, headers=req_headers, timeout=10, proxies=proxy_dict)
                            response.raise_for_status()
                        else:
                            response = requests.get(url, params=params, headers=req_headers, timeout=10)
                            response.raise_for_status()
                    else:
                        response = requests.get(url, params=params, headers=req_headers, timeout=10)
                        response.raise_for_status()

                data = response.json()
                post_list_path = str(source_cfg.get('post_list_path') or '')
                posts = self._get_by_path(data, post_list_path) if post_list_path else data
                if isinstance(posts, dict):
                    posts = [posts]
                if not isinstance(posts, list) or not posts:
                    return localise("not_found")
                post = random.choice(posts)

                file_url = self._get_by_path(post, str(source_cfg.get('file_url_path') or 'file_url'))
                tags_raw = self._get_by_path(post, str(source_cfg.get('tags_path') or 'tags'))
                rating_raw = self._get_by_path(post, str(source_cfg.get('rating_path') or 'rating'))
                tags = tags_raw.split() if isinstance(tags_raw, str) else []
                if not file_url:
                    return localise("not_found")
                return {
                    'id': self._get_by_path(post, str(source_cfg.get('id_path') or 'id')),
                    'file_url': file_url,
                    'tags': tags,
                    'rating': rating_raw or ''
                }

            if src_type == 'danbooru_json':
                req_headers = get_request_headers()
                params = {}
                params[str(source_cfg.get('tags_param') or 'tags')] = search_tags
                params[str(source_cfg.get('limit_param') or 'limit')] = int(source_cfg.get('limit') or 100)

                try:
                    response = requests.get(url, params=params, headers=req_headers, timeout=10)
                    response.raise_for_status()
                except Exception:
                    if use_proxy:
                        proxy_dict = get_working_proxy(url)
                        if proxy_dict:
                            response = requests.get(url, params=params, headers=req_headers, timeout=10, proxies=proxy_dict)
                            response.raise_for_status()
                        else:
                            response = requests.get(url, params=params, headers=req_headers, timeout=10)
                            response.raise_for_status()
                    else:
                        response = requests.get(url, params=params, headers=req_headers, timeout=10)
                        response.raise_for_status()

                data = response.json()
                post_list_path = str(source_cfg.get('post_list_path') or '')
                posts = self._get_by_path(data, post_list_path) if post_list_path else data
                if isinstance(posts, dict):
                    posts = [posts]
                if not isinstance(posts, list) or not posts:
                    return localise("not_found")
                post = random.choice(posts)

                file_url = self._get_by_path(post, str(source_cfg.get('file_url_path') or 'file_url'))
                tags_raw = self._get_by_path(post, str(source_cfg.get('tags_path') or 'tags'))
                rating_raw = self._get_by_path(post, str(source_cfg.get('rating_path') or 'rating'))
                tags = tags_raw.split() if isinstance(tags_raw, str) else []
                if not file_url:
                    return localise("not_found")
                return {
                    'id': self._get_by_path(post, str(source_cfg.get('id_path') or 'id')),
                    'file_url': file_url,
                    'tags': tags,
                    'rating': rating_raw or ''
                }

            BulletinHelper.show_error(f"Unknown custom source type: {src_type}")
            return None

        except Exception as e:
            log(f"[BooruSearch] Ошибка custom source: {e}")
            return None

    def get_image_safebooru(self, query):
        try:
            tags_in_setting = self.get_setting("safebooru_tags_in", "")
            tags_ex_setting = self.get_setting("safebooru_tags_ex", "")
            posts_count = min(int(self.get_setting("safebooru_posts_count", "100")), 1000)
            use_proxy = self.get_setting("use_proxy", True)
            
            query_parts = query.split()
            include_tags = [p for p in query_parts if not p.startswith('-')]
            exclude_tags = [p[1:] for p in query_parts if p.startswith('-')]
            
            all_include = []
            if tags_in_setting:
                all_include.extend(tags_in_setting.split())
            all_include.extend(include_tags)
            search_tags = ' '.join(all_include)
            
            all_exclude_tags = tags_ex_setting.split("; ") + exclude_tags
            tags_ex = [tag.strip() for tag in all_exclude_tags if tag.strip()]
            if tags_ex:
                for tag in tags_ex:
                    search_tags += f' -{tag}'
            
            log(f"[BooruSearch] Safebooru поиск: '{search_tags}'")
            req_headers = get_request_headers()
            try:
                response = requests.get(
                    f"https://safebooru.org/index.php?page=dapi&s=post&q=index&limit={posts_count}&tags={search_tags}&json=1",
                    headers=req_headers,
                    timeout=10
                )
                response.raise_for_status()
            except Exception as e:
                if use_proxy:
                    proxy = get_working_proxy()
                    if proxy:
                        response = requests.get(
                            f"https://safebooru.org/index.php?page=dapi&s=post&q=index&limit={posts_count}&tags={search_tags}&json=1",
                            headers=req_headers,
                            proxies=proxy,
                            timeout=10
                        )
                        response.raise_for_status()
                    else:
                        raise
                else:
