    def _show_custom_sources_example(self):
        try:
            fragment = get_last_fragment()
            activity = fragment.getParentActivity() if fragment else None
            if not activity:
                BulletinHelper.show_error(localise("menu_no_activity"))
                return

            builder = AlertDialogBuilder(activity)
            builder.set_title(localise("custom_sources_example_title"))
            builder.set_message(localise("custom_sources_example_body"))
            builder.set_positive_button(localise("dialog_close"), lambda d, w: d.dismiss())
            run_on_ui_thread(builder.show)
        except Exception as e:
            log(f"[BooruSearch] custom sources example error: {e}")

