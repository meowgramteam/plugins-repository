    def on_send_message_hook(self, account, params):
        if not hasattr(params, 'message') or not isinstance(params.message, str):
            return HookResult()

        msg = params.message.strip()
        usage = localise("usage")
        try:
            if msg.startswith(".proxy_get"):
                self.update_proxy_list()
                params.message = localise("proxy_update_started")
                return HookResult(strategy=HookStrategy.CANCEL)
        except Exception as e:
            log(f"[BooruSearch] proxy_get error: {e}")

        if not (msg.startswith(".r34") or msg.startswith(".yandere") or msg.startswith(".danbooru") or msg.startswith(".safebooru") or msg.startswith(".gelbooru") or msg.startswith(".konachan") or msg.startswith(".xbooru") or msg.startswith(".booru") or msg.startswith(".random")):
            return HookResult()

        cmd_type = ".r34"
        if msg.startswith(".yandere"):
            cmd_type = ".yandere"
            log("[BooruSearch] Команда .yandere обнаружена")
        elif msg.startswith(".danbooru"):
            cmd_type = ".danbooru"
            log("[BooruSearch] Команда .danbooru обнаружена")
        elif msg.startswith(".safebooru"):
            cmd_type = ".safebooru"
            log("[BooruSearch] Команда .safebooru обнаружена")
        elif msg.startswith(".gelbooru"):
            cmd_type = ".gelbooru"
            log("[BooruSearch] Команда .gelbooru обнаружена")
        elif msg.startswith(".konachan"):
            cmd_type = ".konachan"
            log("[BooruSearch] Команда .konachan обнаружена")
        elif msg.startswith(".xbooru"):
            cmd_type = ".xbooru"
            log("[BooruSearch] Команда .xbooru обнаружена")
        elif msg.startswith(".booru"):
            cmd_type = ".booru"
            log("[BooruSearch] Команда .booru обнаружена")
        elif msg.startswith(".random"):
            cmd_type = ".random"
            log("[BooruSearch] Команда .random обнаружена")
        else:
            log("[BooruSearch] Команда .r34 обнаружена")      

        parts = msg.split(" ", 1)
        query = ""
        if len(parts) > 1:
            query = parts[1].strip()

        custom_source_name = ""
        if cmd_type == ".booru":
            subparts = query.split(" ", 1)
            if subparts:
                custom_source_name = subparts[0].strip()
                query = subparts[1].strip() if len(subparts) > 1 else ""
        send_n = 1
        try:
            if cmd_type == ".yandere":
                send_n = int(self.get_setting("yandere_send_count", "1"))
            elif cmd_type == ".danbooru":
                send_n = int(self.get_setting("danbooru_send_count", "1"))
            elif cmd_type == ".safebooru":
                send_n = int(self.get_setting("safebooru_send_count", "1"))
            elif cmd_type == ".gelbooru":
                send_n = int(self.get_setting("gelbooru_send_count", "1"))
            elif cmd_type == ".konachan":
                send_n = int(self.get_setting("konachan_send_count", "1"))
            elif cmd_type == ".xbooru":
                send_n = int(self.get_setting("xbooru_send_count", "1"))
            elif cmd_type == ".random":
                send_n = int(self.get_setting("send_count", "1"))
            else:
                send_n = int(self.get_setting("send_count", "1"))
        except Exception:
            send_n = 1
        try:
            tokens = query.split()
            if tokens and tokens[-1].isdigit():
                send_n = int(tokens[-1])
                tokens = tokens[:-1]
                query = " ".join(tokens)
        except Exception:
            pass
        try:
            send_n = max(1, min(10, int(send_n)))
        except Exception:
            send_n = 1

        log(f"[BooruSearch] Запрос: '{query}'")

        
        include_tags = [part for part in query.split() if not part.startswith('-')]
        if cmd_type == ".yandere":
            tags_in_setting = self.get_setting("yandere_tags_in", "").strip()
        elif cmd_type == ".danbooru":
            tags_in_setting = self.get_setting("danbooru_tags_in", "").strip()
        elif cmd_type == ".xbooru":
            tags_in_setting = self.get_setting("xbooru_tags_in", "").strip()
        elif cmd_type == ".booru":
            tags_in_setting = ""
        else:
            tags_in_setting = self.get_setting("tags_in", "nude").strip()
        
        if not include_tags and not tags_in_setting:
            if cmd_type == ".yandere":
                BulletinHelper.show_error(localise("usage_yandere"))
                return HookResult(strategy=HookStrategy.CANCEL)
            elif cmd_type == ".danbooru":
                BulletinHelper.show_error(localise("usage_danbooru"))
                return HookResult(strategy=HookStrategy.CANCEL)
            else:
                params.message = usage
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

        def search_and_reply(search_query, peer, reply_to_msg=None, reply_to_top_msg=None, send_n: int = 1):
            log(f"[BooruSearch] Начинаем поиск в потоке. Запрос: '{search_query}', отправим {send_n} пост(а)")
            stop_on_not_found = True
            for idx in range(send_n):
                try:
                    if cmd_type == ".yandere":
                        result = self.get_image_yandere(search_query)
                    elif cmd_type == ".danbooru":
                        result = self.get_image_danbooru(search_query)
                    elif cmd_type == ".safebooru":
                        result = self.get_image_safebooru(search_query)
                    elif cmd_type == ".gelbooru":
                        result = self.get_image_gelbooru(search_query)
                    elif cmd_type == ".konachan":
                        result = self.get_image_konachan(search_query)
                    elif cmd_type == ".xbooru":
                        result = self.get_image_xbooru(search_query)
                    elif cmd_type == ".booru":
                        cfg = self._get_custom_source(custom_source_name)
                        if not cfg:
                            result = f"Custom source not found: {custom_source_name}"
                        else:
                            result = self.get_image_custom(cfg, search_query)
                    elif cmd_type == ".random":
                        sources = [self.get_image, self.get_image_yandere, self.get_image_danbooru, self.get_image_safebooru, self.get_image_gelbooru, self.get_image_konachan, self.get_image_xbooru]
                        result = random.choice(sources)(search_query)
                    else:
                        result = self.get_image(search_query)
                    
                    if isinstance(result, str) and stop_on_not_found and result == localise("not_found"):
                        log(f"[BooruSearch] Ничего не найдено и stop_on_not_found=True, прерываем поиск")
                        BulletinHelper.show_error(result)
                        break

                    log(f"[BooruSearch] Результат поиска получен: {type(result)}")

                    if isinstance(result, dict) and result.get("file_url"):
                        log(f"[BooruSearch] Отправляем пост с изображением: {result.get('id', 'unknown')}")
                        if cmd_type == ".yandere":
                            tags_in_setting = self.get_setting("yandere_tags_in", "")
                        elif cmd_type == ".danbooru":
                            tags_in_setting = self.get_setting("danbooru_tags_in", "")
                        else:
                            tags_in_setting = self.get_setting("tags_in", "")
                        requested_tags = (tags_in_setting + (" " + query if query else "")).strip()
                        requested_tags_str = requested_tags if requested_tags else "(пусто)"
                        tags_list = result.get('tags', [])
                        if isinstance(tags_list, str):
                            tags_list = tags_list.split() if tags_list else []
                        post_tags = ", ".join(tags_list)
                        image_url = result.get("file_url")
                        rating = result.get('rating', '') if (cmd_type == ".yandere" or cmd_type == ".danbooru") else ''
                        final_text, message_entities = self._build_caption_with_entities(requested_tags_str, post_tags, image_url, rating)

                        local_path = self._download_media(image_url)
                        if local_path is None:
                            log(f"[BooruSearch] Не удалось скачать медиа")
                            send_message({
                                "peer": peer,
                                "message": final_text,
                                **({"replyToMsg": reply_to_msg} if reply_to_msg is not None else {}),
                                **({"replyToTopMsg": reply_to_top_msg} if reply_to_top_msg is not None else {})
                            })
                            continue

                        try:
                            from org.telegram.messenger import SendMessagesHelper
                            account = get_account_instance()
                            tlrpc_entities = ArrayList()
                            for e in message_entities:
                                tlrpc_entities.add(e)

                            reply_msg_obj = None
                            if reply_to_msg is not None:
                                try:
                                    reply_msg_obj = get_messages_controller().getMessageObject(peer, reply_to_msg, False, 0, False)
                                except Exception:
                                    pass

                            is_video = self._is_video(image_url)
                            if is_video:
                                SendMessagesHelper.prepareSendingVideo(
                                    account, local_path, None, None, None,
                                    peer, reply_msg_obj, None, None, None,
                                    tlrpc_entities, 0, None, True, 0, 0,
                                    False, False, final_text, None, 0,
                                    0, 0,
                                )
                            else:
                                SendMessagesHelper.prepareSendingPhoto(
                                    account, local_path, None, peer, reply_msg_obj,
                                    None, None, final_text, tlrpc_entities,
                                    None, None, 0, None, True, 0, 0, None, 0,
                                )
                        except Exception as se:
                            log(f"[BooruSearch] Ошибка при отправке медиа: {se}")
                            send_message({
                                "peer": peer,
                                "message": final_text,
                                **({"replyToMsg": reply_to_msg} if reply_to_msg is not None else {}),
                                **({"replyToTopMsg": reply_to_top_msg} if reply_to_top_msg is not None else {})
                            })
                    elif isinstance(result, str):
                        log(f"[BooruSearch] Показываем Bulletin: {result}")
                        BulletinHelper.show_error(result)
                    elif result is None:
                        log(f"[BooruSearch] Результат None, ничего не отправляем")
                        pass
                    else:
                        log(f"[BooruSearch] Неожиданный тип результата: {type(result)}")
                        BulletinHelper.show_error(localise("unexpected_url_error"))

                except Exception as e:
                    log(f"[BooruSearch] Ошибка в потоке поиска: {e}")
                    BulletinHelper.show_error(localise("search_thread_error").format(e=e))
                time.sleep(0.3)

        try:
            BulletinHelper.show_info(localise("searching"))
        except Exception as e:
            log(f"[BooruSearch] Ошибка при создании диалога: {e}")

        log("[BooruSearch] Запускаем поток поиска")
        
        threading.Thread(target=lambda: search_and_reply(query, params.peer, params.replyToMsg, params.replyToTopMsg, send_n), daemon=True).start()

        params.message = localise("searching")
        return HookResult(strategy=HookStrategy.CANCEL)

    def update_proxy_list(self):
        def update_proxies_background():
            try:
                BulletinHelper.show_info(localise("proxy_update_started"))
                log("[BooruSearch] Начинаем обновление списка прокси...")

                src = int(self.get_setting("proxy_source", 0) or 0)
                all_proxies = []
                if src == 2:
                    raw_manual = str(self.get_setting("proxy_manual_list", "") or "")
                    for line in raw_manual.splitlines():
                        s = str(line).strip()
                        if not s or s.startswith("#"):
                            continue
                        all_proxies.append(s)
                    log(f"[BooruSearch] Загружено {len(all_proxies)} прокси из ручного списка")
                else:
                    if src == 1:
                        proxy_url = str(self.get_setting("proxy_source_url", "") or "").strip()
                        if not proxy_url:
                            proxy_url = "https://cdn.jsdelivr.net/gh/proxifly/free-proxy-list@main/proxies/all/data.txt"
                    else:
                        proxy_url = "https://cdn.jsdelivr.net/gh/proxifly/free-proxy-list@main/proxies/all/data.txt"

                    all_proxies = get_proxy_list_from_url(proxy_url)
                    log(f"[BooruSearch] Загружено {len(all_proxies)} прокси из {proxy_url}")
                
                if not all_proxies:
                    BulletinHelper.show_error(localise("proxy_update_error").format(error="Не удалось загрузить прокси"))
                    return
                
                unique_proxies = list(set(all_proxies))
                log(f"[BooruSearch] Всего уникальных прокси: {len(unique_proxies)}")
                
                max_proxies_to_check = 2000
                if len(unique_proxies) > max_proxies_to_check:
                    unique_proxies = unique_proxies[:max_proxies_to_check]
                    log(f"[BooruSearch] Ограничиваем проверку до {max_proxies_to_check} прокси")
                
                working_proxies = check_proxies_parallel(unique_proxies, max_workers=100, max_working=30)
                
                if working_proxies:
                    working_proxies.sort(key=lambda x: x['response_time'])
                    
                    save_working_proxies_to_file(working_proxies)
                    
                    BulletinHelper.show_success(localise("proxy_update_success").format(count=len(working_proxies)))
                    log(f"[BooruSearch] Обновление завершено! Найдено {len(working_proxies)} рабочих прокси")
                else:
                    BulletinHelper.show_error(localise("no_working_proxies"))
                    log("[BooruSearch] Рабочие прокси не найдены")
                    
            except Exception as e:
                error_msg = str(e)
                BulletinHelper.show_error(localise("proxy_update_error").format(error=error_msg))
                log(f"[BooruSearch] Ошибка при обновлении прокси: {e}")
        
        threading.Thread(target=update_proxies_background, daemon=True).start()
    
    def _dismiss_dialog(self):
        pass

    def on_setting_changed(self, key, value):
        try:
            if key == "logs_enabled":
                _booru_set_logs_enabled(bool(value))
        except Exception:
            pass


    def _build_caption_text(self, requested_tags_str: str, post_tags: str, image_url: str, rating: str = '') -> str:
        try:
            from java.util import Locale as _Loc
            _lang = _Loc.getDefault().getLanguage()
        except Exception:
            _lang = "ru"

        theme_style = 0
        try:
            theme_style = int(self.get_setting("theme_style", 0) or 0)
        except Exception:
            theme_style = 0

        nsfw = theme_style == 1

        if _lang.startswith("ru"):
            header = "*Найден пост!*"
            req_label = "*Запрошенные теги:*"
            tags_label = "*Теги в посте:*"
            link_label = "*Ссылка:*"
            open_text = "Открыть изображение"
        else:
            header = "*Post found!*"
            req_label = "*Requested tags:*"
            tags_label = "*Post tags:*"
            link_label = "*Link:*"
            open_text = "Open image"

        if theme_style == 2:
            emo_header = str(self.get_setting("custom_emoji_header", localise("emoji_header_normal")) or "")
            emo_req = str(self.get_setting("custom_emoji_req", localise("emoji_req_normal")) or "")
            emo_tags = str(self.get_setting("custom_emoji_tags", localise("emoji_tags_normal")) or "")
            emo_link = str(self.get_setting("custom_emoji_link", localise("emoji_link_normal")) or "")
            rating_emoji_safe = str(self.get_setting("custom_emoji_rating_safe", "[🛡](5276262671962892944)") or "")
            rating_emoji_nsfw = str(self.get_setting("custom_emoji_rating_nsfw", "[💔](5258354685563129815)") or "")
        else:
            rating_emoji_safe = "[🛡](5276262671962892944)"
            rating_emoji_nsfw = "[💔](5258354685563129815)"
            if nsfw:
                emo_header = localise("emoji_header_nso")
                emo_req = localise("emoji_req_nso")
                emo_tags = localise("emoji_tags_nso")
                emo_link = localise("emoji_link_nso")
            else:
                emo_header = localise("emoji_header_normal")
                emo_req = localise("emoji_req_normal")
                emo_tags = localise("emoji_tags_normal")
                emo_link = localise("emoji_link_normal")

        lines = []
        lines.append(f"{emo_header} | {header}")

        if self.get_setting("show_requested_tags", True) and requested_tags_str:
            code_req = self._md_code(requested_tags_str)
            lines.append(f"{emo_req} | {req_label} `{code_req}`")

        if self.get_setting("show_post_tags", True) and post_tags:
            code_tags = self._md_code(post_tags)
            lines.append(f"{emo_tags} | {tags_label} `{code_tags}`")
        
        if rating:
            if _lang.startswith("ru"):
                rating_label = "*Рейтинг:*"
            else:
                rating_label = "*Rating:*"

            rating_emoji = rating_emoji_nsfw if nsfw else rating_emoji_safe
            
            lines.append(f"{rating_emoji} | {rating_label} `{rating}`")

        if self.get_setting("show_image_link", True) and image_url:
            lines.append(f"{emo_link} | {link_label} [{open_text}]({image_url})")

        return "\n".join(lines)

    def _build_caption_with_entities(self, requested_tags_str: str, post_tags: str, image_url: str, rating: str = '') -> tuple:
        message_text = self._build_caption_text(requested_tags_str, post_tags, image_url, rating)
        parsed_message = parse_markdown(message_text)
        tlrpc_entities = []
        for entity in parsed_message.entities:
            try:
                tlrpc_entities.append(entity.to_tlrpc_object())
            except Exception:
                pass
        
        return parsed_message.text, tlrpc_entities

    def _md_code(self, s: str) -> str:
        try:
            return s.replace('`', r'\`')
        except Exception:
            return s

    def _is_video(self, file_url: str) -> bool:
        from urllib.parse import urlparse
        try:
            _, ext = os.path.splitext(urlparse(file_url).path)
            ext = ext.lower()
            return ext in ('.mp4', '.webm', '.avi', '.mkv', '.mov', '.m4v', '.gifv')
        except Exception:
            return False

    def _download_media(self, url: str) -> Optional[str]:

        from urllib.parse import urlparse
        from tempfile import NamedTemporaryFile
        try:
            parsed_url = urlparse(url)
            _, ext = os.path.splitext(parsed_url.path)
            ext = ext.lower() if ext else '.jpg'

            headers = {
                'User-Agent': 'nyashnosti-plugin/2.1.1 (https://t.me/fergntye)',
                'Accept': '*/*',
            }
            if parsed_url.netloc:
                headers['Referer'] = f"{parsed_url.scheme}://{parsed_url.netloc}"

            with requests.get(url, stream=True, timeout=30, headers=headers) as resp:
                if not resp.ok:
                    log(f"[BooruSearch] Статус скачивания: {resp.status_code}")
                    return None
                
                temp_file = NamedTemporaryFile(delete=False, suffix=ext)
                for chunk in resp.iter_content(32768):
                    if chunk:
                        temp_file.write(chunk)
                
                temp_file.flush()
                temp_file.close()
                
                if os.path.getsize(temp_file.name) == 0:
                    log(f"[BooruSearch] Скачанный файл пуст")
                    try:
                        os.remove(temp_file.name)
                    except Exception:
                        pass
                    return None
                
                return temp_file.name

        except Exception as e:
            log(f"[BooruSearch] Ошибка скачивания: {e}")
            return None

