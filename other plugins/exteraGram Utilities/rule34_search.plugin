    def get_image(self, query):
        tags_in_setting = self.get_setting("tags_in", "")
        tags_ex_setting = self.get_setting("tags_ex", "ai_generated")
        antiai = self.get_setting("antiai", True)
        posts_count = int(self.get_setting("posts_count", "100"))
        use_proxy = self.get_setting("use_proxy", True)
        
       
        query_parts = query.split()
        include_tags = []
        exclude_tags = []
        
        for part in query_parts:
            if part.startswith('-'):
                exclude_tags.append(part[1:]) 
            else:
                include_tags.append(part)
        
        search_tags = f"{tags_in_setting} {' '.join(include_tags)}".strip()
        

        all_exclude_tags = tags_ex_setting.split("; ") + exclude_tags
        tags_ex = [tag.strip() for tag in all_exclude_tags if tag.strip()]
        
        log(f"[BooruSearch] Включающие теги: {include_tags}")
        log(f"[BooruSearch] Исключающие теги из запроса: {exclude_tags}")
        log(f"[BooruSearch] Общие исключающие теги: {tags_ex}")

        
        if antiai:
            anti_ai_tags = ['-ai_generated', '-stable_diffusion', '-midjourney', '-artificial_intelligence', '-neural_network', '-machine_learning', '-deepfake', '-ai_art', '-ai-generated', '-generated_by_ai', '-dall_e', '-dalle', '-novelai', '-waifu_diffusion']
            search_tags += ' ' + ' '.join(anti_ai_tags)
            log(f"[BooruSearch] Добавлены анти-ИИ теги в запрос")
        
        
        if tags_ex:
            exclude_tags_api = ['-' + tag for tag in tags_ex]
            search_tags += ' ' + ' '.join(exclude_tags_api)
            log(f"[BooruSearch] Добавлены исключающие теги в запрос: {exclude_tags_api}")
        
        log(f"[BooruSearch] Начинаем поиск. Запрос: '{search_tags}', лимит: {posts_count}")
        log(f"[BooruSearch] Исключающие теги: {tags_ex}")
        log(f"[BooruSearch] Анти-AI включен: {antiai}")

        try:
            base_url = "https://api.rule34.xxx/index.php"
            params = {
                'page': 'dapi',
                's': 'post',
                'q': 'index',
                'limit': posts_count,
                'tags': search_tags,
                'json': 1,  
                'api_key': '1b7ac421841879b859d0a0d771b6df8e4a3419e0ce54f234e90bc0c8969ac6ada2972a757a25a606e33dfa9bbd946a0ca231f90c38644336367db73f918b61ed',
                'user_id': '5925125'
            }

            req_headers = get_request_headers()
            log("[BooruSearch] Пробуем запрос без прокси...")
            try:
                response = requests.get(base_url, params=params, headers=req_headers, timeout=2)
                response.raise_for_status()
                log("[BooruSearch] Запрос без прокси успешен")
            except Exception as e:
                log(f"[BooruSearch] Запрос без прокси не удался: {e}")
               
                if use_proxy:
                    log("[BooruSearch] Начинаем перебор прокси...")
                    proxy_dict = get_working_proxy()
                    if proxy_dict:
                        log(f"[BooruSearch] Используем прокси!")
                        response = requests.get(base_url, params=params, headers=req_headers, proxies=proxy_dict, timeout=10)
                        response.raise_for_status()
                    else:
                        log("[BooruSearch] Рабочие прокси не найдены, пробуем без прокси")
                        response = requests.get(base_url, params=params, headers=req_headers, timeout=10)
                        response.raise_for_status()
                else:
                    log("[BooruSearch] Прокси отключены, пробуем без прокси еще раз")
                    response = requests.get(base_url, params=params, headers=req_headers, timeout=10)
                    response.raise_for_status()
            
            data = response.json()
            if not data:
                log("[BooruSearch] Пустой ответ от API")
                BulletinHelper.show_error(localise("not_found"))
                return localise("not_found")
            
            posts_list = data if isinstance(data, list) else []

            log(f"[BooruSearch] Получено постов с API: {len(posts_list)}")

            if not posts_list:
                log("[BooruSearch] Посты не найдены!")
                BulletinHelper.show_error(localise("not_found"))
                return localise("not_found")

           
            filtered_posts = posts_list
            log(f"[BooruSearch] API уже обработал исключения, используем все {len(filtered_posts)} постов")
            
            if not filtered_posts:
                log("[BooruSearch] Нет подходящих постов после фильтрации!")
                BulletinHelper.show_error(localise("not_found_filtered"))
                return localise("not_found_filtered")

            random_post = random.choice(filtered_posts)
            log(f"[BooruSearch] Выбран случайный пост ID: {random_post.get('id', 'unknown')}")
            
            tags = random_post.get('tags', '')
            if isinstance(tags, str):
                tags = tags.split() if tags else []
            
            image_url = None
            for field in ('file_url', 'jpeg_url', 'sample_url', 'large_file_url', 'image', 'preview_url', 'preview_file_url', 'source'):
                image_url = random_post.get(field)
                if image_url:
                    break
            if not image_url:
                log("[BooruSearch] Не удалось получить URL изображения")
                BulletinHelper.show_error(localise("not_found"))
                return localise("not_found")

            return {
                'id': random_post.get('id'),
                'file_url': image_url,
                'tags': tags,
                'rating': random_post.get('rating', '')
            }

        except requests.exceptions.RequestException as e:
            log(f"[BooruSearch] Ошибка запроса: {e}")
            if "SSLCertVerificationError" in str(e):
                BulletinHelper.show_error(localise("site_blocked_rule34"))
            else:
                BulletinHelper.show_error(localise("request_error").format(e=e))
            return None

