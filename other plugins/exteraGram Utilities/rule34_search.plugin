_BOORU_LOGS_ENABLED = True


def _booru_set_logs_enabled(enabled: bool):
    global _BOORU_LOGS_ENABLED
    _BOORU_LOGS_ENABLED = bool(enabled)


def log(message):
    if not _BOORU_LOGS_ENABLED:
        return
    try:
        _android_log(message)
    except Exception:
        pass



__id__ = "rule34_search"
__name__ = "BooruSearch"
__version__ = "1.9.1"
__description__ = """
Плагин для поиска изображений на Booru-based сайтах.

Поддерживаемые источники:
- rule34.xxx
- yande.re
- danbooru.donmai.us
- safebooru.org
- gelbooru.com
- konachan.com
- xbooru.com
- (Кастом источники)

Использование:
- .r34/yandere/danbooru/safebooru/gelbooru/konachan/xbooru/random/свой айпи [теги] (кол-во)
"""
__author__ = "@ArThirtyFour | @KangelPlugins"
__min_version__ = "12.1.1"
__icon__ = "Sayanoutaaaa/7"

