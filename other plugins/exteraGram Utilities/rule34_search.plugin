                BulletinHelper.show_error(localise("site_blocked_yandere"))
            else:
                BulletinHelper.show_error(localise("request_error").format(e=e))
            return None
        except json.JSONDecodeError as e:
            log(f"[BooruSearch] Ошибка парсинга JSON от Yande.re: {e}")
            BulletinHelper.show_error(localise("yandere_json_error"))
            return None
        except Exception as e:
            log(f"[BooruSearch] Общая ошибка Yande.re: {e}")
            BulletinHelper.show_error(localise("general_data_error").format(e=e))
            return None

