def main_status_badge(health):
    if health["status"] == "ok":
        return "Всё работает нормально"
    if health["status"] == "problem":
        return "Обнаружена проблема"
    return "Требуется внимание"


def main_status_text(health):
    if health["status"] == "ok":
        return "Хранилище исправно, данные сохраняются локально и готовы к восстановлению."
    return health["description"]


def _format_backup_filename(name):
    try:
        ts = datetime.strptime(name, BACKUP_PREFIX + "%Y%m%d_%H%M%S.json")
        return ts.strftime("Резервная копия от %d.%m.%Y %H:%M:%S")
    except (ValueError, IndexError):
        return name


def backup_overview_lines():
    backup_files = list_backup_files()
    latest_label = _format_backup_filename(backup_files[0]) if backup_files else "ещё не создавались"
    return [
        f"Последняя копия: {latest_label}",
        f"Профилей сохранено: {peer_storage.count()}",
    ]


