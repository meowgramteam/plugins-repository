def notify_info(message):
    def _show():
        fragment = get_last_fragment()
        if fragment is None:
            logger.debug("notify_info skipped, no active fragment: %s", message)
            return
        BulletinHelper.show_info(f"{PLUGIN_PREFIX}: {message}", fragment)
    run_on_ui_thread(_show)


def notify_success(message):
    def _show():
        fragment = get_last_fragment()
        if fragment is None:
            logger.debug("notify_success skipped, no active fragment: %s", message)
            return
        BulletinHelper.show_success(f"{PLUGIN_PREFIX}: {message}", fragment)
    run_on_ui_thread(_show)


def notify_error(message):
    def _show():
        fragment = get_last_fragment()
        if fragment is None:
            logger.debug("notify_error skipped, no active fragment: %s", message)
            return
        BulletinHelper.show_error(f"{PLUGIN_PREFIX}: {message}", fragment)
    run_on_ui_thread(_show)


def notify_error_copyable(message, copy_text=None):
    # Ошибка с кнопкой «Копировать»: удобно для длинных трейсбеков. copy_text — что
    # реально кладём в буфер (по умолчанию сам текст сообщения). Ниже несколько
    # запасных путей, чтобы на любой сборке хотя бы показать ошибку.
    copy_payload = str(copy_text if copy_text is not None else message)

    def _copy():
        try:
            from android_utils import copy_to_clipboard
            copy_to_clipboard(copy_payload)
            BulletinHelper.show_copied_to_clipboard()
            return
        except Exception:
            logger.debug("copy_to_clipboard failed, trying AndroidUtilities", exc_info=True)
        try:
            from org.telegram.messenger import AndroidUtilities
            if AndroidUtilities.addToClipboard(copy_payload):
                BulletinHelper.show_copied_to_clipboard()
        except Exception:
            logger.error("Failed to copy error text to clipboard", exc_info=True)

    def _show():
        fragment = get_last_fragment()
        if fragment is None:
            logger.debug("notify_error_copyable skipped, no active fragment: %s", message)
            return
        text = f"{PLUGIN_PREFIX}: {message}"
        try:
            from org.telegram.messenger import R
            BulletinHelper.show_with_button(text, R.raw.error, "Копировать", _copy, fragment)
        except Exception:
            # show_with_button/иконка недоступны — деградируем до обычной ошибки.
            logger.error("show_with_button failed, falling back to show_error", exc_info=True)
            BulletinHelper.show_error(text, fragment)
    run_on_ui_thread(_show)


def run_ui(fn):
    run_on_ui_thread(fn)


def run_in_background(fn, *args, **kwargs):
    # Тяжёлый диск/JSON I/O не должен идти на UI-потоке (ANR). notify_* теперь
    # сами диспетчеризуются на UI-поток, поэтому их безопасно звать изнутри.
    def _runner():
        try:
            fn(*args, **kwargs)
        except Exception:
            logger.error("run_in_background: task failed", exc_info=True)
    threading.Thread(target=_runner, name="utilities-bg", daemon=True).start()


def _is_ui_thread():
    # True, если выполняемся на главном (UI) потоке. При ошибке — False,
    # чтобы не терять данные (поведение как раньше).
    try:
        from android.os import Looper
        return Looper.myLooper() is not None and Looper.myLooper() == Looper.getMainLooper()
    except Exception:
        return False


def arraylist_to_list(value):
    return list(value.toArray()) if value and value.size() > 0 else []


def iterable_to_arraylist(items):
    result = ArrayList()
    for item in items:
        result.add(Integer(int(item)))
    return result


def split_list_into_chunks(items, chunk_size):
    return [items[i:i + chunk_size] for i in range(0, len(items), chunk_size)]



def clone_data(value):
    if isinstance(value, dict):
        return {str(key): clone_data(item) for key, item in value.items()}
    if isinstance(value, list):
        return [clone_data(item) for item in value]
    return value


def set_storage_content(storage, content):
    storage.ensure_loaded()
    with storage._lock:
        storage.content = clone_data(content if isinstance(content, dict) else {})


def get_storage_content_copy():
    # Итерация по live-словарю peer_storage.content небезопасна: SavePeerSettingsHook
    # добавляет ключи из фоновых потоков → RuntimeError "dictionary changed size during iteration".
    # Берём поверхностную копию под _lock — этого достаточно для безопасной итерации.
    peer_storage.ensure_loaded()
    with peer_storage._lock:
        return dict(peer_storage.content)


def storage_snapshot():
    peer_storage.ensure_loaded()
    return {
        "peer_records": normalize_peer_dump(get_storage_content_copy()),
    }


def restore_snapshot(snapshot):
    set_storage_content(peer_storage, snapshot.get("peer_records"))
    peer_ok = peer_storage.write()
    return peer_ok


def human_date_from_iso(value):
    if not value:
        return "неизвестно"
    try:
        # Поддержка суффикса 'Z' (UTC): fromisoformat до Python 3.11 его не парсит.
        clean_value = re.sub(r"Z$", "+00:00", str(value))
        return datetime.fromisoformat(clean_value).strftime("%d.%m.%Y %H:%M")
    except Exception:
        return str(value)


def human_size(num_bytes):
    try:
        value = float(num_bytes)
    except Exception:
        return "неизвестно"
    for unit in ("B", "KB", "MB", "GB"):
        if value < 1024.0 or unit == "GB":
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024.0


def hook_all_matching_methods(clazz, method_name, hook_factory, hook_method, preferred_param_counts=None, only_preferred=False):
    try:
        methods = [m for m in clazz.getDeclaredMethods() if m.getName() == method_name]
        if not methods:
            logger.warning("Method not found: %s", method_name)
            return False
        preferred_param_counts = tuple(preferred_param_counts or ())
        if preferred_param_counts:
            preferred = [m for m in methods if m.getParameterCount() in preferred_param_counts]
            fallback = [m for m in methods if m.getParameterCount() not in preferred_param_counts]
            if only_preferred:
                if not preferred:
                    logger.warning("No preferred overload for %s (param counts %s); refusing fallback overloads", method_name, preferred_param_counts)
                    return False
                methods = preferred
            else:
                methods = preferred + fallback
        attached = 0
        for method in methods:
            try:
                method.setAccessible(True)
                hook_instance = hook_factory()
                hook_method(method, hook_instance)
                attached += 1
            except Exception:
                logger.error("Failed to hook overload %s:", method.getName(), exc_info=True)
        return attached > 0
    except Exception:
        logger.error("Failed to hook %s:", method_name, exc_info=True)
        return False


def get_declared_method(clazz, method_name, *param_types):
    if not clazz:
        return None
    try:
        method = clazz.getDeclaredMethod(method_name, *param_types)
        method.setAccessible(True)
        return method
    except Exception:
        logger.error("Failed to resolve %s.%s:", clazz.getName() if hasattr(clazz, "getName") else clazz, method_name, exc_info=True)
        return None


def ensure_chat_activity_class():
    global ChatActivityClass
    if ChatActivityClass:
        return ChatActivityClass
    try:
        ChatActivityClass = RuntimeChatActivity.getClass()
    except Exception:
        logger.error("Failed to resolve ChatActivity via direct import:", exc_info=True)
    if not ChatActivityClass:
        try:
            ChatActivityClass = jclass("org.telegram.ui.ChatActivity").getClass()
        except Exception:
            logger.error("Failed to resolve ChatActivity via jclass:", exc_info=True)
    if not ChatActivityClass:
        try:
            ChatActivityClass = find_class("org.telegram.ui.ChatActivity")
        except Exception:
            logger.error("Failed to resolve ChatActivity via find_class:", exc_info=True)
    return ChatActivityClass


def ensure_messages_controller_class():
    global MessagesControllerClass, MessagesControllerClassSource
    if MessagesControllerClass:
        return MessagesControllerClass
    try:
        controller = get_messages_controller()
        if controller is not None:
            MessagesControllerClass = controller.getClass()
            MessagesControllerClassSource = "instance_class"
    except Exception:
        logger.error("Failed to resolve MessagesController from runtime instance:", exc_info=True)
    if not MessagesControllerClass:
        try:
            MessagesControllerClass = jclass("org.telegram.messenger.MessagesController").getClass()
            MessagesControllerClassSource = "jclass"
        except Exception:
            logger.error("Failed to resolve MessagesController via jclass:", exc_info=True)
    if not MessagesControllerClass:
        try:
            MessagesControllerClass = find_class("org.telegram.messenger.MessagesController")
            MessagesControllerClassSource = "find_class"
        except Exception:
            logger.error("Failed to resolve MessagesController via find_class:", exc_info=True)
    if not MessagesControllerClass:
        MessagesControllerClassSource = None
        logger.warning("MessagesController class not found")
    return MessagesControllerClass


def ensure_message_object_class():
    global MessageObjectClass
    if MessageObjectClass:
        return MessageObjectClass
    MessageObjectClass = find_class("org.telegram.messenger.MessageObject")
