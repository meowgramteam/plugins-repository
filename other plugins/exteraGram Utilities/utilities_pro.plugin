# Storage
# ─────────────────────────────────────────────────────────────

class JsonStorage:
    def __init__(self, name, default=None, compress=True, legacy_specs=None):
        self.name = name
        self.default = default if default is not None else {}
        self.compress = compress
        self.legacy_specs = legacy_specs
        self.content = self._copy_default()
        self._lock = threading.RLock()
        self._write_lock = threading.Lock()  # сериализует запись на диск, не блокируя читателей content
        self.loaded = False
        self.selected_path = None
        self.selected_source = "current"
        self.last_scan = []
        self._cached_path = None

    def _copy_default(self):
        return dict(self.default) if isinstance(self.default, dict) else self.default

    def path(self):
        if self._cached_path:
            return self._cached_path
        base = get_app_files_dir_path()
        suffix = ".jsonz" if self.compress else ".json"
        path = os.path.join(base, "plugins_data", self.name + suffix)
        if "cache" not in path:
            self._cached_path = path
        return path

    def legacy_paths(self):
        if self.legacy_specs is not None:
            return list(self.legacy_specs)
        files_dir = get_app_files_dir_path()
        return [
            ("legacy_utilities_root_jsonz", os.path.join(files_dir, self.name + ".jsonz"), "gzip_json"),
            ("legacy_utilities_root_json", os.path.join(files_dir, self.name + ".json"), "json"),
            ("user_info_saver_root", os.path.join(files_dir, OLD_PEER_STORAGE_NAME), "zlib_json"),
        ]

    def candidate_paths(self):
        candidates = [("current", self.path(), "gzip_json" if self.compress else "json")]
        candidates.extend(self.legacy_paths())
        old_cache_path = get_old_cache_path()
        if self.name == PEER_STORAGE_NAME and old_cache_path:
            candidates.append(("user_info_saver_cache", old_cache_path, "zlib_json"))
        return candidates

    def _read_payload_by_format(self, path, fmt):
        if fmt == "gzip_json":
            with gzip.open(path, "rt", encoding="utf-8") as file:
                return json.load(file)
        if fmt == "json":
            with open(path, "r", encoding="utf-8") as file:
                return json.load(file)
        if fmt == "zlib_json":
            return read_maybe_zlib_json(path)
        raise ValueError(f"unknown_storage_format:{fmt}")

    def _read_candidate(self, path, fmt):
        data = self._read_payload_by_format(path, fmt)
        if not isinstance(data, dict):
            return {}
        normalized = {}
        for key, value in data.items():
            if not isinstance(value, dict):
                continue
            key_str = str(key)
            # Служебные ключи вида __..__ должны переживать цикл write->read симметрично
            # записи. Из подсчёта профилей они всё равно исключены
            # normalize_peer_dump()/is_user_dialog().
            if key_str.startswith("__") and key_str.endswith("__"):
                normalized[key_str] = value
                continue
            try:
                if int(key_str) <= 0:
                    continue
            except (ValueError, TypeError):
                continue
            normalized[key_str] = value
        return normalized

    def inspect_candidates(self):
        diagnostics = []
        for source, path, fmt in self.candidate_paths():
            entry = {
                "source": source,
                "path": path,
                "format": fmt,
                "exists": bool(path and os.path.exists(path)),
                "count": 0,
                "error": None,
            }
            if entry["exists"]:
                try:
                    data = self._read_candidate(path, fmt)
                    entry["count"] = len(data)
                    entry["_data"] = data
                except Exception:
                    entry["error"] = "read_failed"
                    logger.error("Failed to inspect storage candidate %s:", path, exc_info=True)
            diagnostics.append(entry)
        self.last_scan = diagnostics
        return diagnostics

    def _pick_existing_data(self):
        diagnostics = self.inspect_candidates()
        merged = {}
        selected_source = "current"
        selected_path = self.path()
        precedence = [entry for entry in diagnostics if entry["exists"] and not entry["error"] and entry["count"] > 0]
        merge_order = list(reversed(precedence))
        for entry in merge_order:
            try:
                data = entry.get("_data")
                if data is None:
                    data = self._read_candidate(entry["path"], entry["format"])
                merged.update(data)
            except Exception:
                logger.error("Failed to merge storage candidate %s:", entry["path"], exc_info=True)
        if precedence:
            selected_source = precedence[0]["source"]
            selected_path = precedence[0]["path"]
        return merged, selected_source, selected_path, diagnostics

    def read(self, trigger="explicit_reload"):
        try:
            data, selected_source, selected_path, diagnostics = self._pick_existing_data()
            with self._lock:
                self.content = data if isinstance(data, dict) and data else self._copy_default()
                self.selected_source = selected_source
                self.selected_path = selected_path
                self.loaded = True  # флаг ставим строго под локом (для double-checked locking)
            self.last_scan = diagnostics
            return bool(self.content)
        except Exception:
            with self._lock:
                self.content = self._copy_default()
                self.selected_source = "current"
                self.selected_path = self.path()
            return False

    def ensure_loaded(self):
        if not self.loaded:
            with self._lock:  # DCL: ждём, если другой поток уже грузит хранилище
                if not self.loaded:  # двойная проверка после захвата лока
                    self.read(trigger="initial_load")
        elif self._cached_path and self.selected_path and "cache" in self.selected_path:
            with self._lock:
                if self.selected_path and "cache" in self.selected_path:  # перепроверка под локом
                    self.read(trigger="ensure_loaded_cache_reread")

    def write(self):
        if not self.loaded and not self.content:
            logger.error("Refusing to write empty content: storage never successfully loaded")
            return False
        with self._lock:
            # Глубокая копия: json.dump идёт вне content-лока, а content содержит вложенные словари.
            content_snapshot = clone_data(self.content)
        path = self.path()
        # _write_lock сериализует писателей: без него два потока пишут в один temp и портят GZIP.
        with self._write_lock:
            # Уникальный temp на каждую запись — дополнительная страховка от коллизий.
            temp_path = "%s.%d.%d.tmp" % (path, os.getpid(), threading.get_ident())
            try:
                os.makedirs(os.path.dirname(path), exist_ok=True)
                if self.compress:
                    with gzip.open(temp_path, "wt", encoding="utf-8") as file:
                        json.dump(content_snapshot, file, ensure_ascii=False, separators=(",", ":"))
                else:
                    with open(temp_path, "w", encoding="utf-8") as file:
                        json.dump(content_snapshot, file, ensure_ascii=False, separators=(",", ":"))
                os.replace(temp_path, path)
                with self._lock:  # стейт читается/пишется в read()/ensure_loaded() под _lock
                    self.loaded = True
                    self.selected_path = path
                    self.selected_source = "current"
                return True
            except Exception:
                logger.error("Failed to write storage %s:", path, exc_info=True)
                try:
                    if os.path.exists(temp_path):
                        os.remove(temp_path)
                except Exception:
                    pass
                return False

    def cleanup_stale_temp_files(self):
        # OOM-килл ровно во время json.dump оставляет .tmp навсегда; подчищаем их при загрузке.
        try:
            path = self.path()
            directory = os.path.dirname(path)
            prefix = os.path.basename(path) + "."
            if not directory or not os.path.isdir(directory):
                return
            for name in os.listdir(directory):
                if name.startswith(prefix) and name.endswith(".tmp"):
                    try:
                        os.remove(os.path.join(directory, name))
                    except Exception:
                        pass
        except Exception:
            logger.error("Failed to clean stale temp files", exc_info=True)

    def count(self):
        self.ensure_loaded()
        return len(self.content) if isinstance(self.content, dict) else 0


peer_storage = JsonStorage(PEER_STORAGE_NAME, default={}, compress=True)


def normalize_peer_dump(data):
    if not isinstance(data, dict):
        return {}
    normalized = {}
    for key, value in data.items():
        if not isinstance(value, dict):
            continue
        key_str = str(key)
        if not is_user_dialog(key_str):
            continue
        normalized[key_str] = value
    return normalized


# ─────────────────────────────────────────────────────────────
# Migration and backup
# ──────────────────────────────────────────────────────────────

def get_old_cache_path():
    try:
        return os.path.join(get_plugins_dir(), "cache", OLD_PEER_STORAGE_NAME)
    except Exception:
        return None


def read_maybe_zlib_json(path):
    with open(path, "rb") as file:
        raw = file.read()
    if not raw:
        return {}
    is_zlib = len(raw) >= 2 and (raw[0] & 0x0F) == 8 and (raw[0] * 256 + raw[1]) % 31 == 0
    if is_zlib:
        try:
            raw = zlib.decompress(raw)
        except Exception:
            logger.error("read_maybe_zlib_json: zlib.decompress failed", exc_info=True)
            return {}
    try:
        return normalize_peer_dump(json.loads(raw.decode("utf-8", errors="replace")))
    except Exception:
        logger.error("read_maybe_zlib_json: JSON parse failed", exc_info=True)
        return {}


def _pluralize_records(n):
    n100 = abs(n) % 100
    if 11 <= n100 <= 19:
        return f"{n} записей"
    n10 = n100 % 10
    if n10 == 1:
        return f"{n} запись"
    if 2 <= n10 <= 4:
        return f"{n} записи"
    return f"{n} записей"


def _pluralize_empty_profiles(n):
    n100 = abs(n) % 100
    if 11 <= n100 <= 19:
        return "пустых профилей"
    n10 = n100 % 10
    if n10 == 1:
        return "пустой профиль"
    if 2 <= n10 <= 4:
        return "пустых профиля"
    return "пустых профилей"


def import_peer_dump(data):
    normalized = normalize_peer_dump(data)
    normalized = {key: value for key, value in normalized.items() if is_meaningful_peer_dump(value)}
    if not normalized:
        return 0
    peer_storage.ensure_loaded()
    # _lock держится лишь миллисекунды (I/O ушёл под _write_lock), поэтому блокирующий
    # захват безопасен и не подвесит UI, зато не даст «Восстановить» молча отвалиться.
    with peer_storage._lock:
        # Снимаем глубокую копию прежних значений: rollback не должен восстанавливать
        # возможно-мутировавшую ссылку и ломать консистентность памяти.
        old_values = {k: clone_data(peer_storage.content[k]) for k in normalized if k in peer_storage.content}
        peer_storage.content.update(normalized)
    # Файловый I/O — вне RLock, чтобы не блокировать чтение настроек на UI-потоке.
    # write() сам снимает согласованный deep-copy снимок под своим локом.
    try:
        if not peer_storage.write():
            raise RuntimeError("storage_write_failed")
    except Exception:
        # Запись на диск не удалась → откатываем ровно те ключи, что импортировали,
        # чтобы память не расходилась с диском (фоновый воркер/unload не запишет чужой импорт).
        with peer_storage._lock:
            for k in normalized:
                if k in old_values:
                    peer_storage.content[k] = old_values[k]
                else:
                    peer_storage.content.pop(k, None)
        logger.error("import_peer_dump: write failed, rolled back in-memory import", exc_info=True)
        raise
    return len(normalized)


def is_meaningful_peer_dump(dumped):
    if not isinstance(dumped, dict):
        return False
    if any(dumped.get(field) not in (None, "", 0, False) for field in PRECIOUS_PEER_FIELDS):
        return True
    for field in IMPORTANT_PEER_STATE_FIELDS:
        value = dumped.get(field)
        if isinstance(value, bool) and value:
            return True
        if value not in (None, "", 0, False):
            return True
    for key, value in dumped.items():
        if key in PRECIOUS_PEER_FIELDS or key in IMPORTANT_PEER_STATE_FIELDS:
            continue
        if isinstance(value, bool) and value:
            return True
        if value not in (None, "", 0, False):
            return True
    return False


def is_user_dialog(dialog_id):
    try:
        return int(dialog_id) > 0
    except Exception:
        return False


def get_user_peer_settings_map(msg_controller):
    try:
        return get_private_field(msg_controller, FIELD_USER_PEER_SETTINGS)
    except Exception:
        return None


def cache_restored_peer_settings(msg_controller, dialog_id, settings):
    if not msg_controller or not settings or not is_user_dialog(dialog_id):
        return False
    try:
        user_peer_settings = get_user_peer_settings_map(msg_controller)
        if not user_peer_settings:
            return False
        user_peer_settings.put(dialog_id, settings)
        return True
    except Exception:
        logger.error("Failed to cache restored peer settings for %s", dialog_id, exc_info=True)
        return False


def migrate_old_storage(delete_after_success=True):
    old_path = get_old_cache_path()
    if not old_path or not os.path.exists(old_path):
        return 0
    data = read_maybe_zlib_json(old_path)
    count = import_peer_dump(data)
    if count and delete_after_success:
        try:
            os.remove(old_path)
        except Exception:
            logger.error("Failed to delete old storage after migration:", exc_info=True)
    return count


def inspect_old_storage():
    old_path = get_old_cache_path()
    try:
        if not old_path or not os.path.exists(old_path):
            return {"exists": False, "count": 0, "path": old_path, "error": None}
        count = len(read_maybe_zlib_json(old_path))
        return {"exists": True, "count": count, "path": old_path, "error": None}
    except Exception:
        logger.error("Failed to inspect old storage:", exc_info=True)
        return {"exists": False, "count": 0, "path": old_path, "error": "inspect_failed"}


def migrate_resolved_legacy_storage():
    peer_storage.ensure_loaded()
    selected_path = peer_storage.selected_path
    if not selected_path or selected_path == peer_storage.path():
        return 0
    if not peer_storage.count():
        return 0
    if not peer_storage.write():
        raise RuntimeError("storage_write_failed")
    return peer_storage.count()


def migrate_detected_legacy_now():
    try:
        migrated = migrate_resolved_legacy_storage()
        if migrated > 0:
            notify_success(f"Перенесено {_pluralize_records(migrated)} в текущее хранилище")
        else:
            notify_info("Активное хранилище уже текущее или перенос не требуется")
    except Exception:
        logger.error("Resolved legacy migration failed:", exc_info=True)
        notify_error("Ошибка переноса в текущее хранилище")


def import_old_storage_now():
    try:
        imported = migrate_old_storage(delete_after_success=False)
        if imported > 0:
            notify_success(f"Импортировано {_pluralize_records(imported)}")
        else:
            notify_info("Старые данные не найдены или уже пусты")
    except Exception:
        logger.error("Migration failed:", exc_info=True)
        notify_error("Ошибка миграции старых данных")


def build_backup_payload():
    snapshot = storage_snapshot()
    return {
        "plugin": __id__,
        "version": __version__,
        "created_at": datetime.now().isoformat(timespec="seconds"),
        "records": snapshot["peer_records"],
    }


def write_backup_payload(payload, filename=None):
    backup_dir = get_backup_dir()
    os.makedirs(backup_dir, exist_ok=True)
    filename = filename or (BACKUP_PREFIX + datetime.now().strftime("%Y%m%d_%H%M%S") + ".json")
    path = os.path.join(backup_dir, filename)
    # Атомарная запись: пишем в уникальный temp в той же директории и подменяем через
    # os.replace. Краш посреди json.dump не оставит обрезанный/повреждённый файл на месте
    # прежнего — целевой path либо старый, либо полностью новый. Важно для ротации, где
    # свежая копия перезаписывается перед удалением старых.
    temp_path = "%s.%d.%d.tmp" % (path, os.getpid(), threading.get_ident())
    try:
        with open(temp_path, "w", encoding="utf-8") as file:
            json.dump(payload, file, ensure_ascii=False, indent=2)
        os.replace(temp_path, path)
    except Exception:
        try:
            if os.path.exists(temp_path):
                os.remove(temp_path)
        except Exception:
            pass
        raise
    return path, filename


def export_backup(silent=False, filename=None, payload=None):
    try:
        payload = payload or build_backup_payload()
        _path, written_name = write_backup_payload(payload, filename=filename)
        removed = 0
        # Ротацию применяем только к пользовательским/авто копиям (filename не задан),
        # но не к safety-копиям (autosave/wipe/optimize/repair — у них явное имя).
        if filename is None:
            try:
                S.load()
                if S.backup_rotation_enabled:
                    keep = _ROTATION_KEEP_OPTIONS[S.backup_rotation_keep] if 0 <= S.backup_rotation_keep < len(_ROTATION_KEEP_OPTIONS) else 10
                    removed = rotate_backups_with_merge(keep)
            except Exception:
                logger.error("Backup rotation failed:", exc_info=True)
        if not silent:
            message = f"Резервная копия создана\n{written_name}"
            if removed:
                message += f"\nСтарых копий слито и удалено: {removed}"
            run_ui(lambda: notify_success(message))
        return written_name
    except Exception:
        logger.error("Export failed:", exc_info=True)
        if not silent:
            run_ui(lambda: notify_error("Ошибка экспорта"))
        raise


def list_backup_files():
    backup_dir = get_backup_dir()
    if not os.path.exists(backup_dir):
        return []
    # Only user backups (timestamp-only names); safety copies like
    # *_wipe_/_autosave_/_optimize_/_repair_ are excluded from the restore list.
    pattern = re.compile(r"^" + re.escape(BACKUP_PREFIX) + r"\d{8}_\d{6}\.json$")
    files = [name for name in os.listdir(backup_dir) if pattern.match(name)]
    return sorted(files, reverse=True)


def backup_file_path(filename):
    return os.path.join(get_backup_dir(), filename)


def cleanup_stale_backup_temp_files():
    # Краш ровно между json.dump и os.replace в write_backup_payload может оставить
    # осиротевший .tmp в папке копий. list_backup_files их не показывает (регуляр требует
    # .json на конце), но подметаем при случае, чтобы не копить мусор в Downloads.
    try:
        backup_dir = get_backup_dir()
        if not os.path.isdir(backup_dir):
            return
        for name in os.listdir(backup_dir):
            if name.startswith(BACKUP_PREFIX) and name.endswith(".tmp"):
                try:
                    os.remove(os.path.join(backup_dir, name))
                except Exception:
                    pass
    except Exception:
        logger.error("Failed to clean stale backup temp files", exc_info=True)


def read_backup_file(path):
    try:
        with open(path, "r", encoding="utf-8") as file:
            payload = json.load(file)
    except Exception as e:
        logger.error("Failed to parse backup %s: %s", path, e)
        # Пустышка, чтобы UI отрендерил повреждённый файл и дал его удалить/перезаписать.
        payload = {"records": {}, "created_at": "ОШИБКА ЧТЕНИЯ", "corrupted": True}
    peer_records = {}
    if isinstance(payload, dict):
        if isinstance(payload.get("records"), dict):
            peer_records = normalize_peer_dump(payload["records"])
        else:
            peer_records = normalize_peer_dump(payload)
    else:
        peer_records = normalize_peer_dump(payload)
    return {
        "peer_records": peer_records,
        "raw": payload,
    }


def backup_file_summary(filename):
    path = backup_file_path(filename)
    try:
        stat = os.stat(path)
    except FileNotFoundError:
        return {"filename": filename, "path": path, "size_bytes": 0, "size_label": "0 B",
                "created_at": "", "created_label": "файл не найден",
                "peer_count": 0, "version": "", "plugin": __id__}
    backup = read_backup_file(path)
    raw = backup["raw"] if isinstance(backup.get("raw"), dict) else {}
    return {
        "filename": filename,
        "path": path,
        "size_bytes": stat.st_size,
        "size_label": human_size(stat.st_size),
        "created_at": raw.get("created_at") or datetime.fromtimestamp(stat.st_mtime).isoformat(timespec="seconds"),
        "created_label": human_date_from_iso(raw.get("created_at")) if raw.get("created_at") else datetime.fromtimestamp(stat.st_mtime).strftime("%d.%m.%Y %H:%M"),
        "peer_count": len(backup["peer_records"]),
        "version": raw.get("version") or "неизвестно",
        "plugin": raw.get("plugin") or __id__,
    }


def merge_peer_records(current, incoming, prefer_current=False):
    # Объединение записей двух источников.
    #  - prefer_current=False (по умолчанию): значения incoming побеждают при конфликте,
    #    но пустой incoming не стирает непустые precious-поля из current. На этом историческом
    #    поведении держатся ротация копий и оптимизация (там «новее побеждает»).
    #  - prefer_current=True (восстановление в режиме «Объединить»): merge строго ДОБАВЛЯЮЩИЙ.
    #    Любое осмысленное значение, уже лежащее в хранилище, копией не перезаписывается —
    #    копия лишь заполняет пустые/отсутствующие поля и добавляет отсутствующие профили.
    #    Так «Объединить» не может понизить, затереть или потерять актуальные данные.
    merged = normalize_peer_dump(current)
    for key, value in normalize_peer_dump(incoming).items():
        existing = merged.get(key)
        if not isinstance(existing, dict):
            merged[key] = clone_data(value)
            continue
        combined = clone_data(existing)
        if prefer_current:
            # Только пробелы: непустое значение из current остаётся нетронутым.
            for field, new_val in value.items():
                if combined.get(field) in (None, "", 0, False) and new_val not in (None, "", 0, False):
                    combined[field] = new_val
        else:
            combined.update(value)
            for field in PRECIOUS_PEER_FIELDS:
                if not combined.get(field):
                    old_value = existing.get(field)
                    if old_value not in (None, "", 0, False):
                        combined[field] = old_value
        if is_meaningful_peer_dump(combined):
            merged[key] = combined
    return {key: value for key, value in merged.items() if is_meaningful_peer_dump(value)}


def _is_backup_corrupted(backup_data):
    raw = backup_data.get("raw") if isinstance(backup_data, dict) else None
    return isinstance(raw, dict) and bool(raw.get("corrupted"))


def rotate_backups_with_merge(keep_count):
    # Держим не больше keep_count пользовательских копий. Прежде чем удалить лишние
    # старые, сливаем их уникальные записи в самую свежую копию — так ничего ценного
    # из старых бэкапов не пропадает. Safety-копии в list_backup_files не попадают.
    files = list_backup_files()  # новейшие первые
    if keep_count <= 0 or len(files) <= keep_count:
        return 0
    keep = files[:keep_count]
    stale = files[keep_count:]
    # Сливаем старые от самой старой к более новой, чтобы новее имело приоритет.
    merged_stale = {}
    for name in reversed(stale):
        try:
            data = read_backup_file(backup_file_path(name))
            if _is_backup_corrupted(data):
                continue  # повреждённую копию не подмешиваем
            merged_stale = merge_peer_records(merged_stale, data["peer_records"])
        except Exception:
            logger.error("rotate: failed to read stale backup %s", name, exc_info=True)
    newest_name = keep[0]
    try:
        newest = read_backup_file(backup_file_path(newest_name))
    except Exception:
        logger.error("rotate: failed to read newest backup %s, skipping rotation", newest_name, exc_info=True)
        return 0
    if _is_backup_corrupted(newest):
        # Свежая копия повреждена — не рискуем сливать в неё и удалять старые.
        logger.warning("rotate: newest backup %s is corrupted, rotation skipped", newest_name)
        return 0
    final_records = merge_peer_records(newest["peer_records"], merged_stale)
    newest_raw = newest["raw"] if isinstance(newest.get("raw"), dict) else {}
    payload = {
        "plugin": __id__,
        "version": newest_raw.get("version") or __version__,
        "created_at": newest_raw.get("created_at") or datetime.now().isoformat(timespec="seconds"),
        "records": final_records,
        "rotation_merged_count": len(stale),
    }
    # Сначала перезаписываем свежую копию слитым содержимым, и только потом удаляем
    # старые: сбой записи оставит все файлы на месте, данные не потеряются.
    try:
        write_backup_payload(payload, filename=newest_name)
    except Exception:
        logger.error("rotate: failed to write merged newest backup, rotation aborted", exc_info=True)
        return 0
    removed = 0
    for name in stale:
        try:
            os.remove(backup_file_path(name))
            removed += 1
        except Exception:
            logger.error("rotate: failed to delete stale backup %s", name, exc_info=True)
    return removed


_auto_backup_lock = threading.Lock()


def _maybe_run_auto_backup():
    # Тихий бэкап по расписанию. Зовётся из фоновых потоков (загрузка плагина, RESUME),
    # поэтому дисковый I/O здесь безопасен. Не мешает пользовательским копиям.
    S.load()
    if not S.auto_backup_enabled:
        return
    if not _auto_backup_lock.acquire(blocking=False):
        return
    try:
        cleanup_stale_backup_temp_files()  # подметаем осиротевшие .tmp от прерванных записей
        peer_storage.ensure_loaded()
        if peer_storage.count() <= 0:
            return  # нечего сохранять — метку не двигаем, попробуем позже
        idx = S.auto_backup_interval
        interval_days = _AUTO_BACKUP_DAYS[idx] if 0 <= idx < len(_AUTO_BACKUP_DAYS) else 7
        now = time.time()
        try:
            last = float(S.get("last_auto_backup", "0") or "0")
        except Exception:
            last = 0.0
        if last and (now - last) < interval_days * 86400:
            return
        # export_backup с filename=None сам применит ротацию, если она включена.
        written = export_backup(silent=True)
        S.set("last_auto_backup", str(now))
        logger.info("Auto-backup created: %s", written)
    except Exception:
        logger.error("Auto-backup failed:", exc_info=True)
    finally:
        _auto_backup_lock.release()


def share_backup_file(filename):
    # Открывает системный диалог «Поделиться» для файла копии (перенос на другое устройство).
    try:
        path = backup_file_path(filename)
        if not os.path.isfile(path):
            notify_error("Файл копии не найден")
            return
        context = get_activity_context()
        if not context:
            notify_error("Нет активного окна для отправки")
            return

        def _share():
            try:
                authority = ApplicationLoader.getApplicationId() + ".provider"
                uri = FileProvider.getUriForFile(context, authority, File(path))
                intent = Intent(Intent.ACTION_SEND)
                intent.setType("application/json")
                intent.putExtra(Intent.EXTRA_STREAM, uri)
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                chooser = Intent.createChooser(intent, "Поделиться копией")
                chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                context.startActivity(chooser)
            except Exception:
                logger.error("Failed to share backup %s", filename, exc_info=True)
                notify_error("Не удалось открыть диалог отправки")

        run_ui(_share)
    except Exception:
        logger.error("share_backup_file failed:", exc_info=True)
        notify_error("Ошибка отправки копии")


def share_latest_backup():
    files = list_backup_files()
    if not files:
        notify_info("Резервные копии не найдены")
        return
    share_backup_file(files[0])


def verify_storage_state(expected_peer):
    try:
        fmt = "gzip_json" if peer_storage.compress else "json"
        data = peer_storage._read_candidate(peer_storage.path(), fmt)
    except Exception:
        return False
    return normalize_peer_dump(data) == normalize_peer_dump(expected_peer)


def apply_storage_transaction(peer_content, safety_prefix=None):
    snapshot = storage_snapshot()
    safety_name = None
    try:
        if safety_prefix:
            safety_name = export_backup(
                silent=True,
                filename=BACKUP_PREFIX + safety_prefix + "_" + datetime.now().strftime("%Y%m%d_%H%M%S") + ".json",
            )
        final_peer = normalize_peer_dump(peer_content)
        set_storage_content(peer_storage, final_peer)
        if not peer_storage.write():
            raise RuntimeError("write_failed")
        if not verify_storage_state(final_peer):
            raise RuntimeError("verify_failed")
        return {
            "peer": final_peer,
            "safety_backup": safety_name,
            "snapshot": snapshot,
        }
    except Exception:
        rollback_ok = restore_snapshot(snapshot)
        if not rollback_ok:
            logger.error("Rollback write failed during apply_storage_transaction")
        raise


def import_backup_payload(backup_data, mode="replace"):
    raw = backup_data.get("raw") if isinstance(backup_data, dict) else None
    if isinstance(raw, dict) and raw.get("corrupted"):
        # Повреждённый бэкап нельзя импортировать: иначе «восстановление» затрёт данные пустышкой.
        raise RuntimeError("backup_corrupted")
    snapshot = storage_snapshot()
    incoming_peer = backup_data["peer_records"]
    if mode == "replace":
        final_peer = normalize_peer_dump(incoming_peer)
    else:
        # Восстановление «Объединить» — строго добавляющее: копия заполняет пробелы и
        # добавляет отсутствующие профили, но не перезаписывает актуальные данные в хранилище.
        final_peer = merge_peer_records(snapshot["peer_records"], incoming_peer, prefer_current=True)
    result = apply_storage_transaction(final_peer, safety_prefix="autosave")
    return {
        "peer_count": len(result["peer"]),
        "safety_backup": result["safety_backup"],
    }


def import_backup_file(filename, mode):
    path = backup_file_path(filename)
    try:
        backup_data = read_backup_file(path)
        result = import_backup_payload(backup_data, mode)
        run_ui(lambda: notify_success(
            f"Импорт завершён: {result['peer_count']} профилей\nСтраховочная копия: {result['safety_backup']}"
        ))
        return result
    except Exception:
        logger.error("Import failed:", exc_info=True)
        run_ui(lambda: notify_error("Ошибка импорта, выполнен откат"))
        return None


def wipe_saved_peer_data():
    def confirm(_, __):
        try:
            result = apply_storage_transaction({}, safety_prefix="wipe")
            notify_success(f"Сохранённые данные очищены\nСтраховочная копия: {result['safety_backup']}")
        except Exception:
            logger.error("Wipe failed:", exc_info=True)
            notify_error("Не удалось очистить данные, выполнен откат")

    show_alert(
        "Очистить данные?",
        "Будут удалены только данные UtilitiesPro. Файлы резервных копий и старые плагины не затрагиваются.",
        buttons=[
            ("positive", "Очистить", lambda _a, _b: run_in_background(confirm, _a, _b)),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


def clean_empty_profiles():
    def confirm(_, __):
        try:
            peer_storage.ensure_loaded()
            with peer_storage._lock:
                before = len(peer_storage.content)
                empty_keys = [k for k, v in peer_storage.content.items()
                              if not is_meaningful_peer_dump(v)]
                old_entries = {k: peer_storage.content[k] for k in empty_keys}
                for k in empty_keys:
                    del peer_storage.content[k]
                write_ok = peer_storage.write()
                if not write_ok:
                    for k, v in old_entries.items():
                        peer_storage.content[k] = v
                    notify_error("Не удалось записать изменения, данные восстановлены")
                    return
            notify_success(f"Удалено пустых профилей: {len(empty_keys)} из {before}")
        except Exception:
            logger.error("Clean empty profiles failed:", exc_info=True)
            peer_storage.ensure_loaded()
            notify_error("Не удалось очистить пустые профили")

    peer_storage.ensure_loaded()
    empty_count = sum(1 for v in get_storage_content_copy().values()
                      if not is_meaningful_peer_dump(v))
    if empty_count == 0:
        notify_info("Пустых профилей не найдено")
        return
    show_alert(
        "Очистить пустые профили?",
        f"Найдено {empty_count} {_pluralize_empty_profiles(empty_count)}, в которых нет полезных данных. "
        "Будут удалены только пустые профили — все ценные данные сохранятся.",
        buttons=[
            ("positive", "Очистить", lambda _a, _b: run_in_background(confirm, _a, _b)),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


def delete_saved_peer_data(dialog_id):
    if not is_user_dialog(dialog_id):
        return False
    peer_storage.ensure_loaded()
    dialog_key = str(dialog_id)
    with peer_storage._lock:
        if dialog_key not in peer_storage.content:
            return False
        old_value = peer_storage.content.get(dialog_key)
        del peer_storage.content[dialog_key]
    ok = peer_storage.write()
    if ok:
        notify_success(f"Данные профиля {dialog_id} удалены")
    else:
        with peer_storage._lock:
            if old_value is not None:
                peer_storage.content[dialog_key] = old_value
        notify_error("Ошибка при удалении данных профиля")
    return ok


# ───────────────────────────────────────────────────────────────
# Forward/delete limit bypass
# ───────────────────────────────────────────────────────────────

def ensure_chat_activity_methods():
    global ChatActivityClass, hide_action_mode_method, update_pinned_msg_view_method
    if ChatActivityClass:
        return True
    try:
        ChatActivityClass = ensure_chat_activity_class()
        if not ChatActivityClass:
            return False
        hide_action_mode_method = get_declared_method(ChatActivityClass, "hideActionMode")
        if not hide_action_mode_method:
            return False
        update_pinned_msg_view_method = get_declared_method(ChatActivityClass, "updatePinnedMessageView", Boolean.TYPE)
        if not update_pinned_msg_view_method:
            return False
        return True
    except Exception:
        logger.error("Failed to resolve ChatActivity methods:", exc_info=True)
        return False


def get_selected_msgs_array_index(param):
    if not param.args or param.args[0] is None:
        return 0
    message_object = param.args[0]
    current_dialog_id = get_private_field(param.thisObject, FIELD_DIALOG_ID)
    return int(message_object.getDialogId() != current_dialog_id)


def get_sparsearray_keys(sparse_array):
    return [] if sparse_array is None else [sparse_array.keyAt(i) for i in range(sparse_array.size())]


def get_actions_buttons_layout(chat_activity):
    return get_private_field(chat_activity, FIELD_ACTIONS_BUTTONS_LAYOUT)


def update_reply_button_visibility(chat_activity, should_show):
    actions_buttons_layout = get_actions_buttons_layout(chat_activity)
    if actions_buttons_layout:
        actions_buttons_layout.showReplyButton(should_show, True)


def update_select_button_visibility(chat_activity):
    java_msgs_sparse = get_private_field(chat_activity, FIELD_SELECTED_MESSAGES_IDS)
    messages = get_private_field(chat_activity, FIELD_MESSAGES)
    actions_buttons_layout = get_actions_buttons_layout(chat_activity)
    if actions_buttons_layout is None or java_msgs_sparse is None or messages is None:
        return

    java_msgs_main = java_msgs_sparse[0]
    if java_msgs_main is None:
        return
    new_select_visibility = View.GONE
    if java_msgs_main.size() > 1:
        all_selected_msg_ids = get_sparsearray_keys(java_msgs_main) + get_sparsearray_keys(java_msgs_sparse[1])
        all_selected_msg_ids.sort()
        if all_selected_msg_ids:
            begin = all_selected_msg_ids[0]
            end = all_selected_msg_ids[-1]
            for i in range(messages.size()):
                msg = messages.get(i)
                if msg is None:
                    continue
                msg_id = msg.getId()
                if begin < msg_id < end and java_msgs_main.indexOfKey(msg_id) < 0 and msg.contentType == 0:
                    new_select_visibility = View.VISIBLE
                    break
    try:
        select_button = get_private_field(chat_activity, FIELD_SELECT_BUTTON_ANIMATION)
        if select_button is None:
            select_button = get_private_field(actions_buttons_layout, FIELD_SELECT_BUTTON_ANIMATION)
        if select_button is not None:
            select_button.setVisibility(new_select_visibility)
    except Exception:
        logger.error("Failed to apply select button visibility:", exc_info=True)


def cancel_selection_mode(chat_activity):
    if hide_action_mode_method:
        hide_action_mode_method.invoke(chat_activity)
    if update_pinned_msg_view_method:
        update_pinned_msg_view_method.invoke(chat_activity, [True])


def decrement_private_counter(chat_activity, field_name, target_field_name=None):
    value = get_private_field(chat_activity, field_name)
    if value is None:
        return
    value = max(0, int(value) - 2)
    set_private_field(chat_activity, field_name, Integer(value))
    if value == 0 and target_field_name:
        target = get_private_field(chat_activity, target_field_name)
        if target:
            target.setEnabled(True)
            target.setAlpha(1.0)


class SelectorHook(MethodHook):
    def __init__(self):
        super().__init__()
        self.messages_array = {}
        self.is_processing_msg_group = False
        self.is_last_in_group = False
        self.handle_end_of_select_msg_group_call = False
        self._group_dialog_id = None

    def _ensure_correct_dialog(self, chat_activity):
        dialog_id = str(get_private_field(chat_activity, FIELD_DIALOG_ID))
        if dialog_id != self._group_dialog_id:
            self.is_processing_msg_group = False
            self.is_last_in_group = False
            self.handle_end_of_select_msg_group_call = False
            self._group_dialog_id = dialog_id
        # Защита от утечки: держим в памяти выделение только текущего чата,
        # чтобы MessageObject/ChatActivity не зависали при выходе из чата свайпом.
        if self.messages_array:
            for stale in [k for k in self.messages_array if k != dialog_id]:
                self.messages_array.pop(stale, None)

    def before_hooked_method(self, param):
        if not S.enable_forward_bypass:
            return
        try:
            chat_activity = param.thisObject
            if chat_activity is None or len(param.args) < 3:
                return
            self._ensure_correct_dialog(chat_activity)
            selected_msg_obj = param.args[0]
            if selected_msg_obj is None:
                return
            tapped_outside = param.args[1]
            is_last = param.args[2]
            is_grouped = selected_msg_obj.getGroupId() != 0
            if self.is_processing_msg_group:
                self.is_last_in_group = is_last
                return
            if tapped_outside and is_last and is_grouped:
                self.is_processing_msg_group = True
            index = get_selected_msgs_array_index(param)
            java_msgs_sparse = get_private_field(chat_activity, FIELD_SELECTED_MESSAGES_IDS)
            if java_msgs_sparse is None:
                return
            try:
                java_msgs_sparse[index] = param.thisObject.SparseArrayWithTouch()
            except Exception:
                from java import jclass
                SparseArray = jclass('android.util.SparseArray')
                java_msgs_sparse[index] = SparseArray()
            set_private_field(chat_activity, FIELD_SELECTED_MESSAGES_IDS, java_msgs_sparse)
        except Exception:
            logger.error("Selector before hook failed:", exc_info=True)

    def after_hooked_method(self, param):
        if not S.enable_forward_bypass:
            return
        try:
            if self.handle_end_of_select_msg_group_call:
                self.handle_end_of_select_msg_group_call = False
                return
            is_group_commit_event = False
            if self.is_processing_msg_group:
                if not self.is_last_in_group:
                    return
                self.is_processing_msg_group = False
                self.is_last_in_group = False
                self.handle_end_of_select_msg_group_call = True
                is_group_commit_event = True

            chat_activity = param.thisObject
            if chat_activity is None:
                return
            self._ensure_correct_dialog(chat_activity)
            index = get_selected_msgs_array_index(param)
            java_msgs_sparse = get_private_field(chat_activity, FIELD_SELECTED_MESSAGES_IDS)
            if java_msgs_sparse is None:
                return
            selected_msgs_array = java_msgs_sparse[index]
            if selected_msgs_array is None:
                return

            dialog_key = str(get_private_field(chat_activity, FIELD_DIALOG_ID))
            dialog_msgs = self.messages_array.setdefault(dialog_key, {})

            chat_mode = get_private_field(chat_activity, FIELD_CHAT_MODE)
            current_chat = get_private_field(chat_activity, FIELD_CURRENT_CHAT)
            is_in_schedule_mode = chat_mode == 1
            no_forwards = is_in_schedule_mode or self._is_peer_no_forwards(chat_activity)

            for i in reversed(range(selected_msgs_array.size())):
                message_id = selected_msgs_array.keyAt(i)
                message_object = selected_msgs_array.get(message_id)
                if message_object is None:
                    continue
                if message_id in dialog_msgs:
                    if not message_object.canForwardMessage() or no_forwards:
                        decrement_private_counter(chat_activity, FIELD_CANT_FORWARD_COUNT, FIELD_FORWARD_BUTTON)
                    if not message_object.canDeleteMessage(is_in_schedule_mode, current_chat):
                        decrement_private_counter(chat_activity, FIELD_CANT_DELETE_COUNT, FIELD_DELETE_ITEM)
                    dialog_msgs.pop(message_id)
                else:
                    dialog_msgs[message_id] = message_object

            selected_msgs_array.clear()
            for message_id, message_object in dialog_msgs.items():
                selected_msgs_array.put(message_id, message_object)

            if not dialog_msgs:
                cancel_selection_mode(chat_activity)
                return
            update_reply_button_visibility(chat_activity, len(dialog_msgs) == 1)
            update_select_button_visibility(chat_activity)
        except Exception:
            logger.error("Selector after hook failed:", exc_info=True)

    def _is_peer_no_forwards(self, chat_activity):
        try:
            return bool(chat_activity.isPeerNoForwards())
        except Exception:
            return False

    def clear_message_storage(self):
        self.messages_array.clear()
        self.is_processing_msg_group = False
        self.is_last_in_group = False
        self.handle_end_of_select_msg_group_call = False
        self._group_dialog_id = None


class ClearSelectionHook(MethodHook):
    def __init__(self, selector):
        super().__init__()
        self.selector = selector

    def before_hooked_method(self, _param):
        if S.enable_forward_bypass:
            try:
                self.selector.clear_message_storage()
            except Exception:
                logger.error("ClearSelectionHook failed:", exc_info=True)


class MultiSelectorHook(MethodHook):
    def __init__(self, hook_method):
        super().__init__()
        self.hook_method = hook_method
        self.hooked_classes = set()  # классы, на которые уже повешен хук limitReached

    def after_hooked_method(self, param):
        if not S.enable_forward_bypass:
            return
        try:
            chat_list_view = get_private_field(param.thisObject, FIELD_CHAT_LIST_VIEW)
            if chat_list_view is None:
                return
            selection_listener = get_private_field(chat_list_view, FIELD_MULTI_SELECTION_LISTENER)
            if selection_listener is None:
                cls = chat_list_view.getClass()
                while cls is not None:
                    try:
                        field = cls.getDeclaredField(FIELD_MULTI_SELECTION_LISTENER)
                        field.setAccessible(True)
                        selection_listener = field.get(chat_list_view)
                        if selection_listener is not None:
                            break
                    except Exception:
                        pass
                    cls = cls.getSuperclass()
            if selection_listener is None:
                return
            listener_cls = selection_listener.getClass()
            cls_name = listener_cls.getName()
            # Не вешаем дублирующий хук на тот же класс при каждом выделении.
            if cls_name in self.hooked_classes:
                return
            self.hooked_classes.add(cls_name)
            method = listener_cls.getMethod("limitReached")

            class _BypassLimitReachedHook(MethodReplacement):
                def replace_hooked_method(self, _param):
                    return False

            self.hook_method(method, _BypassLimitReachedHook())
        except Exception:
            logger.error("Multi-selector hook failed:", exc_info=True)


class DeleteMessagesHook(XposedHook):
    chunk_size = 100
    _is_processing = threading.local()  # защита от повторного входа в рамках потока

    def before_hooked_method(self, param):
        if not S.enable_forward_bypass:
            return
        # Блокируем рекурсивный вызов: param.method.invoke снова тригерит этот же хук.
        if getattr(self._is_processing, "active", False):
            return
        try:
            if len(param.args) < 2:
                return
            first_msg_array = param.args[0]
            second_msg_array = param.args[1]
            if first_msg_array is not None and first_msg_array.size() > 0:
                messages_array = first_msg_array
                selected_arg_index = 0
            elif second_msg_array is not None and second_msg_array.size() > 0:
                messages_array = second_msg_array
                selected_arg_index = 1
            else:
                return
            other_array = param.args[1 - selected_arg_index]
            total = messages_array.size()
            if total <= self.chunk_size:
                return
            other_total = other_array.size() if other_array is not None else 0
            self._is_processing.active = True
            # Прогресс, чтобы удаление тысяч сообщений не выглядело как зависание.
            notify_info(f"Удаление {total} сообщений частями…")
            try:
                for start in range(0, total, self.chunk_size):
                    end = min(start + self.chunk_size, total)
                    chunk = ArrayList()
                    for i in range(start, end):
                        chunk.add(Integer(int(messages_array.get(i))))
                    param.args[selected_arg_index] = chunk
                    if other_total > 0:
                        other_start = min(start, other_total)
                        other_end = min(end, other_total)
                        other_chunk = ArrayList()
                        for i in range(other_start, other_end):
                            other_chunk.add(Long(other_array.get(i)))
                        param.args[1 - selected_arg_index] = other_chunk
                    if end < total:
                        try:
                            param.method.invoke(param.thisObject, param.args)
                        except Exception:
                            logger.error("DeleteMessages per-chunk error (chunk %d-%d/%d):", start, end, total, exc_info=True)
                        # Раз в ~5 частей (≈500 сообщений), чтобы не заспамить уведомлениями.
                        chunk_index = start // self.chunk_size + 1
                        if chunk_index % 5 == 0:
                            notify_info(f"Удалено {end}/{total}")
                notify_success(f"Удалено {total} сообщений")
            finally:
                self._is_processing.active = False
        except Exception:
            self._is_processing.active = False
            logger.error("DeleteMessages hook failed:", exc_info=True)


selector_hook = SelectorHook()


def setup_forward_limit_bypass(plugin_instance):
    if not ensure_chat_activity_methods():
        return False
    ok = True
    hook_method = plugin_instance.hook_method
    message_object_class = ensure_message_object_class()
    encrypted_chat_class = ensure_encrypted_chat_class()
    tlobject_class = ensure_tlobject_class()
    if not message_object_class or not encrypted_chat_class or not tlobject_class:
        return False
    try:
        selector_method = get_declared_method(ChatActivityClass, "addToSelectedMessages", message_object_class, Boolean.TYPE, Boolean.TYPE)
        if selector_method:
            hook_method(selector_method, selector_hook)
        else:
            ok = False
    except Exception:
        ok = False
        logger.error("Failed to hook message selection:", exc_info=True)
    try:
        clear_selection_method = get_declared_method(ChatActivityClass, "hideActionMode")
        if clear_selection_method:
            hook_method(clear_selection_method, ClearSelectionHook(selector_hook))
        else:
            ok = False
    except Exception:
        ok = False
        logger.error("Failed to hook selection clear:", exc_info=True)
    try:
        multi_selector_method = get_declared_method(ChatActivityClass, "startMultiselect", Integer.TYPE)
        if multi_selector_method:
            hook_method(multi_selector_method, MultiSelectorHook(hook_method))
        else:
            ok = False
    except Exception:
        ok = False
        logger.error("Failed to hook multiselect:", exc_info=True)
    try:
        clazz = ensure_messages_controller_class()
        delete_messages_method = get_declared_method(
            clazz,
            "deleteMessages",
            ArrayList, ArrayList, encrypted_chat_class, Long.TYPE, Boolean.TYPE,
            Integer.TYPE, Boolean.TYPE, Long.TYPE, tlobject_class, Integer.TYPE,
            Boolean.TYPE, Integer.TYPE,
        )
        if not delete_messages_method and clazz:
            # Telegram часто добавляет параметры (revoke/topicId и т.п.) → жёсткая 12-параметровая
            # сигнатура перестаёт находиться. Fallback: ищем deleteMessages, у которого первые два
            # аргумента — ArrayList (message ids и random ids), и берём перегрузку с максимумом параметров.
            try:
                candidates = []
                for m in clazz.getDeclaredMethods():
                    if m.getName() != "deleteMessages":
                        continue
                    pt = m.getParameterTypes()
                    if len(pt) >= 2 and pt[0].getName() == "java.util.ArrayList" and pt[1].getName() == "java.util.ArrayList":
                        candidates.append((len(pt), m))
                if candidates:
                    candidates.sort(key=lambda c: c[0], reverse=True)
                    delete_messages_method = candidates[0][1]
                    delete_messages_method.setAccessible(True)
                    logger.warning("deleteMessages: exact signature missing, using fallback overload with %d params", candidates[0][0])
            except Exception:
                logger.error("deleteMessages fallback scan failed:", exc_info=True)
        if delete_messages_method:
            hook_method(delete_messages_method, DeleteMessagesHook())
        else:
            ok = False
    except Exception:
        ok = False
        logger.error("Failed to hook deleteMessages:", exc_info=True)
    return ok


# ─────────────────────────────────────────────────────────────
# Peer info saver
# ─────────────────────────────────────────────────────────────

_peer_fields_cache = {}


def _cached_peer_fields(settings):
    # getFields() через JNI-мост дорог, а SavePeerSettingsHook дёргает это при скролле чатов.
    # Кэшируем Field[] по имени класса (набор полей TL_peerSettings неизменен).
    cls = settings.getClass()
    name = cls.getName()
    fields = _peer_fields_cache.get(name)
    if fields is None:
        fields = cls.getFields()
        _peer_fields_cache[name] = fields
    return fields


def peer_settings_to_dict(settings):
    if not settings:
        return None
    data = {}
    fields_failed = 0
    for field in _cached_peer_fields(settings):
        try:
            key = field.getName()
            if not key.islower() or key.startswith("_"):
                continue
            value = field.get(settings)
            # Java boxed-примитивы (Integer/Long/Boolean) приходят как объекты, а не Python-типы —
            # приводим явно, иначе isinstance ниже их отбросит и профиль окажется пустым.
            if isinstance(value, Boolean):
                value = bool(value)
            elif isinstance(value, (Integer, Long)):
                value = int(value)
            # Пропускаем сложные Java-объекты (byte[], TLObject, прокси) — json.dump их не сериализует.
            if not isinstance(value, (int, float, bool, str, type(None))):
                continue
            data[key] = value
        except Exception:
            fields_failed += 1
    if fields_failed:
        logger.warning("peer_settings_to_dict: %d fields failed", fields_failed)
    return data if data else None


def dict_to_peer_settings(dumped):
    dumped = dumped if isinstance(dumped, dict) else None
    if not dumped:
        return None
    settings = TLRPC.TL_peerSettings()
    for key, value in dumped.items():
        try:
            setattr(settings, key, value)
        except Exception:
            logger.error("Failed to restore peer field %s", key, exc_info=True)
    return settings


def merge_saved_peer_fields(base_settings, saved_settings):
    saved_settings = saved_settings if isinstance(saved_settings, dict) else None
    if not saved_settings:
        return base_settings
    if base_settings is None:
        return dict_to_peer_settings(saved_settings)
    base_dump = peer_settings_to_dict(base_settings)
    if not isinstance(base_dump, dict):
        return base_settings
    merged = clone_data(base_dump)
    # Восстанавливаем не только precious, но и important state-поля — но лишь когда Telegram
    # вернул пустое значение (не затираем свежие данные сервера сохранёнными).
    for field in tuple(PRECIOUS_PEER_FIELDS) + tuple(IMPORTANT_PEER_STATE_FIELDS):
        if merged.get(field) in (None, "", 0, False) and saved_settings.get(field) not in (None, "", 0, False):
            merged[field] = saved_settings.get(field)
    return dict_to_peer_settings(merged)


def load_saved_peer_settings(dialog_id):
    if not is_user_dialog(dialog_id):
        return None
    peer_storage.ensure_loaded()
    with peer_storage._lock:
        val = peer_storage.content.get(str(dialog_id)) if isinstance(peer_storage.content, dict) else None
        return clone_data(val)


_storage_write_signal = threading.Event()
_storage_writer_started = False
_storage_writer_lock = threading.Lock()
_worker_active = True  # флаг жизни фонового воркера записи (гасим его при выгрузке плагина)
_writer_thread = None  # ссылка на фоновый поток записи — чтобы дождаться его завершения при выгрузке


def _storage_writer_loop():
    global _worker_active
    while _worker_active:
        _storage_write_signal.wait()
        if not _worker_active:  # разбудили для завершения при выгрузке плагина
            break
        time.sleep(1.0)  # коалесинг: ждём накопления изменений ~1с
        _storage_write_signal.clear()  # сбрасываем сигнал ДО чтения данных — без дублирующей записи
        try:
            peer_storage.write()
        except Exception:
            logger.error("Background storage write failed", exc_info=True)


def _schedule_storage_write():
    global _storage_writer_started, _writer_thread
    with _storage_writer_lock:
        if not _storage_writer_started:
            _storage_writer_started = True
            _writer_thread = threading.Thread(target=_storage_writer_loop, name="peer-storage-writer", daemon=True)
            _writer_thread.start()
    _storage_write_signal.set()


def save_peer_settings(dialog_id, settings):
    if not is_user_dialog(dialog_id):
        return
    # Сначала извлекаем и проверяем полезную нагрузку, и только потом трогаем debounce —
    # иначе пустой/неполный первый вызов «съедает» окно debounce и теряет реальные данные.
    peer_storage.ensure_loaded()
    new_settings = peer_settings_to_dict(settings)
    if not new_settings:
        return
    old_settings = load_saved_peer_settings(dialog_id)
    if old_settings:
        for field in PRECIOUS_PEER_FIELDS:
            if not new_settings.get(field) and old_settings.get(field):
                new_settings[field] = old_settings[field]
    if not is_meaningful_peer_dump(new_settings):
        return
    now = JavaSystem.nanoTime()
    debounce_key = str(dialog_id)
    with _saving_lock:
        last = _saving_dialogs.get(debounce_key, 0)
        if now - last < _save_debounce_seconds * 1_000_000_000:
            return
        _saving_dialogs[debounce_key] = now
        if len(_saving_dialogs) > 512:
            cutoff = now - 60 * 1_000_000_000
            for stale in [k for k, t in _saving_dialogs.items() if t < cutoff]:
                _saving_dialogs.pop(stale, None)
    dialog_key = str(dialog_id)
    with peer_storage._lock:
        peer_storage.content[dialog_key] = new_settings
    # Диск — в фоновом воркере: gzip+I/O нельзя делать на UI-потоке (ANR при скролле).
    _schedule_storage_write()


def resolve_peer_settings(dialog_id, original_settings=None, use_saved=True):
    if original_settings is not None:
        return original_settings
    # Защита от ANR: на UI-потоке не дёргаем getUserFull (возможный синхронный I/O к БД).
    is_main_thread = _is_ui_thread()
    with _resolving_lock:
        if dialog_id in _resolving_dialogs:
            _fast_controller = get_messages_controller()
            if not is_main_thread:
                try:
                    _fast_full = _fast_controller.getUserFull(dialog_id)
                    _fast_settings = getattr(_fast_full, "settings", None)
                    if _fast_settings is not None:
                        return _fast_settings
                except Exception:
                    logger.debug("resolve_peer_settings: fast-path getUserFull failed for dialog %s", dialog_id)
            try:
                _fast_map = get_user_peer_settings_map(_fast_controller)
                if _fast_map:
                    _fast_val = _fast_map.get(dialog_id)
                    if _fast_val is not None:
                        return _fast_val
            except Exception:
                logger.debug("resolve_peer_settings: fast-path get_user_peer_settings_map failed for dialog %s", dialog_id)
                pass
            return None
        _resolving_dialogs.add(dialog_id)
    try:
        msg_controller = get_messages_controller()
        user_full_settings = None
        msg_controller_settings = None
        if not is_main_thread:
            try:
                user_full = msg_controller.getUserFull(dialog_id)
                user_full_settings = getattr(user_full, "settings", None)
            except Exception:
                logger.error("resolve_peer_settings: msg_controller.getUserFull failed", exc_info=True)
        try:
            user_peer_settings = get_user_peer_settings_map(msg_controller)
            msg_controller_settings = user_peer_settings.get(dialog_id) if user_peer_settings else None
        except Exception:
            logger.error("resolve_peer_settings: get_user_peer_settings_map failed", exc_info=True)
        if not use_saved or not is_user_dialog(dialog_id):
            return user_full_settings or msg_controller_settings
        saved_settings = load_saved_peer_settings(dialog_id) if use_saved else None
        if user_full_settings is not None:
            merged_user_full = merge_saved_peer_fields(user_full_settings, saved_settings)
            if merged_user_full is not None:
                return merged_user_full
        if msg_controller_settings is not None:
            merged_controller = merge_saved_peer_fields(msg_controller_settings, saved_settings)
            if merged_controller is not None:
                return merged_controller
        if is_meaningful_peer_dump(saved_settings):
            restored_settings = dict_to_peer_settings(saved_settings)
            if restored_settings is not None:
                cache_restored_peer_settings(msg_controller, dialog_id, restored_settings)
                return restored_settings
        return user_full_settings or msg_controller_settings
    finally:
        with _resolving_lock:
            _resolving_dialogs.discard(dialog_id)


class SavePeerSettingsHook(MethodHook):
    def before_hooked_method(self, param):
        if not S.enable_peer_info_saver:
            return
        try:
            if len(param.args) >= 2:
                save_peer_settings(param.args[0], param.args[1])
        except Exception:
            logger.error("SavePeerSettings hook failed:", exc_info=True)


class LoadPeerSettingsHook(MethodHook):
    # after_hooked_method: даём Telegram самому сходить в SQLite/сеть, а затем
    # обогащаем его результат сохранёнными полями (без Data Starvation).
    def after_hooked_method(self, param):
        if not S.enable_peer_info_saver:
            return
        try:
            if len(param.args) < 1:
                return
            dialog_id = param.args[0]
            if not is_user_dialog(dialog_id):
                return
            original_result = param.getResult()
            saved_settings = load_saved_peer_settings(dialog_id)
            if not is_meaningful_peer_dump(saved_settings):
                return
            enriched_result = None
            if original_result is not None:
                enriched_result = merge_saved_peer_fields(original_result, saved_settings)
            else:
                # Telegram ничего не вернул (нет в БД) — восстанавливаем из дампа.
                restored = dict_to_peer_settings(saved_settings)
                if restored is not None:
                    try:
                        cache_restored_peer_settings(get_messages_controller(), dialog_id, restored)
                    except Exception:
                        logger.debug("cache_restored_peer_settings failed for dialog %s", dialog_id)
                    enriched_result = restored
            if enriched_result is not None:
                param.setResult(enriched_result)
        except Exception:
            logger.error("LoadPeerSettings hook failed:", exc_info=True)


def setup_peer_info_saver(plugin_instance):
    # Статус по каждому хуку отдельно: getPeerSettings и savePeerSettings ставятся
    # независимо. Раньше один общий флаг (get_ok and save_ok) помечал ОБА хука FAIL,
    # когда не привязывался лишь один из них (в логах getPeerSettings реально срабатывал
    # в live-цепочке, но всё равно отображался как FAIL).
    status = {"getPeerSettings": False, "savePeerSettings": False}
    try:
        clazz = ensure_messages_controller_class()
        if not clazz:
            return status
        # only_preferred=False: если перегрузки с ожидаемым числом параметров нет
        # (в свежих сборках Telegram savePeerSettings принимает дополнительный аргумент,
        # поэтому (2,) не находит совпадений), привязываемся к доступной перегрузке.
        # Оба хука дополнительно проверяют число аргументов во время вызова, поэтому
        # это безопасно.
        status["getPeerSettings"] = hook_all_matching_methods(clazz, "getPeerSettings", LoadPeerSettingsHook, plugin_instance.hook_method, preferred_param_counts=(1,), only_preferred=False)
        status["savePeerSettings"] = hook_all_matching_methods(clazz, "savePeerSettings", SavePeerSettingsHook, plugin_instance.hook_method, preferred_param_counts=(2,), only_preferred=False)
        return status
    except Exception:
        logger.error("Failed to setup peer info saver:", exc_info=True)
        return status


def has_resolved_legacy_storage():
    return bool(peer_storage.selected_path and peer_storage.selected_path != peer_storage.path() and peer_storage.count() > 0)


def get_storage_health():
    peer_storage.ensure_loaded()
    old_info = inspect_old_storage()
    issues = []
    actions = []
    if has_resolved_legacy_storage():
        issues.append("Данные ещё работают из старого места")
        actions.append("Перенести в текущее хранилище")
    if old_info.get("exists") and old_info.get("count", 0) > 0:
        issues.append("Найдены старые данные для импорта")
        actions.append("Импортировать старые данные")
    if peer_storage.count() == 0:
        issues.append("Пока нет сохранённых данных")
        actions.append("Открыть профиль и дать плагину сохранить данные")
    status = "ok"
    title = "Всё работает нормально"
    description = "Плагин готов и хранилище выглядит исправным."
    if issues:
        status = "attention"
        title = "Требуется внимание"
        description = issues[0]
    if old_info.get("error"):
        status = "problem"
        title = "Обнаружена проблема"
        description = "Не удалось проверить старое хранилище."
    return {
        "status": status,
        "title": title,
        "description": description,
        "issues": issues,
        "actions": actions,
        "old_info": old_info,
        "peer_count": peer_storage.count(),
    }


def optimize_storage_now():
    try:
        snapshot = storage_snapshot()
        peer_clean = merge_peer_records({}, snapshot["peer_records"])
        result = apply_storage_transaction(peer_clean, safety_prefix="optimize")
        notify_success(f"Оптимизация завершена\nСтраховочная копия: {result['safety_backup']}")
        return True
    except Exception:
        logger.error("Optimize failed:", exc_info=True)
        notify_error("Оптимизация не удалась, выполнен откат")
        return False


def auto_fix_now():
    try:
        actions = []
        imported = migrate_old_storage(delete_after_success=False)
        if imported > 0:
            actions.append(f"Импортировано старых данных: {imported}")
        migrated = migrate_resolved_legacy_storage()
        if migrated > 0:
            actions.append(f"Перенесено в текущее хранилище: {migrated}")
        with peer_storage._lock:  # снимаем стабильный снапшот — без RuntimeError при фоновой записи
            snapshot_content = clone_data(peer_storage.content)
        peer_clean = merge_peer_records({}, snapshot_content)
        result = apply_storage_transaction(peer_clean, safety_prefix="repair")
        if not actions:
            notify_success("Проверка завершена\nПроблем не найдено\n" + f"Страховочная копия: {result['safety_backup']}")
        else:
            notify_success("Исправление завершено\n" + "\n".join(actions) + f"\nСтраховочная копия: {result['safety_backup']}")
        return True
    except Exception:
        logger.error("Auto-fix failed:", exc_info=True)
        notify_error("Автоисправление не удалось, выполнен откат")
        return False


def run_health_check_now():
    health = get_storage_health()
    lines = [
        health["title"],
        health["description"],
        f"Профилей сохранено: {health['peer_count']}",
    ]
    lines.extend(health["issues"][:2] if health["issues"] else ["Проблем не найдено"])
    notify_info("\n".join(lines))
    return health


def restore_latest_backup_now():
    files = list_backup_files()
    if not files:
        notify_info("Резервные копии не найдены")
        return False
    result = import_backup_file(files[0], "replace")
    return bool(result)


def confirm_restore_latest_backup():
    files = list_backup_files()
    if not files:
        notify_info("Резервные копии не найдены")
        return

    def proceed(_, __):
        restore_latest_backup_now()

    show_alert(
        "Восстановить последнюю копию?",
        "Текущие данные будут заменены содержимым последней резервной копии. Перед восстановлением автоматически создаётся страховочная копия.",
        buttons=[
            ("positive", "Восстановить", lambda _a, _b: run_in_background(proceed, _a, _b)),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


def confirm_backup_import(filename, mode):
    summary = backup_file_summary(filename)

    def proceed(_, __):
        import_backup_file(filename, mode)

    mode_label = "Заменить" if mode == "replace" else "Объединить"
    message = (
        f"Файл: {summary['filename']}\n"
        f"Профилей: {summary['peer_count']}\n"
        "\n"
    )
    if mode == "replace":
        message += "Текущие данные будут полностью заменены. Перед импортом автоматически создаётся страховочная копия."
    else:
        message += "Текущие данные останутся нетронутыми: из копии будут добавлены только отсутствующие профили и пустые поля. Ничего не перезаписывается. Перед импортом автоматически создаётся страховочная копия."
    show_alert(
        f"{mode_label} данные?",
        message,
        buttons=[
            ("positive", mode_label, lambda _a, _b: run_in_background(proceed, _a, _b)),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


# ─────────────────────────────────────────────────────────────
# Auto-Update
# ─────────────────────────────────────────────────────────────

def _resolve_python_engine(file_path):
    # Достаём движок ДОСЛОВНО как рабочий ReMandre.perform_install (проверено на этой сборке):
    #   PC = jclass("...PluginsController").getInstance()
    #   engine = PC.engines.get("python")  ->  fallback PC.getPluginEngine(path)
    # ВАЖНО: engines/getInstance — атрибуты ЭКЗЕМПЛЯРА, а не импортированного КЛАССА.
    # Обращение к классу давало "'PluginsController' object has no attribute 'engines'".
    pc = jclass("com.exteragram.messenger.plugins.PluginsController").getInstance()
    engine = None
    try:
        engine = pc.engines.get("python")
    except Exception:
        logger.debug("Auto-update: pc.engines.get('python') failed", exc_info=True)
    if not engine:
        try:
            engine = pc.getPluginEngine(str(file_path))
        except Exception:
            logger.debug("Auto-update: pc.getPluginEngine failed", exc_info=True)
    return pc, engine


def _install_plugin_from_path(file_path):
    # Установка через движок, полученный у ЭКЗЕМПЛЯРА контроллера (см. _resolve_python_engine).
    # 3 аргумента, вложенный callback, блокирующее ожидание. Возвращает True/False.
    # Вызывается из фонового потока (do_install), поэтому done.wait не морозит UI.
    try:
        _pc, engine = _resolve_python_engine(file_path)
    except BaseException:
        logger.error("Auto-update: failed to resolve PluginsController/engine", exc_info=True)
        raise
    if not engine:
        logger.error("Auto-update: PythonPluginsEngine not found")
        return False
    done = threading.Event()
    result = [False]

    class InstallCb(dynamic_proxy(Utilities.Callback)):
        def run(self_cb, error):
            if not error:
                result[0] = True
            done.set()

    try:
        engine.loadPluginFromFile(str(file_path), None, InstallCb())
    except BaseException:
        # BaseException: Java-исключения Chaquopy могут не наследоваться от Exception.
        logger.error("Auto-update: loadPluginFromFile call failed", exc_info=True)
        raise
    done.wait(timeout=30)
    return result[0]


def _parse_update_url(url):
    # Строгий парсинг: только t.me/<username>/<msg_id>, с привязкой к началу/концу строки.
    url = str(url or "").strip()
    m = re.fullmatch(r'(?:https?://)?(?:www\.)?t\.me/([A-Za-z0-9_]{4,32})/(\d+)/?', url)
    if not m:
        return None, None
    if m.group(1).lower() == "c":  # t.me/c/<id>/<msg> — приватные каналы не поддерживаются
        return None, None
    return m.group(1), int(m.group(2))


def _parse_version(value):
    parts = []
    for chunk in re.split(r'[._\-]', str(value).strip()):
        match = re.match(r'(\d+)', chunk)
        parts.append(int(match.group(1)) if match else 0)
    return parts


def _version_gt(candidate, current):
    a, b = _parse_version(candidate), _parse_version(current)
    length = max(len(a), len(b))
    a += [0] * (length - len(a))
    b += [0] * (length - len(b))
    return a > b


def _read_plugin_meta(file_path):
    meta = {}
    try:
        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()
        for field in ("__version__", "__id__", "__name__"):
            m = re.search(field + r'\s*=\s*["\']([^"\']+)["\']', content)
            if m:
                meta[field] = m.group(1)
    except Exception:
        logger.error("Failed to read plugin meta from downloaded plugin", exc_info=True)
    return meta


def _au_note_failure():
    # Считает неудачи связи с каналом подряд. После порога — одно уведомление,
    # чтобы фоновые проверки не отваливались молча. Успех сбрасывает счётчик.
    global _au_consecutive_failures, _au_failure_notified
    with _au_failure_lock:
        _au_consecutive_failures += 1
        count = _au_consecutive_failures
        should_notify = count >= _AU_FAILURE_THRESHOLD and not _au_failure_notified
        if should_notify:
            _au_failure_notified = True
    if should_notify:
        run_on_ui_thread(lambda: notify_error(
            f"Автообновление не смогло связаться с каналом ({count} раз подряд).\n"
            "Проверьте ссылку и подключение к интернету."))


def _au_note_success():
    global _au_consecutive_failures, _au_failure_notified
    with _au_failure_lock:
        _au_consecutive_failures = 0
        _au_failure_notified = False


def _do_check_update(show_no_update=False):
    raw_url = S.auto_update_url.strip()
    channel, msg_id = _parse_update_url(raw_url)
    logger.debug("AU: check started @%s msg=%s (url=%s)", channel, msg_id, raw_url)
    if not channel or not msg_id:
        if show_no_update:
            run_on_ui_thread(lambda: notify_error("Неверная ссылка на сообщение. Ожидается: t.me/Канал/123"))
        return

    try:
        acc = UserConfig.selectedAccount
        logger.debug("AU: account=%s", acc)
    except Exception:
        logger.error("AU: UserConfig.selectedAccount failed", exc_info=True)
        if show_no_update:
            run_on_ui_thread(lambda: notify_error("Не удалось получить аккаунт"))
        return

    try:
        RequestDelegate = jclass("org.telegram.tgnet.RequestDelegate")
        logger.debug("AU: RequestDelegate loaded")
    except Exception:
        logger.error("AU: jclass RequestDelegate failed", exc_info=True)
        if show_no_update:
            run_on_ui_thread(lambda: notify_error("Ошибка SDK: RequestDelegate"))
        return

    class MessagesDelegate(dynamic_proxy(RequestDelegate)):
        def run(self, msg_response, msg_error):
            logger.debug("AU: msgs_cb err=%s hasResp=%s",
                         getattr(msg_error, "text", None) if msg_error else None,
                         msg_response is not None)
            if msg_error or not msg_response:
                _au_note_failure()
                if show_no_update:
                    run_on_ui_thread(lambda: notify_error("Не удалось получить сообщение"))
                return
            _au_note_success()  # канал ответил — связь есть, сбрасываем счётчик неудач
            try:
                logger.debug("AU: msgs_cb step1 list()")
                java_msgs = msg_response.messages
                if java_msgs is None or java_msgs.size() == 0:
                    logger.debug("AU: msgs_cb empty (null or isEmpty)")
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_info("Сообщение с плагином не найдено"))
                    return
                try:
                    message = java_msgs.get(0)
                except Exception:
                    logger.error("AU: msgs_cb get(0) failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: список сообщений"))
                    return
                logger.debug("AU: msgs_cb step2 acc_i")
                try:
                    acc_i = get_account_instance()
                except Exception:
                    logger.error("AU: msgs_cb get_account_instance failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: аккаунт (2)"))
                    return
                logger.debug("AU: msgs_cb step3 MessageObject")
                msg_obj = MessageObject(acc_i.getCurrentAccount(), message, False, False)
                msg_text = getattr(message, "message", "") or ""

                edit_date = getattr(message, "edit_date", 0) or getattr(message, "date", 0)
                stored_date = int(S.get("last_update_edit_date", "0") or "0")
                if not show_no_update and edit_date and edit_date <= stored_date:
                    logger.debug("AU: no newer (edit=%s <= stored=%s)", edit_date, stored_date)
                    return

                logger.debug("AU: spawning download thread")
                threading.Thread(
                    target=lambda: _download_and_install(msg_obj, edit_date, msg_text, show_no_update),
                    daemon=True,
                ).start()
            except Exception:
                logger.error("AU: msgs_cb UNKNOWN", exc_info=True)
                if show_no_update:
                    run_on_ui_thread(lambda: notify_error("Ошибка при проверке обновления"))

    class ResolveDelegate(dynamic_proxy(RequestDelegate)):
        def run(self, response, error):
            logger.debug("AU: resolve_cb err=%s hasResp=%s",
                         getattr(error, "text", None) if error else None,
                         response is not None)
            if error or not response:
                _au_note_failure()
                if show_no_update:
                    run_on_ui_thread(lambda: notify_error(f"Канал @{channel} не найден"))
                return
            try:
                logger.debug("AU: resolve_cb step1 chats")
                try:
                    chats = getattr(response, "chats", None)
                except Exception:
                    logger.error("AU: resolve_cb getattr(chats) failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: чтение chats"))
                    return
                if chats and chats.size() > 0:
                    chat = chats.get(0)
                else:
                    logger.debug("AU: resolve_cb step1b peer")
                    try:
                        peer = getattr(response, "peer", None)
                    except Exception:
                        logger.error("AU: resolve_cb getattr(peer) failed", exc_info=True)
                        if show_no_update:
                            run_on_ui_thread(lambda: notify_error("Ошибка: чтение peer"))
                        return
                    if not peer:
                        if show_no_update:
                            run_on_ui_thread(lambda: notify_error(f"Канал @{channel} не найден"))
                        return
                    chat_id = getattr(peer, "channel_id", 0)
                    logger.debug("AU: resolve_cb step1c getChat(%s)", chat_id)
                    try:
                        mc = get_messages_controller()
                        chat = mc.getChat(chat_id) if chat_id else None
                    except Exception:
                        logger.error("AU: resolve_cb getChat failed", exc_info=True)
                        if show_no_update:
                            run_on_ui_thread(lambda: notify_error("Ошибка: getChat"))
                        return
                if not chat:
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error(f"Канал @{channel} не найден"))
                    return

                logger.debug("AU: resolve_cb channel_id=%s", chat.id)
                logger.debug("AU: resolve_cb step2 TL_inputChannel")
                try:
                    input_channel = TLRPC.TL_inputChannel()
                except Exception:
                    logger.error("AU: resolve_cb TL_inputChannel() failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: InputChannel"))
                    return
                input_channel.channel_id = chat.id
                input_channel.access_hash = getattr(chat, "access_hash", 0)
                logger.debug("AU: resolve_cb step3 req build")
                try:
                    req = TLRPC.TL_channels_getMessages()
                except Exception:
                    logger.error("AU: resolve_cb TL_channels_getMessages() failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: getMessages"))
                    return
                req.channel = input_channel
                msg_ids = ArrayList()
                msg_ids.add(Integer(msg_id))
                req.id = msg_ids
                logger.debug("AU: resolve_cb step4 sendRequest")
                try:
                    cm = ConnectionsManager.getInstance(acc)
                    cm.sendRequest(req, MessagesDelegate())
                    logger.debug("AU: resolve_cb sendRequest dispatched OK")
                except Exception:
                    logger.error("AU: resolve_cb sendRequest failed", exc_info=True)
                    if show_no_update:
                        run_on_ui_thread(lambda: notify_error("Ошибка: запрос сообщений"))
                    return
            except Exception:
                logger.error("AU: resolve_cb UNKNOWN", exc_info=True)
                if show_no_update:
                    run_on_ui_thread(lambda: notify_error("Ошибка при проверке обновления"))

    logger.debug("AU: sending resolveUsername for @%s", channel)
    try:
        resolve_req = TLRPC.TL_contacts_resolveUsername()
        resolve_req.username = channel
        cm = ConnectionsManager.getInstance(acc)
        cm.sendRequest(resolve_req, ResolveDelegate())
        logger.debug("AU: resolveUsername dispatched OK")
    except Exception:
        logger.error("AU: resolveUsername sendRequest failed", exc_info=True)
        if show_no_update:
            run_on_ui_thread(lambda: notify_error("Ошибка: запрос канала"))
        return


def _download_and_install(msg_obj, edit_date, message_text="", show_no_update=False):
    global _is_downloading
    with _update_check_lock:
        if _is_downloading:
            logger.debug("Auto-update: download already in progress, skipping duplicate")
            return
        _is_downloading = True
    try:
        media = MessageObject.getMedia(msg_obj)
        if not media:
            if show_no_update:
                run_on_ui_thread(lambda: notify_error("В сообщении нет файла"))
            return
        attachment = media.document or media.photo
        if not attachment:
            if show_no_update:
                run_on_ui_thread(lambda: notify_error("Не удалось получить файл из сообщения"))
            return

        expected_size = 0
        try:
            expected_size = int(getattr(attachment, "size", 0) or 0)
        except Exception:
            expected_size = 0

        def _size_or_zero(fp):
            try:
                return fp.length() if fp and fp.exists() else 0
            except Exception:
                return 0

        def _is_complete(fp):
            # Завершено только если размер достиг ожидаемого (attachment.size).
            sz = _size_or_zero(fp)
            return sz > 0 and expected_size > 0 and sz >= expected_size

        fl = get_file_loader()
        file_path = fl.getPathToAttach(attachment, True)
        if not _is_complete(file_path):
            file_name = FileLoader.getAttachFileName(attachment)
            logger.debug("Auto-update: downloading %s (expected %d bytes)...", file_name, expected_size)
            run_on_ui_thread(lambda: fl.loadFile(attachment, msg_obj, 1, 1))
            poll_step = 0.2
            last_size = -1
            no_progress = 0
            for attempt in range(600):  # жёсткий потолок ~120с
                time.sleep(poll_step)
                file_path = fl.getPathToAttach(attachment, True)
                if _is_complete(file_path):
                    logger.debug("Auto-update: download complete in %.1fs", (attempt + 1) * poll_step)
                    break
                cur = _size_or_zero(file_path)
                if cur == last_size:
                    no_progress += 1
                    # Неизвестный размер + стабильный ненулевой файл (~4с без роста) → считаем загруженным.
                    if expected_size <= 0 and cur > 0 and no_progress >= 20:
                        logger.debug("Auto-update: download stabilized in %.1fs (%d bytes)", (attempt + 1) * poll_step, cur)
                        break
                    # Нет прогресса ~15с (загрузка так и не пошла) → выходим, не висим 2 минуты.
                    if no_progress >= 75:
                        logger.debug("Auto-update: no download progress (%d bytes) after %.1fs, aborting", cur, (attempt + 1) * poll_step)
                        break
                else:
                    no_progress = 0
                last_size = cur

        file_path = fl.getPathToAttach(attachment, True)
        final_size = _size_or_zero(file_path)
        if not (_is_complete(file_path) or (expected_size <= 0 and final_size > 0)):
            if show_no_update:
                run_on_ui_thread(lambda: notify_error("Не удалось загрузить файл плагина"))
            return

        try:
            _is_plugin = PluginsController.isPlugin(msg_obj)
        except BaseException:
            # isPlugin — статический и на этой сборке работает, но если на другой он
            # бросит (как ломался engines у экземпляра), не маскируем это под ошибку
            # установки: считаем проверку непройденной и выходим с понятным сообщением.
            logger.error("Auto-update: PluginsController.isPlugin failed", exc_info=True)
            if show_no_update:
                run_on_ui_thread(lambda: notify_error("Не удалось проверить файл плагина"))
            return
        if not _is_plugin:
            logger.debug("Auto-update: downloaded file is not a plugin")
            if show_no_update:
                run_on_ui_thread(lambda: notify_info("Загруженный файл не является плагином"))
            return

        meta = _read_plugin_meta(str(file_path))
        new_version = meta.get("__version__")
        new_id = meta.get("__id__")
        if not new_version:
            if show_no_update:
                run_on_ui_thread(lambda: notify_error("Не удалось определить версию в скачанном плагине"))
            return
        if new_id and new_id != __id__:
            logger.warning("Auto-update: plugin id mismatch (downloaded=%s expected=%s)", new_id, __id__)
            if show_no_update:
                run_on_ui_thread(lambda: notify_error(f"Файл не является плагином {__id__}"))
            return

        logger.debug("Auto-update: downloaded v%s (current v%s)", new_version, __version__)
        if not _version_gt(new_version, __version__):
            logger.debug("Auto-update: no newer version (downloaded=%s current=%s)", new_version, __version__)
            if show_no_update:
                run_on_ui_thread(lambda: notify_info(f"Установлена последняя версия (v{__version__})"))
            else:
                S.set("last_update_edit_date", str(edit_date))
            return

        changelog = message_text.strip() if message_text else "Изменения не указаны."
        _file_path = str(file_path)

        def do_install(_, __):
            # Установка в фоне (done.wait до 30с внутри), чтобы не морозить UI-поток.
            def background_install():
                global _is_installing
                with _update_check_lock:
                    if _is_installing:
                        logger.debug("Auto-update: install already in progress, skipping duplicate")
                        return
                    _is_installing = True
                try:
                    logger.info("Auto-update: installing v%s (current v%s)", new_version, __version__)
                    ok = _install_plugin_from_path(_file_path)
                    if ok:
                        S.set("last_update_edit_date", str(edit_date))
                        run_on_ui_thread(lambda: notify_success(
                            f"Плагин обновлён до v{new_version}\nПерезапустите приложение для применения"
                        ))
                    else:
                        run_on_ui_thread(lambda: notify_error("Не удалось установить обновление"))
                except BaseException as _e:
                    # Ловим BaseException, а не только Exception: Java-исключения из Chaquopy
                    # (chaquopy.JavaException и пр.) могут не быть подклассом Python Exception
                    # и иначе пролетели бы мимо, снова давая «тишину».
                    logger.error("Auto-update: install failed", exc_info=True)
                    # Короткое сообщение в бюллетень + полный трейсбек по кнопке «Копировать».
                    _short = repr(_e)
                    _full = traceback.format_exc()
                    run_on_ui_thread(lambda: notify_error_copyable(
                        f"Ошибка установки: {_short[:160]}", copy_text=_full))
                finally:
                    with _update_check_lock:
                        _is_installing = False

            threading.Thread(target=background_install, daemon=True).start()

        run_on_ui_thread(lambda: show_alert(
            f"Доступна версия v{new_version}",
            changelog[:500],
            buttons=[
                ("positive", "Обновить", do_install),
                ("negative", "Отмена", lambda _, __: None),
            ],
            cancelable=True,
        ))
    except Exception:
        logger.error("Auto-update: download/install failed", exc_info=True)
        if show_no_update:
            run_on_ui_thread(lambda: notify_error("Ошибка при загрузке обновления"))
    finally:
        with _update_check_lock:
            _is_downloading = False


def _launch_update_check(show_no_update=False):
    global _is_update_checking
    with _update_check_lock:
        if _is_update_checking:
            if show_no_update:
                notify_info("Проверка уже выполняется…")
            return False
        _is_update_checking = True

    def _wrapped():
        global _is_update_checking
        try:
            _do_check_update(show_no_update=show_no_update)
        finally:
            _is_update_checking = False

    threading.Thread(target=_wrapped, daemon=True).start()
    return True


def check_for_update_now():
    global _last_update_check
    _last_update_check = time.monotonic()
    run_on_ui_thread(lambda: notify_info("Проверка обновлений..."))
    _launch_update_check(show_no_update=True)


def validate_update_url_now():
    # Локальная проверка ссылки без обращения к сети: разбираем канал и ID.
    S.load()
    channel, msg_id = _parse_update_url(S.auto_update_url)
    if channel and msg_id:
        notify_success(f"Ссылка корректна\nКанал: @{channel}  ·  Сообщение: {msg_id}")
    else:
        notify_error("Неверная ссылка. Ожидается формат t.me/Канал/123\n(приватные каналы t.me/c/… не поддерживаются)")


def _schedule_next_check(interval_hours):
    global _update_timer
    _cancel_scheduled_check()
    interval_seconds = interval_hours * 3600
    _update_timer = threading.Timer(interval_seconds, _on_scheduled_check)
    _update_timer.daemon = True
    _update_timer.start()
    logger.debug("Auto-update: next check in %d seconds", interval_seconds)


def _cancel_scheduled_check():
    global _update_timer
    if _update_timer:
        _update_timer.cancel()
        _update_timer = None


def _on_scheduled_check():
    global _last_update_check, _is_update_checking
    with _update_check_lock:
        skip = _is_update_checking
        if not skip:
            _is_update_checking = True
    try:
        if not skip:
            _last_update_check = time.monotonic()
            _do_check_update()
    except Exception:
        logger.error("Auto-update: scheduled check failed", exc_info=True)
    finally:
        if not skip:
            _is_update_checking = False
        if S.auto_update_enabled:
            idx = S.auto_update_interval
            if 0 <= idx < len(_UPDATE_INTERVALS):
                _schedule_next_check(_UPDATE_INTERVALS[idx])


def start_auto_update():
    if not S.auto_update_enabled:
        return
    idx = S.auto_update_interval
    if 0 <= idx < len(_UPDATE_INTERVALS):
        _schedule_next_check(_UPDATE_INTERVALS[idx])
    else:
        # «Вручную» и значения вне диапазона: периодические проверки не планируем.
        logger.debug("Auto-update: manual interval selected, no periodic checks scheduled")
        _cancel_scheduled_check()


def stop_auto_update():
    _cancel_scheduled_check()


# ────────────────────────────────────────────────────────────────
# Settings UI
# ─────────────────────────────────────────────────────────────

PAGE_MAIN = "main"
PAGE_FEATURES = "features"
PAGE_DATA = "data"
PAGE_BACKUP_IMPORT = "backup_import"
PAGE_REPAIR = "repair"
PAGE_ABOUT = "about"
PAGE_VIEW_SAVED = "view_saved"
PAGE_UPDATES = "updates"
PAGE_HELP = "help"


def create_settings(page_id=PAGE_MAIN):
    S.load()
    health = get_storage_health()
    subpage = open_settings_page

    if isinstance(page_id, tuple) and len(page_id) == 2 and page_id[0] == "backup_file":
        filename = page_id[1]
        summary = backup_file_summary(filename)
        return [
            Header("Резервная копия"),
            Divider("Выберите способ восстановления данных из этой копии."),
            Divider(f"Размер: {summary['size_label']}  ·  Дата: {summary['created_label']}"),
            Divider(f"Профилей: {summary['peer_count']}"),
            Text(
                text="Заменить",
                subtext="Стереть текущие и поставить из копии.",
                icon="msg_delete",
                red=True,
                on_click=lambda _: confirm_backup_import(filename, "replace"),
            ),
            Text(
                text="Объединить",
                subtext="Добавить из копии, ничего не стирая.",
                icon="msg_download",
                accent=True,
                on_click=lambda _: confirm_backup_import(filename, "merge"),
            ),
            Text(
                text="Поделиться копией",
                subtext="Отправить файл копии куда угодно.",
                icon="msg_share",
                on_click=lambda _: share_backup_file(filename),
            ),
            Header("Сведения"),
            Divider(f"Файл: {summary['filename']}"),
            Divider(f"Версия плагина: {summary['version']}"),
            Divider(f"Источник: {summary['plugin']}"),
            Divider(f"Путь: {summary['path']}"),
        ]

    if page_id == PAGE_FEATURES:
        return [
            Header("Функции"),
            Divider("Два основных модуля и автообновление. Включайте нужное."),
            Switch(
                key="enable_forward_bypass",
                text="Снять лимит выделения и удаления",
                subtext="Больше 100 сообщений сразу.",
                default=S.enable_forward_bypass,
                icon="msg_share",
                on_change=on_forward_toggle,
                link_alias="bypass",
            ),
            Switch(
                key="enable_peer_info_saver",
                text="Сохранять данные профиля",
                subtext="Страна, дата регистрации, смена имени и фото.",
                default=S.enable_peer_info_saver,
                icon="msg_openprofile",
                on_change=on_peer_saver_toggle,
                link_alias="saver",
            ),
            Header("Совместимость"),
            Divider("Если используются похожие старые плагины — отключите их во избежание конфликтов."),
        ]

    if page_id == PAGE_DATA:
        return [
            Header("Данные"),
            Divider("Сохранение, восстановление и очистка профилей. Все операции со страховкой."),
            *divider_lines(backup_overview_lines()),
            Text(
                text="Создать резервную копию",
                subtext="Сохранить все данные в файл.",
                icon="msg_share",
                accent=True,
                on_click=lambda _: run_in_background(export_backup),
            ),
            Text(
                text="Восстановить из копии",
                subtext="Вернуть данные из сохранённой копии.",
                icon="msg_download",
                accent=True,
                create_sub_fragment=subpage(PAGE_BACKUP_IMPORT),
                link_alias="backup_import",
            ),
            Text(
                text="Восстановить последнюю",
                subtext="Откатиться к последней копии.",
                icon="msg_restore",
                on_click=lambda _: confirm_restore_latest_backup(),
            ),
            Text(
                text="Поделиться последней копией",
                subtext="Отправить свежий файл копии.",
                icon="msg_share",
                on_click=lambda _: share_latest_backup(),
            ),
            Text(
                text="Сохранённые профили",
                subtext=f"Сохранённых профилей: {health['peer_count']}.",
                icon="msg_openprofile",
                create_sub_fragment=subpage(PAGE_VIEW_SAVED),
                link_alias="view_saved",
            ),
            Header("Автобэкап"),
            Divider("Плагин сам создаёт резервную копию раз в выбранный период (тихо, в фоне)."),
            Switch(
                key="auto_backup_enabled",
                text="Автоматический бэкап",
                subtext="Сам создаёт копии по расписанию.",
                default=S.auto_backup_enabled,
                icon="msg_download",
                on_change=on_auto_backup_toggle,
                link_alias="auto_backup",
            ),
            Selector(
                key="auto_backup_interval",
                text="Периодичность",
                default=S.auto_backup_interval,
                items=["раз в день", "раз в 3 дня", "раз в неделю", "раз в 2 недели", "раз в месяц"],
                icon="msg_settings",
                on_change=handle_auto_backup_interval_change,
                link_alias="auto_backup_interval",
            ),
            Header("Ротация копий"),
            Divider("Удаляет старые копии сверх лимита, но перед удалением сливает их данные "
                    "в самую свежую — ничего ценного не теряется."),
            Switch(
                key="backup_rotation_enabled",
                text="Автоматическая ротация",
                subtext="Удалять лишние старые копии.",
                default=S.backup_rotation_enabled,
                icon="msg_clear",
                on_change=on_backup_rotation_toggle,
                link_alias="rotation",
            ),
            Selector(
                key="backup_rotation_keep",
                text="Сколько копий хранить",
                default=S.backup_rotation_keep,
                items=["3 копии", "5 копий", "10 копий", "20 копий"],
                icon="msg_settings",
                on_change=handle_rotation_keep_change,
                link_alias="rotation_keep",
            ),
            Header("Очистка"),
            Text(
                text="Удалить пустые профили",
                subtext="Убрать профили без полезных данных.",
                icon="msg_clear",
                on_click=lambda _: clean_empty_profiles(),
            ),
            Text(
                text="Очистить всё",
                subtext="Удалить все данные. Копии останутся.",
                icon="msg_delete",
                red=True,
                on_click=lambda _: wipe_saved_peer_data(),
            ),
        ]

    if page_id == PAGE_BACKUP_IMPORT:
        files = list_backup_files()
        entries = [Header("Восстановить из копии"), Divider("Выберите резервную копию для восстановления или объединения.")]
        if not files:
            entries.append(Divider("Резервные копии пока не найдены."))
            return entries
        entries.append(Divider(f"Найдено копий: {len(files)}"))
        for filename in files:
            summary = backup_file_summary(filename)
            entries.append(Text(
                text=summary["created_label"],
                subtext=f"Профилей: {summary['peer_count']}  ·  Размер: {summary['size_label']}",
                icon="msg_download",
                create_sub_fragment=subpage(("backup_file", filename)),
            ))
        return entries

    if page_id == PAGE_REPAIR:
        old_info = health["old_info"]
        entries = [
            Header("Исправление проблем"),
            Divider(main_status_badge(health)),
            Divider(main_status_text(health)),
            Text(
                text="Проверить",
                subtext="Проверить, всё ли работает.",
                icon="msg_stats",
                accent=True,
                on_click=lambda _: run_in_background(run_health_check_now),
            ),
            Text(
                text="Исправить автоматически",
                subtext="Починить проблемы автоматически.",
                icon="msg_download_settings",
                accent=True,
                on_click=lambda _: run_in_background(auto_fix_now),
            ),
            Text(
                text="Оптимизировать",
                subtext="Пересобрать данные со страховкой.",
                icon="msg_settings",
                on_click=lambda _: run_in_background(optimize_storage_now),
            ),
        ]
        if old_info.get("exists"):
            entries.append(Text(
                text="Импортировать старые данные",
                subtext=f"Найдено записей: {old_info['count']}. Оригинал цел.",
                icon="msg_download",
                accent=True,
                on_click=lambda _: run_in_background(import_old_storage_now),
            ))
        if has_resolved_legacy_storage():
            entries.append(Text(
                text="Перенести в текущее хранилище",
                subtext="Перенести старые данные в текущее.",
                icon="files_storage",
                on_click=lambda _: run_in_background(migrate_detected_legacy_now),
            ))
        entries.extend(divider_lines([
            f"Профилей сохранено: {health['peer_count']}",
        ]))
        return entries

    if page_id == PAGE_UPDATES:
        update_status = "включено" if S.auto_update_enabled else "выключено"
        interval_labels = ["каждый час", "каждые 6 ч", "каждые 12 ч", "каждые 24 ч", "каждые 7 д", "вручную"]
        interval_text = interval_labels[S.auto_update_interval] if 0 <= S.auto_update_interval < len(interval_labels) else "—"
        return [
            Header("Автообновление"),
            Divider(f"Статус: {update_status}  ·  Интервал: {interval_text}"),
            Divider("Плагин сам проверяет канал, скачивает и устанавливает новую версию."),
            Switch(
                key="auto_update_enabled",
                text="Автообновление",
                subtext="Сам проверяет и ставит новые версии.",
                default=S.auto_update_enabled,
                icon="msg_download",
                on_change=lambda v: handle_auto_update_toggle(v),
                link_alias="auto_update",
            ),
            Selector(
                key="auto_update_interval",
                text="Интервал проверки",
                default=S.auto_update_interval,
                items=interval_labels,
                icon="msg_settings",
                on_change=lambda i: handle_update_interval_change(i),
                link_alias="interval",
            ),
            Input(
                key="auto_update_url",
                text="Ссылка на сообщение",
                subtext="Ссылка вида t.me/Канал/123.",
                default=S.auto_update_url,
                icon="msg_download",
            ),
            Text(
                text="Проверить ссылку",
                subtext="Проверить, что ссылка введена верно.",
                icon="msg_stats",
                on_click=lambda _: validate_update_url_now(),
            ),
            Text(
                text="Проверить обновления",
                subtext="Проверить обновления сейчас.",
                icon="msg_share",
                accent=True,
                on_click=lambda _: check_for_update_now(),
            ),
        ]

    if page_id == PAGE_HELP:
        return [
            Header("Что умеет плагин"),
            Divider("Здесь простыми словами объяснено, что делает каждая функция. "
                    "Читайте сверху вниз — ничего настраивать по ходу не нужно."),

            Header("1. Снять лимит выделения и удаления"),
            Divider("Обычно Telegram разрешает выделять и пересылать не больше 100 сообщений за раз. "
                    "Если выделить больше — часть просто не выделяется, и приходится делать это по частям."),
            Divider("С этой функцией лимит снимается: можно выделить хоть тысячу сообщений и переслать "
                    "или удалить их все сразу, за один раз."),
            Divider("При массовом удалении внизу экрана показывается, сколько уже удалено — например "
                    "«Удалено 300 из 1200», чтобы было видно, что процесс идёт, а не завис."),
            Divider("Где включить: раздел «Функции» → переключатель «Снять лимит выделения и удаления»."),

            Header("2. Сохранять данные профиля"),
            Divider("У каждого человека в Telegram есть скрытые данные: из какой он страны, в каком месяце "
                    "зарегистрировался, когда менял имя и фото. Иногда Telegram перестаёт их показывать."),
            Divider("Функция запоминает эти данные, пока они видны. Если позже Telegram их скроет — "
                    "плагин сам подставит сохранённое, и вы по-прежнему будете их видеть."),
            Divider("Всё хранится только на вашем телефоне. Никуда не отправляется, интернет для этого не нужен."),
            Divider("Где включить: раздел «Функции» → переключатель «Сохранять данные профиля»."),

            Header("3. Резервные копии (бэкапы)"),
            Divider("Резервная копия — это файл, в который складываются все сохранённые данные профилей. "
                    "Если что-то потеряется или сломается, из копии всё можно вернуть обратно."),
            Divider("«Создать резервную копию» — сохранить всё прямо сейчас в файл."),
            Divider("«Восстановить из копии» — выбрать любую копию из списка и вернуть данные из неё."),
            Divider("Где найти: раздел «Данные»."),

            Header("4. Восстановление: «Заменить» и «Объединить»"),
            Divider("Когда восстанавливаете данные из копии, плагин спросит способ."),
            Divider("«Заменить» — стереть всё, что есть сейчас, и поставить ровно то, что в копии. "
                    "Как будто вернулись в тот момент, когда копия создавалась."),
            Divider("«Объединить» — безопасный способ: ничего не стирается. Из копии добавляются только "
                    "те профили и поля, которых сейчас нет. То, что уже есть, остаётся как было."),
            Divider("Не знаете, что выбрать — берите «Объединить», оно ничего не испортит."),
            Divider("Перед любым восстановлением плагин сам делает страховочную копию текущего состояния — "
                    "на случай, если захотите откатиться."),

            Header("5. Автоматический бэкап"),
            Divider("Чтобы не создавать копии вручную, плагин может делать их сам по расписанию: "
                    "раз в день, раз в неделю, раз в месяц — как выберете."),
            Divider("Копии создаются тихо в фоне, вам ничего не нужно нажимать."),
            Divider("Где включить: раздел «Данные» → «Автобэкап»."),

            Header("6. Ротация (чистка старых копий)"),
            Divider("Если копий накопится слишком много, они занимают место. Ротация автоматически "
                    "удаляет самые старые, оставляя только последние (например, 10 штук)."),
            Divider("Важно: перед удалением старой копии всё ценное из неё переносится в свежую. "
                    "Поэтому данные не теряются — удаляются только лишние файлы, а не сами данные."),
            Divider("Где включить: раздел «Данные» → «Ротация копий»."),

            Header("7. Поделиться копией"),
            Divider("Кнопка отправляет файл копии в любое приложение — например, себе в «Избранное», "
                    "на компьютер или другу. Удобно, чтобы перенести данные на другой телефон."),
            Divider("Где найти: раздел «Данные» → «Поделиться последней копией», или внутри конкретной копии."),

            Header("8. Автообновление"),
            Divider("Плагин умеет сам проверять, вышла ли новая версия, скачивать её и предлагать установить. "
                    "Не нужно искать файл вручную."),
            Divider("Можно выбрать, как часто проверять (например, раз в сутки), или проверять только по кнопке."),
            Divider("«Проверить ссылку» — быстрая проверка, что адрес канала с обновлениями введён правильно."),
            Divider("Где найти: раздел «Обновления»."),

            Header("Если что-то пошло не так"),
            Divider("Раздел «Исправление проблем» умеет проверить и починить хранилище автоматически. "
                    "Все действия делаются со страховочной копией, поэтому данные в безопасности."),
        ]

    if page_id == PAGE_ABOUT:
        return [
            Header("UtilitiesPro"),
            Divider(f"v{__version__}  ·  {main_status_badge(health)}"),
            Divider("Обход лимитов · Сохранение профилей · Резервные копии · Автообновление"),
            Header("Авторы"),
            Divider("Форк и разработка: @VibeSPluginS"),
            Divider("Помощь с кодом: @kvuco и @chestertech"),
            Divider("Исходная идея плагинов: @zwylair"),
            Header("Принципы"),
            Divider("Работает локально, без внешних библиотек и серверов."),
            Divider("Сохраняет данные профиля и восстанавливает их, если Telegram перестал их отдавать."),
            Divider("Поддерживает резервное копирование со страховочной копией и автообновление из канала."),
        ]

    if isinstance(page_id, tuple) and len(page_id) == 2 and page_id[0] == "view_saved_detail":
        dialog_id = page_id[1]
        peer_storage.ensure_loaded()
        record = peer_storage.content.get(str(dialog_id), {})
        entries = [Header(f"Профиль {dialog_id}")]
        if not isinstance(record, dict) or not record:
            entries.append(Divider("Нет сохранённых данных для этого профиля"))
            return entries
        precious = []
        for field in PRECIOUS_PEER_FIELDS:
            v = record.get(field)
            if v not in (None, "", 0, False):
                precious.append(f"{field}: {v}")
        state = []
        for field in IMPORTANT_PEER_STATE_FIELDS:
            v = record.get(field)
            if v not in (None, "", 0, False):
                state.append(f"{field}: {v}")
        if precious:
            entries.append(Header("Ценные поля"))
            for line in precious:
                entries.append(Divider(line))
        if state:
            entries.append(Header("Состояние"))
            for line in state:
                entries.append(Divider(line))
        if not precious and not state:
            entries.append(Divider("Нет сохранённых полей"))

        def make_on_delete(did):
            def on_delete(_, __):
                delete_saved_peer_data(did)
                f = get_last_fragment()
                if f:
                    run_ui(f.finishFragment)
            return on_delete

        def confirm_delete(did):
            show_alert(
                f"Удалить профиль {did}?",
                "Сохранённые данные для этого профиля будут удалены без возможности восстановления.",
                buttons=[
                    ("positive", "Удалить", make_on_delete(did)),
                    ("negative", "Отмена", lambda _, __: None),
                ],
                cancelable=True,
            )

        entries.append(Header("Действия"))
        entries.append(Text(
            text="Удалить профиль",
            subtext="Удалить данные профиля навсегда.",
            icon="msg_delete",
            red=True,
            on_click=lambda _: confirm_delete(dialog_id),
        ))
        return entries

    if page_id == PAGE_VIEW_SAVED:
        peer_storage.ensure_loaded()
        raw = normalize_peer_dump(get_storage_content_copy())
        entries = [Header("Сохранённые профили")]
        if not raw:
            entries.append(Divider("Нет сохранённых данных."))
            return entries
        entries.append(Divider(f"Всего профилей: {len(raw)}"))
        for did in sorted(raw.keys(), key=int):
            record = raw[did]
            field_count = sum(1 for f in PRECIOUS_PEER_FIELDS if record.get(f) not in (None, "", 0, False))
            entries.append(Text(
                text=f"Профиль {did}",
                subtext=f"Ценных полей: {field_count}",
                icon="msg_openprofile",
                create_sub_fragment=subpage(("view_saved_detail", did)),
            ))
        return entries

    return [
        Header("UtilitiesPro"),
        Divider(f"v{__version__}  ·  {main_status_badge(health)}"),
        Divider(main_status_text(health)),
        Header("Быстрые действия"),
        Text(
            text="Проверить состояние",
            subtext="Быстро проверить, всё ли работает.",
            icon="msg_stats",
            accent=True,
            on_click=lambda _: run_in_background(run_health_check_now),
        ),
        Text(
            text="Автоисправление",
            subtext="Починить, если что-то сломалось.",
            icon="msg_download_settings",
            accent=True,
            on_click=lambda _: run_in_background(auto_fix_now),
        ),
        Text(
            text="Резервная копия",
            subtext="Сохранить данные в файл.",
            icon="msg_share",
            on_click=lambda _: run_in_background(export_backup),
        ),
        Header("Управление"),
        Text(
            text="Функции",
            subtext=f"Лимиты: {'вкл' if S.enable_forward_bypass else 'выкл'}  ·  Профили: {'вкл' if S.enable_peer_info_saver else 'выкл'}"
                    f"  ·  Обновления: {'вкл' if S.auto_update_enabled else 'выкл'}",
            icon="msg_openprofile",
            accent=True,
            create_sub_fragment=subpage(PAGE_FEATURES),
            link_alias="features",
        ),
        Text(
            text="Данные",
            subtext="Копии, восстановление, очистка профилей.",
            icon="files_storage",
            accent=True,
            create_sub_fragment=subpage(PAGE_DATA),
            link_alias="data",
        ),
        Text(
            text="Обновления",
            subtext="Проверка и установка новых версий.",
            icon="msg_download",
            accent=True,
            create_sub_fragment=subpage(PAGE_UPDATES),
            link_alias="updates",
        ),
        Text(
            text="Исправление проблем",
            subtext=health["description"],
            icon="msg_download_settings",
            create_sub_fragment=subpage(PAGE_REPAIR),
            link_alias="repair",
        ),
        Text(
            text="Как это работает",
            subtext="Простое объяснение всех функций.",
            icon="msg_info",
            accent=True,
            create_sub_fragment=subpage(PAGE_HELP),
            link_alias="help",
        ),
        Text(
            text="О плагине",
            subtext="Версия, авторы и справка.",
            icon="msg_info",
            create_sub_fragment=subpage(PAGE_ABOUT),
            link_alias="about",
        ),
    ]


# ─────────────────────────────────────────────────────────────
# Main plugin
# ─────────────────────────────────────────────────────────────

class UtilitiesPro(BasePlugin):
    def on_plugin_load(self):
        global current_plugin, MessagesControllerClass, MessagesControllerClassSource
        global _worker_active, _storage_writer_started
        current_plugin = self
        MessagesControllerClass = None
        MessagesControllerClassSource = None
        # После «горячей» перезагрузки модуля старый воркер мёртв — переинициализируем флаги,
        # иначе _schedule_storage_write не поднимет новый поток и сохранения прекратятся.
        _worker_active = True
        _storage_writer_started = False
        S.load()
        peer_storage.cleanup_stale_temp_files()  # подчищаем осиротевшие .tmp от прошлых аварийных завершений
        # Разогреваем хранилище в фоне, чтобы первый хук getPeerSettings не морозил UI на 100-300 мс.
        threading.Thread(target=peer_storage.ensure_loaded, name="peer-storage-prewarm", daemon=True).start()
        try:
            setup_forward_limit_bypass(self)
        except Exception:
            logger.error("Forward bypass setup failed:", exc_info=True)
        try:
            setup_peer_info_saver(self)
        except Exception:
            logger.error("Peer info saver setup failed:", exc_info=True)
        self.add_hook("TL_messages_forwardMessages")
        try:
            if S.auto_update_enabled:
                threading.Thread(target=lambda: start_auto_update(), daemon=True).start()
        except Exception:
            logger.error("Auto-update init failed:", exc_info=True)
        try:
            if S.auto_backup_enabled:
                run_in_background(_maybe_run_auto_backup)
        except Exception:
            logger.error("Auto-backup init failed:", exc_info=True)
        logger.info("Loaded.")

    def on_plugin_unload(self):
        global current_plugin, _worker_active, _storage_writer_started, _writer_thread
        # Гасим фоновый воркер записи, чтобы не плодить «мёртвые» потоки при перезагрузке плагина.
        _worker_active = False
        _storage_writer_started = False  # чтобы следующая загрузка подняла новый поток
        _storage_write_signal.set()  # будим поток, чтобы он вышел из wait() и завершился
        # Дожидаемся завершения старого воркера: без join hot-reload мог поднять второй
        # параллельный поток записи, конфликтующий за _write_lock.
        if _writer_thread is not None and _writer_thread.is_alive():
            _writer_thread.join(timeout=2.0)
        _writer_thread = None
        try:
            peer_storage.write()  # финальный сброс накопленных изменений на диск
        except Exception:
            logger.error("Final storage flush on unload failed", exc_info=True)
        stop_auto_update()
        selector_hook.clear_message_storage()
        dismiss_active_dialogs()
        current_plugin = None
        logger.info("Unloaded.")

    def on_app_event(self, event_type):
        global _last_update_check
        try:
            from base_plugin import AppEvent
            if event_type == AppEvent.RESUME:
                if S.auto_update_enabled:
                    idx = S.auto_update_interval
                    if 0 <= idx < len(_UPDATE_INTERVALS):
                        elapsed = time.monotonic() - _last_update_check
                        interval_s = _UPDATE_INTERVALS[idx] * 3600
                        if elapsed >= interval_s:
                            _launch_update_check()
                if S.auto_backup_enabled:
                    run_in_background(_maybe_run_auto_backup)
        except Exception:
            logger.error("Auto-update resume check failed:", exc_info=True)

    def create_settings(self):
        global current_plugin
        current_plugin = self
        return create_settings()

    def pre_request_hook(self, req_name, account, req):
        if req_name == "TL_messages_forwardMessages" and S.enable_forward_bypass:
            selector_hook.clear_message_storage()
        return HookResult()
