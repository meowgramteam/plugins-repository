# Сколько пользовательских копий держать при включённой ротации (индекс из настроек).
_ROTATION_KEEP_OPTIONS = [3, 5, 10, 20]
# Периодичность автобэкапа в днях (индекс из настроек).
_AUTO_BACKUP_DAYS = [1, 3, 7, 14, 30]


class S:
    enable_forward_bypass = True
    enable_peer_info_saver = True
    auto_update_enabled = False
    auto_update_interval = 3
    auto_update_url = "https://t.me/VibeSPluginS/19"
    backup_rotation_enabled = False
    backup_rotation_keep = 2
    auto_backup_enabled = False
    auto_backup_interval = 2
    _loaded = False

    @classmethod
    def get(cls, key, default=None):
        plugin = current_plugin
        if not plugin:
            return default
        return plugin.get_setting(key, default)

    @classmethod
    def set(cls, key, value):
        plugin = current_plugin
        if not plugin:
            return
        try:
            plugin.set_setting(key, value, reload_settings=False)
        except Exception:
            logger.error("Failed to save setting %s", key, exc_info=True)
        cls._loaded = False
        cls.load()

    @classmethod
    def load(cls):
        if cls._loaded:
            return
        cls.enable_forward_bypass = bool(cls.get("enable_forward_bypass", True))
        cls.enable_peer_info_saver = bool(cls.get("enable_peer_info_saver", True))
        cls.auto_update_enabled = bool(cls.get("auto_update_enabled", False))
        try:
            cls.auto_update_interval = int(cls.get("auto_update_interval", 3))
        except Exception:
            cls.auto_update_interval = 3
        if not 0 <= cls.auto_update_interval <= 5:
            cls.auto_update_interval = 3
        cls.auto_update_url = str(cls.get("auto_update_url", "https://t.me/VibeSPluginS/19"))
        cls.backup_rotation_enabled = bool(cls.get("backup_rotation_enabled", False))
        try:
            cls.backup_rotation_keep = int(cls.get("backup_rotation_keep", 2))
        except Exception:
            cls.backup_rotation_keep = 2
        if not 0 <= cls.backup_rotation_keep < len(_ROTATION_KEEP_OPTIONS):
            cls.backup_rotation_keep = 2
        cls.auto_backup_enabled = bool(cls.get("auto_backup_enabled", False))
        try:
            cls.auto_backup_interval = int(cls.get("auto_backup_interval", 2))
        except Exception:
            cls.auto_backup_interval = 2
        if not 0 <= cls.auto_backup_interval < len(_AUTO_BACKUP_DAYS):
            cls.auto_backup_interval = 2
        cls._loaded = True


def on_forward_toggle(enabled):
    S.set("enable_forward_bypass", enabled)


def on_peer_saver_toggle(enabled):
    S.set("enable_peer_info_saver", enabled)


def on_backup_rotation_toggle(enabled):
    S.set("backup_rotation_enabled", enabled)


def handle_rotation_keep_change(index):
    S.set("backup_rotation_keep", index)


def on_auto_backup_toggle(enabled):
    S.set("auto_backup_enabled", enabled)
    if enabled:
        run_in_background(_maybe_run_auto_backup)


def handle_auto_backup_interval_change(index):
    S.set("auto_backup_interval", index)


def handle_auto_update_toggle(enabled):
    S.set("auto_update_enabled", enabled)
    if enabled:
        start_auto_update()
    else:
        stop_auto_update()


def handle_update_interval_change(index):
    S.set("auto_update_interval", index)
    if S.auto_update_enabled:
        stop_auto_update()
        start_auto_update()


