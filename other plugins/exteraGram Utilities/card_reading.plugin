# Во сколько раз чаще выпадает "Сова на скакалке" относительно остальных карт.
# Прокидывается в HTML через ?owl_weight=N — сама HTML-страница считает вероятности.
DEFAULT_OWL_WEIGHT_INDEX = 2  # индекс в OWL_WEIGHT_OPTIONS ниже
OWL_WEIGHT_OPTIONS = [1, 2, 4, 8]  # обычный / чаще / ещё чаще / всегда

__id__ = "card_reading"
__name__ = "Гадание на картах"
__description__ = "Гадание на картах). Кнопка «Гадать» в меню чата или команда .гадать"
