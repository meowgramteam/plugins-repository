__min_version__ = "11.9.0"


def _dp(value: int) -> int:
    """Переводит dp в пиксели через AndroidUtilities, с безопасным fallback."""
    try:
        from org.telegram.messenger import AndroidUtilities
        return AndroidUtilities.dp(value)
    except Exception:
        return int(value * 3)


