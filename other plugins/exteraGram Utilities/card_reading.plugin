<title>Гадание</title>
<style>
  /* =====================================================================
     MATERIAL DESIGN 3 — DARK, DYNAMIC-COLOR-STYLE TOKENS
     ===================================================================== */
  :root {
    --md-primary: #ffb951;
    --md-on-primary: #452b00;
    --md-primary-container: #653f00;
    --md-on-primary-container: #ffddb0;

    --md-secondary: #dcc3a1;
    --md-surface: #141218;
    --md-surface-dim: #141218;
    --md-surface-bright: #3a373e;
    --md-surface-container-lowest: #0f0d13;
    --md-surface-container-low: #1d1b20;
    --md-surface-container: #211f26;
    --md-surface-container-high: #2b2930;
    --md-surface-container-highest: #36343b;
    --md-on-surface: #e6e0e9;
    --md-on-surface-variant: #cac4d0;
    --md-outline: #948f99;
    --md-outline-variant: #49454f;

    --md-elevation-1: 0 1px 3px rgba(0,0,0,0.35), 0 1px 2px rgba(0,0,0,0.5);
    --md-elevation-2: 0 3px 6px rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.35);
    --md-elevation-3: 0 6px 14px rgba(0,0,0,0.45), 0 3px 6px rgba(0,0,0,0.3);

    --shape-xs: 8px;
    --shape-s: 12px;
    --shape-m: 16px;
    --shape-l: 24px;
    --shape-xl: 32px;
    --shape-full: 999px;

    --card-w: 108px;
    --card-h: 156px;

    --motion-standard: cubic-bezier(0.2, 0, 0, 1);
    --motion-emphasized: cubic-bezier(0.3, 0, 0.1, 1);
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  html, body {
    margin: 0; padding: 0; height: 100%;
    background: var(--md-surface);
    font-family: "Google Sans", "Roboto", -apple-system, "Segoe UI", sans-serif;
    color: var(--md-on-surface);
    overflow: hidden;
    overscroll-behavior: none;
    user-select: none;
    -webkit-user-select: none;
  }

  #app {
    position: relative;
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    background:
      radial-gradient(1200px 600px at 50% -10%, rgba(255,185,81,0.10), transparent 60%),
      var(--md-surface);
    padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
  }

  /* ---------- MD3 Top App Bar (small, center-aligned) ---------- */
  #topbar {
    display: flex; align-items: center; justify-content: center;
    height: 56px; flex-shrink: 0;
    position: relative;
  }
  #topbar .title {
    font-size: 17px; font-weight: 500; letter-spacing: 0.1px;
    color: var(--md-on-surface);
    display: flex; align-items: center; gap: 8px;
  }
  #topbar .title .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--md-primary);
    box-shadow: 0 0 10px var(--md-primary);
  }

  /* ---------- Deck area ---------- */
  #deck-zone {
    position: relative;
    flex: 1;
    display: flex; align-items: center; justify-content: center;
    min-height: 0;
  }

  .card {
    position: absolute;
    width: var(--card-w); height: var(--card-h);
    border-radius: var(--shape-m);
    background: var(--md-surface-container-high);
    box-shadow: var(--md-elevation-1);
    transition: transform 0.5s var(--motion-standard), box-shadow 0.3s var(--motion-standard);
    transform-style: preserve-3d;
    will-change: transform;
  }
  .card-back {
    position: absolute; inset: 0;
    border-radius: var(--shape-m);
    background:
      linear-gradient(155deg, var(--md-surface-container-high) 0%, var(--md-surface-container) 100%);
    border: 1px solid var(--md-outline-variant);
    display: flex; align-items: center; justify-content: center;
    backface-visibility: hidden;
  }
  .card-back::after {
    content: "";
    width: 30px; height: 30px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--md-primary) 0%, transparent 70%);
    opacity: 0.55;
  }
  .card-front {
    position: absolute; inset: 0;
    border-radius: var(--shape-m);
    background: var(--md-surface-container-highest);
    backface-visibility: hidden;
    transform: rotateY(180deg);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--md-outline-variant);
  }
  .card-front img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.35s var(--motion-standard);
  }
  .card-front img.loaded { opacity: 1; }
  .card.selected { z-index: 50; box-shadow: var(--md-elevation-3); }

  /* ---------- Controls ---------- */
  #controls {
    flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
    padding: 4px 24px 20px;
  }

  /* MD3 outlined text field */
  .md-field {
    position: relative;
    width: 240px;
  }
  .md-field input {
    width: 100%;
    height: 52px;
    padding: 0 14px;
    border-radius: var(--shape-xs);
    border: 1px solid var(--md-outline);
    background: transparent;
    color: var(--md-on-surface);
    font-size: 15px;
    outline: none;
    text-align: center;
    text-overflow: clip;
    transition: border-color 0.2s var(--motion-standard);
  }
  .md-field input:focus { border-color: var(--md-primary); border-width: 2px; }
  .md-field input::placeholder {
    color: var(--md-on-surface-variant);
    text-align: center;
    overflow: visible;
  }

  /* MD3 filled button */
  .md-button {
    appearance: none; border: none;
    height: 52px; padding: 0 30px;
    border-radius: var(--shape-full);
    background: var(--md-primary);
    color: var(--md-on-primary);
    font-size: 15px; font-weight: 600; letter-spacing: 0.1px;
    box-shadow: var(--md-elevation-1);
    cursor: pointer;
    transition: transform 0.15s var(--motion-standard), box-shadow 0.15s var(--motion-standard), opacity 0.2s;
    position: relative;
    overflow: hidden;
  }
  .md-button:active { transform: scale(0.96); box-shadow: none; }
  .md-button:disabled { opacity: 0.38; box-shadow: none; cursor: default; }

  .md-button-text {
    background: transparent; border: none;
    color: var(--md-primary);
    font-size: 14px; font-weight: 600;
    padding: 12px 24px; border-radius: var(--shape-full);
    cursor: pointer;
    touch-action: manipulation;
    position: relative;
    z-index: 1;
  }
  .md-button-text:active { background: rgba(255,185,81,0.12); }

  /* ---------- Result sheet (MD3 bottom sheet style) ---------- */
  #result {
    position: absolute; left: 0; right: 0; bottom: 0;
    max-height: 48%;
    background: var(--md-surface-container-low);
    border-top-left-radius: var(--shape-xl);
    border-top-right-radius: var(--shape-xl);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.4);
    padding: 10px 24px calc(24px + env(safe-area-inset-bottom));
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    transform: translateY(100%);
    transition: transform 0.45s var(--motion-emphasized);
    pointer-events: none;
    overflow-y: auto;
    z-index: 200; /* always above the cards (cards top out at z-index 100) */
  }
  #result.visible { transform: translateY(0); pointer-events: auto; }
  #result .handle {
    width: 32px; height: 4px; border-radius: var(--shape-full);
    background: var(--md-outline-variant);
    margin-bottom: 4px;
  }
  #result-name {
    font-size: 20px; font-weight: 600; color: var(--md-on-primary-container);
