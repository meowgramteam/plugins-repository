# ─────────────────────────────────────────────────────────────────────────────
#  HELPERS
# ─────────────────────────────────────────────────────────────────────────────

def _s32(v: int) -> int:
    return v if v < 0x80000000 else v - 0x100000000

def _simple(full: str) -> str:
    return full.split(".")[-1].split("$")[0]

def _find_hooks(simple_name: str) -> List[str]:
    low = simple_name.lower()
    result, seen = [], set()
    for key, hooks in HOOK_DB.items():
        if key in low:
            for h in hooks:
                if h not in seen:
                    seen.add(h)
                    result.append(h)
    return result

def _find_theme_info(classes: List[str]) -> List[Tuple[str, str, List[str]]]:
    """Return [(pattern, section_name, [keys])] for view hierarchy."""
    seen_keys: set = set()
    result = []
    for cls in classes:
        low = _simple(cls).lower()
        for pattern, sections in THEME_KEY_DB.items():
            if pattern in low:
                for section_name, keys in sections:
                    fresh = [k for k in keys if k not in seen_keys]
                    if not fresh:
                        continue
                    seen_keys.update(fresh)
                    result.append((pattern, section_name, fresh))
    return result

def _get_tg_color(key: str):
    try:
        Theme = find_class("org.telegram.ui.ActionBar.Theme")
        if Theme:
            return Theme.getColor(key)
    except Exception:
        pass
    return None

def _int_to_hex(color: int) -> str:
    c = color & 0xFFFFFFFF
    return f"#{c:08X}"

def _hierarchy(view, max_depth: int) -> List[str]:
    chain, cur = [], view
    for _ in range(max_depth):
        if cur is None:
            break
        try:
            chain.append(cur.getClass().getName())
            cur = cur.getParent()
        except Exception:
            break
    return chain

def _view_attrs(view) -> dict:
    d = {}
    try: d["w"] = view.getMeasuredWidth()
    except Exception: pass
    try: d["h"] = view.getMeasuredHeight()
    except Exception: pass
    try: d["pl"] = view.getPaddingLeft()
    except Exception: pass
    try: d["pr"] = view.getPaddingRight()
    except Exception: pass
    try: d["pt"] = view.getPaddingTop()
    except Exception: pass
    try: d["pb"] = view.getPaddingBottom()
    except Exception: pass
    try:
        vis = view.getVisibility()
        d["vis"] = {0: "VISIBLE", 4: "INVISIBLE", 8: "GONE"}.get(vis, str(vis))
    except Exception: pass
    try: d["enabled"]   = str(view.isEnabled())
    except Exception: pass
    try: d["clickable"] = str(view.isClickable())
    except Exception: pass
    try: d["focused"]   = str(view.isFocused())
    except Exception: pass
    try:
        bg = view.getBackground()
        if bg and "ColorDrawable" in bg.getClass().getName():
            d["bg_color"] = _int_to_hex(bg.getColor())
    except Exception: pass
    try:
        d["text_color"] = _int_to_hex(view.getCurrentTextColor())
    except Exception: pass
    try:
        vid = view.getId()
        if vid > 0:
            d["res_id"] = view.getResources().getResourceEntryName(vid)
    except Exception: pass
    return d

def _clipboard(ctx, text: str) -> bool:
    try:
        ClipData = find_class("android.content.ClipData")
        cm = ctx.getSystemService("clipboard")
        if not cm:
            return False
        cm.setPrimaryClip(ClipData.newPlainText("HookInspector", text))
        return True
    except Exception as e:
        log(f"{TAG} clipboard: {e}")
        return False

def _write_file(path: str, text: str) -> bool:
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(text)
        return True
    except Exception as e:
        log(f"{TAG} write_file: {e}")
        return False


# ── DEBUG LOG ─────────────────────────────────────────────────────────────────
_DEBUG_BUF: deque = deque(maxlen=300)

def _dlog(plugin, msg: str):
    """Записать в debug-буфер. В logcat только если debug_mode включён."""
    ts = time.strftime("%H:%M:%S")
    _DEBUG_BUF.appendleft(f"[{ts}] {msg}")
    try:
        if plugin and plugin.get_setting("debug_mode", False):
            log(f"{TAG} {msg}")
    except Exception:
        log(f"{TAG} {msg}")

class HookInspectorPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self.panel_open     = False
        self.panel_view     = None
        self.bubble_open    = False
        self.bubble_view    = None
        self.wm             = None
        self._ctx           = None
        self._handler       = None
        self._bubble_silent = False

        self._title_tv   = None
        self._body_ll    = None
        self._filter_bar = None
        self._filter_et  = None
        # Tabs: 0=Inspector 1=Theme 2=Monitor 3=DB Search
        self._tab_idx    = 0
        self._tab_views  = []

        self._current_chain:      List[str]                          = []
        self._current_hooks:      List[str]                          = []
        self._current_attrs:      dict                               = {}
        self._current_theme_info: List[Tuple[str, str, List[str]]]   = []
        self._current_filter:     str                                = ""

        self._history:     deque = deque(maxlen=MAX_HISTORY)
        self._hist_idx:    int   = -1
        self._monitor_log: deque = deque(maxlen=MAX_MONITOR)

        self._px = self.get_setting("pos_x",     40)
        self._py = self.get_setting("pos_y",     100)
        self._pw = self.get_setting("width_dp",  0)
        self._ph = self.get_setting("height_dp", 0)
        self._bx = self.get_setting("bub_x",     20)
        self._by = self.get_setting("bub_y",     200)

        self._click_lock = threading.Lock()
        self._last_click = 0.0

        self._dp       = None
        self._LL       = None
        self._TV       = None
        self._V        = None
        self._fc       = None
        self._Runnable = None
        self._C        = THEME_DARK

    def _theme(self) -> dict:
        return THEME_LIGHT if self.get_setting("panel_theme", 0) == 1 else THEME_DARK

    # ── Lifecycle ──────────────────────────────────────────────────────────────

    def on_plugin_load(self):
        log(f"{TAG} loading v12.0.0")
        _dlog(self, "on_plugin_load start")
        try:
            _dlog(self, "calling _setup_hooks...")
            self._setup_hooks()
            _dlog(self, "_setup_hooks done, adding menu item...")
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                text="Hook Inspector",
                icon="msg_search",
                subtext="UI Inspector v12 — Theme Keys + Full Touch",
                on_click=self._drawer_click,
                priority=10,
            ))
            _dlog(self, "menu item added OK")
            BulletinHelper.show_success("Hook Inspector v12.0.0")
            _dlog(self, "on_plugin_load complete")
        except Exception as e:
            _dlog(self, f"CRITICAL on_plugin_load: {e}\n{traceback.format_exc()}")
            log(f"{TAG} load: {e}\n{traceback.format_exc()}")

    def on_plugin_unload(self):
        run_on_ui_thread(self._destroy_all)

    def _drawer_click(self, ctx):
        enabled = self.get_setting("inspector_enabled", False)
        new_val = not enabled
        self.set_setting("inspector_enabled", new_val, reload_settings=True)
        if new_val:
            BulletinHelper.show_info("Inspector: ON - tap any element")
        else:
            BulletinHelper.show_info("Inspector: OFF")
            run_on_ui_thread(self._destroy_all)

    # ── Xposed hooks ──────────────────────────────────────────────────────────

    def _setup_hooks(self):
        """
        Три хука для полного покрытия всех UI-элементов.
        В debug_mode логирует каждый шаг с полным traceback.
        """
        dbg = lambda msg: _dlog(self, f"[hooks] {msg}")
        dbg("_setup_hooks start")
        try:
            fc = find_class
            dbg("find_class imported OK")

            # Инициализируем shared debounce
            self._last_fire_ms = 0.0
            self._last_fire_id = 0
            self._fire_lock    = threading.Lock()
            dbg("debounce vars initialized")

            # Получаем класс View
            V = None
            try:
                V = fc("android.view.View")
                dbg(f"View class: {V}")
            except Exception as ev:
                dbg(f"FAIL get View class: {ev}")
                log(f"{TAG} CRITICAL: cannot find android.view.View: {ev}")
                return

            if V is None:
                dbg("FAIL: View class is None")
                log(f"{TAG} CRITICAL: View class is None")
                return

            # В Chaquopy find_class() возвращает Python-обёртку.
            # getDeclaredMethod — метод java.lang.Class, не Python-обёртки.
            # Правильно: V.getClass() даёт реальный java.lang.Class объект.
            ViewClass = V.getClass()
            dbg(f"ViewClass (java.lang.Class): {ViewClass}")

            # Hook 1: performClick — обычные кнопки с OnClickListener
            try:
                m = ViewClass.getDeclaredMethod("performClick")
                m.setAccessible(True)
                self.hook_method(m, _ClickHook(self), 10)
                dbg("performClick hooked OK")
                log(f"{TAG} performClick hooked")
            except Exception as e1:
                dbg(f"FAIL performClick: {e1}\n{traceback.format_exc()}")
                log(f"{TAG} performClick hook fail: {e1}")

            # Hook 2: performLongClick
            try:
                m2 = ViewClass.getDeclaredMethod("performLongClick")
                m2.setAccessible(True)
                self.hook_method(m2, _LongClickHook(self), 10)
                dbg("performLongClick hooked OK")
                log(f"{TAG} performLongClick hooked")
            except Exception as e2:
                dbg(f"FAIL performLongClick: {e2}\n{traceback.format_exc()}")
                log(f"{TAG} performLongClick hook fail: {e2}")

            # Hook 3: dispatchTouchEvent — ловит ВСЁ: send button, canvas-кнопки, медиа
            # getDeclaredMethod(String, Class<?>...) — нужен Class<MotionEvent>
            # В Chaquopy: MotionEvent_cls.getClass() даёт java.lang.Class<MotionEvent>
            try:
                MotionEvent_cls = fc("android.view.MotionEvent")
                dbg(f"MotionEvent class: {MotionEvent_cls}")
                MotionEvent_java_cls = MotionEvent_cls.getClass()
                dbg(f"MotionEvent java.lang.Class: {MotionEvent_java_cls}")
                m3 = ViewClass.getDeclaredMethod("dispatchTouchEvent", MotionEvent_java_cls)
                m3.setAccessible(True)
                self.hook_method(m3, _DispatchTouchHook(self), 10)
                dbg("dispatchTouchEvent hooked OK")
                log(f"{TAG} dispatchTouchEvent hooked")
            except Exception as e3:
                dbg(f"FAIL dispatchTouchEvent: {e3}\n{traceback.format_exc()}")
                log(f"{TAG} dispatchTouchEvent hook fail: {e3}")
                # Fallback: попробуем через массив параметров (Chaquopy varargs)
                try:
                    MotionEvent_cls = fc("android.view.MotionEvent")
                    me_cls = MotionEvent_cls.getClass()
                    m3b = ViewClass.getDeclaredMethod("dispatchTouchEvent", [me_cls])
                    m3b.setAccessible(True)
                    self.hook_method(m3b, _DispatchTouchHook(self), 10)
                    dbg("dispatchTouchEvent hooked OK (array fallback)")
                    log(f"{TAG} dispatchTouchEvent hooked (fallback)")
                except Exception as e3b:
                    dbg(f"FAIL dispatchTouchEvent fallback: {e3b}")
                    log(f"{TAG} dispatchTouchEvent fallback fail: {e3b}")

            dbg("_setup_hooks complete")

        except Exception as e:
            dbg(f"CRITICAL exception: {e}\n{traceback.format_exc()}")
            log(f"{TAG} setup_hooks critical: {e}\n{traceback.format_exc()}")

    # ── View event handler ────────────────────────────────────────────────────

    def _is_own_view(self, view) -> bool:
        """Проверить — является ли view частью нашей собственной панели/bubble.
        Если да — не инспектируем (иначе панель очищает сама себя при скролле)."""
        try:
            cur = view
            for _ in range(30):
                if cur is None:
                    break
                # Сравниваем по Java-идентификатору объекта
                try:
                    if self.panel_view is not None:
                        if cur.hashCode() == self.panel_view.hashCode():
                            return True
                    if self.bubble_view is not None:
                        if cur.hashCode() == self.bubble_view.hashCode():
                            return True
                except Exception:
                    pass
                try:
                    cur = cur.getParent()
                except Exception:
                    break
        except Exception:
            pass
        return False

    def on_view_clicked(self, view, is_long=False):
        if not self.get_setting("inspector_enabled", False):
            return
        # КРИТИЧНО: не инспектируем собственные view (панель, bubble)
        # Иначе скролл панели -> hook -> removeAllViews() -> пустой экран
        if self._is_own_view(view):
            return
        depth_idx  = self.get_setting("hierarchy_depth", 1)
        only_known = self.get_setting("show_only_known", False)
        max_depth  = [3, 5, 10][depth_idx]
        plugin     = self
        try:
            cls_name = view.getClass().getName() if view else "None"
            _dlog(self, f"on_view_clicked cls={cls_name} long={is_long}")
        except Exception:
            pass
        try:
            attrs = _view_attrs(view)
        except Exception:
            attrs = {}

        def analyze():
            try:
                chain = _hierarchy(view, max_depth)
                if not chain:
                    return
                seen, merged = set(), []
                for cls in chain:
                    for h in _find_hooks(_simple(cls)):
                        if h not in seen:
                            seen.add(h)
                            merged.append(h)
                if only_known and not merged:
                    return

                theme_info = _find_theme_info(chain)

                ts    = time.strftime("%H:%M:%S")
                cname = _simple(chain[0])
                n_tk  = sum(len(keys) for _, _, keys in theme_info)
                plugin._monitor_log.appendleft(
                    f"[{ts}]{'[L]' if is_long else '   '} {cname}  "
                    f"({len(merged)} hooks, {n_tk} theme keys)"
                )

                if plugin._bubble_silent:
                    plugin._current_chain      = chain
                    plugin._current_hooks      = merged
                    plugin._current_attrs      = attrs
                    plugin._current_theme_info = theme_info
                    plugin._push_history(chain, merged, attrs, theme_info)
                    run_on_ui_thread(plugin._refresh_monitor_view)
                    return

                def on_ui():
                    plugin._current_chain      = chain
                    plugin._current_hooks      = merged
                    plugin._current_attrs      = attrs
                    plugin._current_theme_info = theme_info
                    plugin._push_history(chain, merged, attrs, theme_info)
                    plugin._refresh_monitor_view()
                    if plugin.panel_open:
                        plugin._fill_current_tab()
                        plugin._update_title(chain)
                    else:
                        plugin._open_panel(chain, merged, attrs, theme_info)

                run_on_ui_thread(on_ui)
            except Exception as e:
                log(f"{TAG} analyze: {e}")

        run_on_queue(analyze, PLUGINS_QUEUE)

    # ── History ───────────────────────────────────────────────────────────────

    def _push_history(self, chain, hooks, attrs, theme_info):
        if self._hist_idx > 0:
            for _ in range(self._hist_idx):
                try: self._history.popleft()
                except Exception: pass
            self._hist_idx = 0
        self._history.appendleft((chain, hooks, attrs, theme_info))

    def _hist_back(self):
        if self._hist_idx + 1 < len(self._history):
            self._hist_idx += 1
            chain, hooks, attrs, ti = self._history[self._hist_idx]
            self._current_chain      = chain
            self._current_hooks      = hooks
            self._current_attrs      = attrs
            self._current_theme_info = ti
            self._fill_current_tab()
            self._update_title(chain)

    def _hist_forward(self):
        if self._hist_idx > 0:
            self._hist_idx -= 1
            chain, hooks, attrs, ti = self._history[self._hist_idx]
            self._current_chain      = chain
            self._current_hooks      = hooks
            self._current_attrs      = attrs
            self._current_theme_info = ti
            self._fill_current_tab()
            self._update_title(chain)

    # ── WM / CTX ──────────────────────────────────────────────────────────────

    def _ensure_wm_ctx(self):
        if self.wm and self._ctx:
            return True
        try:
            fc        = find_class
            AppLoader = fc("org.telegram.messenger.ApplicationLoader")
            ctx = AppLoader.applicationContext
            if not ctx:
                return False
            wm = ctx.getSystemService("window")
            if not wm:
                return False
            Build    = fc("android.os.Build")
            Settings = fc("android.provider.Settings")
            if Build.VERSION.SDK_INT >= 23 and not Settings.canDrawOverlays(ctx):
                return False
            Handler_cls  = fc("android.os.Handler")
            Looper_cls   = fc("android.os.Looper")
            Runnable_cls = fc("java.lang.Runnable")
            self._ctx      = ctx
            self.wm        = wm
            self._handler  = Handler_cls(Looper_cls.getMainLooper())
            self._Runnable = Runnable_cls
            return True
        except Exception as e:
            log(f"{TAG} ensure_wm: {e}")
            return False

    def _post_delayed(self, fn, ms):
        try:
            Runnable_cls = self._Runnable
            if not Runnable_cls or not self._handler:
                return
            class _R(dynamic_proxy(Runnable_cls)):
                def __init__(self): super().__init__()
                def run(self): fn()
            self._handler.postDelayed(_R(), ms)
        except Exception as e:
            log(f"{TAG} post_delayed: {e}")

    # ── BUBBLE ────────────────────────────────────────────────────────────────

    def _show_bubble(self):
        if self.bubble_open:
            return
        try:
            if not self._ensure_wm_ctx():
                return
            fc               = find_class
            LayoutParams     = fc("android.view.WindowManager$LayoutParams")
            Gravity_cls      = fc("android.view.Gravity")
            GradientDrawable = fc("android.graphics.drawable.GradientDrawable")
            PixelFormat      = fc("android.graphics.PixelFormat")
            Build            = fc("android.os.Build")
            ImageView        = fc("android.widget.ImageView")
            OnTouchListener  = fc("android.view.View$OnTouchListener")
            MotionEvent      = fc("android.view.MotionEvent")
            FrameLayout      = fc("android.widget.FrameLayout")
            Gravity          = fc("android.view.Gravity")

            ctx    = self._ctx
            wm     = self.wm
            dp     = AndroidUtilities.dp
            plugin = self
            C      = self._theme()

            bg = GradientDrawable()
            bg.setShape(GradientDrawable.OVAL)
            bg.setColor(_s32(0xEE0A1628))
            bg.setStroke(dp(2.0), _s32(C["ACCENT"]))

            container = FrameLayout(ctx)
            container.setBackground(bg)
            container.setClickable(True)
            container.setFocusable(True)
            try: container.setLayerType(2, None)   # software layer для bubble
            except Exception: pass

            try:
                iv = ImageView(ctx)
                rid = ctx.getResources().getIdentifier(
                    "msg_search", "drawable", ctx.getPackageName())
                if rid != 0:
                    iv.setImageResource(rid)
                    PD = fc("android.graphics.PorterDuff$Mode")
                    CF = fc("android.graphics.PorterDuffColorFilter")
                    iv.setColorFilter(CF(_s32(C["ACCENT"]), PD.SRC_IN))
                fl_lp = FrameLayout.LayoutParams(dp(24.0), dp(24.0))
                fl_lp.gravity = Gravity.CENTER
                container.addView(iv, fl_lp)
            except Exception as e:
                log(f"{TAG} bubble icon: {e}")

            class _BubTouch(dynamic_proxy(OnTouchListener)):
                def __init__(self):
                    super().__init__()
                    self._tx = self._ty = 0.0
                    self._vx = self._vy = 0
                    self._moved = False

                def onTouch(self_t, v, ev):
                    if not plugin.bubble_view or not plugin.wm:
                        return False
                    lp  = plugin.bubble_view.getLayoutParams()
                    act = ev.getAction()
                    if act == MotionEvent.ACTION_DOWN:
                        self_t._tx, self_t._ty = ev.getRawX(), ev.getRawY()
                        self_t._vx, self_t._vy = lp.x, lp.y
                        self_t._moved = False
                        return True
                    elif act == MotionEvent.ACTION_MOVE:
                        dx = ev.getRawX() - self_t._tx
                        dy = ev.getRawY() - self_t._ty
                        if abs(dx) > 8 or abs(dy) > 8:
                            self_t._moved = True
                        if self_t._moved:
                            lp.x = int(self_t._vx + dx)
                            lp.y = int(self_t._vy + dy)
                            try: plugin.wm.updateViewLayout(plugin.bubble_view, lp)
                            except Exception: pass
                        return True
                    elif act == MotionEvent.ACTION_UP:
                        if self_t._moved:
                            plugin._bx = lp.x
                            plugin._by = lp.y
                            plugin.set_setting("bub_x", lp.x)
                            plugin.set_setting("bub_y", lp.y)
                        else:
                            run_on_ui_thread(plugin._bubble_expand)
                        return True
                    return False

            container.setOnTouchListener(_BubTouch())

            lp_type  = (LayoutParams.TYPE_APPLICATION_OVERLAY
                        if Build.VERSION.SDK_INT >= 26
                        else LayoutParams.TYPE_PHONE)
            wm_flags = (LayoutParams.FLAG_NOT_FOCUSABLE |
                        LayoutParams.FLAG_NOT_TOUCH_MODAL |
                        LayoutParams.FLAG_LAYOUT_NO_LIMITS)
            sz = dp(56.0)
            lp = LayoutParams(sz, sz, self._bx, self._by,
                              lp_type, wm_flags, PixelFormat.TRANSLUCENT)
            lp.gravity = Gravity_cls.TOP | Gravity_cls.LEFT
            wm.addView(container, lp)
            self.bubble_view    = container
            self.bubble_open    = True
            self._bubble_silent = True

            try:
                container.setAlpha(0.0)
                container.setScaleX(0.3)
                container.setScaleY(0.3)
                container.animate().alpha(1.0).scaleX(1.0).scaleY(1.0).setDuration(240).start()
            except Exception: pass

        except Exception as e:
            log(f"{TAG} show_bubble: {e}\n{traceback.format_exc()}")

    def _hide_bubble(self, animated=True):
        bub = self.bubble_view
        if not bub:
            self.bubble_open    = False
            self._bubble_silent = False
            return
        plugin = self
        if animated:
            try:
                bub.animate().alpha(0.0).scaleX(0.3).scaleY(0.3).setDuration(160).start()
            except Exception: pass
            def _remove():
                try:
                    if plugin.wm and plugin.bubble_view:
                        plugin.wm.removeView(plugin.bubble_view)
                except Exception: pass
                plugin.bubble_view    = None
                plugin.bubble_open    = False
                plugin._bubble_silent = False
            self._post_delayed(_remove, 180)
        else:
            try:
                if self.wm: self.wm.removeView(bub)
            except Exception: pass
            self.bubble_view    = None
            self.bubble_open    = False
            self._bubble_silent = False

    def _bubble_expand(self):
        self._hide_bubble(animated=False)
        self._open_panel(
            self._current_chain, self._current_hooks,
            self._current_attrs, self._current_theme_info
        )

    # ── PANEL ─────────────────────────────────────────────────────────────────

    def _open_panel(self, chain, hooks, attrs, theme_info=None):
        if theme_info is None:
            theme_info = []
        if self.panel_open:
            self._current_chain      = chain
            self._current_hooks      = hooks
            self._current_attrs      = attrs
            self._current_theme_info = theme_info
            self._fill_current_tab()
            self._update_title(chain)
            return
        try:
            if not self._ensure_wm_ctx():
                BulletinHelper.show_error("No overlay permission")
                return

            fc               = find_class
            LayoutParams     = fc("android.view.WindowManager$LayoutParams")
            Gravity_cls      = fc("android.view.Gravity")
            LinearLayout     = fc("android.widget.LinearLayout")
            FrameLayout      = fc("android.widget.FrameLayout")
            ScrollView       = fc("android.widget.ScrollView")
            TextView         = fc("android.widget.TextView")
            ImageView        = fc("android.widget.ImageView")
            EditText         = fc("android.widget.EditText")
            View             = fc("android.view.View")
            GradientDrawable = fc("android.graphics.drawable.GradientDrawable")
            PixelFormat      = fc("android.graphics.PixelFormat")
            Build            = fc("android.os.Build")
            OnTouchListener  = fc("android.view.View$OnTouchListener")
            MotionEvent      = fc("android.view.MotionEvent")
            Runnable_cls     = fc("java.lang.Runnable")

            ctx    = self._ctx
            wm     = self.wm
            dp     = AndroidUtilities.dp
            plugin = self
            C      = self._theme()

            self._LL       = LinearLayout
            self._TV       = TextView
            self._V        = View
            self._fc       = fc
            self._dp       = dp
            self._Runnable = Runnable_cls
            self._C        = C

            def mk_round(color, r=16, sw=0, sc=0):
                d = GradientDrawable()
                d.setColor(_s32(color))
                d.setCornerRadius(float(dp(r)))
                if sw: d.setStroke(sw, _s32(sc))
                return d

            def mk_corners(color, tl=0, tr=0, br=0, bl=0, sw=0, sc=0):
                d = GradientDrawable()
                d.setColor(_s32(color))
                try:
                    d.setCornerRadii([float(dp(tl)), float(dp(tl)),
                                      float(dp(tr)), float(dp(tr)),
                                      float(dp(br)), float(dp(br)),
                                      float(dp(bl)), float(dp(bl))])
                except Exception:
                    d.setCornerRadius(float(dp(max(tl, tr, br, bl) or 0)))
                if sw: d.setStroke(sw, _s32(sc))
                return d

            Point_cls = fc("android.graphics.Point")
            sz_pt = Point_cls()
            wm.getDefaultDisplay().getSize(sz_pt)
            screen_w, screen_h = sz_pt.x, sz_pt.y
            ov_w  = self._pw if self._pw > 0 else int(screen_w * 0.92)
            ov_h  = self._ph if self._ph > 0 else int(screen_h * 0.58)
            pos_x = self._px if self._px else int((screen_w - ov_w) // 2)
            pos_y = self._py if self._py else int(screen_h * 0.06)

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setBackground(mk_corners(C["BG"], 20, 20, 20, 20, dp(1), C["BORDER"]))
            root.setAlpha(0.0)
            try:
                root.setTranslationY(float(-dp(20)))
                root.setScaleX(0.95)
                root.setScaleY(0.95)
            except Exception: pass

            # ── Drag ─────────────────────────────────────────────────────────
            class _DragTouch(dynamic_proxy(OnTouchListener)):
                def __init__(self):
                    super().__init__()
                    self._tx = self._ty = 0.0
                    self._vx = self._vy = 0
                    self._moved = False
                def onTouch(self_t, v, ev):
                    if not plugin.panel_view or not plugin.wm: return False
                    lp  = plugin.panel_view.getLayoutParams()
                    act = ev.getAction()
                    if act == MotionEvent.ACTION_DOWN:
                        self_t._tx, self_t._ty = ev.getRawX(), ev.getRawY()
                        self_t._vx, self_t._vy = lp.x, lp.y
                        self_t._moved = False
                        return True
                    elif act == MotionEvent.ACTION_MOVE:
                        dx = ev.getRawX() - self_t._tx
                        dy = ev.getRawY() - self_t._ty
                        if abs(dx) > 5 or abs(dy) > 5: self_t._moved = True
                        if self_t._moved:
                            lp.x = int(self_t._vx + dx)
                            lp.y = int(self_t._vy + dy)
                            try: plugin.wm.updateViewLayout(plugin.panel_view, lp)
                            except Exception: pass
                        return True
                    elif act == MotionEvent.ACTION_UP:
                        if self_t._moved:
                            plugin._px = lp.x; plugin._py = lp.y
                            plugin.set_setting("pos_x", lp.x)
                            plugin.set_setting("pos_y", lp.y)
                        return self_t._moved
                    return False

            # ── Resize ───────────────────────────────────────────────────────
            class _ResizeTouch(dynamic_proxy(OnTouchListener)):
                def __init__(self):
                    super().__init__()
                    self._tx = self._ty = 0.0
                    self._iw = self._ih = 0
                def onTouch(self_t, v, ev):
                    if not plugin.panel_view or not plugin.wm: return False
                    lp  = plugin.panel_view.getLayoutParams()
                    act = ev.getAction()
                    if act == MotionEvent.ACTION_DOWN:
                        self_t._tx, self_t._ty = ev.getRawX(), ev.getRawY()
                        self_t._iw, self_t._ih = lp.width, lp.height
                        return True
                    elif act == MotionEvent.ACTION_MOVE:
                        dx = ev.getRawX() - self_t._tx
                        dy = ev.getRawY() - self_t._ty
                        lp.width  = max(dp(260.0), int(self_t._iw + dx))
                        lp.height = max(dp(180.0), int(self_t._ih + dy))
                        try: plugin.wm.updateViewLayout(plugin.panel_view, lp)
                        except Exception: pass
                        return True
                    elif act == MotionEvent.ACTION_UP:
                        plugin.set_setting("width_dp",  lp.width)
                        plugin.set_setting("height_dp", lp.height)
                        return True
                    return False

            # ── HEADER ───────────────────────────────────────────────────────
            hdr = LinearLayout(ctx)
            hdr.setOrientation(LinearLayout.HORIZONTAL)
            hdr.setGravity(Gravity_cls.CENTER_VERTICAL)
            hdr.setPadding(dp(12), dp(8), dp(8), dp(8))
            hdr.setBackground(mk_corners(C["HDR"], tl=20, tr=20))
            hdr.setOnTouchListener(_DragTouch())
            try: hdr.setLayerType(2, None)
            except Exception: pass

            try:
                iv_s = ImageView(ctx)
                rid  = ctx.getResources().getIdentifier(
                    "msg_search", "drawable", ctx.getPackageName())
                if rid != 0:
                    iv_s.setImageResource(rid)
                    PD = fc("android.graphics.PorterDuff$Mode")
                    CF = fc("android.graphics.PorterDuffColorFilter")
                    iv_s.setColorFilter(CF(_s32(C["ACCENT"]), PD.SRC_IN))
                il = LinearLayout.LayoutParams(dp(18.0), dp(18.0))
                il.rightMargin = dp(8)
                hdr.addView(iv_s, il)
            except Exception: pass

            title_tv = TextView(ctx)
            title_tv.setTextColor(_s32(C["CLASS"]))
            title_tv.setTextSize(1, 13.0)
            title_tv.setSingleLine(True)
            try:
                title_tv.setTypeface(AndroidUtilities.getTypeface(
                    AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
            except Exception: pass
            hdr.addView(title_tv, LinearLayout.LayoutParams(0, -2, 1.0))

            def mk_hdr_btn(icon_name, fallback_text, bg_col, tx_col, fn, ml=4):
                fl = FrameLayout(ctx)
                fl.setBackground(mk_round(bg_col, 10))
                fl.setClickable(True)
                fl.setFocusable(True)
                fl.setOnClickListener(OnClickListener(fn))
                sb = dp(30.0)
                bl = LinearLayout.LayoutParams(sb, sb)
                bl.leftMargin = dp(ml)
                fl.setLayoutParams(bl)
                try:
                    rid = ctx.getResources().getIdentifier(
                        icon_name, "drawable", ctx.getPackageName())
                    if rid != 0:
                        iv = ImageView(ctx)
                        iv.setImageResource(rid)
                        PD = fc("android.graphics.PorterDuff$Mode")
                        CF = fc("android.graphics.PorterDuffColorFilter")
                        iv.setColorFilter(CF(_s32(tx_col), PD.SRC_IN))
                        ic = FrameLayout.LayoutParams(dp(15.0), dp(15.0))
                        ic.gravity = Gravity_cls.CENTER
                        fl.addView(iv, ic)
                    else: raise Exception()
                except Exception:
                    tv = TextView(ctx)
                    tv.setText(fallback_text)
                    tv.setTextSize(1, 11.0)
                    tv.setTextColor(_s32(tx_col))
                    tv.setGravity(Gravity_cls.CENTER)
                    fl.addView(tv, FrameLayout.LayoutParams(-1, -1))
                return fl

            hdr.addView(mk_hdr_btn("msg_arrow_back",  "<", C["MIN_BG"],   C["BTN_TX"], lambda v: run_on_ui_thread(plugin._hist_back)))
            hdr.addView(mk_hdr_btn("msg_arrow_next",  ">", C["MIN_BG"],   C["BTN_TX"], lambda v: run_on_ui_thread(plugin._hist_forward)))
            hdr.addView(mk_hdr_btn("msg_arrow_down",  "v", C["MIN_BG"],   C["BTN_TX"], lambda v: run_on_ui_thread(plugin._to_bubble)))
            hdr.addView(mk_hdr_btn("msg_close",       "x", C["CLOSE_BG"], C["CLOSE_TX"],
                lambda v: (plugin.set_setting("inspector_enabled", False, reload_settings=True),
                           run_on_ui_thread(plugin._destroy_all),
                           BulletinHelper.show_info("Inspector OFF"))))
            root.addView(hdr, LinearLayout.LayoutParams(-1, -2))

            accent_v = View(ctx)
            accent_v.setBackgroundColor(_s32(C["ACCENT"]))
            root.addView(accent_v, LinearLayout.LayoutParams(-1, dp(1)))

            # ── TAB BAR: Inspector | Theme | Monitor | DB ────────────────────
            tab_bar = LinearLayout(ctx)
            tab_bar.setOrientation(LinearLayout.HORIZONTAL)
            tab_bar.setBackgroundColor(_s32(C["HDR"]))
            tab_bar.setPadding(dp(8), dp(4), dp(8), dp(4))
            try: tab_bar.setLayerType(2, None)
            except Exception: pass

            tab_labels    = ["Inspector", "Theme", "Monitor", "DB", "Log"]
            tab_views_list = []

            def _mk_tab_btn(label, idx, tabs_ref):
                tv = TextView(ctx)
                tv.setText(label)
                tv.setTextSize(1, 10.5)
                tv.setGravity(Gravity_cls.CENTER)
                tv.setPadding(dp(8), dp(5), dp(8), dp(5))
                tv.setBackground(mk_round(
                    C["TAB_ACT"] if plugin._tab_idx == idx else C["TAB_INA"], 8))
                tv.setTextColor(_s32(C["TAB_TX"]))
                tv.setClickable(True)
                tv.setFocusable(True)
                lp = LinearLayout.LayoutParams(0, -2, 1.0)
                lp.setMargins(dp(2), 0, dp(2), 0)
                tv.setLayoutParams(lp)
                def _on_tab(v, i=idx):
                    plugin._tab_idx = i
                    for j, t in enumerate(tabs_ref):
                        try: t.setBackground(mk_round(
                            C["TAB_ACT"] if j == i else C["TAB_INA"], 8))
                        except Exception: pass
                    plugin._fill_current_tab()
                tv.setOnClickListener(OnClickListener(_on_tab))
                return tv

            for i, lbl in enumerate(tab_labels):
                t = _mk_tab_btn(lbl, i, tab_views_list)
                tab_views_list.append(t)
                tab_bar.addView(t)
            root.addView(tab_bar, LinearLayout.LayoutParams(-1, -2))

            div_tab = View(ctx)
            div_tab.setBackgroundColor(_s32(C["DIV"]))
            root.addView(div_tab, LinearLayout.LayoutParams(-1, dp(1)))

            # ── FILTER BAR (Inspector only) ───────────────────────────────────
            filter_bar = LinearLayout(ctx)
            filter_bar.setOrientation(LinearLayout.HORIZONTAL)
            filter_bar.setGravity(Gravity_cls.CENTER_VERTICAL)
            filter_bar.setBackgroundColor(_s32(C["HDR"]))
            filter_bar.setPadding(dp(8), dp(4), dp(8), dp(4))

            filter_et = EditText(ctx)
            filter_et.setHint("Filter hooks...")
            filter_et.setTextSize(1, 11.0)
            filter_et.setTextColor(_s32(C["INPUT_TX"]))
            try: filter_et.setHintTextColor(_s32(0xFF556677))
            except Exception: pass
            gd_f = GradientDrawable()
            gd_f.setColor(_s32(C["INPUT_BG"]))
            gd_f.setCornerRadius(float(dp(8)))
            filter_et.setBackground(gd_f)
            filter_et.setPadding(dp(8), dp(4), dp(8), dp(4))
            filter_et.setSingleLine(True)
            filter_bar.addView(filter_et, LinearLayout.LayoutParams(0, -2, 1.0))

            try:
                FCL = fc("android.view.View$OnFocusChangeListener")
                class _FC(dynamic_proxy(FCL)):
                    def __init__(self): super().__init__()
                    def onFocusChange(self_t, v, has_focus):
                        try:
                            lp2 = plugin.panel_view.getLayoutParams()
                            if has_focus:
                                lp2.flags &= ~LayoutParams.FLAG_NOT_FOCUSABLE
                                lp2.softInputMode = LayoutParams.SOFT_INPUT_ADJUST_RESIZE
                            else:
                                lp2.flags |= LayoutParams.FLAG_NOT_FOCUSABLE
                                lp2.softInputMode = 0
                                try:
                                    plugin._current_filter = str(filter_et.getText()).strip().lower()
                                    plugin._fill_current_tab()
                                except Exception: pass
                            if plugin.wm and plugin.panel_view:
                                plugin.wm.updateViewLayout(plugin.panel_view, lp2)
                        except Exception as e2: log(f"{TAG} focus: {e2}")
                filter_et.setOnFocusChangeListener(_FC())
            except Exception: pass

            def _apply_filter(v):
                try:
                    plugin._current_filter = str(filter_et.getText()).strip().lower()
                    plugin._fill_current_tab()
                    try:
                        imm = ctx.getSystemService("input_method")
                        imm.hideSoftInputFromWindow(filter_et.getWindowToken(), 0)
                        filter_et.clearFocus()
                    except Exception: pass
                except Exception: pass

            def _clear_filter(v):
                plugin._current_filter = ""
                try: filter_et.setText("")
                except Exception: pass
                plugin._fill_current_tab()

            ok_btn = TextView(ctx)
            ok_btn.setText("OK")
            ok_btn.setTextSize(1, 11.0)
            ok_btn.setTextColor(_s32(C["BTN_TX"]))
            ok_btn.setGravity(Gravity_cls.CENTER)
            ok_btn.setPadding(dp(8), dp(4), dp(8), dp(4))
            ok_btn.setBackground(mk_round(C["BTN_BG"], 8))
            ok_btn.setClickable(True); ok_btn.setFocusable(True)
            ok_btn.setOnClickListener(OnClickListener(_apply_filter))
            ok_lp = LinearLayout.LayoutParams(-2, -2)
            ok_lp.leftMargin = dp(6)
            filter_bar.addView(ok_btn, ok_lp)

            cl_btn = TextView(ctx)
            cl_btn.setText("X")
            cl_btn.setTextSize(1, 11.0)
            cl_btn.setTextColor(_s32(C["CLOSE_TX"]))
            cl_btn.setGravity(Gravity_cls.CENTER)
            cl_btn.setPadding(dp(6), dp(4), dp(6), dp(4))
            cl_btn.setBackground(mk_round(C["CLOSE_BG"], 8))
            cl_btn.setClickable(True); cl_btn.setFocusable(True)
            cl_btn.setOnClickListener(OnClickListener(_clear_filter))
            cl_lp = LinearLayout.LayoutParams(-2, -2)
            cl_lp.leftMargin = dp(4)
            filter_bar.addView(cl_btn, cl_lp)

            root.addView(filter_bar, LinearLayout.LayoutParams(-1, -2))
            div_f = View(ctx)
            div_f.setBackgroundColor(_s32(C["DIV"]))
            root.addView(div_f, LinearLayout.LayoutParams(-1, dp(1)))

            # ── BODY ─────────────────────────────────────────────────────────
            sv = ScrollView(ctx)
            sv.setFillViewport(True)
            root.addView(sv, LinearLayout.LayoutParams(-1, 0, 1.0))
            body = LinearLayout(ctx)
            body.setOrientation(LinearLayout.VERTICAL)
            body.setPadding(dp(14), dp(10), dp(14), dp(6))
            sv.addView(body, LinearLayout.LayoutParams(-1, -2))

            # ── FOOTER ───────────────────────────────────────────────────────
            ft_sep = View(ctx)
            ft_sep.setBackgroundColor(_s32(C["DIV"]))
            root.addView(ft_sep, LinearLayout.LayoutParams(-1, dp(1)))

            footer = LinearLayout(ctx)
            footer.setOrientation(LinearLayout.HORIZONTAL)
            footer.setGravity(Gravity_cls.CENTER_VERTICAL)
            footer.setBackground(mk_corners(C["FT_BG"], br=20, bl=20))
            footer.setPadding(dp(6), dp(6), dp(4), dp(7))
            try: footer.setLayerType(2, None)
            except Exception: pass

            def mk_ft_btn(label, fn):
                b = TextView(ctx)
                b.setText(label)
                b.setTextColor(_s32(C["BTN_TX"]))
                b.setTextSize(1, 10.5)
                b.setGravity(Gravity_cls.CENTER)
                b.setPadding(dp(6), dp(5), dp(6), dp(5))
                b.setBackground(mk_round(C["BTN_BG"], 8))
                b.setClickable(True); b.setFocusable(True)
                b.setOnClickListener(OnClickListener(fn))
                lp = LinearLayout.LayoutParams(0, -2, 1.0)
                lp.setMargins(dp(2), 0, dp(2), 0)
                b.setLayoutParams(lp)
                return b

            def _do_export(v):
                try:
                    ts   = time.strftime("%Y%m%d_%H%M%S")
                    path = f"{EXPORT_DIR}/{ts}.txt"
                    ok   = _write_file(path, plugin._plain_text())
                    BulletinHelper.show_success(f"Saved: {path}" if ok else "Export failed")
                except Exception as e2:
                    BulletinHelper.show_error(f"Export: {e2}")

            def _copy_theme_keys(v):
                ti  = plugin._current_theme_info
                if not ti:
                    BulletinHelper.show_info("No theme keys")
                    return
                lines = []
                for _, sec, keys in ti:
                    lines.append(f"// {sec}")
                    for k in keys:
                        lines.append(f"Theme.getColor(\"{k}\")")
                ok = _clipboard(ctx, "\n".join(lines))
                n  = sum(len(kk) for _, _, kk in ti)
                BulletinHelper.show_info(f"Copied {n} theme keys" if ok else "Error")

            footer.addView(mk_ft_btn("All",
                lambda v: (_clipboard(ctx, plugin._plain_text()),
                           BulletinHelper.show_info("Copied"))))
            footer.addView(mk_ft_btn("Class",
                lambda v: (_clipboard(ctx, plugin._current_chain[0]) if plugin._current_chain else None,
                           BulletinHelper.show_info("Class copied" if plugin._current_chain else "Nothing"))))
            footer.addView(mk_ft_btn("Hooks",
                lambda v: (_clipboard(ctx, "\n".join(f"* {h}" for h in plugin._current_hooks)) if plugin._current_hooks else None,
                           BulletinHelper.show_info(
                               f"{len(plugin._current_hooks)} hooks" if plugin._current_hooks else "No hooks"))))
            footer.addView(mk_ft_btn("Theme", _copy_theme_keys))
            footer.addView(mk_ft_btn("Save", _do_export))

            # Resize corner
            resize_fl = FrameLayout(ctx)
            rd = GradientDrawable()
            rd.setColor(_s32(C["RESIZE"]))
            rd.setCornerRadius(float(dp(6)))
            rd.setStroke(dp(1.0), _s32(C["ACCENT"]))
            resize_fl.setBackground(rd)
            resize_fl.setOnTouchListener(_ResizeTouch())
            resize_fl.setClickable(True); resize_fl.setFocusable(True)
            rs_lp = LinearLayout.LayoutParams(dp(30.0), dp(26.0))
            rs_lp.setMargins(dp(4), 0, dp(2), 0)
            resize_fl.setLayoutParams(rs_lp)
            _rs_added = False
            for iname in ("msg_fullscreen", "msg_expand", "msg_screencast"):
                try:
                    rid = ctx.getResources().getIdentifier(iname, "drawable", ctx.getPackageName())
                    if rid != 0:
                        rv = ImageView(ctx)
                        rv.setImageResource(rid)
                        PD = fc("android.graphics.PorterDuff$Mode")
                        CF = fc("android.graphics.PorterDuffColorFilter")
                        rv.setColorFilter(CF(_s32(C["BTN_TX"]), PD.SRC_IN))
                        ic = FrameLayout.LayoutParams(dp(14.0), dp(14.0))
                        ic.gravity = Gravity_cls.CENTER
                        resize_fl.addView(rv, ic)
                        _rs_added = True
                        break
                except Exception: pass
            if not _rs_added:
                rv_tv = TextView(ctx)
                rv_tv.setText("\u2921")
                rv_tv.setTextSize(1, 13.0)
                rv_tv.setTextColor(_s32(C["BTN_TX"]))
                rv_tv.setGravity(Gravity_cls.CENTER)
                resize_fl.addView(rv_tv, FrameLayout.LayoutParams(-1, -1))
            footer.addView(resize_fl)
            root.addView(footer, LinearLayout.LayoutParams(-1, -2))

            self._title_tv      = title_tv
            self._body_ll       = body
            self._filter_bar    = filter_bar
            self._filter_et     = filter_et
            self._tab_views     = tab_views_list
            self._current_chain      = chain
            self._current_hooks      = hooks
            self._current_attrs      = attrs
            self._current_theme_info = theme_info
            self._fill_current_tab()
            self._update_title(chain)

            lp_type  = (LayoutParams.TYPE_APPLICATION_OVERLAY
                        if Build.VERSION.SDK_INT >= 26
                        else LayoutParams.TYPE_PHONE)
            wm_flags = (LayoutParams.FLAG_NOT_FOCUSABLE |
                        LayoutParams.FLAG_NOT_TOUCH_MODAL |
                        LayoutParams.FLAG_LAYOUT_NO_LIMITS)
            wm_lp = LayoutParams(ov_w, ov_h, pos_x, pos_y,
                                 lp_type, wm_flags, PixelFormat.TRANSLUCENT)
            wm_lp.gravity = Gravity_cls.TOP | Gravity_cls.LEFT

            # LAYER_TYPE_SOFTWARE = 2
            # Обязательно для overlay-окон: GPU-кэш текстур вылетает и текст
            # заменяется цветными прямоугольниками. Software rendering решает это.
            try:
                root.setLayerType(2, None)
            except Exception as e_layer:
                log(f"{TAG} setLayerType: {e_layer}")

            wm.addView(root, wm_lp)
            self.panel_view = root
            self.panel_open = True

            try:
                root.animate().alpha(1.0).translationY(0.0) \
                    .scaleX(1.0).scaleY(1.0).setDuration(250).start()
            except Exception:
                try: root.setAlpha(1.0)
                except Exception: pass

        except Exception as e:
            log(f"{TAG} _open_panel: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_error(f"Inspector: {e}")
            self.panel_view = None
            self.panel_open = False

    # ── To bubble ─────────────────────────────────────────────────────────────

    def _to_bubble(self):
        if not self.panel_view or not self.wm:
            return
        panel  = self.panel_view
        plugin = self
        try:
            panel.animate().alpha(0.0).scaleX(0.85).scaleY(0.85).setDuration(180).start()
        except Exception: pass
        def _switch():
            try:
                if plugin.wm and plugin.panel_view:
                    plugin.wm.removeView(plugin.panel_view)
            except Exception: pass
            plugin.panel_view = None
            plugin.panel_open = False
            plugin._show_bubble()
        self._post_delayed(_switch, 190)

    # ── Tab routing ───────────────────────────────────────────────────────────


    # ── [5] DEBUG LOG TAB ─────────────────────────────────────────────────────

    def _open_log_panel(self):
        """Открыть overlay-панель сразу на вкладке Log."""
        self._tab_idx = 4
        if self.panel_open:
            # Панель уже открыта — просто переключаем вкладку
            try:
                for j, t in enumerate(self._tab_views):
                    C = self._C
                    fc = self._fc
                    dp = self._dp
                    GD = fc("android.graphics.drawable.GradientDrawable")
                    gd = GD()
                    gd.setColor(self._s32_local(C["TAB_ACT"] if j == 4 else C["TAB_INA"]))
                    gd.setCornerRadius(float(dp(8)))
                    t.setBackground(gd)
            except Exception: pass
            self._fill_debug_log()
            return
        # Панель закрыта — открываем с пустыми данными, Log будет отображён
        run_on_ui_thread(lambda: self._open_panel([], [], {}, []))

    def _s32_local(self, v: int) -> int:
        return v if v < 0x80000000 else v - 0x100000000

    def _fill_debug_log(self):
        """Вкладка Log — показывает _DEBUG_BUF прямо в панели."""
        try:
            body = self._body_ll
            dp   = self._dp
            LL   = self._LL
            TV   = self._TV
            V    = self._V
            ctx  = self._ctx
            fc   = self._fc
            C    = self._C
            body.removeAllViews()

            Gravity = fc("android.view.Gravity")
            GD      = fc("android.graphics.drawable.GradientDrawable")

            # ── Header row ───────────────────────────────────────────────────
            hdr = TV(ctx)
            hdr.setText(f"DEBUG LOG  ({len(_DEBUG_BUF)} entries)")
            hdr.setTextColor(self._s32_local(C["HOOK_IC"]))
            hdr.setTextSize(1, 10.5)
            body.addView(hdr, LL.LayoutParams(-1, -2))

            # ── Кнопки управления ────────────────────────────────────────────
            btn_row = LL(ctx)
            btn_row.setOrientation(LL.HORIZONTAL)
            btn_row.setGravity(Gravity.CENTER_VERTICAL)
            lp_br = LL.LayoutParams(-1, -2)
            lp_br.topMargin = dp(6)
            lp_br.bottomMargin = dp(6)

            plugin = self

            def mk_btn(label, fn):
                b = TV(ctx)
                b.setText(label)
                b.setTextColor(self._s32_local(C["BTN_TX"]))
                b.setTextSize(1, 10.5)
                b.setGravity(Gravity.CENTER)
                b.setPadding(dp(8), dp(5), dp(8), dp(5))
                gd = GD()
                gd.setColor(self._s32_local(C["BTN_BG"]))
                gd.setCornerRadius(float(dp(8)))
                b.setBackground(gd)
                b.setClickable(True)
                b.setFocusable(True)
                b.setOnClickListener(OnClickListener(fn))
                lp = LL.LayoutParams(0, -2, 1.0)
                lp.setMargins(dp(2), 0, dp(2), 0)
                b.setLayoutParams(lp)
                return b

            def _clear_log(v):
                _DEBUG_BUF.clear()
                plugin._fill_debug_log()
                BulletinHelper.show_info("Log cleared")

            def _run_diag(v):
                plugin._run_diagnostics(v)
                # После запуска — обновляем вкладку
                run_on_ui_thread(plugin._fill_debug_log)

            btn_row.addView(mk_btn("Run Diagnostics", _run_diag))
            btn_row.addView(mk_btn("Clear", _clear_log))
            body.addView(btn_row, lp_br)

            # Подсказка как читать логи
            hint = TV(ctx)
            hint.setText("adb logcat | grep '[HI]'  — для logcat")
            hint.setTextColor(self._s32_local(C["MON_TS"]))
            hint.setTextSize(1, 9.5)
            lp_h = LL.LayoutParams(-1, -2)
            lp_h.bottomMargin = dp(6)
            body.addView(hint, lp_h)

            div = V(ctx)
            div.setBackgroundColor(self._s32_local(C["DIV"]))
            body.addView(div, LL.LayoutParams(-1, dp(1)))

            if not _DEBUG_BUF:
                t = TV(ctx)
                t.setText("Log is empty.\nTap any UI element to generate entries.")
                t.setTextColor(self._s32_local(C["PARENT"]))
                t.setTextSize(1, 11.5)
                lp_t = LL.LayoutParams(-1, -2)
                lp_t.topMargin = dp(8)
                body.addView(t, lp_t)
                return

            # ── Записи лога ──────────────────────────────────────────────────
            for i, entry in enumerate(_DEBUG_BUF):
                t = TV(ctx)
                t.setText(entry)
                # Цвет по содержимому: FAIL/CRITICAL — красный, OK — зелёный, default
                if "FAIL" in entry or "CRITICAL" in entry or "ERROR" in entry:
                    color = 0xFFFF7B72  # красный
                elif "OK" in entry or "hooked" in entry or "complete" in entry:
                    color = 0xFF7EE787  # зелёный
                elif "WARN" in entry:
                    color = 0xFFE3A847  # жёлтый
                else:
                    color = C["MON_TX"]
                t.setTextColor(self._s32_local(color))
                t.setTextSize(1, 10.0)
                try:
                    Tf = fc("android.graphics.Typeface")
                    t.setTypeface(Tf.MONOSPACE)
                except Exception: pass
                try: t.setTextIsSelectable(True)
                except Exception: pass
                lp = LL.LayoutParams(-1, -2)
                lp.bottomMargin = dp(1)
                body.addView(t, lp)

        except Exception as e:
            log(f"{TAG} _fill_debug_log: {e}\n{traceback.format_exc()}")

    def _fill_current_tab(self):
        try:
            try:
                vis = 0 if self._tab_idx == 0 else 8
                self._filter_bar.setVisibility(vis)
            except Exception: pass
            if   self._tab_idx == 0: self._fill_inspector()
            elif self._tab_idx == 1: self._fill_theme_tab()
            elif self._tab_idx == 2: self._fill_monitor()
            elif self._tab_idx == 3: self._fill_db_search()
            elif self._tab_idx == 4: self._fill_debug_log()
        except Exception as e:
            log(f"{TAG} fill_tab: {e}")

    # ── [0] INSPECTOR TAB ─────────────────────────────────────────────────────

    def _fill_inspector(self):
        try:
            body  = self._body_ll
            dp    = self._dp
            LL    = self._LL
            TV    = self._TV
            V     = self._V
            ctx   = self._ctx
            fc    = self._fc
            C     = self._C
            chain = self._current_chain
            hooks = self._current_hooks
            attrs = self._current_attrs
            filt  = self._current_filter
            body.removeAllViews()

            GD      = fc("android.graphics.drawable.GradientDrawable")
            Gravity = fc("android.view.Gravity")
            OnLCL   = fc("android.view.View$OnLongClickListener")

            def mk_badge(text, bg, stroke, tc):
                bd = GD()
                bd.setColor(_s32(bg))
                bd.setCornerRadius(float(dp(4)))
                bd.setStroke(dp(1.0), _s32(stroke))
                tv = TV(ctx)
                tv.setText(text)
                tv.setTextSize(1, 8.0)
                tv.setTextColor(_s32(tc))
                tv.setPadding(dp(5), dp(2), dp(5), dp(2))
                tv.setBackground(bd)
                return tv

            def mk_sep(top=8, bot=4):
                dv = V(ctx)
                dv.setBackgroundColor(_s32(C["DIV"]))
                lp = LL.LayoutParams(-1, dp(1))
                lp.topMargin = dp(top); lp.bottomMargin = dp(bot)
                return dv

            if not chain:
                t = TV(ctx)
                t.setText("Tap any UI element...")
                t.setTextColor(_s32(C["PARENT"]))
                t.setTextSize(1, 13.0)
                body.addView(t, LL.LayoutParams(-1, -2))
                return

            # CLASS row
            row1 = LL(ctx)
            row1.setOrientation(LL.HORIZONTAL)
            row1.setGravity(Gravity.CENTER_VERTICAL)
            lp_b = LL.LayoutParams(-2, -2)
            lp_b.rightMargin = dp(8)
            row1.addView(mk_badge("CLASS", 0xFF102040, 0xFF1E4080, C["ACCENT"]), lp_b)
            cls_tv = TV(ctx)
            cls_tv.setText(chain[0])
            cls_tv.setTextColor(_s32(C["CLASS"]))
            cls_tv.setTextSize(1, 11.0)
            try:
                Tf = fc("android.graphics.Typeface")
                cls_tv.setTypeface(Tf.MONOSPACE)
            except Exception: pass
            try: cls_tv.setTextIsSelectable(True)
            except Exception: pass
            row1.addView(cls_tv, LL.LayoutParams(0, -2, 1.0))
            body.addView(row1, LL.LayoutParams(-1, -2))

            # ResID
            res = attrs.get("res_id", "")
            if res:
                r = TV(ctx)
                r.setText(f"@id/{res}")
                r.setTextColor(_s32(C["RESID"]))
                r.setTextSize(1, 10.5)
                try:
                    Tf = fc("android.graphics.Typeface")
                    r.setTypeface(Tf.MONOSPACE)
                except Exception: pass
                lp_r = LL.LayoutParams(-1, -2)
                lp_r.topMargin = dp(3)
                body.addView(r, lp_r)

            # Attrs
            if attrs:
                body.addView(mk_sep())
                body.addView(mk_badge("ATTRS", 0xFF102818, 0xFF1A4828, C["ATTR_TX"]),
                             LL.LayoutParams(-2, -2))
                lines = []
                if "w" in attrs and "h" in attrs:
                    lines.append(f"size: {attrs['w']} x {attrs['h']} px")
                pads = [attrs.get(k) for k in ("pl", "pt", "pr", "pb")]
                if all(p is not None for p in pads):
                    lines.append(f"padding: L{pads[0]} T{pads[1]} R{pads[2]} B{pads[3]}")
                for k in ("vis", "enabled", "clickable", "focused"):
                    if k in attrs: lines.append(f"{k}: {attrs[k]}")
                for k in ("bg_color", "text_color"):
                    if k in attrs: lines.append(f"{k}: {attrs[k]}")
                for line in lines:
                    t = TV(ctx)
                    t.setText(line)
                    t.setTextColor(_s32(C["ATTR_TX"]))
                    t.setTextSize(1, 10.5)
                    try:
                        Tf = fc("android.graphics.Typeface")
                        t.setTypeface(Tf.MONOSPACE)
                    except Exception: pass
                    lp_t = LL.LayoutParams(-1, -2)
                    lp_t.topMargin = dp(1)
                    body.addView(t, lp_t)

            # Hierarchy
            if len(chain) > 1:
                body.addView(mk_sep())
                body.addView(mk_badge("HIERARCHY", 0xFF0D1A30, 0xFF1A3060, C["PARENT"]),
                             LL.LayoutParams(-2, -2))
                for i, cls in enumerate(chain[1:], 1):
                    t = TV(ctx)
                    t.setText("  " * i + "- " + _simple(cls))
                    t.setTextColor(_s32(HIER_COLORS[i % len(HIER_COLORS)]))
                    t.setTextSize(1, 10.5)
                    try: t.setTextIsSelectable(True)
                    except Exception: pass
                    lp_t = LL.LayoutParams(-1, -2)
                    lp_t.topMargin = dp(1)
                    body.addView(t, lp_t)

            # Hooks
            body.addView(mk_sep())
            filtered = [h for h in hooks if filt in h.lower()] if filt else hooks
            if filtered:
                cnt_row = LL(ctx)
                cnt_row.setOrientation(LL.HORIZONTAL)
                cnt_row.setGravity(Gravity.CENTER_VERTICAL)
                cnt_row.addView(mk_badge("HOOKS", 0xFF2A1A00, 0xFF4A3000, C["HOOK_IC"]))
                cnt = TV(ctx)
                cnt.setText(f"  {len(filtered)}/{len(hooks)}" if filt else f"  {len(hooks)}")
                cnt.setTextSize(1, 10.0)
                cnt.setTextColor(_s32(C["PARENT"]))
                cnt_row.addView(cnt)
                body.addView(cnt_row, LL.LayoutParams(-1, -2))

                for h in filtered:
                    h_row = LL(ctx)
                    h_row.setOrientation(LL.HORIZONTAL)
                    h_row.setPadding(0, dp(2), 0, dp(1))
                    dot = TV(ctx)
                    dot.setText("> ")
                    dot.setTextColor(_s32(C["HOOK_IC"]))
                    dot.setTextSize(1, 13.0)
                    h_row.addView(dot, LL.LayoutParams(-2, -2))
                    h_tv = TV(ctx)
                    h_tv.setText(h)
                    h_tv.setTextColor(_s32(C["HOOK_TX"]))
                    h_tv.setTextSize(1, 11.5)
                    h_tv.setMaxLines(3)
                    try: h_tv.setTextIsSelectable(True)
                    except Exception: pass
                    h_row.addView(h_tv, LL.LayoutParams(0, -2, 1.0))
                    try:
                        class _HL(dynamic_proxy(OnLCL)):
                            def __init__(self, hs):
                                super().__init__()
                                self._h = hs
                            def onLongClick(self_t, v2):
                                ok = _clipboard(ctx, self_t._h)
                                BulletinHelper.show_info("Hook copied" if ok else "Error")
                                return True
                        h_row.setLongClickable(True)
                        h_row.setOnLongClickListener(_HL(h))
                    except Exception: pass
                    body.addView(h_row, LL.LayoutParams(-1, -2))
            else:
                no = TV(ctx)
                no.setText(f"No hooks match '{filt}'" if filt
                           else f"Not in database.\nfind_class(\"{chain[0]}\")")
                no.setTextColor(_s32(0xFF6A7A8A))
                no.setTextSize(1, 11.5)
                try: no.setTextIsSelectable(True)
                except Exception: pass
                body.addView(no, LL.LayoutParams(-1, -2))

            body.addView(mk_sep(top=10))
            attr = TV(ctx)
            attr.setText("@rei_plugins  |  @lyzos")
            attr.setTextColor(_s32(0xFF2A3A4A))
            attr.setTextSize(1, 9.5)
            attr.setGravity(1)
            lp_a = LL.LayoutParams(-1, -2)
            lp_a.topMargin = dp(4); lp_a.bottomMargin = dp(4)
            body.addView(attr, lp_a)

        except Exception as e:
            log(f"{TAG} _fill_inspector: {e}\n{traceback.format_exc()}")

    # ── [1] THEME TAB ─────────────────────────────────────────────────────────

    def _fill_theme_tab(self):
        """Show Theme.getColor() keys grouped by section (= редактор тем), with live color swatches."""
        try:
            body  = self._body_ll
            dp    = self._dp
            LL    = self._LL
            TV    = self._TV
            V     = self._V
            ctx   = self._ctx
            fc    = self._fc
            C     = self._C
            chain = self._current_chain
            ti    = self._current_theme_info   # [(pattern, section, [keys])]
            attrs = self._current_attrs
            body.removeAllViews()

            GD      = fc("android.graphics.drawable.GradientDrawable")
            Gravity = fc("android.view.Gravity")
            OnLCL   = fc("android.view.View$OnLongClickListener")

            def mk_sep():
                dv = V(ctx)
                dv.setBackgroundColor(_s32(C["DIV"]))
                lp = LL.LayoutParams(-1, dp(1))
                lp.topMargin = dp(6); lp.bottomMargin = dp(4)
                return dv

            if not chain:
                t = TV(ctx)
                t.setText("Tap any UI element first...")
                t.setTextColor(_s32(C["PARENT"]))
                t.setTextSize(1, 13.0)
                body.addView(t, LL.LayoutParams(-1, -2))
                return

            # Class name header
            cls_tv = TV(ctx)
            cls_tv.setText(_simple(chain[0]))
            cls_tv.setTextColor(_s32(C["CLASS"]))
            cls_tv.setTextSize(1, 12.0)
            try:
                cls_tv.setTypeface(AndroidUtilities.getTypeface(
                    AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
            except Exception: pass
            body.addView(cls_tv, LL.LayoutParams(-1, -2))

            # Detected bg/text color from view itself
            bg_col  = attrs.get("bg_color",   "")
            txt_col = attrs.get("text_color", "")
            if bg_col or txt_col:
                clr_row = LL(ctx)
                clr_row.setOrientation(LL.HORIZONTAL)
                clr_row.setGravity(Gravity.CENTER_VERTICAL)
                lp_cr = LL.LayoutParams(-1, -2)
                lp_cr.topMargin = dp(4)
                for label, hx in (("bg:", bg_col), ("text:", txt_col)):
                    if not hx:
                        continue
                    try:
                        sw_d = GD()
                        sw_d.setColor(_s32(int(hx.replace("#", ""), 16)))
                        sw_d.setCornerRadius(float(dp(3)))
                        sw_d.setStroke(dp(1.0), _s32(0xFF444444))
                        sw_v = V(ctx)
                        sw_v.setBackground(sw_d)
                        sw_lp = LL.LayoutParams(dp(14.0), dp(14.0))
                        sw_lp.rightMargin = dp(4)
                        clr_row.addView(sw_v, sw_lp)
                    except Exception: pass
                    lbl = TV(ctx)
                    lbl.setText(f"{label} {hx}  ")
                    lbl.setTextColor(_s32(C["ATTR_TX"]))
                    lbl.setTextSize(1, 10.0)
                    try:
                        Tf = fc("android.graphics.Typeface")
                        lbl.setTypeface(Tf.MONOSPACE)
                    except Exception: pass
                    clr_row.addView(lbl, LL.LayoutParams(-2, -2))
                body.addView(clr_row, lp_cr)

            body.addView(mk_sep())

            if not ti:
                no = TV(ctx)
                no.setText(
                    "No theme keys found for this class.\n"
                    "Class pattern is not in THEME_KEY_DB.\n"
                    "Try the DB tab to search manually."
                )
                no.setTextColor(_s32(C["TH_NONE"]))
                no.setTextSize(1, 11.5)
                body.addView(no, LL.LayoutParams(-1, -2))

                # Still show a hint with the class name for manual lookup
                hint = TV(ctx)
                hint.setText(f"Simple name: {_simple(chain[0])}")
                hint.setTextColor(_s32(C["PARENT"]))
                hint.setTextSize(1, 10.5)
                lp_h = LL.LayoutParams(-1, -2)
                lp_h.topMargin = dp(6)
                body.addView(hint, lp_h)
                return

            # Stat header
            n_total = sum(len(keys) for _, _, keys in ti)
            n_sec   = len(ti)
            hdr_r = LL(ctx)
            hdr_r.setOrientation(LL.HORIZONTAL)
            hdr_r.setGravity(Gravity.CENTER_VERTICAL)

            bd = GD()
            bd.setColor(_s32(C["TH_BG"]))
            bd.setCornerRadius(float(dp(4)))
            bd.setStroke(dp(1.0), _s32(C["TH_BD"]))
            badge = TV(ctx)
            badge.setText("THEME KEYS")
            badge.setTextSize(1, 8.0)
            badge.setTextColor(_s32(C["TH_TX"]))
            badge.setPadding(dp(5), dp(2), dp(5), dp(2))
            badge.setBackground(bd)
            hdr_r.addView(badge)
            cnt_tv = TV(ctx)
            cnt_tv.setText(f"  {n_total} keys in {n_sec} sections")
            cnt_tv.setTextSize(1, 10.0)
            cnt_tv.setTextColor(_s32(C["PARENT"]))
            hdr_r.addView(cnt_tv)
            body.addView(hdr_r, LL.LayoutParams(-1, -2))

            hint_lp = LL.LayoutParams(-1, -2)
            hint_lp.topMargin = dp(2); hint_lp.bottomMargin = dp(6)
            hint_tv = TV(ctx)
            hint_tv.setText("Long-press a key row to copy Theme.getColor() call")
            hint_tv.setTextColor(_s32(0xFF445566))
            hint_tv.setTextSize(1, 9.5)
            body.addView(hint_tv, hint_lp)

            # Each section
            last_pattern = None
            for pattern, section_name, keys in ti:

                # Pattern header (only when pattern changes)
                if pattern != last_pattern:
                    last_pattern = pattern
                    body.addView(mk_sep())
                    p_tv = TV(ctx)
                    p_tv.setText(f"  {pattern}")
                    p_tv.setTextColor(_s32(C["PARENT"]))
                    p_tv.setTextSize(1, 9.0)
                    body.addView(p_tv, LL.LayoutParams(-1, -2))

                # Section name (= Telegram theme editor section)
                sec_row = LL(ctx)
                sec_row.setOrientation(LL.HORIZONTAL)
                sec_row.setGravity(Gravity.CENTER_VERTICAL)
                sec_row.setPadding(0, dp(4), 0, dp(2))

                sec_bd = GD()
                sec_bd.setColor(_s32(0x201A0A00))
                sec_bd.setCornerRadius(float(dp(3)))
                sec_tv = TV(ctx)
                sec_tv.setText(section_name)
                sec_tv.setTextColor(_s32(C["TH_SEC"]))
                sec_tv.setTextSize(1, 10.5)
                try:
                    sec_tv.setTypeface(AndroidUtilities.getTypeface(
                        AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
                except Exception: pass
                sec_row.addView(sec_tv, LL.LayoutParams(0, -2, 1.0))
                body.addView(sec_row, LL.LayoutParams(-1, -2))

                # Keys with live color swatch
                for key in keys:
                    key_row = LL(ctx)
                    key_row.setOrientation(LL.HORIZONTAL)
                    key_row.setGravity(Gravity.CENTER_VERTICAL)
                    key_row.setPadding(dp(4), dp(3), 0, dp(3))

                    # Color swatch — live value from Theme.getColor()
                    hex_str = ""
                    try:
                        color_val = _get_tg_color(key)
                        if color_val is not None:
                            hex_str = _int_to_hex(color_val)
                            sw_d = GD()
                            sw_d.setColor(color_val)
                            sw_d.setCornerRadius(float(dp(3)))
                            sw_d.setStroke(dp(1.0), _s32(0xFF333333))
                            sw = V(ctx)
                            sw.setBackground(sw_d)
                            sw_lp = LL.LayoutParams(dp(16.0), dp(16.0))
                            sw_lp.rightMargin = dp(8)
                            key_row.addView(sw, sw_lp)
                    except Exception: pass

                    key_tv = TV(ctx)
                    key_tv.setText(key)
                    key_tv.setTextColor(_s32(C["TH_KEY"]))
                    key_tv.setTextSize(1, 11.5)
                    try:
                        Tf = fc("android.graphics.Typeface")
                        key_tv.setTypeface(Tf.MONOSPACE)
                    except Exception: pass
                    try: key_tv.setTextIsSelectable(True)
                    except Exception: pass
                    key_row.addView(key_tv, LL.LayoutParams(0, -2, 1.0))

                    if hex_str:
                        hex_tv = TV(ctx)
                        hex_tv.setText(hex_str)
                        hex_tv.setTextColor(_s32(C["TH_HEX"]))
                        hex_tv.setTextSize(1, 9.5)
                        try:
                            Tf = fc("android.graphics.Typeface")
                            hex_tv.setTypeface(Tf.MONOSPACE)
                        except Exception: pass
                        hex_lp = LL.LayoutParams(-2, -2)
                        hex_lp.leftMargin = dp(6)
                        key_row.addView(hex_tv, hex_lp)

                    # Long-press → copy Theme.getColor("key")
                    try:
                        class _KL(dynamic_proxy(OnLCL)):
                            def __init__(self, k):
                                super().__init__()
                                self._k = k
                            def onLongClick(self_t, v2):
                                ok = _clipboard(ctx, f'Theme.getColor("{self_t._k}")')
                                BulletinHelper.show_info("Copied!" if ok else "Error")
                                return True
                        key_row.setLongClickable(True)
                        key_row.setOnLongClickListener(_KL(key))
                    except Exception: pass

                    body.addView(key_row, LL.LayoutParams(-1, -2))

            # Copy-all button
            body.addView(mk_sep())
            plugin = self
            copy_all = TV(ctx)
            copy_all.setText("Copy all as Theme.getColor() calls")
            copy_all.setTextColor(_s32(C["ACCENT"]))
            copy_all.setTextSize(1, 11.0)
            copy_all.setGravity(Gravity.CENTER)
            copy_all.setPadding(dp(10), dp(7), dp(10), dp(7))
            gd_ca = GD()
            gd_ca.setColor(_s32(C["BTN_BG"]))
            gd_ca.setCornerRadius(float(dp(8)))
            gd_ca.setStroke(dp(1.0), _s32(C["ACCENT"]))
            copy_all.setBackground(gd_ca)
            copy_all.setClickable(True); copy_all.setFocusable(True)
            def _copy_all_keys(v):
                lines = []
                for _, sec, keys in plugin._current_theme_info:
                    lines.append(f"// {sec}")
                    for k in keys:
                        lines.append(f'Theme.getColor("{k}")')
                ok = _clipboard(ctx, "\n".join(lines))
                n  = sum(len(kk) for _, _, kk in plugin._current_theme_info)
                BulletinHelper.show_info(f"Copied {n} keys" if ok else "Error")
            copy_all.setOnClickListener(OnClickListener(_copy_all_keys))
            lp_ca = LL.LayoutParams(-1, -2)
            lp_ca.topMargin = dp(4)
            body.addView(copy_all, lp_ca)

        except Exception as e:
            log(f"{TAG} _fill_theme_tab: {e}\n{traceback.format_exc()}")

    # ── [2] MONITOR TAB ──────────────────────────────────────────────────────

    def _fill_monitor(self):
        try:
            body = self._body_ll
            dp   = self._dp
            LL   = self._LL
            TV   = self._TV
            V    = self._V
            ctx  = self._ctx
            fc   = self._fc
            C    = self._C
            body.removeAllViews()

            Gravity = fc("android.view.Gravity")
            GD      = fc("android.graphics.drawable.GradientDrawable")

            hdr_tv = TV(ctx)
            hdr_tv.setText(f"LIVE MONITOR  (last {MAX_MONITOR} events)")
            hdr_tv.setTextColor(_s32(C["HOOK_IC"]))
            hdr_tv.setTextSize(1, 10.0)
            body.addView(hdr_tv, LL.LayoutParams(-1, -2))

            exp_btn = TV(ctx)
            exp_btn.setText("Export log to file")
            exp_btn.setTextSize(1, 10.5)
            exp_btn.setTextColor(_s32(C["ATTR_TX"]))
            exp_btn.setGravity(Gravity.CENTER)
            exp_btn.setPadding(dp(8), dp(4), dp(8), dp(4))
            gd_e = GD()
            gd_e.setColor(_s32(C["BTN_BG"]))
            gd_e.setCornerRadius(float(dp(8)))
            exp_btn.setBackground(gd_e)
            exp_btn.setClickable(True); exp_btn.setFocusable(True)
            plugin = self
            def _exp_mon(v):
                try:
                    ts   = time.strftime("%Y%m%d_%H%M%S")
                    path = f"{EXPORT_DIR}/monitor_{ts}.txt"
                    ok   = _write_file(path, "\n".join(plugin._monitor_log))
                    BulletinHelper.show_success(f"Saved: {path}" if ok else "Failed")
                except Exception as e2: BulletinHelper.show_error(f"Export: {e2}")
            exp_btn.setOnClickListener(OnClickListener(_exp_mon))
            lp_e = LL.LayoutParams(-2, -2)
            lp_e.topMargin = dp(6); lp_e.bottomMargin = dp(6)
            body.addView(exp_btn, lp_e)

            dv = V(ctx)
            dv.setBackgroundColor(_s32(C["DIV"]))
            body.addView(dv, LL.LayoutParams(-1, dp(1)))

            if not self._monitor_log:
                t = TV(ctx)
                t.setText("No events yet — tap UI elements...")
                t.setTextColor(_s32(C["PARENT"]))
                t.setTextSize(1, 11.5)
                lp_t = LL.LayoutParams(-1, -2)
                lp_t.topMargin = dp(6)
                body.addView(t, lp_t)
                return

            for entry in self._monitor_log:
                t = TV(ctx)
                t.setText(entry)
                t.setTextColor(_s32(C["MON_TX"]))
                t.setTextSize(1, 10.5)
                try:
                    Tf = fc("android.graphics.Typeface")
                    t.setTypeface(Tf.MONOSPACE)
                except Exception: pass
                lp = LL.LayoutParams(-1, -2)
                lp.bottomMargin = dp(1)
                body.addView(t, lp)

        except Exception as e:
            log(f"{TAG} _fill_monitor: {e}")

    def _refresh_monitor_view(self):
        if self.panel_open and self._tab_idx == 2:
            self._fill_monitor()

    # ── [3] DB SEARCH TAB ────────────────────────────────────────────────────

    def _fill_db_search(self):
        try:
            body = self._body_ll
            dp   = self._dp
            LL   = self._LL
            TV   = self._TV
            ctx  = self._ctx
            fc   = self._fc
            C    = self._C
            body.removeAllViews()

            Gravity_cls  = fc("android.view.Gravity")
            GD           = fc("android.graphics.drawable.GradientDrawable")
            LayoutParams = fc("android.view.WindowManager$LayoutParams")
            EditText     = fc("android.widget.EditText")
            OnLCL        = fc("android.view.View$OnLongClickListener")

            hdr_t = TV(ctx)
            hdr_t.setText("Search Hooks + Theme Keys by class name")
            hdr_t.setTextColor(_s32(C["HOOK_IC"]))
            hdr_t.setTextSize(1, 10.0)
            body.addView(hdr_t, LL.LayoutParams(-1, -2))

            keys_tv = TV(ctx)
            keys_tv.setText("Hook DB keys: " + ", ".join(sorted(HOOK_DB.keys())))
            keys_tv.setTextColor(_s32(C["MON_TS"]))
            keys_tv.setTextSize(1, 9.0)
            keys_tv.setMaxLines(3)
            lp_k = LL.LayoutParams(-1, -2)
            lp_k.topMargin = dp(4); lp_k.bottomMargin = dp(6)
            body.addView(keys_tv, lp_k)

            search_row = LL(ctx)
            search_row.setOrientation(LL.HORIZONTAL)
            search_row.setGravity(Gravity_cls.CENTER_VERTICAL)

            db_et = EditText(ctx)
            db_et.setHint("e.g. chatmessagecell or dialogs")
            db_et.setTextSize(1, 11.0)
            db_et.setTextColor(_s32(C["INPUT_TX"]))
            try: db_et.setHintTextColor(_s32(0xFF556677))
            except Exception: pass
            gd_d = GD()
            gd_d.setColor(_s32(C["INPUT_BG"]))
            gd_d.setCornerRadius(float(dp(8)))
            db_et.setBackground(gd_d)
            db_et.setPadding(dp(8), dp(4), dp(8), dp(4))
            db_et.setSingleLine(True)
            search_row.addView(db_et, LL.LayoutParams(0, -2, 1.0))

            plugin = self
            try:
                FCL = fc("android.view.View$OnFocusChangeListener")
                class _DBFocus(dynamic_proxy(FCL)):
                    def __init__(self): super().__init__()
                    def onFocusChange(self_t, v, has_focus):
                        try:
                            lp2 = plugin.panel_view.getLayoutParams()
                            if has_focus:
                                lp2.flags &= ~LayoutParams.FLAG_NOT_FOCUSABLE
                                lp2.softInputMode = LayoutParams.SOFT_INPUT_ADJUST_RESIZE
                            else:
                                lp2.flags |= LayoutParams.FLAG_NOT_FOCUSABLE
                                lp2.softInputMode = 0
                            if plugin.wm and plugin.panel_view:
                                plugin.wm.updateViewLayout(plugin.panel_view, lp2)
                        except Exception: pass
                db_et.setOnFocusChangeListener(_DBFocus())
            except Exception: pass

            result_ll = LL(ctx)
            result_ll.setOrientation(LL.VERTICAL)
            result_ll.setPadding(0, dp(6), 0, 0)

            def _do_search(v):
                try:
                    q = str(db_et.getText()).strip().lower()
                    try:
                        imm = ctx.getSystemService("input_method")
                        imm.hideSoftInputFromWindow(db_et.getWindowToken(), 0)
                        db_et.clearFocus()
                    except Exception: pass
                    result_ll.removeAllViews()
                    if not q:
                        return

                    # Search HOOK_DB
                    hook_found = []
                    for key, hs in HOOK_DB.items():
                        if q in key:
                            hook_found.extend(hs)

                    # Search THEME_KEY_DB — collect (section, [keys])
                    theme_found = []
                    for key, sections in THEME_KEY_DB.items():
                        if q in key:
                            for sec_name, keys in sections:
                                theme_found.append((sec_name, keys))

                    if not hook_found and not theme_found:
                        t = TV(ctx)
                        t.setText(f"Nothing found for '{q}'")
                        t.setTextColor(_s32(C["PARENT"]))
                        t.setTextSize(1, 11.0)
                        result_ll.addView(t, LL.LayoutParams(-1, -2))
                        return

                    if hook_found:
                        hh = TV(ctx)
                        hh.setText(f"Hooks ({len(hook_found)}):")
                        hh.setTextColor(_s32(C["HOOK_IC"]))
                        hh.setTextSize(1, 10.5)
                        result_ll.addView(hh, LL.LayoutParams(-1, -2))
                        for h in hook_found:
                            ht = TV(ctx)
                            ht.setText("> " + h)
                            ht.setTextColor(_s32(C["HOOK_TX"]))
                            ht.setTextSize(1, 11.0)
                            ht.setMaxLines(2)
                            try: ht.setTextIsSelectable(True)
                            except Exception: pass
                            try:
                                class _HL(dynamic_proxy(OnLCL)):
                                    def __init__(self, hs2):
                                        super().__init__()
                                        self._h = hs2
                                    def onLongClick(self_t, v2):
                                        ok = _clipboard(ctx, self_t._h)
                                        BulletinHelper.show_info("Copied" if ok else "Error")
                                        return True
                                ht.setLongClickable(True)
                                ht.setOnLongClickListener(_HL(h))
                            except Exception: pass
                            lp_h = LL.LayoutParams(-1, -2)
                            lp_h.bottomMargin = dp(1)
                            result_ll.addView(ht, lp_h)

                    if theme_found:
                        n_tk = sum(len(ks) for _, ks in theme_found)
                        th = TV(ctx)
                        th.setText(f"\nTheme keys ({n_tk} in {len(theme_found)} sections):")
                        th.setTextColor(_s32(C["TH_SEC"]))
                        th.setTextSize(1, 10.5)
                        result_ll.addView(th, LL.LayoutParams(-1, -2))
                        for sec_name, keys in theme_found:
                            sn = TV(ctx)
                            sn.setText(f"  [{sec_name}]")
                            sn.setTextColor(_s32(C["TH_SEC"]))
                            sn.setTextSize(1, 10.5)
                            lp_sn = LL.LayoutParams(-1, -2)
                            lp_sn.topMargin = dp(4)
                            result_ll.addView(sn, lp_sn)
                            for k in keys:
                                kt = TV(ctx)
                                kt.setText("    " + k)
                                kt.setTextColor(_s32(C["TH_KEY"]))
                                kt.setTextSize(1, 11.0)
                                try: kt.setTextIsSelectable(True)
                                except Exception: pass
                                try:
                                    class _KL(dynamic_proxy(OnLCL)):
                                        def __init__(self, kk):
                                            super().__init__()
                                            self._k = kk
                                        def onLongClick(self_t, v2):
                                            ok = _clipboard(ctx, f'Theme.getColor("{self_t._k}")')
                                            BulletinHelper.show_info("Copied" if ok else "Error")
                                            return True
                                    kt.setLongClickable(True)
                                    kt.setOnLongClickListener(_KL(k))
                                except Exception: pass
                                lp_k2 = LL.LayoutParams(-1, -2)
                                lp_k2.bottomMargin = dp(1)
                                result_ll.addView(kt, lp_k2)

                except Exception as e2: log(f"{TAG} db_search: {e2}")

            go_btn = TV(ctx)
            go_btn.setText("Go")
            go_btn.setTextColor(_s32(C["BTN_TX"]))
            go_btn.setTextSize(1, 11.0)
            go_btn.setGravity(Gravity_cls.CENTER)
            go_btn.setPadding(dp(10), dp(4), dp(10), dp(4))
            gd_go = GD()
            gd_go.setColor(_s32(C["BTN_BG"]))
            gd_go.setCornerRadius(float(dp(8)))
            go_btn.setBackground(gd_go)
            go_btn.setClickable(True); go_btn.setFocusable(True)
            go_btn.setOnClickListener(OnClickListener(_do_search))
            sb_lp = LL.LayoutParams(-2, -2)
            sb_lp.leftMargin = dp(6)
            search_row.addView(go_btn, sb_lp)

            body.addView(search_row, LL.LayoutParams(-1, -2))
            body.addView(result_ll,  LL.LayoutParams(-1, -2))

        except Exception as e:
            log(f"{TAG} _fill_db_search: {e}\n{traceback.format_exc()}")

    # ── Helpers ───────────────────────────────────────────────────────────────

    def _update_title(self, chain):
        try:
            if self._title_tv:
                self._title_tv.setText(_simple(chain[0]) if chain else "Hook Inspector")
        except Exception: pass

    def _plain_text(self) -> str:
        chain = self._current_chain
        hooks = self._current_hooks
        attrs = self._current_attrs
        ti    = self._current_theme_info
        lines = [
            "Hook Inspector v11  |  @rei_plugins",
            "=" * 40,
            f"Class: {chain[0] if chain else '?'}",
        ]
        res = attrs.get("res_id", "")
        if res: lines.append(f"ResID: @id/{res}")
        if attrs:
            w = attrs.get("w"); h = attrs.get("h")
            if w and h: lines.append(f"Size: {w}x{h} px")
            for k in ("vis", "enabled", "clickable", "focused", "bg_color", "text_color"):
                if k in attrs: lines.append(f"{k}: {attrs[k]}")
        if len(chain) > 1:
            lines.append("Parents:")
            for i, c in enumerate(chain[1:], 1):
                lines.append("  " * i + "- " + c)
        if hooks:
            lines.append(f"\nHooks ({len(hooks)}):")
            for hk in hooks: lines.append(f"* {hk}")
        if ti:
            n_total = sum(len(kk) for _, _, kk in ti)
            lines.append(f"\nTheme Keys ({n_total}):")
            for _, sec, keys in ti:
                lines.append(f"  // {sec}")
                for k in keys:
                    lines.append(f'  Theme.getColor("{k}")')
        lines.append("\n@rei_plugins | @lyzos")
        return "\n".join(lines)

    def _destroy_all(self):
        for view in [self.panel_view, self.bubble_view]:
            try:
                if view and self.wm:
                    self.wm.removeView(view)
            except Exception: pass
        self.panel_view     = None
        self.panel_open     = False
        self.bubble_view    = None
        self.bubble_open    = False
        self._bubble_silent = False
        self.wm             = None
        self._ctx           = None

    # ── Settings ───────────────────────────────────────────────────────────────

    def _on_inspector_toggle(self, enabled: bool):
        if not enabled:
            run_on_ui_thread(self._destroy_all)

    def _open_tg(self, username: str):
        try:
            AppLoader  = find_class("org.telegram.messenger.ApplicationLoader")
            Intent_cls = find_class("android.content.Intent")
            Uri_cls    = find_class("android.net.Uri")
            ctx        = AppLoader.applicationContext
            it = Intent_cls(Intent_cls.ACTION_VIEW,
                            Uri_cls.parse(f"https://t.me/{username}"))
            it.addFlags(Intent_cls.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(it)
        except Exception as e:
            log(f"{TAG} open_tg: {e}")

    def _reset_pos(self, v):
        for k in ["pos_x", "pos_y", "width_dp", "height_dp", "bub_x", "bub_y"]:
            self.set_setting(k, 0)
        self._px = self._py = self._pw = self._ph = 0
        self._bx = 20; self._by = 200
        BulletinHelper.show_success("Position reset")

    def _run_diagnostics(self, v=None):
        """Запустить диагностику — результат пишется в _DEBUG_BUF, потом открывается Log-панель."""
        try:
            _dlog(self, "=== DIAGNOSTICS START ===")
            _dlog(self, f"inspector_enabled={self.get_setting('inspector_enabled', False)}")
            _dlog(self, f"debug_mode={self.get_setting('debug_mode', False)}")
            _dlog(self, f"hierarchy_depth={self.get_setting('hierarchy_depth', 1)}")
            _dlog(self, f"show_only_known={self.get_setting('show_only_known', False)}")
            _dlog(self, f"panel_open={self.panel_open} bubble_open={self.bubble_open}")
            _dlog(self, f"_fire_lock exists={hasattr(self, '_fire_lock')}")
            _dlog(self, f"_last_fire_ms={getattr(self, '_last_fire_ms', 'NOT SET')}")
            _dlog(self, f"wm={self.wm is not None} _ctx={self._ctx is not None}")

            # Проверяем критичные классы через find_class
            checks = [
                ("android.view.View",                        "View"),
                ("android.view.MotionEvent",                 "MotionEvent"),
                ("org.telegram.ui.ActionBar.Theme",          "Telegram Theme"),
                ("org.telegram.messenger.ApplicationLoader", "ApplicationLoader"),
                ("android.os.Build",                         "Build"),
                ("android.provider.Settings",                "Settings"),
                ("android.view.WindowManager$LayoutParams",  "WM LayoutParams"),
            ]
            for cls_name, label in checks:
                try:
                    cls = find_class(cls_name)
                    _dlog(self, f"[OK] {label}: {cls}")
                except Exception as e:
                    _dlog(self, f"[FAIL] {label}: {e}")

            # Overlay permission
            try:
                AppLoader = find_class("org.telegram.messenger.ApplicationLoader")
                ctx = AppLoader.applicationContext
                Build = find_class("android.os.Build")
                Settings = find_class("android.provider.Settings")
                sdk = Build.VERSION.SDK_INT
                if sdk >= 23:
                    can = Settings.canDrawOverlays(ctx)
                    if can:
                        _dlog(self, f"[OK] canDrawOverlays SDK={sdk}")
                    else:
                        _dlog(self, f"[FAIL] canDrawOverlays=False SDK={sdk} — overlay НЕ работает!")
                else:
                    _dlog(self, f"[OK] SDK={sdk} < 23 — overlay разрешение не нужно")
            except Exception as e:
                _dlog(self, f"[FAIL] overlay check: {e}")

            _dlog(self, "=== DIAGNOSTICS END ===")
            BulletinHelper.show_info("Diagnostics done — открой вкладку Log")

        except Exception as e:
            _dlog(self, f"[CRITICAL] _run_diagnostics: {e}")
            log(f"{TAG} diagnostics: {e}\n{traceback.format_exc()}")

    def _show_debug_log(self, v=None):
        """Открыть Log-вкладку в overlay-панели."""
        run_on_ui_thread(self._open_log_panel)

    def _on_debug_toggle(self, enabled: bool):
        if enabled:
            BulletinHelper.show_info("Debug mode ON — логи в logcat [HI]")
            _dlog(self, "debug_mode enabled by user")
        else:
            BulletinHelper.show_info("Debug mode OFF")

    def create_settings(self) -> list:
        enabled    = self.get_setting("inspector_enabled", False)
        debug      = self.get_setting("debug_mode", False)
        n_hook_cls = len(HOOK_DB)
        n_hook_tot = sum(len(v) for v in HOOK_DB.values())
        n_th_cls   = len(THEME_KEY_DB)
        n_th_tot   = sum(len(k) for secs in THEME_KEY_DB.values() for _, k in secs)
        status     = "ON — тапай любой элемент" if enabled else "OFF"
        dbg_buf    = len(_DEBUG_BUF)
        return [
            Header(text="Hook Inspector v12"),
            Switch(
                key="inspector_enabled",
                text="Inspector mode",
                default=False,
                subtext="Тапни UI-элемент — класс, ключи темы, хуки.",
                icon="msg_search",
                on_change=self._on_inspector_toggle,
                link_alias="inspector_toggle",
            ),
            Text(text=status, icon="msg_info", accent=enabled),
            Divider(),
            Header(text="Options"),
            Selector(
                key="hierarchy_depth",
                text="Hierarchy depth",
                default=1,
                items=["3 levels", "5 levels (recommended)", "10 levels"],
                icon="msg_forward",
                link_alias="hierarchy_depth",
            ),
            Switch(
                key="show_only_known",
                text="Skip unknown classes",
                default=False,
                subtext="Не открывать панель если класс не в базе.",
                icon="msg_filter",
                link_alias="skip_unknown",
            ),
            Selector(
                key="panel_theme",
                text="Panel theme",
                default=0,
                items=["Dark (default)", "Light"],
                icon="msg_theme",
                link_alias="panel_theme",
            ),
            Text(
                text="Reset panel position and size",
                icon="msg_retract",
                on_click=self._reset_pos,
                red=True,
            ),
            Divider(),
            Header(text="Debug"),
            Switch(
                key="debug_mode",
                text="Debug mode",
                default=False,
                subtext="Подробные логи в logcat (тег [HI]). Нужен adb logcat или DevCheck.",
                icon="msg_info",
                on_change=self._on_debug_toggle,
                link_alias="debug_mode",
            ),
            Text(
                text=f"Open Log Panel  ({dbg_buf} entries)",
                icon="msg_search",
                accent=True,
                on_click=self._show_debug_log,
            ),
            Text(
                text="Run Diagnostics (writes to Log)",
                icon="msg_info",
                on_click=self._run_diagnostics,
            ),
            Text(
                text="Logcat tag: [HI]  |  adb logcat | grep [HI]",
                icon="msg_info",
            ),
            Divider(),
            Header(text="Database"),
            Text(
                text=f"Hooks: {n_hook_cls} classes  |  {n_hook_tot} suggestions",
                icon="msg_info",
            ),
            Text(
                text=f"Theme keys: {n_th_cls} classes  |  {n_th_tot} keys",
                icon="msg_theme",
            ),
            Divider(),
            Header(text="About"),
            Text(
                text="Channel: @rei_plugins",
                icon="msg_channel",
                accent=True,
                on_click=lambda v: self._open_tg("rei_plugins"),
                link_alias="channel_link",
            ),
            Text(
                text="Author: @lyzos",
                icon="msg_contact",
                accent=True,
                on_click=lambda v: self._open_tg("lyzos"),
                link_alias="author_link",
            ),
            Divider(text=f"Hook Inspector v12.0.0  |  {n_hook_cls} classes  |  @rei_plugins"),
        ]



# ─────────────────────────────────────────────────────────────────────────────
#  HOOKS
# ─────────────────────────────────────────────────────────────────────────────



# ─────────────────────────────────────────────────────────────────────────────
#  HOOK CLASSES
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
#  HOOK CLASSES
#  Важно: в Chaquopy (ExteraGram plugin runtime) hook на базовый View работает
#  через V.getClass().getDeclaredMethod(), а НЕ V.getDeclaredMethod().
#  find_class() возвращает Python-обёртку; getClass() даёт java.lang.Class.
# ─────────────────────────────────────────────────────────────────────────────

def _fire_view(plugin, view, is_long: bool):
    """Общая точка входа — вызывается из всех хук-классов."""
    try:
        now = time.time() * 1000.0
        vid = 0
        try: vid = id(view)
        except Exception: pass
        lock = getattr(plugin, "_fire_lock", None)
        if lock is None:
            return False
        debounce = 600 if is_long else 400
        with lock:
            lms = getattr(plugin, "_last_fire_ms", 0.0)
            lid = getattr(plugin, "_last_fire_id", 0)
            if now - lms < debounce and vid == lid:
                return False
            plugin._last_fire_ms = now
            plugin._last_fire_id = vid
        run_on_ui_thread(lambda: plugin.on_view_clicked(view, is_long=is_long))
        return True
    except Exception as e:
        log(f"{TAG} _fire_view: {e}")
        return False


class _ClickHook(MethodHook):
    """
    Hook performClick() — обычные кнопки с OnClickListener.
    before_hooked_method: срабатывает ДО performClick, что безопасно.
    """
    def __init__(self, plugin):
        self._plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self._plugin.get_setting("inspector_enabled", False):
                return
            view = param.thisObject
            if view is not None and not self._plugin._is_own_view(view):
                _fire_view(self._plugin, view, False)
        except Exception as e:
            log(f"{TAG} click_hook: {e}")


class _LongClickHook(MethodHook):
    """
    Hook performLongClick() — лонг-тап.
    """
    def __init__(self, plugin):
        self._plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self._plugin.get_setting("inspector_enabled", False):
                return
            view = param.thisObject
            if view is not None and not self._plugin._is_own_view(view):
                _fire_view(self._plugin, view, True)
        except Exception as e:
            log(f"{TAG} longclick_hook: {e}")


class _DispatchTouchHook(MethodHook):
    """
    Hook View.dispatchTouchEvent(MotionEvent) — ловит ВСЁ что не через performClick:
    кнопка отправки (SendButton), canvas-кнопки, медиа-кнопки, ImageView, и т.д.

    Используем after_hooked_method чтобы знать что view вернул true
    (потребил событие). Фильтр: ACTION_UP (=1) — только завершение тапа.
    Если getResult() недоступен — используем before как fallback.
    """
    def __init__(self, plugin):
        self._plugin = plugin
        self._pending_views = {}  # vid -> view, для ACTION_DOWN -> ACTION_UP матчинга

    def before_hooked_method(self, param):
        """Запоминаем view на ACTION_DOWN для fallback если after не сработает."""
        try:
            if not self._plugin.get_setting("inspector_enabled", False):
                return
            ev = param.args[0] if param.args else None
            if ev is None:
                return
            action = ev.getAction() & 0xFF
            if action != 0:  # ACTION_DOWN = 0
                return
            view = param.thisObject
            if view is None:
                return
            vid = 0
            try: vid = id(view)
            except Exception: pass
            self._pending_views[vid] = view
            # Ограничиваем размер pending dict
            if len(self._pending_views) > 20:
                oldest = next(iter(self._pending_views))
                del self._pending_views[oldest]
        except Exception:
            pass

    def after_hooked_method(self, param):
        try:
            if not self._plugin.get_setting("inspector_enabled", False):
                return
            ev = param.args[0] if param.args else None
            if ev is None:
                return
            action = ev.getAction() & 0xFF
            if action != 1:  # ACTION_UP = 1
                return

            view = param.thisObject
            if view is None:
                return

            # Проверяем что view потребил событие (вернул true)
            consumed = False
            try:
                result = param.getResult()
                consumed = bool(result)
            except Exception:
                # getResult() не всегда доступен — проверяем через pending
                vid = 0
                try: vid = id(view)
                except Exception: pass
                consumed = vid in self._pending_views

            if not consumed:
                return

            # Чистим pending
            try:
                vid = id(view)
                self._pending_views.pop(vid, None)
            except Exception:
                pass

            # Не реагируем на собственные view панели
            if self._plugin._is_own_view(view):
                return
            _fire_view(self._plugin, view, False)

        except Exception as e:
            log(f"{TAG} dispatch_touch_hook: {e}")
