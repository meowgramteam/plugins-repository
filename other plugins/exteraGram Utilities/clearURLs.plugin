class URLCleaner:
    def __init__(self):
        self.universal_rules: List[re.Pattern] = []
        self.host_rules: Dict[re.Pattern, List[re.Pattern]] = {}
        self._compile_rules()

    @staticmethod
    def _escape(text: str) -> str:
        return re.escape(text).replace(r'\*', '.+?')

    def _compile_rules(self):
        for rule in DEFAULT_RULES:
            if '@' not in rule:
                self.universal_rules.append(re.compile(f"^{self._escape(rule)}$"))
            else:
                param, host = rule.split('@', 1)
                param_regex = re.compile(f"^{self._escape(param)}$")

                host_regex_str = f"^{self._escape(host)}$".replace(r'\.\*', '.*')
                host_regex = re.compile(host_regex_str)

                if host_regex not in self.host_rules:
                    self.host_rules[host_regex] = []
                self.host_rules[host_regex].append(param_regex)

    def _should_remove(self, param: str, hostname: str) -> bool:
        if any(r.match(param) for r in self.universal_rules):
            return True

        for host_regex, param_list in self.host_rules.items():
            if host_regex.match(hostname):
                if any(p.match(param) for p in param_list):
                    return True
        return False

    def clean_url(self, url: str) -> str:
        try:
            parsed = urlparse(url)
        except Exception:
            return url

        hostname = parsed.hostname or ""

        query_params = parse_qsl(parsed.query, keep_blank_values=True)
        cleaned_params = [
            (k, v) for k, v in query_params
            if not self._should_remove(k, hostname)
        ]

        new_netloc = parsed.netloc
        new_path = parsed.path
        new_query = urlencode(cleaned_params)

        if hostname in ("www.youtube.com", "youtube.com"):
            params_dict = dict(cleaned_params)
            if parsed.path.startswith("/watch") and "v" in params_dict:
                video_id = params_dict["v"]
                if video_id:
                    new_netloc = "youtu.be"
                    new_path = f"/{video_id}"
                    cleaned_params = [(k, v) for k, v in cleaned_params if k != "v"]
                    new_query = urlencode(cleaned_params)

        cleaned = parsed._replace(
            netloc=new_netloc,
            path=new_path,
            query=new_query,
            fragment=""
        )
        return urlunparse(cleaned).rstrip("/")

    def process_message(self, message: str) -> str:
        return re.sub(
            r'https?://[^\s<]+[^<.,:;"\')\]\s]',
            lambda m: self.clean_url(m.group(0)),
            message
        )


