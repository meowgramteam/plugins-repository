logger = zwylib.build_log(__name__)
bulletin = zwylib.build_bulletin_helper()

cleaner = URLCleaner()


class ClearURLs(BasePlugin):
    def on_plugin_load(self):
        zwylib.add_autoupdater_task(AU_CHANNEL_ID, AU_MSG_ID)
        self.add_on_send_message_hook()
        logger.info("Loaded.")

    def on_plugin_unload(self):
        logger.info("Unloaded.")

    def on_send_message_hook(self, account, params):
        if not params.message:
            return HookResult()

        if not re.search(r'http(s)?://', params.message):
            return HookResult()

        params.message = cleaner.process_message(params.message)
        return HookResult(strategy=HookStrategy.MODIFY, params=params)
